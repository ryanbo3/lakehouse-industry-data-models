# --- Attribute Properties ---
ind:cltvRecordId rdf:type rdf:Property ;
    rdfs:label 'Cltv Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each Customer Lifetime Value (CLTV) record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Reference to the loyalty program in which this consumer is enrolled at the time of CLTV calculation. Loyalty membership status is a key behavioral modifier in CLTV model inputs.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:shopperId rdf:type rdf:Property ;
    rdfs:label 'Shopper Id' ;
    rdfs:comment 'Reference to the consumer profile for whom this CLTV record is calculated. Links to the SSOT consumer master in the Consumer domain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:aov rdf:type rdf:Property ;
    rdfs:label 'Aov' ;
    rdfs:comment 'Average net revenue per transaction for this consumer, calculated over the historical observation window used in the CLTV model. Key behavioral input metric reflecting per-transaction spending level.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The business date on which this CLTV record was computed. Used to track the temporal snapshot of the consumer\'s economic value and to support trend analysis over time.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Lifecycle status of this CLTV record indicating whether the calculation completed successfully, is pending, failed validation, or has been superseded by a newer calculation for the same consumer.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnProbability rdf:type rdf:Property ;
    rdfs:label 'Churn Probability' ;
    rdfs:comment 'Model-estimated probability (0.0000–1.0000) that this consumer will cease purchasing within the next 12 months. Used to identify at-risk consumers for retention campaigns and to discount future revenue predictions.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'The composite CLTV monetary value representing the net present value of all future cash flows attributed to this consumer relationship, as computed by the CLTV model. Primary metric for consumer investment prioritization.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'Categorical tier classifying the consumer\'s economic value relative to the overall consumer base. Used for investment prioritization, personalized engagement strategy, and resource allocation across CRM and trade promotion programs.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current consent status of the consumer for use of their personal data in CLTV modeling and personalized engagement. Ensures CLTV-driven activation complies with GDPR and CCPA consent requirements.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerTenureDays rdf:type rdf:Property ;
    rdfs:label 'Consumer Tenure Days' ;
    rdfs:comment 'Number of days between the consumer\'s first purchase date and the CLTV calculation date. Represents the length of the consumer relationship and is used to normalize lifetime revenue metrics.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this CLTV record was first written to the Silver Layer. Provides the audit trail creation anchor for data lineage and compliance purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which all monetary CLTV values (historical revenue, predicted revenue, AOV, CLTV score) are expressed. Supports multi-currency consumer bases across global markets.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Data Completeness Score' ;
    rdfs:comment 'Score (0.0000–1.0000) reflecting the proportion of required CLTV model input fields that were available and valid for this consumer at calculation time. Supports data quality monitoring and model input auditability.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProcessingBasis rdf:type rdf:Property ;
    rdfs:label 'Data Processing Basis' ;
    rdfs:comment 'Legal basis under GDPR Article 6 for processing this consumer\'s personal data in CLTV calculations. Required for regulatory compliance documentation and data subject rights management.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceLastPurchase rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Purchase' ;
    rdfs:comment 'Number of days elapsed between the consumer\'s last purchase date and the CLTV calculation date. Primary recency metric used in churn probability modeling and re-engagement targeting.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Annual discount rate (0.0000–1.0000) applied in the net present value calculation of future consumer cash flows within the CLTV model. Reflects the time value of money and cost of capital assumptions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'Timestamp from which this CLTV record is considered the current active record for the consumer. Supports slowly changing dimension (SCD) Type 2 history management in the Silver Layer.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Until Timestamp' ;
    rdfs:comment 'Timestamp until which this CLTV record is considered active. Null indicates the current active record. Supports SCD Type 2 history management and point-in-time querying in the Silver Layer.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'Date of the consumer\'s first recorded purchase transaction. Used to calculate consumer tenure, cohort assignment, and to contextualize lifetime revenue figures.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inputDataSummary rdf:type rdf:Property ;
    rdfs:label 'Input Data Summary' ;
    rdfs:comment 'Human-readable summary of the key data sources and input signals used in this CLTV calculation (e.g., POS transactions, loyalty events, NPS surveys). Supports auditability and model explainability for business stakeholders.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the consumer\'s most recent purchase transaction prior to the calculation date. Key recency signal used in churn probability estimation and RFM (Recency, Frequency, Monetary) analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Model Confidence Score' ;
    rdfs:comment 'Statistical confidence score (0.0000–1.0000) assigned by the CLTV model to this record\'s predictions, reflecting data completeness and model certainty. Low-confidence records may be flagged for manual review or excluded from activation.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the CLTV predictive model used to generate this record (e.g., v1.0, v2.3). Enables model governance, reproducibility, and comparison across model iterations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'NPS classification of the consumer based on their most recent NPS score: Promoter (9–10), Passive (7–8), or Detractor (0–6). Used in consumer engagement strategy and churn risk segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) recorded for this consumer at or prior to the calculation date, on a scale of 0–10. Used as a satisfaction and advocacy signal that modulates churn probability and CLTV tier assignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationWindowMonths rdf:type rdf:Property ;
    rdfs:label 'Observation Window Months' ;
    rdfs:comment 'Number of months of historical transaction data used as the lookback period for computing behavioral inputs (AOV, purchase frequency) in this CLTV calculation. Governs the scope of historical data ingested.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether this consumer is eligible for CLTV-driven personalized marketing and engagement activation, based on consent status, suppression flags, and data quality thresholds.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predictedRevenue12m rdf:type rdf:Property ;
    rdfs:label 'Predicted Revenue 12m' ;
    rdfs:comment 'Model-predicted net revenue expected from this consumer over the next 12 months from the calculation date. Core output of the CLTV model used for short-term investment and engagement decisions.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedRevenue24m rdf:type rdf:Property ;
    rdfs:label 'Predicted Revenue 24m' ;
    rdfs:comment 'Model-predicted net revenue expected from this consumer over the next 24 months from the calculation date. Supports medium-term consumer investment planning and loyalty program design.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Prediction Horizon Months' ;
    rdfs:comment 'Number of months into the future for which the CLTV model projects consumer revenue. Defines the forward-looking scope of the CLTV score and predicted revenue fields.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousCltvScore rdf:type rdf:Property ;
    rdfs:label 'Previous Cltv Score' ;
    rdfs:comment 'The CLTV score from the immediately preceding calculation run for this consumer. Enables trend analysis, score movement tracking, and tier transition monitoring over time.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousCltvTier rdf:type rdf:Property ;
    rdfs:label 'Previous Cltv Tier' ;
    rdfs:comment 'The CLTV tier assigned in the immediately preceding calculation run for this consumer. Used to detect tier upgrades or downgrades and trigger corresponding engagement or retention actions.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBrandCode rdf:type rdf:Property ;
    rdfs:label 'Primary Brand Code' ;
    rdfs:comment 'Code identifying the brand with the highest share of this consumer\'s historical spend. Used to align CLTV-driven investment decisions with brand-level marketing and trade promotion strategies.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Category Code' ;
    rdfs:comment 'Code identifying the product category (e.g., personal care, household, health) representing the largest share of this consumer\'s historical spend. Supports category-level personalization and NPD targeting.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant channel through which this consumer makes purchases, as determined over the historical observation window. Supports channel-specific engagement strategy and DTC vs. retail investment decisions. [ENUM-REF-CANDIDATE: dtc|ecommerce|retail|wholesale|loyalty_app|other — promote to reference product if channel taxonomy expands]' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency' ;
    rdfs:comment 'Average number of purchase transactions made by this consumer per year over the historical observation window. Core behavioral driver in the CLTV model alongside AOV and churn probability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenue12mHistorical rdf:type rdf:Property ;
    rdfs:label 'Revenue 12m Historical' ;
    rdfs:comment 'Total net revenue generated by this consumer in the trailing 12-month period prior to the calculation date. Sourced from POS and DTC transaction records. Used as a key input to CLTV model training and validation.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenue24mHistorical rdf:type rdf:Property ;
    rdfs:label 'Revenue 24m Historical' ;
    rdfs:comment 'Total net revenue generated by this consumer in the trailing 24-month period prior to the calculation date. Provides a longer-horizon view of consumer spending behavior for model calibration.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueLifetimeHistorical rdf:type rdf:Property ;
    rdfs:label 'Revenue Lifetime Historical' ;
    rdfs:comment 'Total net revenue generated by this consumer since their first recorded transaction with the business. Represents the full realized economic value of the consumer relationship to date.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the upstream operational system or analytical pipeline that produced this CLTV record (e.g., Salesforce Consumer Goods Cloud, internal ML platform). Supports data lineage and auditability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Change Flag' ;
    rdfs:comment 'Indicates whether this consumer\'s CLTV tier has changed compared to the previous calculation run. Triggers downstream CRM workflows for tier-transition communications and loyalty reward adjustments.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCountLifetime rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Lifetime' ;
    rdfs:comment 'Total number of purchase transactions recorded for this consumer since their first transaction. Used as a behavioral richness indicator and model input for purchase frequency normalization.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this CLTV record in the Silver Layer. Used for incremental processing, data freshness monitoring, and audit trail completeness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer communication preference record in the Consumer Goods lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Reference to the associated legal consent record in the consent_record product. This preference record captures the consumer\'s desired engagement experience; the consent_record captures the legal basis. These are distinct but linked. Null if no formal consent record is linked.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:marketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Id' ;
    rdfs:comment 'Reference to the specific brand for which this communication preference applies. Enables brand-level preference management across a multi-brand Consumer Goods portfolio.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:campaignExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Exclusion Flag' ;
    rdfs:comment 'Indicates whether the consumer has requested exclusion from all campaign-based communications (True) while still receiving transactional messages. Distinct from global opt-out — the consumer remains reachable for order confirmations, recalls, and service messages.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captureTouchpoint rdf:type rdf:Property ;
    rdfs:label 'Capture Touchpoint' ;
    rdfs:comment 'The consumer-facing touchpoint or interaction channel through which this preference was originally captured. Distinct from source_system (which is the back-end system). Used for consumer journey analytics and preference capture optimization. [ENUM-REF-CANDIDATE: website|mobile_app|in_store|call_center|loyalty_enrollment|promotion|qr_code — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'The communication channel to which this preference record applies. Governs how the brand may contact the consumer. Examples include email, SMS, push notification, direct mail, phone, and in-app messaging. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|phone|in_app|whatsapp|social_media — promote to reference product if additional channels are added]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationCategory rdf:type rdf:Property ;
    rdfs:label 'Communication Category' ;
    rdfs:comment 'The category of communication content to which this preference applies. Allows consumers to opt in or out at a granular content level (e.g., opt out of promotional emails but remain opted in for transactional and product recall notifications). [ENUM-REF-CANDIDATE: promotional|transactional|loyalty|product_recall|survey|newsletter|event|regulatory — promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Flag' ;
    rdfs:comment 'Indicates whether a confirmation message has been sent to the consumer acknowledging their preference update (True) or not yet sent (False). Required for double opt-in workflows and regulatory compliance confirmation obligations.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the consumer confirmed their preference (e.g., clicked the confirmation link in a double opt-in email). Null if confirmation has not yet been received or if single opt-in was used. Critical for GDPR double opt-in audit trails.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactTimeZone rdf:type rdf:Property ;
    rdfs:label 'Contact Time Zone' ;
    rdfs:comment 'IANA time zone identifier (e.g., \'America/New_York\', \'Europe/London\') representing the consumer\'s local time zone. Used in conjunction with preferred_time_of_day and preferred_day_of_week to schedule communications at the correct local time.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the consumer\'s country of residence at the time this preference was recorded. Determines applicable regulatory framework (e.g., GDPR for EU, CCPA for California, CASL for Canada) governing this preference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this communication preference record is effective and should be honored by outbound communication systems. Supports time-bound preference management and scheduled preference changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The date until which this communication preference record is effective. Null indicates an open-ended preference with no expiry. Supports time-limited preferences such as seasonal opt-ins or promotional campaign-specific preferences.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGlobalOptOut rdf:type rdf:Property ;
    rdfs:label 'Is Global Opt Out' ;
    rdfs:comment 'Indicates whether this record represents a global opt-out across all channels and brands (True) rather than a channel-specific preference (False). When True, all outbound marketing communications to this consumer must be suppressed regardless of other preference records.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when this communication preference record was most recently modified by the consumer or an authorized system. Critical for GDPR/CCPA audit trails and for determining the most current preference when multiple records exist.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxMessagesPerWeek rdf:type rdf:Property ;
    rdfs:label 'Max Messages Per Week' ;
    rdfs:comment 'Consumer-specified maximum number of non-transactional messages they are willing to receive per week via this channel. A null value indicates no consumer-specified cap. Used by CRM contact frequency management to prevent over-communication.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional context or special instructions related to this communication preference record. May include agent notes from call center interactions, special consumer requests, or escalation context. Not used for automated processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInMethod rdf:type rdf:Property ;
    rdfs:label 'Opt In Method' ;
    rdfs:comment 'The mechanism by which the consumer provided their opt-in or opt-out for this channel. Double opt-in requires email confirmation; single opt-in is a direct checkbox; paper form is a physical sign-up; verbal is a call-center capture; imported is from a legacy or third-party system.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Indicates whether the consumer has opted in (True) or opted out (False) for communications via the specified channel. Distinct from legal consent — this captures the consumer\'s desired engagement experience.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of this communication preference record. \'active\' means the preference is in effect; \'inactive\' means the consumer has deactivated it; \'pending\' means awaiting confirmation; \'suspended\' means temporarily paused.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceVersion rdf:type rdf:Property ;
    rdfs:label 'Preference Version' ;
    rdfs:comment 'Monotonically incrementing version number for this communication preference record. Incremented each time the preference is updated. Supports optimistic concurrency control and preference history reconstruction for audit purposes.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Preferred Day Of Week' ;
    rdfs:comment 'Consumer\'s preferred day of the week for receiving non-transactional communications such as newsletters, promotions, and product updates. Supports send-time optimization in CRM and marketing automation platforms. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFrequency rdf:type rdf:Property ;
    rdfs:label 'Preferred Frequency' ;
    rdfs:comment 'Consumer\'s preferred frequency for receiving communications via this channel. \'transactional_only\' means the consumer only wants order confirmations, shipping updates, and similar transactional messages. Used by CRM and marketing automation to throttle outbound contact.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 alpha-2 country subtag, e.g., \'en-US\', \'fr-FR\') representing the consumer\'s preferred language for all communications via this channel. Drives content localization in CRM and personalization engines.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimeOfDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Of Day' ;
    rdfs:comment 'Consumer\'s preferred time window for receiving communications. Used by marketing automation and CRM to schedule outbound messages at the consumer\'s preferred time, improving engagement rates.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryPreference rdf:type rdf:Property ;
    rdfs:label 'Product Category Preference' ;
    rdfs:comment 'Consumer-specified product category or categories for which they wish to receive communications (e.g., \'personal_care\', \'household_cleaning\', \'health_nutrition\'). Free-text or comma-separated category codes aligned to the Consumer Goods product taxonomy. Null means no category restriction.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The primary privacy and data protection regulatory framework governing this communication preference record, determined by the consumer\'s country of residence. Drives compliance workflows and audit requirements. Examples: GDPR (EU), CCPA (California), CASL (Canada), PDPA (Thailand/Singapore), LGPD (Brazil).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resubscribe Timestamp' ;
    rdfs:comment 'The date and time when the consumer most recently re-opted in to this communication channel after a prior unsubscribe. Null if the consumer has never resubscribed. Supports win-back campaign analytics and preference lifecycle reporting.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retailerBannerPreference rdf:type rdf:Property ;
    rdfs:label 'Retailer Banner Preference' ;
    rdfs:comment 'Consumer\'s preferred retail banner or channel through which they prefer to receive offers and promotions (e.g., \'walmart\', \'target\', \'amazon\', \'dtc_website\'). Used to route trade promotion communications and personalized offers through the consumer\'s preferred retail touchpoint.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordRef rdf:type rdf:Property ;
    rdfs:label 'Source Record Ref' ;
    rdfs:comment 'The native record identifier from the source system (e.g., Salesforce Contact ID, SAP Business Partner number) that corresponds to this communication preference. Enables cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this consumer is suppressed from all communications on this channel regardless of opt-in status. True means the consumer must not be contacted via this channel (e.g., due to a legal hold, complaint, or regulatory requirement). Overrides opt_in_status.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why the suppression_flag has been set to True for this consumer and channel. Null when suppression_flag is False. Used for compliance audit trails and operational reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Flag' ;
    rdfs:comment 'Indicates whether the consumer has consented (True) to their communication preferences and contact data being shared with authorized third-party partners (e.g., retail partners, co-marketing partners) for outbound communications. False means data must not be shared.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'The date and time when the consumer most recently unsubscribed or opted out from this communication channel. Null if the consumer has never unsubscribed. Provides a precise audit trail for regulatory compliance and suppression list management.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:updatedByActor rdf:type rdf:Property ;
    rdfs:label 'Updated By Actor' ;
    rdfs:comment 'Identifies the type of actor who last updated this preference record. \'consumer_self_service\' means the consumer updated it directly via a portal or app; \'brand_agent\' means a call center or field agent updated it on behalf of the consumer; \'system_automated\' means an automated process applied the change.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentEventId rdf:type rdf:Property ;
    rdfs:label 'Consent Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable consent status change event record in the audit log. Primary key of the consent_event table.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign or trade promotion that triggered or was associated with this consent collection event. Enables campaign-level consent acquisition analytics and Trade Promotion Management (TPM) reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:dataSubjectRequestId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Id' ;
    rdfs:comment 'Reference identifier of the formal Data Subject Access Request (DSAR), right-to-erasure request, or opt-out request that triggered this consent event. Populated when change_trigger is \'regulatory_request\'. Links the event to the formal rights management workflow.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSubjectRequest .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the human agent (e.g., call center representative, CRM user) or automated system that processed and recorded this consent change event. Supports accountability tracing required by GDPR Article 5(2).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to regulatory.jurisdiction. Business justification: Regulatory reporting of consent changes must reference the jurisdiction that governs the consent.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:preferenceCenterId rdf:type rdf:Property ;
    rdfs:label 'Preference Center Id' ;
    rdfs:comment 'Reference to the specific preference center or consent management portal instance through which this consent event was captured. Supports multi-brand and multi-region preference center deployments.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferenceCenter .

ind:reversalEventConsentEventId rdf:type rdf:Property ;
    rdfs:label 'Reversal Event Consent Event Id' ;
    rdfs:comment 'Reference to the consent event that reversed or corrected this event, if applicable. Populated when event_status is \'reversed\'. Maintains the immutable audit chain while flagging erroneous records.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentEvent .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Unique identifier of the web or mobile application session during which the consent event was captured. Enables cross-referencing with session analytics and digital behavior logs for audit trail completeness.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentSession .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Code identifying the Consumer Goods brand or product line in whose context the consent was collected (e.g., a specific personal care or household brand). Supports brand-level consent segmentation and multi-brand CRM programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeChannel rdf:type rdf:Property ;
    rdfs:label 'Change Channel' ;
    rdfs:comment 'The interaction channel through which the consent change was submitted or processed. Supports channel-level compliance reporting and consumer journey analytics. [ENUM-REF-CANDIDATE: web|mobile_app|call_center|in_store|email|postal|crm_agent|api — promote to reference product]' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTrigger rdf:type rdf:Property ;
    rdfs:label 'Change Trigger' ;
    rdfs:comment 'The initiating cause of the consent status change. \'consumer_action\' = consumer explicitly acted; \'system_expiry\' = automated expiry rule fired; \'regulatory_request\' = GDPR/CCPA erasure or opt-out request; \'admin_override\' = internal compliance team action; \'data_import\' = bulk migration or integration import.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the consent granted in this event is scheduled to expire and require renewal. Supports automated consent refresh workflows and ensures time-limited consent is not used beyond its valid period.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the consent notice was presented to the consumer (e.g., \'en\', \'en-US\', \'fr-FR\'). Supports multilingual compliance documentation.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentPurposeCode rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose Code' ;
    rdfs:comment 'Standardized code identifying the specific processing purpose for which consent was changed (e.g., MARKETING_EMAIL, PERSONALIZATION, ANALYTICS, THIRD_PARTY_SHARING, LOYALTY_PROGRAM). Aligns with the consent purpose taxonomy defined under GDPR Article 5(1)(b) and CCPA categories.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentPurposeName rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose Name' ;
    rdfs:comment 'Human-readable name of the processing purpose for which consent was changed. Provides business-friendly label alongside the consent_purpose_code for reporting and consumer-facing disclosures.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextSnapshot rdf:type rdf:Property ;
    rdfs:label 'Consent Text Snapshot' ;
    rdfs:comment 'Verbatim or summarized text of the consent notice or opt-in/opt-out statement presented to the consumer at the time of this event. Immutable snapshot stored for evidentiary purposes under GDPR Article 7(1) and CCPA audit requirements.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent notice, privacy policy, or terms document that was presented to the consumer at the time of this consent event. Required to demonstrate that consent was informed under GDPR Article 7(1).' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether this consent grant was confirmed via a double opt-in mechanism (True), where the consumer confirmed their consent through a secondary verification step such as an email confirmation link. Relevant for email marketing compliance.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'Date and time when the consumer completed the double opt-in confirmation step (e.g., clicked the email verification link). Null if double_opt_in_flag is False or not applicable.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Processing status of this consent event record. \'processed\' = successfully applied to the consumer\'s consent profile; \'pending\' = awaiting confirmation (e.g., double opt-in); \'failed\' = processing error; \'reversed\' = event was reversed due to error correction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the consent status change event occurred. This is the authoritative business event time used for GDPR Article 7 and CCPA compliance audits, distinct from the record ingestion timestamp.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Discriminator classifying the kind of consent change event. \'grant\' = consumer actively provided consent; \'withdraw\' = consumer revoked consent; \'update\' = scope or preferences modified; \'expire\' = consent lapsed due to time limit; \'regulatory_erasure\' = right-to-be-forgotten request; \'system_expiry\' = automated system-driven expiry. [ENUM-REF-CANDIDATE: grant|withdraw|update|expire|regulatory_erasure|system_expiry — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the consumer\'s device at the time of the consent event submission. Captured as evidentiary proof of consent origin for GDPR Article 7 compliance. May be considered PII in certain jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasisCode rdf:type rdf:Property ;
    rdfs:label 'Legal Basis Code' ;
    rdfs:comment 'GDPR Article 6 lawful basis under which personal data processing is authorized at the time of this event. \'consent\' is the primary basis for marketing; other bases apply to operational processing. Required for GDPR Article 30 Records of Processing Activities.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Flag' ;
    rdfs:comment 'Indicates whether the consumer was identified as a minor (under 16 years for GDPR, under 13 for COPPA) at the time of this consent event. Triggers parental consent verification workflows and restricts certain processing activities.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newConsentStatus rdf:type rdf:Property ;
    rdfs:label 'New Consent Status' ;
    rdfs:comment 'The consent status of the consumer immediately after this event was processed. Together with prior_consent_status, provides the complete state transition record for regulatory audit purposes.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Indicates whether the resulting consent status after this event represents an active opt-in (True) or opt-out/withdrawal (False). Provides a simple boolean signal for downstream marketing suppression lists and CRM segmentation.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained for this consent event, applicable when minor_flag is True. Required for GDPR Article 8 and COPPA compliance for processing data of minors.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Consent Status' ;
    rdfs:comment 'The consent status of the consumer immediately before this event was processed. Captured as an immutable snapshot to enable full before/after audit trail required by GDPR Article 7 compliance reviews.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingSystem rdf:type rdf:Property ;
    rdfs:label 'Processing System' ;
    rdfs:comment 'Name or identifier of the operational system that processed and recorded this consent event (e.g., Salesforce Consumer Goods Cloud, CRM Portal, Preference Center API). Provides system-level audit trail for data lineage.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profilingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Profiling Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer has consented to automated profiling and personalization activities (True = profiling consented; False = profiling not consented or withdrawn). Relevant for GDPR Article 22 automated decision-making compliance.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfConsentReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Consent Reference' ;
    rdfs:comment 'Reference identifier or document path pointing to the stored evidence of consent (e.g., signed form scan, recorded call reference, screenshot archive, Veeva Vault document ID). Supports GDPR Article 7(1) burden-of-proof requirements.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when this consent event record was first ingested and persisted in the data platform (Silver Layer). Distinct from event_timestamp which captures the real-world business event time. Used for data lineage and SLA monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'The web URL or deep-link of the page, form, or digital touchpoint where the consumer submitted the consent change (e.g., preference center URL, checkout page, registration form). Provides evidence of the consent collection point for GDPR Article 7 accountability.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user-agent string captured at the time of the consent event. Provides technical evidence of the device and browser environment used when consent was given, supporting GDPR Article 7 proof-of-consent requirements.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason Code' ;
    rdfs:comment 'Standardized code capturing the consumer\'s stated reason for withdrawing consent (e.g., TOO_FREQUENT, NOT_RELEVANT, PRIVACY_CONCERN, UNSUBSCRIBE_ALL). Null for non-withdrawal events. Supports consumer experience analytics and suppression management.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReasonText rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason Text' ;
    rdfs:comment 'Free-text description provided by the consumer or agent explaining the reason for consent withdrawal. Supplements withdrawal_reason_code with verbatim consumer feedback for qualitative analysis.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelClassificationId rdf:type rdf:Property ;
    rdfs:label 'Channel Classification Id' ;
    rdfs:comment 'Reference to the distribution or engagement channel (e.g., DTC e-commerce, retail loyalty, mobile app) through which the consumer relationship was established and consent was captured. Supports channel-level consent analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelClassification .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer\'s consent was captured. Identifies whether consent was obtained via a web form, mobile app, in-store interaction, call center agent, paper form, or email link. Required for GDPR proof-of-consent obligations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Exact date and time (with timezone offset) when the consumer\'s consent action was recorded in the system. This is the principal business event timestamp for the consent record and is immutable once set. Required for GDPR Article 7 audit trail.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentProofReference rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored proof-of-consent artifact (e.g., screenshot, signed form scan, call recording reference, Veeva Vault document ID). Supports GDPR Article 7(1) obligation to demonstrate that consent was given.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Defines the breadth of the consent grant — whether it applies globally across all Consumer Goods brands and products, is restricted to a specific brand, product category, or a single campaign. Enables granular consent management across the product portfolio.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent being captured, defining the specific processing activity for which the consumer has provided or withheld consent. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies as required by GDPR and CCPA.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieConsentCategories rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Categories' ;
    rdfs:comment 'Comma-separated list of cookie categories for which the consumer has granted consent (e.g., \'functional,analytics,marketing\'). Captures granular cookie preferences as required by the ePrivacy Directive and GDPR for digital channels. [ENUM-REF-CANDIDATE: necessary|functional|analytics|marketing|social_media|personalization|advertising — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used by the consumer when providing consent in digital channels. Supports forensic audit trails and UX analysis of consent capture flows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this consent record is considered active and binding. Typically aligns with the capture date but may differ for backdated or scheduled consent activations. Supports MASTER_AGREEMENT role effective-period tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which this consent record expires and must be renewed or re-confirmed by the consumer. Null indicates open-ended consent with no defined expiry. Used to trigger consent renewal workflows and ensure ongoing compliance with GDPR\'s requirement for time-limited consent.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this row represents the current active consent record for the consumer-consent_type combination. Supports Slowly Changing Dimension (SCD Type 2) pattern in the Silver Layer, where historical consent versions are retained for audit purposes and this flag identifies the latest version.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 or equivalent regulation for processing the consumer\'s personal data. Consent is one of six legal bases; this field distinguishes consent-based processing from other lawful bases to support compliance reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorAgeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minor Age Threshold' ;
    rdfs:comment 'Age threshold (in years) used to determine whether parental consent was required for this consent record, based on the applicable jurisdiction\'s rules (e.g., 16 for GDPR default, 13 for COPPA, 13-16 for EU member state variations). Null if consumer is not a minor.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingAgent rdf:type rdf:Property ;
    rdfs:label 'Processing Agent' ;
    rdfs:comment 'Identifier of the system, application, or human agent (call center representative ID or system name) that processed and recorded the consent event. Supports accountability requirements under GDPR Article 5(2) and provides an audit trail of who or what captured the consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentDeadline rdf:type rdf:Property ;
    rdfs:label 'Re Consent Deadline' ;
    rdfs:comment 'Date by which the consumer must re-confirm their consent before the current consent record is automatically withdrawn or expired. Null if re-consent is not required. Used to drive automated consent renewal campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the consumer due to a material change in the privacy policy, consent notice, or processing purpose. Triggers re-consent outreach workflows in the CRM system.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Sequential version number of this consent record for the consumer-consent_type combination. Increments with each status change or update, enabling full audit history reconstruction. Version 1 is the initial consent capture; subsequent versions reflect changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The applicable privacy regulation or jurisdiction framework under which this consent record was created and must be managed. Determines the legal basis, retention rules, and consumer rights applicable to this record (e.g., GDPR for EU consumers, CCPA for California residents).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days this consent record must be retained for compliance purposes after the consent is withdrawn or expires. Determined by applicable regulatory requirements (e.g., GDPR Article 5(1)(e) storage limitation, CCPA). Drives automated data lifecycle management.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer withdrew their consent. Null if consent has not been withdrawn. Required to demonstrate that withdrawal was as easy as giving consent per GDPR Article 7(3).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Exact date and time when the consumer withdrew their consent. Null if consent has not been withdrawn. GDPR Article 7(3) requires that withdrawal be as easy as giving consent; this timestamp documents the withdrawal event for audit purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer address record in the Consumer Goods DTC/B2C platform. Primary key for the consumer_address data product.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'The originating channel or system through which this address was captured. Supports data lineage, source quality scoring, and GDPR/CCPA consent audit trails. [ENUM-REF-CANDIDATE: crm|dtc_checkout|loyalty_enrollment|call_center|mobile_app|web_portal|third_party|manual_entry — promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are eligible for order fulfillment and marketing. Inactive addresses are retained for historical reporting. Deleted status supports GDPR right-to-erasure soft-delete workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address by its business purpose. Billing addresses are used for invoicing and financial compliance; shipping addresses drive DTC order fulfillment and last-mile logistics; home and work addresses support personalized marketing and consumer segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRoute rdf:type rdf:Property ;
    rdfs:label 'Carrier Route' ;
    rdfs:comment 'USPS carrier route code assigned to this address (e.g., C001, R001, B001, H001). Used for direct mail presort discounts, delivery sequence optimization, and postal cost modeling in consumer marketing programs.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTract rdf:type rdf:Property ;
    rdfs:label 'Census Tract' ;
    rdfs:comment 'U.S. Census Bureau census tract code for the address location. Enables demographic overlay analysis, market penetration reporting by socioeconomic segment, and trade area planning for consumer goods distribution.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the consumer\'s address. Used for geographic segmentation, regional marketing campaigns, distribution zone assignment, and regulatory data residency tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCaptured rdf:type rdf:Property ;
    rdfs:label 'Consent Captured' ;
    rdfs:comment 'Indicates whether explicit consumer consent was obtained for storing and processing this address record under applicable privacy regulations (GDPR/CCPA). True indicates consent is on file; False requires consent collection before marketing use.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the consumer provided consent for storage and processing of this address record. Required for GDPR Article 7 compliance documentation and CCPA opt-in audit trails.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic data residency classification for this address record, indicating the regulatory jurisdiction governing data storage and processing. Drives GDPR (EU), CCPA (US/CA), and other regional privacy law compliance for data localization requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverabilityScore rdf:type rdf:Property ;
    rdfs:label 'Deliverability Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the likelihood that a physical shipment or direct mail piece will be successfully delivered to this address. Derived from address validation provider output. Supports carrier selection and DTC fulfillment risk management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area (DMA) code for the address location. Used for media planning, Share of Voice (SOV) analysis, and regional brand marketing investment allocation in consumer goods trade promotion programs.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Indicates whether the consumer has opted out of physical direct mail marketing to this address. When True, this address must be suppressed from direct mail campaign execution lists. Supports GDPR right-to-object and CCPA opt-out compliance.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpvConfirmation rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation' ;
    rdfs:comment 'USPS Delivery Point Validation confirmation code indicating the deliverability of the address. Y=Confirmed deliverable, S=Confirmed deliverable (secondary info missing), D=Confirmed deliverable (secondary info present but unneeded), N=Not confirmed. Critical for DTC fulfillment and direct mail campaigns.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this address record is considered valid and active for business use. Supports bi-temporal data modeling, address history tracking, and GDPR right-to-erasure compliance by enabling point-in-time address reconstruction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the address format to guide formatting, validation, and carrier routing logic. PO Box addresses may not be eligible for certain DTC carriers; military addresses (APO/FPO/DPO) require specific handling; rural route addresses may have extended delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates for this address. Rooftop indicates exact parcel-level geocoding; range_interpolated indicates interpolation between street numbers; geometric_center indicates centroid of a polygon. Impacts reliability of proximity-based analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default billing address for payment processing and invoice generation. Used in DTC checkout flows and financial compliance reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default shipping destination for DTC orders. Distinct from is_primary as a consumer may have a primary home address but a different default shipping address (e.g., workplace).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the consumer\'s primary address record for the given address type. When True, this address is used as the default for order fulfillment, marketing communications, and regulatory correspondence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Enables geocoded proximity analysis, delivery zone optimization, and location-based personalized marketing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including house/building number and street name. Core component of the consumer\'s physical location used for DTC order fulfillment, direct mail marketing, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for apartment, suite, unit, floor, or building designations. Supplements address_line_1 to ensure complete and accurate delivery routing for DTC shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as neighborhood, district, or care-of designations. Used in international address formats where three address lines are required.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Used alongside latitude for geocoded proximity analysis, store locator features, and last-mile delivery optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plus4Code rdf:type rdf:Property ;
    rdfs:label 'Plus4 Code' ;
    rdfs:comment 'The four-digit USPS ZIP+4 extension code that narrows delivery to a specific block face or building. Enables postal presort discounts for direct mail campaigns and improves delivery precision for DTC shipments within the United States.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'ZIP or postal code of the consumer\'s address. Used for last-mile delivery routing, trade area analysis, demographic segmentation, and carrier rate determination in DTC fulfillment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Indicator' ;
    rdfs:comment 'Classification of the address as residential or commercial. Impacts carrier surcharge calculations (UPS/FedEx residential delivery fees), marketing segmentation, and DTC fulfillment cost modeling.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Internal sales territory or region code assigned to this address based on geographic boundaries. Used for Sales Force Automation (SFA) territory assignment, trade promotion planning, and regional sales performance reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The native record identifier from the originating operational system of record (e.g., Salesforce Consumer Goods Cloud Contact Address ID, SAP S/4HANA Business Partner Address GUID). Enables cross-system reconciliation and data lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system of record from which this address record originated. Supports data lineage, master data management (MDM) conflict resolution, and Silver Layer data quality governance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'The full address formatted as a single standardized string per USPS/UPU postal standards after address validation and normalization (e.g., \'123 MAIN ST APT 4B, CHICAGO IL 60601-1234\'). Used as the canonical address for carrier label generation and deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the consumer\'s address using ISO 3166-2 subdivision codes (e.g., US-CA, CA-ON). Supports tax jurisdiction determination, regional compliance, and territory-based sales reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Europe/London). Used for scheduling personalized marketing communications at optimal local times and for regulatory compliance with time-sensitive consumer notifications.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for data quality governance and vendor performance tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed DTC deliveries and return-to-sender costs. Failed addresses require consumer outreach before order fulfillment.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is needed based on data freshness policies and to support data quality SLA reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer interaction record in the silver layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCallId rdf:type rdf:Property ;
    rdfs:label 'Account Call Id' ;
    rdfs:comment 'Foreign key linking to sales.account_call. Business justification: Customer service interactions often trigger sales account calls; linking allows tracking follow-up actions and performance metrics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountCall .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Support interactions incur costs that must be charged to a cost center for service-cost analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:distributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Distribution Facility Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_facility. Business justification: Customer service logs need to reference the DC responsible for a delivery issue to drive escalation and performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:environmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_incident. Business justification: Captures consumer-reported product incidents and ties them to environmental incident tracking for compliance and remediation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalIncident .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_shipment. Business justification: Customer service interactions about delivery status must reference the specific shipment to provide accurate updates and log issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsShipment .

ind:parentInteractionId rdf:type rdf:Property ;
    rdfs:label 'Parent Interaction Id' ;
    rdfs:comment 'Self-referencing identifier linking this interaction to a parent case when it is a follow-up, escalation, or sub-case of a prior interaction. Enables interaction hierarchy and repeat-contact chain analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:productComplaintId rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.product_complaint. Business justification: Customer service process records each interaction against the specific product complaint it addresses for root-cause tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductComplaint .

ind:promotionEventId rdf:type rdf:Property ;
    rdfs:label 'Promotion Event Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_event. Business justification: Needed for Customer Service Interaction log linking to specific promotion events, enabling issue tracking and promotion effectiveness analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionEvent .

ind:retailStoreId rdf:type rdf:Property ;
    rdfs:label 'Retail Store Id' ;
    rdfs:comment 'Reference to the retail account or store where the consumer purchased the product referenced in this interaction. Supports retail execution quality analysis, DSD complaint tracking, and trade partner performance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the specific product (SKU) associated with this consumer interaction, such as the product being complained about, inquired about, or referenced in a feedback submission.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:tradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Trade Account Id' ;
    rdfs:comment 'Foreign key linking to customer.trade_account. Business justification: Support interactions tied to a specific trade account enable account-level SLA tracking and issue resolution reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:adverseEventFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Flag' ;
    rdfs:comment 'Indicates whether this interaction has been classified as an adverse event report (e.g., allergic reaction, injury, illness linked to product use). Triggers mandatory regulatory reporting workflows under FDA, CPSC, and EU REACH regulations.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturing batch or lot number of the product referenced in this interaction, as reported by the consumer. Critical for adverse event investigations, product recalls, and GMP traceability under FDA and ISO 22716 requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case or ticket reference number assigned by the CRM system (e.g., Salesforce Consumer Goods Cloud) at the time the interaction is logged. Used for consumer-facing communication and SLA tracking.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The consumer-facing touchpoint channel through which this interaction was initiated. Supports omnichannel analytics and channel performance reporting. [ENUM-REF-CANDIDATE: call_center|live_chat|email|social_media|in_app|retail|web_form — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer provided explicit consent for their interaction data to be used for quality improvement, marketing analytics, or regulatory reporting purposes at the time of the interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactReasonCode rdf:type rdf:Property ;
    rdfs:label 'Contact Reason Code' ;
    rdfs:comment 'Standardized code categorizing the specific reason for consumer contact (e.g., product defect, packaging issue, allergic reaction, pricing query, loyalty redemption). Enables granular root cause analysis and product quality reporting. [ENUM-REF-CANDIDATE: promote to reference product with full taxonomy]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'The date after which this interaction record must be purged or anonymized in compliance with GDPR right-to-erasure and CCPA data retention policies. Calculated based on interaction type and applicable jurisdiction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the consumer interaction in seconds, applicable primarily to real-time channels (call center, live chat). Used for agent efficiency KPIs, average handle time (AHT) reporting, and capacity planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this interaction was escalated to a higher-tier support team, supervisor, or regulatory body during its lifecycle. Drives escalation workflow reporting and quality management reviews.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Categorical reason why the interaction was escalated. Null if escalation_flag is False. Supports root cause analysis and process improvement initiatives. [ENUM-REF-CANDIDATE: sla_breach|consumer_request|regulatory_requirement|repeat_contact|safety_concern|management_review — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Full narrative text of the consumer interaction as captured by the agent or automated system. Contains the consumer\'s verbatim concern, inquiry, or feedback. Classified confidential due to potential inclusion of personal context.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction within the CRM case management workflow. Drives SLA monitoring, escalation triggers, and operational dashboards.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the consumer interaction was initiated or first recorded. This is the principal real-world event time used for SLA calculation, trend analysis, and regulatory reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature of the consumer touchpoint. Drives routing, SLA assignment, and regulatory reporting workflows. \'adverse_event_report\' triggers mandatory escalation per FDA/CPSC requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBotHandled rdf:type rdf:Property ;
    rdfs:label 'Is Bot Handled' ;
    rdfs:comment 'Indicates whether this interaction was fully or partially handled by an automated bot or virtual assistant without human agent involvement. Used to measure automation rate and bot containment KPIs.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'BCP 47 language code indicating the language in which the consumer interaction was conducted (e.g., en-US, fr-FR, es-MX). Drives multilingual routing, translation workflows, and regional analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Audit timestamp of the most recent update to this interaction record. Used for incremental data pipeline processing and change tracking in the silver layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the interaction, determining routing urgency and SLA tier. Critical priority is automatically assigned to adverse event reports and regulatory complaints per CPSC and FDA guidelines.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date on which the consumer purchased the product referenced in this interaction, as reported by the consumer or verified via POS/loyalty data. Used for warranty validation, product age assessment, and adverse event timeline analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Number' ;
    rdfs:comment 'Reference number assigned when this interaction triggers a mandatory regulatory submission (e.g., FDA MedWatch report number, CPSC incident report ID). Null if no regulatory report was filed.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatContactFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Contact Flag' ;
    rdfs:comment 'Indicates whether this interaction is a follow-up or repeat contact from the same consumer regarding the same issue within a defined lookback window. Key metric for first-contact resolution (FCR) KPI measurement.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Agent-authored narrative documenting the resolution actions taken, root cause identified, and outcome communicated to the consumer. Supports quality audits and repeat-contact analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the consumer interaction was formally resolved or closed. Used to calculate actual resolution time against SLA targets and for consumer satisfaction measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorical classification of the resolution action taken to close this interaction. Drives cost-of-service analytics, consumer satisfaction correlation, and resolution effectiveness reporting. [ENUM-REF-CANDIDATE: refund|replacement|coupon|apology|information_provided|no_action_required|regulatory_referral — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentLabel rdf:type rdf:Property ;
    rdfs:label 'Sentiment Label' ;
    rdfs:comment 'Categorical sentiment classification derived from the sentiment_score or manual agent tagging. Used for quick-filter reporting and consumer satisfaction trend analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Numeric sentiment classification score derived from NLP analysis of the interaction text, ranging from -1.0 (most negative) to +1.0 (most positive). Feeds consumer sentiment dashboards and brand health monitoring.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the interaction exceeded its defined SLA target resolution time. True if resolution_timestamp minus interaction_timestamp exceeds sla_target_hours. Drives escalation and quality reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which this interaction must be resolved, based on interaction type and channel. Used for SLA compliance reporting and KPI dashboards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief, structured subject line or title summarizing the consumer interaction. Used for case categorization, search, and reporting in CRM systems.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The Universal Product Code (UPC) or GTIN of the product as reported or scanned by the consumer. Enables precise product identification when the consumer provides packaging information, supporting recall and quality investigations.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer segment definition record in the Consumer Goods lakehouse silver layer. Serves as the primary key for all segment definition and membership records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent segment when this segment is a sub-segment or child in a hierarchical segmentation structure (e.g., \'High-Value Loyalists\' as a child of \'Loyalty Program Members\'). Null for top-level segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'The primary marketing activation channel for which this segment is designed (e.g., email campaigns, SMS, push notifications, paid media audiences, in-store promotions). Drives channel-specific audience export configurations in Salesforce Consumer Goods Cloud and CRM platforms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'For demographic segments, the maximum consumer age (in years) defining the upper bound for segment inclusion. Used alongside age_range_min to define age-banded demographic segments (e.g., Millennials: 28–43).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'For demographic segments, the minimum consumer age (in years) required for segment inclusion. Used in age-gated product targeting (e.g., health supplements, alcohol-adjacent personal care) and regulatory compliance with COPPA for under-13 restrictions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which consumers are assigned to this segment. \'rule_based\' uses deterministic business rules (e.g., purchase frequency thresholds); \'ml_model\' uses a trained machine learning classifier; \'manual\' indicates analyst-driven assignment; \'hybrid\' combines rule-based and ML approaches.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'The distribution or engagement channel(s) for which this segment is applicable. \'dtc\' (Direct to Consumer) segments target consumers via owned digital channels; \'retail\' targets in-store shoppers; \'ecommerce\' targets online platform shoppers; \'omnichannel\' applies across all channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvMaxValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Max Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the maximum predicted CLTV value defining the upper bound of this segment tier. Used to create banded CLTV segments (e.g., mid-value tier: CLTV between $500 and $2000). Null if no upper bound applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvMinValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Min Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the minimum predicted CLTV score or monetary value required for a consumer to qualify for segment membership. Enables tiered loyalty and high-value consumer targeting strategies. Null for non-CLTV segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 or CCPA for processing consumer data within this segment. \'consent\' requires explicit opt-in; \'legitimate_interest\' applies where the business has a justified interest; \'contract\' applies for contractual necessity; \'not_required\' for non-personal aggregate segments.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit consumer consent is required before a consumer can be assigned to or activated within this segment. True for segments used in direct marketing, personalization, or profiling activities subject to GDPR Article 6 or CCPA opt-in requirements.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this segment definition expires and is no longer eligible for active targeting. Null indicates an open-ended segment with no planned expiry. Used for time-variant segment membership tracking and historical analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this segment definition becomes valid and eligible for use in CRM targeting, personalization, and trade promotion activation. Supports time-variant segment tracking and bi-temporal data modeling in the silver layer.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code(s) or region identifiers defining the geographic boundary of this segment (e.g., \'USA\', \'GBR\', \'DEU\'). Supports multi-country CPG brand activation and ensures GDPR/CCPA-compliant targeting within applicable jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuppressionSegment rdf:type rdf:Property ;
    rdfs:label 'Is Suppression Segment' ;
    rdfs:comment 'Indicates whether this segment is a suppression list used to exclude consumers from campaigns (e.g., opted-out consumers, recent purchasers, regulatory exclusions). True means consumers in this segment are excluded from targeted marketing activations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership was last recalculated and updated. Used to assess data freshness for CRM targeting and to trigger refresh workflows when the segment is stale relative to its defined refresh frequency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyTierScope rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Scope' ;
    rdfs:comment 'The loyalty program tier(s) targeted by this segment. Enables differentiated engagement strategies for loyalty program members (e.g., exclusive offers for Platinum tier, win-back campaigns for Bronze tier). \'all\' indicates the segment applies across all loyalty tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Min Confidence Score' ;
    rdfs:comment 'The minimum ML model confidence score (0.0000 to 1.0000) required for a consumer to be assigned to this segment when using ML-based assignment. Consumers with scores below this threshold are excluded. Null for rule-based or manual segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlModelCode rdf:type rdf:Property ;
    rdfs:label 'Ml Model Code' ;
    rdfs:comment 'Identifier of the machine learning model used to generate or score this segment, when assignment_method is \'ml_model\' or \'hybrid\'. Enables traceability to the model registry for audit, retraining, and explainability purposes. Null for rule_based or manual segments.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreMax rdf:type rdf:Property ;
    rdfs:label 'Nps Score Max' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the maximum NPS score (0–10 scale) defining the upper bound for segment inclusion. Used in conjunction with nps_score_min to define NPS-banded segments (e.g., detractors: 0–6).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsScoreMin rdf:type rdf:Property ;
    rdfs:label 'Nps Score Min' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the minimum NPS score (0–10 scale) required for segment inclusion. Enables targeting of promoters (9–10), passives (7–8), or detractors (0–6) for tailored consumer engagement programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The business unit (BU) within Consumer Goods responsible for this segment\'s definition, governance, and activation (e.g., \'Personal Care\', \'Home Care\', \'Health & Wellness\'). Used for segment ownership reporting and cross-BU deduplication governance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority rank used to resolve conflicts when a consumer qualifies for multiple overlapping segments. Lower values indicate higher priority. Used by CRM and personalization engines to determine which segment\'s rules take precedence for offer assignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How frequently the segment membership is recalculated and updated. Determines the cadence at which consumer assignments are re-evaluated against the segment\'s rules or ML model. Impacts CRM campaign freshness and personalization accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmFrequencyMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Frequency Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum number of purchase transactions required within the recency window for a consumer to qualify for the frequency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmMonetaryMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Monetary Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum cumulative spend amount (in the segment\'s currency) required within the recency window for a consumer to qualify for the monetary criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfmRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Rfm Recency Days' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the number of days used to define the recency window (e.g., last 90 days). Consumers with a purchase within this window qualify for the recency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the segment, used in CRM campaign targeting, trade promotion management (TPM) systems, and Salesforce Consumer Goods Cloud audience configurations. Unique per segment version.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s defining characteristics, inclusion criteria, and intended business use (e.g., targeting strategy, personalization approach, or trade promotion eligibility). Authored by the owning brand or business unit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable business name of the consumer segment (e.g., \'High-Value Loyalists\', \'Lapsed Shoppers\', \'Health-Conscious Millennials\'). Used in marketing activation, CRM dashboards, and trade promotion targeting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. \'active\' segments are available for CRM targeting and trade promotion activation; \'draft\' segments are under construction; \'archived\' segments are retained for historical analysis but no longer used in campaigns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied to define this segment. Behavioral segments are based on purchase patterns; demographic on age/gender/income; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; CLTV (Customer Lifetime Value)-based on predicted long-term value; geographic on location.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Source Segment Code' ;
    rdfs:comment 'The native identifier of this segment in the originating operational system (e.g., Salesforce Consumer Goods Cloud segment ID, Nielsen IQ panel group code). Enables cross-system reconciliation and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'The estimated or actual count of unique consumers assigned to this segment at the time of last refresh. Used for campaign planning, media budget allocation, and share of voice (SOV) estimation. Not a real-time count — reflects the last segment refresh cycle.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradePromotionEligible rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligible' ;
    rdfs:comment 'Indicates whether this consumer segment is eligible for trade promotion targeting within the Trade Promotion Management (TPM) system. True enables the segment to be used in TPM/TPO campaign audience configurations in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Integer version number of this segment definition record, incremented each time the segment\'s criteria, model, or metadata is materially updated. Supports bi-temporal tracking and enables comparison of segment membership across definition versions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcOrderId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each Direct-to-Consumer (DTC) order record in the Silver layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcOrder .

ind:carbonEmissionId rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_emission. Business justification: Order-level carbon footprint reporting required for ESG disclosures; each order is linked to its calculated carbon emission record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonEmission .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Required for consolidated revenue reporting across channels; DTC orders must be reconciled with central sales order for finance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Required for Order Fulfillment Tracking report linking each consumer DTC order to the procurement purchase order that supplied the goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Reference to the consumer subscription plan that generated this DTC order, when subscription_order_flag is True. Links to the subscription master for recurring order management, churn analysis, and subscription revenue reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date the shipment was confirmed as delivered to the consumer. Compared against promised_delivery_date to calculate OTIF performance and identify late delivery patterns for carrier SLA management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddressSameFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same Flag' ;
    rdfs:comment 'Indicates whether the billing address is identical to the shipping address for this order. When False, a separate billing address record is maintained. Used for payment processing and fraud risk scoring.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier assigned to deliver this DTC order (e.g., UPS, FedEx, USPS, DHL). Used for carrier performance analysis, SLA tracking, and logistics cost allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The specific owned DTC channel through which the order was placed (e.g., brand website, mobile app, social commerce). Enables channel-level performance analysis, attribution modeling, and Share of Voice (SOV) reporting across DTC touchpoints.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary discount applied at the order header level, including promotional codes, loyalty redemptions, and trade promotion discounts. Used for Trade Promotion Management (TPM) ROI analysis and net revenue reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentRef rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Ref' ;
    rdfs:comment 'External reference number linking this DTC order to the fulfillment system (e.g., Blue Yonder WMS warehouse order, 3PL fulfillment reference, or SAP WM transfer order). Enables end-to-end order-to-delivery traceability and OTIF measurement.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment state of the DTC order at the header level, indicating whether all line items have been picked, packed, and shipped. Used for OTIF (On Time In Full) KPI reporting and supply chain performance dashboards.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was placed as a gift, triggering gift wrapping, suppression of price information on packing slips, and gift message inclusion. Used for seasonal demand analysis and consumer gifting behavior modeling.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ip Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from the consumer\'s IP address at the time of order placement. Used for fraud detection, geo-restriction compliance, and cross-border commerce analytics. Classified as potentially PII under GDPR.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty program points earned by the consumer for this DTC order, based on the order total and applicable loyalty tier multipliers. Feeds into CLTV calculations and loyalty program engagement analytics.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the consumer as a discount on this DTC order. Used for loyalty liability accounting, redemption rate analysis, and consumer engagement reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The exact date and time (UTC) when the consumer submitted the order through the DTC e-commerce or brand website channel. This is the principal business event timestamp used for demand planning, daily sales reporting, and S&OP inputs. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the DTC order, tracking progression from placement through fulfillment or cancellation. Used for order management dashboards, OTIF reporting, and consumer communication triggers. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: pending|confirmed|processing|shipped|delivered|cancelled|returned — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The final net amount charged to the consumer, calculated as subtotal minus discounts plus shipping plus tax. This is the authoritative revenue figure for DTC channel financial reporting and EBITDA contribution analysis. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET net total.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument type used by the consumer to complete this DTC order (e.g., credit card, PayPal, digital wallet). Used for payment analytics, fraud detection, and consumer payment preference reporting. Note: No raw card data is stored; only the instrument type.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction associated with this DTC order, tracking authorization through capture or refund. Critical for revenue recognition, accounts receivable (DSO), and consumer dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Ref' ;
    rdfs:comment 'External payment gateway transaction reference or authorization code for this order. Used for payment reconciliation, chargeback management, and financial audit trails. Does not contain sensitive card data (PCI DSS compliant tokenized reference only).' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The delivery date committed to the consumer at the time of order placement, based on Available to Promise (ATP) or Capable to Promise (CTP) logic. Used for SLA compliance measurement and consumer expectation management.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or coupon code entered by the consumer at checkout, linking this order to a specific Trade Promotion Management (TPM) campaign. Enables TPM ROI measurement, promotional lift analysis, and Trade Promotion Optimization (TPO) modeling.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether any item in this DTC order has been returned or a return has been initiated. Used for return rate analysis, product quality monitoring, and consumer satisfaction (NPS) correlation studies.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the order return (e.g., defective product, wrong item, consumer changed mind). Populated when return_flag is True. Used for quality defect analysis, product improvement, and COGS impact reporting. [ENUM-REF-CANDIDATE: defective|wrong_item|not_as_described|changed_mind|damaged_in_transit|late_delivery|other — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'Primary street address line for the shipping destination of this DTC order. Used for carrier routing, last-mile delivery, and geographic sales analysis. Classified as PII under GDPR and CCPA.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City of the shipping destination for this DTC order. Used for geographic demand analysis, Distribution Requirements Planning (DRP), and regional marketing segmentation.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping destination. Drives international shipping compliance, customs documentation, import/export regulatory requirements, and multi-country revenue reporting.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToName rdf:type rdf:Property ;
    rdfs:label 'Ship To Name' ;
    rdfs:comment 'Full name of the recipient at the shipping address for this DTC order. May differ from the ordering consumer (e.g., gift orders). Required for carrier label generation and last-mile delivery. Classified as PII under GDPR and CCPA.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipping destination. Used for carrier rate calculation, geographic clustering, and micro-market demand analysis.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State or province of the shipping destination. Used for tax jurisdiction determination, regional sales reporting, and regulatory compliance (e.g., state-level FDA or EPA requirements).' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'The date the order was physically dispatched from the fulfillment center or warehouse. Used for lead time analysis, carrier handoff tracking, and revenue recognition timing under ASC 606.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges billed to the consumer for this DTC order. Used for logistics cost analysis, free-shipping threshold reporting, and net revenue calculations.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating e-commerce platform or ERP system (e.g., Salesforce Commerce Cloud order ID, SAP SD sales order number). Used for cross-system reconciliation, EDI integration, and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was generated as part of a recurring subscription (subscribe-and-save) program. Used to distinguish subscription revenue from one-time purchase revenue for CLTV modeling and replenishment trigger analysis.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The gross merchandise value of all line items before discounts, shipping charges, and taxes are applied. Used as the base for promotional discount calculations, COGS analysis, and gross margin reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax or VAT charged on this DTC order, calculated based on the shipping destination jurisdiction. Required for financial reporting, tax compliance, and SOX audit trails. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment associated with this DTC order. Provided to the consumer for last-mile visibility and used internally for delivery confirmation and OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line item within a DTC order. Primary key for this entity. Role: TRANSACTION_LINE.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Supports Receiving Verification process linking consumer order line to the goods receipt confirming physical receipt from supplier.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Needed for Line-Level Fulfillment report to map each consumer order line to the procurement PO line that provided the SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:productRecallId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Id' ;
    rdfs:comment 'Foreign key linking to regulatory.product_recall. Business justification: Recall effectiveness analysis needs to associate each order line with the recall that affected the SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Each line item contributes to a profit center; needed for profit-center reporting per SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_movement. Business justification: Shipment tracking process ties each order line to the inventory movement record that shipped the product.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockMovement .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Fulfillment allocation report requires linking each order line to the specific stock position that supplied the SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:supplyAtpRecordId rdf:type rdf:Property ;
    rdfs:label 'Supply Atp Record Id' ;
    rdfs:comment 'Foreign key linking to supply.atp_record. Business justification: REQUIRED: Order line allocation references the ATP record used for inventory commitment; this link supports order-to-inventory reconciliation and fulfillment reporting.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtpRecord .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Date on which the order line was physically dispatched from the fulfillment warehouse. Used to calculate On Time In Full (OTIF) performance and carrier SLA adherence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Standard cost of goods for the units on this order line at time of sale. Used for gross margin calculation, DTC channel profitability analysis, and EBITDA reporting. Classified confidential as it reveals internal cost structure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtcReturnId rdf:type rdf:Property ;
    rdfs:label 'Dtc Return Id' ;
    rdfs:comment 'Reference to the consumer return record associated with this order line when a return has been initiated. Enables end-to-end return lifecycle tracking and refund reconciliation.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Flag' ;
    rdfs:comment 'Indicates whether this order line was designated as a gift by the consumer. True when the consumer selected gift options (e.g., gift wrapping, gift message). Supports gifting program analytics and packaging operations.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'GS1-standard Global Trade Item Number for the product on this line. Enables cross-retailer product identification, barcode scanning, and regulatory traceability. Conforms to GS1 GTIN-8, GTIN-12 (UPC), GTIN-13 (EAN), or GTIN-14 formats.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the product on this order line is classified as a hazardous material requiring special handling, packaging, or shipping restrictions. True for products subject to DOT, IATA, or EPA hazmat regulations. Critical for carrier compliance and Safety Data Sheet (SDS) requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether this order line has been subject to a consumer return. True when a return has been initiated or completed. Enables return rate analysis by SKU, category, and consumer segment for product quality and consumer experience programs.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this order line, including promotional discounts, coupon redemptions, and loyalty rewards. Used for Trade Promotion Management (TPM) analysis and margin reporting.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Line Discount Pct' ;
    rdfs:comment 'Discount rate applied to this order line expressed as a percentage of the gross unit price. Enables promotional effectiveness analysis and margin impact assessment without requiring price recalculation.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this order line after all discounts have been applied but before tax. Core revenue recognition field for DTC channel P&L reporting and COGS analysis. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT monetary component.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this line item within the parent DTC order. Used for ordering, display, and reconciliation of multi-line orders. Satisfies TRANSACTION_LINE LINE_SEQUENCE category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Gross line value before tax, calculated as unit_price multiplied by quantity_ordered. Represents the pre-discount, pre-tax revenue contribution of this line item.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Final total amount for this order line inclusive of all discounts and taxes. Represents the actual amount charged to the consumer for this line item. Used for revenue reporting and consumer billing reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'Hierarchical product category classification code for the SKU on this line (e.g., Personal Care > Hair Care > Shampoo). Enables category-level sales analysis, assortment planning, and consumer purchase pattern segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Commercial name of the product SKU as displayed to the consumer at time of purchase. Captured at order time to preserve historical accuracy independent of future product name changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'Date on which the order line was committed to ship to the consumer at time of order placement. Basis for Available to Promise (ATP) and Service Level Agreement (SLA) compliance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'Number of units cancelled on this order line, either by the consumer or due to inventory unavailability. Supports cancellation rate analysis and demand signal correction.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units of the SKU ordered by the consumer on this line. Basis for demand planning, inventory reservation, and fulfillment processing. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual number of units of the SKU dispatched to the consumer for this line. May differ from quantity_ordered due to partial fulfillment, Out of Stock (OOS) situations, or split shipments. Key metric for On Time In Full (OTIF) measurement.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this order line is subject to a regulatory hold preventing fulfillment (e.g., FDA product recall, CPSC safety alert, EU REACH restriction). True when a hold is active. Supports compliance-driven order management and consumer safety programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Flag' ;
    rdfs:comment 'Indicates whether this order line was generated as part of a recurring subscription program (e.g., Subscribe & Save). True for subscription-triggered lines. Enables subscription revenue tracking and replenishment program analysis.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure in which the SKU quantity is expressed on this order line (e.g., EA=Each, CS=Case, PK=Pack). Aligns with GS1 and SAP UOM standards for consistent quantity interpretation. [ENUM-REF-CANDIDATE: EA|CS|PK|BX|KG|LB|OZ|L|ML — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Gross selling price per unit of the SKU at the time of order placement, before any discounts or promotions. Represents the consumer-facing price (RSP/MSRP or DTC-specific price). Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Return investigation workflow uses inspection lot data to determine defect source and regulatory hold decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Reference to the specific order line item being returned within the original DTC order. Enables line-level return tracking and partial-order return scenarios.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcOrderLine .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the return request was approved by the consumer service team or automated system. Used for SLA tracking and return processing time analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the shipping carrier handling the return shipment (e.g., UPS, FedEx, USPS, DHL). Used for carrier performance analysis, reverse logistics cost allocation, and carrier claims for damaged-in-transit returns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Consumer Satisfaction Score' ;
    rdfs:comment 'Post-return consumer satisfaction rating collected via survey (typically 1–5 or 1–10 scale). Used as an input to Net Promoter Score (NPS) calculations and consumer experience improvement programs. Collected via Salesforce Consumer Goods Cloud post-return survey.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the returned product after quality inspection. Drives inventory management, COGS impact, and regulatory compliance for product destruction. Valid values: restock (return to sellable inventory), refurbish (rework required), destroy (product destroyed per policy), return_to_vendor (sent back to supplier), quarantine (held pending investigation).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Flag' ;
    rdfs:comment 'Indicates whether this return has been flagged for manual fraud review based on fraud_risk_score or other risk signals. Supports loss prevention workflows and return abuse management.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Numeric risk score (0.00–100.00) assigned by the fraud detection system to assess the likelihood of return fraud. Drives manual review routing and automated rejection thresholds. Supports loss prevention analytics.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointsRefunded rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Refunded' ;
    rdfs:comment 'Number of loyalty program points credited back to the consumer\'s account as part of the refund. Populated when refund_method is \'loyalty_points\' or when loyalty points were originally redeemed on the order. Supports loyalty program financial reconciliation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'Net monetary amount actually refunded to the consumer after deducting any restocking fees or adjustments from the gross refund amount. Used for financial settlement and consumer account reconciliation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productConditionCode rdf:type rdf:Property ;
    rdfs:label 'Product Condition Code' ;
    rdfs:comment 'Assessed condition of the returned product upon receipt at the warehouse. Determines disposition (restock, refurbish, destroy) and impacts inventory valuation. Assessed by warehouse quality inspection team per GMP guidelines.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectCode rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Code' ;
    rdfs:comment 'Standardized quality defect classification code assigned when the return reason indicates a product quality issue (defective, damaged). Feeds into the Quality Management (QM) system for defect trending, root cause analysis, and regulatory reporting. Sourced from SAP QM or Siemens Opcenter MES quality module.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date on which the returned product was physically received at the warehouse or returns processing center. Triggers refund processing and inventory restock workflows. Sourced from Blue Yonder WMS goods receipt.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Gross monetary amount to be refunded or already refunded to the consumer, in the transaction currency. Represents the base refund before any deductions such as restocking fees. Used for financial reconciliation and COGS impact reporting.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Issued Date' ;
    rdfs:comment 'Date on which the refund was issued to the consumer. Used for financial reconciliation, Days Sales Outstanding (DSO) adjustment, and consumer satisfaction SLA measurement.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund is issued to the consumer. Drives financial processing workflows and consumer communication. Valid values: original_payment (refund to original payment instrument), store_credit (credit to consumer account), loyalty_points (converted to loyalty program points), bank_transfer (direct bank transfer), gift_card (issued as gift card value).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required' ;
    rdfs:comment 'Indicates whether this return requires submission of a regulatory report to a governing body (FDA, CPSC, EPA). Driven by safety_incident_flag, product category, and jurisdiction. Supports compliance workflow automation and audit readiness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the return request was rejected. Populated only when return_status is \'rejected\'. Used for consumer communication SLA tracking and dispute resolution analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason code explaining why the return request was rejected. Populated only when return_status is \'rejected\'. Supports consumer dispute resolution and return policy analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the consumer submitted the return request. Used for SLA measurement, return window eligibility validation, and trend reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the consumer submitted the return request. Used for SLA measurement at sub-day granularity and audit trail purposes.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee deducted from the refund amount to cover reverse logistics and restocking costs, where applicable per return policy. Used for net refund calculation and cost recovery reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnChannel rdf:type rdf:Property ;
    rdfs:label 'Return Channel' ;
    rdfs:comment 'Digital or service channel through which the consumer initiated the return request. Distinct from return method (physical logistics). Used for channel analytics and consumer experience optimization.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Label Tracking Number' ;
    rdfs:comment 'Carrier tracking number assigned to the prepaid return shipping label issued to the consumer. Enables reverse logistics tracking and proof-of-return verification. Sourced from Blue Yonder WMS or carrier integration.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'Physical method by which the consumer returns the product. Determines logistics handling, prepaid label issuance, and reverse logistics cost allocation. Valid values: mail_in (consumer ships via postal/courier), drop_off (consumer drops at designated location), carrier_pickup (carrier collects from consumer address), in_store (returned at retail partner location).' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'Externally-visible, human-readable Return Merchandise Authorization (RMA) number assigned to this return request. Used in consumer communications, shipping labels, and customer service interactions. Sourced from Salesforce Consumer Goods Cloud or SAP SD returns order.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Return Policy Version' ;
    rdfs:comment 'Version identifier of the return policy that was in effect at the time the return was requested. Ensures consistent policy application and supports audit trails for policy change impact analysis.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Number of units of the product being returned in this return request. Used for inventory restock planning, refund calculation, and return rate KPI computation.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the consumer describing the specific reason for the return. Supplements the standardized return reason code with qualitative detail for quality analysis and consumer service resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle state of the return request. Tracks the return workflow from initial consumer request through final resolution. Valid values: requested (consumer submitted), approved (return authorized), received (item received at warehouse), refunded (refund issued), rejected (return denied), cancelled (consumer cancelled). [ENUM-REF-CANDIDATE: requested|approved|received|refunded|rejected|cancelled — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowEligible rdf:type rdf:Property ;
    rdfs:label 'Return Window Eligible' ;
    rdfs:comment 'Indicates whether the return request was submitted within the brand\'s published return policy window (e.g., 30 days from delivery). Drives automated approval/rejection workflows and consumer communication.' ;
    rdfs:domain ind:DtcReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether the return involves a consumer safety incident (e.g., injury, adverse reaction, product hazard). When true, triggers mandatory regulatory reporting workflows to FDA, CPSC, or EPA as applicable. Critical for product safety compliance and recall management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique surrogate identifier for the household record in the Consumer Goods lakehouse. Primary key for all household-level analytics, loyalty pooling, and basket analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:mergedFromHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged From Household Id' ;
    rdfs:comment 'Reference to the source household record that was merged into this household during deduplication or household consolidation. Null if no merge has occurred. Supports data lineage and audit trails.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:panelId rdf:type rdf:Property ;
    rdfs:label 'Panel Id' ;
    rdfs:comment 'External identifier assigned to the household by the consumer research panel provider (e.g., Nielsen IQ). Used for cross-referencing panel purchase diary data with internal CRM and loyalty records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:brandAffinityFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Flag' ;
    rdfs:comment 'Indicates whether the household has demonstrated strong brand loyalty to the company\'s portfolio based on repeat purchase patterns and SOV (Share of Voice) analysis. Used for brand marketing investment decisions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the household has exercised the right to opt out of the sale of personal information under CCPA (California Consumer Privacy Act). Mandatory compliance field for California-resident households.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childrenPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Children Present Flag' ;
    rdfs:comment 'Indicates whether children under 18 are present in the household. Key trigger for cross-sell targeting of baby, child health, and family-oriented CPG/FMCG product categories.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvBand rdf:type rdf:Property ;
    rdfs:label 'Cltv Band' ;
    rdfs:comment 'Categorical CLTV (Customer Lifetime Value) band assigned to the household based on historical purchase behavior and predictive modeling. Used for investment prioritization in trade promotion and personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to any consent or privacy preference for the household. Critical for GDPR/CCPA audit trails and demonstrating lawful basis for data processing.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Originating system or channel from which the household record was first created or last enriched. Used for data lineage, quality scoring, and source system reconciliation in the lakehouse. [ENUM-REF-CANDIDATE: crm|loyalty_program|ecommerce|panel|pos|dtc|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Flag' ;
    rdfs:comment 'Indicates whether the household actively engages with the brand through digital channels (e-commerce, mobile app, social media). Used for DTC (Direct to Consumer) channel strategy and omnichannel personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the household was dissolved, merged, or deactivated. Null for active households. Used for lifecycle reporting and GDPR/CCPA data retention compliance.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dwellingType rdf:type rdf:Property ;
    rdfs:label 'Dwelling Type' ;
    rdfs:comment 'Type of residential dwelling occupied by the household. Used for product category targeting (e.g., home care, cleaning products) and basket size normalization in CPG analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Estimated number of individuals residing in the household. Used for basket size normalization, per-capita consumption analysis, and product volume forecasting in S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date on which the household record was first established in the system, representing when the household unit was recognized as a distinct entity for loyalty and analytics purposes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the household has provided valid consent for data processing under GDPR (General Data Protection Regulation). Mandatory for EU-resident households before any marketing or analytics processing.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broad geographic region of the household\'s residence (e.g., Northeast, Southeast, Midwest, West, Southwest). Used for regional demand planning and distribution channel management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCode rdf:type rdf:Property ;
    rdfs:label 'Household Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the household, used in CRM, loyalty, and DTC channel communications. Distinct from the surrogate primary key.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable label for the household, typically the primary shopper\'s surname or a family name used for display in CRM and loyalty program communications.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle state of the household record. \'merged\' indicates consolidation with another household; \'dissolved\' indicates the household no longer exists as a unit.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Categorical classification of the household composition used for segmentation and cross-sell targeting in CPG/FMCG analytics. [ENUM-REF-CANDIDATE: single|couple|family|multi_generational|shared_living|other — promote to reference product if values expand]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Estimated annual household income bracket used for consumer segmentation, RSP (Recommended Selling Price) sensitivity analysis, and premium product targeting. Derived from third-party panel data or self-reported.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeStage rdf:type rdf:Property ;
    rdfs:label 'Life Stage' ;
    rdfs:comment 'Life stage classification of the household used for targeted marketing and NPD (New Product Development) insights (e.g., young_single, young_couple_no_children, family_with_young_children, family_with_teens, empty_nester, retired). Enables cross-sell triggers such as recommending baby products when life stage transitions. [ENUM-REF-CANDIDATE: young_single|young_couple_no_children|family_with_young_children|family_with_teens|empty_nester|retired|other — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the household was enrolled in the loyalty program. Used to calculate loyalty tenure, tier progression timelines, and CLTV (Customer Lifetime Value) cohort analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current unredeemed loyalty points balance accumulated at the household level across all member consumers. Supports household-level pooling for CPG/FMCG loyalty programs.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current loyalty program tier of the household based on cumulative purchase activity. Drives reward multipliers, exclusive offers, and CLTV (Customer Lifetime Value) segmentation.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Strategic consumer market segment assigned to the household for brand marketing and consumer engagement programs (e.g., health_conscious, value_seeker, premium_buyer, eco_friendly). [ENUM-REF-CANDIDATE: health_conscious|value_seeker|premium_buyer|eco_friendly|convenience_driven|brand_loyal — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing communications (email, SMS, push notifications) from the brand. Governs eligibility for trade promotion and consumer engagement campaigns.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent NPS (Net Promoter Score) survey response was recorded for the household. Used to assess recency of satisfaction data for consumer engagement decisions.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:panelMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Panel Member Flag' ;
    rdfs:comment 'Indicates whether the household is an active member of a consumer research panel (e.g., Nielsen IQ Consumer Panel). Panel households provide purchase diary data used for market intelligence and SOM (Share of Market) analysis.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:petOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Pet Owner Flag' ;
    rdfs:comment 'Indicates whether the household owns pets. Used for targeted marketing of pet care product categories and cross-sell recommendations within the CPG/FMCG portfolio.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRetailerBanner rdf:type rdf:Property ;
    rdfs:label 'Primary Retailer Banner' ;
    rdfs:comment 'The retail banner or chain where the household conducts the majority of its grocery or consumer goods shopping (e.g., Walmart, Target, Kroger). Used for OSA (On Shelf Availability) and POG (Planogram) analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelBuyerFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Buyer Flag' ;
    rdfs:comment 'Indicates whether the household regularly purchases private label or store-brand products in addition to or instead of branded CPG products. Used for competitive analysis and brand switching risk assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Band' ;
    rdfs:comment 'Categorical band representing how frequently the household makes purchases across CPG/FMCG categories. Derived from POS (Point of Sale) transaction history and used for demand sensing and replenishment planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureType rdf:type rdf:Property ;
    rdfs:label 'Tenure Type' ;
    rdfs:comment 'Indicates whether the household owns or rents their residence. Used for home improvement and home care product category targeting and consumer segmentation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityLinkId rdf:type rdf:Property ;
    rdfs:label 'Identity Link Id' ;
    rdfs:comment 'Unique surrogate primary key for each identity link record in the cross-channel identity resolution graph. Uniquely identifies a single identity token linked to a unified consumer profile.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossDeviceClusterRef rdf:type rdf:Property ;
    rdfs:label 'Cross Device Cluster Ref' ;
    rdfs:comment 'Identifier of the cross-device cluster or device graph node to which this identity token belongs. Groups multiple device_id and cookie_id tokens that are probabilistically inferred to belong to the same physical consumer. Enables cross-device journey stitching, frequency capping, and reach deduplication in digital advertising and personalization campaigns.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Flag' ;
    rdfs:comment 'Boolean flag indicating that this identity token has been flagged as potentially fraudulent, synthetic, or associated with account takeover activity. Flagged identities are quarantined from loyalty program accrual, promotional redemption, and DTC account access pending investigation. Supports CPG brand protection and loyalty fraud prevention programs.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityProvider rdf:type rdf:Property ;
    rdfs:label 'Identity Provider' ;
    rdfs:comment 'The specific identity provider or platform that issued or validated this identity credential. For social_id type: the OAuth provider (e.g., Google, Facebook, Apple). For loyalty_card type: the loyalty program operator. For device_id type: the device ecosystem (e.g., Apple IDFA, Google GAID). For email/phone: the CRM or DTC platform. Critical for federated identity governance and third-party data processor agreements under GDPR Article 28.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityType rdf:type rdf:Property ;
    rdfs:label 'Identity Type' ;
    rdfs:comment 'Categorical classification of the identity token being linked. Defines the channel or credential class: email (email address), phone (mobile/landline number), device_id (mobile or connected device identifier), social_id (social login from OAuth provider), loyalty_card (loyalty program card number), cookie_id (browser or app cookie identifier). Drives resolution logic and PII handling rules per GDPR/CCPA.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityValue rdf:type rdf:Property ;
    rdfs:label 'Identity Value' ;
    rdfs:comment 'The actual tokenized or hashed value of the identity credential (e.g., SHA-256 hashed email address, masked phone number, device advertising ID, loyalty card number). Raw PII values must be hashed or tokenized before storage in the Silver layer per GDPR Article 25 data minimization and CCPA privacy-by-design requirements. Supports deterministic matching in identity resolution pipelines.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityValueHash rdf:type rdf:Property ;
    rdfs:label 'Identity Value Hash' ;
    rdfs:comment 'SHA-256 cryptographic hash of the raw identity value, used for deterministic matching without exposing the underlying PII. Enables privacy-safe identity resolution joins across systems (e.g., hashed email matching with retail partners, clean room environments). Mandatory for cross-partner data collaboration under GDPR Article 28 data processor agreements.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVerifiedOptIn rdf:type rdf:Property ;
    rdfs:label 'Is Verified Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the consumer has completed a double opt-in or confirmed opt-in verification for this specific identity token (e.g., email click-through confirmation, SMS reply confirmation). Verified opt-in identities are eligible for direct marketing communications under GDPR Article 7 and CAN-SPAM / TCPA regulatory requirements.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'The most recent date and time this identity token was observed or validated as active across any consumer touchpoint. Used to assess identity freshness, detect stale or abandoned identities, and trigger re-validation workflows. Critical for probabilistic link decay models and identity graph maintenance.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Link Confidence Score' ;
    rdfs:comment 'Numeric probability score between 0.0000 and 1.0000 representing the confidence that this identity token correctly belongs to the resolved consumer profile. Scores above 0.9 indicate high-confidence deterministic matches; scores between 0.5 and 0.9 indicate probabilistic matches requiring periodic re-evaluation. Used to filter identity links for high-stakes personalization, regulatory consent enforcement, and omnichannel reach deduplication.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkDate rdf:type rdf:Property ;
    rdfs:label 'Link Date' ;
    rdfs:comment 'The calendar date on which this identity token was first linked to the unified consumer profile. Used for identity graph aging analysis, link freshness scoring, and regulatory retention period calculations under GDPR Article 5(1)(e) storage limitation principle.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkMethod rdf:type rdf:Property ;
    rdfs:label 'Link Method' ;
    rdfs:comment 'The algorithmic or operational method used to establish the link between this identity token and the unified consumer profile. Deterministic: exact match on a shared identifier (e.g., email). Probabilistic: statistical inference based on behavioral signals, device graphs, or ML models. Federated: identity asserted by a trusted third-party identity provider (e.g., OAuth, SAML). Manual: link established by a human operator or customer service agent override.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the identity link record. Active: the identity is currently associated with the consumer profile. Inactive: the identity is no longer in use but retained for audit. Pending: awaiting validation or confirmation. Suppressed: excluded from processing due to consumer opt-out or regulatory hold. Revoked: explicitly removed following a consumer deletion request (GDPR Right to Erasure / CCPA Right to Delete).' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which this identity token was linked to the unified consumer profile. Provides millisecond-level audit precision required for GDPR Article 30 processing records and real-time identity resolution event logging in the Databricks Silver layer.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Ordinal ranking of this identity token relative to other identities linked to the same consumer profile, within the same identity_type. Rank 1 indicates the primary or most trusted identity of that type. Used to select the canonical identity for outbound communications, personalization targeting, and consumer reach deduplication in omnichannel campaign execution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionRunRef rdf:type rdf:Property ;
    rdfs:label 'Resolution Run Ref' ;
    rdfs:comment 'Identifier of the identity resolution batch or streaming job execution that created or last updated this link. Enables full data lineage tracing from the Silver layer back to the specific ETL/ELT pipeline run, supporting audit, debugging, and regulatory data provenance requirements.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyAccountId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the loyalty program account record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyAccount .

ind:carbonOffsetId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_offset. Business justification: Tracks carbon offset purchases tied to loyalty accounts for reward-based sustainability programs and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffset .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Reference to the loyalty program definition under which this account was created (e.g., brand-specific rewards program, coalition program).' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:referralAccountId rdf:type rdf:Property ;
    rdfs:label 'Referral Account Id' ;
    rdfs:comment 'Loyalty account ID of the existing member who referred this consumer to the program. Used for referral reward attribution, viral growth tracking, and network-effect analysis in consumer retention programs.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyAccount .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible, human-readable membership number assigned to the consumer at enrollment. Printed on loyalty cards, referenced in consumer communications, and used for in-store identification. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty account. \'active\' = fully operational; \'suspended\' = temporarily restricted (e.g., fraud review); \'closed\' = permanently deactivated; \'pending\' = enrollment not yet confirmed; \'frozen\' = points locked pending investigation. Serves as the LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the loyalty account indicating whether it belongs to an individual consumer, a household unit, a small business buyer, or a coalition partner program. Drives eligibility rules and benefit structures.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Consumer\'s current Customer Lifetime Value (CLTV) segment classification derived from purchase history, points activity, and predictive modeling. Used for personalized promotion targeting, retention investment prioritization, and Trade Promotion Optimization (TPO). Not a calculated metric — this is a segment label assigned by the analytics/ML pipeline.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Consumer\'s preferred channel for receiving loyalty program communications (e.g., points balance updates, tier change notifications, promotional offers). Drives outbound communication channel selection in CRM and marketing automation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their loyalty data with third-party partners (e.g., retail partners, coalition program members). Required for GDPR and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive marketing communications related to the loyalty program. Required for GDPR Article 6 lawful basis and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp at which the consumer\'s most recent consent preferences were captured or last updated. Required for GDPR audit trail demonstrating when consent was obtained. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the consumer enrolled in the loyalty program (e.g., web, mobile app, in-store, call center, partner, Direct-to-Consumer (DTC) platform). Used for channel attribution and acquisition cost analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the consumer formally enrolled in the loyalty program. Used to calculate membership tenure, anniversary rewards, and cohort-based retention analytics. Serves as EFFECTIVE_FROM for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentSourceCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Code' ;
    rdfs:comment 'Campaign or promotion source code associated with the consumer\'s enrollment event (e.g., a Trade Promotion Management (TPM) campaign code, QR code identifier, or referral code). Used for acquisition attribution and Trade Promotion Optimization (TPO) ROI analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this loyalty account has been flagged for suspected fraudulent activity (e.g., points manipulation, account takeover, synthetic identity). True = flagged for review; False = no fraud concern. Triggers account suspension workflow.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReviewDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Date' ;
    rdfs:comment 'Date on which the most recent fraud review was conducted or scheduled for this account. Nullable if no fraud review has occurred. Used by the fraud operations team to track investigation timelines.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent qualifying activity (purchase, redemption, or engagement event) on this loyalty account. Used to determine account dormancy, trigger re-engagement campaigns, and apply activity-based points expiry policies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date of the most recent points earn event on this account. Used to assess earn recency for RFM (Recency, Frequency, Monetary) segmentation and to trigger earn-reminder communications.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent points redemption event on this account. Used to assess redemption engagement, identify high-value redeemers, and support personalized redemption offer targeting.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all points ever earned on this account since enrollment, including base earn, bonus earn, and promotional earn events. Never decremented by redemptions or expirations. Used for Customer Lifetime Value (CLTV) calculation and tier qualification history.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Cumulative total of all points that have expired on this account due to inactivity or program rules. Used for points liability release reporting in finance and consumer re-engagement analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Cumulative total of all points ever redeemed on this account since enrollment. Used for redemption rate analysis, points liability reconciliation, and CLTV modeling.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkedCardToken rdf:type rdf:Property ;
    rdfs:label 'Linked Card Token' ;
    rdfs:comment 'Tokenized reference to the consumer\'s linked payment card used for automatic points earn at point-of-sale (POS). Stored as a PCI-compliant token — never the raw card number. Enables card-linked offer (CLO) programs and automatic earn without physical loyalty card presentation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Current loyalty tier of the account reflecting the consumer\'s engagement and spend level (e.g., Standard, Silver, Gold, Platinum, Elite). Determines benefit multipliers, exclusive offers, and service levels. Reviewed periodically against tier_qualification_spend.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date on which the consumer formally opted out of the loyalty program or withdrew consent for data processing. Nullable if the consumer has not opted out. Required for GDPR right-to-erasure and CCPA opt-out compliance tracking.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current redeemable points balance on the loyalty account as of the last transaction processing. Represents the net of all earned, redeemed, adjusted, and expired points. Used for consumer-facing balance display and finance points liability reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Points Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the monetary currency in which tier_qualification_spend and redemption values are denominated (e.g., USD, EUR, GBP). Supports multi-currency global loyalty programs.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when unredeemed points on this account expire. Options include rolling 12-month inactivity, annual calendar expiry, never-expire, program-end expiry, or activity-based reset. Drives points liability forecasting and consumer communication triggers.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredRedemptionType rdf:type rdf:Property ;
    rdfs:label 'Preferred Redemption Type' ;
    rdfs:comment 'Consumer\'s stated or inferred preferred method of redeeming loyalty points. Used for personalized redemption offer targeting and program design optimization. [ENUM-REF-CANDIDATE: discount|free_product|gift_card|charity|cashback|experience|travel|merchandise — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'The membership tier held by the consumer immediately before the most recent tier change. Used for tier transition analysis, win-back campaigns, and understanding tier migration patterns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the current membership tier became effective. Used to calculate tier tenure, assess tier stability, and trigger tier-anniversary benefits.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Spend' ;
    rdfs:comment 'Cumulative qualifying purchase spend (in program currency) accumulated within the current tier review period. Compared against tier thresholds to determine tier upgrade, maintenance, or downgrade at the next tier review date.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierReviewDate rdf:type rdf:Property ;
    rdfs:label 'Tier Review Date' ;
    rdfs:comment 'Scheduled date on which the consumer\'s membership tier will be evaluated against tier_qualification_spend thresholds for potential upgrade, maintenance, or downgrade. Drives proactive consumer engagement campaigns before review.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each loyalty points movement event. Serves as the primary key for the loyalty_transaction data product and enables precise audit trail reconciliation of all points currency activity.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Required for accounting loyalty point expense; loyalty_transaction must post expense to a GL account for financial statements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:reversalReferenceLoyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Loyalty Transaction Id' ;
    rdfs:comment 'For reversal-type transactions, the loyalty_transaction_id of the original transaction being reversed. Enables bidirectional audit trail linking between original and reversal entries for points reconciliation.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTransaction .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Reference to the loyalty program tier (e.g., Silver, Gold, Platinum) that was active on the consumer\'s account at the time of this transaction. Tier determines earn rate multipliers and redemption eligibility.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTier .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text narrative entered by a customer service agent or system process explaining the rationale for a manual points adjustment or reversal. Supports audit review and consumer dispute resolution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for manual point adjustments or reversals (e.g., GOODWILL, DATA_CORRECTION, FRAUD_REVERSAL, SYSTEM_ERROR, PROMOTION_CORRECTION). Populated only for adjust and reversal transaction types. [ENUM-REF-CANDIDATE: GOODWILL|DATA_CORRECTION|FRAUD_REVERSAL|SYSTEM_ERROR|PROMOTION_CORRECTION|COMPLAINT_RESOLUTION — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Multiplier' ;
    rdfs:comment 'The multiplier applied to the base earn rate for bonus transactions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null for non-bonus transactions. Used to decompose total points awarded into base and bonus components for TPM ROI analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentVerified rdf:type rdf:Property ;
    rdfs:label 'Consent Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s active consent for loyalty program participation and data processing was verified at the time of this transaction. Supports GDPR Article 7 and CCPA consent audit requirements.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Retention Flag' ;
    rdfs:comment 'Indicates whether this transaction record is subject to a data retention hold, preventing deletion or anonymization beyond the standard retention period. Set to True for records under legal hold, active fraud investigation, or regulatory audit. Supports GDPR right-to-erasure compliance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnRate rdf:type rdf:Property ;
    rdfs:label 'Earn Rate' ;
    rdfs:comment 'The points-per-currency-unit rate applied to calculate the points_amount for earn transactions (e.g., 1.5 points per USD spent). Captures the rate in effect at the time of the transaction for historical accuracy and program performance analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'The outcome of the fraud review process for transactions flagged by the fraud detection system: not_reviewed (default), under_review (investigation in progress), cleared (confirmed legitimate), or confirmed_fraud (fraudulent transaction confirmed and reversed).' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Transaction' ;
    rdfs:comment 'Indicates whether this earn transaction includes a bonus points multiplier applied on top of the base earn rate (e.g., double-points promotion, birthday bonus, new member bonus). Enables separation of base earn from promotional bonus in program cost analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'The monetary equivalent value of the points moved in this transaction, expressed in the program\'s base currency. Used for points liability valuation on the balance sheet and for calculating the cost of loyalty rewards in COGS reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'The absolute number of loyalty points moved in this transaction. Always stored as a positive value regardless of direction; the transaction_type field determines whether points are added or subtracted from the account balance. Supports fractional points for precision in tiered earn-rate calculations.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately after this transaction was applied. Together with points_balance_before, provides the complete before/after audit trail for each points movement event.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately before this transaction was applied. Critical for audit trail completeness and points liability reconciliation required by finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsDirection rdf:type rdf:Property ;
    rdfs:label 'Points Direction' ;
    rdfs:comment 'Indicates whether the points_amount increases (credit) or decreases (debit) the loyalty account balance. Enables double-entry-style reconciliation of the points ledger for finance liability reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'The date on which the points awarded in this earn transaction are scheduled to expire per the loyalty program\'s currency expiration policy. Null for non-earn transactions. Drives the points liability aging schedule reported to finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Points Liability Flag' ;
    rdfs:comment 'Indicates whether this transaction contributes to the outstanding points liability on the company\'s balance sheet (True for unspent earned points, False for redeemed or expired points). Supports finance\'s points liability reserve calculation under GAAP/IFRS.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time at which the loyalty transaction was processed and posted to the account balance by the loyalty engine. May differ from transaction_timestamp due to batch processing windows or pending verification holds.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The fiscal or calendar year of the loyalty program in which this transaction occurred. Used for annual points balance resets, year-over-year program performance reporting, and points expiration policy enforcement.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'The net purchase amount (after discounts, excluding taxes) on the triggering order that qualified for points earning. Used to verify earn rate calculations and supports COGS and loyalty cost-per-transaction reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionValue rdf:type rdf:Property ;
    rdfs:label 'Redemption Value' ;
    rdfs:comment 'The monetary discount or reward value applied to the consumer\'s order when points are redeemed. Populated only for redeem-type transactions. Used to calculate the effective discount rate and redemption liability release in financial reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Ref' ;
    rdfs:comment 'The native transaction identifier from the originating source system (e.g., Salesforce record ID, SAP document number, POS receipt number). Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the loyalty transaction, formatted as LT-{YYYY}-{sequence}. Used in consumer-facing communications, call-centre lookups, and points dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current workflow state of the loyalty transaction reflecting its processing lifecycle: pending (awaiting confirmation), processed (successfully posted to account), reversed (cancelled after posting), failed (processing error), or cancelled (voided before posting).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the loyalty points movement event occurred in the real world — i.e., when the triggering business event (purchase, referral, etc.) was confirmed and points were posted. This is the principal business event timestamp, distinct from system audit timestamps.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Categorical discriminator identifying the nature of the points movement: earn (points awarded), redeem (points consumed), adjust (manual correction), expire (points lapsed per program rules), transfer (inter-account movement), or reversal (cancellation of a prior transaction). [ENUM-REF-CANDIDATE: earn|redeem|adjust|expire|transfer|reversal — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The specific business event that initiated this points movement, such as purchase, referral, product_review, birthday_bonus, promotion_bonus, account_registration, social_share, or survey_completion. Drives attribution analysis and program ROI reporting. [ENUM-REF-CANDIDATE: purchase|referral|product_review|birthday_bonus|promotion_bonus|account_registration|social_share|survey_completion — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsResponseId rdf:type rdf:Property ;
    rdfs:label 'Nps Response Id' ;
    rdfs:comment 'Unique surrogate identifier for each NPS survey response record in the Consumer Goods consumer feedback system. Primary key for the nps_response data product.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Reference to the NPS survey definition or campaign that triggered this response. Links to the survey master record defining the questionnaire, target audience, and campaign parameters.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Survey .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Name of the CPG brand being evaluated in this NPS survey response. Stored denormalized for direct use in brand health reporting and consumer sentiment dashboards without requiring a join to the brand master.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedLoopActionDate rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Action Date' ;
    rdfs:comment 'Date on which the closed-loop follow-up action was completed or resolved for this NPS response. Used to measure response time SLA compliance for consumer feedback management programs.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedLoopStatus rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Status' ;
    rdfs:comment 'Status of the closed-loop consumer feedback management action triggered by this NPS response. Tracks whether a follow-up action has been initiated, is in progress, resolved, or escalated — particularly critical for Detractor responses to recover consumer relationships.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer provided valid consent for their NPS survey response data to be collected, stored, and used for brand analytics and personalization purposes. Mandatory for GDPR and CCPA compliance in consumer data processing.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerSegment rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment' ;
    rdfs:comment 'Marketing segmentation label assigned to the consumer at the time of survey dispatch (e.g., Loyalist, Occasional Buyer, Lapsed, New Consumer). Enables NPS analysis by consumer segment for targeted closed-loop follow-up and personalization programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this NPS response was ingested into the Databricks Silver Layer (e.g., Salesforce Consumer Goods Cloud, SAP S/4HANA, TradeEdge, Nielsen IQ, Custom Survey Platform, Third-Party Panel). Supports data lineage and audit traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Flag' ;
    rdfs:comment 'Indicates whether the consumer who submitted this NPS response is an active member of the brand\'s loyalty program at the time of survey. Enables comparison of NPS scores between loyalty members and non-members for CLTV and retention analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The consumer goods product category associated with the surveyed product or brand (e.g., Personal Care, Household Cleaning, Health & Wellness, Food & Beverage). Enables NPS benchmarking and brand health analysis at the category level for portfolio management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Purchase Channel' ;
    rdfs:comment 'The retail or distribution channel through which the consumer purchased the product prior to receiving this NPS survey (e.g., E-Commerce, Retail Store, DTC, Wholesale, DSD, Pharmacy). Enables channel-level NPS benchmarking for distribution and channel management strategy.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderReference rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Reference' ;
    rdfs:comment 'Reference to the consumer\'s purchase transaction (order number or POS transaction ID) that triggered this post-purchase NPS survey. Enables linkage of NPS scores to specific purchase events for CLTV and consumer journey analytics.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatBuyerFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Buyer Flag' ;
    rdfs:comment 'Indicates whether the consumer had made more than one purchase of the brand or product prior to submitting this NPS response. Enables differentiation of NPS scores between first-time and repeat buyers for consumer retention and NPD analytics.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentCategory rdf:type rdf:Property ;
    rdfs:label 'Respondent Category' ;
    rdfs:comment 'Classification of the consumer based on their NPS score: Promoter (score 9-10), Passive (score 7-8), or Detractor (score 0-6). Derived classification stored for direct use in brand health dashboards, consumer segmentation, and closed-loop follow-up prioritization.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Response Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this NPS survey response, used for closed-loop follow-up, consumer service case creation, and cross-system traceability (e.g., CRM ticket linkage).' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the NPS survey response record: Submitted (complete response received), Partial (survey started but not completed), Abandoned (survey opened but no score entered), Invalid (failed validation rules), Closed (response processed and closed-loop action completed).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the consumer submitted the NPS survey response. Enables intraday analysis, response latency measurement, and audit trail for closed-loop feedback management.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retailerName rdf:type rdf:Property ;
    rdfs:label 'Retailer Name' ;
    rdfs:comment 'Name of the retail account or e-commerce platform where the consumer purchased the product. Enables retailer-level NPS analysis to support trade promotion management (TPM) and retail execution decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The SKU identifier of the specific product variant evaluated in this NPS survey response. Nullable when the survey is brand-level rather than product-level. Enables product-level NPS analysis for NPD and PLM decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceResponseRef rdf:type rdf:Property ;
    rdfs:label 'Source Response Ref' ;
    rdfs:comment 'The native identifier of this NPS response record in the originating operational system of record (e.g., Salesforce Survey Response ID, SAP interaction record ID). Enables cross-system traceability and deduplication during Silver Layer ingestion.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'The communication channel through which the NPS survey was delivered to the consumer (e.g., Email, In-App, SMS, Post-Purchase, Web, IVR). Enables channel-level response rate analysis and omnichannel consumer engagement optimization. [ENUM-REF-CANDIDATE: Email|In-App|SMS|Post-Purchase|Web|IVR — promote to reference product]' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'Calendar date on which the consumer submitted the NPS survey response. Used as the primary business event date for brand health trend analysis, period-over-period NPS reporting, and S&OP consumer sentiment inputs.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Survey Trigger Event' ;
    rdfs:comment 'The business event that triggered the dispatch of this NPS survey to the consumer (e.g., Post-Purchase, Post-Delivery, Post-Support interaction, Periodic relationship survey, Event-Based, Onboarding). Enables analysis of NPS scores by consumer journey touchpoint.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the NPS survey questionnaire used to capture this response. Ensures comparability of NPS scores across survey redesigns and supports longitudinal brand health trend analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicTags rdf:type rdf:Property ;
    rdfs:label 'Topic Tags' ;
    rdfs:comment 'Comma-separated list of business topic labels extracted from the verbatim comment via NLP text classification (e.g., \'packaging,scent,value-for-money,availability\'). Enables topic-level consumer feedback analysis for product development, quality, and marketing teams.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimComment rdf:type rdf:Property ;
    rdfs:label 'Verbatim Comment' ;
    rdfs:comment 'Free-text open-ended comment provided by the consumer explaining their NPS score. Contains qualitative consumer sentiment, product feedback, and brand perception insights used for text analytics, sentiment analysis, and AI/ML-driven consumer intelligence programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer preference record in the Consumer Goods lakehouse silver layer. Primary key for the preference data product.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingProfileId rdf:type rdf:Property ;
    rdfs:label 'Packaging Profile Id' ;
    rdfs:comment 'Foreign key linking to sustainability.packaging_profile. Business justification: Links consumer packaging preferences to specific packaging profiles to guide sustainable packaging design decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingProfile .

ind:brandOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Override Flag' ;
    rdfs:comment 'Indicates whether this preference record has been overridden at the brand level, superseding the consumer\'s global preference. When True, the brand_id field identifies which brand applied the override. Enables brand-specific preference management within a multi-brand CPG portfolio.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Brand Override Reason' ;
    rdfs:comment 'The business reason for the brand-level preference override when brand_override_flag is True. Used for audit trails and compliance reporting, particularly for regulatory restrictions (e.g., FDA, CPSC product safety communications).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Numeric confidence level (0.0000 to 1.0000) assigned to this preference record, particularly relevant for ML-inferred preferences. A score of 1.0 indicates absolute certainty (typically for declared preferences); lower scores indicate inferred preferences with varying degrees of model confidence. Used by recommendation systems to weight preference signals.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSubjectRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Flag' ;
    rdfs:comment 'Indicates whether this preference record is subject to an active Data Subject Request (DSR) under GDPR or CCPA (e.g., right to erasure, right to access, right to portability). When True, downstream systems must apply appropriate data handling restrictions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flavorFragrancePreference rdf:type rdf:Property ;
    rdfs:label 'Flavor Fragrance Preference' ;
    rdfs:comment 'The consumer\'s preferred flavor (for food/beverage/oral care) or fragrance (for personal care/household products). Drives variant-level recommendations and new product development (NPD) consumer insights. Aligns with INCI nomenclature for fragrance ingredients.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceBasis rdf:type rdf:Property ;
    rdfs:label 'Inference Basis' ;
    rdfs:comment 'The data signal or behavioral evidence used to infer this preference when preference_source is ML-inferred. Provides transparency into the inference methodology for model explainability and GDPR Article 22 automated decision-making compliance.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'The version identifier of the ML model used to infer this preference when preference_source is \'inferred_ml\' or \'inferred_purchase_history\'. Enables model governance, A/B testing of recommendation algorithms, and reproducibility of inferred preferences for audit purposes.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalPreference rdf:type rdf:Property ;
    rdfs:label 'Is Global Preference' ;
    rdfs:comment 'Indicates whether this preference applies globally across all brands in the CPG portfolio (True) or is specific to a single brand identified by brand_id (False). Global preferences serve as the default when no brand-specific preference exists.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsSegment rdf:type rdf:Property ;
    rdfs:label 'Nps Segment' ;
    rdfs:comment 'The consumer\'s NPS (Net Promoter Score) segment classification at the time this preference was captured. Used to contextualize preference data — promoters may have stronger brand preferences while detractors may have channel avoidance preferences. Supports consumer engagement strategy.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSizePreference rdf:type rdf:Property ;
    rdfs:label 'Pack Size Preference' ;
    rdfs:comment 'The consumer\'s preferred pack size or format (e.g., \'travel_size\', \'standard\', \'family_size\', \'bulk\', \'subscription_bundle\'). Used to tailor product recommendations and promotional offers to the consumer\'s typical purchase behavior.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level classification of the preference type. Defines what dimension of consumer behavior or communication this preference record governs. [ENUM-REF-CANDIDATE: product_category|brand|flavor_fragrance|pack_size|channel|communication_channel|contact_frequency|preferred_time_of_day|preferred_language — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceRank rdf:type rdf:Property ;
    rdfs:label 'Preference Rank' ;
    rdfs:comment 'Ordinal ranking of this preference value relative to other values within the same category for the same consumer. Rank 1 indicates the most preferred option. Enables ranked preference lists for recommendation engines (e.g., first, second, third flavor choice).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Origin of the preference record indicating whether it was explicitly declared by the consumer through a digital or physical touchpoint, or inferred by an ML model or behavioral analysis. Declared preferences carry higher trust weight in personalization engines. [ENUM-REF-CANDIDATE: declared_web|declared_app|declared_call_center|declared_in_store|inferred_ml|inferred_purchase_history|inferred_survey — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The specific declared or inferred preference value within the category and subcategory. Examples: \'mint\' for flavor, \'English\' for language, \'morning\' for time of day, \'weekly\' for contact frequency, \'email\' for communication channel. Free-form string to accommodate diverse CPG preference dimensions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'The consumer\'s preferred channel for receiving brand communications, promotions, and personalized content. Drives communication orchestration in Salesforce Consumer Goods Cloud and DTC engagement programs. \'none\' indicates the consumer has opted out of all outbound communications. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_app|whatsapp|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactFrequency rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Frequency' ;
    rdfs:comment 'The consumer\'s declared preference for how often they wish to receive brand communications. Used by communication orchestration engines to enforce contact frequency caps and prevent consumer fatigue in CPG engagement programs. [ENUM-REF-CANDIDATE: daily|weekly|bi_weekly|monthly|quarterly|as_needed|never — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimezone rdf:type rdf:Property ;
    rdfs:label 'Preferred Timezone' ;
    rdfs:comment 'The IANA timezone identifier for the consumer\'s preferred timezone (e.g., \'America/New_York\', \'Europe/London\'). Used in conjunction with preferred_time_of_day to schedule communications at the correct local time for global CPG consumer bases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Retail Channel Preference' ;
    rdfs:comment 'The consumer\'s preferred retail channel for purchasing CPG products. Used for channel-specific targeting, trade promotion alignment, and omnichannel engagement strategies. Supports DSD (Direct Store Delivery) and DTC channel optimization. [ENUM-REF-CANDIDATE: ecommerce|grocery|mass_retail|pharmacy|dtc|club_store|convenience|specialty — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuPreference rdf:type rdf:Property ;
    rdfs:label 'Sku Preference' ;
    rdfs:comment 'The specific SKU (Stock Keeping Unit) code that the consumer has declared or demonstrated a preference for. Enables SKU-level personalization and targeted replenishment reminders in DTC and e-commerce channels. Aligns with SAP S/4HANA MM material master.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPreferenceRef rdf:type rdf:Property ;
    rdfs:label 'Source System Preference Ref' ;
    rdfs:comment 'The native identifier of this preference record in the originating source system (e.g., Salesforce Consumer Goods Cloud preference record ID). Enables cross-system reconciliation and EDI-based data exchange between CPG operational systems.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Granular sub-classification within the preference category. For example, within \'product_category\' the subcategory may be \'hair_care\' or \'oral_care\'; within \'communication_channel\' it may be \'email\' or \'push_notification\'. Enables multi-level preference taxonomy for CPG personalization engines.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique system-generated identifier for each consumer referral record in the CPG brand\'s Direct to Consumer (DTC) or loyalty referral program. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Referral program generates sales opportunities; linking referral to opportunity enables attribution and pipeline forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:referralReferredConsumerShopperId rdf:type rdf:Property ;
    rdfs:label 'Referral Referred Consumer Shopper Id' ;
    rdfs:comment 'Identifier of the new consumer (referee) who was referred. Populated upon registration or conversion; may be null if the referred party has not yet created an account.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:referralShopperId rdf:type rdf:Property ;
    rdfs:label 'Referral Shopper Id' ;
    rdfs:comment 'Identifier of the existing consumer (referrer) who initiated the referral. Links to the consumer master record in the Single Source of Truth (SSOT) consumer domain.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The business channel through which the referral program is operating — Direct to Consumer (DTC), loyalty app, e-commerce, or mobile app. Supports channel-level acquisition performance analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential count of referral attempts made by the same referrer within the same program period. Supports referral frequency capping and reward abuse detection.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Click Timestamp' ;
    rdfs:comment 'Timestamp when the referred consumer first clicked or opened the referral link. Null if the referral has not been clicked. Used to measure referral engagement latency.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date on which the referred consumer completed the qualifying conversion action (e.g., first purchase, loyalty enrollment). Null if not yet converted. Key metric for referral program Return on Investment (ROI) measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysToConvert rdf:type rdf:Property ;
    rdfs:label 'Days To Convert' ;
    rdfs:comment 'Number of calendar days elapsed between the referral_date and the conversion_date. Null if not yet converted. Stored as an operational field in the referral management system to support referral velocity and program effectiveness analytics without requiring real-time calculation.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medium rdf:type rdf:Property ;
    rdfs:label 'Medium' ;
    rdfs:comment 'The media classification of the referral distribution (organic, paid, owned, earned). Supports Share of Voice (SOV) and word-of-mouth acquisition analytics.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingActionType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Action Type' ;
    rdfs:comment 'The specific consumer action required for the referral to be counted as converted. Defines the conversion event tracked against the referral record.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to this referral event, shared by the referrer with the prospective consumer via email, social share, or referral link. Acts as the externally-known business identifier for the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'The principal business event timestamp recording when the referral was initiated by the referrer. Used as the primary event time for referral program performance reporting.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle state of the referral record. sent = referral issued but not yet acted upon; clicked = referred party opened the referral link; converted = referred party completed the qualifying action; expired = referral window elapsed without conversion; cancelled = referral voided by program rules or fraud review.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredRewardStatus rdf:type rdf:Property ;
    rdfs:label 'Referred Reward Status' ;
    rdfs:comment 'Current fulfillment status of the reward owed to the referred consumer. Tracks the reward lifecycle from pending issuance through redemption or expiry.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredRewardType rdf:type rdf:Property ;
    rdfs:label 'Referred Reward Type' ;
    rdfs:comment 'The type of reward earned by the referred (new) consumer upon completing the qualifying conversion action. Incentivizes the referred party to complete the sign-up or first purchase.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredRewardValue rdf:type rdf:Property ;
    rdfs:label 'Referred Reward Value' ;
    rdfs:comment 'The monetary or points value of the reward earned by the referred consumer upon conversion. Expressed in the program\'s reward currency (points or monetary unit per currency_code).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referrerRewardStatus rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Status' ;
    rdfs:comment 'Current fulfillment status of the reward owed to the referrer. Tracks the reward lifecycle from pending issuance through redemption or expiry.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardType rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Type' ;
    rdfs:comment 'The type of reward earned by the referrer upon successful conversion of the referred consumer. Determines how the reward is fulfilled within the loyalty or Direct to Consumer (DTC) platform.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardValue rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Value' ;
    rdfs:comment 'The monetary or points value of the reward earned by the referrer upon successful referral conversion. Expressed in the program\'s reward currency (points or monetary unit per currency_code).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Flag' ;
    rdfs:comment 'Indicates whether a follow-up reminder communication was sent to the referred consumer to encourage conversion before the referral expiry date.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Timestamp' ;
    rdfs:comment 'Timestamp of the most recent reminder communication sent to the referred consumer. Null if no reminder has been sent.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:selfReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Self Referral Flag' ;
    rdfs:comment 'Indicates whether the referrer and referred consumer are determined to be the same individual (e.g., same device, same email domain, same household). Used to detect and suppress reward abuse.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:socialPlatform rdf:type rdf:Property ;
    rdfs:label 'Social Platform' ;
    rdfs:comment 'The specific social media platform used when channel is social_share. Enables platform-level referral performance benchmarking. [ENUM-REF-CANDIDATE: facebook|instagram|twitter_x|whatsapp|tiktok|pinterest|snapchat|linkedin|other — promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for each segment membership association record in the consumer domain. Primary key for the segment_membership data product.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationCount rdf:type rdf:Property ;
    rdfs:label 'Activation Count' ;
    rdfs:comment 'The number of times this segment membership has been activated or used in campaign targeting or personalization executions. Supports frequency capping and engagement fatigue management.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the consumer was assigned or enrolled into this segment. Marks the start of the membership period for time-variant tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandAffinityCode rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Code' ;
    rdfs:comment 'Code identifying the specific brand or brand portfolio for which this segment membership is relevant. Enables brand-level personalization and targeted engagement within a multi-brand consumer goods portfolio.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'The cadence at which this segment membership is re-evaluated and potentially updated. Real-time indicates event-driven evaluation; daily/weekly/monthly/quarterly indicate batch evaluation schedules.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlGroup rdf:type rdf:Property ;
    rdfs:label 'Is Control Group' ;
    rdfs:comment 'Flag indicating whether the consumer is assigned to a holdout or control group within this segment for A/B testing or campaign measurement purposes. True indicates the consumer is in the control group and should not receive targeted communications.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Flag indicating whether this segment is the primary or dominant segment for the consumer when multiple segment memberships exist simultaneously. True indicates this is the primary segment used for default personalization.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivationDate rdf:type rdf:Property ;
    rdfs:label 'Last Activation Date' ;
    rdfs:comment 'The most recent date on which this segment membership was used to activate a campaign, promotion, or personalization event. Supports recency analysis and frequency capping in campaign management.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'The date and time when the segment membership was last re-evaluated by the segmentation engine or rule processor. Indicates freshness of the assignment and supports refresh scheduling.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the segment membership record. Active indicates the consumer is currently a member of the segment; expired indicates the membership period has lapsed; suspended indicates temporary hold.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Nps Score At Assignment' ;
    rdfs:comment 'The Net Promoter Score (NPS) of the consumer at the time of segment assignment. Captured as a point-in-time snapshot to contextualize the segmentation decision and support consumer satisfaction analytics.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the consumer has exercised their right to opt out of data-driven segmentation and targeted marketing under CCPA or GDPR. True means the consumer has opted out and this membership must not be used for targeting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text description of the business justification for a manual segment assignment or override. Populated when assignment_method is manual. Required for audit compliance and governance review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The scheduled date for periodic review or re-evaluation of this segment membership. Supports governance processes ensuring segment assignments remain accurate and consent remains valid.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ruleSetCode rdf:type rdf:Property ;
    rdfs:label 'Rule Set Code' ;
    rdfs:comment 'Identifier of the business rule set applied when assignment_method is rule_based. Enables traceability of which rule definition produced the membership assignment.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Numeric priority rank for this segment membership when a consumer belongs to multiple overlapping segments. Lower values indicate higher priority. Used to resolve conflicts in personalization and campaign targeting logic.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Version' ;
    rdfs:comment 'The version identifier of the segment definition that was active at the time of assignment. Enables tracking of membership against evolving segment criteria and supports reproducibility of historical targeting decisions.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the consumer was first acquired or registered in the system (yyyy-MM-dd). Used for cohort analysis, consumer tenure calculations, and lifecycle marketing programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ageVerified rdf:type rdf:Property ;
    rdfs:label 'Age Verified' ;
    rdfs:comment 'Indicates whether the consumer has passed age verification for access to age-restricted products (e.g., alcohol, tobacco, certain health products). TRUE = age verified; FALSE = not verified. Required for regulatory compliance with FDA and CPSC age-restriction mandates.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'The consumer\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification (e.g., age-restricted products), lifecycle segmentation, birthday loyalty rewards, and regulatory compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaSubject rdf:type rdf:Property ;
    rdfs:label 'Ccpa Subject' ;
    rdfs:comment 'Indicates whether this consumer is a California resident subject to CCPA protections. TRUE = CCPA applies; FALSE = not a CCPA subject. Drives opt-out of sale workflows, data deletion requests, and disclosure obligations.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerType rdf:type rdf:Property ;
    rdfs:label 'Consumer Type' ;
    rdfs:comment 'Categorical classification of the shopper record distinguishing individual consumers, household accounts, small business buyers, enrolled loyalty program members, and guest/anonymous shoppers. Drives CRM segmentation and personalization strategy.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their personal data with third-party partners (e.g., retail partners, market research firms such as Nielsen IQ). TRUE = consented; FALSE = not consented. Critical for GDPR Article 6 lawful basis and CCPA opt-out compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The consumer\'s preferred display name or alias used in digital channels, loyalty portals, and personalized marketing communications. May differ from legal name.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive email marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Mandatory suppression flag for GDPR/CCPA compliance in all outbound email campaigns.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The consumer\'s legal family name (surname) as captured at registration or identity verification. Combined with given_name to form the full legal identity for CRM, personalization, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSubject rdf:type rdf:Property ;
    rdfs:label 'Gdpr Subject' ;
    rdfs:comment 'Indicates whether this consumer is a GDPR data subject (i.e., located in the EU/EEA and subject to GDPR protections). TRUE = GDPR applies; FALSE = not a GDPR subject. Drives data processing lawful basis checks, right-to-erasure workflows, and data portability requests.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'The consumer\'s self-reported gender identity. Used for consumer segmentation, personalized product recommendations, and inclusive marketing. Collected with explicit consent per GDPR/CCPA.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The consumer\'s legal given name (first name) as captured at registration or identity verification. Used for personalized communications, CRM, and regulatory subject identification under GDPR/CCPA.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'The date on which the consumer\'s identity was most recently verified (yyyy-MM-dd). Used to assess verification recency and trigger re-verification workflows for high-risk transactions or regulatory audits.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerified rdf:type rdf:Property ;
    rdfs:label 'Identity Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s identity has been formally verified through an identity verification process (e.g., email confirmation, document verification, phone OTP). TRUE = verified; FALSE = unverified. Affects eligibility for high-value loyalty redemptions and DTC account features.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the consumer record in the lifecycle. \'active\' = engaged consumer; \'inactive\' = no activity within defined period; \'opted_out\' = consumer has withdrawn consent and must not be contacted; \'suspended\' = account temporarily restricted; \'pending_verification\' = identity not yet confirmed. Drives GDPR/CCPA suppression logic.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The consumer\'s preferred transaction currency in ISO 4217 three-letter code (e.g., \'USD\', \'EUR\', \'GBP\'). Used for DTC pricing display, loyalty point valuation, and cross-border e-commerce personalization.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredStoreBanner rdf:type rdf:Property ;
    rdfs:label 'Preferred Store Banner' ;
    rdfs:comment 'The consumer\'s self-reported or behaviorally-inferred preferred retail store banner or chain (e.g., \'Walmart\', \'Target\', \'Kroger\'). Used for retail execution targeting, trade promotion personalization, and channel affinity analytics in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address used for all consumer communications, loyalty program enrollment, DTC order confirmations, and digital marketing. Serves as the principal digital identity key in CRM and Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The consumer\'s primary contact phone number in E.164 international format. Used for SMS marketing, two-factor authentication, consumer care, and DTC order notifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the consumer has opted in to receive push notifications via the brand\'s mobile application. TRUE = opted in; FALSE = opted out or not set. Drives mobile engagement campaign eligibility.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Source Url' ;
    rdfs:comment 'The URL or digital touchpoint from which the consumer completed their registration (e.g., brand website landing page, DTC checkout, loyalty sign-up page). Supports digital marketing attribution and campaign source tracking.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive SMS/text marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Required for TCPA compliance in the US and equivalent regulations globally.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemConsumerRef rdf:type rdf:Property ;
    rdfs:label 'Source System Consumer Ref' ;
    rdfs:comment 'The consumer\'s unique identifier as recorded in the originating source system (e.g., SAP Business Partner ID, Salesforce Contact ID, DTC platform user ID). Enables cross-system reconciliation, MDM golden record matching, and audit traceability back to the system of record.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Reference to the consumer\'s preferred delivery address for subscription fulfillment. Links to the address master for DSD (Direct Store Delivery) routing and last-mile logistics planning via Blue Yonder WMS.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract. Business justification: Ensures Subscription sourcing audit linking each consumer subscription to the supplier contract governing the product supply.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Marketing source or campaign that drove the consumer to subscribe (e.g., email campaign code, paid search, influencer referral, loyalty program). Used for marketing ROI (Return on Investment) attribution and SOV (Share of Voice) analysis.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription is configured to automatically renew at the end of each billing cycle (True) or requires explicit consumer action to continue (False). Governs recurring revenue recognition and consumer notification obligations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1–31) on which the subscription billing charge is processed. Governs the recurring payment schedule and aligns with the consumer\'s preferred billing date. Used in accounts receivable and DSO (Days Sales Outstanding) reporting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Calendar date on which the consumer formally cancelled the subscription. Distinct from end_date (which may be a future scheduled end). Used in churn cohort analysis and subscription tenure reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Consumer-stated or system-derived reason for cancelling the subscription. Populated when subscription_status transitions to \'cancelled\'. Critical input for churn analysis, NPS (Net Promoter Score) correlation, and consumer retention strategy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the subscription is scheduled to end or was terminated. Null for open-ended subscriptions. Represents EFFECTIVE_UNTIL for this agreement. Populated on cancellation or plan expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'Cumulative number of failed payment attempts on this subscription since inception. Used to trigger dunning workflows, payment retry logic, and subscription suspension rules. Key indicator for revenue leakage management.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Cadence at which the subscription order is automatically triggered and fulfilled. Drives the replenishment schedule and next order date calculation. Key input for demand planning and S&OP forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Calendar date of the most recently fulfilled subscription order. Used to validate subscription activity, detect stalled subscriptions, and support FEFO (First Expired First Out) inventory allocation for replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Actual amount charged to the consumer per billing cycle after applying the discount rate. Equals subscription_price × (1 - discount_rate). Used in revenue recognition, COGS (Cost of Goods Sold) analysis, and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextOrderDate rdf:type rdf:Property ;
    rdfs:label 'Next Order Date' ;
    rdfs:comment 'Scheduled calendar date for the next automatic order generation under this subscription. Used by fulfillment systems for ATP (Available to Promise) checks and demand sensing. Updated after each successful order cycle.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'Calendar date on which the subscription pause is scheduled to end and auto-replenishment is set to resume. Null if the pause is indefinite. Used in demand forecasting to anticipate reactivation volumes.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseReason rdf:type rdf:Property ;
    rdfs:label 'Pause Reason' ;
    rdfs:comment 'Consumer-stated reason for pausing the subscription. Populated when subscription_status transitions to \'paused\'. Used in consumer retention analysis and proactive re-engagement campaign targeting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'Calendar date on which the consumer-initiated subscription pause became effective. Used to calculate pause duration and adjust next_order_date upon resumption. Supports consumer retention lifecycle tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Category of payment instrument used for recurring subscription billing (e.g., credit_card, digital_wallet). Stored as a type reference only — no raw card or account data is stored here per PCI DSS compliance. Supports payment failure analysis and retry logic.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTokenReference rdf:type rdf:Property ;
    rdfs:label 'Payment Token Reference' ;
    rdfs:comment 'Tokenized reference identifier for the consumer\'s stored payment method, issued by the payment processor vault. Never contains raw card or bank account data. Used to initiate recurring charges without storing PCI-sensitive data. Compliant with PCI DSS tokenization requirements.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Gross price charged to the consumer per billing cycle before any discounts are applied. Expressed in the subscription\'s billing currency. Used in subscription revenue forecasting and CLTV (Customer Lifetime Value) calculations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the subscribed SKU to be fulfilled per order cycle. Drives replenishment volume, inventory reservation, and demand planning inputs for S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the subscription became effective and the first order cycle was initiated. Represents EFFECTIVE_FROM for this agreement. Used in cohort analysis and subscription tenure calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Externally visible, human-readable subscription reference number communicated to the consumer in confirmation emails, invoices, and customer service interactions. Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription. \'active\' = fulfilling orders; \'paused\' = consumer-initiated hold; \'cancelled\' = permanently terminated; \'pending\' = awaiting first payment confirmation; \'expired\' = plan term ended without renewal. Drives LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription program type. \'auto_replenishment\' covers single-SKU DTC replenishment; \'subscription_box\' covers curated multi-product boxes; \'bundle\' covers fixed product bundles; \'trial\' covers introductory trial subscriptions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrdersFulfilled rdf:type rdf:Property ;
    rdfs:label 'Total Orders Fulfilled' ;
    rdfs:comment 'Cumulative count of successfully fulfilled subscription orders since the subscription start date. Non-derived operational counter maintained by the fulfillment system. Used in subscription tenure analysis and OTIF (On Time In Full) performance tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Calendar date on which the trial period ends and standard subscription billing commences. Null for non-trial subscriptions. Used to trigger trial-to-paid conversion communications and revenue recognition timing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Flag' ;
    rdfs:comment 'Indicates whether this subscription was initiated as a trial or introductory offer (True) or as a standard paid subscription (False). Used to segment trial-to-paid conversion analytics and NPD (New Product Development) launch performance.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountAddressId rdf:type rdf:Property ;
    rdfs:label 'Account Address Id' ;
    rdfs:comment 'Unique identifier for the account address record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountAddress .

ind:accountAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Account Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for transactions; inactive addresses are retained for historical reporting; pending addresses await validation; closed addresses are permanently retired.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and building identifier. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, apartment, or unit number. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Additional address line for complex addresses, building names, or delivery instructions. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressName rdf:type rdf:Property ;
    rdfs:label 'Address Name' ;
    rdfs:comment 'Business name or label for this address location (e.g., \'Main Distribution Center\', \'Regional Office - Northeast\', \'Store #1234\').' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationDate rdf:type rdf:Property ;
    rdfs:label 'Address Validation Date' ;
    rdfs:comment 'Date when the address was last validated against postal authority databases. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of address verification against postal authority databases. Validated addresses improve delivery success rates and reduce logistics costs.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions for delivery personnel including receiving hours, dock locations, access codes, contact requirements, and handling instructions. Critical for On Time In Full (OTIF) performance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Specific dock door or bay number for deliveries at warehouse or distribution center locations. Used by carriers and Direct Store Delivery (DSD) drivers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Eligible Flag' ;
    rdfs:comment 'Indicates whether this location is eligible for Direct Store Delivery (DSD) routing (True) or requires warehouse distribution (False). Critical for route planning and logistics optimization.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLocationQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Location Qualifier' ;
    rdfs:comment 'EDI X12 location qualifier code used in Electronic Data Interchange (EDI) transactions to identify the address role (e.g., ST for ship-to, BT for bill-to, SF for ship-from). Supports automated order processing and Advanced Shipping Notice (ASN) generation.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number uniquely identifying this physical location in the global supply chain. 13-digit numeric identifier used for EDI transactions and supply chain visibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactivationReason rdf:type rdf:Property ;
    rdfs:label 'Inactivation Reason' ;
    rdfs:comment 'Business reason for address inactivation (e.g., location closed, address changed, account terminated, consolidation). Used for audit trails and business intelligence.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary address for the account (True) or a secondary/alternate address (False). Used for default shipping and billing operations.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours End' ;
    rdfs:comment 'End time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours Start' ;
    rdfs:comment 'Start time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Standardized Address Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal authority format (True) or remains in original input format (False).' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for sales tax, value-added tax (VAT), or goods and services tax (GST) calculation. Used in invoice generation and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for this location (e.g., America/New_York, America/Chicago, Europe/London). Used for delivery scheduling, service level agreement (SLA) tracking, and On Time In Full (OTIF) calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssortmentId rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Id' ;
    rdfs:comment 'Unique identifier for the account assortment record. Primary key for this entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountAssortment .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assortment Authorization audit requires linking the approving employee to each assortment entry.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productLcaId rdf:type rdf:Property ;
    rdfs:label 'Product Lca Id' ;
    rdfs:comment 'Foreign key linking to sustainability.product_lca. Business justification: Assortment planning uses product LCA data to select SKUs that meet carbon-footprint and water-footprint targets.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductLca .

ind:rdProjectId rdf:type rdf:Property ;
    rdfs:label 'Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.rd_project. Business justification: Assortment Planning Report requires linking each assortment record to the originating R&D project that defined the SKU, enabling traceability from market launch back to development.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdProject .

ind:assortmentType rdf:type rdf:Property ;
    rdfs:label 'Assortment Type' ;
    rdfs:comment 'Classification of the assortment item. Core range items are permanent listings; seasonal items are time-bound; promotional items support trade promotions; new items are recent launches; limited edition items are short-run offerings; test market items are regional trials.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when this assortment listing was formally authorized or approved. Used for compliance and audit purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedDistributionPoints rdf:type rdf:Property ;
    rdfs:label 'Authorized Distribution Points' ;
    rdfs:comment 'The number of store locations or distribution points within the account where this SKU is authorized for sale. Used for TDP and ACV calculations.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryRole rdf:type rdf:Property ;
    rdfs:label 'Category Role' ;
    rdfs:comment 'The strategic role this SKU plays in the category assortment. Destination items drive traffic; routine items are everyday purchases; occasional items are infrequent buys; convenience items are impulse purchases.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'The reference number or identifier of the trade agreement or contract that governs this assortment. Links to master trade agreement documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistDate rdf:type rdf:Property ;
    rdfs:label 'Delist Date' ;
    rdfs:comment 'The date when the product was or will be removed from the authorized assortment. Null for active listings. Used for OSA monitoring and distribution gap analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this SKU is delivered via direct store delivery to this account. True if DSD; false if warehouse delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this SKU is exclusive to this account (not available to other retailers). True if exclusive; false if non-exclusive.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'The most recent date when this SKU was shipped to this account. Used for on-time in-full (OTIF) tracking and distribution monitoring.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchWave rdf:type rdf:Property ;
    rdfs:label 'Launch Wave' ;
    rdfs:comment 'The launch wave or phase identifier for new item introductions. Used to track rollout progress and coordinate new item launch activities.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'The date when the product was first authorized for sale to this account. Marks the start of the assortment agreement for this SKU.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current status of the product listing with the account. Listed indicates active authorization; delisted indicates removal from assortment; pending indicates approval in progress; suspended indicates temporary hold; discontinued indicates permanent removal.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The minimum order quantity agreed between the manufacturer and the account for this SKU. Expressed in the base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'The unit of measure for the minimum order quantity. Defines whether MOQ is expressed in eaches, cases, pallets, layers, or inner packs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramSlotCount rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Count' ;
    rdfs:comment 'The number of shelf facings or slots allocated to this SKU in the retailers planogram. Used for on-shelf availability (OSA) monitoring and space management analysis.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this assortment item is part of a trade promotion or promotional event. True if promotional; false if regular assortment.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this assortment record was last updated in the lakehouse. Used for change tracking and audit purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for vendor managed inventory replenishment with this account. True if VMI-eligible; false otherwise.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the account compliance record. Primary key for this entity.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to regulatory.compliance_obligation. Business justification: Each compliance record must reference the specific regulatory obligation it satisfies, supporting the Compliance Obligation Tracking report used by legal and risk teams.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceObligation .

ind:environmentalPermitId rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_permit. Business justification: Compliance records reference the specific environmental permit governing the account\'s operations for regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalPermit .

ind:esgCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Esg Commitment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_commitment. Business justification: ESG compliance reporting links each compliance record to the relevant ESG commitment it satisfies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgCommitment .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance verification reports must capture which employee performed the verification for each record.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceScope rdf:type rdf:Property ;
    rdfs:label 'Compliance Scope' ;
    rdfs:comment 'Describes the scope or coverage of the compliance record, such as specific product categories, geographic regions, or business activities covered by this license or certification.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current lifecycle status of the compliance record. Indicates whether the license or certification is currently valid, expired, pending approval, suspended, or revoked.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'The category of compliance or regulatory requirement. Defines the nature of the license, certification, or regulatory registration required to conduct business with this trade partner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the scanned or digital copy of the compliance document stored in the document management system (e.g., Veeva Vault). Enables audit trail and verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the license, permit, or certification was originally issued by the regulatory authority. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The name of the governmental body, regulatory agency, or certification organization that issued the license or certification (e.g., FDA, EPA, State Department of Health, EU REACH).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country in which the issuing authority operates (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Issuing State Province' ;
    rdfs:comment 'The state, province, or regional subdivision within the issuing country where the license or certification was granted. Relevant for jurisdictions with state-level regulatory requirements.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The most recent date on which this compliance record was successfully renewed. Nullable if never renewed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique alphanumeric identifier assigned by the issuing authority for this license, permit, or certification. Used for verification and audit purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the most recent compliance notification (renewal reminder, expiry alert) was sent. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a renewal or expiry notification has been sent to the account or internal stakeholders. True if notification sent, False otherwise.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the license or certification must be renewed to avoid lapse. Used for proactive compliance monitoring and alerts. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Indicates the current state of the renewal process for this compliance record. Tracks whether renewal is pending, submitted, approved, rejected, or overdue.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the business risk associated with non-compliance or lapse of this record. Critical risk indicates that business cannot be conducted without this compliance in place.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the compliance record was last verified by internal compliance or legal teams. Used to track due diligence and audit readiness. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountContactId rdf:type rdf:Property ;
    rdfs:label 'Account Contact Id' ;
    rdfs:comment 'Unique identifier for the account contact record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountContact .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Reference to another account contact record representing this contact\'s direct manager or supervisor within the trade account organization. Enables organizational hierarchy mapping.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountContact .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'The name of the contact\'s administrative assistant or executive assistant, if applicable. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'The phone number of the contact\'s administrative assistant. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactNotes rdf:type rdf:Property ;
    rdfs:label 'Contact Notes' ;
    rdfs:comment 'Free-form text field for capturing additional notes, preferences, or context about the contact. Used by sales representatives to document relationship insights.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The contact\'s role in the buying decision process. Distinguishes between primary decision-makers, influencers, and administrative contacts. Critical for sales force automation and account planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts are currently employed and engaged with the account. Inactive or terminated contacts are retained for historical reference.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s primary functional role at the trade account. Determines which business processes and communications this contact participates in.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The organizational department or functional area within the trade account where this contact works. Examples include Procurement, Logistics, Finance, Marketing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary business email address for the contact. Used for commercial communications, order confirmations, and business correspondence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the contact, if applicable. Still used in some trade channels for purchase orders and formal documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The given name of the individual contact at the trade account.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The complete formatted name of the contact, typically concatenated as first name and last name. Used for display and reporting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Boolean flag indicating whether this contact has purchasing authority and decision-making power for the account. True if decision maker, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary point of contact for the trade account. True if primary, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position held by the contact at the trade account organization. Examples include Senior Buyer, Category Manager, Supply Chain Director.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The contact\'s preferred language for business communications, represented as a 3-letter ISO 639-2 language code. Examples: ENG (English), SPA (Spanish), FRA (French).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date of the most recent interaction or communication with this contact. Used to track engagement frequency and identify dormant relationships.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The family name or surname of the individual contact at the trade account.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL of the contact\'s LinkedIn professional profile. Used for social selling and relationship intelligence.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact. Used for urgent communications and field-based retail execution activities.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'The scheduled date for the next planned follow-up or interaction with this contact. Supports proactive account management and sales cadence planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial email communications. True if opted in, False if opted out. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial phone communications. True if opted in, False if opted out. Required for telemarketing compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial SMS or text message communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business telephone number for the contact. Includes country code, area code, and local number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method for receiving business communications. Supports personalized engagement strategies in SFA and retail execution workflows.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Code' ;
    rdfs:comment 'The Salesforce user ID of the sales representative or account manager responsible for this contact. Links to the internal sales team member managing the relationship.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'The sales territory or region code to which this contact and their account are assigned. Used for sales force automation and territory management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreditProfileId rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Id' ;
    rdfs:comment 'Unique identifier for the account credit profile record. Primary key.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Remaining credit capacity available for new orders, calculated as credit limit minus current exposure. Used for order release decisions.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankruptcyFilingDate rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Filing Date' ;
    rdfs:comment 'Date when the account filed for bankruptcy. Null if no bankruptcy filing exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankruptcyFlag rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Flag' ;
    rdfs:comment 'Indicates whether this account has filed for bankruptcy or is in bankruptcy proceedings. True = bankruptcy status, False = no bankruptcy.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAnalystNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Analyst Notes' ;
    rdfs:comment 'Free-text notes from the credit analyst documenting credit decisions, risk factors, payment behavior, disputes, and other relevant credit management information.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date when the credit hold was placed on this account. Null if no hold is currently active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason Code' ;
    rdfs:comment 'Code indicating the reason for credit hold (e.g., OVERLIMIT = exceeded credit limit, PASTDUE = overdue invoices, DISPUTE = payment dispute, BANKRUPTCY = customer bankruptcy filing).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Status' ;
    rdfs:comment 'Current credit hold status for this account. Active = credit hold in effect, orders blocked; Released = no hold, orders allowed; Manual Review = requires credit analyst approval; Blocked = permanently blocked.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Amount' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this account. Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether this account is covered by trade credit insurance. True = covered, False = not covered.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Policy number for the trade credit insurance covering this account. Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider (e.g., Euler Hermes, Atradius, Coface). Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure authorized for this trade account, expressed in the account\'s functional currency. Approved by credit management and reviewed periodically.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the credit limit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitOverrideExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Expiry Date' ;
    rdfs:comment 'Expiration date for a temporary credit limit override. After this date, the credit limit reverts to the standard amount. Null if no override is active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Flag' ;
    rdfs:comment 'Indicates whether the credit limit has been manually overridden by credit management (e.g., temporary increase for seasonal demand). True = override active, False = standard limit.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Reason' ;
    rdfs:comment 'Business justification for the credit limit override (e.g., \'Seasonal demand increase for Q4 holiday period\', \'Strategic account expansion\').' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date of the most recent credit review for this account. Credit reviews are typically conducted annually or triggered by significant events (payment default, financial distress).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Current outstanding receivables balance for this account, including open invoices, unbilled deliveries, and pending orders. Updated in real-time from SAP FI-AR.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoActualDays rdf:type rdf:Property ;
    rdfs:label 'Dso Actual Days' ;
    rdfs:comment 'Actual DSO (Days Sales Outstanding) for this account over the trailing 90-day period, calculated as (Average Accounts Receivable / Revenue) × Number of Days.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsoTargetDays rdf:type rdf:Property ;
    rdfs:label 'Dso Target Days' ;
    rdfs:comment 'Target DSO (Days Sales Outstanding) for this account, representing the expected number of days to collect payment. Used for performance monitoring and credit risk assessment.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (collection escalation stage) for this account. 0 = no dunning, 1-9 = escalating collection actions. Higher levels indicate more aggressive collection efforts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'Credit rating from external credit bureau or rating agency (e.g., Dun & Bradstreet PAYDEX score, Experian rating). Format varies by provider.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCreditScore rdf:type rdf:Property ;
    rdfs:label 'External Credit Score' ;
    rdfs:comment 'Numeric credit score from external credit bureau (e.g., PAYDEX score 0-100, FICO commercial score). Higher scores indicate lower risk.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'Internal credit rating assigned by the company\'s credit analysts based on payment history, financial strength, and business relationship. Scale: AAA (highest) to D (default). [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice (collection letter) sent to this account. Null if no dunning has occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this credit profile record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review. Used for credit management workflow and compliance with internal credit policy.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for this account. ACH = Automated Clearing House, Wire = wire transfer, Check = paper check, EDI = Electronic Data Interchange payment, Credit Card = corporate credit card.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms code defining the due date calculation and discount conditions (e.g., NET30, NET60, 2/10NET30, COD). Maps to SAP payment terms master.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Human-readable description of payment terms (e.g., \'Net 30 days\', \'Net 60 days\', \'2% discount if paid within 10 days, net 30\', \'Cash on Delivery\').' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current status of this credit profile record. Active = currently in use, Inactive = historical/superseded, Suspended = temporarily disabled, Under Review = pending credit analyst review.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Overall financial risk classification for this account based on credit rating, payment history, exposure, and external factors. Low = minimal risk, Medium = moderate risk, High = elevated risk, Critical = severe risk.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record. Primary key.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Trade Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy. References the lower-level organizational entity (e.g., store, banner, chain).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Account Id' ;
    rdfs:comment 'Identifier of the parent account in the hierarchy. References the higher-level organizational entity (e.g., banner, chain, parent corporation).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:acvRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Rollup Flag' ;
    rdfs:comment 'Indicates whether All Commodity Volume (ACV) metrics should be rolled up from child to parent account. True means include in ACV aggregation; false means exclude. Critical for market coverage and distribution analysis.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval status of the hierarchical relationship change. Draft indicates the relationship is being defined; pending approval indicates the relationship is awaiting management review; approved indicates the relationship has been validated; rejected indicates the relationship was not approved.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the business user who approved the hierarchical relationship. Used for audit trail and governance purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the hierarchical relationship was approved. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether financial and operational metrics from the child account should be consolidated into the parent account for reporting purposes. True means consolidate; false means report separately. Critical for All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance roll-ups.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account within the hierarchy tree, with 1 representing the top level (parent corporation) and increasing numbers representing deeper levels (chain, banner, store). Used for recursive queries and hierarchy traversal.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Level of the child account within the organizational hierarchy. Store represents individual retail locations; banner represents a retail brand or fascia; chain represents a retail chain or group; parent corporation represents the ultimate parent entity; division represents a business division; region represents a geographic region.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representing the full lineage from root to child account, typically formatted as slash-separated account identifiers (e.g., /1/23/456/7890). Enables efficient ancestor and descendant queries for Sales and Operations Planning (S&OP) and Trade Promotion Management (TPM) reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Type of organizational hierarchy relationship. Commercial hierarchies support sales and trade promotion roll-ups; logistics hierarchies support distribution and delivery planning; financial hierarchies support invoicing and payment consolidation; reporting hierarchies support management reporting structures; legal hierarchies represent corporate ownership; operational hierarchies support day-to-day execution.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or control the parent account has over the child account. Used for proportional consolidation in financial and operational reporting. Range 0.00 to 100.00.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryHierarchyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Hierarchy Flag' ;
    rdfs:comment 'Indicates whether this is the primary hierarchical relationship for the child account when multiple hierarchy types exist. True means this is the default hierarchy for reporting and analytics; false means this is a secondary or alternate hierarchy.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Business code or identifier representing the nature of the parent-child relationship. May include codes for wholly-owned subsidiary, franchise, joint venture, affiliate, or other relationship types specific to the consumer goods trade channel.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipName rdf:type rdf:Property ;
    rdfs:label 'Relationship Name' ;
    rdfs:comment 'Human-readable name or description of the hierarchical relationship. Provides business context for the parent-child linkage (e.g., Regional Banner Group, Corporate Ownership, Distribution Network).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current status of the hierarchical relationship. Active indicates the relationship is currently in effect; inactive indicates the relationship has ended; pending indicates the relationship is awaiting activation; suspended indicates the relationship is temporarily paused; terminated indicates the relationship has been permanently ended.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollupWeight rdf:type rdf:Property ;
    rdfs:label 'Rollup Weight' ;
    rdfs:comment 'Weighting factor applied when rolling up metrics from child to parent account. Used for proportional allocation of All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance when a child account participates in multiple hierarchies or has split ownership.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Rollup Flag' ;
    rdfs:comment 'Indicates whether sales performance metrics should be rolled up from child to parent account. True means include in sales aggregation; false means exclude. Essential for Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Rollup Flag' ;
    rdfs:comment 'Indicates whether Total Distribution Points (TDP) metrics should be rolled up from child to parent account. True means include in TDP aggregation; false means exclude. Essential for numeric distribution and weighted distribution reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeSpendRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Rollup Flag' ;
    rdfs:comment 'Indicates whether trade promotion spending should be rolled up from child to parent account. True means include in trade spend aggregation; false means exclude. Critical for Trade Promotion Management (TPM) and Trade Promotion Optimization (TPO) reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Account Onboarding Id' ;
    rdfs:comment 'Unique surrogate key for each account onboarding record.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountPricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Id' ;
    rdfs:comment 'Reference to the first pricing agreement established during onboarding.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountPricingAgreement .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'Date the trade account was officially activated and began transacting.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicantDunsNumber rdf:type rdf:Property ;
    rdfs:label 'Applicant Duns Number' ;
    rdfs:comment 'Dun & Bradstreet unique identifier for the applicant organization.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Applicant Legal Entity' ;
    rdfs:comment 'Legal name of the organization applying for a trade account.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Assortment Agreement Status' ;
    rdfs:comment 'Status of the product assortment agreement with the trade account.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceChecklistCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Checklist Completed Flag' ;
    rdfs:comment 'Indicates whether all required compliance documents have been submitted and approved.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Application Status' ;
    rdfs:comment 'Lifecycle status of the credit application submitted during onboarding.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Enabled Flag' ;
    rdfs:comment 'Indicates whether the account uses Direct Store Delivery logistics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediSetupMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Milestone Date' ;
    rdfs:comment 'Date the Electronic Data Interchange (EDI) configuration was completed for the account.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date the onboarding agreement ends or is superseded; null if open-ended.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kybStatus rdf:type rdf:Property ;
    rdfs:label 'Kyb Status' ;
    rdfs:comment 'Current status of KYB verification for the applicant.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of KYC verification for the applicant.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingRequestDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Request Date' ;
    rdfs:comment 'Date the onboarding request was submitted by the prospective trade account.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage of the onboarding lifecycle.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding effort (e.g., brand-new account, transfer from another system, reinstatement after suspension).' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'High-level status indicating whether onboarding is ongoing, finished, or halted.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Status' ;
    rdfs:comment 'Status of the pricing agreement (price list, discounts) for the trade account.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentsCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Required Documents Completed Flag' ;
    rdfs:comment 'True when all mandatory legal and compliance documents have been received and validated.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Level' ;
    rdfs:comment 'Risk tier derived from the risk assessment score.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numerical score (0-100) representing the overall risk of onboarding this account.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOsaPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Osa Percent' ;
    rdfs:comment 'Target On-Shelf-Availability service level agreement percentage for the account.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOtifPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otif Percent' ;
    rdfs:comment 'Target On-Time-In-Full service level agreement percentage for the account.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'Planned date for the trade account to become active in the system.' ;
    rdfs:domain ind:AccountOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Indicates whether the account participates in a VMI program.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Reference to the master price list that serves as the base for this agreement. The price list contains SKU-level pricing that may be further adjusted by discounts and rebates defined in this agreement.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:primaryAccountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Manager Employee Id' ;
    rdfs:comment 'The employee ID of the account manager or key account manager responsible for this trade relationship and pricing agreement.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name for the pricing agreement, typically including the account name and agreement period for easy identification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for this pricing agreement, used in contracts and communications with the trade partner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'The current lifecycle status of the pricing agreement. Draft agreements are being negotiated, pending approval agreements await internal authorization, active agreements are in force, suspended agreements are temporarily inactive, expired agreements have passed their end date, and terminated agreements have been cancelled before expiration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the pricing agreement structure. Standard agreements use fixed pricing, promotional agreements support temporary campaigns, volume-based agreements offer discounts based on purchase volume, tiered agreements have multiple pricing levels, custom agreements are negotiated individually, national account agreements cover enterprise-wide terms, and regional agreements apply to specific geographic areas. [ENUM-REF-CANDIDATE: standard|promotional|volume_based|tiered|custom|national_account|regional — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this agreement automatically renews at the end of the effective period. When true, the agreement extends for another term unless either party provides termination notice.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Base Discount Percent' ;
    rdfs:comment 'The negotiated base discount percentage applied to list prices for this account. This is the foundational discount before any volume rebates or promotional allowances.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'The distribution channel through which products are sold under this agreement (e.g., retail, foodservice, wholesale, DTC). Different channels may have different pricing structures.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'The product division or business unit to which this pricing agreement applies (e.g., personal care, household products, health and wellness). Allows different divisions to maintain separate pricing agreements with the same account.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percent' ;
    rdfs:comment 'The discount percentage offered if the account pays invoices before the standard payment due date, incentivizing faster payment.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum order quantity required per order or per SKU to qualify for the negotiated pricing terms. Ensures economical order sizes for manufacturing and logistics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpGuidanceAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Guidance Amount' ;
    rdfs:comment 'The manufacturer\'s suggested retail price for products covered by this agreement. Similar to RSP but typically used for durable goods and higher-value items.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing strategy model applied to this agreement. EDLP (Everyday Low Price) maintains consistent low prices, Hi-Lo (High-Low) uses regular price with frequent promotions, hybrid combines both approaches, cost-plus adds margin to cost, and market-based aligns with competitive market rates.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The tier level assigned to this account within the pricing hierarchy, determining the base discount level. Higher tiers typically receive better pricing based on volume commitments, strategic importance, or relationship strength.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowanceCapAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Cap Amount' ;
    rdfs:comment 'The maximum dollar amount available for promotional allowances during the agreement period. Caps the total promotional funding regardless of purchase volume.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalAllowancePercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Percent' ;
    rdfs:comment 'The negotiated promotional allowance percentage that the account can apply toward trade promotions, displays, and marketing activities. This is a fund allocation for cooperative marketing efforts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of days before the effective end date that either party must provide notice if they wish to terminate rather than renew the agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rspGuidanceAmount rdf:type rdf:Property ;
    rdfs:label 'Rsp Guidance Amount' ;
    rdfs:comment 'The manufacturer\'s recommended selling price guidance provided to the trade account for consumer-facing pricing. This is advisory and not binding, but helps maintain brand positioning and margin expectations.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'The sales organization responsible for managing this pricing agreement. In SAP S/4HANA, this determines the organizational unit that owns the customer relationship and pricing terms.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRebateEnabled rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Enabled' ;
    rdfs:comment 'Indicates whether volume-based rebates are active for this agreement. When true, the account qualifies for additional discounts based on purchase volume thresholds.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeRebatePercent1 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 1' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 1 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebatePercent2 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 2' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 2 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebatePercent3 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 3' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 3 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold1 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 1' ;
    rdfs:comment 'The first volume threshold (in currency or units) that triggers an additional rebate percentage. Represents the minimum purchase volume required to qualify for the first tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold2 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 2' ;
    rdfs:comment 'The second volume threshold that triggers a higher rebate percentage. Represents the purchase volume required to qualify for the second tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold3 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 3' ;
    rdfs:comment 'The third volume threshold that triggers the highest rebate percentage. Represents the purchase volume required to qualify for the third tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountSegmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Id' ;
    rdfs:comment 'Unique identifier for the account segment record. Primary key.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_consumer_segment. Business justification: Account segmentation aligns with marketing consumer segment definitions; the link supports segment-based campaign targeting and ROI analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerSegment .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Identifier of the user or system that assigned this segment classification.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this account segment assignment is currently active and in use for commercial operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acvTier rdf:type rdf:Property ;
    rdfs:label 'Acv Tier' ;
    rdfs:comment 'Tier classification based on All Commodity Volume, representing the total retail sales volume of the account across all product categories.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Geographic region where this segmentation applies (e.g., North America, EMEA, APAC, LATAM).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this segment assignment was formally approved.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedSalesRegion rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Region' ;
    rdfs:comment 'Sales region or territory to which this account segment is assigned for field sales coverage and quota allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelTier rdf:type rdf:Property ;
    rdfs:label 'Channel Tier' ;
    rdfs:comment 'Hierarchical tier assignment within the channel, indicating relative importance or volume contribution (tier_1 = highest, tier_4 = lowest).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitTier rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Tier' ;
    rdfs:comment 'Credit limit tier classification for accounts in this segment, determining maximum outstanding receivables allowed.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer value tier assignment based on revenue, volume, or strategic importance (platinum = highest value, standard = baseline).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether the account is eligible for Direct Store Delivery, bypassing distribution centers for direct product delivery to retail locations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTradingPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Flag' ;
    rdfs:comment 'Indicates whether the account is configured as an EDI trading partner for automated order and invoice exchange.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldSalesCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Field Sales Call Frequency' ;
    rdfs:comment 'Recommended frequency of field sales representative visits based on account segment and strategic priority.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this account segment assignment was last reviewed and validated by commercial leadership.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next review of this account segment assignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifSlaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Pct' ;
    rdfs:comment 'Target percentage for On Time In Full delivery performance as defined in the service level agreement for this account segment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannelCode rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Code' ;
    rdfs:comment 'Code representing the primary channel classification (e.g., RETAIL, FOODSERVICE, WHOLESALE, DTC).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelName rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Name' ;
    rdfs:comment 'Full name of the primary channel (e.g., Retail, Foodservice, Wholesale, Direct to Consumer).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryChannelCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Channel Code' ;
    rdfs:comment 'Code representing the secondary channel sub-classification (e.g., GROCERY, MASS, CLUB, DRUG, CONVENIENCE, ECOMMERCE, QSR, INSTITUTIONAL).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryChannelName rdf:type rdf:Property ;
    rdfs:label 'Secondary Channel Name' ;
    rdfs:comment 'Full name of the secondary channel sub-classification (e.g., Grocery, Mass Merchandiser, Club, Drug, Convenience Store, E-Commerce, Quick Service Restaurant, Institutional).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentReason rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Reason' ;
    rdfs:comment 'Business rationale or trigger for this segment assignment (e.g., annual review, volume threshold met, strategic partnership established).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or algorithm used to assign this segment (e.g., 2024.Q1, V3.2).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Flag' ;
    rdfs:comment 'Indicates whether this account is designated as a strategic priority for executive engagement and resource allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpTier rdf:type rdf:Property ;
    rdfs:label 'Tdp Tier' ;
    rdfs:comment 'Tier classification based on Total Distribution Points, representing the weighted distribution reach of the account.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePromotionEligibility rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligibility' ;
    rdfs:comment 'Eligibility status for trade promotion programs and funding allocation based on segment classification.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSlaId rdf:type rdf:Property ;
    rdfs:label 'Account Sla Id' ;
    rdfs:comment 'Unique identifier for the account service level agreement record. Primary key.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for SLA ownership tracking; SLA records must reference the employee managing the account.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountSlaStatus rdf:type rdf:Property ;
    rdfs:label 'Account Sla Status' ;
    rdfs:comment 'Current lifecycle state of the SLA. Draft indicates pending approval; active indicates in force; suspended indicates temporarily paused; expired indicates end date reached; terminated indicates early cancellation; under review indicates renegotiation in progress.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the SLA automatically renews at the end of the effective period (True) or requires explicit renegotiation (False).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when the SLA terms expire or are scheduled to end. Nullable for open-ended agreements subject to termination notice.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the process and contacts for escalating SLA breaches or disputes. Includes escalation levels, response times, and resolution authority.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Description of circumstances under which SLA performance measurement is suspended or penalties waived (e.g., force majeure, natural disasters, customer-caused delays, system outages).' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Monetary value of incentive per occurrence or per measurement period when SLA target is exceeded. Nullable if incentive is non-monetary or variable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveTerms rdf:type rdf:Property ;
    rdfs:label 'Incentive Terms' ;
    rdfs:comment 'Description of rewards or bonuses provided when performance exceeds the target. May include volume bonuses, preferred status, or co-investment in joint initiatives.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time window over which SLA performance is calculated and reported. Rolling periods provide continuous assessment; fixed periods align with calendar or fiscal cycles. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|rolling_30_days|rolling_90_days — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPerformanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Performance Threshold' ;
    rdfs:comment 'Lowest acceptable performance level before penalties or escalation are triggered. Typically set below the target to allow for minor variance.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name or identifier of the internal commercial, sales, or customer service team responsible for managing this SLA and the account relationship.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary value of penalty per occurrence or per measurement period when SLA is breached. Nullable if penalty is non-monetary or variable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyTerms rdf:type rdf:Property ;
    rdfs:label 'Penalty Terms' ;
    rdfs:comment 'Description of financial or commercial penalties applied when performance falls below the minimum threshold. May include rebates, credits, discounts, or service recovery actions.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Cadence at which SLA performance reports are generated and shared with the account. On-demand indicates ad-hoc reporting upon request. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annual|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Cadence at which the SLA terms are formally reviewed and potentially renegotiated with the account. As-needed indicates event-driven reviews.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Number' ;
    rdfs:comment 'Business identifier for the SLA. Externally-known unique code used in contracts and commercial communications.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service tier classification indicating the level of commitment and priority. Higher tiers typically receive more favorable terms, faster response, and stricter performance guarantees.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of service level commitment. OTIF (On Time In Full) measures delivery timeliness and completeness; fill rate measures order fulfillment percentage; lead time measures order-to-delivery duration; invoice accuracy measures billing correctness; claims resolution measures dispute handling speed; order accuracy measures picking/shipping correctness.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Target Metric Unit' ;
    rdfs:comment 'Unit of measure for the target metric value. Percentage for rate-based metrics (OTIF, fill rate, accuracy); days or hours for time-based metrics (lead time, resolution time); count for volume-based metrics; ratio for comparative metrics.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Quantitative performance target that must be achieved. For OTIF this is percentage (e.g., 95.00 for 95%); for lead time this is days; for fill rate this is percentage; for invoice accuracy this is percentage; for claims resolution this is days.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the SLA before the effective end date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the person who created this SLA record. Audit trail for accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique identifier for each account status change event record. Primary key for the account status history audit trail.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedHistoryAccountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed History Account Status History Id' ;
    rdfs:comment 'Foreign key reference to the original account_status_history record that this entry reverses or corrects. Null if this is not a reversal entry.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountStatusHistory .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this status change required managerial or compliance approval before execution. True if approval workflow was triggered, false if change was auto-approved or did not require approval.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Full name of the approver who authorized the status change. Denormalized for audit readability.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeMethod rdf:type rdf:Property ;
    rdfs:label 'Change Method' ;
    rdfs:comment 'The method by which the status change was executed: manual user action, automated workflow, batch process, API call, or EDI transaction. Distinguishes human-initiated vs system-initiated changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Change Source System' ;
    rdfs:comment 'The operational system or application that originated the status change event (e.g., SAP_SD, SALESFORCE_CG_CLOUD, CREDIT_MANAGEMENT_SYSTEM, EDI_GATEWAY). Used for traceability and system integration audit.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUserName rdf:type rdf:Property ;
    rdfs:label 'Changed By User Name' ;
    rdfs:comment 'Full name of the user who initiated the status change. Denormalized for audit readability and historical reporting when user records may be archived.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Code' ;
    rdfs:comment 'Standardized code identifying the specific compliance violation that triggered a compliance hold or suspension. Null if status change is not compliance-related.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAtChange rdf:type rdf:Property ;
    rdfs:label 'Credit Limit At Change' ;
    rdfs:comment 'The credit limit assigned to the trade account at the time of this status change. Captured for historical credit risk analysis and compliance audit. Expressed in the accounts base currency.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstandingAtChange rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding At Change' ;
    rdfs:comment 'The DSO metric for the trade account at the time of status change. Measures average collection period and provides context for payment-related status transitions.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ediControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Control Number' ;
    rdfs:comment 'The unique control number of the EDI transaction that triggered or communicated this status change. Used for EDI audit trail and reconciliation. Null for non-EDI status changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The EDI transaction set code (e.g., 846 Inventory Inquiry, 997 Functional Acknowledgment) associated with this status change if the change was triggered by or communicated via EDI. Null for non-EDI status changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The scheduled or actual date when a hold status was or will be released. Used for temporary holds with defined resolution timelines. Null for permanent status changes or non-hold statuses.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Specific classification of hold when the new status is a hold state. Distinguishes between credit holds, compliance holds, quality holds, legal holds, and payment holds. Null if status is not a hold state.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the trade account after this change event. Captures the to-state in the account lifecycle transition. [ENUM-REF-CANDIDATE: new|active|on_hold|credit_hold|compliance_hold|suspended|closed|inactive — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when the status change notification was sent. Null if no notification was sent or if notification failed.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingBalanceAtChange rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance At Change' ;
    rdfs:comment 'The total outstanding receivables balance for the trade account at the time of this status change. Provides financial context for credit-related status transitions. Expressed in the accounts base currency.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the trade account immediately before this change event. Captures the from-state in the account lifecycle transition. [ENUM-REF-CANDIDATE: new|active|on_hold|credit_hold|compliance_hold|suspended|closed|inactive — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this status change event must be included in regulatory reporting submissions (e.g., SOX compliance, FDA audit trails, anti-money laundering reports). True if regulatory disclosure is required.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this status change record represents a reversal or correction of a previous status change. True if this is a corrective entry, false for normal status transitions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Impact Flag' ;
    rdfs:comment 'Indicates whether this status change affects the accounts SLA terms or service level commitments. True if SLA metrics or obligations are modified by this status transition.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status change (e.g., CREDIT_LIMIT_EXCEEDED, COMPLIANCE_VIOLATION, CUSTOMER_REQUEST, ACCOUNT_CLOSURE, REACTIVATION_APPROVED). Used for categorization and root cause analysis.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the account status was changed. Provides context beyond the reason code for audit and compliance purposes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'The precise date and time when the account status change was executed in the system. Primary business event timestamp for this audit record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation for this status change (e.g., approval memo, compliance report, customer correspondence, legal notice). Used to link audit trail to source documents.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentChannelClassificationId rdf:type rdf:Property ;
    rdfs:label 'Parent Channel Classification Id' ;
    rdfs:comment 'Reference to the parent channel classification in a hierarchical taxonomy, enabling multi-level channel rollups. Null for top-level classifications.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelClassification .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current lifecycle status of the channel classification. Active classifications are used for account assignment and reporting; inactive classifications are retained for historical reference.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Eligible Flag' ;
    rdfs:comment 'Indicates whether accounts in this channel are eligible for ACV (All Commodity Volume) measurement and reporting. True if channel participates in syndicated retail measurement services.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel classification, including business characteristics, typical account types, and operational considerations.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelFormat rdf:type rdf:Property ;
    rdfs:label 'Channel Format' ;
    rdfs:comment 'Store or outlet format descriptor providing additional context on the physical or digital format (e.g., superstore, neighborhood market, pure-play online, omnichannel).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Full business name of the trade channel (e.g., Grocery Retail, Mass Merchandise, E-Commerce, Quick Service Restaurant).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionModel rdf:type rdf:Property ;
    rdfs:label 'Distribution Model' ;
    rdfs:comment 'Primary distribution model used for this channel: DSD (Direct Store Delivery), warehouse delivery, hybrid, drop ship, or VMI (Vendor Managed Inventory).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether accounts in this channel typically support EDI (Electronic Data Interchange) for order processing, invoicing, and inventory management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Standard lead time in days from order placement to delivery for accounts in this channel.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderFrequency rdf:type rdf:Property ;
    rdfs:label 'Order Frequency' ;
    rdfs:comment 'Typical order frequency pattern for accounts in this channel (daily, weekly, biweekly, monthly, on-demand).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target OTIF (On Time In Full) service level percentage for accounts in this channel, typically defined in SLA (Service Level Agreement) terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsStandard rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Standard' ;
    rdfs:comment 'Standard payment terms typically negotiated with accounts in this channel (e.g., Net 30, Net 60, 2/10 Net 30).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Required Flag' ;
    rdfs:comment 'Indicates whether accounts in this channel typically require POG (Planogram) compliance for shelf placement and merchandising.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posDataAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Data Available Flag' ;
    rdfs:comment 'Indicates whether POS (Point of Sale) data is typically available from accounts in this channel for demand sensing and analytics.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryTier rdf:type rdf:Property ;
    rdfs:label 'Primary Tier' ;
    rdfs:comment 'Top-level classification of the trade channel. Primary tier segments the market into major channel categories.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicy rdf:type rdf:Property ;
    rdfs:label 'Return Policy' ;
    rdfs:comment 'Standard return and unsaleables policy applicable to accounts in this channel (e.g., full credit, partial credit, no returns).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTier rdf:type rdf:Property ;
    rdfs:label 'Secondary Tier' ;
    rdfs:comment 'Sub-classification within the primary tier providing granular channel segmentation (e.g., grocery, mass, club, drug, convenience, e-commerce, QSR - Quick Service Restaurant, institutional, cash and carry, broker). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|ecommerce|qsr|institutional|cash_and_carry|broker — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric value controlling the display sequence of channel classifications in reports and user interfaces.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tdpEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Eligible Flag' ;
    rdfs:comment 'Indicates whether accounts in this channel are eligible for TDP (Total Distribution Points) calculation. True if channel is included in weighted distribution metrics.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tertiaryTier rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tier' ;
    rdfs:comment 'Optional third-level classification for highly specialized channel segments or sub-formats within secondary tier (e.g., natural/organic grocery, dollar stores, online marketplace).' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePromotionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligible Flag' ;
    rdfs:comment 'Indicates whether accounts in this channel are eligible for trade promotion programs, TPM (Trade Promotion Management), and promotional funding.' ;
    rdfs:domain ind:ChannelClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerVmiAgreementId rdf:type rdf:Property ;
    rdfs:label 'Customer Vmi Agreement Id' ;
    rdfs:comment 'Unique identifier for the VMI agreement record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerVmiAgreement .

ind:primaryCustomerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Employee Id' ;
    rdfs:comment 'Reference to the manufacturer employee (demand planner or supply planner) responsible for managing this VMI agreement and executing replenishment decisions.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: VMI program execution requires linking each customer VMI agreement to the supplying vendor for inventory replenishment planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:tertiaryCustomerModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Customer Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified this VMI agreement record. Supports audit and accountability.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract document stored in the document management system (e.g., Veeva Vault, SharePoint).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredSkuCount rdf:type rdf:Property ;
    rdfs:label 'Covered Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs included in the VMI agreement scope. Used for agreement complexity assessment and system configuration.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastSharingCadence rdf:type rdf:Property ;
    rdfs:label 'Forecast Sharing Cadence' ;
    rdfs:comment 'Frequency at which the trade account shares demand forecasts, POS data, or promotional plans with the manufacturer to support VMI planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership Model' ;
    rdfs:comment 'Defines who owns the inventory at the trade account location: customer-owned (traditional), supplier-owned consignment (ownership transfers at sale), shared risk, or pay-on-scan (ownership transfers at POS scan).' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value inventory under this VMI agreement: FIFO (First In First Out), LIFO (Last In First Out), weighted average, or standard cost.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVisibilityMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Visibility Method' ;
    rdfs:comment 'Technical method by which the manufacturer receives inventory position data from the trade account: EDI 846 (inventory inquiry/advice), API integration, web portal access, manual reports, WMS integration, or none.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review meeting or report for this VMI agreement. Used to track review compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxInventoryWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Weeks Of Supply' ;
    rdfs:comment 'Maximum inventory target expressed as weeks of supply. Replenishment orders are sized to bring inventory to this level without exceeding it.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minInventoryWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Min Inventory Weeks Of Supply' ;
    rdfs:comment 'Minimum inventory target expressed as weeks of supply (demand coverage). Triggers replenishment when inventory falls below this threshold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next formal performance review meeting or report. Drives calendar reminders and preparation workflows.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderTransmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Order Transmission Method' ;
    rdfs:comment 'Method by which replenishment orders are transmitted to the trade account or their systems: EDI 850 (purchase order), API, web portal, email, fax, or manual entry.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountPerIncident rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Per Incident' ;
    rdfs:comment 'Fixed financial penalty amount charged per SLA violation incident (e.g., per OOS event, per late delivery). Expressed in the agreement currency.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseEnabled rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Enabled' ;
    rdfs:comment 'Indicates whether the VMI agreement includes financial penalties or chargebacks for SLA violations (e.g., missed OTIF targets, excess OOS incidents).' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Cadence at which the manufacturer and trade account conduct formal performance reviews of VMI metrics (fill rate, OTIF, inventory turns, OOS incidents).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posDataSharingEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Data Sharing Enabled' ;
    rdfs:comment 'Indicates whether the trade account shares real-time or near-real-time POS (point of sale) data with the manufacturer to improve demand sensing accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency' ;
    rdfs:comment 'Cadence at which the manufacturer reviews inventory levels and triggers replenishment orders: daily, twice weekly, weekly, bi-weekly, monthly, on-demand (event-driven), or continuous (real-time). [ENUM-REF-CANDIDATE: daily|twice_weekly|weekly|bi_weekly|monthly|on_demand|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Committed lead time in days from replenishment order creation to delivery at the trade account location. Used for min/max inventory calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockWeeks rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Weeks' ;
    rdfs:comment 'Buffer inventory expressed as weeks of supply to protect against demand variability and supply disruptions. Included in min inventory calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuScopeType rdf:type rdf:Property ;
    rdfs:label 'Sku Scope Type' ;
    rdfs:comment 'Defines the breadth of SKU coverage in the VMI agreement: all SKUs, specific product category, specific brand, explicit SKU list, or custom selection criteria.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Fill Rate Percent' ;
    rdfs:comment 'Contractual target for order fill rate (percentage of ordered quantity delivered) that the manufacturer commits to achieve under this VMI agreement. Typically 95-99%.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOosIncidentsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Sla Target Oos Incidents Per Month' ;
    rdfs:comment 'Maximum allowable number of out-of-stock incidents per month at the trade account location under this VMI agreement. Exceeding this triggers penalty or review clauses.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradePartnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Email' ;
    rdfs:comment 'Email address of the primary trade account contact for VMI communications, forecast sharing, and issue escalation.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePartnerContactName rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the trade account responsible for VMI coordination and issue resolution.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePartnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Phone' ;
    rdfs:comment 'Phone number of the primary trade account contact for urgent VMI issues and escalations.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiProgramType rdf:type rdf:Property ;
    rdfs:label 'Vmi Program Type' ;
    rdfs:comment 'Classification of the VMI program model: full VMI (supplier owns inventory decisions), CMI/Co-Managed Inventory (collaborative), consignment (supplier owns inventory until sale), supplier-managed replenishment, continuous replenishment, or vendor-owned inventory.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTradingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Id' ;
    rdfs:comment 'Unique identifier for the EDI trading partner configuration record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTradingPartner .

ind:acknowledgmentSlaHours rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sla Hours' ;
    rdfs:comment 'The contractual turnaround time (in hours) for Consumer Goods to send functional acknowledgments (997) or business acknowledgments (855) back to the trading partner after receiving an EDI transaction.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:as2Identifier rdf:type rdf:Property ;
    rdfs:label 'As2 Identifier' ;
    rdfs:comment 'The AS2 identifier (AS2-From or AS2-To) used in AS2 message headers when AS2 protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'The communication protocol used to transmit EDI documents between Consumer Goods and the trading partner (e.g., AS2 for secure internet-based exchange, SFTP for file transfer, VAN for value-added network).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'The email address of the primary EDI contact at the trading partner for operational communication and issue escalation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'The name of the primary EDI coordinator or technical contact at the trading partner organization responsible for EDI operations and issue resolution.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'The phone number of the primary EDI contact at the trading partner for urgent operational issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Required' ;
    rdfs:comment 'Indicates whether EDI transmissions must include digital signatures for non-repudiation (common in AS2 protocol).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Edi Go Live Date' ;
    rdfs:comment 'The date when EDI transactions with this trading partner went live in production.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Code' ;
    rdfs:comment 'The unique EDI partner identifier assigned to the trading partner, used in EDI envelope headers (ISA/GS segments) to route transactions.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI messaging standard used for communication with this trading partner (e.g., ANSI X12 for North America, UN/EDIFACT for international).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTradingPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Status' ;
    rdfs:comment 'Current operational status of the EDI trading partner configuration (active for live production, testing for certification phase, inactive for discontinued partners, suspended for temporary holds).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Version' ;
    rdfs:comment 'The specific version of the EDI standard in use (e.g., 004010, 005010 for ANSI X12; D96A, D01B for EDIFACT).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether EDI transmissions with this trading partner must be encrypted (e.g., AS2 with encryption, SFTP with SSH).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentType rdf:type rdf:Property ;
    rdfs:label 'Environment Type' ;
    rdfs:comment 'Indicates whether this EDI configuration is for production transactions, testing/certification, or development purposes.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsQualifier rdf:type rdf:Property ;
    rdfs:label 'Gs Qualifier' ;
    rdfs:comment 'GS application sender/receiver code qualifier that identifies the type of identification being used in the GS segment.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Gs Receiver Code' ;
    rdfs:comment 'The application receiver code used in the GS03 segment, identifying the trading partner as the receiver at the functional group level.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsSenderCode rdf:type rdf:Property ;
    rdfs:label 'Gs Sender Code' ;
    rdfs:comment 'The application sender code used in the GS02 segment, identifying Consumer Goods as the sender at the functional group level.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaQualifier rdf:type rdf:Property ;
    rdfs:label 'Isa Qualifier' ;
    rdfs:comment 'ISA interchange ID qualifier code that identifies the type of identification being used in the ISA segment (e.g., 01=DUNS, 14=DUNS+4, ZZ=Mutually Defined). [ENUM-REF-CANDIDATE: 01|14|20|27|28|29|30|33|ZZ — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Isa Receiver Code' ;
    rdfs:comment 'The receiver identification code used in the ISA08 segment of outbound EDI transactions, representing the trading partner receiving the data.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaSenderCode rdf:type rdf:Property ;
    rdfs:label 'Isa Sender Code' ;
    rdfs:comment 'The sender identification code used in the ISA06 segment of outbound EDI transactions from Consumer Goods to the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdnRequested rdf:type rdf:Property ;
    rdfs:label 'Mdn Requested' ;
    rdfs:comment 'Indicates whether Consumer Goods requests a Message Disposition Notification (MDN) receipt from the trading partner when using AS2 protocol.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Processing Sla Hours' ;
    rdfs:comment 'The contractual turnaround time (in hours) for Consumer Goods to process inbound EDI transactions (e.g., convert 850 PO into sales order) after receipt.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sftpDirectoryInbound rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Inbound' ;
    rdfs:comment 'The directory path on the SFTP server where Consumer Goods retrieves inbound EDI files from the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpDirectoryOutbound rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Outbound' ;
    rdfs:comment 'The directory path on the SFTP server where Consumer Goods deposits outbound EDI files for the trading partner to retrieve.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpHost rdf:type rdf:Property ;
    rdfs:label 'Sftp Host' ;
    rdfs:comment 'The SFTP server hostname or IP address used for file-based EDI exchange when SFTP protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpPort rdf:type rdf:Property ;
    rdfs:label 'Sftp Port' ;
    rdfs:comment 'The TCP port number used for SFTP connections (typically 22).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sftpUsername rdf:type rdf:Property ;
    rdfs:label 'Sftp Username' ;
    rdfs:comment 'The username credential used to authenticate to the trading partner SFTP server.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSet810Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 810 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 810 Invoice transaction sets to the trading partner for billing.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet846Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 846 Enabled' ;
    rdfs:comment 'Indicates whether inventory position data is exchanged via 846 Inventory Inquiry/Advice transaction sets for Vendor Managed Inventory (VMI) programs.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet850Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 850 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 850 Purchase Order transaction sets to Consumer Goods.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet852Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 852 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 852 Product Activity Data (POS sales data) to Consumer Goods for demand sensing and replenishment.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet855Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 855 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 855 Purchase Order Acknowledgment transaction sets back to the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet856Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 856 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 856 Advanced Ship Notice transaction sets to notify the trading partner of shipments.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet867Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 867 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 867 Product Transfer and Resale Report transaction sets for secondary sales visibility (distributor to retailer).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet997Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 997 Enabled' ;
    rdfs:comment 'Indicates whether 997 Functional Acknowledgment transaction sets are exchanged to confirm receipt and syntactic validation of EDI documents.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vanMailboxCode rdf:type rdf:Property ;
    rdfs:label 'Van Mailbox Code' ;
    rdfs:comment 'The mailbox identifier assigned by the VAN provider for routing EDI documents to and from the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vanProvider rdf:type rdf:Property ;
    rdfs:label 'Van Provider' ;
    rdfs:comment 'The name of the Value-Added Network provider facilitating EDI exchange (e.g., SPS Commerce, TrueCommerce, Cleo) when VAN protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Store Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Store Manager Assignment report linking each store to the responsible employee manager.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Store-level VMI or direct replenishment ties a retail store to the exact supplier site that ships inventory, needed for logistics and OTIF tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:acvWeight rdf:type rdf:Property ;
    rdfs:label 'Acv Weight' ;
    rdfs:comment 'All Commodity Volume (ACV) weighting factor representing this stores share of total market volume, used for distribution and market share calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'The retail banner or brand under which this store operates (e.g., Walmart Supercenter, Target, Kroger).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the store permanently closed or is scheduled to close. Null if store is active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdRouteCode rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Code' ;
    rdfs:comment 'Route code or identifier for Direct Store Delivery (DSD) logistics and delivery scheduling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recent retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Visit Date' ;
    rdfs:comment 'Date of the next planned retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the store first opened for business operations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the store (e.g., Mon-Fri 8am-10pm, Sat-Sun 9am-9pm) used for retail execution visit planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Osa Target Pct' ;
    rdfs:comment 'Target On Shelf Availability (OSA) percentage for this store indicating expected in-stock performance for key Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramZone rdf:type rdf:Property ;
    rdfs:label 'Planogram Zone' ;
    rdfs:comment 'Planogram zone or cluster assignment indicating which shelf layout and assortment plan applies to this store.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Type or vendor of the Point of Sale (POS) system used at this store for transaction processing and sales data capture.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'The retail format classification of the store indicating size, assortment, and operational model. [ENUM-REF-CANDIDATE: hypermarket|supermarket|convenience|club|drug|dollar|specialty|e-commerce_fulfillment_center — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The official name or designation of the retail store location.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The retailer-assigned unique store number or code used for operational identification and Direct Store Delivery (DSD) routing.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePhone rdf:type rdf:Property ;
    rdfs:label 'Store Phone' ;
    rdfs:comment 'Primary contact phone number for the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeSizeSqFt rdf:type rdf:Property ;
    rdfs:label 'Store Size Sq Ft' ;
    rdfs:comment 'Total retail selling space of the store measured in square feet, used for All Commodity Volume (ACV) and Total Distribution Points (TDP) calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeStatus rdf:type rdf:Property ;
    rdfs:label 'Store Status' ;
    rdfs:comment 'Current operational status of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeTier rdf:type rdf:Property ;
    rdfs:label 'Store Tier' ;
    rdfs:comment 'Strategic tier classification (e.g., Tier 1, Tier 2) indicating store importance based on volume, profitability, or strategic value for prioritized retail execution.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpWeight rdf:type rdf:Property ;
    rdfs:label 'Tdp Weight' ;
    rdfs:comment 'Total Distribution Points (TDP) weighting factor representing this stores contribution to numeric distribution metrics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingArea rdf:type rdf:Property ;
    rdfs:label 'Trading Area' ;
    rdfs:comment 'Geographic trading area or market designation (e.g., metro area, region) used for sales territory and distribution planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_storage_location. Business justification: VMI replenishment planning requires each trade account to have a designated warehouse (storage location); the default_storage_location_id FK enables the VMI allocation report.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'The date when this trade account was permanently closed or terminated, if applicable.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'The date when this trade account was first established and approved for business transactions.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier classification based on account size, coverage, and business importance: Tier 1 (national key accounts), Tier 2 (regional chains), Tier 3 (local/metro accounts), Tier 4 (independent operators).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvTotal rdf:type rdf:Property ;
    rdfs:label 'Acv Total' ;
    rdfs:comment 'The total All Commodity Volume representing the annual dollar sales volume across all product categories for this retail account, used for market coverage analysis.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit risk rating assigned to this trade account by internal credit management or external credit bureau (e.g., AAA, AA, A, BBB, BB, B, CCC, D).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or DBA name under which the account operates in the market, if different from legal entity name.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Flag' ;
    rdfs:comment 'Indicates whether this trade account receives direct store delivery (DSD) shipments bypassing the retailers distribution center.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number assigned by Dun & Bradstreet for unique identification of the business entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'The first line of the street address for the trade account headquarters or primary business location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'The second line of the street address (suite, floor, building) for the trade account headquarters.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'The city name of the trade account headquarters location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'The 3-letter ISO 3166-1 alpha-3 country code for the trade account headquarters location (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'The state, province, or administrative region of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The official registered legal name of the trade partner organization as it appears on legal documents and contracts.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifSlaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Percent' ;
    rdfs:comment 'The contractual OTIF service level agreement target percentage for order fulfillment performance (e.g., 95.00 represents 95% of orders delivered on time and in full).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The business email address of the primary contact for order management, invoicing, and account communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact or account manager at the trade partner organization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The business phone number of the primary contact, including country code and extension if applicable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'The 2-letter ISO 639-1 language code for the preferred communication language with this trade account (e.g., en, es, fr, de).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'The business reason or justification for the most recent account status change (e.g., payment default, business closure, credit improvement, contract renewal).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangedByUser rdf:type rdf:Property ;
    rdfs:label 'Status Changed By User' ;
    rdfs:comment 'The user ID or name of the person who executed the most recent account status change, for audit and accountability purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this trade account holds a valid tax exemption certificate for sales tax or VAT purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'The government-issued tax identification number for this legal entity (e.g., EIN in USA, VAT number in EU, GST number in other jurisdictions).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCount rdf:type rdf:Property ;
    rdfs:label 'Tdp Count' ;
    rdfs:comment 'The total number of distribution points (store locations or outlets) operated by this trade account where products can be sold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeChannel rdf:type rdf:Property ;
    rdfs:label 'Trade Channel' ;
    rdfs:comment 'The primary retail or distribution channel through which this trade account operates: grocery (supermarkets), mass (mass merchandisers), club (warehouse clubs), drug (pharmacy chains), convenience stores, foodservice (restaurants/institutions), or e-commerce (online retailers). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|foodservice|e-commerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event record. Primary key for the distribution cycle count entity.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the supervisor or manager who approved the cycle count adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:distributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the distribution center where the cycle count was performed.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Identifier of the specific lot or batch being counted, critical for FEFO/FIFO inventory rotation and traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:primaryDistributionCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Counter Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate who performed the physical count.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC inventory classification of the SKU at the time of count: A (high value/velocity), B (medium), C (low), D (obsolete/slow-moving).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Approved Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been approved by a supervisor or manager.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether an inventory adjustment is required based on the variance exceeding tolerance thresholds.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity was completed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The method used to perform the physical count: manual (paper-based), RF scanner (handheld device), voice picking (voice-directed), or automated (RFID/sensor).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count event, typically generated by the WMS. Format: CC-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReasonCode rdf:type rdf:Property ;
    rdfs:label 'Count Reason Code' ;
    rdfs:comment 'The business reason triggering this cycle count: routine (scheduled ABC cycle), discrepancy (prior variance), audit (compliance), quality (QC hold), recall (product recall), transfer (location move).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity began.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event: scheduled (routine ABC cycle), ad-hoc (unplanned), exception (triggered by discrepancy), blind (counter does not see system quantity), or targeted (specific SKU/lot focus).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValueVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Variance Amount' ;
    rdfs:comment 'The financial impact of the variance, calculated as variance_quantity multiplied by the standard cost of the SKU. Expressed in the DC\'s functional currency.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount iteration this represents (1 for first recount, 2 for second, etc.). Null if no recount performed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variance or quality control procedures.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the cycle count was scheduled to be performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'The inventory status of the counted stock: available (unrestricted), hold (QC hold), quarantine (quality review), damaged, expired, or reserved (allocated to orders).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The quantity of the SKU/lot recorded in the WMS at the time of the cycle count.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance percentage threshold. Variances within this percentage may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Quantity' ;
    rdfs:comment 'The acceptable variance quantity threshold defined for this SKU/location combination. Variances within this threshold may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes providing additional context or explanation for the variance observed during the cycle count.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the system quantity, calculated as (variance_quantity / system_quantity) * 100.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between counted quantity and system quantity (counted minus system). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Root cause classification for the variance: picking error, receiving error, damage, theft, system error, location error, expiry, or other. [ENUM-REF-CANDIDATE: picking_error|receiving_error|damage|theft|system_error|location_error|expiry|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Code' ;
    rdfs:comment 'The unique transaction identifier generated by the WMS for this cycle count event, used for audit trail and system reconciliation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery transaction. Primary key for the distribution_dsd_delivery product.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionDsdDelivery .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Reference to the DSD route this delivery is part of. Links to the route master data defining the planned sequence of store visits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual timestamp when the driver arrived at the retail store location. Used for On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the delivery attempt. Used for root cause analysis of delivery failures. [ENUM-REF-CANDIDATE: store_closed|access_denied|incomplete_order|damaged_product|wrong_address|weather_delay|traffic_delay|vehicle_breakdown|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes captured by the driver regarding delivery conditions, store feedback, or special circumstances encountered during the visit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Business identifier for the DSD delivery transaction. Externally visible delivery document number used for tracking and proof of delivery reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the DSD delivery transaction. Tracks progression from scheduled visit through completion or failure. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|in_progress|completed|failed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Value Amount' ;
    rdfs:comment 'The total monetary value of products delivered during this visit, calculated at invoice price. Represents gross delivery value before returns and credits.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'The end of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'The beginning of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureTime rdf:type rdf:Property ;
    rdfs:label 'Departure Time' ;
    rdfs:comment 'The timestamp when the driver departed from the retail store after completing delivery and merchandising activities.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the complete ordered quantity was delivered without shortages. Component of OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Reference to the sales invoice document generated for this DSD delivery. Links to financial billing and accounts receivable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingActivityType rdf:type rdf:Property ;
    rdfs:label 'Merchandising Activity Type' ;
    rdfs:comment 'The type of in-store merchandising activity performed during the delivery visit. Supports retail execution and On Shelf Availability (OSA) objectives.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Merchandising Duration Minutes' ;
    rdfs:comment 'The total time in minutes spent on merchandising activities during the store visit. Used for labor productivity analysis.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchandising Performed Flag' ;
    rdfs:comment 'Indicates whether in-store merchandising activities (shelf stocking, rotation, display setup) were performed during this delivery visit.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDeliveryAmount rdf:type rdf:Property ;
    rdfs:label 'Net Delivery Amount' ;
    rdfs:comment 'The net monetary value of the delivery after subtracting return credits from gross delivery value. Represents actual secondary sales value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the delivery arrived within the agreed delivery time window. Component of OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliance Flag' ;
    rdfs:comment 'Indicates whether this delivery met On Time In Full (OTIF) performance criteria: arrived within delivery window and delivered complete order quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'The method used to capture proof of delivery from the store recipient. Electronic signature and photo are preferred for audit trail.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Photo Url' ;
    rdfs:comment 'URL reference to the photo evidence of delivery captured at the store. Links to document management system for audit purposes.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Image Url' ;
    rdfs:comment 'URL reference to the stored electronic signature image captured as proof of delivery. Links to document management system.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'The name of the store employee who received and acknowledged the delivery. Captured for proof of delivery and accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Return Credit Amount' ;
    rdfs:comment 'The total monetary value of product returns credited to the store during this visit. Reduces net delivery value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'The planned arrival timestamp at the retail store based on route optimization and store delivery window requirements.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether temperature-sensitive products were maintained within required cold chain temperature ranges during delivery. Critical for food safety and quality compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Cases Delivered' ;
    rdfs:comment 'The total quantity of product cases delivered to the store during this visit. Aggregate measure across all SKUs (Stock Keeping Units) delivered.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCasesReturned rdf:type rdf:Property ;
    rdfs:label 'Total Cases Returned' ;
    rdfs:comment 'The total quantity of product cases returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Units Delivered' ;
    rdfs:comment 'The total quantity of individual product units delivered to the store during this visit. Aggregate measure across all SKUs delivered.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsReturned rdf:type rdf:Property ;
    rdfs:label 'Total Units Returned' ;
    rdfs:comment 'The total quantity of individual product units returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Reference to the delivery vehicle used for this DSD delivery. Links to fleet asset master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'The calendar date on which the DSD delivery visit to the retail store occurred. Business event date for reporting and analytics.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionDsdRouteId rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Id' ;
    rdfs:comment 'Unique identifier for the DSD route record. Primary key.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: DSD route planning assigns a carrier to each route; the carrier_id FK enables carrier performance and cost analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Foreign key linking to logistics.lane. Business justification: DSD route aligns with a transport lane to calculate distance, fuel surcharge, and service level expectations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:primaryDistributionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Employee Id' ;
    rdfs:comment 'Identifier of the driver or sales representative permanently or primarily assigned to this route. May be null for unassigned or pool routes.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Identifier of the sales or service territory to which this route is assigned. Used for sales force alignment and performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:averageOrderValue rdf:type rdf:Property ;
    rdfs:label 'Average Order Value' ;
    rdfs:comment 'Historical average order value per stop on this route in local currency. Used for revenue forecasting and route profitability analysis.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDriveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Drive Time Minutes' ;
    rdfs:comment 'Estimated total driving time for the route in minutes, excluding stop service time. Used for driver shift planning and OTIF performance targets.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Time Minutes' ;
    rdfs:comment 'Estimated total time spent at customer stops for unloading, merchandising, and order processing in minutes. Combined with drive time for total route duration.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOptimizationDate rdf:type rdf:Property ;
    rdfs:label 'Last Optimization Date' ;
    rdfs:comment 'Date when this route was last reviewed and optimized for efficiency. Used to identify routes due for re-evaluation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandisingRequired rdf:type rdf:Property ;
    rdfs:label 'Merchandising Required' ;
    rdfs:comment 'Boolean flag indicating whether this route includes merchandising activities (shelf stocking, display setup, POG compliance) in addition to delivery. True if merchandising is part of the service.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'Total count of retail store or customer locations included in this route. Used for route capacity planning and driver workload estimation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:osaTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percentage' ;
    rdfs:comment 'Target OSA percentage for stores on this route, representing the expected in-stock rate at point of sale. Used for DSD execution quality and replenishment effectiveness tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'Standard departure time from the DC for this route in HH:MM format (24-hour clock). Used for driver scheduling and DC loading dock coordination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReturnTime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Time' ;
    rdfs:comment 'Expected return time to the DC for this route in HH:MM format (24-hour clock). Used for driver shift planning and vehicle turnaround scheduling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Boolean flag indicating whether this route requires temperature-controlled (refrigerated or frozen) transportation for product integrity. True if cold chain is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Certification' ;
    rdfs:comment 'Boolean flag indicating whether the driver assigned to this route must hold hazmat certification due to regulated products (e.g., aerosols, flammables). True if certification is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Business identifier for the DSD route, used for operational reference and scheduling. Typically alphanumeric code assigned by logistics planning.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the DSD route, often including geographic or customer identifiers (e.g., \'Downtown Metro Route A\', \'North Region Convenience Stores\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Score' ;
    rdfs:comment 'Calculated efficiency score for this route based on distance, time, stops, and revenue, typically ranging from 0-100. Higher scores indicate more optimized routes. Used for continuous improvement initiatives.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the DSD route. Active routes are in regular service; inactive routes are permanently discontinued; suspended routes are temporarily paused; under_review routes are being optimized; seasonal_closed routes are off-season.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the DSD route based on service model: standard (regular scheduled delivery), express (same-day or expedited), bulk (high-volume customers), emergency (unplanned replenishment), seasonal (temporary routes for peak demand).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDayPattern rdf:type rdf:Property ;
    rdfs:label 'Service Day Pattern' ;
    rdfs:comment 'Comma-separated list of days of the week this route is scheduled to run (e.g., \'Mon,Wed,Fri\' for a three-day-per-week route). Supports recurring schedule planning.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total driving distance for the complete route in kilometers, from DC departure through all stops and return. Used for fuel cost estimation and vehicle range planning.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacityRequiredUnits rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Required Units' ;
    rdfs:comment 'Minimum vehicle cargo capacity required in standard units (cases, pallets, or cubic meters) to fulfill typical route demand. Used for vehicle assignment.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Type of vehicle required to service this route based on cargo volume, weight, and product requirements (e.g., refrigerated for cold chain products).' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks the facility manager employee for each distribution center, required for operational performance metrics and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the distribution center ceased operations. Null for active facilities. Used for historical analysis and network optimization studies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crossDockEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Enabled Flag' ;
    rdfs:comment 'Indicates whether the facility supports cross-docking operations where inbound goods are directly transferred to outbound shipments with minimal storage time.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Standard frequency in days for cycle counting inventory at this facility. Used for inventory accuracy management and audit compliance.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems. Externally-known unique code for the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcName rdf:type rdf:Property ;
    rdfs:label 'Dc Name' ;
    rdfs:comment 'Official business name of the distribution center or warehouse facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorsInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Inbound' ;
    rdfs:comment 'Number of dock doors designated for inbound receiving operations. Impacts receiving throughput capacity and scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Outbound' ;
    rdfs:comment 'Number of dock doors designated for outbound shipping operations. Impacts shipping throughput capacity and carrier scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdHubFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Hub Flag' ;
    rdfs:comment 'Indicates whether this facility serves as a DSD hub for direct-to-retail delivery operations. DSD hubs bypass traditional distribution channels for faster store replenishment.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the distribution center based on temperature control and operational model. Ambient for room temperature, chilled for refrigerated, frozen for sub-zero, multi-temperature for mixed zones, DSD hub for Direct Store Delivery operations, cross-dock for flow-through distribution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fscCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under FSC chain of custody standards for sustainable sourcing. Required for handling FSC-certified paper and wood-based products.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under Good Manufacturing Practice standards. Required for handling cosmetics, personal care, and certain consumer goods products.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified to handle and store hazardous materials. Required for distribution of products with EPA or OSHA regulated substances.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryRotationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Rotation Method' ;
    rdfs:comment 'Primary inventory rotation method used at this facility. FIFO (First In First Out) for standard goods, FEFO (First Expired First Out) for perishables and date-sensitive products, LIFO (Last In First Out) for specific use cases.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Expiration date of the facility lease agreement. Null for owned facilities. Used for lease renewal planning and facility strategy.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this distribution center record was last modified. Audit trail for change tracking and data quality monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the distribution center commenced operations. Used for facility age analysis and depreciation calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM. Used for scheduling inbound deliveries, outbound shipments, and workforce planning.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. Used for scheduling weekend operations and carrier coordination.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the distribution center in its lifecycle. Active indicates full operations, inactive for temporarily closed, under construction for new facilities being built, decommissioned for permanently closed, seasonal for facilities operating only during peak periods, maintenance for temporary closure due to upgrades or repairs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of facility ownership model. Owned for company-owned facilities, leased for long-term leased properties, third-party logistics for 3PL-operated warehouses.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code representing this distribution center in the ERP system. Maps to the SAP MM and WM modules for material management and warehouse management.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location' ;
    rdfs:comment 'SAP S/4HANA storage location code within the plant. Represents the primary storage location identifier for inventory transactions in SAP WM module.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Shifts Per Day' ;
    rdfs:comment 'Number of operational shifts per day at the facility. Used for labor planning, throughput capacity modeling, and operational cost analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallet Positions' ;
    rdfs:comment 'Maximum number of pallet positions available for storage. Key metric for inventory capacity planning and space utilization analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the facility has temperature-controlled storage zones. True for facilities with chilled or frozen capabilities, false for ambient-only.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Sqft' ;
    rdfs:comment 'Total warehouse floor space capacity in square feet. Includes all storage, staging, and operational areas within the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsSiteCode rdf:type rdf:Property ;
    rdfs:label 'Wms Site Code' ;
    rdfs:comment 'Unique site identifier in the Blue Yonder WMS system. Used for integration and synchronization between the lakehouse and the operational WMS platform.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Unique identifier for the distribution shipment record. Primary key for the distribution shipment entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionShipment .

ind:intransitShipmentId rdf:type rdf:Property ;
    rdfs:label 'Intransit Shipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.intransit_shipment. Business justification: SHIPMENT HAND-OFF: Distribution shipment creates an In-Transit Shipment record to track movement from DC to destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntransitShipment .

ind:loadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Loaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Load Execution Log to record which warehouse employee performed the loading of each shipment, supporting OTIF compliance and labor costing.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:manufacturingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Facility Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Shipment origin tracking: linking shipments to the originating manufacturing facility enables performance dashboards and OTIF analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingFacility .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to distribution.outbound_order. Business justification: Shipment is a child of an outbound order; each shipment fulfills an order. Adding outbound_order_id to distribution_shipment creates the necessary parent link without creating a bidirectional relation' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment was delivered and received at the destination. Used for final OTIF calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment departed the DC. Critical for OTIF calculation and carrier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Unique identifier of the bill of lading document issued by the carrier. Legal document for freight movement and proof of shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service tier selected for this shipment defining speed and handling requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or cases included in the shipment. Used for piece-level tracking and receiving verification.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the shipment destination address.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Code' ;
    rdfs:comment 'Business identifier of the destination location (store number, DC code, customer account number) where goods are being delivered.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the shipment destination for customs and routing purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationName rdf:type rdf:Property ;
    rdfs:label 'Destination Name' ;
    rdfs:comment 'Human-readable name of the destination location for display and confirmation purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State or province code of the shipment destination address.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the shipment destination entity type for routing and handling purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Current estimated delivery date and time based on real-time tracking and carrier updates. Updated dynamically during transit.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight cost charged for this shipment in the transaction currency. Used for logistics cost analysis and freight audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight charge amount.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining which party is responsible for freight payment and at what point ownership transfers. Critical for cost allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Document Number' ;
    rdfs:comment 'SAP SD goods issue document number linking the physical shipment to the ERP inventory transaction. Critical for inventory accuracy.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in the shipment. Used for picking complexity and receiving planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadNumber rdf:type rdf:Property ;
    rdfs:label 'Load Number' ;
    rdfs:comment 'Identifier of the load plan that consolidated multiple orders or shipments into this trailer. Used for load optimization tracking.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Calculated OTIF performance status indicating whether the shipment was delivered on time and complete per customer commitment. Key supply chain KPI.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets included in the shipment. Used for handling unit tracking and dock labor planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned progressive number used for tracking and tracing the shipment in the carriers system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for the shipment to arrive at the destination. Used for customer commitment and OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to arrive at the destination. Precision timestamp for delivery window commitments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to depart from the DC dock. Precision timestamp for appointment scheduling and carrier coordination.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Planned date for the shipment to depart from the distribution center. Used for OTIF performance measurement baseline.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique identifier of the security seal applied to the trailer or container to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment assigned by the WMS. Used for tracking and reference across systems and with carriers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the outbound fulfillment workflow. Tracks progression from planning through final delivery. [ENUM-REF-CANDIDATE: planned|staged|loading|loaded|departed|in_transit|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on delivery method and business purpose. DSD indicates Direct Store Delivery channel.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDcCode rdf:type rdf:Property ;
    rdfs:label 'Source Dc Code' ;
    rdfs:comment 'Code identifying the originating distribution center from which goods are being shipped.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total quantity of individual sellable units (eaches) included in the shipment across all SKUs.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total cube or volume of the shipment in cubic meters. Critical for trailer utilization and dimensional weight calculations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms including product and packaging. Used for freight rating and load planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Identifier of the trailer or container unit used to transport the shipment. Critical for load tracking and yard management.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Identifier of the warehouse picking wave that generated the orders included in this shipment. Links shipment to WMS wave planning.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle designation within the warehouse layout for physical navigation and picking route optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay or column position within the aisle for precise horizontal location reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binPosition rdf:type rdf:Property ;
    rdfs:label 'Bin Position' ;
    rdfs:comment 'Specific bin or slot position within the level for granular inventory placement and retrieval.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDate rdf:type rdf:Property ;
    rdfs:label 'Blocked Date' ;
    rdfs:comment 'Date when the storage location was blocked or made unavailable for operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Explanation for why the location is blocked or unavailable, such as maintenance, damage, safety hold, or quality quarantine.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for cycle counting inventory at this location to maintain inventory accuracy and compliance.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the bay for height-based slotting and equipment compatibility.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location for put-away and picking operations.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the storage location is scheduled to be decommissioned or removed from active use. Null for indefinite locations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fefoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FEFO inventory rotation logic for expiry-sensitive products (pharmaceuticals, food, cosmetics).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FIFO inventory rotation logic for age-based stock management.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the storage location in centimeters for vertical clearance and equipment reach validation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed at this storage location.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the storage location in centimeters for dimensional slotting and equipment compatibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier for the storage location as defined in Blue Yonder WMS. Typically formatted as aisle-bay-level-bin (e.g., A01-B05-L03-P12).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the storage location for operational reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location indicating availability for inventory placement and retrieval.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location by operational function: bulk storage, active pick face, reserve inventory, staging area, dock door, or cross-dock zone.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple lot or batch numbers for the same SKU or requires lot segregation.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple SKUs simultaneously or requires single-SKU dedication.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face for order fulfillment operations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'Order fulfillment picking method supported by this location: batch picking, wave picking, zone picking, discrete (single-order), or cluster picking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Algorithm used to assign incoming inventory to this location: directed (system-assigned), random, fixed (dedicated SKU), or dynamic (velocity-based).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority ranking for automated replenishment from reserve to pick locations, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the storage location to ensure product integrity and regulatory compliance (ambient, refrigerated 2-8°C, frozen <-18°C, controlled room temperature).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity M3' ;
    rdfs:comment 'Maximum volume capacity of the storage location in cubic meters for space utilization and slotting algorithms.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms for safe load management and slotting optimization.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the storage location in centimeters for dimensional slotting and equipment compatibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Logical zone classification within the distribution center for grouping locations by product category, velocity, or operational workflow (e.g., FAST-PICK, SLOW-MOVE, HAZMAT).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Id' ;
    rdfs:comment 'Unique identifier for the dock appointment record. Primary key for the dock appointment entity.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Allows Dock Scheduling System to capture which employee scheduled the appointment, enabling workload planning and audit of appointment creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the carrier truck checked in at the distribution center gate. Used to calculate on-time arrival performance and carrier compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCaseCount rdf:type rdf:Property ;
    rdfs:label 'Actual Case Count' ;
    rdfs:comment 'Actual number of cases handled during the appointment. Used for variance analysis and operational performance tracking.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual timestamp when loading or unloading operations were completed and the truck departed. Used to calculate dock turnaround time and throughput metrics.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPalletCount rdf:type rdf:Property ;
    rdfs:label 'Actual Pallet Count' ;
    rdfs:comment 'Actual number of pallets loaded or unloaded during the appointment. Compared against expected count to identify discrepancies.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual timestamp when loading or unloading operations began at the dock door. Marks the beginning of active dock utilization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual total weight of goods handled in kilograms. Verified through weigh station or scale integration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique appointment reference number used for scheduling and tracking. Externally visible identifier shared with carriers and suppliers.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the dock appointment: scheduled (initial booking), confirmed (carrier acknowledged), checked_in (truck arrived at gate), in_progress (loading/unloading active), completed (finished), cancelled (appointment voided), no_show (carrier missed appointment). [ENUM-REF-CANDIDATE: scheduled|confirmed|checked_in|in_progress|completed|cancelled|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the dock appointment purpose: inbound receipt (supplier delivery), outbound load (customer shipment), inter-DC transfer (internal movement), cross-dock (direct transfer), returns processing, or emergency delivery.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Advanced Shipping Notice identifier sent by supplier prior to shipment arrival. Used to pre-plan receiving operations and validate expected contents.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this is a cross-dock appointment where goods are transferred directly from inbound to outbound without storage. True for cross-dock operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionMinutes rdf:type rdf:Property ;
    rdfs:label 'Detention Minutes' ;
    rdfs:comment 'Total time in minutes that the carrier was detained beyond the scheduled appointment window. Used to calculate detention charges and identify operational bottlenecks.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver assigned to this appointment. Used for gate check-in verification and security purposes.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPhone rdf:type rdf:Property ;
    rdfs:label 'Driver Phone' ;
    rdfs:comment 'Contact phone number for the driver. Used for real-time communication regarding delays, gate instructions, or operational issues.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCaseCount rdf:type rdf:Property ;
    rdfs:label 'Expected Case Count' ;
    rdfs:comment 'Anticipated number of cases to be handled during this appointment. Supports detailed capacity and labor planning for case-level operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Anticipated number of pallets to be loaded or unloaded during this appointment. Used for dock capacity planning and labor scheduling.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Total expected weight of goods in kilograms for this appointment. Used for equipment planning and safety compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard classification code for hazardous materials (e.g., 3 for flammable liquids, 8 for corrosives). Required for HAZMAT compliance and safety protocols.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicates whether the appointment met On Time In Full performance criteria: arrived within scheduled window and delivered expected quantities. True if OTIF compliant.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Sales order number associated with outbound load appointments. Links the dock appointment to customer orders being shipped.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for the carrier to arrive at the dock door. Used for day-level appointment planning and capacity management.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when the appointment window closes. Carrier should complete loading/unloading by this time to maintain schedule compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when the appointment window begins. Carrier is expected to arrive at or after this time.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was intact upon arrival. True if seal is unbroken, false if compromised. Critical for security and quality control.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdDeliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery line item. Primary key for this product.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether cold chain temperature requirements were maintained throughout delivery. True if compliant, False if temperature excursion occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of the SKU delivered to the store during this visit. Used for secondary sales capture and inventory replenishment tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when this specific line item was delivered or processed at the store. Used for OTIF performance tracking and delivery window compliance.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of this delivery line. Values: DELIVERED (fully delivered), PARTIAL (partially delivered), REJECTED (rejected by store), RETURNED (returned to warehouse), CANCELLED (cancelled before delivery).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number for the delivered product. Critical for traceability, quality control, and recall management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date the product was manufactured. Used for shelf-life calculation and quality tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net monetary value for this line after discounts and taxes (line_total_amount - discount_amount + tax_amount). Represents final revenue for this line.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Indicates whether the store was out of stock for this SKU at the time of delivery. True if OOS condition detected, False otherwise. Critical for OSA metrics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally ordered by the store or planned for delivery. Used for fill-rate and OTIF analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Flag' ;
    rdfs:comment 'Indicates whether the product was placed according to the store planogram. True if compliant, False if deviation occurred.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating why the delivery line was rejected by the store. Values: DAMAGED, WRONG_PRODUCT, QUALITY, UNAUTHORIZED, EXPIRED, OTHER.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of the SKU returned from the store during this visit. Includes damaged goods, expired products, and unsold inventory.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPlacementConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Placement Confirmed Flag' ;
    rdfs:comment 'Indicates whether the DSD driver confirmed proper shelf placement and merchandising of the delivered product. True if confirmed, False otherwise.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Selling price per unit for this SKU at the time of delivery. Used for revenue calculation and pricing analysis.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code for the product. Standard barcode identifier used in North American retail.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:primaryInboundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Employee Id' ;
    rdfs:comment 'Identifier of the quality control personnel who performed the inspection, used for accountability and audit trail.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingClerkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Clerk Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who processed the inbound receipt, used for labor tracking and accountability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:warehouseDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Distribution Facility Id' ;
    rdfs:comment 'Identifier of the specific warehouse or storage facility within the distribution center where goods were received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Quantity of goods accepted into inventory after quality inspection, excluding rejected or damaged items.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the physical goods arrived and were checked in at the receiving dock, representing the principal business event for this transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Number of cases or cartons received in this inbound shipment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO standard container identifier for ocean freight shipments, following the BIC (Bureau International des Containers) format.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicator of whether any discrepancies (quantity, quality, or documentation) were identified during the receiving process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description providing additional details about any discrepancies identified during the receiving process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Classification of the type of discrepancy identified during receiving, used for root cause analysis and supplier performance management.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Document Number' ;
    rdfs:comment 'SAP Material Management (MM) goods receipt document number generated upon posting the receipt to inventory, linking WMS to ERP.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Reference to the originating purchase order that authorized this inbound shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicator of whether formal quality inspection was required for this receipt based on product category, supplier risk profile, or regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual total quantity of goods physically received and counted during the receiving process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of goods rejected during receiving due to quality issues, damage, or non-conformance to specifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt line. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceiptLine .

ind:regulatoryRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.registration. Business justification: Regulatory registration verification during inbound receipt ensures each received SKU is registered in the jurisdiction, a standard compliance step.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRegistration .

ind:asnLineNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Line Number' ;
    rdfs:comment 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Cases' ;
    rdfs:comment 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Eaches' ;
    rdfs:comment 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Line number on the purchase order corresponding to this receipt line. Enables three-way matching between PO, receipt, and invoice.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putAwayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Put Away Timestamp' ;
    rdfs:comment 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Cases' ;
    rdfs:comment 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Eaches' ;
    rdfs:comment 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the goods were physically received at the warehouse dock. Critical for OTIF performance measurement and cycle time analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse storage location code where the received goods were put away. Identifies the bin, rack, or zone within the distribution center.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt Celsius' ;
    rdfs:comment 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit for the received goods as specified in the purchase order. Used for inventory valuation and COGS calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Cases' ;
    rdfs:comment 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Eaches' ;
    rdfs:comment 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Code identifying the distribution center or warehouse facility where the receipt occurred. Used for multi-site inventory management.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Supports Inventory Ownership Dashboard, assigning a responsible employee for each DC inventory position for accountability and cycle-count oversight.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'The unit cost of the inventory lot. Used for inventory valuation and cost of goods sold calculations. Business confidential financial data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The quantity available for new order allocation and picking. Calculated as quantity_on_hand minus quantity_allocated minus quantity_quarantine minus quantity_hold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date when the inventory lot was received into the distribution center. Used for inventory aging and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The timestamp when this inventory position snapshot was captured. Used for point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the outbound load plan record. Primary key.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLoadingSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Loading Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the warehouse supervisor who verified and approved the completed load before dispatch.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Identifier of the picking wave that generated the orders included in this load plan. Links load planning to upstream warehouse execution.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual date and time when the loaded trailer departed the distribution center, used for OTIF performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'Estimated transportation cost for this load based on carrier rates, distance, and service level.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying any exception or deviation from standard load planning process (e.g., overweight, incomplete orders, equipment failure).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing any exceptions, special handling instructions, or deviations from the standard load plan.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated freight cost.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Load Plan Number' ;
    rdfs:comment 'Business-facing unique identifier for the load plan, typically generated by the WMS. Used for operational tracking and communication with carriers and warehouse staff.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan, tracking progression from planning through dispatch. [ENUM-REF-CANDIDATE: draft|confirmed|in_progress|loaded|sealed|dispatched|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceStrategy rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Strategy' ;
    rdfs:comment 'Strategy used to determine the order in which pallets are loaded into the trailer, typically aligned with delivery stop sequence.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load based on shipment mode and delivery strategy. DSD indicates Direct Store Delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Loading Completion Datetime' ;
    rdfs:comment 'Date and time when physical loading of the trailer was completed and verified.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Loading Start Datetime' ;
    rdfs:comment 'Date and time when physical loading of the trailer began at the dock door.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderCount rdf:type rdf:Property ;
    rdfs:label 'Order Count' ;
    rdfs:comment 'Total number of distinct outbound orders consolidated into this load plan.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifTargetDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Otif Target Delivery Datetime' ;
    rdfs:comment 'Target delivery date and time committed to the customer, used for OTIF performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:palletConfiguration rdf:type rdf:Property ;
    rdfs:label 'Pallet Configuration' ;
    rdfs:comment 'Description of how pallets are arranged and stacked within the trailer, supporting optimal space utilization and load stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Datetime' ;
    rdfs:comment 'Scheduled date and time when the loaded trailer is planned to depart the distribution center.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopCount rdf:type rdf:Property ;
    rdfs:label 'Stop Count' ;
    rdfs:comment 'Total number of delivery stops planned for this load, used for multi-stop route optimization.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled loads during transit.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled loads during transit.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerCode rdf:type rdf:Property ;
    rdfs:label 'Trailer Code' ;
    rdfs:comment 'Unique identifier of the trailer or vehicle assigned to this load. May be a license plate, fleet number, or container number.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerType rdf:type rdf:Property ;
    rdfs:label 'Trailer Type' ;
    rdfs:comment 'Type of trailer or vehicle used for this load, determining capacity and product compatibility.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Trailer Utilization Percentage' ;
    rdfs:comment 'Percentage of trailer capacity utilized by this load, calculated based on weight, volume, or pallet positions.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifEventId rdf:type rdf:Property ;
    rdfs:label 'Otif Event Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement event. Primary key for the OTIF event record.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Reference to the delivery execution record for Direct Store Delivery (DSD) or carrier delivery. Links to the actual delivery event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Enables OTIF Incident Management report to identify the employee responsible for resolving each OTIF event, meeting internal SLA tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed to the customer per the Service Level Agreement (SLA) or purchase order terms. Baseline for on-time performance measurement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Timestamp' ;
    rdfs:comment 'The precise delivery date and time committed to the customer, including time window for time-sensitive deliveries. Used for precise OTIF measurement when time windows apply.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The total quantity committed to the customer per the sales order or purchase order. Baseline for in-full performance measurement. Measured in order unit of measure.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The logistics channel used for delivery execution. Values include Direct Store Delivery (DSD), Less Than Truckload (LTL) carrier, Full Truckload (FTL) carrier, parcel, customer pickup, or third-party logistics (3PL).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Days' ;
    rdfs:comment 'The number of days variance between committed and actual delivery date. Negative values indicate early delivery, positive values indicate late delivery, zero indicates on-time.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the OTIF measurement is under dispute by the customer or internal stakeholders. True indicates active dispute, False indicates accepted measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation of why the OTIF measurement is disputed. Captures customer or internal objections to the performance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'The primary root cause category for OTIF failures. Used for operational improvement analysis and accountability assignment. Values include DC pick error, inventory shortage, dock delay, carrier issue, customer refused, weather delay, system error, quality hold, damaged product, address issue, or no failure for successful deliveries. [ENUM-REF-CANDIDATE: dc_pick_error|inventory_shortage|dock_delay|carrier_issue|customer_refused|weather_delay|system_error|quality_hold|damaged_product|address_issue|no_failure — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Detail' ;
    rdfs:comment 'Detailed explanation of the root cause for OTIF failure. Free-text field capturing specific circumstances, corrective actions, and accountability notes.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'In Full Tolerance Percent' ;
    rdfs:comment 'The acceptable variance percentage per customer SLA or business policy. Deliveries within this tolerance are considered in-full compliant.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when the OTIF performance was measured and recorded. Used for reporting period assignment and trend analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'The customer purchase order or sales order number associated with this shipment. Business identifier for traceability to the originating order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Composite OTIF performance indicator. True only when both on_time_flag and in_full_flag are True. Primary KPI for DC operations accountability and retailer scorecard compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the retailer penalty amount. Standard currency codes such as USD, EUR, GBP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether an electronic or physical signature was captured at delivery. True indicates signature obtained, False indicates delivery without signature capture.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'The timestamp when proof of delivery was captured, typically via electronic signature, barcode scan, or delivery confirmation. Source of truth for actual delivery time.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'The unit of measure for committed and delivered quantities. Common values include cases, pallets, eaches, or other standard units.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between delivered quantity and committed quantity. Negative values indicate short shipment, positive values indicate over shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Percent' ;
    rdfs:comment 'The percentage variance between delivered and committed quantity, calculated as (delivered - committed) / committed * 100. Used to assess severity of in-full failures.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational function or external party accountable for the OTIF failure. Used for performance accountability and continuous improvement initiatives.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Retailer Penalty Amount' ;
    rdfs:comment 'The financial penalty or chargeback amount assessed by the retailer for OTIF non-compliance per the customer contract or retailer compliance program. Zero for compliant deliveries.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: Freight order creation for every outbound order manages carrier tendering, freight cost tracking, and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: Regulatory traceability: outbound orders must reference the production order that generated the shipped product for recall and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:shipToLocationDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Distribution Facility Id' ;
    rdfs:comment 'Identifier of the destination location where the order will be delivered. May reference retail store, warehouse, or customer facility.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the order was cancelled. Null for active orders. Used for cancellation rate analysis and order lifecycle reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms defining the division of costs and risks between buyer and seller. Critical for export orders and freight responsibility determination. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the outbound order based on fulfillment channel and destination. Retail replenishment serves store orders, DSD (Direct Store Delivery) bypasses DC, ecommerce serves online consumers, inter-DC transfer moves inventory between distribution centers, wholesale serves B2B customers, export serves international markets.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms agreed with the customer for this order. Examples include Net 30, Net 60, COD (Cash on Delivery), or prepaid. Impacts accounts receivable and cash flow management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to the outbound order for warehouse sequencing and resource allocation. Critical orders receive highest priority, rush orders are expedited, expedited orders have faster processing, standard orders follow normal flow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Delivery speed commitment for the outbound order. Determines carrier selection, freight cost, and OTIF measurement criteria.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Transportation mode used for order delivery. Ground for truck, air for expedited freight, ocean for international, rail for bulk, parcel for small packages, LTL (Less Than Truckload) for partial loads, FTL (Full Truckload) for full loads. [ENUM-REF-CANDIDATE: ground|air|ocean|rail|parcel|ltl|ftl — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Identifier of the warehouse wave that includes this order. Wave picking groups orders for efficient batch picking and resource optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Unique identifier for the outbound order line item.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:labelVersionId rdf:type rdf:Property ;
    rdfs:label 'Label Version Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_version. Business justification: Label version compliance check before order fulfillment guarantees the label used for the SKU is approved for the destination market.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Quantity allocated from warehouse inventory to this order line.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Unit Quantity' ;
    rdfs:comment 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed available for fulfillment after ATP (Available to Promise) check.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPoLineNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Line Number' ;
    rdfs:comment 'Customer\'s purchase order line number for cross-reference and reconciliation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediLineReference rdf:type rdf:Property ;
    rdfs:label 'Edi Line Reference' ;
    rdfs:comment 'EDI transaction line reference number for electronic order processing and ASN generation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Code' ;
    rdfs:comment 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Line Volume M3' ;
    rdfs:comment 'Total volume of the shipped quantity for this line in cubic meters.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineWeightKg rdf:type rdf:Property ;
    rdfs:label 'Line Weight Kg' ;
    rdfs:comment 'Total weight of the shipped quantity for this line in kilograms.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed into shipping containers.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers and ready for dispatch.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse pick zone designation for labor management and routing optimization.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Quantity physically picked from warehouse storage locations during fulfillment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was shipped from the distribution center.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Quantity actually shipped to the customer, may differ from ordered due to short-ship scenarios.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortShipFlag rdf:type rdf:Property ;
    rdfs:label 'Short Ship Flag' ;
    rdfs:comment 'Indicates whether this line was short-shipped (shipped quantity less than ordered quantity).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code for short shipment (OOS=Out of Stock, DAMAGE=Damaged Inventory, RECALL=Product Recall, EXPIRED=Expired Product, ALLOCATION=Allocation Constraint).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Unit Volume M3' ;
    rdfs:comment 'Volume per unit of the SKU in cubic meters for space utilization and load planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeightKg rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Kg' ;
    rdfs:comment 'Weight per unit of the SKU in kilograms for freight calculation and capacity planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Distribution center or warehouse location code from which this line was fulfilled.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the packing task record. Primary key.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPackEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pack Employee Id' ;
    rdfs:comment 'Identifier of the warehouse operator who performed the packing task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier for the shipping carton or container used for packing.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonizationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Cartonization Rule Code' ;
    rdfs:comment 'Reference to the cartonization algorithm or business rule used to determine optimal packing configuration.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Code' ;
    rdfs:comment 'Code identifying the destination distribution center, retail store, or customer facility for the packed shipment.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the packed container including product and packaging materials, measured in kilograms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelPrintedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Printed Timestamp' ;
    rdfs:comment 'Timestamp when the shipping label was printed for the packed container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Type of shipping label applied to the packed container.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the product contents excluding packaging materials, measured in kilograms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetShipDate rdf:type rdf:Property ;
    rdfs:label 'Otif Target Ship Date' ;
    rdfs:comment 'Target ship date for OTIF performance measurement and customer service level compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Completion Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was completed and sealed for dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the packing task, used for labor productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was initiated by the operator.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Identifier of the physical pack station or workstation where packing occurred.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the packing task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packType rdf:type rdf:Property ;
    rdfs:label 'Pack Type' ;
    rdfs:comment 'Type of packing configuration used for the task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used for the carton or pallet.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of quality verification performed on the packed container before dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs packed into the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total quantity of units packed across all SKUs in the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric capacity of the packed container in cubic meters, used for transportation planning.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Unique identifier for the pick task record. Primary key for the pick_task data product.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Employee Id' ;
    rdfs:comment 'Reference to the warehouse operator or picker assigned to execute this task.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:gs1128Label rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Label' ;
    rdfs:comment 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickAccuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Flag' ;
    rdfs:comment 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickListNumber rdf:type rdf:Property ;
    rdfs:label 'Pick List Number' ;
    rdfs:comment 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Quantity' ;
    rdfs:comment 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was assigned to an operator by the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was completed and confirmed by the operator or WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Timestamp when the operator began executing the pick task (scanned start or confirmed task initiation). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the pick task: pending (awaiting assignment), assigned (allocated to operator), in_progress (actively being executed), completed (finished successfully), cancelled (voided), on_hold (temporarily suspended).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Discriminator indicating the type of fulfillment task: pick (picking only), pack (packing only), pick_and_pack (combined operation), or replenishment_pick (internal stock movement).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskId rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Id' ;
    rdfs:comment 'Unique identifier for the putaway task record generated by the WMS. Primary key for the putaway task entity.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryReplenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Inventory Replenishment Order Id' ;
    rdfs:comment 'Identifier of the replenishment order that generated this putaway task, applicable when the task type is replenishment from reserve to pick face.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryReplenishmentOrder .

ind:primaryPutawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Putaway Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location from which the goods are being moved (e.g., receiving dock, staging area, reserve storage).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:targetLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Location Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location to which the goods are being moved (e.g., reserve storage bin, pick face slot, cross-dock staging).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'The method used by the warehouse operator to confirm task completion: barcode scan, RFID tag read, manual entry, voice-directed picking system, or vision-based verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cubeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Cube Cubic Feet' ;
    rdfs:comment 'The total volume in cubic feet of the goods being moved, used for space utilization analysis and slotting optimization.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'The elapsed time in minutes from task start to task completion, a key labor productivity KPI used to measure warehouse associate efficiency and identify process bottlenecks.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Code' ;
    rdfs:comment 'Identifier of the material handling equipment (forklift, pallet jack, reach truck) used to execute the putaway task, tracked for equipment utilization and maintenance scheduling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text description of the exception or issue encountered during putaway execution, providing additional context for operational review and corrective action.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStrategy rdf:type rdf:Property ;
    rdfs:label 'Movement Strategy' ;
    rdfs:comment 'The inventory rotation or replenishment strategy applied to this putaway task: FEFO (First Expired First Out), FIFO (First In First Out), min/max threshold-based, kanban pull signal, wave-driven batch, zone-based slotting, or ABC classification velocity-based. [ENUM-REF-CANDIDATE: FEFO|FIFO|min_max|kanban|wave_driven|zone_based|ABC_classification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required quality inspection has been completed and passed, enabling downstream processes to proceed.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a quality inspection is required before or after putaway completion, typically for high-value items, temperature-sensitive goods, or regulatory compliance.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Human-readable code of the source location (e.g., DOCK-A-01, STAGE-B-05) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system or module that generated this putaway task record (e.g., BLUE_YONDER_WMS, SAP_EWM, MANHATTAN_WMS), used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Target Location Code' ;
    rdfs:comment 'Human-readable code of the target location (e.g., A-12-03-B, PICK-C-22) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was cancelled, applicable when the task is aborted due to inventory discrepancies, system errors, or operational changes.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was created by the WMS, marking the start of the task lifecycle and used for cycle time calculation.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the putaway task, typically generated by Blue Yonder WMS for tracking and operator reference.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'The physical distance in feet traveled by the warehouse operator from source to target location, used for slotting optimization and labor efficiency analysis.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Lbs' ;
    rdfs:comment 'The total weight in pounds of the goods being moved in this putaway task, used for equipment selection, labor safety, and capacity planning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Id' ;
    rdfs:comment 'Unique identifier for the returns receipt record. Primary key.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReturnsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Returns Employee Id' ;
    rdfs:comment 'Identifier of the quality assurance employee who performed the condition inspection of the returned goods.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Identifier of the recall event if this return is recall-driven, linking to the recall management record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Quality inspection result indicating the physical and salability condition of the returned goods: resalable, damaged, expired, defective, or contaminated.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total monetary credit amount issued to the customer for the returned goods.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued to the customer account for the returned goods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destroyQuantity rdf:type rdf:Property ;
    rdfs:label 'Destroy Quantity' ;
    rdfs:comment 'Quantity of returned units that must be destroyed due to damage, contamination, or recall requirements.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Completion Timestamp' ;
    rdfs:comment 'Date and time when the final disposition decision was executed (resale, destroy, rework, etc.).' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on how the returned goods will be handled: resale to inventory, destroy, rework/repackage, donate, or return to vendor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Timestamp' ;
    rdfs:comment 'Date and time when the quality and condition inspection of returned goods was completed.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Total quantity of units returned in this receipt.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether the return is part of a product recall event (True) or not (False).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time when the returned goods were physically received at the distribution center. Principal business event timestamp.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resalableQuantity rdf:type rdf:Property ;
    rdfs:label 'Resalable Quantity' ;
    rdfs:comment 'Quantity of returned units deemed resalable and eligible to be returned to inventory.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally-known return authorization number issued to approve the return. Also known as RA# or RMA number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return source: retailer return, DSD (Direct Store Delivery) customer return, consumer return, recall-driven return, or internal transfer.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of returned units that will be reworked, repackaged, or refurbished for resale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeAccrualId rdf:type rdf:Property ;
    rdfs:label 'Finance Accrual Id' ;
    rdfs:comment 'Unique identifier for the financial accrual record. Primary key for the accrual entity.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFinanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Finance Employee Id' ;
    rdfs:comment 'User ID of the finance manager or controller who approved the accrual entry. Required for SOX compliance and segregation of duties.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFinanceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Finance Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the accrual entry. Tracks changes for audit trail and SOX compliance.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualCategory rdf:type rdf:Property ;
    rdfs:label 'Accrual Category' ;
    rdfs:comment 'High-level accounting category of the accrual entry. Determines whether this is an expense accrual, liability accrual, revenue accrual, or prepaid asset.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the accrual entry. Tracks the approval and posting workflow state for SOX compliance and audit trail.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the accrual by business purpose. Determines the nature of the expense or liability being recognized.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of the accrual in the base currency. Represents the estimated expense or liability being recognized in the current accounting period.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text notes documenting the business rationale, assumptions, and any special circumstances related to the accrual. Supports external audit review.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Method by which the accrual was calculated and recorded. Indicates whether the accrual was manually entered by finance staff or automatically generated by system rules.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area or division code for cross-company segment reporting. Enables consolidated financial statements by business line.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Calculation Method Description' ;
    rdfs:comment 'Detailed explanation of how the accrual amount was calculated. Supports audit review and ensures transparency in accrual estimation methodology.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity company code for which the accrual is recorded. Supports multi-entity consolidation and statutory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Date on the source document that triggered the accrual. May differ from posting date for period-end adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique document number assigned to this accrual entry in the financial system. Used for audit trail and cross-reference with source documents.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month) within the fiscal year when the accrual is recognized. Typically 1-12 for monthly periods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the accrual is recognized. Supports period-end reporting and year-over-year analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost of sales accounting. Distinguishes between COGS, SG&A, R&D, and other functional expense categories.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account number to which the accrual is posted. Determines the financial statement line item affected by this accrual.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Product or material SKU if the accrual is product-specific (e.g., warranty accrual by SKU). Null for non-product accruals.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date when the accrual entry was posted to the general ledger. Determines the accounting period in which the accrual is recognized.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center code for segment reporting and profitability analysis. Supports EBITDA reporting by business unit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Scheduled date when the accrual will be automatically reversed in the subsequent accounting period. Null for accruals that do not auto-reverse.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversal entry if the accrual has been reversed. Links the original accrual to its reversal for complete audit trail.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Reason code explaining why the accrual was reversed. Supports audit review and analysis of accrual accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Unique identifier of the source document or transaction in the originating system. Enables traceability back to the source for audit purposes.' ;
    rdfs:domain ind:FinanceAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether the accrual entry meets SOX compliance requirements including proper documentation, approval, and audit trail. True if compliant, False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice entity.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Reference to the company bank account from which payment was or will be made. Used for cash management and bank reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the automated payment run batch that processed this invoice payment. Used for payment reconciliation and audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated. Typically the invoice date or goods receipt date depending on payment term configuration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The financial document number that cleared the open payable balance. Links the invoice to the payment transaction for reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center to which the invoice expense is allocated. Used for management accounting and departmental cost tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID of the person who created the invoice record. Required for SOX-compliant audit trails and segregation of duties verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor according to the payment terms. Used for cash flow planning and Days Sales Outstanding (DSO) tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyPaymentDiscountTaken rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Taken' ;
    rdfs:comment 'The actual cash discount amount captured by paying the invoice within the early payment discount period. Key metric for working capital optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate used to convert the invoice amount to the company\'s local currency for financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before any deductions, including all line items, taxes, and freight charges.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'Classification of the invoice by spend category (e.g., raw materials, packaging, contract manufacturing, indirect goods, services). Used for spend analytics and procurement reporting. [ENUM-REF-CANDIDATE: raw_materials|packaging|contract_manufacturing|indirect_goods|services|freight|utilities|rent — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. This is the document date from the vendor\'s invoice and is used for aging analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or header text providing additional context about the invoice, such as the nature of goods or services purchased.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable process. Tracks the invoice from receipt through payment and clearing. [ENUM-REF-CANDIDATE: draft|posted|approved|paid|partially_paid|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Status of the three-way match verification process comparing the invoice to the purchase order and goods receipt. Critical for payment approval workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The user ID of the person who last modified the invoice record. Required for SOX-compliant audit trails.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The actual amount paid to the vendor. May differ from net amount if partial payments or adjustments were made.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if the invoice is blocked for payment and the reason for the block (e.g., price variance, quantity variance, quality issue, pending approval).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date payment was executed to the vendor. Used for cash flow tracking and Days Inventory Outstanding (DIO) calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Additional reference number for cross-referencing to other documents such as delivery notes, packing slips, or contract numbers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction code or tax type applied to the invoice (e.g., sales tax, VAT, GST). Used for tax reporting and compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Code' ;
    rdfs:comment 'Reference to the vendor\'s bank account to which payment was or will be sent. Required for electronic payment processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice number assigned by the vendor. This is the external reference number printed on the vendor\'s invoice document.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment to the vendor as required by tax regulations. Must be remitted to tax authorities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment record. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Identifier of the invoice being paid. Links to the accounts payable invoice record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerGoods .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the payment was approved. Supports audit trails and payment cycle time analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountCode rdf:type rdf:Property ;
    rdfs:label 'Bank Account Code' ;
    rdfs:comment 'Identifier of the company bank account from which the payment was issued. Links to the bank account master data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the payment cleared the open invoice in the accounts payable subledger. Used for Days Inventory Outstanding (DIO) and working capital analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The date by which the payment must be made to qualify for the early payment discount. Used for working capital optimization decisions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The payment amount converted to the company\'s local reporting currency using the exchange rate. Used for consolidated financial reporting and EBITDA calculations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company\'s local reporting currency (e.g., USD). Used for financial consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified the payment record. Supports SOX-compliant audit trails and change tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net payment amount after applying early payment discounts and any other adjustments. This is the actual amount transferred to the supplier.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Approval status of the payment. Pending indicates awaiting approval, approved indicates authorized for processing, rejected indicates payment was denied. Supports SOX-compliant approval workflows.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Description of the reason the payment was blocked (e.g., pending invoice verification, supplier on hold, duplicate payment suspected). Used for exception management.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReleasedBy rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released By' ;
    rdfs:comment 'User ID or name of the person who released the payment block and authorized the payment to proceed. Supports SOX-compliant audit trails.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released Date' ;
    rdfs:comment 'The date on which the payment block was released and the payment was authorized to proceed. Supports audit trails and payment cycle time analysis.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP). Supports multi-currency payment processing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The externally-known payment document number assigned by the ERP system. Used for reconciliation and audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments about the payment. Used to capture special instructions, exceptions, or additional context for audit and reconciliation purposes.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number provided to the supplier for payment identification and reconciliation (e.g., check number, wire confirmation number, ACH trace number).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunCode rdf:type rdf:Property ;
    rdfs:label 'Payment Run Code' ;
    rdfs:comment 'Identifier of the payment run batch that grouped multiple payments for processing. Used for batch reconciliation and audit trails.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the supplier. Used for supplier communication tracking.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a remittance advice was sent to the supplier to notify them of the payment details. True indicates sent, False indicates not sent.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable invoice record. Primary key for the AR invoice entity.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sales Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: AR invoice reconciliation process matches each AR invoice to the originating sales invoice for cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:amountReceived rdf:type rdf:Property ;
    rdfs:label 'Amount Received' ;
    rdfs:comment 'Total amount received from the customer against this invoice. May be less than total amount due to partial payments or deductions. Null for unpaid invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when the invoice was created and issued to the customer. Principal business event timestamp for the invoice lifecycle.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Billing Document Type' ;
    rdfs:comment 'SAP billing document type code indicating the nature of the invoice (e.g., F2=standard invoice, G2=credit memo, L2=debit memo). Determines accounting treatment and revenue recognition.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference' ;
    rdfs:comment 'Reference number assigned when the invoice is cleared in the financial system. Links to the clearing document for audit trail. Null for open invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total amount of deductions taken by the customer against this invoice. Includes short-payments, chargebacks, and unauthorized deductions requiring resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Reason Code' ;
    rdfs:comment 'Code indicating the reason for customer deductions (e.g., pricing dispute, damaged goods, short shipment, promotional allowance). Used for deduction root cause analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Channel through which the goods were sold (e.g., retail, wholesale, DTC, e-commerce). Used for channel profitability analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoAgingBucket rdf:type rdf:Property ;
    rdfs:label 'Dso Aging Bucket' ;
    rdfs:comment 'Aging category based on number of days the invoice has been outstanding past the due date. Used for DSO reporting, collections prioritization, and bad debt provisioning.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the invoice was posted to the general ledger. Used for financial period assignment and month-end close processes.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total amount minus amount received. Zero when invoice is fully paid or cleared.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this invoice is recognized in the financial statements under ASC 606/IFRS 15. May differ from billing date based on performance obligation fulfillment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP sales organization responsible for the sale. Used for sales performance reporting and commission calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final invoice amount including all discounts and taxes. This is the total amount due from the customer and the target for cash application.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Total trade discounts applied to the invoice, including volume discounts, promotional allowances, and negotiated rebates. Reduces gross amount to net amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible bad debt. Null for invoices not written off. Impacts bad debt expense and allowance for doubtful accounts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date when the invoice or portion thereof was written off as uncollectible. Null for invoices not written off.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Code indicating the reason for write-off (e.g., customer bankruptcy, uncollectible, small balance write-off). Used for bad debt analysis and credit policy refinement.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment record. Primary key.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Amount of payment applied to the invoice after deductions and adjustments. Net amount reducing accounts receivable balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank transaction reference or confirmation number. Used for bank statement reconciliation and audit trail.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number when payment method is check. Used for check reconciliation and fraud prevention.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToPay rdf:type rdf:Property ;
    rdfs:label 'Days To Pay' ;
    rdfs:comment 'Number of days between invoice date and payment date. Key metric for Days Sales Outstanding (DSO) calculation and customer payment behavior analysis.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionNotes rdf:type rdf:Property ;
    rdfs:label 'Deduction Notes' ;
    rdfs:comment 'Free-text notes explaining the deduction or short payment. Captures customer explanation and internal investigation details.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSetReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set Reference' ;
    rdfs:comment 'EDI 820 transaction set control number when payment received via EDI. Used for EDI reconciliation and compliance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'Lockbox batch identifier when payment received through bank lockbox service. Used for lockbox reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Overpayment Flag' ;
    rdfs:comment 'Indicates whether payment amount exceeds the invoice balance. True if customer paid more than owed.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates whether this is a partial payment against the invoice. True if payment amount is less than invoice balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which payment was received. Distinguishes interface from payment instrument.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Code' ;
    rdfs:comment 'Transaction identifier from third-party payment processor (e.g., Stripe, PayPal, Adyen). Used for processor reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number from customer remittance advice document. Links payment to customer payment notification (EDI 820 or paper remittance).' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Short Payment Flag' ;
    rdfs:comment 'Indicates whether customer paid less than invoice amount without authorized deduction. Triggers deduction management workflow.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Date when funds become available in the bank account. May differ from payment date due to clearing time.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cogsAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Id' ;
    rdfs:comment 'Unique identifier for the COGS allocation record. Primary key for the product costing and COGS allocation master.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productBomId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Id' ;
    rdfs:comment 'Reference to the bill of materials used for this cost calculation. Links cost to recipe/formula structure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBom .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Reference to the production routing (sequence of operations) used for this cost calculation. Links cost to manufacturing process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date when the COGS allocation was calculated and posted. Key business event timestamp for cost assignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate costs to the product: direct (traced), activity_based (ABC costing), weighted_average, FIFO (first-in-first-out), or standard (predetermined rate).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'Quantity basis used for cost calculation. Fixed costs are spread over this lot size to determine unit cost.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingSheet rdf:type rdf:Property ;
    rdfs:label 'Costing Sheet' ;
    rdfs:comment 'Template defining overhead calculation rules and cost component structure for this allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingType rdf:type rdf:Property ;
    rdfs:label 'Costing Type' ;
    rdfs:comment 'Type of cost estimate: standard (baseline for valuation), actual (realized costs), planned (budgeted), or simulated (what-if scenario).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'Version identifier for the costing run (e.g., standard cost, planned cost, actual cost). Enables parallel costing scenarios and version comparison.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationCost rdf:type rdf:Property ;
    rdfs:label 'Depreciation Cost' ;
    rdfs:comment 'Allocated depreciation expense for production equipment and facilities used in manufacturing.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directLaborCost rdf:type rdf:Property ;
    rdfs:label 'Direct Labor Cost' ;
    rdfs:comment 'Cost component for direct production labor involved in manufacturing the product.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Fixed Overhead Cost' ;
    rdfs:comment 'Fixed manufacturing overhead costs that remain constant regardless of production volume (e.g., facility rent, salaries).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInCost rdf:type rdf:Property ;
    rdfs:label 'Freight In Cost' ;
    rdfs:comment 'Inbound freight and logistics costs for raw materials and components. Part of landed cost calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Lot Size Unit' ;
    rdfs:comment 'Unit of measure for the costing lot size (e.g., EA for each, KG for kilogram, L for liter).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Machine Overhead Cost' ;
    rdfs:comment 'Cost component for machine and equipment usage, including depreciation, maintenance, and operating costs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherCost rdf:type rdf:Property ;
    rdfs:label 'Other Cost' ;
    rdfs:comment 'Miscellaneous cost components not classified in standard categories (e.g., quality testing, rework, scrap).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Cost component for primary, secondary, and tertiary packaging materials. Critical for CPG product costing.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Indicates whether material is valued at standard price (S) or moving average price (V). Critical for inventory valuation method.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'Cost component for raw materials and ingredients used in production. Key driver of COGS in consumer goods manufacturing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Lifecycle status of the cost estimate: draft (in progress), released (approved for use), locked (frozen for audit), archived (historical).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total allocated cost per unit including all cost components (raw material, packaging, labor, overhead, freight, depreciation).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'End date until which this cost estimate remains valid. Null indicates open-ended validity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Start date from which this cost estimate is valid and applicable for inventory valuation and margin calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Classification code that determines which general ledger accounts are updated during inventory movements and COGS posting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Variable Overhead Cost' ;
    rdfs:comment 'Variable manufacturing overhead costs that fluctuate with production volume (e.g., utilities, indirect materials).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between standard cost and actual cost. Positive indicates unfavorable variance (actual > standard), negative indicates favorable variance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Classification of cost variance by root cause: price (input cost change), quantity (usage deviation), mix (recipe change), yield (output efficiency), efficiency (labor/machine productivity), volume (fixed cost absorption).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Employee identifier of the manager accountable for this cost center\'s budget and performance. Used for approval workflows and variance analysis reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Activity Type Indicator' ;
    rdfs:comment 'Flag indicating whether this cost center performs activity-based costing. True if the center provides measurable activities (e.g., machine hours, labor hours) that are allocated to cost objects.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetProfileCode rdf:type rdf:Property ;
    rdfs:label 'Budget Profile Code' ;
    rdfs:comment 'Budget control profile defining budget planning rules, tolerance limits, and approval workflows for this cost center. Determines budget availability check behavior.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'Controlling area to which this cost center belongs. Represents the highest organizational unit in SAP CO module for internal cost accounting and management reporting. Typically aligned with legal entity or geographic region.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Accounting classification indicating whether costs are direct (attributable to products), indirect (supporting operations), overhead (administrative), or capital (asset-related). Critical for COGS calculation and financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended description providing additional context about the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Logical grouping of cost centers for consolidated reporting and analysis. Enables flexible aggregation beyond standard hierarchy (e.g., all brand marketing centers, all R&D centers).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center. Human-readable label identifying the organizational unit (e.g., \'Brand Marketing - North America\', \'Manufacturing Plant 01 - Production Line A\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept postings; inactive centers are closed; blocked centers are temporarily suspended; planned centers are approved but not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area. Determines the nature of costs tracked and reporting hierarchy. Used for COGS allocation and EBITDA segmentation. [ENUM-REF-CANDIDATE: production|sales|marketing|distribution|administration|research_development|quality_assurance|procurement|finance|shared_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department or functional unit code within the organization. Provides granular classification for workforce planning and departmental cost analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Standard hierarchy assignment for organizational reporting. Defines the cost center\'s position in the corporate hierarchy tree for roll-up reporting and budget consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID of the person who last modified the cost center master record. Audit trail for change tracking and SOX compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the cost center is locked for actual postings. Used during period-end close and organizational changes to prevent unintended transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'Code of the parent cost center in the organizational hierarchy. Enables hierarchical roll-up of costs for management reporting and budget aggregation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Manufacturing plant or distribution center code associated with this cost center. Links production and logistics cost centers to physical facilities for COGS allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region classification (e.g., NOAM, EMEA, APAC, LATAM) for regional financial reporting and performance benchmarking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Flag indicating whether this is a statistical cost center used only for informational reporting without actual cost postings. Used for tracking non-financial metrics.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which the cost center is valid and can accept cost postings. Supports time-dependent organizational changes and fiscal year transitions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which the cost center is valid. Nullable for open-ended cost centers. Used for organizational restructuring and cost center retirement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Unique identifier for the finance budget record. Primary key for the finance budget entity.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID or name of the individual who approved this budget line. Supports SOX-compliant audit trail and segregation of duties.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level categorization of the budget type such as operating expense (OPEX), capital expenditure (CAPEX), headcount, revenue, cost of goods sold (COGS), marketing, or research and development (R&D). [ENUM-REF-CANDIDATE: opex|capex|headcount|revenue|cogs|marketing|r_and_d — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional free-text comments or notes related to this budget line. Provides supplementary context for budget review and analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'Cost element classification code used in controlling for cost type categorization (e.g., labor, materials, overhead).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaCategory rdf:type rdf:Property ;
    rdfs:label 'Ebitda Category' ;
    rdfs:comment 'EBITDA bridge category classification for this budget line (revenue, COGS, operating expense, depreciation, amortization, non-operating). Supports EBITDA waterfall and bridge analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group reporting currency in which the planned amount is converted.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibpIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Ibp Integration Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is integrated with the Integrated Business Planning (IBP) or Sales and Operations Planning (S&OP) process.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Free-text notes providing business justification, rationale, or assumptions underlying this budget line. Supports zero-based budgeting (ZBB) and budget review processes.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Budgeting methodology applied to this budget line (incremental, zero-based, activity-based, driver-based, rolling). Supports methodological transparency and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmountGroup rdf:type rdf:Property ;
    rdfs:label 'Planned Amount Group' ;
    rdfs:comment 'Planned budget amount converted to the group reporting currency. Used for consolidated financial reporting and cross-entity analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Planned Amount Local' ;
    rdfs:comment 'Planned budget amount in the local currency of the company code. Primary budget value for local financial planning and reporting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Planned quantity or volume associated with this budget line (e.g., units produced, headcount, hours). Used for activity-based costing and volume variance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code identifying the product line or product category to which this budget is allocated. Supports product-level profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Budget profile or template code defining the budget structure, rules, and allocation logic applied to this budget line.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Percentage threshold for budget variance alerting and exception reporting. Used to trigger management review when actual spending deviates from budget.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key for the fixed asset master data. Inferred role: MASTER_RESOURCE.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since the asset was placed in service. Represents the cumulative reduction in asset value over time. Used to calculate net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or historical cost of the asset at acquisition, including all costs necessary to bring the asset to working condition (purchase price, freight, installation, testing). Basis for depreciation calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code that categorizes the asset by type (e.g., machinery, buildings, vehicles, IT equipment). Determines depreciation rules, useful life, and accounting treatment. Corresponds to SAP Asset Class or Oracle Asset Category.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset, including make, model, specifications, and distinguishing characteristics. Used for identification and reporting purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetGroupCode rdf:type rdf:Property ;
    rdfs:label 'Asset Group Code' ;
    rdfs:comment 'Grouping code for reporting and analysis purposes. Used to aggregate assets by category, function, or business unit for management reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset identifier assigned by the enterprise. Business identifier used for asset tracking, reporting, and audit trails. Corresponds to SAP Asset Number or Oracle Asset Number.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique identifier assigned by the vendor. Used for warranty tracking, maintenance, and physical verification.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Indicates whether the asset is operational, under construction, retired, or disposed. Controls depreciation posting and asset transactions. [ENUM-REF-CANDIDATE: active|in_service|under_construction|retired|disposed|impaired|transferred|inactive — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectCode rdf:type rdf:Property ;
    rdfs:label 'Capex Project Code' ;
    rdfs:comment 'Capital project or work breakdown structure (WBS) element under which the asset was acquired. Used for capital budget tracking and project cost reconciliation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when the asset was capitalized and placed in service. Depreciation begins from this date. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'Depreciation area or book (e.g., book depreciation, tax depreciation, IFRS depreciation). Allows parallel valuation for different reporting purposes. Corresponds to SAP Depreciation Area.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationEndDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation End Date' ;
    rdfs:comment 'Date when depreciation posting ends for the asset. Calculated based on useful life or set manually when the asset is fully depreciated, retired, or disposed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to allocate the cost of the asset over its useful life. Common methods include straight-line, declining balance, and units of production. Determines the depreciation expense pattern.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'Date when depreciation posting begins for the asset. Typically the capitalization date or the first day of the following month, depending on enterprise policy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the asset was disposed, sold, scrapped, or retired. Marks the end of the asset lifecycle. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from the sale or disposal of the asset. Used to calculate gain or loss on disposal (proceeds minus net book value at disposal).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'Business reason for disposing of the asset. Used for asset lifecycle analysis, capital planning, and audit trails. [ENUM-REF-CANDIDATE: sale|scrap|obsolete|damaged|transfer|donation|end_of_life — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Cumulative impairment loss recognized on the asset when its recoverable amount falls below its carrying value. Required under IAS 36 Impairment of Assets. Reduces net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Revaluation Date' ;
    rdfs:comment 'Date of the most recent asset revaluation. Revaluations adjust the carrying value to fair market value under IAS 16 revaluation model. Used for compliance and financial reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or vendor who produced the asset. Used for warranty claims, spare parts sourcing, and vendor performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model or part number of the asset. Used for technical specifications, spare parts identification, and maintenance planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation. Represents the remaining capitalized value of the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Amount of the most recent revaluation adjustment. Positive values indicate upward revaluation; negative values indicate impairment. Posted to revaluation reserve or income statement per IAS 16.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. The amount expected to be recovered through sale or disposal. Depreciation is calculated on acquisition cost minus salvage value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected economic useful life of the asset in years, as determined by asset class and enterprise policy. Used to calculate annual depreciation expense. May be fractional (e.g., 7.5 years).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Identifier of the vendor or supplier from whom the asset was purchased. Used for vendor performance tracking and procurement analytics.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer warranty expires. Used to determine whether repairs are covered under warranty or require capital expenditure.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GL account ownership required for audit trails and SOX compliance; reports list responsible employee per account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts framework to which this account belongs. Links to the chart_of_accounts master data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Reference to the company code (legal entity) to which this GL account belongs. Links to the company_code master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:controllingAreaId rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Id' ;
    rdfs:comment 'Reference to the controlling area for cost accounting and management reporting. Links to the controlling_area master data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControllingArea .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group classification that controls field status, number ranges, and posting rules in the ERP system.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The full descriptive name of the GL account as it appears in financial reports and statements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in condensed reports and system displays.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, indicates whether the account is a current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to accounts that are under review, closed, or being restructured.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether budget availability checking is active for this account. When enabled, postings are validated against approved budgets.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'For accounts that impact cash flow, indicates the cash flow statement category: operating activities, investing activities, or financing activities. Not applicable for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The corresponding account number in the group consolidation chart of accounts. Used for mapping local accounts to group reporting structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. Used for internal cost allocation and management reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, indicates whether it is a primary cost element (direct posting from FI) or secondary cost element (internal allocation only). Not applicable if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this GL account is also defined as a cost element in the Controlling (CO) module for cost center and internal order postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the account normally carries a debit balance or credit balance in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status group that controls which fields are required, optional, or suppressed when posting to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'The primary financial statement where this account appears: balance sheet, income statement (P&L), cash flow statement, retained earnings, or statistical.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item or section within the financial statement where this account balance is reported (e.g., Current Assets, Cost of Goods Sold, Operating Expenses).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions that require clearing and elimination in consolidated financial statements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line item details are stored and can be displayed for this account. Required for detailed transaction analysis and audit trails.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether this account uses open item management for tracking and clearing individual line items (e.g., AR, AP, bank clearing accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plCategory rdf:type rdf:Property ;
    rdfs:label 'Pl Category' ;
    rdfs:comment 'For income statement accounts, indicates the P&L category: gross revenue, net revenue, COGS, gross margin, operating expense (SG&A, marketing, trade spend), EBITDA, EBIT, or net income. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|cogs|gross_margin|operating_expense|ebitda|ebit|net_income|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The organizational level at which budget planning and forecasting is performed for this account (e.g., company code, profit center, cost center).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct postings are allowed to this account. Some accounts (e.g., summary or control accounts) may only accept postings from automated processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. Used for segment reporting and profitability analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as AR, AP, or inventory.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainedEarningsAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Flag' ;
    rdfs:comment 'Indicates whether this is the retained earnings account where net income/loss is transferred during year-end closing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort key used for organizing and displaying line items within this account (e.g., posting date, document number, amount).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Account Flag' ;
    rdfs:comment 'Indicates whether this account is subject to SOX internal control requirements and enhanced audit procedures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account (e.g., taxable revenue, non-taxable revenue, input tax, output tax, tax-exempt). Used for VAT, sales tax, and GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Code Allowed Flag' ;
    rdfs:comment 'Indicates whether tax codes can be entered when posting to this account. Typically true for revenue and expense accounts, false for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for this entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliminationJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Elimination Journal Entry Id' ;
    rdfs:comment 'The unique identifier of the consolidation elimination journal entry that reversed this intercompany transaction in the group financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:nettingRunId rdf:type rdf:Property ;
    rdfs:label 'Netting Run Id' ;
    rdfs:comment 'The unique identifier of the netting run in which this intercompany transaction was processed, if applicable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingRun .

ind:armsLengthValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Arms Length Validated Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the transfer price has been validated as compliant with arms-length pricing principles under OECD transfer pricing guidelines.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this intercompany transaction has been eliminated in the consolidated group financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the corporate group\'s reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingStatus rdf:type rdf:Property ;
    rdfs:label 'Matching Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction has been successfully matched with the corresponding entry in the counterparty entity\'s records during the intercompany reconciliation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction has been included in an intercompany netting process to reduce cash movements between entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The company code of the legal entity receiving the intercompany transaction. Represents the crediting entity in the intercompany posting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'The unique reference number linking this intercompany transaction to its corresponding entry in the counterparty entity\'s books for reconciliation purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'The company code of the legal entity initiating or sending the intercompany transaction. Represents the debiting entity in the intercompany posting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this intercompany transaction is subject to SOX internal control testing and audit procedures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary value of the intercompany transaction in the transaction currency, before any adjustments or eliminations.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'Free-text description providing additional context and business rationale for this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this intercompany transaction in the ERP system. Used for cross-reference and audit trail.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'The price charged for goods or services in this intercompany transaction, established according to the company\'s transfer pricing policy.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The transfer pricing methodology applied to determine the arms-length price: Comparable Uncontrolled Price (CUP), Resale Price Method (RPM), Cost Plus Method (CPM), Transactional Net Margin Method (TNMM), Profit Split Method (PSM), or other.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry header.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Journal entries belong to a specific ledger; adding ledger_id FK links each entry to its ledger without removing existing ledger_group (kept for reporting).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'User ID of the person who posted or created this journal entry. Critical for SOX compliance and audit trail. Confidential business information.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date used for calculating payment terms and due dates for vendor invoices and customer receivables. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Identifier of the batch input session if this journal entry was created through automated batch processing. Used for tracking mass data uploads and interface postings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Organizational unit in management accounting that represents a closed system for cost accounting. Used for internal management reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification code indicating the nature and source of the journal entry. Examples: SA (General Ledger Document), AB (Accounting Document), KR (Vendor Invoice), DR (Customer Invoice), DZ (Customer Payment), KA (Vendor Payment), KG (Vendor Credit Memo), KN (Customer Credit Memo), KZ (Payment Request), RE (Invoice Receipt), RV (Invoice Reversal), WA (Goods Issue), WE (Goods Receipt), ZP (Payment Posting). [ENUM-REF-CANDIDATE: SA|AB|KR|DR|DZ|KA|KG|KN|KZ|RE|RV|WA|WE|ZP — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the journal entry was created or entered into the system. Used for audit trail and process monitoring. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Code indicating the type of exchange rate used for currency translation. Examples: M (Average Rate), B (Bank Buying Rate), G (Bank Selling Rate), P (Posting Date Rate).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form text field for additional information or explanation about the journal entry. Used for documentation and audit purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry involves intercompany transactions between different company codes within the enterprise. True if intercompany, False otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger or accounting principle under which this entry is recorded. Examples: 0L (Leading Ledger - IFRS), 2L (Local GAAP), 3L (Management Reporting). Supports parallel accounting for multiple reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Values: draft (entry created but not posted), posted (entry successfully posted to GL), parked (entry saved for later posting), cancelled (entry voided before posting), reversed (entry reversed by a subsequent document).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal document, False otherwise.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original journal entry that is being reversed by this entry. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date relevant for tax reporting purposes. May differ from posting date based on tax jurisdiction rules. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Company code of the intercompany trading partner if this is an intercompany transaction. Used for consolidation and elimination entries. Null if not an intercompany transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'SAP transaction code or Oracle program identifier used to create this journal entry. Examples: FB01 (Post Document), FB50 (G/L Account Posting), MIRO (Enter Invoice), F-28 (Post Incoming Payments). Used for audit trail and process analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular cost allocation, COGS decomposition, and SOX-compliant audit trail tracing at the line level.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountCompanyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Company Code Currency' ;
    rdfs:comment 'Monetary amount converted to the local currency of the company code. Used for statutory reporting and local GAAP compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount converted to the group reporting currency. Enables consolidated financial reporting across all subsidiaries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Monetary amount of this line item in the original transaction currency. Preserves the original posting amount before currency conversion.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field for additional reference information such as invoice number, purchase order, or payment reference. Enhances traceability.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code local currency. Typically the statutory reporting currency of the legal entity.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'Customer account number for revenue and receivables postings. Links financial transactions to customer master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order for tracking costs of short-term jobs, events, or overhead activities. Enables job costing and overhead allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the journal entry header. Determines the ordering and position of this line in the document.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Material or SKU associated with this line item for inventory and COGS postings. Links financial postings to product master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit posting key controlling account type, debit/credit indicator, and field status. Fundamental to SAP FI posting logic.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Special GL indicator for down payments, bills of exchange, guarantees, or other special transactions. Enables special ledger processing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Descriptive text explaining the nature or purpose of this journal entry line. Provides human-readable context for audit and review.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Identifier of the intercompany trading partner for intercompany transactions. Enables intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Vendor account number for procurement and payables postings. Links financial transactions to vendor master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS element for project-related postings. Links costs and revenues to specific projects, phases, or deliverables in project accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle applied in this ledger, such as International Financial Reporting Standards (IFRS), United States Generally Accepted Accounting Principles (US GAAP), local country-specific GAAP, tax accounting rules, or management accounting conventions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Boolean flag indicating whether comprehensive audit trail logging is enabled for all postings and changes to this ledger, supporting regulatory compliance and forensic analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the base currency in which this ledger maintains balances (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this ledger is used for group consolidation purposes, aggregating financial data from multiple legal entities for consolidated financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency perspective maintained in this ledger. Local currency represents the operating entity\'s functional currency, group currency is the consolidated reporting currency, hard currency is a stable reference currency (e.g., USD, EUR), and index currency supports inflation-adjusted reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code identifying the fiscal year calendar structure used by this ledger, defining the number of posting periods, special periods, and year-end closing rules. Common in SAP S/4HANA FI to support diverse fiscal calendars across global entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeadingLedger rdf:type rdf:Property ;
    rdfs:label 'Is Leading Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this is the leading ledger (primary book of record) for the company code. Only one ledger per company code can be designated as the leading ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the ledger within the enterprise. Used as the business identifier for the ledger in SAP S/4HANA FI and Oracle Cloud Financials.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Detailed textual description of the ledger\'s purpose, scope, and usage within the enterprise financial reporting architecture. Provides context for finance users and auditors.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger for human-readable identification and reporting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger. Active ledgers accept postings, inactive ledgers are configured but not yet in use, closed ledgers are archived and no longer accept postings, and suspended ledgers are temporarily disabled.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger indicating its role in the financial reporting architecture. Leading ledger is the primary book of record, parallel ledgers support alternative accounting principles (e.g., local GAAP), and extension ledgers provide management reporting views.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Code defining the posting period structure for this ledger, including the number of regular periods (typically 12 monthly periods) and special periods for year-end adjustments and closing entries.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that financial data in this ledger must be retained to comply with statutory, tax, and regulatory record-keeping requirements. Common retention periods range from 7 to 10 years for financial records.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsCostOfSalesAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Of Sales Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports cost of sales (COGS) accounting method, which matches costs directly to revenue in the period of sale, as opposed to period-based cost accounting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProfitCenterAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Profit Center Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger maintains profit center accounting data for internal management reporting and profitability analysis by organizational unit.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSegmentReporting rdf:type rdf:Property ;
    rdfs:label 'Supports Segment Reporting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports segment reporting as required by IFRS 8 Operating Segments. Segment reporting enables financial analysis by business unit, product line, or geographic region.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'Defines the valuation perspective applied in this ledger. Legal valuation follows statutory requirements, group valuation applies consolidated group policies, profit center valuation supports internal management reporting, and cost center valuation tracks cost allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in a hierarchical profit center structure. Enables roll-up reporting and EBITDA decomposition across organizational levels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code of the consolidation unit for group reporting. Links profit center to the financial consolidation hierarchy for IFRS/GAAP reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code of the cost center group associated with this profit center. Links profit center accounting to cost center accounting for overhead allocation and COGS calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code representing the primary geographic location of the profit center for regional segment reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center participates in budgeting and financial planning processes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit center\'s business scope, responsibilities, and strategic objectives.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full business name of the profit center representing the product line, brand, or geographic business unit.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center indicating whether it is operational, temporarily suspended, or permanently closed.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension: product line, brand, geographic region, sales channel, or business unit. Determines the segment reporting structure.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the profit center manager for financial reporting notifications and escalations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the business leader or manager accountable for the profit center\'s financial performance and operational results.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center used in reports and dashboards for space-constrained displays.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'State or province code for the profit center\'s location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Primary key for revenue_recognition' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the sales contract or customer agreement under which revenue is being recognized.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerGoods .

ind:originalEventRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Event Revenue Recognition Id' ;
    rdfs:comment 'Reference to the original revenue recognition event ID if this record is a reversal or adjustment.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier for the specific performance obligation within the contract that is being satisfied. A contract may have multiple performance obligations (e.g., product delivery, extended warranty, promotional services).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order or transaction that triggered this revenue recognition event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier for the audit trail or approval workflow associated with this revenue recognition event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied Flag' ;
    rdfs:comment 'Indicates whether a constraint was applied to the variable consideration estimate to prevent revenue reversal in future periods.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeCatchUpAdjustment rdf:type rdf:Property ;
    rdfs:label 'Cumulative Catch Up Adjustment' ;
    rdfs:comment 'Cumulative catch-up adjustment to revenue recognized in prior periods due to changes in estimates of variable consideration or performance obligation satisfaction.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Amount' ;
    rdfs:comment 'The amount of revenue deferred to future periods because the performance obligation has not yet been satisfied.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedReturnsReserve rdf:type rdf:Property ;
    rdfs:label 'Estimated Returns Reserve' ;
    rdfs:comment 'Reserve amount set aside for estimated product returns based on historical return rates and current sales.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAccrual rdf:type rdf:Property ;
    rdfs:label 'Rebate Accrual' ;
    rdfs:comment 'Accrued rebate amount expected to be paid to the customer based on volume or performance thresholds.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which revenue is recognized in the financial statements under ASC 606 or IFRS 15. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized: point-in-time (at delivery or transfer of control) or over-time (as performance obligation is satisfied over a period).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event: draft (pending approval), posted (finalized in GL), reversed (cancelled), or adjusted (modified after posting).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Revenue Amount' ;
    rdfs:comment 'The amount of revenue recognized in this event after applying all constraints and adjustments.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier for the specific product or service being recognized.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePromotionDeduction rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Deduction' ;
    rdfs:comment 'Amount deducted from transaction price due to trade promotion allowances, discounts, or incentives provided to customers.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'Total transaction price allocated to this performance obligation before adjustments for variable consideration.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'Estimated amount of variable consideration including trade promotions, rebates, volume discounts, returns, and other price concessions that reduce the transaction price.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Unique identifier for the SOX control record. Primary key for the sox_control data product.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySoxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sox Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for executing and maintaining the control.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySoxTesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sox Tester Employee Id' ;
    rdfs:comment 'Identifier of the internal auditor or external auditor who performed the most recent control test.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlCode rdf:type rdf:Property ;
    rdfs:label 'Control Code' ;
    rdfs:comment 'Business identifier for the control, typically following organizational control numbering scheme (e.g., FIN-AP-001, FIN-GL-005).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDocumentationLink rdf:type rdf:Property ;
    rdfs:label 'Control Documentation Link' ;
    rdfs:comment 'URL or file path to the detailed control documentation, including control narratives, process flows, and evidence repositories.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or executed (e.g., daily reconciliation, monthly close review, event-driven approval).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short descriptive name of the control (e.g., \'Three-Way Match for Purchase Orders\', \'Journal Entry Approval\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNature rdf:type rdf:Property ;
    rdfs:label 'Control Nature' ;
    rdfs:comment 'Indicates whether the control is performed manually by personnel, automated through system configuration, or semi-automated requiring both system and manual steps.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'Detailed statement of what the control is designed to achieve, including the risk it mitigates and the assertion it supports (e.g., \'Ensure all vendor invoices are matched to purchase orders and receiving documents before payment to prevent unauthorized disbursements\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerName rdf:type rdf:Property ;
    rdfs:label 'Control Owner Name' ;
    rdfs:comment 'Full name of the control owner for reporting and accountability purposes.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerTitle rdf:type rdf:Property ;
    rdfs:label 'Control Owner Title' ;
    rdfs:comment 'Job title of the control owner (e.g., Accounts Payable Manager, Financial Controller, GL Accountant).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control: active (in operation), inactive (temporarily suspended), under-review (being evaluated for changes), or retired (no longer applicable).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its timing and purpose: preventive (stops errors before they occur), detective (identifies errors after occurrence), or corrective (remediates identified errors).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of any identified control deficiency: none (no issues), control deficiency (minor issue), significant deficiency (important enough to merit attention), or material weakness (reasonable possibility of material misstatement).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Overall assessment of control effectiveness based on testing results: effective (operating as designed), ineffective (deficiency identified), not-tested (testing not yet performed), or not-applicable (control not in scope for current period).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Exceptions Identified Count' ;
    rdfs:comment 'The number of exceptions or deviations identified during the most recent control test.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditorFirm rdf:type rdf:Property ;
    rdfs:label 'External Auditor Firm' ;
    rdfs:comment 'Name of the external audit firm that reviewed this control (e.g., Deloitte, PwC, EY, KPMG).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorReviewedIndicator rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reviewed Indicator' ;
    rdfs:comment 'Flag indicating whether this control has been reviewed by external auditors (true) or only by internal audit (false).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementAssertion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Assertion' ;
    rdfs:comment 'The specific financial statement assertion that this control supports: existence (assets/liabilities exist), completeness (all transactions recorded), accuracy (amounts correct), valuation (proper measurement), rights and obligations (entity has legal claim), or presentation and disclosure (proper classification and disclosure).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter for which this control test and assessment applies, supporting quarterly SOX certification requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itgcDependentIndicator rdf:type rdf:Property ;
    rdfs:label 'Itgc Dependent Indicator' ;
    rdfs:comment 'Flag indicating whether this control relies on IT general controls (true) or operates independently (false). ITGC-dependent controls require underlying IT controls to be effective.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Key Control Indicator' ;
    rdfs:comment 'Flag indicating whether this is a key control (true) or supporting control (false). Key controls are critical to preventing or detecting material misstatements and receive heightened testing and monitoring.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which identified deficiencies must be remediated, typically driven by materiality and external audit timelines.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Detailed notes on remediation activities, including actions taken, resources required, and progress updates.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts for identified deficiencies: not-required (no deficiency), planned (remediation plan approved), in-progress (actively remediating), completed (remediation finished), or validated (remediation effectiveness confirmed).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskArea rdf:type rdf:Property ;
    rdfs:label 'Risk Area' ;
    rdfs:comment 'The financial statement area or business process that this control addresses (e.g., Revenue Recognition, Accounts Payable, Inventory Valuation, Financial Close, COGS Allocation).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testConclusion rdf:type rdf:Property ;
    rdfs:label 'Test Conclusion' ;
    rdfs:comment 'Detailed conclusion statement from the most recent control test, including auditor assessment, basis for conclusion, and any qualifications or limitations.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the most recent control test was performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'The audit procedure used to test the control: inquiry (asking control owner), observation (watching control execution), inspection (examining evidence), re-performance (auditor executes control independently), or analytical review (comparing data patterns).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Test Population Size' ;
    rdfs:comment 'The total number of items or transactions in the population from which the test sample was drawn.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testSampleSize rdf:type rdf:Property ;
    rdfs:label 'Test Sample Size' ;
    rdfs:comment 'The number of items or transactions selected for testing in the most recent control test.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testerName rdf:type rdf:Property ;
    rdfs:label 'Tester Name' ;
    rdfs:comment 'Full name of the tester for audit trail and accountability purposes.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Unique identifier for the standard cost record. Primary key for the standard cost master data.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStandardManufacturingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Manufacturing Facility Id' ;
    rdfs:comment 'Reference to the manufacturing plant or production facility where this standard cost applies. Standard costs are plant-specific in CPG manufacturing.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingFacility .

ind:primaryStandardSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Sku Id' ;
    rdfs:comment 'Reference to the material (finished good, semi-finished good, or raw material) for which this standard cost is defined. Links to the product master.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'The BOM usage type (e.g., production, costing, engineering) that was used as the basis for material cost calculation in this estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who created this cost estimate. Used for audit trail and accountability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was first created in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who last modified this cost estimate. Used for audit trail and change tracking.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was last modified in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'The unique business identifier for the cost estimate document in the source ERP system. Used for audit trail and traceability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'The absolute difference between the current standard cost and the previous standard cost. Positive indicates cost increase, negative indicates cost decrease.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'The percentage change in standard cost compared to the previous period. Calculated as (current - previous) / previous * 100.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingLotSizeUom rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size Uom' ;
    rdfs:comment 'The unit of measure for the costing lot size (e.g., EA, KG, L, CS). Must align with the materials base unit of measure.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Cost' ;
    rdfs:comment 'The cost component for packaging materials (primary, secondary, tertiary) used for one unit. Critical for CPG cost structure analysis.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardCost rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Cost' ;
    rdfs:comment 'The total standard cost from the prior costing period or version. Used for variance analysis and cost trend reporting.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The date when this standard cost estimate was officially released and became active for inventory valuation and COGS calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingUsage rdf:type rdf:Property ;
    rdfs:label 'Routing Usage' ;
    rdfs:comment 'The routing usage type (e.g., production, costing) that was used as the basis for labor and machine cost calculation in this estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStandardCost rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost' ;
    rdfs:comment 'The total standard cost per unit of the material, summing all cost components (raw material, packaging, labor, overhead, freight). This is the authoritative cost for inventory valuation and COGS.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationVariant rdf:type rdf:Property ;
    rdfs:label 'Valuation Variant' ;
    rdfs:comment 'The valuation variant that defines the costing methodology and cost component structure used for this estimate (e.g., full costing, marginal costing).' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Network Node Id' ;
    rdfs:comment 'Identifier of the target location in the distribution network where the shipment is being delivered (distribution center, warehouse, retail store, or customer location).' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryIntransitNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Intransit Network Node Id' ;
    rdfs:comment 'Identifier of the source location in the distribution network from which the shipment departed (supplier facility, distribution center, warehouse, or manufacturing plant).' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:researchFormulationId rdf:type rdf:Property ;
    rdfs:label 'Research Formulation Id' ;
    rdfs:comment 'Foreign key linking to research.research_formulation. Business justification: Launch logistics report tracks shipments of newly launched formulations, tying in-transit data to the formulation for rollout monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchFormulation .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment physically departed from the origin node. Used for transit time calculation and OTIF (On Time In Full) measurement.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the destination location type in the supply chain network.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment encountered any exceptions during transit (delays, damage, routing issues, temperature excursions).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the primary exception encountered during shipment transit. Null if no exception occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned or estimated date when the shipment is expected to arrive at the destination node. Used for inventory planning and ATP (Available to Promise) calculations.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight transportation cost for this shipment in the base currency. Used for logistics cost allocation and freight audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight cost amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intransitQuantity rdf:type rdf:Property ;
    rdfs:label 'Intransit Quantity' ;
    rdfs:comment 'Total quantity of inventory units currently in-transit for this shipment. Represents stock that has left origin but not yet arrived at destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originNodeType rdf:type rdf:Property ;
    rdfs:label 'Origin Node Type' ;
    rdfs:comment 'Classification of the origin location type in the supply chain network.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment met OTIF performance criteria (arrived on time with full quantity). True if both time and quantity targets were met.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Max C' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temperature Min C' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'External business identifier for the shipment, used for tracking and communication with carriers and logistics partners. May be ASN (Advanced Shipping Notice) number or BOL (Bill of Lading) number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Shipment Volume M3' ;
    rdfs:comment 'Total volume of the shipment in cubic meters. Used for transportation capacity planning and dimensional weight calculations.' ;
    rdfs:domain ind:IntransitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Number of calendar days the shipment was in transit from departure to arrival. Calculated as the difference between actual arrival and departure timestamps.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used for moving the shipment between origin and destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the inventory cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalCountInventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Original Count Inventory Cycle Count Id' ;
    rdfs:comment 'If this is a recount, references the inventory_cycle_count_id of the original count that triggered the recount requirement. Null for initial counts.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:primaryInventoryCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Counter Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate or employee who performed the physical count. Used for accountability and performance tracking.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'The ERP (Enterprise Resource Planning) document number or transaction ID generated when the inventory adjustment was posted. Used for financial audit trail and reconciliation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the variance has been posted as an inventory adjustment in the ERP (Enterprise Resource Planning) system. True = adjustment posted, False = pending posting.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical cycle count was performed.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Timestamp' ;
    rdfs:comment 'Precise date and time when the cycle count was executed. Used for audit trail and WMS (Warehouse Management System) reconciliation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countZone rdf:type rdf:Property ;
    rdfs:label 'Count Zone' ;
    rdfs:comment 'The warehouse zone or area designation where the count took place (e.g., receiving, picking, reserve, quarantine). Used for zone-based cycle count scheduling.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValueAtCount rdf:type rdf:Property ;
    rdfs:label 'Inventory Value At Count' ;
    rdfs:comment 'The total monetary value of the counted inventory based on the counted quantity and the unit cost at the time of count. Used for financial reconciliation and shrinkage cost calculation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the counted inventory is in quarantine status pending quality inspection or regulatory clearance. True = quarantined, False = available.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether this cycle count is a recount of a previous count that exceeded variance thresholds. True = recount, False = initial count.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The monetary value of the variance (variance_quantity * unit_cost). Represents the financial impact of the inventory discrepancy. Used for shrinkage reporting and P&L (Profit and Loss) impact analysis.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Location Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each storage location has a manager responsible for inventory integrity; used in location performance and accountability reports.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: WAREHOUSE MANAGEMENT: each storage location is physically part of a supply network node; required for location-level inventory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:thirdPartyProviderId rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider Id' ;
    rdfs:comment 'Reference to the third-party logistics provider managing this location, if applicable. Null for company-owned facilities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyProvider .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Bin or slot identifier representing the smallest addressable storage unit within a level, used for item-level location precision.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions that can be stored in this location, used for pallet-based inventory planning.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location in cubic meters, used for space utilization optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms, used for load planning and safety compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Inventory Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within a bay, used for precise location addressing in multi-tier racking systems.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInventoryCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed at this location, used for inventory accuracy tracking.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement (putaway, pick, transfer) at this location, used for activity analysis and slotting optimization.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingPriority rdf:type rdf:Property ;
    rdfs:label 'Picking Priority' ;
    rdfs:comment 'Numeric priority ranking for order picking optimization. Lower numbers indicate higher priority for fast-moving SKUs and efficient pick path planning.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Threshold' ;
    rdfs:comment 'Percentage threshold that triggers automatic replenishment from reserve to pick locations. Used in Vendor Managed Inventory (VMI) and automated replenishment processes.' ;
    rdfs:domain ind:InventoryStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationRule rdf:type rdf:Property ;
    rdfs:label 'Rotation Rule' ;
    rdfs:comment 'Inventory rotation policy applied to this location. FEFO (First Expired First Out) for perishables, FIFO (First In First Out) for standard goods, LIFO (Last In First Out) for specific scenarios, or MANUAL for operator-controlled picking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the storage location based on access controls and monitoring requirements. High-value for premium products, controlled substance for regulated materials, restricted for limited access areas.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVmiAgreementId rdf:type rdf:Property ;
    rdfs:label 'Inventory Vmi Agreement Id' ;
    rdfs:comment 'Unique identifier for the VMI agreement record. Primary key.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInventoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Employee Id' ;
    rdfs:comment 'Identifier of the Consumer Goods employee responsible for managing this VMI agreement.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInventoryLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inventory Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this VMI agreement record.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automated replenishment orders are triggered based on inventory levels without manual approval.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which invoices are generated for inventory replenished under this VMI agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingMethod rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Method' ;
    rdfs:comment 'Technical method or platform used to exchange inventory visibility and replenishment data between Consumer Goods and the VMI partner.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastSharingEnabled rdf:type rdf:Property ;
    rdfs:label 'Forecast Sharing Enabled' ;
    rdfs:comment 'Indicates whether demand forecast data is shared between Consumer Goods and the VMI partner for collaborative planning.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryOwnership rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership' ;
    rdfs:comment 'Defines who owns the inventory at the partner location until point of sale or consumption.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVmiAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Vmi Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the VMI agreement.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTraceabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Required' ;
    rdfs:comment 'Indicates whether lot or batch traceability is mandatory for inventory managed under this VMI agreement for recall readiness.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'Maximum inventory quantity threshold at partner location to avoid overstocking.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Minimum inventory quantity threshold at partner location that triggers replenishment.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosPenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Oos Penalty Clause' ;
    rdfs:comment 'Description of financial or operational penalties applied if out-of-stock events occur at partner location.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Target percentage for deliveries that meet both on-time and in-full criteria as defined in the VMI agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'Buffer inventory quantity maintained to mitigate stockout risk due to demand variability or supply disruption.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'Committed service level percentage for on-time in-full (OTIF) delivery under this VMI agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockLevelUom rdf:type rdf:Property ;
    rdfs:label 'Stock Level Uom' ;
    rdfs:comment 'Unit of measure for all stock level thresholds (e.g., cases, pallets, eaches, kilograms).' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStockLevel rdf:type rdf:Property ;
    rdfs:label 'Target Stock Level' ;
    rdfs:comment 'Optimal inventory quantity to maintain at partner location under normal conditions.' ;
    rdfs:domain ind:InventoryVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dossierId rdf:type rdf:Property ;
    rdfs:label 'Dossier Id' ;
    rdfs:comment 'Foreign key linking to regulatory.dossier. Business justification: Batch traceability links each lot/batch to its regulatory dossier for post-market surveillance and recall investigations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dossier .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory quality inspection requires recording the employee ID of the inspector for each batch; essential for traceability and compliance audits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'The current lifecycle status of the lot or batch. Indicates whether the batch is active and available, depleted, expired, recalled, destroyed, or transferred to another location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'The date until which the product retains optimal quality. Distinct from expiry_date; product may still be safe but quality may degrade after this date.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'The unique identifier for the Certificate of Analysis document that records the quality test results for this lot or batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting regulatory compliance status, exceptions, or special handling requirements for this lot or batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code representing the country where this lot or batch was manufactured. Required for customs, trade compliance, and labeling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Status' ;
    rdfs:comment 'Indicates whether this lot or batch was produced in compliance with Good Manufacturing Practice standards. Critical for regulatory compliance and quality assurance.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot or batch is on hold and cannot be used or shipped. True if on hold, False otherwise.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'The business reason why this lot or batch is on hold, if applicable. Examples: pending quality review, regulatory investigation, customer complaint.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The date on which quality control inspection was performed on this lot or batch.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this lot or batch was manufactured or produced. Critical for shelf-life calculation and First Expired First Out (FEFO) rotation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'The production order or work order number under which this lot or batch was manufactured. Links to Manufacturing Execution System (MES) records.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'The quality grade or classification assigned to this lot or batch based on quality control inspection results. May affect pricing, distribution channel, or disposal decisions. [ENUM-REF-CANDIDATE: A|B|C|premium|standard|substandard|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The total quantity of product manufactured in this lot or batch, measured in the base unit of measure.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current quarantine or release status of the lot or batch. Quarantined lots cannot be used or shipped until quality inspection is complete and status is changed to released.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot or batch meets all applicable regulatory compliance requirements. True if compliant, False otherwise.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'The number of days remaining until expiry_date as of the current date. Used for inventory rotation and markdown decisions.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date by which the lot or batch must be retested to confirm continued quality and compliance. Common in pharmaceutical and chemical manufacturing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'The number of days from manufacturing_date to expiry_date, representing the total shelf life of this lot or batch. Used for First Expired First Out (FEFO) calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageConditionRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Requirement' ;
    rdfs:comment 'The required storage conditions for this lot or batch to maintain product quality and safety. Examples: ambient, refrigerated, frozen, controlled room temperature.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The lot or batch number assigned by the supplier for received raw materials or finished goods. Used for traceability back to the supplier in case of quality issues or recalls.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'A unique code used for end-to-end supply chain traceability of this lot or batch. May be a GS1 Global Trade Item Number (GTIN) with batch extension or similar standard.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The name of the vendor or supplier from whom this lot or batch was received, if applicable for purchased goods.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosEventId rdf:type rdf:Property ;
    rdfs:label 'Oos Event Id' ;
    rdfs:comment 'Unique identifier for the out-of-stock event record.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousOosEventId rdf:type rdf:Property ;
    rdfs:label 'Previous Oos Event Id' ;
    rdfs:comment 'Reference to the previous OOS event ID for the same SKU-location if this is a recurrence, enabling trend analysis.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosEvent .

ind:actualDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Demand Units' ;
    rdfs:comment 'Actual observed demand in units during the OOS event period, used to identify demand spikes or forecast misses.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of the corrective action plan implemented to prevent recurrence of similar OOS events in the future.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether the OOS event resulted in direct customer impact such as lost sales, customer complaints, or service level breaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Units' ;
    rdfs:comment 'Forecasted demand in units for the period during which the OOS event occurred, used to compare actual vs. planned demand.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'System or channel that detected and reported the out-of-stock event, such as POS system, WMS, demand sensing platform, manual report, retail execution app, or EDI feed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLostSalesValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Sales Value' ;
    rdfs:comment 'Estimated monetary value of sales lost due to the out-of-stock condition, calculated based on historical demand patterns and average selling price.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLostUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Units' ;
    rdfs:comment 'Estimated quantity of units that could not be sold due to the out-of-stock condition.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'Forecast accuracy percentage for the SKU-location during the period of the OOS event, calculated as (1 - |actual - forecast| / actual) * 100.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Severity classification of the OOS event impact based on lost sales value, SKU importance, and customer impact. Categories: critical, high, medium, low.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOnHandAtOos rdf:type rdf:Property ;
    rdfs:label 'Inventory On Hand At Oos' ;
    rdfs:comment 'System-recorded inventory quantity on hand at the time the OOS event was detected, used to identify phantom inventory situations.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'Date of the most recent replenishment delivery prior to the OOS event, used to analyze replenishment frequency adequacy.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Replenishment Date' ;
    rdfs:comment 'Date of the next scheduled replenishment delivery at the time of the OOS event, used to assess replenishment planning gaps.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosDurationHours rdf:type rdf:Property ;
    rdfs:label 'Oos Duration Hours' ;
    rdfs:comment 'Total duration of the out-of-stock event measured in hours, calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos End Timestamp' ;
    rdfs:comment 'Timestamp when the out-of-stock condition was resolved and inventory became available again.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Start Timestamp' ;
    rdfs:comment 'Timestamp when the out-of-stock condition was first detected. Sourced from POS data feeds or demand sensing signals.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosType rdf:type rdf:Property ;
    rdfs:label 'Oos Type' ;
    rdfs:comment 'Classification of the OOS event type: warehouse stockout (no inventory in facility), shelf stockout (inventory in back room but not on shelf), phantom inventory (system shows stock but physical count is zero), or system mismatch.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaActualPercent rdf:type rdf:Property ;
    rdfs:label 'Osa Actual Percent' ;
    rdfs:comment 'Actual on-shelf availability percentage achieved during the period including the OOS event, calculated from POS and inventory data.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:osaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percent' ;
    rdfs:comment 'Target on-shelf availability percentage for the SKU-location at the time of the OOS event, used to measure performance against goals.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean flag indicating whether this OOS event is a recurrence of a previous OOS event for the same SKU-location combination within a defined time window.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Configured reorder point threshold for the SKU at this location, used to evaluate whether replenishment triggers were properly set.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve the out-of-stock event, such as emergency replenishment, transfer from alternate location, expedited shipment, customer backorder, substitution offered, or no action taken.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Primary root cause classification for the OOS event. Categories include demand spike, replenishment failure, forecast miss, upstream stockout, logistics delay, or system error.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the root cause behind the out-of-stock event, providing context beyond the category classification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory recall processes assign a coordinator employee; tracking the employee ID is mandatory for audit trails and communication logs.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedGtinList rdf:type rdf:Property ;
    rdfs:label 'Affected Gtin List' ;
    rdfs:comment 'Comma-separated list of GTIN/UPC/EAN codes for recalled products. Enables point-of-sale blocking and supply chain traceability across trading partners using GS1 standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLotBatchRange rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Batch Range' ;
    rdfs:comment 'Specification of the lot numbers, batch codes, or serial number ranges included in the recall. Critical for traceability and targeted recovery. May be expressed as ranges, lists, or patterns.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Product Description' ;
    rdfs:comment 'Comprehensive description of the product(s) subject to recall, including brand names, product names, sizes, formulations, and any distinguishing characteristics. Used for consumer identification.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSkuList rdf:type rdf:Property ;
    rdfs:label 'Affected Sku List' ;
    rdfs:comment 'Comma-separated or structured list of SKU codes for all products included in the recall scope. Links to product master for detailed SKU attributes and enables inventory queries.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the regulatory authority officially closed the recall after reviewing effectiveness checks and final reports. Nullable until regulatory closure is granted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when all recall activities were completed, including product recovery, customer notification, and corrective actions. Nullable until recall is finished.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerContactMethod rdf:type rdf:Property ;
    rdfs:label 'Consumer Contact Method' ;
    rdfs:comment 'Primary method(s) used to notify consumers about the recall. Press Release: public media announcement. Direct Mail: letters to registered consumers. Email: electronic notification. Phone: direct phone contact. Social Media: notification via social platforms. Retail Signage: point-of-sale notices. Multiple Methods: combination approach. [ENUM-REF-CANDIDATE: Press Release|Direct Mail|Email|Phone|Social Media|Retail Signage|Multiple Methods — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of corrective and preventive actions (CAPA) implemented to address the root cause and prevent recurrence. Includes process changes, equipment modifications, supplier changes, and quality system improvements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthOfRecall rdf:type rdf:Property ;
    rdfs:label 'Depth Of Recall' ;
    rdfs:comment 'Level in the distribution chain to which the recall extends. Consumer Level: recall reaches end consumers. Retail Level: recall stops at retail stores. Wholesale Level: recall stops at wholesalers/distributors. Distribution Center: recall stops at company distribution centers before reaching trade.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the recall including product cost, logistics, customer credits, disposal, regulatory fines, and brand impact. Expressed in reporting currency. Used for financial reserves and management reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range End' ;
    rdfs:comment 'Latest expiration or best-by date printed on recalled products. Defines the full date range for consumer identification.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Expiration Date Range Start' ;
    rdfs:comment 'Earliest expiration or best-by date printed on recalled products. Helps consumers and retailers identify affected units on shelf.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated financial impact amount. Enables multi-currency recall cost tracking and consolidation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardEvaluation rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Evaluation' ;
    rdfs:comment 'FDA or internal assessment of the health risk posed by the recalled product. Describes potential adverse health consequences and likelihood of occurrence. Used to determine recall classification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the recall was officially initiated by the company. This is the business event date when the decision to recall was made and communicated internally.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range End' ;
    rdfs:comment 'Latest manufacturing date of products included in the recall scope. Defines the cutoff for affected production runs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range Start' ;
    rdfs:comment 'Earliest manufacturing date of products included in the recall scope. Used to identify affected inventory based on production timeline.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the regulatory authority (FDA, CPSC, EPA, or other governing body) was formally notified of the recall event. Required for compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'Date when the recall was publicly announced through press release, FDA website posting, or other public communication channels.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Quantity Distributed' ;
    rdfs:comment 'Total quantity of affected product that was distributed into the market prior to recall initiation. Expressed in base unit of measure (units, cases, kilograms). Represents the maximum potential recall scope.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecalled rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled' ;
    rdfs:comment 'Total quantity of product subject to the recall action. May differ from quantity distributed if recall scope is narrowed to specific lots, channels, or geographies.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecovered rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered' ;
    rdfs:comment 'Actual quantity of recalled product recovered from the market through returns, destructions, and corrections. Updated throughout recall lifecycle. Used to calculate recall effectiveness percentage.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all quantity fields in this recall record. Ensures consistent interpretation of distributed, recalled, and recovered quantities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific defect, contamination, safety issue, or regulatory violation that triggered the recall. Includes root cause findings and quality investigation summary.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClassification rdf:type rdf:Property ;
    rdfs:label 'Recall Classification' ;
    rdfs:comment 'FDA or regulatory classification of the recall severity. Class I: dangerous or defective products that could cause serious health problems or death. Class II: products that might cause temporary health problem or pose slight threat of serious nature. Class III: products unlikely to cause adverse health reaction but violate FDA labeling or manufacturing regulations. Voluntary Withdrawal: firm removes product from market not required by FDA. Market Withdrawal: minor violation not subject to legal action. Stock Recovery: correction of product still in distribution chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEffectivenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Percentage' ;
    rdfs:comment 'Calculated percentage of recalled product successfully recovered from the market. Formula: (quantity_recovered / quantity_recalled) * 100. FDA expects effectiveness checks at 2, 4, and 8 weeks. High effectiveness (>95%) supports recall closure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'External recall identification number assigned by the company or regulatory authority for tracking and communication purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScopeChannel rdf:type rdf:Property ;
    rdfs:label 'Recall Scope Channel' ;
    rdfs:comment 'Distribution channel(s) affected by the recall. Retail: products sold through retail stores. Wholesale: products in wholesale/distributor inventory. DTC: direct-to-consumer shipments. Food Service: products sold to restaurants/institutions. Healthcare: products distributed to healthcare facilities. All Channels: recall spans all distribution paths.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScopeCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Recall Scope Customer Segment' ;
    rdfs:comment 'Specific customer segments, account types, or customer groups affected by the recall. Used for targeted notification and recovery when recall does not affect all customers.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScopeGeographic rdf:type rdf:Property ;
    rdfs:label 'Recall Scope Geographic' ;
    rdfs:comment 'Geographic scope of the recall expressed as countries, states, regions, or distribution territories. Examples: USA nationwide, California only, EU markets, specific distribution centers. Supports targeted recovery and regulatory reporting by jurisdiction.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event. Initiated: recall has been declared and communication started. In Progress: active recovery and customer notification underway. Ongoing: recall activities continuing. Completed: all recall activities finished, awaiting final regulatory closure. Terminated: recall ended by firm decision. Closed: regulatory authority has reviewed and closed the recall.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStrategy rdf:type rdf:Property ;
    rdfs:label 'Recall Strategy' ;
    rdfs:comment 'Documented strategy for executing the recall including communication plan, recovery method, depth of recall (consumer level, retail level, wholesale level), and timeline. Required by FDA 21 CFR 7.42.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Primary reason category for the recall event. Safety: product poses health or safety risk. Quality: product fails quality specifications. Regulatory: non-compliance with regulations. Labeling: incorrect or missing label information. Contamination: presence of foreign material or microbial contamination. Allergen: undeclared allergen present.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary regulatory authority overseeing this recall. FDA: U.S. Food and Drug Administration. CPSC: Consumer Product Safety Commission. EPA: Environmental Protection Agency. EU REACH: European chemicals regulation. Health Canada: Canadian health authority. ANVISA: Brazilian health authority. TGA: Australian Therapeutic Goods Administration. MHRA: UK Medicines and Healthcare products Regulatory Agency. [ENUM-REF-CANDIDATE: FDA|CPSC|EPA|EU REACH|Health Canada|ANVISA|TGA|MHRA|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Official case or reference number assigned by the regulatory authority for tracking this recall in their system. Used for all regulatory correspondence and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Summary' ;
    rdfs:comment 'Summary of the root cause investigation findings including failure mode, contributing factors, and systemic issues identified. Supports CAPA and regulatory reporting.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Inventory Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution center, or retail location that will receive the replenished inventory.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:primaryInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution center, or manufacturing facility from which inventory will be shipped to fulfill this replenishment order.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: REQUIRED: Internal replenishment orders are driven by purchase requisitions; linking supports demand-driven planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Quantity of the SKU approved for fulfillment after review and Available to Promise (ATP) validation. May differ from requested quantity due to supply constraints.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Prevention Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was created to prevent an anticipated Out of Stock (OOS) event based on demand forecasting.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Approval Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was approved for fulfillment by the supply chain planner or automated approval workflow.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderCancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was cancelled, if applicable. Null for active orders.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Creation Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was first created in the system, either automatically by planning algorithms or manually by a planner.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field for planners to capture special instructions, handling requirements, or contextual information about the replenishment order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the replenishment order, used for tracking and communication across systems and stakeholders.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of the replenishment order generation method: Vendor Managed Inventory (VMI) auto-replenishment, Distribution Requirements Planning (DRP) planned order, manual trigger by planner, safety stock replenishment, emergency order, or seasonal build.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the replenishment inventory is needed at the destination location to prevent Out of Stock (OOS) conditions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of the SKU requested for replenishment, as calculated by the demand planning system or entered by the planner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was triggered by inventory falling below the safety stock threshold at the destination location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the shipment associated with this replenishment order. Used for in-transit visibility.' ;
    rdfs:domain ind:InventoryReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Primary key for reservation' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Reservation Sales Order Id' ;
    rdfs:comment 'Reference to the sales order document that triggered this reservation. Populated when reservation_type is sales_order.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:reservationTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Reservation Transfer Order Id' ;
    rdfs:comment 'Reference to the intercompany or inter-facility transfer order. Populated when reservation_type is intercompany_transfer.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocationRule rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule' ;
    rdfs:comment 'Inventory allocation rule applied to this reservation: First Expired First Out (FEFO), First In First Out (FIFO), Last In First Out (LIFO), specific lot assignment, or customer priority-based.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:comment 'Indicates whether the reservation is temporarily blocked from fulfillment due to quality hold, credit hold, or other business constraints.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedToCustomerFlag rdf:type rdf:Property ;
    rdfs:label 'Committed To Customer Flag' ;
    rdfs:comment 'Indicates whether this reservation represents a firm commitment to a customer with contractual On Time In Full (OTIF) obligations.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'Quantity of the reservation that has been fulfilled through goods issue or consumption. Measured in the product\'s base unit of measure.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'Planned method for fulfilling this reservation: warehouse pick and pack, Direct Store Delivery (DSD), cross-dock transfer, or drop-ship from supplier.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Date' ;
    rdfs:comment 'Date when the inventory reservation was created and stock was earmarked for this demand.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Business-facing unique reservation number used for tracking and reference across systems and documents.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle status of the reservation indicating whether it is active, partially fulfilled, fully fulfilled, cancelled, or expired.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the reservation purpose: sales order fulfillment, production consumption, promotional commitment, intercompany transfer, quality hold, or safety stock allocation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of inventory units reserved and earmarked for this specific demand. Measured in the product\'s base unit of measure.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for serialized inventory items reserved at the individual unit level.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocument rdf:type rdf:Property ;
    rdfs:label 'Source Document' ;
    rdfs:comment 'Reference number or identifier of the originating business document that triggered the reservation (order number, forecast ID, promotion code).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiReplenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Replenishment Flag' ;
    rdfs:comment 'Indicates whether this reservation is part of a Vendor Managed Inventory (VMI) replenishment program where the supplier manages customer inventory levels.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockPolicyId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Policy Id' ;
    rdfs:comment 'Unique identifier for the safety stock policy record. Primary key.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Employee Id' ;
    rdfs:comment 'Reference to the supply chain planner or inventory analyst responsible for maintaining and reviewing this safety stock policy.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageDailyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand' ;
    rdfs:comment 'The mean daily demand quantity for this SKU at this location, calculated from historical sales and forecast data. Used in reorder point and safety stock calculations.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to determine safety stock levels. Statistical methods use demand variability and service level; time-based methods use fixed days of supply; manual methods rely on planner judgment; hybrid methods combine multiple approaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryingCostRatePercent rdf:type rdf:Property ;
    rdfs:label 'Carrying Cost Rate Percent' ;
    rdfs:comment 'The annual percentage cost of holding inventory, including warehousing, insurance, obsolescence, and cost of capital. Used to calculate the financial impact of safety stock levels.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business importance classification indicating the impact of stockouts. Critical items cause production stops or lost sales; high items significantly impact operations; medium and low items have manageable stockout consequences.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Demand Standard Deviation' ;
    rdfs:comment 'Statistical measure of demand variability around the average daily demand. Used to calculate safety stock levels for a given service level target.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand volatility, typically the coefficient of variation (standard deviation divided by mean demand). Higher values indicate greater uncertainty and require higher safety stock.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'The upper inventory threshold for this SKU-location combination. Prevents overstocking and excess inventory carrying costs.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'The minimum number of days of remaining shelf life required for a product to be shipped to customers or transferred to retail. Products below this threshold may be blocked from sale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The quantity increment in which orders must be placed (e.g., pallet quantities, case pack sizes). Orders are rounded to the nearest multiple.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Organizational grouping code identifying the supply chain planning team or business unit responsible for managing this safety stock policy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier for the safety stock policy, typically a concatenation of SKU and location codes for external reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text field for planners to document special considerations, exceptions, seasonal adjustments, or business context relevant to this safety stock policy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the safety stock policy methodology. Fixed policies use static parameters; dynamic policies adjust based on demand variability; seasonal policies account for cyclical patterns; promotional policies support campaign-driven demand; VMI (Vendor Managed Inventory) policies are supplier-controlled; consignment policies apply to stock owned by suppliers.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'The inventory replenishment approach applied to this SKU-location. Reorder point triggers orders when stock falls below ROP; periodic review orders at fixed intervals; min-max maintains stock between bounds; kanban uses visual signals; DRP (Distribution Requirements Planning) uses time-phased planning; VMI (Vendor Managed Inventory) is supplier-controlled.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'The number of days between scheduled reviews of this safety stock policy. High-value or high-variability items may be reviewed weekly or monthly; stable items may be reviewed quarterly or annually.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Policy Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock policy. Active policies are in effect; inactive policies are not applied; suspended policies are temporarily paused; under_review policies are being evaluated; expired policies have passed their validity period; draft policies are not yet approved.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The target safety stock quantity to be maintained at the location for this SKU, expressed in the base unit of measure. This buffer inventory protects against demand variability and supply uncertainty.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyTimeDays rdf:type rdf:Property ;
    rdfs:label 'Safety Time Days' ;
    rdfs:comment 'Additional lead time buffer added to the replenishment lead time to account for supply uncertainty. Used in time-based safety stock calculations.' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percent' ;
    rdfs:comment 'The target percentage of demand that should be met from available stock without stockouts. Typically ranges from 90% to 99.9% depending on product criticality and business strategy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated cost per unit of a stockout event, including lost sales, expedited freight, production downtime, and customer dissatisfaction. Used in service level optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'System Generated Flag' ;
    rdfs:comment 'Indicates whether this policy was automatically generated by SAP IBP optimization algorithms (true) or manually created by a planner (false).' ;
    rdfs:domain ind:SafetyStockPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'Demand variability classification. X items have stable, predictable demand; Y items have moderate variability; Z items have highly erratic or unpredictable demand patterns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Stock Adjustment Id' ;
    rdfs:comment 'Primary key for stock_adjustment' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStockEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Employee Id' ;
    rdfs:comment 'User identifier of the person who initiated or created the adjustment transaction in the system.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedAdjustmentStockAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversed Adjustment Stock Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment transaction that this record reverses, establishing the correction chain for audit purposes.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockAdjustment .

ind:tertiaryStockPostedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Stock Posted By User Employee Id' ;
    rdfs:comment 'User identifier of the person who posted the adjustment to the inventory and financial ledgers.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Identifier of the warehouse or distribution center where the inventory adjustment occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'Net quantity change applied to inventory (positive for additions, negative for reductions), measured in the base unit of measure.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value' ;
    rdfs:comment 'Total financial value of the inventory adjustment calculated as adjusted quantity multiplied by unit cost, impacting Cost of Goods Sold (COGS) and inventory valuation.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'Business date when the inventory adjustment was physically identified or when the correction event occurred, distinct from system posting date.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-facing unique adjustment document number used for tracking and reference in operational systems and audit trails.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Description' ;
    rdfs:comment 'Detailed textual explanation of why the inventory adjustment was necessary, providing business context beyond the reason code.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment transaction indicating its approval and posting state in the inventory ledger.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Precise date and time when the adjustment transaction was created or recorded in the system.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment transaction indicating the nature of the inventory correction (physical count variance, shrinkage, damage, expiry, system reconciliation, theft).' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code classifying the inventory transaction for goods movement and financial posting (e.g., 701 for goods issue, 702 for goods receipt).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Physical Count Quantity' ;
    rdfs:comment 'Actual physical quantity counted during inventory verification, used to calculate the adjustment variance for cycle counts and physical inventories.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of supporting document referenced for the adjustment, providing audit trail and justification context. [ENUM-REF-CANDIDATE: physical_inventory|cycle_count|damage_report|quality_inspection|sampling_request|promotional_giveaway|recall_notice — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Code indicating special stock categories such as consignment, vendor-managed inventory (VMI), or customer-owned stock requiring separate tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of inventory stock status indicating availability for use (unrestricted, quality inspection, blocked, restricted, returns).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'System Quantity After' ;
    rdfs:comment 'Resulting inventory quantity in the system after the adjustment has been posted, representing the corrected stock balance.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'System Quantity Before' ;
    rdfs:comment 'Inventory quantity recorded in the system before the adjustment was applied, used for variance analysis and audit trails.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockHoldId rdf:type rdf:Property ;
    rdfs:label 'Stock Hold Id' ;
    rdfs:comment 'Primary key for stock_hold' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approving Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Hold decisions must be approved by a designated employee; the link enables hold audit logs and compliance verification.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Identifier linking this hold to a customer complaint or quality issue reported from the field. Used for root cause analysis.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductComplaint .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the disposition decision was made and executed. Null if disposition is still pending.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Additional notes or comments regarding the disposition decision, including justification and any special handling instructions.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'Target date by which the hold is expected to be resolved. Used for planning and escalation management.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdDurationDays rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Days' ;
    rdfs:comment 'Number of calendar days the inventory has been on hold. Calculated as the difference between current date (or release date) and hold start date. Used for aging analysis and KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Business-facing unique identifier for the hold, used in quality management and warehouse operations. Format: HLD-NNNNNNNN.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level for resolving the hold. Critical holds require immediate action (e.g., safety issues); low priority holds can be resolved in normal workflow.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'Quantity of inventory units placed on hold. Measured in the base unit of measure for the SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity Uom' ;
    rdfs:comment 'Unit of measure for the hold quantity. EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon. [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code identifying the specific reason for the hold. Format: AAA-NNN. Examples: QCF-001 (failed inspection), REG-002 (FDA recall), DMG-005 (physical damage).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the hold was placed, including specific quality defects, regulatory citations, or commercial issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the hold was released, including time zone. Used for calculating hold duration and compliance metrics.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'Date when the hold was placed on the inventory. This is the business event date when the stock became restricted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the hold was initiated, including time zone. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold. Active holds block inventory movement; released holds allow disposition; pending review awaits approval; escalated holds require management intervention.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdValueAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Value Amount' ;
    rdfs:comment 'Total monetary value of the inventory on hold, calculated at standard cost. Used for financial impact analysis and reporting.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Hold Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the hold value amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecallRelated rdf:type rdf:Property ;
    rdfs:label 'Is Recall Related' ;
    rdfs:comment 'Flag indicating whether this hold is related to a product recall. True if the hold is part of a recall action; false otherwise.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when stakeholder notifications were sent regarding this hold. Used for compliance and audit trail.' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'External reference number from regulatory authority (FDA, EPA, CPSC) if the hold is related to a regulatory action, recall, or investigation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Specific bin, aisle, or zone location within the warehouse where the held inventory is stored. Format varies by WMS (Warehouse Management System).' ;
    rdfs:domain ind:StockHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Foreign key linking to product.bom_line. Business justification: Manufacturing consumption tracking links inventory movements to specific BOM lines, enabling component usage analysis per product in the Component Consumption Report.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:campaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_flight. Business justification: Logistics teams track stock movements tied to specific campaign flights to measure promotional material delivery and OTIF performance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignFlight .

ind:primaryStockInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Inventory Storage Location Id' ;
    rdfs:comment 'Warehouse, plant, or storage location from which inventory is being moved. Null for goods receipts from external sources.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:reversedMovementStockMovementId rdf:type rdf:Property ;
    rdfs:label 'Reversed Movement Stock Movement Id' ;
    rdfs:comment 'Reference to the original stock movement record that this transaction reverses or cancels.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockMovement .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated for this goods movement. Unique identifier in the source ERP system.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year of the material document for SAP document key uniqueness.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level classification of the movement event for reporting and analytics purposes.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementNotes rdf:type rdf:Property ;
    rdfs:label 'Movement Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the stock movement event.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical inventory movement occurred or was recorded in the system.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP movement type code identifying the nature of the inventory transaction (e.g., 101=Goods Receipt from PO, 261=Goods Issue to Production, 311=Stock Transfer, 551=Scrapping, 601=Goods Receipt from Delivery).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether this stock movement requires quality inspection before the inventory can be released for use.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code explaining the business reason for the movement (e.g., quality issue, damage, expiration, customer return, production scrap).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLine rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line' ;
    rdfs:comment 'Line item number within the reference document that corresponds to this stock movement.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Specific storage location or bin within the plant or warehouse where inventory is stored.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total financial value of the inventory movement (quantity × unit cost) for financial reporting and inventory accounting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Sub-classification for split valuation of the same material (e.g., domestic vs imported, new vs refurbished).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: REQUIRED: Traceability of on-hand stock to the goods receipt that created it for audit and regulatory compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:skuPlanningParamId rdf:type rdf:Property ;
    rdfs:label 'Sku Planning Param Id' ;
    rdfs:comment 'Foreign key linking to supply.sku_planning_param. Business justification: REPLENISHMENT PLANNING: stock positions need to reference SKU planning parameters for safety stock and lot sizing decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPlanningParam .

ind:availableToPromiseQuantity rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Quantity' ;
    rdfs:comment 'Quantity available for new customer orders after accounting for existing commitments and reservations. Calculated as unrestricted quantity minus reserved quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity of stock that is blocked from use due to quality issues, regulatory holds, or other restrictions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInventoryOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Inventory Outstanding' ;
    rdfs:comment 'Number of days the current inventory level would last based on average daily demand. Key metric for working capital efficiency and cash flow management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Date when the inventory was physically received at this storage location. Used for FIFO rotation and aging analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of stock currently in transit between locations (plant-to-warehouse, warehouse-to-store, etc.) and not yet received at destination.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction (receipt, issue, transfer) for this stock position. Used to identify slow-moving or obsolete inventory.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date when the last physical count or cycle count was performed for this stock position. Used for inventory accuracy monitoring.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum inventory level allowed at this location to prevent overstocking and optimize working capital.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteFlag rdf:type rdf:Property ;
    rdfs:label 'Obsolete Flag' ;
    rdfs:comment 'Indicates whether the inventory is obsolete (discontinued product, expired, or no longer saleable) and should be written off or disposed.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oosRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Risk Flag' ;
    rdfs:comment 'Indicates whether the current stock level is below safety stock and at risk of stockout. Used for proactive replenishment alerts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity of stock currently undergoing quality control inspection and not yet released for use.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Hold Flag' ;
    rdfs:comment 'Indicates whether the stock is on hold due to a product recall or safety alert. Prevents further distribution or sale.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level that triggers automatic replenishment. When stock falls to this level, a purchase requisition or transfer order is generated.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeRemainingDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Remaining Days' ;
    rdfs:comment 'Number of days remaining until expiration. Used for FEFO prioritization and markdown planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slowMovingFlag rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Flag' ;
    rdfs:comment 'Indicates whether the inventory has had no or minimal movement over a defined period (typically 90+ days), signaling potential obsolescence risk.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockRotationRule rdf:type rdf:Property ;
    rdfs:label 'Stock Rotation Rule' ;
    rdfs:comment 'Inventory rotation policy applied at this location. FIFO=First In First Out; FEFO=First Expired First Out (for perishables); LIFO=Last In First Out; Manual=operator-controlled picking.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrestrictedQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Quantity' ;
    rdfs:comment 'Quantity of stock that is freely available for sale, production, or distribution without any restrictions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Unique identifier for the stock valuation record. Primary key.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialLedgerPostingId rdf:type rdf:Property ;
    rdfs:label 'Material Ledger Posting Id' ;
    rdfs:comment 'The unique identifier of the corresponding material ledger posting in the financial system (SAP MM-FI integration reference).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialLedgerPosting .

ind:actualUnitCost rdf:type rdf:Property ;
    rdfs:label 'Actual Unit Cost' ;
    rdfs:comment 'The actual cost per unit used for this valuation snapshot, determined by the selected valuation method.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Amount' ;
    rdfs:comment 'The portion of inventory value allocated to COGS during the valuation period, representing goods sold or consumed.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTurnoverRatio rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Ratio' ;
    rdfs:comment 'The number of times inventory is sold and replaced over the period, calculated as COGS divided by average inventory value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'The date of the most recent goods issue or consumption transaction for this SKU-location combination.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'The date of the most recent goods receipt transaction for this SKU-location combination, used for aging analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'The continuously recalculated average cost per unit based on all goods receipts and invoice receipts, used for moving average valuation method.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRealizableValue rdf:type rdf:Property ;
    rdfs:label 'Net Realizable Value' ;
    rdfs:comment 'The estimated selling price in the ordinary course of business less the estimated costs of completion and sale. Used to determine if write-down is required.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockValue rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Value' ;
    rdfs:comment 'The monetary value of safety stock (buffer inventory) maintained to prevent stockouts, calculated using safety stock quantity and unit cost.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The predetermined cost per unit set by the cost accounting team, used for standard costing valuation method.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'The total monetary value of inventory at this location, calculated as quantity on hand multiplied by actual unit cost.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which this inventory valuation snapshot was taken. Typically aligned with financial period close dates.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The accounting method used to calculate inventory value: standard cost, moving average price, FIFO (First In First Out), weighted average, or LIFO (Last In First Out).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'The current status of this valuation record in the financial close process: preliminary, final, adjusted, or closed.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Down Amount' ;
    rdfs:comment 'The monetary amount by which inventory value has been reduced due to obsolescence, damage, or net realizable value adjustments.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeDownReason rdf:type rdf:Property ;
    rdfs:label 'Write Down Reason' ;
    rdfs:comment 'The business reason for the inventory write-down: obsolescence, physical damage, expiration, market value decline, quality issue, or other.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiTrackingCapable rdf:type rdf:Property ;
    rdfs:label 'Api Tracking Capable' ;
    rdfs:comment 'Indicates whether the carrier provides a real-time shipment tracking API for track-and-trace integration. Enables automated shipment status updates in the TMS without manual EDI 214 processing. Used in carrier technology capability assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier in the Consumer Goods approved carrier program. Active carriers are eligible for shipment tendering. Suspended carriers are temporarily blocked pending compliance review. Blacklisted carriers are permanently disqualified. Drives carrier selection eligibility in TMS routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary transportation mode classification of the carrier. Drives rate card selection, shipment planning rules, and EDI transaction sets. TL (Truckload), LTL (Less-Than-Truckload), parcel, rail, ocean, air, intermodal, and courier are the standard classifications in consumer goods logistics. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|rail|ocean|air|intermodal|courier — promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the carrier has certified temperature-controlled transportation capability (refrigerated or frozen) for cold-chain compliant shipments of health, hygiene, and personal care products requiring temperature management. Critical for product safety and regulatory compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the current master transportation services agreement. Triggers contract renewal workflows and rate renegotiation processes. Shipment tendering to the carrier may be restricted after this date if no renewal is in place.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current master transportation services agreement between Consumer Goods and the carrier. Defines the period during which contracted rates and service commitments are valid.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and incorporated. Used for cross-border compliance checks, customs documentation, and carrier eligibility for specific trade lanes.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. Federal Motor Carrier Safety Administration (FMCSA) to commercial motor carriers operating in interstate commerce. Required for regulatory compliance verification and safety rating lookup. Mandatory for US-based trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated exchange of shipment tenders (204), load tenders (990), shipment status (214), and freight invoices (210). EDI-capable carriers are preferred for high-volume automated tendering in the TMS.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCode rdf:type rdf:Property ;
    rdfs:label 'Edi Code' ;
    rdfs:comment 'Carrier\'s EDI interchange identifier used in the ISA segment of X12 EDI transactions. Combined with the EDI qualifier, this uniquely identifies the carrier as an EDI trading partner. Required for automated tender and status message routing.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'Two-digit qualifier code identifying the type of EDI sender/receiver identifier used in ISA segment of X12 EDI transactions (e.g., 02 = DUNS, 08 = UCC/EAN, ZZ = Mutually Defined). Required for EDI trading partner setup and message routing.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmcsaRatingDate rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Rating Date' ;
    rdfs:comment 'Date on which the current FMCSA safety rating was issued or last updated. Used to assess rating currency and trigger re-evaluation workflows when ratings are older than the compliance review threshold.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmcsaSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Safety Rating' ;
    rdfs:comment 'Official safety fitness rating assigned by the FMCSA to motor carriers based on compliance reviews and safety audits. Satisfactory rating is required for carrier approval in Consumer Goods\' carrier program. Conditional or Unsatisfactory ratings trigger carrier review or suspension. Mandatory compliance field for US trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the carrier\'s operational geographic coverage scope, including regions, countries, or trade lanes served. Used in TMS routing logic to filter eligible carriers by origin-destination pair. Examples: \'Continental US\', \'US-Canada cross-border\', \'Trans-Pacific\', \'EU domestic\'.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the carrier\'s hazardous materials transportation certification. Triggers compliance alerts and blocks HAZMAT shipment tendering to the carrier if certification has lapsed.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carrier holds valid certification to transport hazardous materials (HAZMAT) as defined by DOT 49 CFR. Required for shipments of aerosols, flammable products, and chemical-based consumer goods. Validated against DOT HAZMAT registration database.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the carrier\'s principal place of business or corporate headquarters. Used for legal correspondence, contract execution, and regulatory filings. Includes street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment '2-3 character alphanumeric code assigned by IATA to identify air freight carriers. Used for air waybill generation, air freight booking, and international air cargo tracking. Applicable only to air freight carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCargoAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Cargo Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s cargo insurance policy covering loss or damage to goods in transit. Consumer Goods mandates minimum cargo insurance thresholds based on shipment value profiles. Critical for high-value CPG product shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the carrier\'s current certificate of insurance (COI) on file with Consumer Goods. Used for insurance verification, claims processing, and audit trail of carrier compliance documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date on which the carrier\'s insurance certificate expires. Triggers automated renewal reminder workflows and carrier status suspension if insurance lapses. Critical compliance field for carrier program management.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Liability Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s general liability insurance policy. Consumer Goods requires minimum liability coverage thresholds as a condition of carrier approval. Validated during carrier onboarding and annual renewal.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review conducted for this carrier, covering safety ratings, insurance certificates, HAZMAT certifications, and contractual obligations. Used to schedule periodic re-evaluations and flag overdue reviews.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered business name of the transportation carrier as filed with regulatory authorities (FMCSA, state business registry). Used in contracts, freight invoices, and regulatory filings. Must match the name on the carrier\'s operating authority.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum weight capacity in kilograms that the carrier\'s standard equipment can transport per shipment. Used in load planning, shipment consolidation, and carrier eligibility checks to prevent overweight violations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by the FMCSA to for-hire motor carriers transporting regulated commodities in interstate commerce. Distinct from DOT number — MC number grants operating authority while DOT number is for safety registration. Used in carrier compliance validation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the carrier was formally approved and onboarded into Consumer Goods\' carrier program, completing all compliance checks, insurance verification, and EDI/API setup. Marks the start of the carrier\'s operational eligibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Indicates whether the carrier has been designated as a preferred carrier in Consumer Goods\' carrier program, typically based on negotiated rates, service performance, and strategic partnership status. Preferred carriers receive priority in TMS automated tendering sequences.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique 2-4 character alpha code assigned by the National Motor Freight Traffic Association (NMFTA) to identify transportation carriers in North America. Used in EDI transactions (204, 214, 990) and freight billing. Mandatory for motor carriers operating in the US.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaCountries rdf:type rdf:Property ;
    rdfs:label 'Service Area Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the countries in which the carrier provides transportation services. Used for international shipment routing, customs compliance validation, and carrier eligibility filtering in cross-border logistics.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Service level classification offered by the carrier indicating transit speed and handling commitment. Drives SLA assignment, freight cost tier selection, and shipment routing logic in the TMS. Used in OTIF (On Time In Full) performance measurement.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Combined with the minimum temperature range, defines the carrier\'s certified temperature corridor for cold-chain shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Used to validate carrier eligibility for temperature-sensitive product shipments and cold-chain compliance verification.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for the carrier\'s web-based shipment tracking portal, with a placeholder (e.g., {tracking_number}) for dynamic substitution. Used to generate direct tracking links in shipment notifications, customer portals, and internal TMS dashboards.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used by the carrier in commercial operations, which may differ from the legal registered name. Used in operational communications, carrier portals, and reporting where the trade name is more recognizable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the carrier contract record in the logistics data platform. Primary key for the carrier_contract entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContract .

ind:accessorialScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Accessorial Schedule Code' ;
    rdfs:comment 'Reference code identifying the accessorial charge schedule applicable to this contract. Accessorial charges include liftgate, residential delivery, inside delivery, detention, layover, hazmat handling, and temperature-controlled surcharges. Links to the accessorial rate table for freight audit and cost estimation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this carrier contract automatically renews at expiry unless terminated with advance notice. When true, the renewal_notice_days field defines the required notice period. Supports contract lifecycle management and procurement planning.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The primary negotiated freight rate under this contract before surcharges and accessorial charges are applied. The unit of measure for this rate is defined by the rate_type field (e.g., per mile, per CWT, per pallet, flat). Used as the foundation for freight cost estimation and freight audit rate lookup.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this contract covers temperature-controlled (cold chain) shipments requiring refrigerated or frozen transport. When true, cold chain compliance monitoring, temperature logging, and FEFO inventory management protocols apply. Relevant for health, hygiene, and perishable consumer goods.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the procurement or logistics team. Used in EDI communications, freight audit, and carrier correspondence. Aligns with SAP S/4HANA MM contract document number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the carrier contract. Draft indicates contract is being authored; pending_approval is awaiting sign-off; active means the contract is in force; suspended means temporarily halted; expired means the term has lapsed; terminated means the contract was ended before expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the freight contract by commercial arrangement type. Spot contracts cover single-shipment rates; committed contracts lock volume at negotiated rates; preferred carrier agreements define priority tender; dedicated contracts reserve capacity; intermodal covers multi-mode arrangements; 3PL master covers third-party logistics umbrella agreements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic destination zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionFreeTimeHours rdf:type rdf:Property ;
    rdfs:label 'Detention Free Time Hours' ;
    rdfs:comment 'Number of hours the carrier\'s equipment (trailer/container) may remain at a Consumer Goods facility for loading or unloading without incurring detention charges. Exceeding this threshold triggers accessorial detention fees per the contract rate schedule.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Basis' ;
    rdfs:comment 'Defines how the fuel surcharge is calculated and applied: as a percentage of the base freight rate, a flat amount per mile, a flat amount per shipment, or dynamically linked to the DOE diesel fuel price index. Determines the fuel surcharge computation method in freight audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Contracted fuel surcharge rate expressed as a percentage of the base rate or as a fixed amount per unit, applied on top of the base freight rate to account for fuel cost variability. Linked to a fuel index table or DOE diesel price index. Critical for freight cost estimation and audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Maximum cargo insurance coverage amount provided by the carrier under this contract, expressed in the contract currency. Defines the financial liability limit for cargo loss or damage claims. Used in risk management and claims processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityLimitPerKg rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Per Kg' ;
    rdfs:comment 'Contractual carrier liability limit per kilogram of cargo for loss or damage claims, expressed in the contract currency. Used in freight claims management to calculate maximum recoverable amounts for damaged or lost shipments.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms at which this contract rate applies. Defines the upper bound of the weight break tier. Null indicates no upper limit (applies to all weights above the minimum). Used in freight cost estimation and audit.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWeightKg rdf:type rdf:Property ;
    rdfs:label 'Min Weight Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms at which this contract rate applies. Defines the lower bound of the weight break tier for rate applicability. Used in freight cost estimation and audit to validate correct rate application.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the origin country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Geographic origin zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Otif Penalty Rate' ;
    rdfs:comment 'Contractual penalty rate applied to the carrier for OTIF (On Time In Full) failures, expressed as a percentage of the invoice value or a fixed amount per incident. OTIF is a key KPI in consumer goods supply chain performance management. Supports carrier performance management and deduction processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Otif Threshold Pct' ;
    rdfs:comment 'Minimum OTIF performance percentage the carrier must achieve to avoid penalty charges under this contract. Expressed as a percentage (e.g., 98.5 means 98.5% OTIF compliance required). Below this threshold, the otif_penalty_rate is triggered.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Pickup Lead Time Hours' ;
    rdfs:comment 'Contracted lead time in hours from tender acceptance to carrier pickup at the origin facility. Used in shipment planning, load scheduling, and Blue Yonder WMS labor planning for dock door assignment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Defines the unit basis on which the base_rate is charged. Per-mile rates apply to distance-based pricing; per-CWT (hundredweight) applies to weight-based LTL pricing; per-pallet applies to unit-load pricing; flat rate is a fixed charge per shipment regardless of weight or distance; per-kg and per-lb are weight-based variants used in air and parcel freight. [ENUM-REF-CANDIDATE: per_mile|per_cwt|per_pallet|per_shipment|flat|per_kg|per_lb — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Exceedance triggers non-conformance reporting and potential product rejection.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Used for cold chain compliance monitoring and carrier performance audits.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackTraceMethod rdf:type rdf:Property ;
    rdfs:label 'Track Trace Method' ;
    rdfs:comment 'Method by which shipment tracking and status updates are provided by the carrier under this contract. EDI 214 is the standard electronic shipment status transaction; API enables real-time integration; portal requires manual check-in; email is manual notification. Drives track-and-trace capability in logistics operations.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Contracted standard transit time in calendar days from pickup to delivery for shipments under this contract and lane. Used as the SLA baseline for OTIF measurement, delivery promise, and ATP/CTP calculations in demand planning.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Units' ;
    rdfs:comment 'Contracted minimum volume commitment by Consumer Goods to the carrier over the contract term, expressed in the unit defined by volume_commitment_uom (e.g., shipments, pallets, CWT, revenue miles). Failure to meet this commitment may trigger shortfall penalties or rate renegotiation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the volume_commitment_units field. Defines whether the volume commitment is expressed in number of shipments, pallets, hundredweight (CWT), revenue miles, kilograms, or truckloads.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each carrier performance scorecard record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgTransitDays rdf:type rdf:Property ;
    rdfs:label 'Avg Transit Days' ;
    rdfs:comment 'Average number of calendar days from actual pickup to actual delivery across all shipments in the measurement period. Compared against standard transit days to assess transit time performance.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierContactName rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Name' ;
    rdfs:comment 'Name of the carrier\'s primary account representative or performance manager who receives and acknowledges this scorecard.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claims Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total_claims_amount field (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsRatePct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Pct' ;
    rdfs:comment 'Percentage of shipments resulting in a freight claim (loss, damage, or shortage) during the measurement period. Key indicator of cargo handling quality.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted composite score (0–100) summarizing the carrier\'s overall performance across all measured KPIs for the period. Drives performance tier assignment and contract renewal decisions.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRatePct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Pct' ;
    rdfs:comment 'Percentage of shipments with reported product damage upon delivery during the measurement period. Distinct from claims rate as it isolates physical damage from loss/shortage events.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Edi Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments for which the carrier transmitted all required EDI transaction sets (e.g., 214 shipment status, 210 freight invoice) accurately and on time during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightSpendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total_freight_spend field (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether a formal Carrier Improvement Plan (CIP) is active for this carrier as of this measurement period. True = improvement plan in effect; False = no active plan.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inFullRatePct rdf:type rdf:Property ;
    rdfs:label 'In Full Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered with the complete ordered quantity, without short-shipment or partial delivery, during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRatePct rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate Pct' ;
    rdfs:comment 'Percentage of carrier freight invoices that matched the contracted rate without requiring correction or dispute during the measurement period. Supports freight audit and pay processes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Granularity of the performance measurement window — weekly, monthly, quarterly, or annual. Determines the cadence at which KPIs are aggregated and reviewed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic network region covered by this scorecard (e.g., Northeast US, Western Europe, APAC). Enables regional performance benchmarking across the carrier network.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered to the destination within the committed delivery window during the measurement period. Distinct from OTIF as it excludes the in-full dimension.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimePickupRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Pickup Rate Pct' ;
    rdfs:comment 'Percentage of shipments where the carrier arrived at the origin facility within the scheduled pickup window during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRatePct rdf:type rdf:Property ;
    rdfs:label 'Otif Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered both on time and in full during the measurement period. Core OTIF KPI used in carrier scorecards and contract compliance reviews. Calculated as (OTIF shipments / total shipments) × 100.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Overall performance classification assigned to the carrier for this measurement period based on composite KPI scoring. Preferred = top-tier; Approved = meets standards; Probation = below threshold with improvement plan; Suspended = removed from routing guide pending review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date of the measurement period covered by this scorecard record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date of the measurement period covered by this scorecard record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Pod Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments for which a valid Proof of Delivery (POD) document was received within the contractually required timeframe during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Composite Score' ;
    rdfs:comment 'Composite performance score from the immediately preceding measurement period. Enables trend analysis and period-over-period performance comparison without requiring a self-join.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Finalized Date' ;
    rdfs:comment 'Calendar date on which the scorecard was locked as final after the dispute resolution window closed. Null if scorecard is not yet finalized.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardNotes rdf:type rdf:Property ;
    rdfs:label 'Scorecard Notes' ;
    rdfs:comment 'Free-text field for logistics team commentary on the scorecard, including context for performance anomalies, weather events, or force majeure conditions that impacted KPIs.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Externally-known business identifier for this scorecard record, used in carrier communications and contract review meetings. Format: CPSC-YYYY-MM-XXXXXX.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardPublishedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Published Date' ;
    rdfs:comment 'Calendar date on which the scorecard was formally published and shared with the carrier for review. Marks the start of the carrier\'s dispute window.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle state of the scorecard record. Draft = under calculation; Published = shared with carrier; Disputed = carrier has raised a challenge; Finalized = agreed and locked; Archived = historical.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAcceptanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Rate Pct' ;
    rdfs:comment 'Percentage of load tenders accepted by the carrier on first offer during the measurement period. Low acceptance rates indicate capacity reliability issues and routing guide compliance failures.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderAcceptanceTargetPct rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Target Pct' ;
    rdfs:comment 'Contracted minimum tender acceptance rate for this carrier during the measurement period. Compared against actual tender acceptance rate to assess routing guide compliance.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Amount' ;
    rdfs:comment 'Total monetary value of freight claims filed against the carrier during the measurement period, expressed in the reporting currency. Used for financial recovery tracking and carrier liability assessment.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightSpend rdf:type rdf:Property ;
    rdfs:label 'Total Freight Spend' ;
    rdfs:comment 'Total freight cost paid to the carrier during the measurement period, including base freight, fuel surcharges, and accessorial charges. Used for spend analytics and contract benchmarking.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
    rdfs:label 'Total Shipments' ;
    rdfs:comment 'Total number of shipments tendered to the carrier during the measurement period. Serves as the denominator for rate-based KPI calculations.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTenders rdf:type rdf:Property ;
    rdfs:label 'Total Tenders' ;
    rdfs:comment 'Total number of load tenders issued to the carrier during the measurement period, including both accepted and rejected tenders.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coldChainLogId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each cold chain monitoring log record. Primary key for the cold_chain_log data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityDistributionCenterDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Distribution Center Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility to which the cold chain shipment is destined. Used to assess whether excursions occurred in transit versus at origin or destination.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:primaryColdDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Cold Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility from which the cold chain shipment originated. Used to correlate excursions with origin facility loading conditions and cold storage practices.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Reference to the specific shipment leg or segment within a multi-leg journey during which this sensor reading was recorded. Enables excursion attribution to a specific carrier or transit segment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLeg .

ind:transportUnitId rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Id' ;
    rdfs:comment 'Identifier of the transport unit (trailer, container, refrigerated truck, or intermodal container) in which the sensor is installed. Used to correlate readings with equipment maintenance records and carrier performance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportUnit .

ind:alertAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the triggered alert was acknowledged by a responsible party (logistics manager, QA officer, or 3PL coordinator). Used to measure alert response time and compliance with excursion management SLAs.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertTriggered rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered' ;
    rdfs:comment 'Indicates whether this reading triggered an automated alert notification to logistics, quality, or operations teams. True = alert was sent. Used to audit alert responsiveness and SLA compliance.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Free-text description of the corrective action taken in response to a detected excursion (e.g., \'Refrigeration unit reset and temperature restored\', \'Shipment quarantined pending QA review\', \'Product returned to cold storage\'). Required for FDA compliance documentation and CAPA (Corrective and Preventive Action) records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when the corrective action was initiated or completed in response to an excursion. Used to calculate response time and assess compliance with SLA and regulatory requirements for excursion management.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataLoggerReportCode rdf:type rdf:Property ;
    rdfs:label 'Data Logger Report Code' ;
    rdfs:comment 'Unique identifier of the data logger report or download session from which this reading was extracted. Enables traceability back to the original device report file for audit and regulatory submission purposes.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Cumulative duration in minutes that the shipment has been in an excursion state up to and including this reading. Used to assess product safety impact, Mean Kinetic Temperature (MKT) calculations, and regulatory disposition decisions.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'Indicates whether this reading represents a temperature or humidity excursion — i.e., the observed value fell outside the defined min/max thresholds. True = excursion detected. Used to trigger alerts, corrective actions, and FDA compliance documentation.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity' ;
    rdfs:comment 'Severity classification of the excursion based on the magnitude of deviation from threshold and duration. Critical = immediate product safety risk; Major = significant deviation requiring QA review; Minor = within acceptable tolerance band; None = no excursion. Drives escalation and corrective action workflows.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionType rdf:type rdf:Property ;
    rdfs:label 'Excursion Type' ;
    rdfs:comment 'Classifies the type of excursion detected at this reading: temperature above maximum threshold (temperature_high), temperature below minimum threshold (temperature_low), humidity above maximum (humidity_high), humidity below minimum (humidity_low), or no excursion (none). Supports root cause analysis and regulatory reporting.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityMaxThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Max Threshold Pct' ;
    rdfs:comment 'The upper bound relative humidity threshold percentage defined for this shipment or product category. A reading above this value may indicate a humidity excursion risk.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityMinThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Min Threshold Pct' ;
    rdfs:comment 'The lower bound relative humidity threshold percentage defined for this shipment or product category. A reading below this value may indicate a humidity excursion risk.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityPct rdf:type rdf:Property ;
    rdfs:label 'Humidity Pct' ;
    rdfs:comment 'Observed relative humidity percentage recorded by the sensor at the reading timestamp. Critical for products sensitive to moisture (e.g., personal care, health products). Used alongside temperature to assess storage condition compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Log Sequence Number' ;
    rdfs:comment 'Sequential integer representing the order of this reading within the shipment\'s cold chain monitoring session. Enables chronological reconstruction of the temperature/humidity profile for a shipment and detection of data gaps.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meanKineticTempC rdf:type rdf:Property ;
    rdfs:label 'Mean Kinetic Temp C' ;
    rdfs:comment 'Calculated Mean Kinetic Temperature in degrees Celsius for the shipment up to this reading point. MKT is the single calculated temperature that, if maintained over the storage period, would produce the same thermal challenge as the actual temperature variations. Used for product stability and regulatory disposition decisions.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSessionCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Session Code' ;
    rdfs:comment 'Identifier grouping all sensor readings belonging to a single continuous monitoring session (from sensor activation to deactivation). Used to reconstruct the complete temperature profile for a shipment and detect session gaps.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTemperatureClass rdf:type rdf:Property ;
    rdfs:label 'Product Temperature Class' ;
    rdfs:comment 'Temperature storage classification of the product(s) in this shipment as defined by product specifications or regulatory requirements. Frozen = below -18°C; Refrigerated = 2–8°C; Controlled Room Temp = 15–25°C; Cool = 8–15°C. Determines applicable thresholds.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaDisposition rdf:type rdf:Property ;
    rdfs:label 'Qa Disposition' ;
    rdfs:comment 'Quality disposition decision made by the QA team for the affected product lot following excursion review. Approved = product released; Rejected = product destroyed or returned; Quarantined = held pending further investigation; Pending Review = awaiting QA decision; Conditionally Approved = released with conditions. Populated only when excursion_flag is True.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Review Timestamp' ;
    rdfs:comment 'Date and time when the QA team completed their review and issued a disposition decision for the excursion event. Used to measure QA response time and compliance with regulatory timelines.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Reading Interval Seconds' ;
    rdfs:comment 'Configured interval in seconds between consecutive sensor readings for this monitoring session. Typical values range from 60 (1 minute) to 900 (15 minutes). Used to validate data completeness and detect missing readings.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone offset) at which the sensor captured the temperature and humidity measurement. This is the principal event timestamp for the log record and is critical for FDA cold-chain compliance documentation.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sensorBatteryPct rdf:type rdf:Property ;
    rdfs:label 'Sensor Battery Pct' ;
    rdfs:comment 'Remaining battery level of the sensor device at the time of this reading, expressed as a percentage. Used to predict sensor failure risk and ensure data continuity for compliance documentation.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensorCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Date' ;
    rdfs:comment 'Date on which the sensor device was last calibrated. Required for FDA and GMP compliance to ensure measurement accuracy. Readings from uncalibrated or expired-calibration sensors may be flagged for review.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensorCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Sensor Calibration Due Date' ;
    rdfs:comment 'Date by which the sensor device must next be calibrated to remain compliant. Readings captured after this date may be flagged as non-compliant in regulatory submissions.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Unique identifier of the IoT temperature/humidity sensor device that captured this reading. Used for device traceability, calibration audit, and excursion investigation. Sourced from the sensor manufacturer\'s serial number or asset tag.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorModel rdf:type rdf:Property ;
    rdfs:label 'Sensor Model' ;
    rdfs:comment 'Manufacturer model designation of the sensor device (e.g., \'Sensitech TempTale 4\', \'Emerson DL8000\'). Used for device management, calibration scheduling, and accuracy benchmarking.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorPlacement rdf:type rdf:Property ;
    rdfs:label 'Sensor Placement' ;
    rdfs:comment 'Physical placement location of the sensor within the transport unit (e.g., ambient air, product contact, door panel, floor, ceiling, center load, return air). Affects interpretation of readings and excursion impact assessment. [ENUM-REF-CANDIDATE: ambient|product_contact|door_panel|floor|ceiling|center_load|return_air|none — promote to reference product]' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Observed temperature value in degrees Celsius recorded by the sensor at the reading timestamp. The principal quantitative measurement for cold-chain compliance monitoring. Used to detect excursions against defined min/max thresholds.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMaxThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Threshold C' ;
    rdfs:comment 'The upper bound temperature threshold in degrees Celsius defined for this shipment or product category. A reading above this value triggers a heat excursion flag. Sourced from product specification or regulatory requirement.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinThresholdC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Threshold C' ;
    rdfs:comment 'The lower bound temperature threshold in degrees Celsius defined for this shipment or product category. A reading below this value triggers a cold excursion flag. Sourced from product specification or regulatory requirement.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportUnitType rdf:type rdf:Property ;
    rdfs:label 'Transport Unit Type' ;
    rdfs:comment 'Classification of the transport unit used for this cold chain shipment leg. Determines expected temperature maintenance capability and regulatory documentation requirements.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Reference' ;
    rdfs:comment 'Reference identifier of the associated quality or regulatory document stored in Veeva Vault (e.g., excursion investigation report, CAPA record, regulatory submission). Enables traceability between cold chain log records and formal quality documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Id' ;
    rdfs:comment 'Unique surrogate identifier for the customs declaration record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ams Reference Number' ;
    rdfs:comment 'Reference number from the U.S. CBP Automated Manifest System (AMS) or equivalent advance cargo notification system (e.g., EU ICS2). Required for pre-arrival security filing for ocean and air shipments.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiDumpingCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Case Number' ;
    rdfs:comment 'Reference number for an applicable anti-dumping or countervailing duty (ADD/CVD) order affecting the declared goods. Triggers additional duty assessment beyond standard tariff rates.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondNumber rdf:type rdf:Property ;
    rdfs:label 'Bond Number' ;
    rdfs:comment 'Reference number of the customs bond (surety bond) guaranteeing payment of duties and taxes. Required for U.S. formal entries and other jurisdictions requiring financial security for customs obligations.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Broker Reference Number' ;
    rdfs:comment 'The customs broker\'s own internal reference number for this declaration filing. Used for reconciliation with broker invoices and correspondence.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the Certificate of Origin document supporting preferential duty treatment claims under a trade agreement. Required when trade_agreement_code is populated.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'Date and time when the customs authority officially cleared and released the shipment. Null if clearance has not yet occurred. Critical for OTIF tracking and logistics planning.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the goods were manufactured or substantially transformed. May differ from origin_country_code (country of export). Determines preferential duty treatment and trade agreement applicability.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Externally-known official customs declaration number assigned by the customs authority or filing system (e.g., Entry Number in US CBP, MRN in EU). This is the primary business identifier used in regulatory correspondence and audit trails.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the customs declaration as reported by the customs authority or broker. Drives operational actions such as release of goods, duty payment, or compliance escalation. [ENUM-REF-CANDIDATE: draft|filed|accepted|held|cleared|released|rejected — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Classification of the customs declaration indicating the direction and nature of the cross-border movement. Drives applicable regulatory requirements and duty calculations.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'The gross declared value of the goods as submitted to customs authorities, used as the basis for ad valorem duty and tax calculations. Expressed in the declared currency. Must comply with WCO Transaction Value method.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the declared customs value amount (e.g., USD, EUR, GBP). Required for duty calculation and currency conversion by customs authorities.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Total import or export duty assessed by the customs authority on the declared goods. Expressed in the duty currency. Includes ad valorem and specific duties as applicable.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyCurrency rdf:type rdf:Property ;
    rdfs:label 'Duty Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which duty and tax amounts are assessed and payable to the customs authority.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePct rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Pct' ;
    rdfs:comment 'The applicable ad valorem duty rate percentage applied to the declared value to calculate the duty amount. Sourced from the applicable tariff schedule for the HS code and country pair.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Type of customs examination applied to the shipment (e.g., document review, physical inspection, laboratory testing). Drives expected clearance delay and compliance action requirements.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Government-issued export license or authorization number required for controlled goods subject to export regulations. Required for dual-use goods, hazardous materials, or goods subject to trade sanctions.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterOfRecord rdf:type rdf:Property ;
    rdfs:label 'Exporter Of Record' ;
    rdfs:comment 'Legal name of the entity designated as the Exporter of Record (EOR) responsible for export compliance, filing export declarations, and maintaining export records.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filed Timestamp' ;
    rdfs:comment 'The principal business event timestamp recording when the customs declaration was officially submitted to the customs authority. Used for regulatory compliance tracking and SLA measurement.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freeTradeZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Free Trade Zone Flag' ;
    rdfs:comment 'Indicates whether the goods are entering or exiting a Free Trade Zone (FTZ) or Special Economic Zone (SEZ), which may affect duty suspension, deferral, or exemption treatment.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Official textual description of the goods as declared to customs authorities. Must accurately describe the nature, composition, and intended use of the products. Used for HS code validation and customs examination.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'The primary Harmonized System (HS) tariff classification code assigned to the goods in this declaration. A 6-10 digit code per WCO Harmonized System nomenclature used to determine applicable duty rates, import restrictions, and trade statistics. For multi-line declarations, this represents the primary or header-level HS code.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Government-issued import license or permit number required for regulated goods (e.g., FDA-regulated consumer products, EPA-regulated chemicals, CPSC-regulated items). Required for customs clearance of controlled product categories.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecord rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record' ;
    rdfs:comment 'Legal name of the entity designated as the Importer of Record (IOR) responsible for ensuring goods comply with all import laws and regulations and for paying applicable duties and taxes.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the allocation of costs, risks, and responsibilities between buyer and seller for the shipment. Determines the customs value basis (e.g., CIF vs FOB) used for duty calculation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Official code of the customs port or border crossing point where the goods enter the destination country (e.g., UN/LOCODE, U.S. CBP Port Code). Used for routing, examination scheduling, and regulatory reporting.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfExportCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Export Code' ;
    rdfs:comment 'Official code of the customs port or border crossing point from which the goods are exported from the origin country (e.g., UN/LOCODE). Used for export declaration filing and trade statistics.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDeclared rdf:type rdf:Property ;
    rdfs:label 'Quantity Declared' ;
    rdfs:comment 'Quantity of goods declared to customs in the applicable unit of measure (e.g., units, liters, kilograms). Used for specific duty calculations and statistical reporting.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Description of the reason for a customs hold or examination, such as FDA import alert, CPSC safety review, missing documentation, or random inspection. Populated when declaration_status is \'held\'.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Code' ;
    rdfs:comment 'Code identifying the preferential trade agreement under which reduced or zero duty rates are claimed (e.g., USMCA, EU-UK TCA, CPTPP, RCEP). Null if no preferential treatment is claimed.' ;
    rdfs:domain ind:CustomsDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Reference to the vehicle or transport unit used for this delivery. Supports fleet management, cold-chain compliance, and route analytics.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual temperature in degrees Celsius recorded during delivery, captured by IoT sensor or driver log. Used to verify cold-chain compliance and support FDA/EU GDP regulatory reporting for temperature-sensitive goods.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the delivery destination. Captured at time of delivery for POD (Proof of Delivery) and audit purposes, independent of master address data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'External tracking number assigned by the carrier for track-and-trace visibility. Enables real-time shipment monitoring and customer-facing delivery status updates.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal or trading name of the receiving party (store, warehouse, or customer) at the delivery destination. Used for POD (Proof of Delivery) documentation and dispute resolution.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery method. DSD (Direct Store Delivery) = manufacturer delivers directly to retail shelf; warehouse = delivery to distribution center; cross_dock = transit without storage; drop_ship = vendor ships directly to consignee; returns = reverse logistics delivery. [ENUM-REF-CANDIDATE: DSD|warehouse|cross_dock|drop_ship|returns — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Flag' ;
    rdfs:comment 'Indicates whether the POD (Proof of Delivery) signature was captured electronically (True) via e-POD app or DSD handheld, or obtained on paper (False). Determines evidentiary strength for dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Attempt Timestamp' ;
    rdfs:comment 'Date and time of the first delivery attempt at the consignee location. Relevant when the delivery required multiple attempts (e.g., failed first attempt followed by successful re-delivery). Supports carrier performance analytics.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsConditionCode rdf:type rdf:Property ;
    rdfs:label 'Goods Condition Code' ;
    rdfs:comment 'Condition of goods as assessed at point of delivery receipt. \'good\' = acceptable; \'damaged\' = physical damage observed; \'partial_damage\' = some units damaged; \'temperature_breach\' = cold-chain violation detected; \'contaminated\' = product integrity compromised. Triggers quality investigation and regulatory reporting. [ENUM-REF-CANDIDATE: good|damaged|partial_damage|temperature_breach|contaminated — promote to reference product]' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Reference' ;
    rdfs:comment 'Storage reference or URL to photo evidence captured at delivery (e.g., goods condition, placement, damaged packaging). Supports POD (Proof of Delivery) documentation and insurance claims.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSource rdf:type rdf:Property ;
    rdfs:label 'Pod Source' ;
    rdfs:comment 'System or method used to capture the POD (Proof of Delivery). DSD_handheld = Direct Store Delivery device; epod_app = electronic POD mobile application; paper_scan = digitized paper document; EDI = Electronic Data Interchange confirmation; manual = manually entered. Determines data quality and evidentiary weight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Refused Quantity' ;
    rdfs:comment 'Quantity of goods refused or rejected by the consignee at point of delivery. Triggers reverse logistics, credit memo processing, and quality investigation workflows.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signatureReference rdf:type rdf:Property ;
    rdfs:label 'Signature Reference' ;
    rdfs:comment 'Storage reference or URL pointing to the captured electronic or scanned signature image for this delivery. Used as legal evidence in POD (Proof of Delivery) dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAuditResultId rdf:type rdf:Property ;
    rdfs:label 'Freight Audit Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each freight audit result record. Primary key for the freight_audit_result data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualAmount rdf:type rdf:Property ;
    rdfs:label 'Accrual Amount' ;
    rdfs:comment 'Amount accrued in the general ledger for this freight cost prior to invoice receipt and audit. Used to reconcile accrual vs. actual freight cost and manage period-end close accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVsStandardVariance rdf:type rdf:Property ;
    rdfs:label 'Actual Vs Standard Variance' ;
    rdfs:comment 'Difference between the audited freight amount and the standard freight cost (audited_amount minus standard_cost_amount). Positive value indicates actual cost exceeded standard; negative indicates favorable variance. Key input to COGS freight component and logistics P&L.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The calendar date on which the freight invoice was audited against contracted rates and shipment data. Principal business event date for the audit lifecycle.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditSource rdf:type rdf:Property ;
    rdfs:label 'Audit Source' ;
    rdfs:comment 'Indicates whether the freight audit was performed by an internal team, a third-party freight audit provider, or an automated audit system. Supports audit quality governance and cost-to-audit tracking.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current workflow status of the freight audit result. \'approved\' means invoiced amount matches contracted rate; \'disputed\' means a formal dispute has been raised with the carrier; \'short_paid\' means payment was issued for the audited (lower) amount; \'pending\' means audit is in progress; \'voided\' means the audit record was cancelled; \'escalated\' means the dispute has been escalated for resolution. [ENUM-REF-CANDIDATE: approved|disputed|short_paid|pending|voided|escalated — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedAmount rdf:type rdf:Property ;
    rdfs:label 'Audited Amount' ;
    rdfs:comment 'Final freight amount determined by the audit process as the correct payable amount. May equal the contracted rate amount or reflect adjustments for accessorials, corrections, or negotiated settlements.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number associated with the shipment being audited. Used to cross-reference shipment documentation and validate carrier charges against actual freight moved.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'Freight amount calculated by applying the contracted carrier rate to the actual shipment characteristics (weight, volume, lane). Represents the expected charge per the governing carrier contract.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Basis' ;
    rdfs:comment 'Basis used to allocate the audited freight cost across cost centers, products, or business units. \'weight\' allocates by shipment weight (kg); \'volume\' by cubic meters; \'value\' by declared goods value; \'units\' by case/pallet count; \'equal_split\' divides equally.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the freight cost component being audited. \'line_haul\' is the base transportation charge; \'fuel_surcharge\' is the fuel adjustment; \'accessorial\' covers additional services (liftgate, residential delivery, etc.); \'duty\' covers customs/import duties; \'insurance\' covers cargo insurance; \'detention\' covers carrier wait-time charges. [ENUM-REF-CANDIDATE: line_haul|fuel_surcharge|accessorial|duty|insurance|detention — promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date on which a formal dispute was raised with the carrier for the identified freight charge variance. Used to track dispute aging and carrier SLA compliance for dispute resolution.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Carrier-assigned or internally-assigned reference number for a formal freight charge dispute. Populated when audit_status is \'disputed\' or \'escalated\'. Used to track dispute resolution progress and recovery.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'Date on which the carrier dispute was formally resolved (credit issued, short-payment accepted, or dispute closed). Used to measure dispute resolution cycle time and carrier performance.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Number' ;
    rdfs:comment 'Carrier-issued invoice number for the freight charges being audited. Primary external business identifier for the audit record; used for carrier dispute management and accounts payable matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert invoice currency amounts to reporting currency at the time of audit. Sourced from SAP FI or Oracle Cloud Financials daily rate tables.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrency rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the carrier\'s freight invoice (e.g., USD, EUR, GBP). Required for multi-currency freight cost consolidation and FX translation to reporting currency.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'Date the freight invoice was received by the company\'s accounts payable or freight audit team. Used to measure invoice processing cycle time and payment terms compliance.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Gross freight amount as billed by the carrier on the invoice, in the invoice currency. Represents the carrier\'s claimed charge before audit validation.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the audited freight invoice must be paid per carrier contract payment terms. Drives accounts payable scheduling and early payment discount capture.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount actually recovered from the carrier through short-payment, credit memo, or dispute resolution. May differ from variance_amount if only partial recovery was achieved.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for internal financial reporting and COGS freight component allocation (e.g., USD as functional currency). Enables consistent cross-currency logistics cost-to-serve analysis.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Pre-established standard freight cost for this lane and transport mode, used as the benchmark for actual vs. standard cost variance analysis. Feeds COGS standard costing and logistics cost-to-serve reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Description' ;
    rdfs:comment 'Free-text narrative explanation of the variance reason, providing additional context beyond the variance_reason_code. Used by freight audit analysts and carrier dispute managers.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightActualKg rdf:type rdf:Property ;
    rdfs:label 'Weight Actual Kg' ;
    rdfs:comment 'Actual verified shipment weight (in kilograms) as recorded at origin or confirmed by weigh-in-motion data. Used to validate carrier billed weight and identify weight discrepancy variances.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBilledKg rdf:type rdf:Property ;
    rdfs:label 'Weight Billed Kg' ;
    rdfs:comment 'Shipment weight (in kilograms) as billed by the carrier on the freight invoice. Compared against actual/verified weight to identify weight-based billing discrepancies.' ;
    rdfs:domain ind:FreightAuditResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostId rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Id' ;
    rdfs:comment 'Unique surrogate identifier for each freight cost record at the shipment or shipment-leg level. Primary key for the freight_cost data product.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Flag' ;
    rdfs:comment 'Indicates whether this freight cost record represents an accrued (estimated) cost rather than an actual invoiced amount. True = accrual entry; False = actual invoiced cost. Critical for COGS freight component accuracy in period-end close.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'Method used to allocate or apportion this freight cost across shipment lines or cost centers. Weight = allocated by gross weight (kg); Volume = allocated by cubic volume (m3); Value = allocated by declared goods value; Units = allocated by case/unit count; Flat = fixed charge not allocated; Distance = allocated by route distance (km).' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Quantity' ;
    rdfs:comment 'The quantity value used as the basis for cost allocation (e.g., weight in kg, volume in m3, declared value in currency, number of cases). Paired with allocation_basis and allocation_uom to fully describe the allocation driver.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationUom rdf:type rdf:Property ;
    rdfs:label 'Allocation Uom' ;
    rdfs:comment 'Unit of measure corresponding to the allocation_quantity field. KG = kilograms (weight basis); M3 = cubic meters (volume basis); USD = US Dollars (value basis); EA = each/cases (unit basis); KM = kilometers (distance basis); PCT = percentage (proportional basis).' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDiscrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Discrepancy Amount' ;
    rdfs:comment 'Monetary difference identified during freight audit between the carrier-invoiced amount and the expected contractual amount. Positive = carrier overcharged; Negative = carrier undercharged. Drives dispute and recovery actions.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'Accounting period (YYYY-MM) in which this freight cost is recognized for financial reporting. Used for period-end accrual matching and monthly freight cost trend analysis.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Chargeable Weight Kg' ;
    rdfs:comment 'The weight used by the carrier for billing purposes, which is the greater of actual gross weight and dimensional (volumetric) weight. Critical for air and parcel freight rate validation and audit.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Premium Amount' ;
    rdfs:comment 'Additional freight cost premium charged for temperature-controlled (cold chain) transportation. Applicable for perishable consumer goods, health, and personal care products requiring refrigerated or frozen transport.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Gross freight cost amount in the transaction currency for this cost category and shipment. Represents the base charge before any adjustments or credits. Core monetary field for logistics cost-to-serve analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Amount Usd' ;
    rdfs:comment 'Freight cost amount converted to US Dollars using the exchange rate at the time of cost recognition. Enables global freight cost consolidation and cross-currency benchmarking.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Document Number' ;
    rdfs:comment 'Externally-known business identifier for this freight cost record, typically sourced from the freight audit or ERP system (e.g., SAP FI document number or freight invoice reference). Used for reconciliation and audit trail.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Cost Recognition Date' ;
    rdfs:comment 'The principal business event date on which this freight cost is recognized in the financial system. For accruals, this is the estimated service completion date; for actuals, this is the invoice posting date.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of the freight cost record. Accrued = estimated cost booked before invoice; Invoiced = carrier invoice received; Approved = freight audit approved for payment; Disputed = charge under dispute; Paid = payment issued; Reversed = cost entry reversed or cancelled.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Sub Category' ;
    rdfs:comment 'Granular classification within the cost category (e.g., detention, liftgate, residential delivery, hazmat surcharge, cold-chain premium, oversize, re-delivery). Enables detailed cost-to-serve analysis by accessorial type.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number for a formal freight cost dispute raised with the carrier. Populated when freight_audit_status = disputed. Used to track dispute resolution and recovery amounts.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Audit Status' ;
    rdfs:comment 'Status of the freight audit process for this cost record. Pending = awaiting audit review; Passed = audit confirmed charge is correct; Failed = audit identified discrepancy; Disputed = formal dispute raised with carrier; Waived = audit waived per policy threshold.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Hazmat Surcharge Amount' ;
    rdfs:comment 'Additional freight cost surcharge for transportation of hazardous materials (e.g., aerosols, flammable products, chemical ingredients). Applicable per DOT/IATA/IMDG hazmat regulations.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'Applied freight rate per kilogram in the transaction currency. Used for rate compliance validation against contracted tariff and for cost-per-unit-weight benchmarking.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerKm rdf:type rdf:Property ;
    rdfs:label 'Rate Per Km' ;
    rdfs:comment 'Applied freight rate per kilometer in the transaction currency for distance-based pricing models. Used for road freight rate compliance validation and lane cost benchmarking.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentDirection rdf:type rdf:Property ;
    rdfs:label 'Shipment Direction' ;
    rdfs:comment 'Direction of the freight movement: Inbound = supplier to facility; Outbound = facility to customer/retailer; Interplant = between internal facilities; Return = reverse logistics. Enables inbound vs. outbound freight cost split for COGS and logistics P&L.' ;
    rdfs:domain ind:FreightCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Cubic volume in cubic meters of the freight associated with this cost record. Used as the allocation driver when allocation_basis = volume and for dimensional weight rate validation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Gross weight in kilograms of the freight associated with this cost record. Used as the allocation driver when allocation_basis = weight and for rate validation against weight-break tariffs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight invoice record in the Consumer Goods lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessorialAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Amount' ;
    rdfs:comment 'Total amount of accessorial charges on the invoice, including but not limited to liftgate, residential delivery, inside delivery, detention, redelivery, and hazmat fees. Audited against contracted accessorial schedules.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Amount approved for payment to the carrier after freight audit review and any adjustments. May differ from invoiced total if disputes or corrections were applied. This is the amount that flows to accounts payable for payment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Completed Timestamp' ;
    rdfs:comment 'Date and time the freight audit review was completed for this invoice. Marks the transition from \'under_audit\' to \'approved\' or \'disputed\' status in the freight audit and pay (FAP) workflow.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Expected freight charge calculated from the applicable carrier contract rate for this lane, mode, and service level. Used as the benchmark in freight audit to identify billing variances.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Code identifying the shipment destination facility (customer DC, retail store, or consumer address) to which the freight was delivered. Used for lane-level freight cost analysis.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes describing the reason for disputing the freight invoice, including specific discrepancies identified during freight audit. Supports carrier communication and dispute resolution.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for disputing the freight invoice (e.g., rate discrepancy, duplicate invoice, service failure, unauthorized accessorial). Populated when invoice_status is \'disputed\'. [ENUM-REF-CANDIDATE: rate_discrepancy|duplicate_invoice|service_failure|unauthorized_accessorial|weight_discrepancy|missing_bol — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Code' ;
    rdfs:comment 'EDI (Electronic Data Interchange) transaction set identifier for invoices received electronically via EDI 210 (Motor Carrier Freight Invoice) or equivalent. Enables traceability of electronic invoice transmission.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'National Motor Freight Classification (NMFC) freight class assigned to the shipment (e.g., 50, 70, 100, 150). Determines LTL (Less-Than-Truckload) base rates and is a key audit point for freight invoice validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Carrier-applied fuel surcharge amount added to the base line-haul charge. Typically calculated as a percentage of line-haul based on the DOE (Department of Energy) fuel index. Key component for freight cost variance analysis.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceSource rdf:type rdf:Property ;
    rdfs:label 'Invoice Source' ;
    rdfs:comment 'Channel through which the freight invoice was received by Consumer Goods. Used to track EDI adoption rates and identify manual processing inefficiencies.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the freight invoice by document type. Distinguishes standard carrier invoices from credit memos, debit memos, rebills, and adjustments for accurate financial processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Total Amount' ;
    rdfs:comment 'Total gross amount invoiced by the carrier, inclusive of line-haul, fuel surcharge, accessorials, and taxes. This is the amount the carrier is requesting for payment before audit adjustments.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isColdChain rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain' ;
    rdfs:comment 'Indicates whether this freight invoice covers a temperature-controlled (cold chain) shipment requiring refrigerated or frozen transport. Relevant for Consumer Goods products with cold-chain compliance requirements.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether the shipment covered by this invoice contains hazardous materials requiring special handling, labeling, and regulatory compliance. Triggers validation of hazmat accessorial charges.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineHaulAmount rdf:type rdf:Property ;
    rdfs:label 'Line Haul Amount' ;
    rdfs:comment 'Base transportation charge for moving freight from origin to destination, excluding surcharges and accessorials. Core component of the freight invoice monetary triplet.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the shipment origin facility (plant, warehouse, or distribution center) from which the freight movement originated. Used for lane-level freight cost analysis and carrier performance reporting.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the payment was issued to the carrier for this freight invoice. Used to calculate Days Sales Outstanding (DSO), confirm on-time payment, and support carrier relationship management.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Internal payment document or check/ACH reference number assigned when the invoice was paid. Used to reconcile freight invoices against bank statements and carrier remittance advice.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date the transportation service was rendered (pickup or delivery date). Used to match the invoice to the correct accounting period and validate service delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Supply Network Node Id' ;
    rdfs:comment 'Reference to the pickup/origin location (plant, warehouse, distribution center, or supplier facility) from which the freight order originates.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:accessorialChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Amount' ;
    rdfs:comment 'Total accessorial charges (e.g., liftgate, detention, residential delivery, inside delivery, hazmat handling) applied to this freight order beyond the base rate and fuel surcharge.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'The actual date and time the carrier picked up the freight at the origin location. Compared against the pickup window to determine on-time pickup performance for OTIF reporting.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agreedFreightRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Freight Rate' ;
    rdfs:comment 'The negotiated or spot-quoted rate agreed with the carrier for executing this freight order, expressed in the transaction currency. Used for freight cost accrual, freight audit, and carrier rate benchmarking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the carrier for this freight order. Used for freight audit and payment matching in accounts payable. Populated upon receipt of carrier invoice.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates the direction of the freight movement relative to the company\'s network: inbound (from supplier to plant/DC), outbound (from plant/DC to customer/retailer), or interplant (between internal facilities).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of transportation equipment required for this freight order (e.g., dry van, refrigerated/reefer, flatbed, tanker, intermodal container). Critical for cold-chain compliance for temperature-sensitive consumer goods. [ENUM-REF-CANDIDATE: dry_van|reefer|flatbed|tanker|intermodal|curtainsider|box_truck — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Order Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the freight order as issued by the Transportation Management System (TMS). Used in carrier communications, EDI transactions, and proof-of-delivery documents.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Pickup Window End' ;
    rdfs:comment 'End of the agreed pickup time window at the origin location. Defines the latest time the carrier may arrive for loading without incurring a late pickup penalty.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupWindowStart rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Start' ;
    rdfs:comment 'Start of the agreed pickup time window at the origin location. Defines the earliest time the carrier may arrive for loading. Used for dock scheduling and carrier compliance measurement.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podReceived rdf:type rdf:Property ;
    rdfs:label 'Pod Received' ;
    rdfs:comment 'Indicates whether a signed Proof of Delivery (POD) document has been received and recorded for this freight order. Required for freight payment release, dispute resolution, and retailer compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time the Proof of Delivery (POD) was received and confirmed. Used for delivery confirmation, OTIF (On Time In Full) final measurement, and freight payment processing.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The date on which the shipper requests the carrier to pick up the freight at the origin location. Used for OTIF (On Time In Full) measurement and carrier performance tracking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenderingMethod rdf:type rdf:Property ;
    rdfs:label 'Tendering Method' ;
    rdfs:comment 'Method used to tender the freight order to a carrier. Contract indicates a pre-negotiated rate agreement; spot indicates a one-time market rate; load_board indicates posting to a freight exchange; dedicated indicates a committed fleet arrangement; auction indicates a competitive bidding process.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Tms Source System' ;
    rdfs:comment 'Identifies the source Transportation Management System (TMS) from which this freight order record was ingested into the lakehouse. Supports data lineage, reconciliation, and multi-system integration auditing.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total cost of this freight order including base rate, fuel surcharge, and all accessorial charges. Used for COGS (Cost of Goods Sold) allocation, freight budget vs. actuals reporting, and carrier invoice audit.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Unique system-generated identifier for a freight rate record. Primary key for the freight_rate data product.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossBorder rdf:type rdf:Property ;
    rdfs:label 'Cross Border' ;
    rdfs:comment 'Indicates whether this freight rate applies to cross-border (international) shipments. Cross-border rates include additional cost components for customs, duties, and border crossing fees not present in domestic rates.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationPostalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code From' ;
    rdfs:comment 'Starting postal code of the destination zone range for this freight rate. Used for zone-based rate determination when the rate applies to a range of destination postal codes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code To' ;
    rdfs:comment 'Ending postal code of the destination zone range for this freight rate. Together with destination_postal_code_from, defines the geographic destination band to which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'Carrier-defined zone code for the destination geography. Used in conjunction with origin_zone_code for zone-pair rate determination in carrier tariff structures.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Standard distance in kilometers for the origin-to-destination lane associated with this rate. Used in per-mile/per-km rate calculations and freight cost benchmarking.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatApplicable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Applicable' ;
    rdfs:comment 'Indicates whether this freight rate applies to hazardous materials (hazmat) shipments. Consumer goods with hazmat classification (e.g., aerosols, flammable products) require specialized rates and carrier certifications per DOT and EPA regulations.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCharge rdf:type rdf:Property ;
    rdfs:label 'Max Charge' ;
    rdfs:comment 'Maximum charge amount that applies as a cap for this rate, regardless of shipment weight or distance. Null indicates no cap. Used in negotiated contract rates to protect shippers from excessive charges on large shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCharge rdf:type rdf:Property ;
    rdfs:label 'Min Charge' ;
    rdfs:comment 'Minimum charge amount that applies regardless of shipment weight or distance. Ensures the carrier recovers a floor cost for any shipment under this rate. Used in freight cost estimation to enforce rate floor.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originPostalCodeFrom rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code From' ;
    rdfs:comment 'Starting postal code of the origin zone range for this freight rate. Used for zone-based rate determination when the rate applies to a range of origin postal codes rather than a single location.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCodeTo rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code To' ;
    rdfs:comment 'Ending postal code of the origin zone range for this freight rate. Together with origin_postal_code_from, defines the geographic origin band to which this rate applies.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZoneCode rdf:type rdf:Property ;
    rdfs:label 'Origin Zone Code' ;
    rdfs:comment 'Carrier-defined zone code for the origin geography. Zone codes are used in carrier tariff structures to group postal codes into pricing zones for simplified rate lookup.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasisUom rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Uom' ;
    rdfs:comment 'Unit of measure that defines the denominator for the base_rate. Specifies what one unit of the rate_type represents (e.g., KG for per-kilogram rates, CWT for hundredweight, PALLET for per-pallet rates). Essential for correct freight cost computation. [ENUM-REF-CANDIDATE: KG|CWT|PALLET|MILE|KM|UNIT|SHIPMENT|CONTAINER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Number' ;
    rdfs:comment 'Externally-known business identifier for this freight rate record, used in carrier communications, freight audit, and cost estimation workflows. Typically sourced from the carrier tariff or contract schedule.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the freight rate — whether derived from a negotiated carrier contract, spot market quote, published tariff, or benchmark rate. Used to distinguish contracted rates from market rates in freight cost analysis.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate record. Indicates whether the rate is currently applicable for freight cost estimation and shipment planning.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotQuoteReference rdf:type rdf:Property ;
    rdfs:label 'Spot Quote Reference' ;
    rdfs:comment 'Reference number for the spot market quote when rate_source is \'spot_market\' or \'spot_quote\'. Enables traceability back to the original carrier quote for audit and freight cost reconciliation purposes.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Name or identifier of the carrier\'s published tariff schedule from which this rate is derived. Used when rate_source is \'tariff\' to reference the specific tariff document governing the rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms for this rate to apply. Defines the upper bound of the weight break tier. Null indicates no upper limit (applies to all weights above the minimum).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms for this rate to apply. Defines the lower bound of the weight break tier. Used in LTL and CWT-based rate structures to determine applicable rate.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Supply Network Node Id' ;
    rdfs:comment 'Reference to the destination facility, distribution center, retail store, or customer location where freight is delivered on this lane. Links to the location master in the logistics domain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:laneBackupCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Backup Carrier Id' ;
    rdfs:comment 'Reference to the secondary/backup carrier for this lane, used when the preferred carrier declines the tender or is unavailable. Represents the second position in the routing guide.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:lanePreferredCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Preferred Carrier Id' ;
    rdfs:comment 'Reference to the primary/preferred carrier assigned to this lane for freight tendering. Represents the first-tender carrier in the routing guide hierarchy. Links to the carrier master in the logistics domain.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:laneSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Lane Supply Network Node Id' ;
    rdfs:comment 'Reference to the origin facility, distribution center, plant, or supplier location from which freight departs on this lane. Links to the location master in the logistics domain.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:annualVolumeLoads rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Loads' ;
    rdfs:comment 'Historical or planned annual shipment volume on this lane expressed in number of loads (truckloads, containers, or equivalent units). Used for carrier contract negotiations, network design, and freight spend forecasting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeWeightKg rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Weight Kg' ;
    rdfs:comment 'Historical or planned annual freight weight moved on this lane in kilograms. Used for carrier contract negotiations, modal optimization, and carbon emissions intensity calculations per ISO 14001.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateFlat rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Flat' ;
    rdfs:comment 'Lane-level flat cost benchmark (all-in rate per load/shipment) in the operating currency. Used for truckload lanes where per-km pricing is not applicable. Supports freight audit and carrier contract negotiation.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRatePerKm rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Per Km' ;
    rdfs:comment 'Lane-level cost benchmark expressed as rate per kilometer in the operating currency. Used for freight audit, carrier performance benchmarking, and transportation cost variance analysis. Confidential as it reflects negotiated contract intelligence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor' ;
    rdfs:comment 'Lane-level carbon emission intensity factor expressed as kilograms of CO2 equivalent per kilometer, based on transport mode and equipment type. Used for Scope 3 emissions reporting, sustainability KPIs, and ESG disclosures per ISO 14001 and EPA Greenhouse Gas Reporting Program.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Directional and functional classification of the lane within the supply chain network. Inbound covers supplier-to-plant/DC movements; outbound covers DC-to-customer/retailer; inter-facility covers plant-to-DC or DC-to-DC; last-mile covers final delivery to end consumer or store; reverse covers returns flow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsTradeZone rdf:type rdf:Property ;
    rdfs:label 'Customs Trade Zone' ;
    rdfs:comment 'Trade zone or customs agreement applicable to this cross-border lane (e.g., USMCA, EU Single Market, ASEAN). Determines duty rates, documentation requirements, and customs clearance procedures. Populated only for cross-border lanes.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligible rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible' ;
    rdfs:comment 'Indicates whether this lane supports Direct Store Delivery (DSD), where product is delivered directly from the manufacturer or distributor to the retail store, bypassing the retailer\'s distribution center. Relevant for high-velocity CPG categories.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether this lane requires carriers certified for hazardous materials (HAZMAT) transport. Applicable for lanes carrying chemical, aerosol, or regulated consumer goods. Triggers carrier qualification checks and regulatory documentation requirements per DOT/EPA/OSHA.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the transportation lane, used in carrier contracts, freight tenders, and TMS systems. Typically formatted as ORIGIN-DEST-MODE (e.g., CHI-NYC-TL). Aligns with SAP TM lane master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the transportation lane, typically combining origin and destination location names and transport mode (e.g., \'Chicago DC to New York RDC - Truckload\'). Used in reporting and carrier communication.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current lifecycle status of the transportation lane. Active lanes are available for freight tendering and route optimization. Inactive or suspended lanes are excluded from planning runs.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'City name of the lane origin point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStateProvince rdf:type rdf:Property ;
    rdfs:label 'Origin State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the lane origin. Used in carrier rate zone mapping, regulatory compliance (e.g., CARB emissions zones), and freight cost benchmarking.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGuideRank rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Rank' ;
    rdfs:comment 'Numeric rank of the preferred carrier in the lane routing guide sequence. Rank 1 is the primary carrier; higher ranks are fallback options. Used in automated freight tendering workflows to determine tender sequence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Contractually agreed or operationally standard number of calendar days for freight to travel from origin to destination on this lane. Used as the baseline for OTIF (On Time In Full) measurement, delivery promise, and ATP/CTP calculations in SAP IBP.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: Recall traceability: connect shipments to the specific production batch to enable FDA batch-level recall and quality investigations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:consolidationId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Id' ;
    rdfs:comment 'Identifier linking this shipment to a consolidation group (e.g., a multi-stop truckload or ocean container consolidation). Enables freight cost allocation across consolidated shipments and container-level tracking.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consolidation .

ind:marketingEventId rdf:type rdf:Property ;
    rdfs:label 'Marketing Event Id' ;
    rdfs:comment 'Foreign key linking to marketing.event. Business justification: Supports event logistics tracking, tying shipments of promotional goods to the specific marketing event they serve for post-event analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingEvent .

ind:originTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Origin Trade Account Id' ;
    rdfs:comment 'Foreign key linking to customer.trade_account. Business justification: Shipment origin account is needed for cost attribution, SLA reporting, and regulatory shipment origin documentation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryLogisticsDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Logistics Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility (plant, distribution center, warehouse, or supplier location) from which the shipment departs.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:otifInFull rdf:type rdf:Property ;
    rdfs:label 'Otif In Full' ;
    rdfs:comment 'Indicates whether the shipment was delivered with the complete ordered quantity, contributing to the OTIF (On Time In Full) KPI. Supports retailer compliance scorecarding and deduction management.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifOnTime rdf:type rdf:Property ;
    rdfs:label 'Otif On Time' ;
    rdfs:comment 'Indicates whether the shipment was delivered on or before the planned delivery date, contributing to the OTIF (On Time In Full) KPI. Derived from planned vs. actual delivery date comparison and stored for reporting efficiency.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The date on which the shipment is expected to arrive at the destination facility, based on contracted transit time and lane performance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The date on which the shipment is scheduled to depart from the origin facility, as determined by the transportation plan or S&OP (Sales and Operations Planning) process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threePlReference rdf:type rdf:Property ;
    rdfs:label 'Three Pl Reference' ;
    rdfs:comment 'Reference number assigned by the 3PL (Third-Party Logistics) provider for this shipment in their WMS or TMS. Enables cross-system reconciliation and 3PL billing validation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCases rdf:type rdf:Property ;
    rdfs:label 'Total Cases' ;
    rdfs:comment 'Total number of cases (cartons) included in the shipment. Used for pick/pack verification, receiving reconciliation, and OTIF (On Time In Full) quantity compliance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPallets rdf:type rdf:Property ;
    rdfs:label 'Total Pallets' ;
    rdfs:comment 'Total number of pallets included in the shipment. Used for dock scheduling, trailer loading planning, and carrier billing for LTL shipments.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic meters. Used for dimensional weight calculation, trailer utilization, and freight cost optimization.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Unique system-generated identifier for the proof of delivery record. Primary key for this entity.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Scan Timestamp' ;
    rdfs:comment 'Timestamp of the carrier\'s own barcode or RFID scan event at the point of delivery, as transmitted via EDI or carrier portal. May differ from receipt_timestamp if there is a lag between physical delivery and system capture.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The consignee\'s own purchase order or reference number for this delivery. Enables cross-referencing between the supplier\'s POD and the customer\'s receiving records for EDI reconciliation and dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationGln rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) of the delivery destination. Provides a globally unique, standardized identifier for the consignee location, enabling interoperability with trading partners and EDI systems.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationName rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Name' ;
    rdfs:comment 'Name of the physical delivery location (e.g., store name, distribution center name, warehouse name). Provides human-readable identification of the delivery destination for reporting and operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Delivery Temperature C' ;
    rdfs:comment 'Recorded temperature in degrees Celsius at the point of delivery for temperature-sensitive goods. Used to verify cold-chain compliance and support FDA regulatory reporting for perishable or pharmaceutical consumer goods.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Categorical classification of the type of discrepancy identified at delivery. Enables structured reporting and root cause analysis across the logistics network. [ENUM-REF-CANDIDATE: quantity_shortage|overage|damaged_goods|wrong_item|temperature_breach|missing_documentation — promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which a delivery dispute was formally resolved. Used to measure dispute resolution cycle time and SLA compliance for freight audit and carrier management.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any freight or delivery dispute associated with this POD. Tracks the lifecycle of dispute resolution from identification through closure. Supports freight audit and carrier claims management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteStopSequence rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Stop Sequence' ;
    rdfs:comment 'The sequential stop number of this delivery within the DSD route. Used for route optimization analysis, driver performance measurement, and DSD compliance reporting in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightBillNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Bill Number' ;
    rdfs:comment 'The carrier-issued freight bill or bill of lading (BOL) number associated with this delivery. Used to match POD records to freight invoices during freight audit and payment processes.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Geofence Validated Flag' ;
    rdfs:comment 'Indicates whether the GPS coordinates captured at delivery were within the expected geofence boundary of the consignee location (True = within geofence). Used to detect fraudulent or erroneous POD captures in DSD operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time of delivery confirmation. Used for geofencing validation, proof of delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time of delivery confirmation. Used alongside latitude for geofencing validation, delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsCondition rdf:type rdf:Property ;
    rdfs:label 'Goods Condition' ;
    rdfs:comment 'Condition of the goods as assessed at the point of delivery by the recipient. Drives claims processing, carrier liability assessment, and quality incident reporting. [ENUM-REF-CANDIDATE: intact|damaged|partial_damage|refused|short_delivered — promote to reference product if additional conditions are required]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Count' ;
    rdfs:comment 'Number of photo attachments captured and associated with this POD record. Indicates the volume of photographic evidence available for dispute resolution and claims processing.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoAttachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Urls' ;
    rdfs:comment 'Comma-separated list of URL or file path references to photo images captured at delivery (e.g., photos of damaged goods, delivery location, pallet condition). Stored in secure document repository and referenced for dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmation Method' ;
    rdfs:comment 'The method used to confirm delivery receipt (e.g., signature, PIN code, photo-only, verbal confirmation, unattended drop). Supports compliance with carrier SLA requirements and DSD operational standards.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'Externally-known business reference number for this POD document. Used in freight audit, dispute resolution, and EDI acknowledgement exchanges with carriers and customers.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTitle rdf:type rdf:Property ;
    rdfs:label 'Recipient Title' ;
    rdfs:comment 'Job title or role of the individual who received the goods (e.g., Receiving Manager, Store Associate, Warehouse Clerk). Provides context for authorization level of the signatory.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or file path reference to the stored digital image of the recipient\'s signature. Used as legal evidence in freight disputes and customer claims. Stored in secure document repository.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual timestamp at which the vehicle departed the depot. Compared against planned_departure_time to measure on-time departure performance and identify dispatch delays.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'Actual driving distance recorded for the route in kilometers, typically captured via telematics or GPS. Compared against planned distance for route efficiency analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMin rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Min' ;
    rdfs:comment 'Actual total route duration in minutes from depot departure to return. Used to measure route execution efficiency and identify deviations from plan.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReturnTime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Time' ;
    rdfs:comment 'Actual timestamp at which the vehicle returned to the depot. Used to calculate total route duration, driver overtime, and vehicle utilization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:co2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide emissions in kilograms for this route, calculated from fuel consumption and vehicle type. Supports sustainability reporting, ESG disclosures, and ISO 14001 environmental management.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total planned or actual freight cost for this route in the operating currency. Used for transportation cost tracking, carrier invoice reconciliation, and freight audit processes.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumptionLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Liters' ;
    rdfs:comment 'Estimated or actual fuel consumed in liters for this route. Used for fleet cost management, carbon emissions calculation, and sustainability reporting under ISO 14001.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Indicates whether this route carries hazardous materials (e.g., aerosols, flammable cleaning products) requiring special handling, placarding, and regulatory compliance under DOT and EPA regulations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDsd rdf:type rdf:Property ;
    rdfs:label 'Is Dsd' ;
    rdfs:comment 'Indicates whether this route is a Direct Store Delivery (DSD) route, where the manufacturer delivers directly to retail store shelves bypassing the retailer\'s distribution center. Drives specific execution workflows in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm' ;
    rdfs:comment 'Name or identifier of the route optimization algorithm or engine used to generate this route plan (e.g., \'VRP-TW\', \'Clarke-Wright\', \'Blue Yonder Optimizer v4.2\'). Supports algorithm performance benchmarking and audit.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Timestamp' ;
    rdfs:comment 'Timestamp when the route optimization algorithm was executed to generate this route plan. Used to track plan freshness and identify routes built on stale demand data.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifCompliant rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant' ;
    rdfs:comment 'Indicates whether this route achieved full OTIF (On Time In Full) compliance — all stops were serviced within the agreed time windows and all ordered quantities were delivered. Key KPI for retailer scorecards.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Planned Distance Km' ;
    rdfs:comment 'Total planned driving distance for the route in kilometers, as calculated by the route optimization algorithm. Used for fuel cost estimation, carbon footprint calculation, and driver pay.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationMin rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Min' ;
    rdfs:comment 'Total planned route duration in minutes, including drive time and estimated stop dwell times. Used for driver scheduling and OTIF planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfDeliveryRequired rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Required' ;
    rdfs:comment 'Indicates whether electronic or physical proof of delivery (POD) must be captured at each stop on this route. Drives mobile app workflows for drivers and supports dispute resolution.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDate rdf:type rdf:Property ;
    rdfs:label 'Route Date' ;
    rdfs:comment 'The calendar date on which this route is planned to be executed. Used for daily route scheduling, driver dispatch, and OTIF performance tracking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeNumber rdf:type rdf:Property ;
    rdfs:label 'Route Number' ;
    rdfs:comment 'Externally-known business identifier for the route, used in operational communications, driver manifests, and carrier EDI exchanges. May align with SAP Transportation Management route codes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Service Time Window End' ;
    rdfs:comment 'Latest allowable timestamp for the route to complete servicing stops. Breaching this window results in OTIF failures and potential retailer chargebacks.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Service Time Window Start' ;
    rdfs:comment 'Earliest allowable timestamp for the route to begin servicing stops, as defined by customer or retailer receiving window constraints. Used as an input constraint in the route optimization algorithm.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCasesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Cases Planned' ;
    rdfs:comment 'Total number of cases (selling units) planned for delivery across all stops on this route. Used for vehicle load planning and OTIF measurement.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Pallets Planned' ;
    rdfs:comment 'Total number of pallets planned for loading on this route. Used for vehicle capacity utilization and dock door planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Stops Completed' ;
    rdfs:comment 'Actual number of stops successfully completed during route execution. Compared against total_stops_planned to measure route completion rate and identify failed deliveries.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Stops Planned' ;
    rdfs:comment 'Total number of delivery or pickup stops planned for this route. Used for workload balancing, route complexity scoring, and driver capacity planning.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of the vehicle\'s rated payload capacity utilized by the planned load on this route. Key metric for fleet efficiency and freight cost optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeStopId rdf:type rdf:Property ;
    rdfs:label 'Route Stop Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual stop on a planned delivery route. Primary key for the route_stop entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCases rdf:type rdf:Property ;
    rdfs:label 'Actual Cases' ;
    rdfs:comment 'Actual number of cases delivered or picked up at this stop as confirmed by the driver or proof of delivery (POD) scan. Used for OTIF fill rate calculation and short-shipment identification.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPallets rdf:type rdf:Property ;
    rdfs:label 'Actual Pallets' ;
    rdfs:comment 'Actual number of pallets delivered or picked up at this stop as confirmed at execution. Used for OTIF measurement, pallet reconciliation, and carrier billing verification.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrivalVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Arrival Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual arrival time and planned arrival time. Positive values indicate late arrival; negative values indicate early arrival. Core metric for OTIF and route adherence KPI reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line of the delivery location for this stop. Used for driver navigation, proof of delivery, and logistics compliance documentation.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for the delivery location (suite, unit, dock number, building identifier). Supplements the primary address for precise delivery execution.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City of the delivery location for this stop. Used for geographic segmentation of delivery performance and freight cost analysis.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the delivery location (e.g., USA, GBR, DEU). Used for cross-border logistics compliance and international freight management.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery location. Used for route optimization, freight zone determination, and last-mile delivery analytics.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province of the delivery location. Used for regulatory compliance, freight lane analysis, and geographic reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Total time in minutes the driver spent at this stop, calculated as the difference between actual departure and actual arrival times. Key KPI for stop-level efficiency, driver productivity, and route optimization.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Reason code or description explaining why a delivery stop was not completed successfully (e.g., consignee closed, refused delivery, access denied, vehicle breakdown). Required for failed or skipped stop status. [ENUM-REF-CANDIDATE: consignee_closed|refused_delivery|access_denied|vehicle_breakdown|incorrect_address|no_dock_available|weather — promote to reference product]' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Time' ;
    rdfs:comment 'Scheduled date and time the driver is expected to arrive at this stop, as determined by the route planning system. Used as the baseline for On Time In Full (OTIF) measurement and service level agreement (SLA) compliance.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCases rdf:type rdf:Property ;
    rdfs:label 'Planned Cases' ;
    rdfs:comment 'Number of cases (standard shipping units) planned to be delivered or picked up at this stop as per the delivery order. Used for load planning, vehicle capacity utilization, and OTIF measurement.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPallets rdf:type rdf:Property ;
    rdfs:label 'Planned Pallets' ;
    rdfs:comment 'Number of pallets planned to be delivered or picked up at this stop. Used for vehicle load planning, dock scheduling, and warehouse labor planning.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Weight Kg' ;
    rdfs:comment 'Total planned weight in kilograms of goods to be delivered or picked up at this stop. Used for vehicle load compliance, freight cost calculation, and carrier billing.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podCaptured rdf:type rdf:Property ;
    rdfs:label 'Pod Captured' ;
    rdfs:comment 'Indicates whether a proof of delivery (POD) was successfully captured at this stop (e.g., electronic signature, barcode scan, photo). Required for invoice settlement, dispute resolution, and regulatory compliance.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Method' ;
    rdfs:comment 'Method used to capture proof of delivery at this stop. Electronic_signature indicates digital sign-off; barcode_scan indicates GS1 scan confirmation; photo indicates photographic evidence; paper indicates manual paper POD; none indicates no POD captured.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Pod Signatory Name' ;
    rdfs:comment 'Name of the individual who signed or confirmed receipt of the delivery at this stop. Used for delivery verification, dispute resolution, and compliance documentation.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopName rdf:type rdf:Property ;
    rdfs:label 'Stop Name' ;
    rdfs:comment 'Human-readable name or label for the stop location, typically the retail store name, distribution center name, or customer site name. Used for driver manifests and operational reporting.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Number' ;
    rdfs:comment 'Sequential position of this stop within the planned delivery route. Determines the order in which the driver visits consignees. Used for route adherence analysis and optimization.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current execution status of this route stop within its lifecycle. Planned indicates not yet visited; in_transit indicates driver en route; arrived indicates driver on-site; completed indicates delivery confirmed; skipped indicates stop bypassed; failed indicates delivery attempt unsuccessful.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the activity performed at this stop. Delivery indicates outbound drop-off; pickup indicates inbound collection; cross_dock indicates transfer without storage; return indicates reverse logistics collection; service indicates a non-product visit.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExceedance rdf:type rdf:Property ;
    rdfs:label 'Temperature Exceedance' ;
    rdfs:comment 'Indicates whether a temperature exceedance event was recorded during transit to or at this stop. Triggers quality hold, product disposition review, and regulatory notification processes.' ;
    rdfs:domain ind:RouteStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line item record in the logistics data platform. Primary key for the shipment_item entity.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSkuId rdf:type rdf:Property ;
    rdfs:label 'Event Sku Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_event_sku. Business justification: Needed for Promotional SKU shipment reconciliation to calculate allocated vs actual promotional volume per shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventSku .

ind:handlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Id' ;
    rdfs:comment 'Identifier for the physical handling unit (pallet, carton, tote) in which this item is packed for shipment. Used for load planning, dock management, and proof of delivery reconciliation in the WMS.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:prototypeId rdf:type rdf:Property ;
    rdfs:label 'Prototype Id' ;
    rdfs:comment 'Foreign key linking to research.prototype. Business justification: Needed to associate shipped items with the specific prototype they contain, enabling prototype test result traceability in the Prototype Test Management process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prototype .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'ERP delivery document number (e.g., SAP outbound delivery number) associated with this shipment line. Serves as the primary cross-reference between the logistics execution system and the financial/order management system.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the product, used for customs clearance, import duty calculation, and international trade compliance. Typically 6-10 digits per WCO HS nomenclature.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Indicates whether this item contains a controlled substance subject to DEA scheduling, FDA drug regulations, or equivalent international narcotics controls. Triggers enhanced chain-of-custody documentation requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Sensitive' ;
    rdfs:comment 'Indicates whether this item requires temperature-controlled handling and transport (cold chain). When true, temperature range requirements and cold-chain compliance monitoring are enforced throughout the shipment lifecycle.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product being shipped, including product name, variant, and pack size. Used on shipping documents, proof of delivery, and freight audit records.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of this shipment line item. Tracks progression from warehouse picking through delivery confirmation. [ENUM-REF-CANDIDATE: planned|picked|loaded|in_transit|delivered|short_shipped|cancelled — promote to reference product]' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total declared value of this shipment line item (shipped_quantity × unit_cost), used for customs valuation, cargo insurance, and financial reporting. Expressed in the shipment currency.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Exceedances trigger quality holds and non-conformance reporting.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Used to configure cold-chain monitoring alerts and carrier SLA requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging unit in which the item is shipped. Determines handling requirements, stacking rules, and warehouse slotting. Aligns with GS1 packaging hierarchy levels.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether this shipment line item has been placed on a quality hold due to a failed QC inspection, temperature exceedance, or regulatory non-conformance. Items on hold must not be delivered until released by QA.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Product registration or regulatory approval number required for cross-border shipments of regulated consumer goods (e.g., FDA registration, EPA registration, EU REACH authorization). Stored for customs and import compliance documentation.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderLine rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line' ;
    rdfs:comment 'Line item number within the originating sales order corresponding to this shipment item. Used for precise order-to-shipment reconciliation and partial fulfillment tracking.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Id' ;
    rdfs:comment 'Reference to the logistics node (warehouse, plant, port, cross-dock, or distribution center) at which this leg arrives. Used for route optimization and delivery confirmation.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual elapsed transit time in hours for this leg, calculated from actual departure to actual arrival timestamps. Used for carrier performance benchmarking and OTIF analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide equivalent (CO₂e) emissions in kilograms for this shipment leg, calculated based on transport mode, distance, and cargo weight. Supports sustainability reporting under ISO 14001 and ESG commitments.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number or tracking number for this leg. Used for carrier track-and-trace, freight bill matching, and proof of delivery retrieval.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether this leg crosses an international border and requires customs clearance (True). Triggers customs documentation workflows and compliance checks under applicable trade regulations.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Official customs entry or declaration number assigned by the customs authority for this leg. Required for cross-border shipments and regulatory compliance documentation.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of any departure or arrival delay on this leg (e.g., weather, customs hold, carrier capacity, traffic, mechanical failure). Used for OTIF root-cause analysis and carrier performance management. [ENUM-REF-CANDIDATE: weather|customs_hold|carrier_capacity|traffic|mechanical_failure|port_congestion|documentation — promote to reference product]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Most recent carrier-provided or system-calculated Estimated Time of Arrival (ETA) for this leg. Updated dynamically during transit to reflect real-time conditions. Distinct from planned arrival (static) and actual arrival (confirmed).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isTransshipmentPoint rdf:type rdf:Property ;
    rdfs:label 'Is Transshipment Point' ;
    rdfs:comment 'Indicates whether the destination node of this leg is an intermediate transshipment point (True) rather than the final delivery destination (False). Used to identify relay legs in intermodal routing and cost allocation.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Leg Distance Km' ;
    rdfs:comment 'Total distance in kilometers for this shipment leg from origin node to destination node. Used for freight cost calculation, carbon emissions estimation, and route optimization analytics.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Number' ;
    rdfs:comment 'Sequential integer indicating the order of this leg within the parent shipment (e.g., 1 = first leg, 2 = second leg). Enables reconstruction of the full shipment route in correct order.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this shipment leg, often assigned by the carrier or freight forwarder (e.g., waybill number, booking reference). Used for carrier communication and freight audit.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current lifecycle status of the shipment leg reflecting its operational state. Drives track-and-trace visibility and exception management workflows. [ENUM-REF-CANDIDATE: planned|in_transit|arrived|completed|cancelled|delayed — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled date and time at which the shipment leg is expected to arrive at the destination node. Used for receiving planning, dock scheduling, and OTIF target setting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled date and time at which the shipment leg is planned to depart from the origin node. Used for transportation planning, carrier booking, and On Time In Full (OTIF) baseline measurement.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Hours' ;
    rdfs:comment 'Expected transit duration in hours for this leg as defined in the carrier contract or transportation plan. Used as the baseline for on-time performance measurement and SLA compliance.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Status' ;
    rdfs:comment 'Status of the Proof of Delivery (POD) document for this leg. Tracks whether POD has been received, is pending, or is under dispute. Required for freight audit, accounts payable, and customer dispute resolution.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportServiceType rdf:type rdf:Property ;
    rdfs:label 'Transport Service Type' ;
    rdfs:comment 'Service level classification for this leg (e.g., Full Truckload (FTL), Less-than-Truckload (LTL), parcel, express, standard, bulk). Impacts freight cost calculation and carrier selection logic.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Total cargo volume in cubic meters (CBM) for this leg. Used for volumetric freight rate calculation, container utilization analysis, and load planning optimization.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL of the 3PL provider\'s API endpoint used for real-time track-and-trace, shipment status updates, and capacity queries. Applicable when integration_method is API. Stored securely; used by Consumer Goods integration middleware for automated data exchange.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsResolutionSlaDays rdf:type rdf:Property ;
    rdfs:label 'Claims Resolution Sla Days' ;
    rdfs:comment 'Maximum number of calendar days within which the 3PL provider is contractually obligated to resolve freight damage or loss claims. Used for claims management SLA tracking and financial recovery monitoring.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Email' ;
    rdfs:comment 'Email address of the senior escalation contact (e.g., account manager or operations director) at the 3PL provider. Used when primary contact is unresponsive or for critical SLA breach escalations.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the 3PL provider\'s headquarters is located. Used for sanctions screening, trade compliance, and financial reporting.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationMethod rdf:type rdf:Property ;
    rdfs:label 'Integration Method' ;
    rdfs:comment 'Primary method used for electronic data interchange between Consumer Goods systems and the 3PL provider. EDI: ANSI X12 or EDIFACT message sets; API: REST/SOAP web services; portal: manual web portal entry; email: unstructured email exchange; ftp: file-based batch transfer. Drives integration architecture and operational SLA for data latency.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the 3PL provider across Consumer Goods systems (SAP S/4HANA vendor master, Oracle Cloud Procurement). Used as the business key for cross-system reconciliation and EDI partner identification.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerStatus rdf:type rdf:Property ;
    rdfs:label 'Provider Status' ;
    rdfs:comment 'Current lifecycle status of the 3PL provider relationship. active: fully operational and eligible for shipment assignment; onboarding: in setup/qualification phase; suspended: temporarily blocked (e.g., SLA breach, compliance issue); terminated: contract ended; inactive: not currently engaged.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the logistics provider by operational model. 3PL: outsourced logistics services; 4PL: manages other 3PLs on behalf of Consumer Goods; lead_logistics: single-point orchestrator; freight_broker: arranges carrier capacity; customs_broker: specializes in import/export clearance.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountries rdf:type rdf:Property ;
    rdfs:label 'Service Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing countries where this 3PL is operationally active (e.g., \'USA,CAN,MEX\'). Used for automated lane-to-provider matching, cross-border compliance checks, and network coverage analytics.' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Pipe-delimited list of logistics service categories provided by this 3PL (e.g., transportation|warehousing|customs|last_mile|value_added_services|cold_chain|reverse_logistics). Drives service assignment logic in Blue Yonder WMS and SAP TM. [ENUM-REF-CANDIDATE: transportation|warehousing|customs|last_mile|value_added_services|cold_chain|reverse_logistics|cross_docking|freight_forwarding — promote to reference product]' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportModes rdf:type rdf:Property ;
    rdfs:label 'Transport Modes' ;
    rdfs:comment 'Pipe-delimited list of transport modes the 3PL is certified and operationally capable of managing (e.g., road|rail|ocean|air|intermodal|last_mile). Used for multi-modal shipment planning and carrier/3PL selection in SAP TM and Blue Yonder. [ENUM-REF-CANDIDATE: road|rail|ocean|air|intermodal|last_mile|barge|pipeline — promote to reference product]' ;
    rdfs:domain ind:ThirdPartyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment tracking event record in the silver layer lakehouse. Primary key for the tracking_event data product.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierEventCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Code' ;
    rdfs:comment 'The carrier\'s native status or event code as transmitted via EDI 214/990 or carrier API (e.g., \'X1\', \'D1\', \'AF\', \'OFD\'). Preserves the source system code for carrier-specific reporting and reconciliation against carrier invoices and SLA commitments.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierSlaMet rdf:type rdf:Property ;
    rdfs:label 'Carrier Sla Met' ;
    rdfs:comment 'Indicates whether the carrier met the contracted Service Level Agreement (SLA) milestone at this event (e.g., on-time pickup, on-time delivery). Derived from comparison of event_timestamp against planned_event_timestamp and carrier contract terms. Feeds carrier performance scorecards and SLA penalty/incentive calculations.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'The customs clearance status of the shipment at the time of this tracking event, applicable to cross-border shipments. Indicates whether the shipment has cleared customs, is held for inspection, pending documentation, released after hold, or seized. Critical for international supply chain visibility and compliance.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediInterchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Interchange Control Number' ;
    rdfs:comment 'The unique interchange control number from the EDI envelope (ISA segment) of the source EDI transmission that generated this tracking event. Enables end-to-end EDI message traceability and duplicate detection.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCity rdf:type rdf:Property ;
    rdfs:label 'Event City' ;
    rdfs:comment 'The city where the tracking event occurred, as reported by the carrier or GPS system. Used for geographic visualization of shipment progress and lane-level exception analysis.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCountryCode rdf:type rdf:Property ;
    rdfs:label 'Event Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country where the tracking event occurred (e.g., \'USA\', \'CAN\', \'MEX\'). Required for cross-border shipment tracking and customs compliance reporting.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStateProvince rdf:type rdf:Property ;
    rdfs:label 'Event State Province' ;
    rdfs:comment 'The state or province where the tracking event occurred, using standard postal abbreviations (e.g., \'CA\', \'TX\', \'ON\'). Supports regional performance reporting and regulatory compliance tracking.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Exception Root Cause Code' ;
    rdfs:comment 'Standardized root cause code categorizing the reason for a shipment exception (e.g., \'WEATHER\', \'CARRIER_DELAY\', \'CUSTOMS_HOLD\', \'MECHANICAL_FAILURE\', \'INCORRECT_ADDRESS\', \'REFUSED_BY_CONSIGNEE\', \'DAMAGED_IN_TRANSIT\'). Used for exception trend analysis and carrier performance management. [ENUM-REF-CANDIDATE: WEATHER|CARRIER_DELAY|CUSTOMS_HOLD|MECHANICAL_FAILURE|INCORRECT_ADDRESS|REFUSED_BY_CONSIGNEE|DAMAGED_IN_TRANSIT — promote to reference product]' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'The code identifying the carrier terminal, cross-dock, distribution center, port, or customer facility where the tracking event occurred (e.g., carrier hub code, GLN). Supports facility-level dwell time and throughput analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated monetary value of the financial impact associated with this tracking event exception (e.g., cost of delay, damage claim value, re-delivery cost, expedite surcharge). Used for freight cost variance analysis and carrier chargeback management. Expressed in the currency defined by financial_impact_currency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geofenceZone rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone' ;
    rdfs:comment 'The named geofence zone or virtual boundary that triggered this tracking event (e.g., \'CUSTOMER_DC_INBOUND\', \'CARRIER_TERMINAL_CHICAGO\', \'PORT_OF_LA_GATE\'). Populated for GPS telematics events generated by geofence entry/exit triggers. Supports automated milestone detection without manual carrier check-ins.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Event Timestamp' ;
    rdfs:comment 'The originally scheduled or planned date and time for this event milestone (e.g., planned pickup time, planned delivery window). Compared against event_timestamp to calculate schedule adherence and On-Time In-Full (OTIF) performance at the event level.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podSignatureName rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Name' ;
    rdfs:comment 'The name of the individual who signed for the delivery at the consignee location, as captured on the Proof of Delivery (POD) document. Populated only for \'delivered\' event types. Supports dispute resolution and delivery confirmation.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Code' ;
    rdfs:comment 'Standardized code identifying the corrective action taken to resolve the exception associated with this tracking event (e.g., \'REROUTED\', \'REDELIVERY_SCHEDULED\', \'CLAIM_FILED\', \'PRODUCT_QUARANTINED\', \'CARRIER_NOTIFIED\', \'EXPEDITED\'). Supports exception resolution tracking and SLA compliance measurement. [ENUM-REF-CANDIDATE: REROUTED|REDELIVERY_SCHEDULED|CLAIM_FILED|PRODUCT_QUARANTINED|CARRIER_NOTIFIED|EXPEDITED — promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLegNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Number' ;
    rdfs:comment 'Sequential leg number within a multi-leg shipment (e.g., leg 1 = origin DC to cross-dock, leg 2 = cross-dock to destination). Enables granular tracking of multi-modal or relay shipments across the inbound and outbound network.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'The speed of the transport vehicle in kilometers per hour at the time of the GPS telematics event. Used for route compliance monitoring, driver safety analytics, and detection of unauthorized stops or route deviations. Null for non-GPS-sourced events.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureBreach rdf:type rdf:Property ;
    rdfs:label 'Temperature Breach' ;
    rdfs:comment 'Indicates whether the temperature reading at this event exceeded the shipment\'s defined cold-chain temperature range (temperature_min_c to temperature_max_c as defined on the parent shipment). True signals a cold-chain compliance violation requiring exception management and potential product quarantine.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportExceptionId rdf:type rdf:Property ;
    rdfs:label 'Transport Exception Id' ;
    rdfs:comment 'Unique surrogate identifier for each transportation exception or disruption event record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportException .

ind:sourceExceptionId rdf:type rdf:Property ;
    rdfs:label 'Source Exception Id' ;
    rdfs:comment 'Original exception identifier from the source operational system (SAP S/4HANA, Blue Yonder WMS, or carrier EDI). Preserved for data lineage, reconciliation, and cross-system traceability in the Silver Layer.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportException .

ind:carrierNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Notification Timestamp' ;
    rdfs:comment 'Timestamp when the carrier was formally notified of the exception. Populated when carrier_notified_flag is True. Used to measure carrier response time and SLA compliance.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Notified Flag' ;
    rdfs:comment 'Indicates whether the carrier has been formally notified of the exception and required resolution actions. True=carrier notification sent. Tracks communication compliance in carrier management processes.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Amount' ;
    rdfs:comment 'Monetary amount formally claimed against the carrier for the exception event (damage, loss, or delay penalty). May differ from financial_impact_amount if only a portion is recoverable under the carrier contract.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'Carrier-assigned or internal reference number for the freight claim associated with this exception. Used to track claim status in freight audit and payment systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current status of the freight claim filed against the carrier for this exception. not_filed=no claim initiated, filed=claim submitted to carrier, under_review=carrier reviewing, approved=carrier accepted liability, rejected=carrier denied claim, settled=financial settlement completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Breach Flag' ;
    rdfs:comment 'Indicates whether the exception involved a breach of cold-chain temperature requirements. True=temperature excursion or cold-chain protocol violation occurred. Triggers regulatory notification and product disposition review per FDA and GMP requirements.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayDurationHours rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hours' ;
    rdfs:comment 'Estimated or actual duration of the delay in hours caused by the exception. Applicable primarily to delay-type exceptions. Used to calculate OTIF impact and carrier SLA breach severity.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Timestamp when the exception was escalated to management or carrier leadership. Populated only when escalation_flag is True. Used to measure escalation response time.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Exception Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the transportation exception occurred. Used for cross-border exception analysis and regulatory compliance reporting.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionLocation rdf:type rdf:Property ;
    rdfs:label 'Exception Location' ;
    rdfs:comment 'Geographic location (city, facility, port, or GPS coordinate description) where the transportation exception was identified or occurred. Critical for route-level exception analysis and cold-chain compliance investigations.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the transportation exception event. Used in carrier communications, freight audit correspondence, and claims processing. Format: EXC- followed by 10 digits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle state of the transportation exception record. Drives workflow routing and SLA tracking. open=newly identified, in_progress=resolution underway, resolved=corrective action taken, closed=fully closed with no further action, escalated=elevated to management or carrier leadership.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionSubtype rdf:type rdf:Property ;
    rdfs:label 'Exception Subtype' ;
    rdfs:comment 'Secondary classification providing granular detail within the exception type (e.g., \'partial_damage\', \'temperature_excursion\', \'missed_pickup\', \'customs_hold\', \'driver_no_show\', \'equipment_failure\'). [ENUM-REF-CANDIDATE: partial_damage|temperature_excursion|missed_pickup|customs_hold|driver_no_show|equipment_failure|address_error|capacity_constraint — promote to reference product]' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'The principal real-world timestamp when the transportation exception was first identified or occurred. This is the business event time, distinct from the record creation audit timestamp. Used as the primary time dimension for OTIF root-cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Involved Flag' ;
    rdfs:comment 'Indicates whether the exception involved a shipment containing hazardous materials. True=hazmat goods were part of the impacted shipment. Triggers mandatory regulatory incident reporting to EPA, DOT, and OSHA.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Impact Flag' ;
    rdfs:comment 'Indicates whether this exception caused a breach of the On Time In Full (OTIF) delivery commitment for the associated shipment. True=OTIF KPI was negatively impacted; False=exception resolved without OTIF breach. Feeds OTIF root-cause analysis dashboards.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this exception requires formal notification to a regulatory authority (FDA, EPA, CPSC, DOT, etc.). True=regulatory notification must be filed. Driven by hazmat_involved_flag, cold_chain_breach_flag, or product safety classification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Timestamp when the required regulatory notification was submitted to the relevant authority. Populated only when regulatory_notification_required is True. Used for compliance audit trails.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Timestamp when the exception was formally reported into the transportation management system by the carrier, driver, or logistics coordinator. May differ from exception_timestamp if there is a reporting lag.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionActionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Notes' ;
    rdfs:comment 'Free-text description of the specific corrective action taken to resolve the transportation exception. Supplements the resolution_action_code with operational detail for audit and continuous improvement purposes.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the transportation exception as determined during investigation. Used for systemic trend analysis and carrier performance scorecards. Examples: RC001=carrier capacity, RC002=weather event, RC003=customs delay, RC004=equipment breakdown, RC005=incorrect address. [ENUM-REF-CANDIDATE: RC001|RC002|RC003|RC004|RC005|RC006|RC007|RC008 — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business-assessed severity of the exception based on financial impact, customer impact, and regulatory risk. critical=immediate executive escalation required, high=same-day resolution required, medium=resolution within SLA window, low=informational tracking only.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Max C' ;
    rdfs:comment 'Maximum recorded temperature in Celsius during the cold-chain breach event. Populated only when cold_chain_breach_flag is True. Used alongside temperature_excursion_min_c for product disposition and regulatory reporting.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Min C' ;
    rdfs:comment 'Minimum recorded temperature in Celsius during the cold-chain breach event. Populated only when cold_chain_breach_flag is True. Used for product disposition decisions and regulatory reporting.' ;
    rdfs:domain ind:TransportException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBatchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Employee Id' ;
    rdfs:comment 'Reference to the quality assurance personnel who performed final batch release. Links to workforce master data.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line used for this batch. Links to equipment master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version of the bill of materials used for this batch. Ensures traceability of raw material specifications.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Minutes' ;
    rdfs:comment 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during batch production. Used for OEE calculation and maintenance planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Count' ;
    rdfs:comment 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Count' ;
    rdfs:comment 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotGenealogyCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Complete Flag' ;
    rdfs:comment 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Overall equipment effectiveness achieved during batch production. Composite metric of availability, performance, and quality.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Release Flag' ;
    rdfs:comment 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Release Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version of the production routing used for this batch. Documents the manufacturing process steps executed.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of product scrapped during batch production. Used for yield calculation and waste reduction analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Ratio of actual batch size to planned batch size expressed as percentage. Key performance indicator for manufacturing efficiency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverId rdf:type rdf:Property ;
    rdfs:label 'Changeover Id' ;
    rdfs:comment 'Unique identifier for the changeover event. Primary key for the changeover record.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeoverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Changeover Employee Id' ;
    rdfs:comment 'Identifier of the primary operator or technician responsible for executing the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeoverQualityInspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Changeover Quality Inspector Employee Id' ;
    rdfs:comment 'Identifier of the quality assurance inspector who verified and approved the changeover completion and cleaning procedures.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fromSkuId rdf:type rdf:Property ;
    rdfs:label 'From Sku Id' ;
    rdfs:comment 'Identifier of the SKU that was being produced before the changeover.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:toSkuId rdf:type rdf:Property ;
    rdfs:label 'To Sku Id' ;
    rdfs:comment 'Identifier of the SKU that will be produced after the changeover.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'FK to manufacturing.work_center' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from changeover start to completion, calculated from actual start and end timestamps.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the changeover execution was completed and the line was ready for production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverStatus rdf:type rdf:Property ;
    rdfs:label 'Changeover Status' ;
    rdfs:comment 'Current lifecycle status of the changeover event indicating its progress through the execution workflow.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverType rdf:type rdf:Property ;
    rdfs:label 'Changeover Type' ;
    rdfs:comment 'Classification of the changeover based on the nature of the change: flavor (product variant), format (packaging type), size (package size), cleaning (sanitation), material (raw material switch), or color (product color change).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cleaning Verification Timestamp' ;
    rdfs:comment 'Date and time when the GMP cleaning verification was completed and approved by quality assurance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for any delays or extended downtime during the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Description' ;
    rdfs:comment 'Detailed description of the reason for any delays or extended downtime during the changeover execution.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAdjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether mechanical or equipment adjustments were required as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPassYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'First Pass Yield Percentage' ;
    rdfs:comment 'Percentage of production output that met quality standards on the first production run immediately following the changeover, indicating changeover quality effectiveness.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCleaningVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Cleaning Verified Flag' ;
    rdfs:comment 'Indicates whether the required GMP cleaning and sanitation procedures were completed and verified as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:improvementInitiativeCode rdf:type rdf:Property ;
    rdfs:label 'Improvement Initiative Code' ;
    rdfs:comment 'Identifier linking this changeover to a specific continuous improvement initiative or project.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialWasteKg rdf:type rdf:Property ;
    rdfs:label 'Material Waste Kg' ;
    rdfs:comment 'Quantity of raw material or work-in-process material wasted or scrapped during the changeover, measured in kilograms.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Percentage' ;
    rdfs:comment 'Calculated impact of this changeover event on the production lines overall equipment effectiveness for the shift or day, expressed as a percentage.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the changeover was scheduled to be completed according to the production schedule.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the changeover was scheduled to begin according to the production schedule.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the production shift during which the changeover occurred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smedImprovementFlag rdf:type rdf:Property ;
    rdfs:label 'Smed Improvement Flag' ;
    rdfs:comment 'Indicates whether this changeover was part of a SMED continuous improvement initiative or pilot program.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Duration Minutes' ;
    rdfs:comment 'Standard or target duration in minutes for this type of changeover based on engineering standards and historical performance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of operators or technicians involved in executing the changeover.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolingChangeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tooling Change Required Flag' ;
    rdfs:comment 'Indicates whether tooling or die changes were required as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual and standard changeover duration. Positive values indicate the changeover took longer than standard; negative values indicate faster than standard performance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique identifier for the downtime event record. Primary key for the downtime event entity.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDowntimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Downtime Employee Id' ;
    rdfs:comment 'Identifier of the production operator who reported or was present during the downtime event.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Identifier of the production shift during which the downtime event occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:batchHoldRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Hold Required' ;
    rdfs:comment 'Indicates whether production batches affected by this downtime event require quality hold pending investigation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. [ENUM-REF-CANDIDATE: mechanical_failure|electrical_failure|changeover|material_shortage|operator_absence|planned_maintenance|cleaning_sanitation|quality_hold|tooling_issue|system_failure|unplanned_maintenance — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event ended and production resumed. Null if downtime is ongoing.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event began. Captured from MES system or manual entry.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime was planned (scheduled maintenance, changeover) or unplanned (breakdown, shortage).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the downtime event measured in minutes. Calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFailureMode rdf:type rdf:Property ;
    rdfs:label 'Equipment Failure Mode' ;
    rdfs:comment 'Specific failure mode of the equipment that caused the downtime, used for reliability analysis and FMEA.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level of management escalation required or triggered by this downtime event based on duration and impact.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Indicates whether the downtime event and its resolution comply with GMP requirements per ISO 22716.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event is included in OEE availability loss calculations.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Required' ;
    rdfs:comment 'Indicates whether preventive action is required to avoid recurrence of this downtime event.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Estimated number of production units lost due to this downtime event, based on standard production rate.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the downtime event resolution process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department responsible for addressing or preventing this type of downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpEventId rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the GMP compliance event record. Primary key for the gmp_event data product. Entity role: TRANSACTION_HEADER — represents a discrete GMP compliance business event with a clear lifecycle.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Reference to the Corrective and Preventive Action (CAPA) record initiated in response to this GMP event. Nullable when no CAPA has been raised yet or when event severity does not require CAPA. Managed in Veeva Vault Quality module.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Reference to the specific piece of manufacturing equipment involved in or associated with the GMP event. Particularly relevant for equipment_failure and process_parameter_breach event types. Links to equipment master in SAP PM (Plant Maintenance) module.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:primaryGmpDetectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gmp Detected By Employee Id' ;
    rdfs:comment 'Reference to the employee (operator, quality technician, or supervisor) who first detected and reported the GMP event. Links to Workday HCM employee master. Required for GMP accountability and electronic signature audit trail under 21 CFR Part 11.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorEventGmpEventId rdf:type rdf:Property ;
    rdfs:label 'Prior Event Gmp Event Id' ;
    rdfs:comment 'Reference to the previous GMP event of the same type that this event is a recurrence of. Populated only when recurrence_flag is true. Enables recurrence trend analysis and CAPA effectiveness assessment across event lineage.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmpEvent .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of product (in the batch unit of measure) potentially affected by the GMP event. Used for impact assessment, recall scope estimation, and financial exposure calculation. Serves as the QUANTITATIVE_RESULT measurement for this non-monetary transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Uom' ;
    rdfs:comment 'Unit of measure for the affected batch quantity (e.g., KG for kilograms, L for liters, EA for each/units). Aligned with GS1 unit of measure codes and SAP S/4HANA base unit of measure configuration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchDisposition rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Quality disposition decision for the affected batch resulting from the GMP event investigation. released: batch meets quality standards and is approved for distribution. quarantined: batch held pending investigation outcome. rejected: batch fails quality standards and cannot be released. reworked: batch underwent approved rework procedure. destroyed: batch disposed of due to quality failure.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpCode rdf:type rdf:Property ;
    rdfs:label 'Ccp Code' ;
    rdfs:comment 'Identifier of the Critical Control Point (CCP) in the manufacturing process where the GMP event was detected. Applicable for process_parameter_breach and environmental_monitoring_excursion event types. Aligned with HACCP and GMP process control frameworks.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the GMP event was formally closed after all required CAPA actions were completed and verified effective. Nullable for open or in-progress events. Used to calculate event resolution cycle time for quality KPI reporting.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containmentActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Action Timestamp' ;
    rdfs:comment 'Date and time when the immediate containment action was executed following GMP event detection (e.g., line stoppage, batch quarantine). Used to calculate detection-to-containment response time, a key GMP performance metric.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the GMP compliance event was first detected or observed on the shop floor or in the laboratory. This is the principal real-world event time (BUSINESS_EVENT_TIMESTAMP category). Distinct from the record creation timestamp. Critical for regulatory timelines and investigation SLA tracking.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Electronic signature token or hash of the approver who reviewed and closed the GMP event record, as required by FDA 21 CFR Part 11. Captures the meaning of the signature (e.g., \'Reviewed and Approved\'), the signer identity reference, and timestamp encoded in the token. Managed by Veeva Vault e-signature module.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'ISO cleanroom classification zone or EU GMP environmental grade where the GMP event occurred. Relevant for environmental_monitoring_excursion event types. Grade A/B are highest cleanliness requirements; Grade C/D are controlled areas. Used for contamination risk assessment.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the GMP compliance event, including what was observed, where it occurred, and the immediate circumstances. Captured by the detecting operator or quality technician at time of detection. Serves as the QUANTITATIVE_RESULT (qualitative payload) category for non-monetary TRANSACTION_HEADER.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the GMP compliance event, used in regulatory submissions, CAPA tracking, and cross-system references. Format: GMP-{YYYY}-{NNNNNN}. Serves as the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Risk-based severity classification of the GMP event. Critical: potential impact on product safety or patient/consumer harm; requires immediate escalation and regulatory notification. Major: significant departure from GMP requirements with potential quality impact. Minor: low-risk deviation with minimal quality impact. Drives CAPA prioritization and regulatory reporting obligations.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate containment or corrective action taken at the time of GMP event detection to prevent further impact (e.g., line stoppage, batch quarantine, equipment isolation). Distinct from the formal CAPA which addresses root cause prevention.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date by which the root cause investigation must be completed, based on event severity and regulatory SLA requirements. Critical events typically require investigation within 3 business days; major within 10 days; minor within 30 days. Used for overdue investigation tracking.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isProductRecallTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Product Recall Trigger' ;
    rdfs:comment 'Indicates whether this GMP event has been assessed as a potential trigger for a product recall or market withdrawal. True when the event involves a safety risk to consumers that may require removal of product from distribution channels. Activates recall management workflow.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Name or code of the specific manufacturing process step (e.g., mixing, filling, packaging, sterilization, labeling) during which the GMP event was detected. Sourced from Siemens Opcenter MES routing. Used for process-level failure mode analysis.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulatory standard or clause that this GMP event relates to or potentially violates. Examples: \'ISO 22716:2007 Section 10.2\', \'FDA 21 CFR Part 211.113\', \'EU GMP Annex 1\'. Used for regulatory submission mapping and compliance gap analysis.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority was formally notified of this GMP event. Populated only when regulatory_notification_required is true and notification has been submitted. Used for regulatory compliance timeline tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the GMP event based on ICH Q9 risk assessment methodology, combining probability of occurrence, severity of impact, and detectability. Typically scored on a 1-100 scale. Used for risk-based prioritization of investigations and CAPA resources.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Number' ;
    rdfs:comment 'SAP S/4HANA Quality Management (QM) notification number associated with this GMP event. Quality notifications in SAP QM are the operational system of record for defect tracking and corrective actions. Enables reconciliation between the lakehouse and SAP QM.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key for the manufacturing BOM entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:primaryManufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Sku Id' ;
    rdfs:comment 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Identifier for a group of interchangeable components that can substitute for each other in production. Used for supply chain flexibility, multi-sourcing strategies, and material availability optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The reference quantity of the finished good for which the component quantities are defined. Typically 1 unit, 100 units, or 1 batch. All component quantities are expressed per this base quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'The externally-known unique business identifier for this BOM, typically assigned by the PLM or ERP system. Used for cross-system reference and production order material requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM structure. Production BOM is used for standard manufacturing, co-product for joint production scenarios, phantom for intermediate assemblies not stocked, engineering for R&D prototypes, and planning for demand forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective End Date' ;
    rdfs:comment 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective Start Date' ;
    rdfs:comment 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentItemCategory rdf:type rdf:Property ;
    rdfs:label 'Component Item Category' ;
    rdfs:comment 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentItemNumber rdf:type rdf:Property ;
    rdfs:label 'Component Item Number' ;
    rdfs:comment 'Sequential line number for each component within the BOM structure. Defines the order of components for display, reporting, and regulatory ingredient listing (descending order by weight for INCI compliance).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this component is classified as a hazardous material requiring special handling, storage, and disposal per OSHA and EPA regulations. True if hazardous. Triggers safety data sheet requirements and GMP compliance protocols.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciName rdf:type rdf:Property ;
    rdfs:label 'Inci Name' ;
    rdfs:comment 'The standardized INCI name for cosmetic ingredients as required by FDA and EU regulations. Used for product labeling, regulatory submissions, and consumer transparency. Mandatory for personal care and cosmetic products.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Lot Size Requirement' ;
    rdfs:comment 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Certification or standard that this component meets for sustainable sourcing (e.g., FSC for paper, RSPO for palm oil, Fair Trade, Organic). Used for corporate sustainability reporting and consumer transparency initiatives.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the facility was officially commissioned and began production operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwhPerYear rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Year' ;
    rdfs:comment 'Annual energy consumption of the facility measured in kilowatt-hours, used for sustainability reporting and cost management.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Site Number' ;
    rdfs:comment 'EPA facility identifier for environmental compliance tracking and reporting under EPA regulations.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpPlantCode rdf:type rdf:Property ;
    rdfs:label 'Erp Plant Code' ;
    rdfs:comment 'Plant identifier in the SAP S/4HANA ERP system used for integration with MM, PP, SD, and WM modules.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the manufacturing facility or plant site.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Number' ;
    rdfs:comment 'FDA-issued establishment identifier for facilities manufacturing FDA-regulated products (cosmetics, OTC drugs, food). Required for US market distribution.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Date' ;
    rdfs:comment 'Date when the facility received its current GMP certification.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the facility holds current Good Manufacturing Practice certification required for consumer goods production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Expiration Date' ;
    rdfs:comment 'Date when the current GMP certification expires and requires renewal.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22716ComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Iso 22716 Compliance Tier' ;
    rdfs:comment 'Internal classification of the facility\'s compliance level with ISO 22716 cosmetics GMP standards: tier_1 (full compliance), tier_2 (partial compliance), tier_3 (basic compliance), non_compliant.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 9001 Quality Management System certification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent quality or compliance audit conducted at the facility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesSystemIntegrated rdf:type rdf:Property ;
    rdfs:label 'Mes System Integrated' ;
    rdfs:comment 'Indicates whether the facility is integrated with Siemens Opcenter MES for real-time production tracking and shop floor data collection.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next quality or compliance audit at the facility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines within the facility available for manufacturing operations.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Establishment Number' ;
    rdfs:comment 'OSHA establishment identifier for workplace safety reporting and compliance tracking.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Product Category' ;
    rdfs:comment 'Main product category or line manufactured at this facility (e.g., skincare, haircare, household cleaning, personal care).' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily production capacity of the facility measured in finished goods units per day under normal operating conditions.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard operating shift pattern for the facility: single (8 hours), two_shift (16 hours), three_shift (24 hours), continuous (24/7), flexible (variable).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total floor area of the manufacturing facility in square feet, including production, warehouse, and administrative spaces.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Internal sustainability performance rating for the facility based on environmental impact, energy efficiency, waste reduction, and sustainable sourcing practices.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionCubicMetersPerYear rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters Per Year' ;
    rdfs:comment 'Annual water consumption of the facility measured in cubic meters, tracked for environmental compliance and sustainability reporting.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of employees (full-time equivalent) assigned to the manufacturing facility.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique identifier for the OEE measurement record. Primary key for the OEE record entity.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOeeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Oee Employee Id' ;
    rdfs:comment 'Identifier of the supervisor responsible for the production shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Seconds' ;
    rdfs:comment 'Average actual time in seconds to produce one unit during the shift, calculated as Actual Operating Time / Total Units Produced.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOperatingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Operating Time Minutes' ;
    rdfs:comment 'Actual time the production line was operating during the shift in minutes, after subtracting unplanned downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'Percentage of planned production time that the line was actually operating, calculated as (Planned Production Time - Downtime) / Planned Production Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverCount rdf:type rdf:Property ;
    rdfs:label 'Changeover Count' ;
    rdfs:comment 'Number of product or format changeovers performed during the shift. Impacts availability and performance metrics.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Total time spent on changeovers during the shift in minutes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method by which OEE data was captured (automated from sensors, manual entry, or semi-automated).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Good Units Produced' ;
    rdfs:comment 'Count of units that passed quality inspection and met specifications, calculated as Total Units Produced - Total Units Rejected.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idealCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Ideal Cycle Time Seconds' ;
    rdfs:comment 'Theoretical minimum time in seconds to produce one unit at maximum design speed under optimal conditions.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesDataSource rdf:type rdf:Property ;
    rdfs:label 'Mes Data Source' ;
    rdfs:comment 'Source system identifier for the OEE data, typically Siemens Opcenter MES or equivalent system.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microStopCount rdf:type rdf:Property ;
    rdfs:label 'Micro Stop Count' ;
    rdfs:comment 'Number of brief stoppages (typically under 5 minutes) that impact performance but may not be classified as downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeStatus rdf:type rdf:Property ;
    rdfs:label 'Oee Status' ;
    rdfs:comment 'Current lifecycle status of the OEE record indicating validation and approval state.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators assigned to the production line during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceRate rdf:type rdf:Property ;
    rdfs:label 'Performance Rate' ;
    rdfs:comment 'Percentage of ideal production speed achieved, calculated as (Ideal Cycle Time × Total Units Produced) / Actual Operating Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total scheduled production time for the shift in minutes, excluding planned downtime such as breaks and scheduled maintenance.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Quality Loss Minutes' ;
    rdfs:comment 'Time equivalent of production lost due to quality defects and rework in minutes.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'Percentage of good units produced without defects, calculated as (Total Units Produced - Total Units Rejected) / Total Units Produced. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkUnits rdf:type rdf:Property ;
    rdfs:label 'Rework Units' ;
    rdfs:comment 'Count of units that required rework or reprocessing to meet quality standards during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapWeightKg rdf:type rdf:Property ;
    rdfs:label 'Scrap Weight Kg' ;
    rdfs:comment 'Total weight of scrap material generated during the shift in kilograms.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date on which the production shift occurred. Principal business event timestamp for OEE measurement.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Descriptive name of the production shift (e.g., day, evening, night).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Sequential shift identifier within the shift date (e.g., 1 for first shift, 2 for second shift, 3 for third shift).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Speed Loss Minutes' ;
    rdfs:comment 'Time lost due to production running below ideal cycle time in minutes, representing performance inefficiency.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Total Units Produced' ;
    rdfs:comment 'Total count of units produced during the shift, including both good units and rejected units.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsRejected rdf:type rdf:Property ;
    rdfs:label 'Total Units Rejected' ;
    rdfs:comment 'Total count of units rejected due to quality defects during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unplannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Unplanned Stop Count' ;
    rdfs:comment 'Number of unplanned production stoppages during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Production Order Id' ;
    rdfs:comment 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:tradePromotionId rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Id' ;
    rdfs:comment 'Foreign key linking to promotion.trade_promotion. Business justification: Planned Promotional Production aligns MRP planned orders with upcoming trade promotions to ensure supply availability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePromotion .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceReference rdf:type rdf:Property ;
    rdfs:label 'Demand Source Reference' ;
    rdfs:comment 'Reference number or identifier of the originating demand document (sales order number, forecast ID, transfer request number, etc.).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the MRP exception condition requiring planner attention.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'The date when this planned order was firmed by a planner. Null if not yet firmed.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this planned order is firmed (locked from automatic MRP changes). True = firmed, False = subject to MRP rescheduling.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Ibp Plan Version' ;
    rdfs:comment 'Version identifier from SAP IBP system that generated the demand signal driving this planned order. Format: IBP-YYYYMM.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'Code indicating the lot-sizing procedure used: EX (exact lot size), HB (lot-for-lot), FX (fixed lot size), PD (periodic lot size), WM (weekly lot size).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Code identifying the MRP controller or planning group responsible for this material and plant combination.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Code' ;
    rdfs:comment 'Reference to the specific MRP run that generated or last modified this planned order. Links to MRP execution history.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning time bucket this order belongs to, expressed as YYYY-Wnn (week), YYYY-Mnn (month), or YYYY-Qn (quarter). Used for MPS and S&OP alignment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStrategyGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy Group' ;
    rdfs:comment 'Two-digit code defining the planning strategy (e.g., 10 = make-to-stock, 20 = make-to-order, 40 = planning with final assembly, 50 = planning without final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether this planned order is for in-house production (IN_HOUSE), external procurement (EXTERNAL), or can be either (BOTH).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Identifies the specific combination of BOM (Bill of Materials) and routing to be used for production. Links to production master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the MPS schedule that generated or governs this planned order. Enables tracking of schedule changes over time.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'The planned date when production or procurement activities for this order should be completed and goods available.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date when production or procurement activities for this order should begin.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopCycleReference rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Reference' ;
    rdfs:comment 'Reference to the S&OP planning cycle that this planned order aligns with. Format: SOP-YYYY-Mnn or SOP-YYYY-Qn.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter record. Primary key for in-process control and critical process parameter measurements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Reference to the product specification or process specification document that defines the control limits for this parameter.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured value of the process parameter recorded during manufacturing operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date when the measuring instrument or sensor is next due for calibration. Ensures measurement validity per GMP requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Boolean indicator whether the measurement result requires corrective action or investigation (True = action required, False = no action needed).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'Calculated percentage deviation of the actual value from the target value. Used for trend analysis and process capability assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower acceptable boundary for the parameter value. Values below this threshold trigger out-of-specification alerts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to capture the parameter measurement: manual entry by operator, automated sensor reading, inline PAT sensor, or laboratory analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The date and time when the parameter measurement was taken during the manufacturing process. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the process parameter being measured (e.g., temperature, pH, viscosity, fill weight, torque, pressure, mixing speed, dwell time).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Classification of the parameter: CPP (Critical Process Parameter), CQA (Critical Quality Attribute), IPC (In-Process Control), PAT (Process Analytical Technology).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'The manufacturing process stage or operation step during which the parameter was measured (e.g., mixing, heating, filling, cooling, packaging).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier of the specific production line within the work center where the parameter was measured. Enables line-level performance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean indicator whether this parameter measurement must be included in regulatory submissions or audit documentation (True = reportable, False = internal only).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Identifier of the physical sample taken for measurement, if applicable. Links to laboratory information management system (LIMS).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Identifier of the specific sensor or probe that captured the measurement, if applicable. Used for sensor calibration tracking.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target or setpoint value for the process parameter as defined in the batch master recipe or process specification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper acceptable boundary for the parameter value. Values above this threshold trigger out-of-specification alerts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the parameter measurement verification by quality assurance: pending review, verified as acceptable, rejected, or under investigation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the parameter measurement was verified by quality assurance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Identifier of the quality assurance personnel who verified or approved the parameter measurement record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Code identifying the manufacturing work center or production line where the parameter was measured. Aligns with SAP PP work center master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Reference to the shop floor operator or employee who executed and confirmed this manufacturing operation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Confirmation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedScrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Scrap Quantity' ;
    rdfs:comment 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Yield Quantity' ;
    rdfs:comment 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction reference from the Siemens Opcenter MES system that originated this confirmation. Used for traceability and system reconciliation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Sequential operation identifier within the production order routing. Typically a 4-digit numeric code representing the step in the manufacturing process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned completion date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyCertificateId rdf:type rdf:Property ;
    rdfs:label 'Energy Certificate Id' ;
    rdfs:comment 'Foreign key linking to sustainability.energy_certificate. Business justification: Energy certificates certify renewable energy for a line; linking enables line-level energy compliance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyCertificate .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Line supervisor drives OEE, quality and shift planning; plant experts expect a dedicated supervisor link per line.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allergenHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Flag' ;
    rdfs:comment 'Indicates whether this production line handles products containing allergens. Critical for cross-contamination prevention and regulatory compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of allergen types handled on this line (e.g., nuts, dairy, gluten). Used for allergen management and cleaning validation protocols.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag number assigned to the production line for asset management and tracking purposes. Links to the fixed asset register in the ERP system.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation on the production line. Indicates the level of human intervention required and impacts labor planning and quality consistency.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Standard Minutes' ;
    rdfs:comment 'Standard time in minutes required to change over the production line from one product or batch to another. Used for production scheduling and OEE loss calculation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationProtocol rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Protocol' ;
    rdfs:comment 'Reference to the cleaning validation protocol document applicable to this production line. Ensures GMP compliance and prevents cross-contamination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Crew Size Standard' ;
    rdfs:comment 'Standard number of operators required to run the production line at full capacity. Used for labor planning and cost allocation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designSpeedUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Speed Units Per Hour' ;
    rdfs:comment 'Theoretical maximum production capacity of the line measured in units per hour under ideal conditions. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption per unit produced on this line, measured in kilowatt-hours. Key metric for sustainability reporting and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalControlRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Control Required' ;
    rdfs:comment 'Indicates whether the production line requires controlled environmental conditions such as temperature, humidity, or air quality. Critical for GMP compliance and product quality.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP classification level of the production line indicating the quality and cleanliness standards required for products manufactured on this line. Critical for regulatory compliance and product safety.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRangePercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Range Percent' ;
    rdfs:comment 'Acceptable relative humidity range for the production line as a percentage. Format: min-max (e.g., 40-60). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedPowerKw rdf:type rdf:Property ;
    rdfs:label 'Installed Power Kw' ;
    rdfs:comment 'Total installed electrical power capacity of the production line in kilowatts. Used for energy consumption tracking and sustainability reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or refurbishment of the production line. Used for maintenance planning and asset condition assessment.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the production line. Unique within the facility and used for operational reference in MES systems and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line in meters. Used for facility layout planning and material flow analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name of the production line. Used for display in dashboards, reports, and operator interfaces.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the production line based on its primary manufacturing function. Determines the type of operations and products that can be processed on this line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average time in hours between equipment failures on this production line. Key reliability metric used for maintenance optimization and capacity planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time in hours required to repair and restore the production line to operational status after a failure. Used for downtime analysis and maintenance resource planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesAssetTag rdf:type rdf:Property ;
    rdfs:label 'Mes Asset Tag' ;
    rdfs:comment 'Unique asset identifier for this production line in the Siemens Opcenter MES system. Used for real-time data collection, production tracking, and integration with shop floor systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity for this production line. Used for maintenance scheduling and production planning coordination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominalOeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Nominal Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this production line. OEE is calculated as Availability × Performance × Quality and represents the benchmark for line performance evaluation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcSystemType rdf:type rdf:Property ;
    rdfs:label 'Plc System Type' ;
    rdfs:comment 'Type and model of the PLC system controlling the production line. Used for technical support, integration planning, and system upgrade management.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryCapability rdf:type rdf:Property ;
    rdfs:label 'Product Category Capability' ;
    rdfs:comment 'Comma-separated list of product categories that can be manufactured on this line. Used for production planning and product-line matching in scheduling systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Frequency' ;
    rdfs:comment 'Standard frequency for quality control inspections on this production line. Defines the QC sampling plan and compliance with GMP requirements.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Source system from which this production line record originated (e.g., SAP S/4HANA PP, Siemens Opcenter MES). Used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Enabled' ;
    rdfs:comment 'Indicates whether the production line is integrated with the SCADA system for real-time monitoring and control. Enables remote visibility and data collection.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Rate Target Percent' ;
    rdfs:comment 'Target scrap rate percentage for this production line. Used for quality performance benchmarking and waste reduction initiatives.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Acceptable operating temperature range for the production line in Celsius. Format: min-max (e.g., 18-25). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Production orders trigger an inspection plan; linking allows the order execution system to retrieve the exact inspection plan governing sampling and testing for that batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costObject rdf:type rdf:Property ;
    rdfs:label 'Cost Object' ;
    rdfs:comment 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number created for quality control of the production output. Links to QM inspection results.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Planned quantity to be produced in base unit of measure. Target output for the production order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionSupervisor rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor' ;
    rdfs:comment 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID of the person who released the production order for execution. Audit trail for production authorization.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Routing or recipe number defining the sequence of operations for production. Links to work center and operation master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person who created this routing record. Supports audit trail and data lineage.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Employee Id' ;
    rdfs:comment 'User identifier of the person who approved this routing for production use. Supports audit trail and compliance requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:routingLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Routing Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this routing record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard cost amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedScrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Scrap Percentage' ;
    rdfs:comment 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Ipc Checkpoint Count' ;
    rdfs:comment 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeRestriction rdf:type rdf:Property ;
    rdfs:label 'Lot Size Restriction' ;
    rdfs:comment 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSchedulerCode rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Code' ;
    rdfs:comment 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed textual description of the routing, including its purpose, scope, and any special instructions for production planners and shop floor operators.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center after accounting for planned downtime, breaks, and maintenance windows.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the rated capacity indicating how production output is quantified for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanRoomClass rdf:type rdf:Property ;
    rdfs:label 'Clean Room Class' ;
    rdfs:comment 'ISO 14644 clean room classification for work centers in controlled environments, critical for cosmetics and personal care product manufacturing per GMP requirements. [ENUM-REF-CANDIDATE: iso_3|iso_4|iso_5|iso_6|iso_7|iso_8|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Standard number of operators required to run this work center during normal production operations, used for labor planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the work center was retired from production service, supporting asset lifecycle tracking and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwhPerHour rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Hour' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours per operating hour, supporting sustainability reporting and cost allocation per ISO 14001 environmental management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Qualification Status' ;
    rdfs:comment 'Current qualification status of the work center per GMP requirements. IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification) track equipment validation stages per ISO 22716.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Area Classification' ;
    rdfs:comment 'Electrical area classification for work centers handling flammable or explosive materials, ensuring compliance with Occupational Safety and Health Administration (OSHA) and ATEX directives. [ENUM-REF-CANDIDATE: non_hazardous|class_1_div_1|class_1_div_2|class_2_div_1|class_2_div_2|atex_zone_0|atex_zone_1|atex_zone_2 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled Flag' ;
    rdfs:comment 'Indicates whether this work center operates in a humidity-controlled environment requiring environmental monitoring per GMP standards.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration performed on this work center, supporting traceability and compliance documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceClass rdf:type rdf:Property ;
    rdfs:label 'Maintenance Class' ;
    rdfs:comment 'Classification of the work center by maintenance priority and frequency requirements, driving preventive maintenance scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Maintenance approach applied to this work center defining how maintenance activities are planned and executed.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Mes Equipment Code' ;
    rdfs:comment 'Unique equipment identifier in the Siemens Opcenter MES system enabling real-time production tracking and shop floor data collection.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorSkillLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Operator Skill Level Required' ;
    rdfs:comment 'Minimum operator skill level required to operate this work center safely and effectively, supporting workforce planning and training requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the work center achieved its current GMP qualification status, establishing the baseline for requalification scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'Maximum production capacity of the work center expressed in units per time period, used for Material Requirements Planning (MRP) capacity calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which the work center must undergo requalification to maintain GMP compliance and production authorization.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Safety certifications held by this work center such as CE marking, UL listing, or other regulatory approvals required for operation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to prepare the work center for production, including changeover and configuration activities.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to complete one production cycle or unit at this work center, used for scheduling and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean, sanitize, and reset the work center after production completion per Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Target utilization rate as a percentage of available capacity, used for capacity planning and Overall Equipment Effectiveness (OEE) benchmarking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'High-level category grouping work centers by operational domain for capacity planning and resource allocation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed description of the work center including its purpose, capabilities, and operational characteristics.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center for identification and reporting purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center indicating availability for production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center by its primary function in the manufacturing process. Categorizes equipment by operational role.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Unique identifier for the yield tracking record. Primary key for the yield record entity.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryYieldEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Yield Employee Id' ;
    rdfs:comment 'Reference to the production operator or technician who recorded the yield measurement. Links to workforce master data for training and performance tracking.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryYieldLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Yield Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that last modified this yield record. Audit trail for data governance and regulatory compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percentage' ;
    rdfs:comment 'Actual yield percentage achieved calculated as (output_quantity / input_quantity) * 100. Key Performance Indicator (KPI) for manufacturing efficiency.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Record Status' ;
    rdfs:comment 'Current lifecycle status of the batch record documentation. Tracks progression through Good Manufacturing Practice (GMP) review and approval workflow.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Document number in the Enterprise Resource Planning (ERP) system (SAP S/4HANA) that records the goods movement associated with this yield. Links to material document for inventory reconciliation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'Total quantity of raw materials or semi-finished goods consumed as input for this operation. Used to calculate theoretical yield and material consumption variance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation completed. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation began. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'Total quantity of finished or semi-finished goods produced as output from this operation. Represents the good production yield before scrap and rework.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Specific production line identifier within the plant. Enables line-level yield analysis and capacity planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'Quality Control (QC) inspection lot number associated with this yield record. Links yield data to quality inspection results for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Number' ;
    rdfs:comment 'Specific operation sequence number within the production routing where yield is measured. Identifies the manufacturing step in the Bill of Materials (BOM) routing.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Per Unit' ;
    rdfs:comment 'Standard cost per unit of output based on Bill of Materials (BOM) and routing. Used to calculate yield variance impact on Cost of Goods Sold (COGS).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Percentage' ;
    rdfs:comment 'Expected yield percentage based on Bill of Materials (BOM) specifications and standard operating procedures. Baseline for variance analysis.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of yield variance. Used for Pareto analysis and continuous improvement initiatives. Examples: EQUIP_FAIL, MAT_DEFECT, PROC_ERROR, QUAL_REJECT.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldLossReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Description' ;
    rdfs:comment 'Detailed description of the yield loss root cause. Provides context for quality investigations and corrective action planning.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldVarianceCostImpact rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Cost Impact' ;
    rdfs:comment 'Financial impact of yield variance calculated as (theoretical_yield - actual_yield) * standard_cost_per_unit. Feeds into Cost of Goods Sold (COGS) variance reporting.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Percentage' ;
    rdfs:comment 'Variance between actual and theoretical yield expressed as percentage. Calculated as (actual_yield_percentage - theoretical_yield_percentage). Negative values indicate yield loss.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'Unique identifier for the marketing agency partner. Primary key for the agency master record.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the agency\'s primary business address (suite, floor, building name). Nullable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Internal short code or identifier used to reference the agency in operational systems and reporting.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Legal or trade name of the marketing agency partner.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Primary classification of the agency based on core service offering: creative (brand and campaign creative development), media (media planning and buying), digital (digital marketing and social media), pr (public relations and communications), shopper (shopper marketing and retail execution), research (market research and consumer insights).' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRetainerAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Retainer Amount' ;
    rdfs:comment 'Total annual retainer fee amount committed under the current contract. Null if engagement is project-based only.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedBrands rdf:type rdf:Property ;
    rdfs:label 'Assigned Brands' ;
    rdfs:comment 'Comma-separated list of Consumer Goods brand names or brand identifiers that this agency is contracted to support.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementModel rdf:type rdf:Property ;
    rdfs:label 'Engagement Model' ;
    rdfs:comment 'Basis of the commercial relationship: retainer (ongoing monthly/annual fee), project (discrete project-based fees), hybrid (combination of retainer and project fees), performance (fee tied to performance metrics).' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Description of the agency\'s fee arrangement, including rate type (hourly, monthly retainer, project-based, commission percentage, performance-based) and any tiered or volume-based pricing.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingGroup rdf:type rdf:Property ;
    rdfs:label 'Holding Group' ;
    rdfs:comment 'Name of the parent holding company or network to which the agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if the agency is independent.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this agency record is currently active and available for assignment to campaigns and projects. False indicates the agency relationship has been terminated or is inactive.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinorityOwned rdf:type rdf:Property ;
    rdfs:label 'Is Minority Owned' ;
    rdfs:comment 'Indicates whether the agency is certified as a minority-owned business enterprise (MBE) for supplier diversity tracking and reporting.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredVendor rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Vendor' ;
    rdfs:comment 'Indicates whether the agency is designated as a preferred or strategic vendor with priority consideration for new projects and campaigns.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWomanOwned rdf:type rdf:Property ;
    rdfs:label 'Is Woman Owned' ;
    rdfs:comment 'Indicates whether the agency is certified as a woman-owned business enterprise (WBE) for supplier diversity tracking and reporting.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketsServed rdf:type rdf:Property ;
    rdfs:label 'Markets Served' ;
    rdfs:comment 'Comma-separated list of geographic markets or regions where the agency provides services to Consumer Goods (e.g., North America, EMEA, APAC, LATAM, or specific country codes).' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating assigned to the agency based on quality of work, timeliness, collaboration, and business impact. Used for agency benchmarking and roster optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the services provided by the agency under the current engagement (e.g., brand strategy, creative production, media planning, digital campaign execution, influencer management, market research).' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the agency relationship was formally terminated or the agency was removed from the active roster. Null if the agency is still active.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attributionId rdf:type rdf:Property ;
    rdfs:label 'Attribution Id' ;
    rdfs:comment 'Primary key for attribution' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Attribution models are maintained by an analyst; linking provides accountability and traceability for model changes.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Identifier of the creative asset (ad, banner, video) shown at this touchpoint.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Identifier of the product purchased or converted in the attributed event.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:attributedConversions rdf:type rdf:Property ;
    rdfs:label 'Attributed Conversions' ;
    rdfs:comment 'Fractional conversion count credited to this touchpoint (e.g., 0.25 conversions for 25% attribution weight).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'Revenue amount credited to this touchpoint based on the attribution weight.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Status of the attribution record (final, provisional, recalculated, voided).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when the attribution calculation was performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionEventCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Code' ;
    rdfs:comment 'Identifier of the conversion event (purchase, sign-up, download) being attributed.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the conversion event occurred.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Type of conversion event being attributed (purchase, add-to-cart, sign-up, download, lead, subscription, trial, engagement). [ENUM-REF-CANDIDATE: purchase|add_to_cart|sign_up|download|lead|subscription|trial|engagement — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpa rdf:type rdf:Property ;
    rdfs:label 'Cpa' ;
    rdfs:comment 'Cost per acquisition for this attributed touchpoint (media spend attributed / attributed conversions).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'Three-letter country code where the conversion occurred.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDirectConversion rdf:type rdf:Property ;
    rdfs:label 'Is Direct Conversion' ;
    rdfs:comment 'Flag indicating whether this was a direct conversion with no prior touchpoints (True/False).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isViewThrough rdf:type rdf:Property ;
    rdfs:label 'Is View Through' ;
    rdfs:comment 'Flag indicating whether this touchpoint was a view-through impression (ad viewed but not clicked) (True/False).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lookbackWindowDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Days' ;
    rdfs:comment 'Number of days in the attribution lookback window used to identify contributing touchpoints.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaSpendAttributedAmount rdf:type rdf:Property ;
    rdfs:label 'Media Spend Attributed Amount' ;
    rdfs:comment 'Portion of media spend allocated to this touchpoint based on attribution weight.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Type of attribution model applied to assign credit (last-touch, first-touch, linear, time-decay, position-based, data-driven MTA).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Digital platform or publisher where the touchpoint occurred (Google Ads, Facebook, Instagram, YouTube, etc.).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on Ad Spend calculated for this attributed touchpoint (attributed revenue / media spend attributed).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'Number of hours elapsed between this touchpoint and the final conversion event.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTouchpoints rdf:type rdf:Property ;
    rdfs:label 'Total Touchpoints' ;
    rdfs:comment 'Total number of marketing touchpoints in the consumer journey leading to this conversion.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Number' ;
    rdfs:comment 'Position of this touchpoint in the consumer journey sequence (1 = first touch, N = last touch).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Date and time when this specific marketing touchpoint occurred.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Fractional credit assigned to this touchpoint by the attribution model (0.0000 to 1.0000, sum across all touchpoints = 1.0).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the parent brand in the brand hierarchy. Null for masterbrand level. Used to establish brand family relationships and roll-up reporting.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Brand Supplier Management: each brand designates a primary supplier for sourcing, required for supplier performance and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:annualMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget' ;
    rdfs:comment 'Total allocated marketing investment for the brand for the fiscal year, including media spend, trade promotion, consumer promotion, and agency fees.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Planned annual revenue goal for the brand in the base currency. Used for budget planning, performance tracking, and brand portfolio prioritization.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectureTier rdf:type rdf:Property ;
    rdfs:label 'Architecture Tier' ;
    rdfs:comment 'Classification of the brand within the corporate brand architecture hierarchy. Masterbrand represents the corporate umbrella, subbrand is a distinct offering under the masterbrand, endorsed carries both corporate and product brand, ingredient brand is a component brand, private label is retailer-owned, and house brand is a proprietary store brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Awareness Percent' ;
    rdfs:comment 'Percentage of target consumers who recognize or recall the brand when prompted or unprompted. Measured through consumer surveys and market research panels.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary product category or market segment in which the brand competes. Examples include personal care, household cleaning, health and wellness, beauty, food and beverage.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative describing the brand\'s purpose, value proposition, and positioning in the market. Used for internal reference and marketing brief development.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Operational status of the brand. Active indicates current market presence with ongoing marketing investment, inactive is temporarily paused, pending launch is approved but not yet in market, under review is strategic assessment phase, sunset is planned phase-out, and archived is historical record only.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:considerationPercent rdf:type rdf:Property ;
    rdfs:label 'Consideration Percent' ;
    rdfs:comment 'Percentage of target consumers who would consider purchasing the brand when making a category purchase decision. Key indicator of brand relevance and competitive positioning.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the brand was officially discontinued or withdrawn from active marketing. Null for active brands. Used for portfolio rationalization reporting and historical analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Composite metric measuring the overall strength and value of the brand based on consumer awareness, perceived quality, brand associations, and loyalty. Typically scaled 0-100 with higher scores indicating stronger brand equity.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarketScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Scope' ;
    rdfs:comment 'Geographic reach of the brand\'s distribution and marketing activities. Global indicates worldwide presence, regional covers multiple countries in a region, national is single-country, and local is sub-national markets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Guidelines Url' ;
    rdfs:comment 'URL or file path to the comprehensive brand guidelines document containing logo usage, color specifications, typography, tone of voice, and visual identity standards.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensedBrand rdf:type rdf:Property ;
    rdfs:label 'Is Licensed Brand' ;
    rdfs:comment 'Boolean flag indicating whether the brand is operated under a licensing agreement from another entity. True indicates licensed brand, false indicates owned brand.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Boolean flag indicating whether the brand is a private label or store brand owned by a retail customer rather than the manufacturer. True indicates private label, false indicates manufacturer-owned brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the brand was first introduced to the market. Used for brand age calculations, anniversary campaigns, and lifecycle analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the brand in its market lifecycle. Development indicates pre-launch planning, launch is initial market introduction, growth is rapid expansion phase, maturity is stable market presence, decline is decreasing market share, revitalization is strategic renewal effort, and discontinued indicates end of active marketing. [ENUM-REF-CANDIDATE: development|launch|growth|maturity|decline|revitalization|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL or file path to the official brand logo asset in the digital asset management system. Used for marketing materials, packaging design, and digital campaigns.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the intellectual property rights to the brand. May differ from the manufacturing or distribution entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Concise statement defining the brand\'s unique value proposition, competitive differentiation, and emotional benefit to the target consumer. Foundation for all marketing communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferencePercent rdf:type rdf:Property ;
    rdfs:label 'Preference Percent' ;
    rdfs:comment 'Percentage of target consumers who prefer this brand over competitive alternatives. Indicates brand loyalty and pricing power potential.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the primary brand color used in packaging, marketing materials, and digital assets. Ensures consistent brand identity across touchpoints.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Channel' ;
    rdfs:comment 'Main channel through which the brand reaches consumers. Examples include mass retail, specialty retail, e-commerce, DTC (Direct to Consumer), professional/salon, or foodservice.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somPercent rdf:type rdf:Property ;
    rdfs:label 'Som Percent' ;
    rdfs:comment 'Brand\'s percentage of total category sales volume or value. Primary metric for competitive market position and growth tracking.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovPercent rdf:type rdf:Property ;
    rdfs:label 'Sov Percent' ;
    rdfs:comment 'Brand\'s share of total advertising and promotional activity within the category, measured across paid media, earned media, and owned channels. Key indicator of marketing investment relative to competitors.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetConsumerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment' ;
    rdfs:comment 'Primary demographic and psychographic profile of the intended consumer audience for the brand. Includes age range, income level, lifestyle attributes, and purchase behaviors.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSomPercent rdf:type rdf:Property ;
    rdfs:label 'Target Som Percent' ;
    rdfs:comment 'Strategic target for the brand\'s market share. Used for annual planning, performance evaluation, and resource allocation decisions.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Strategic target for the brand\'s share of voice in the category. Used for media planning and budget allocation decisions. Typically set to exceed current SOM (Share of Market) to drive growth.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trademarkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Expiration Date' ;
    rdfs:comment 'Date when the current trademark registration expires and requires renewal. Critical for maintaining legal protection of brand assets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Trademark Jurisdiction' ;
    rdfs:comment 'Geographic territories or countries where the brand trademark is registered and legally protected. May include multiple jurisdictions separated by semicolons.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Date' ;
    rdfs:comment 'Date when the trademark was officially registered with the relevant trademark authority. Used for renewal tracking and IP portfolio management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official registration number assigned by the trademark authority for the brand name, logo, or other protected brand elements. Used for legal protection and IP (Intellectual Property) management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Estimated financial value of the brand as an intangible asset. Calculated using income, market, or cost approaches for financial reporting and M&A (Mergers and Acquisitions) purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandHealthTrackerId rdf:type rdf:Property ;
    rdfs:label 'Brand Health Tracker Id' ;
    rdfs:comment 'Unique identifier for the brand health tracking record.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Reference to the product category for which brand health is tracked.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:primaryCompetitorBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the primary competing brand used for benchmarking.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:aidedAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Pct' ;
    rdfs:comment 'Percentage of consumers who recognize the brand when prompted with a list of brands in the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandEquityIndex rdf:type rdf:Property ;
    rdfs:label 'Brand Equity Index' ;
    rdfs:comment 'Composite index score measuring overall brand strength combining awareness, consideration, preference, and loyalty metrics.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Brand Spend Amount' ;
    rdfs:comment 'Total advertising spend for this brand during the measurement period.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorSomValuePct rdf:type rdf:Property ;
    rdfs:label 'Competitor Som Value Pct' ;
    rdfs:comment 'Primary competitor share of market by value for benchmarking purposes.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorSovTotalPct rdf:type rdf:Property ;
    rdfs:label 'Competitor Sov Total Pct' ;
    rdfs:comment 'Primary competitor total share of voice for benchmarking purposes.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationPct rdf:type rdf:Property ;
    rdfs:label 'Consideration Pct' ;
    rdfs:comment 'Percentage of consumers who would consider purchasing the brand.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Perception Score' ;
    rdfs:comment 'Consumer perception score for brand innovation attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'Geographic market where brand health is measured (country, region, or city).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Net Sentiment Score' ;
    rdfs:comment 'Net sentiment score calculated as positive percentage minus negative percentage, ranging from -100 to +100.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferencePct rdf:type rdf:Property ;
    rdfs:label 'Preference Pct' ;
    rdfs:comment 'Percentage of consumers who prefer this brand over competitors in the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Pct' ;
    rdfs:comment 'Percentage of consumers who intend to purchase the brand in the next purchase cycle.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Quality Perception Score' ;
    rdfs:comment 'Consumer perception score for product quality attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareOfConversationPct rdf:type rdf:Property ;
    rdfs:label 'Share Of Conversation Pct' ;
    rdfs:comment 'Brand share of total social media conversation volume within the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMentionVolume rdf:type rdf:Property ;
    rdfs:label 'Social Mention Volume' ;
    rdfs:comment 'Total number of social media mentions for the brand during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialSentimentNegativePct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Negative Pct' ;
    rdfs:comment 'Percentage of social media mentions with negative sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSentimentNeutralPct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Neutral Pct' ;
    rdfs:comment 'Percentage of social media mentions with neutral sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSentimentPositivePct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Positive Pct' ;
    rdfs:comment 'Percentage of social media mentions with positive sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:somValuePct rdf:type rdf:Property ;
    rdfs:label 'Som Value Pct' ;
    rdfs:comment 'Brand share of total category sales measured by value (revenue) for the period and geography.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:somVolumePct rdf:type rdf:Property ;
    rdfs:label 'Som Volume Pct' ;
    rdfs:comment 'Brand share of total category sales measured by volume (units) for the period and geography.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovDigitalPct rdf:type rdf:Property ;
    rdfs:label 'Sov Digital Pct' ;
    rdfs:comment 'Share of voice for digital advertising (display, search, video) as percentage of total category digital spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovOohPct rdf:type rdf:Property ;
    rdfs:label 'Sov Ooh Pct' ;
    rdfs:comment 'Share of voice for out-of-home advertising (billboards, transit, etc.) as percentage of total category OOH spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovSocialPct rdf:type rdf:Property ;
    rdfs:label 'Sov Social Pct' ;
    rdfs:comment 'Share of voice for social media advertising as percentage of total category social spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovTotalPct rdf:type rdf:Property ;
    rdfs:label 'Sov Total Pct' ;
    rdfs:comment 'Total share of voice across all media channels as percentage of total category advertising spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovTvPct rdf:type rdf:Property ;
    rdfs:label 'Sov Tv Pct' ;
    rdfs:comment 'Share of voice for television advertising as percentage of total category TV spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spontaneousAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Spontaneous Awareness Pct' ;
    rdfs:comment 'Percentage of consumers who mention the brand unprompted when asked about the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Perception Score' ;
    rdfs:comment 'Consumer perception score for environmental and social responsibility attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCategorySpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Category Spend Amount' ;
    rdfs:comment 'Total advertising spend across all brands in the category for the measurement period.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Tracking Period End Date' ;
    rdfs:comment 'End date of the brand health measurement period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Tracking Period Start Date' ;
    rdfs:comment 'Start date of the brand health measurement period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Trust Perception Score' ;
    rdfs:comment 'Consumer perception score for brand trust and reliability attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuePerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Value Perception Score' ;
    rdfs:comment 'Consumer perception score for value-for-money attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee or user who approved this campaign for execution. Links to workforce/user master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign planning and ROI attribution need a primary SKU reference to allocate budget and measure lift per product.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Campaigns are owned by a sales rep responsible for execution and alignment with sales activities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Reference to the predefined consumer segment this campaign is designed to reach. Links to consumer segmentation master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date the campaign concluded. May differ from planned end date due to extensions, early termination, or performance-based adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Media Spend Amount' ;
    rdfs:comment 'The actual total media spend incurred for this campaign, in the company\'s reporting currency. Includes all paid media costs across channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Production Cost Amount' ;
    rdfs:comment 'The actual cost incurred for creative production, including all content creation, design, video production, and asset development expenses.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date the campaign went live and began execution. May differ from planned start date due to operational adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Short alphanumeric code used to identify and track the campaign across systems, media buys, and analytics platforms.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign\'s purpose, strategy, key messages, and expected outcomes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'The official name or title of the marketing campaign as used in internal planning and external communications.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (initial planning), planned (scheduled), approved (ready for execution), active (currently running), paused (temporarily suspended), completed (finished), or cancelled (terminated before completion). [ENUM-REF-CANDIDATE: draft|planned|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by execution approach: ATL (Above The Line - mass media), BTL (Below The Line - targeted), digital (online channels), shopper (in-store/retail), influencer (social media partnerships), or integrated (multi-channel).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of marketing channels used in the campaign (e.g., TV, digital display, social media, print, radio, OOH, in-store).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where the campaign is executed (e.g., USA,CAN,MEX).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'High-level description of the creative theme, messaging strategy, and visual identity used in the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic reach of the campaign: global (worldwide), regional (multi-country region), national (single country), or local (city/metro area).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business goal of the campaign: awareness (brand visibility), consideration (product evaluation), conversion (purchase), loyalty (retention), launch (new product introduction), or relaunch (product refresh).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The originally scheduled date for campaign conclusion as defined during planning phase.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Media Spend Amount' ;
    rdfs:comment 'The budgeted total media spend allocated to this campaign during the planning phase, in the company\'s reporting currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Production Cost Amount' ;
    rdfs:comment 'The budgeted cost for creative production, including content creation, design, video production, and asset development.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The originally scheduled date for campaign launch as defined during planning phase.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Textual description of the intended consumer segment for this campaign, including demographic, psychographic, and behavioral characteristics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Flight Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Flight manager (employee) oversees execution; essential for flight performance review and responsibility logs.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'Actual number of impressions delivered during the flight. Core metric for reach and frequency analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution methodology used to assign conversion credit to this flight. Critical for multi-touch attribution analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget allocated to this flight. Represents the planned media spend for this specific flight execution.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent on this flight. Used for budget variance analysis and Return on Ad Spend (ROAS) calculation.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of clicks generated by the flight. Primary engagement metric for digital and search campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Conversion rate expressed as a decimal (conversions divided by clicks or impressions). Measures campaign effectiveness in driving desired actions.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversions rdf:type rdf:Property ;
    rdfs:label 'Conversions' ;
    rdfs:comment 'Total number of conversions attributed to this flight. Conversion definition varies by campaign objective (purchase, sign-up, download, etc.).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Average cost per click for this flight. Key efficiency metric for paid search and digital campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Click-through rate expressed as a decimal (clicks divided by impressions). Key performance indicator for digital campaign effectiveness.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Descriptive name of the campaign flight for business user identification and reporting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Business identifier for the flight within the campaign. Used for external reporting and agency coordination.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current lifecycle status of the campaign flight.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'Gross Rating Points for traditional media (TV, radio, OOH). Measures total audience delivery as a percentage of target population multiplied by frequency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Specific placement or ad format type within the channel (e.g., banner, video, native, sponsored post, display, search text ad). Enables placement-level optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Estimated number of unique individuals exposed to the campaign flight. Used for audience coverage analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date for the flight media run. Defines the flight duration for budget allocation and performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions for this flight. Used for media planning and performance target setting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Percentage of video views that were completed (watched to end). Measures creative engagement quality.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views for video creative flights. Applicable to digital video, social, and TV campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAssetCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Creative Asset Id' ;
    rdfs:comment 'Identifier of the parent creative asset if this asset is a derivative, localized version, or variant of another asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:actualPublishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Date' ;
    rdfs:comment 'Actual date when the creative asset was published or went live.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the creative asset for tracking and reference purposes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the creative asset (e.g., \'Spring Campaign Hero Banner\', \'Product Launch Video 30s\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the creative asset by media type (video, image, audio, document, HTML, social post, email template). [ENUM-REF-CANDIDATE: video|image|audio|document|html|social_post|email_template — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory and legal compliance review for the creative asset (not required, pending, approved, rejected).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Business category or use case of the creative asset (TV commercial, digital banner, social media, print ad, packaging visual, influencer brief, blog post, email content, landing page, infographic). [ENUM-REF-CANDIDATE: tv_commercial|digital_banner|social_media|print_ad|packaging_visual|influencer_brief|blog_post|email_content|landing_page|infographic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Specific file format or content format of the asset (e.g., MP4, JPEG, PNG, PDF, GIF, HTML5).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current publishing lifecycle status of the creative asset (planned, scheduled, published, archived, withdrawn).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAgencyName rdf:type rdf:Property ;
    rdfs:label 'Creative Agency Name' ;
    rdfs:comment 'Name of the external creative agency or partner that produced the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Description' ;
    rdfs:comment 'Detailed textual description of the creative asset content, purpose, and key messaging.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'Unique identifier or reference code in the Digital Asset Management system where the asset is stored.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the creative asset file in bytes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Height dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMasterVersion rdf:type rdf:Property ;
    rdfs:label 'Is Master Version' ;
    rdfs:comment 'Flag indicating whether this is the master or primary version of the creative asset (True) or a derivative/variant (False).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the creative asset for search and discovery purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPublishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Publish Date' ;
    rdfs:comment 'Planned or scheduled date for the creative asset to be published or go live.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'Total cost incurred to produce the creative asset.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishingChannel rdf:type rdf:Property ;
    rdfs:label 'Publishing Channel' ;
    rdfs:comment 'Primary channel or platform where the creative asset is published or distributed (e.g., \'Facebook\', \'Instagram\', \'YouTube\', \'Website\', \'Email\', \'TV\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date when the usage rights or licensing for the creative asset expire.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'Full URL or file path where the creative asset is stored in the DAM or content repository.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Primary target audience or consumer segment for the creative asset (e.g., \'Millennials\', \'Parents with young children\', \'Health-conscious consumers\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL of the thumbnail or preview image for the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Description of usage rights, licensing terms, or restrictions governing how the creative asset may be used (e.g., \'Global rights\', \'North America only\', \'Digital channels only\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number or identifier for the creative asset (e.g., \'v1.0\', \'v2.1\', \'Final\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Width dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Digital Performance Id' ;
    rdfs:comment 'Unique identifier for the digital campaign performance record. Primary key for this transactional performance measurement entity.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The specific creative format of the digital ad (e.g., carousel, single image, video, story, banner, interstitial, native). Describes the presentation style of the creative asset.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'The number of days after ad interaction during which conversions are attributed to this campaign. Defines the lookback period for conversion tracking.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost per thousand impressions (total cost divided by impressions, multiplied by 1000). Standard metric for awareness campaigns.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the ad was displayed to users. Represents the reach volume of the campaign on this date and channel.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this performance record was ingested into the lakehouse from the source platform API. Supports data freshness monitoring and audit trail.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total revenue attributed to conversions from this campaign on this date and channel. Used to calculate ROAS and campaign profitability.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile25Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 25 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 25% completion point. Expressed as a decimal. Tracks early engagement drop-off.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile50Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 50 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 50% completion point (midpoint). Expressed as a decimal. Measures sustained viewer interest.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile75Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 75 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 75% completion point. Expressed as a decimal. Indicates strong creative engagement.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewThroughConversions rdf:type rdf:Property ;
    rdfs:label 'View Through Conversions' ;
    rdfs:comment 'Number of conversions attributed to users who viewed but did not click the ad, then converted within the attribution window. Measures passive ad influence.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryId rdf:type rdf:Property ;
    rdfs:label 'Product Category Id' ;
    rdfs:comment 'Identifier of the product category featured in this event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCategory .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Actual number of attendees who participated in the event.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total planned budget allocated for the event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Unique business identifier or code for the event used for tracking and reporting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Official name of the marketing event (e.g., \'Spring Product Launch 2024\', \'Summer Sampling Tour\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadCount rdf:type rdf:Property ;
    rdfs:label 'Lead Count' ;
    rdfs:comment 'Number of qualified leads or prospects generated from the event.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall assessment of the event outcome relative to objectives and targets.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Registration Required Flag' ;
    rdfs:comment 'Indicates whether attendee registration was required for the event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleUnitsDistributed rdf:type rdf:Property ;
    rdfs:label 'Sample Units Distributed' ;
    rdfs:comment 'Total number of product sample units distributed during the event.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAttendance rdf:type rdf:Property ;
    rdfs:label 'Target Attendance' ;
    rdfs:comment 'Planned or target number of attendees for the event.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical or virtual venue where the event takes place.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueType rdf:type rdf:Property ;
    rdfs:label 'Venue Type' ;
    rdfs:comment 'Classification of the venue or location type for the event.' ;
    rdfs:domain ind:MarketingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Unique identifier for the influencer or content creator partner. Primary key.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentContact rdf:type rdf:Property ;
    rdfs:label 'Agent Contact' ;
    rdfs:comment 'Contact email or phone number for the influencer\'s agent or manager.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Name of the influencer\'s agent, manager, or talent representation, if applicable.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceAgeRange rdf:type rdf:Property ;
    rdfs:label 'Audience Age Range' ;
    rdfs:comment 'Dominant age demographic of the influencer\'s audience, used for campaign targeting and brand alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGenderSplit rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split' ;
    rdfs:comment 'Gender distribution of the influencer\'s audience (e.g., 60% Female, 40% Male). Used for campaign targeting.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGeography rdf:type rdf:Property ;
    rdfs:label 'Audience Geography' ;
    rdfs:comment 'Primary geographic markets where the influencer\'s audience is concentrated, expressed as comma-separated ISO 3-letter country codes (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePostImpressions rdf:type rdf:Property ;
    rdfs:label 'Average Post Impressions' ;
    rdfs:comment 'Average total impressions (views) per post, calculated from historical campaign performance data.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averagePostReach rdf:type rdf:Property ;
    rdfs:label 'Average Post Reach' ;
    rdfs:comment 'Average number of unique users reached per post, calculated from historical campaign performance data.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Score' ;
    rdfs:comment 'Brand safety assessment score (0.00 to 5.00) evaluating the influencer\'s content for alignment with brand values, absence of controversial content, and reputational risk. Higher scores indicate safer partnerships.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementRatePercent rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate Percent' ;
    rdfs:comment 'Average engagement rate (likes, comments, shares divided by followers) expressed as a percentage. Key metric for influencer effectiveness.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'Product category or categories covered by the exclusivity clause (e.g., Beauty, Personal Care, Household). Null if no exclusivity.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClause rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause' ;
    rdfs:comment 'Indicates whether the influencer is under an exclusivity agreement preventing them from promoting competing brands.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followerCount rdf:type rdf:Property ;
    rdfs:label 'Follower Count' ;
    rdfs:comment 'Total number of followers across the primary platform at the time of last update. Used for tier classification and reach estimation.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handle rdf:type rdf:Property ;
    rdfs:label 'Handle' ;
    rdfs:comment 'Primary social media handle or username of the influencer (e.g., @username). Used as the public identifier across platforms.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influencerTier rdf:type rdf:Property ;
    rdfs:label 'Influencer Tier' ;
    rdfs:comment 'Classification tier based on follower count: Nano (<10K), Micro (10K-100K), Macro (100K-1M), Mega (1M+), Celebrity (established public figure).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCampaignDate rdf:type rdf:Property ;
    rdfs:label 'Last Campaign Date' ;
    rdfs:comment 'Date of the most recent campaign engagement with this influencer. Used for recency analysis and re-engagement planning.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Preferred method for business communication with the influencer or their representation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPlatform rdf:type rdf:Property ;
    rdfs:label 'Primary Platform' ;
    rdfs:comment 'The primary social media platform where the influencer has the largest following or engagement.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPlatforms rdf:type rdf:Property ;
    rdfs:label 'Secondary Platforms' ;
    rdfs:comment 'Comma-separated list of additional social media platforms where the influencer maintains an active presence.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCampaignsParticipated rdf:type rdf:Property ;
    rdfs:label 'Total Campaigns Participated' ;
    rdfs:comment 'Cumulative count of campaigns the influencer has participated in with Consumer Goods. Used for partnership history and performance tracking.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketResearchStudyId rdf:type rdf:Property ;
    rdfs:label 'Market Research Study Id' ;
    rdfs:comment 'Unique identifier for the market research study or syndicated data subscription. Primary key.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Completion Date' ;
    rdfs:comment 'The date when the research analysis and reporting were finalized and delivered.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageBasketSize rdf:type rdf:Property ;
    rdfs:label 'Average Basket Size' ;
    rdfs:comment 'The average number of units or volume purchased per transaction by panel households during the measurement period.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Brand Awareness Pct' ;
    rdfs:comment 'The percentage of respondents who demonstrated awareness of the brand, either aided or unaided, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandConsiderationPct rdf:type rdf:Property ;
    rdfs:label 'Brand Consideration Pct' ;
    rdfs:comment 'The percentage of respondents who would consider purchasing the brand, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandPreferencePct rdf:type rdf:Property ;
    rdfs:label 'Brand Preference Pct' ;
    rdfs:comment 'The percentage of respondents who prefer the brand over competitors, as measured in the brand health tracker.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division that commissioned and is responsible for the market research study (e.g., Skincare, Haircare, Home Care).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerDemographics rdf:type rdf:Property ;
    rdfs:label 'Buyer Demographics' ;
    rdfs:comment 'Summary of the demographic profile of buyers identified in the consumer panel, including age, gender, income, household composition, and other relevant characteristics.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProviderName rdf:type rdf:Property ;
    rdfs:label 'Data Provider Name' ;
    rdfs:comment 'The name of the syndicated data provider for ongoing panel subscriptions or continuous measurement services.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when data collection or fieldwork for the research study was completed.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date when data collection or fieldwork for the research study began.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:householdPenetrationPct rdf:type rdf:Property ;
    rdfs:label 'Household Penetration Pct' ;
    rdfs:comment 'The percentage of households in the target market that have purchased the brand or category during the measurement period, as reported by consumer panel data.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Executive summary of the key insights, findings, and actionable recommendations from the market research study.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatRatePct rdf:type rdf:Property ;
    rdfs:label 'Repeat Rate Pct' ;
    rdfs:comment 'The percentage of buyers who made repeat purchases of the brand or product during the measurement period, indicating loyalty and retention.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchAgencyName rdf:type rdf:Property ;
    rdfs:label 'Research Agency Name' ;
    rdfs:comment 'The name of the external market research agency or syndicated data provider conducting or supplying the study (e.g., Nielsen IQ, Kantar, Circana, Ipsos).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchObjective rdf:type rdf:Property ;
    rdfs:label 'Research Objective' ;
    rdfs:comment 'The primary business objective or research question that the study was designed to address (e.g., measure brand health, test new product concept, understand usage barriers, track competitive dynamics).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchType rdf:type rdf:Property ;
    rdfs:label 'Research Type' ;
    rdfs:comment 'The type or methodology of the market research study. Includes quantitative surveys, qualitative focus groups, usage and attitude (U&A) studies, concept testing, packaging tests, Net Promoter Score (NPS) surveys, brand health trackers, and consumer panel subscriptions. [ENUM-REF-CANDIDATE: quantitative|qualitative|usage_and_attitude|concept_test|pack_test|nps|brand_health_tracker|consumer_panel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The total number of respondents or households included in the research study sample.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'The unique business identifier or project code assigned to the market research study for tracking and reference purposes.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Study Investment Amount' ;
    rdfs:comment 'The total financial investment or cost incurred for commissioning and conducting the market research study, including agency fees, fieldwork costs, and data licensing.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'The official name or title of the market research study or syndicated data subscription.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'The current lifecycle status of the market research study. Tracks progression from planning through fieldwork, analysis, and completion.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'The end date or renewal date of the syndicated data subscription or continuous panel tracking service.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'The start date of the syndicated data subscription or continuous panel tracking service.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:switchingBehaviorIndex rdf:type rdf:Property ;
    rdfs:label 'Switching Behavior Index' ;
    rdfs:comment 'A metric indicating the rate at which consumers switch between brands within the category, as measured by consumer panel data.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'The geographic market or region where the research study is being conducted (e.g., North America, Western Europe, APAC).' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareRecordId rdf:type rdf:Property ;
    rdfs:label 'Market Share Record Id' ;
    rdfs:comment 'Unique identifier for the market share measurement record.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvPercent rdf:type rdf:Property ;
    rdfs:label 'Acv Percent' ;
    rdfs:comment 'Percentage of total category sales volume represented by stores carrying the brand or SKU (weighted distribution).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandValueAmount rdf:type rdf:Property ;
    rdfs:label 'Brand Value Amount' ;
    rdfs:comment 'Total sales value (revenue) for the brand or SKU during the measurement period.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Brand Volume Quantity' ;
    rdfs:comment 'Total sales volume (units) for the brand or SKU during the measurement period.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryTotalValueAmount rdf:type rdf:Property ;
    rdfs:label 'Category Total Value Amount' ;
    rdfs:comment 'Total sales value (revenue) for the entire category during the measurement period.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryTotalVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Category Total Volume Quantity' ;
    rdfs:comment 'Total sales volume (units) for the entire category during the measurement period.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Data quality or confidence level assigned to this measurement (high, medium, low) based on sample size or data completeness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceReportCode rdf:type rdf:Property ;
    rdfs:label 'Data Source Report Code' ;
    rdfs:comment 'Unique identifier or reference number from the source system report.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'Code representing the specific geographic area (e.g., country code, state code, metro code) for the measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyLevel rdf:type rdf:Property ;
    rdfs:label 'Geography Level' ;
    rdfs:comment 'Geographic granularity at which market share is measured (national, regional, state, metro, local).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyName rdf:type rdf:Property ;
    rdfs:label 'Geography Name' ;
    rdfs:comment 'Human-readable name of the geographic area for the measurement.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProjected rdf:type rdf:Property ;
    rdfs:label 'Is Projected' ;
    rdfs:comment 'Flag indicating whether this record contains projected/estimated data (true) or actual reported data (false).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketDefinition rdf:type rdf:Property ;
    rdfs:label 'Market Definition' ;
    rdfs:comment 'Description of the market scope and boundaries used for the share calculation (e.g., total category, specific segment, competitive set).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the time period for which market share is measured.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the time period for which market share is measured (e.g., week, month, quarter).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Granularity of the measurement period (weekly, monthly, quarterly, yearly).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rankPosition rdf:type rdf:Property ;
    rdfs:label 'Rank Position' ;
    rdfs:comment 'Competitive rank position of the brand or SKU within the category for this period (1 = market leader).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharePointChange rdf:type rdf:Property ;
    rdfs:label 'Share Point Change' ;
    rdfs:comment 'Change in value share percentage points compared to the previous comparable period (positive = gain, negative = loss).' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueSharePercent rdf:type rdf:Property ;
    rdfs:label 'Value Share Percent' ;
    rdfs:comment 'Market share expressed as a percentage of total category sales value (revenue). Also known as dollar share or revenue share.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeSharePercent rdf:type rdf:Property ;
    rdfs:label 'Volume Share Percent' ;
    rdfs:comment 'Market share expressed as a percentage of total category sales volume (units). Also known as unit share.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volume quantities (e.g., units, cases, liters, kilograms).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOverYearChangePercent rdf:type rdf:Property ;
    rdfs:label 'Year Over Year Change Percent' ;
    rdfs:comment 'Percentage change in value share compared to the same period in the prior year.' ;
    rdfs:domain ind:MarketShareRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingBudgetId rdf:type rdf:Property ;
    rdfs:label 'Marketing Budget Id' ;
    rdfs:comment 'Unique identifier for the marketing budget allocation record. Primary key.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMarketingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Marketing Employee Id' ;
    rdfs:comment 'Identifier of the marketing leader or business owner responsible for managing and executing this budget allocation.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'The cumulative amount of budget that has been actually spent (invoiced and paid) as of the measurement date.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'The portion of the budget allocated to agency fees and retainers for creative, media, and strategic services.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known unique code for this marketing budget allocation, used for tracking and reference across planning systems.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable name or title for this marketing budget allocation, typically describing the scope or purpose.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget allocation in the approval and execution workflow.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget allocation by planning horizon and purpose (annual, quarterly, campaign-specific, project-based, tactical, or strategic).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Spend Amount' ;
    rdfs:comment 'The cumulative amount of budget that has been committed through purchase orders, contracts, or reservations but not yet invoiced or paid.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget Amount' ;
    rdfs:comment 'The portion of the budget held in reserve for unforeseen opportunities or adjustments during the budget period.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonWorkingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Non Working Budget Amount' ;
    rdfs:comment 'The portion of the total budget allocated to non-working expenses (production, creative development, agency fees, research) that do not directly reach consumers.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Production Budget Amount' ;
    rdfs:comment 'The portion of the budget allocated specifically to creative production costs (video production, photography, design, content creation).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Research Budget Amount' ;
    rdfs:comment 'The portion of the budget allocated to market research, consumer insights, brand tracking, and measurement activities.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The total approved marketing investment amount for this budget allocation, including all working and non-working components.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingMediaBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Working Media Budget Amount' ;
    rdfs:comment 'The portion of the total budget allocated to working media spend (paid media placements, impressions, airtime) that directly reaches consumers.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryConsumerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Consumer Employee Id' ;
    rdfs:comment 'Identifier of the marketing team member or business unit responsible for managing and activating this segment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ageRangeLower rdf:type rdf:Property ;
    rdfs:label 'Age Range Lower' ;
    rdfs:comment 'Lower bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.' ;
