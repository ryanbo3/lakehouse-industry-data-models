    rdfs:range xsd:integer .

ind:assessmentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Approval Date' ;
    rdfs:comment 'Date on which the assessment was formally approved.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Approved By' ;
    rdfs:comment 'User identifier of the person who approved the assessment.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Created By' ;
    rdfs:comment 'User identifier of the person who created the assessment record.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-form comments captured by the assessor.' ;
