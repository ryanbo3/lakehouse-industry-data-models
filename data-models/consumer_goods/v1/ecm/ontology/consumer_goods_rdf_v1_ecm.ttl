    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterUsageM3 rdf:type rdf:Property ;
    rdfs:label 'Water Usage M3' ;
    rdfs:comment 'Volume of water (cubic metres) consumed in the production of the assessed commodity.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateName rdf:type rdf:Property ;
    rdfs:label 'Certificate Name' ;
    rdfs:comment 'Human-readable name or title for the certificate.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Energy Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energySource rdf:type rdf:Property ;
    rdfs:label 'Energy Source' ;
    rdfs:comment 'Primary energy generation source for the certificate.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatingFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Generating Facility Location' ;
    rdfs:comment 'Geographic location (city, country) of the generating facility.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatingFacilityName rdf:type rdf:Property ;
    rdfs:label 'Generating Facility Name' ;
    rdfs:comment 'Name of the power plant or facility that generated the renewable electricity.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Compliance Flag' ;
    rdfs:comment 'Indicates whether the certificate acquisition complies with ISO 14001 environmental management standards.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date on which the certificate was purchased or acquired.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityMwh rdf:type rdf:Property ;
    rdfs:label 'Quantity Mwh' ;
    rdfs:comment 'Amount of renewable electricity represented by the certificate, expressed in megawatt-hours.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the registry that issued or tracks the certificate (e.g., GRET, APX, I-REC Registry).' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Percentage' ;
    rdfs:comment 'Percentage of the certificate’s energy that is classified as renewable.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingQuarter rdf:type rdf:Property ;
    rdfs:label 'Reporting Quarter' ;
    rdfs:comment 'Quarter of the reporting year (1-4) associated with the certificate.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Retirement Confirmation Number' ;
    rdfs:comment 'Reference number confirming the certificate’s retirement in the registry.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageEndDate rdf:type rdf:Property ;
    rdfs:label 'Vintage End Date' ;
    rdfs:comment 'Last day of the period covered by the certificate.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vintageStartDate rdf:type rdf:Property ;
    rdfs:label 'Vintage Start Date' ;
    rdfs:comment 'First day of the period covered by the certificate.' ;
    rdfs:domain ind:EnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionReference rdf:type rdf:Property ;
    rdfs:label 'Consumption Reference' ;
    rdfs:comment 'Business reference code for the consumption record, used in reporting and reconciliation.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'Date and time when the energy consumption measurement was taken or recorded.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:energyConsumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Status' ;
    rdfs:comment 'Current lifecycle state of the consumption record.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyIntensityRatio rdf:type rdf:Property ;
    rdfs:label 'Energy Intensity Ratio' ;
    rdfs:comment 'Energy consumption per unit of production output (e.g., MWh per ton of product).' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyQuantity rdf:type rdf:Property ;
    rdfs:label 'Energy Quantity' ;
    rdfs:comment 'Amount of energy consumed during the period, expressed in the unit defined by energy_unit.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyType rdf:type rdf:Property ;
    rdfs:label 'Energy Type' ;
    rdfs:comment 'Category of energy consumed.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Unit' ;
    rdfs:comment 'Unit of measure for energy_quantity (megawatt-hours or gigajoules).' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso50001ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 50001 Compliance Flag' ;
    rdfs:comment 'Indicates whether the measurement complies with ISO 50001 energy management standards (True/False).' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Origin of the consumption data (direct meter reading, utility bill, or estimated).' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterCode rdf:type rdf:Property ;
    rdfs:label 'Meter Code' ;
    rdfs:comment 'Unique identifier of the physical meter or virtual metering point used to capture the consumption.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffRate rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate' ;
    rdfs:comment 'Applicable cost rate for the energy type during the consumption period, expressed in local currency per unit.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgAuditId rdf:type rdf:Property ;
    rdfs:label 'Esg Audit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_audit. Business justification: Incidents are often audited; linking to ESG audit captures audit findings related to each incident.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgAudit .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the estimated cost.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Summary of the assessed environmental impact (e.g., area affected, ecosystem risk).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Status' ;
    rdfs:comment 'Current processing state of the incident record.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Projected financial cost to remediate the incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Free-text description of what happened, including circumstances and immediate impacts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Human-readable reference number assigned to the incident for tracking and reporting.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSubtype rdf:type rdf:Property ;
    rdfs:label 'Incident Subtype' ;
    rdfs:comment 'More detailed classification within the incident type, free-text for specific description.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Exact date and time when the incident occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Category of the environmental incident (e.g., chemical spill, air emission exceedance).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the incident must be reported to a regulator (e.g., EPA, OSHA).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-text description of the precise location within the facility (e.g., building, zone, equipment).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReleased rdf:type rdf:Property ;
    rdfs:label 'Quantity Released' ;
    rdfs:comment 'Measured amount of the substance released during the incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationEndDate rdf:type rdf:Property ;
    rdfs:label 'Remediation End Date' ;
    rdfs:comment 'Date remediation work was completed.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStartDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Start Date' ;
    rdfs:comment 'Date remediation work began.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter state or province abbreviation (U.S. format).' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceCode rdf:type rdf:Property ;
    rdfs:label 'Substance Code' ;
    rdfs:comment 'Chemical Abstracts Service (CAS) registry number identifying the substance.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment 'Postal/ZIP code of the incident location.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Narrative description of the activity authorized by the permit (e.g., manufacturing process, waste handling).' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeLimit rdf:type rdf:Property ;
    rdfs:label 'Discharge Limit' ;
    rdfs:comment 'Maximum allowable discharge quantity for the permitted activity.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimit rdf:type rdf:Property ;
    rdfs:label 'Emission Limit' ;
    rdfs:comment 'Maximum allowable emission quantity for the permitted activity.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Linkage rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Linkage' ;
    rdfs:comment 'Reference to the facility\'s ISO 14001 Environmental Management System certification status.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection of the permit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitUnit rdf:type rdf:Property ;
    rdfs:label 'Limit Unit' ;
    rdfs:comment 'Unit of measure for emission or discharge limits.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often compliance monitoring is required.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit or license number assigned by the issuing authority.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Category of the environmental permit (e.g., air emissions, wastewater discharge, hazardous waste storage, stormwater).' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Specific reporting obligations tied to the permit (e.g., format, submission deadlines).' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Certification Status' ;
    rdfs:comment 'Status of the related certification after the audit (e.g., maintained, revoked, pending).' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDurationHours rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Hours' ;
    rdfs:comment 'Total time spent on the audit, expressed in hours.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'Narrative summary of key findings and observations.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLocation rdf:type rdf:Property ;
    rdfs:label 'Audit Location' ;
    rdfs:comment 'City or locality where the audit was conducted.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRegion rdf:type rdf:Property ;
    rdfs:label 'Audit Region' ;
    rdfs:comment 'Three-letter ISO country code of the audit location.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document identifier for the final audit report.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Scope Description' ;
    rdfs:comment 'Detailed textual description of the audit scope.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Organization or entity that performed the audit.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Flag' ;
    rdfs:comment 'Indicates whether carbon emission data were evaluated in the audit.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Impact Flag' ;
    rdfs:comment 'Indicates whether audit findings affect ISO certification renewal (true = impact).' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlanRef rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Ref' ;
    rdfs:comment 'Reference code or identifier for the corrective action plan linked to this audit.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Flag' ;
    rdfs:comment 'Indicates whether energy consumption aspects were covered.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingsMajor rdf:type rdf:Property ;
    rdfs:label 'Findings Major' ;
    rdfs:comment 'Number of major non-conformances identified.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsMinor rdf:type rdf:Property ;
    rdfs:label 'Findings Minor' ;
    rdfs:comment 'Number of minor non-conformances identified.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsObservation rdf:type rdf:Property ;
    rdfs:label 'Findings Observation' ;
    rdfs:comment 'Number of observations (opportunities for improvement) recorded.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall outcome of the audit after evaluating findings.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSeverity rdf:type rdf:Property ;
    rdfs:label 'Risk Severity' ;
    rdfs:comment 'Overall risk rating derived from audit findings.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Management Flag' ;
    rdfs:comment 'Indicates whether waste management aspects were covered.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Water Usage Flag' ;
    rdfs:comment 'Indicates whether water consumption aspects were covered.' ;
    rdfs:domain ind:EsgAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Measured value of the metric in the baseline year.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'Year used as the reference point for measuring progress.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentCode rdf:type rdf:Property ;
    rdfs:label 'Commitment Code' ;
    rdfs:comment 'External reference code or number used in public disclosures and internal tracking.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Commitment Description' ;
    rdfs:comment 'Narrative description of the ESG pledge, including scope and rationale.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentOwner rdf:type rdf:Property ;
    rdfs:label 'Commitment Owner' ;
    rdfs:comment 'Internal department or business unit responsible for the commitment.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentScope rdf:type rdf:Property ;
    rdfs:label 'Commitment Scope' ;
    rdfs:comment 'Geographic or operational scope of the commitment.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Category of the ESG pledge (e.g., carbon neutrality, water stewardship).' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Whether the commitment is publicly disclosed, kept private, or confidential.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgCommitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Esg Commitment Status' ;
    rdfs:comment 'Current lifecycle state of the commitment.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressCadence rdf:type rdf:Property ;
    rdfs:label 'Progress Cadence' ;
    rdfs:comment 'Frequency at which progress against the commitment is reported.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetYear rdf:type rdf:Property ;
    rdfs:label 'Target Year' ;
    rdfs:comment 'Calendar year by which the commitment target should be achieved.' ;
    rdfs:domain ind:EsgCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esgDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Id' ;
    rdfs:comment 'Unique surrogate key for each ESG disclosure record.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment Id' ;
    rdfs:comment 'Reference to the materiality assessment that underpins the disclosed metrics.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialityAssessment .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'Level of external assurance applied to the ESG disclosure.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Assurance Provider' ;
    rdfs:comment 'Name of the third-party assurance firm providing verification.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionsScope1 rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Scope1' ;
    rdfs:comment 'Direct (Scope 1) greenhouse gas emissions, measured in metric tonnes CO₂e.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionsScope2 rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Scope2' ;
    rdfs:comment 'Indirect (Scope 2) greenhouse gas emissions from purchased electricity, measured in metric tonnes CO₂e.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionsScope3 rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Scope3' ;
    rdfs:comment 'Other indirect (Scope 3) greenhouse gas emissions across the value chain, measured in metric tonnes CO₂e.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureReference rdf:type rdf:Property ;
    rdfs:label 'Disclosure Reference' ;
    rdfs:comment 'Business identifier assigned to the ESG disclosure submission (e.g., internal tracking number).' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumption rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption' ;
    rdfs:comment 'Total energy consumed, measured in megawatt-hours (MWh).' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the ESG disclosure.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:framework rdf:type rdf:Property ;
    rdfs:label 'Framework' ;
    rdfs:comment 'Framework used for the ESG disclosure (e.g., GRI, CDP, TCFD, SASB, EU CSRD, SEC Climate Rule, UN SDG). [ENUM-REF-CANDIDATE: GRI|CDP|TCFD|SASB|EU_CS_RD|SEC_Climate|UN_SDG — promote to reference product]' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingRecyclabilityRate rdf:type rdf:Property ;
    rdfs:label 'Packaging Recyclability Rate' ;
    rdfs:comment 'Percentage of packaging material that is recyclable or made from recycled content.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicUrl rdf:type rdf:Property ;
    rdfs:label 'Public Url' ;
    rdfs:comment 'Web address where the published ESG disclosure can be accessed.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the ESG reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the ESG reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCarbonEmissions rdf:type rdf:Property ;
    rdfs:label 'Total Carbon Emissions' ;
    rdfs:comment 'Aggregated total carbon emissions (Scope 1 + Scope 2 + Scope 3) for the reporting period.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteGenerated rdf:type rdf:Property ;
    rdfs:label 'Waste Generated' ;
    rdfs:comment 'Total waste produced, measured in metric tonnes.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumption rdf:type rdf:Property ;
    rdfs:label 'Water Consumption' ;
    rdfs:comment 'Total water used in operations during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:additionalCertification rdf:type rdf:Property ;
