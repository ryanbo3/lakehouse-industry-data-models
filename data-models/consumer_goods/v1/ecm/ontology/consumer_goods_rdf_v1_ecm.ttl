    rdfs:domain ind:CommitmentProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deforestationAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Deforestation Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each deforestation risk assessment record.' ;
