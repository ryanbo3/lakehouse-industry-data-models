ind:sovSomGap rdf:type rdf:Property ;
    rdfs:label 'Sov Som Gap' ;
    rdfs:comment 'Difference between brand SOV percentage and brand SOM percentage (SOV - SOM). Positive gap indicates over-investment; negative gap indicates under-investment.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topCompetitorBrandName rdf:type rdf:Property ;
    rdfs:label 'Top Competitor Brand Name' ;
    rdfs:comment 'Name of the competitor brand with the highest Share of Voice in the category during the measurement period.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topCompetitorSovPercentage rdf:type rdf:Property ;
    rdfs:label 'Top Competitor Sov Percentage' ;
    rdfs:comment 'Share of Voice percentage of the top competitor brand in the category.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Id' ;
    rdfs:comment 'Unique identifier for the sponsorship agreement record. Primary key.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorshipApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee or executive who approved this sponsorship agreement.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sponsorshipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Employee Id' ;
    rdfs:comment 'Reference to the employee or marketing manager responsible for managing this sponsorship relationship.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationRights rdf:type rdf:Property ;
    rdfs:label 'Activation Rights' ;
    rdfs:comment 'Detailed description of marketing activation rights granted under the sponsorship, including logo usage, signage, hospitality, content creation, social media, and promotional activities.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyPartnerName rdf:type rdf:Property ;
    rdfs:label 'Agency Partner Name' ;
    rdfs:comment 'Name of the external agency or consultant managing sponsorship activation and measurement.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualValueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Value Amount' ;
    rdfs:comment 'Annual monetary value of the sponsorship agreement, calculated as total contract value divided by contract duration in years.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Reference URL or file path to the signed sponsorship contract document stored in the document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationYears rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Years' ;
    rdfs:comment 'The length of the sponsorship contract expressed in years, including fractional years for partial-year agreements.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value of the sponsorship contract over its full term.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this sponsorship includes category exclusivity rights preventing competitors from sponsoring the same property.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the scope of exclusivity rights, including product categories, geographic territories, and competitive restrictions.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalityEntitlements rdf:type rdf:Property ;
    rdfs:label 'Hospitality Entitlements' ;
    rdfs:comment 'Description of hospitality benefits included in the sponsorship, such as VIP tickets, suite access, meet-and-greet opportunities, and event passes.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFramework rdf:type rdf:Property ;
    rdfs:label 'Measurement Framework' ;
    rdfs:comment 'Description of the measurement methodology and key performance indicators (KPIs) used to evaluate sponsorship effectiveness and ROI.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaRights rdf:type rdf:Property ;
    rdfs:label 'Media Rights' ;
    rdfs:comment 'Description of media and broadcast rights included in the sponsorship, such as commercial time, broadcast mentions, digital content rights, and streaming access.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Description of the payment terms and schedule for the sponsorship contract, including installment amounts and due dates.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligations rdf:type rdf:Property ;
    rdfs:label 'Performance Obligations' ;
    rdfs:comment 'Contractual performance obligations and deliverables required from the sponsored property, including appearances, content creation, and promotional activities.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyName rdf:type rdf:Property ;
    rdfs:label 'Property Name' ;
    rdfs:comment 'The name of the sponsored property (e.g., team name, event name, celebrity name, venue name).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyType rdf:type rdf:Property ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'The category of property being sponsored (e.g., sports team, entertainment event, festival, celebrity, influencer). [ENUM-REF-CANDIDATE: sports_team|sports_league|sports_event|entertainment_event|music_festival|cultural_event|celebrity|influencer|venue|broadcast_property|esports — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the sponsorship contract includes an option for renewal at the end of the current term.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Description of the renewal terms, conditions, and pricing structure if renewal option exists.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percent' ;
    rdfs:comment 'Target return on investment percentage for this sponsorship, used for performance evaluation and portfolio optimization.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorshipCode rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Code' ;
    rdfs:comment 'Internal business identifier or code used to reference this sponsorship in financial and marketing systems.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipName rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Name' ;
    rdfs:comment 'The official name or title of the sponsorship agreement as recognized in marketing materials and contracts.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Status' ;
    rdfs:comment 'Current lifecycle status of the sponsorship agreement. [ENUM-REF-CANDIDATE: draft|negotiation|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'The level or tier of sponsorship (e.g., title sponsor, presenting sponsor, official sponsor, associate sponsor) indicating prominence and rights.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of contract termination conditions, notice periods, and penalties for early termination by either party.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territory or market scope covered by the sponsorship agreement, using three-letter ISO country codes or regional descriptors.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSupplierListId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List Id' ;
    rdfs:comment 'Unique identifier for the approved supplier list entry. Primary key for the ASL record.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsId rdf:type rdf:Property ;
    rdfs:label 'Sds Id' ;
    rdfs:comment 'Reference to the Safety Data Sheet document for hazardous materials supplied by this supplier. Links to document management system. Required for chemicals, fragrances, and hazardous substances per OSHA and REACH regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sds .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the person or committee who authorized the supplier approval. Provides accountability and audit trail.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalBasis rdf:type rdf:Property ;
    rdfs:label 'Approval Basis' ;
    rdfs:comment 'Method or evidence used to grant supplier approval. Audit = on-site supplier audit; Certification = third-party certification (ISO, FSC, RSPO); Qualification test = material sample testing; Performance review = historical performance analysis; Risk assessment = supply chain risk evaluation; Legacy approval = pre-existing authorization.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date when the current approval expires and requires re-evaluation. Null indicates indefinite approval subject to periodic review.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingDate rdf:type rdf:Property ;
    rdfs:label 'Blocking Date' ;
    rdfs:comment 'Date when the supplier was blocked, delisted, or suspended. Null when status is approved, conditional, or pending.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Explanation for why the supplier is blocked, delisted, or suspended. Includes quality issues, compliance violations, delivery failures, financial instability, or ethical concerns. Null when status is approved or conditional.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms' ;
    rdfs:comment 'Specific restrictions or requirements when approval status is conditional. Examples: reduced order quantities, enhanced inspection, expedited payment terms, or geographic limitations. Null when status is not conditional.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Rating' ;
    rdfs:comment 'Supplier delivery performance rating for this material-plant combination. A = excellent (>95% OTIF); B = good (90-95% OTIF); C = acceptable (85-90% OTIF); D = marginal (80-85% OTIF); F = failing (<80% OTIF).' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether electronic purchase orders and confirmations are enabled for this supplier-material-plant combination. True = EDI transactions supported; False = manual processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether incoming goods from this supplier-material combination require quality inspection before goods receipt posting. True = inspection mandatory; False = direct posting allowed.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for this material-plant combination. Used to enforce purchasing constraints in PO creation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the preferred source for this material-plant combination. True = preferred supplier with priority allocation; False = approved but not preferred.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'End date of the current pricing agreement. Null indicates open-ended pricing subject to change notification.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Start date of the current pricing agreement for this supplier-material-plant combination. Used to enforce valid pricing periods in PO creation.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Supplier quality performance rating for this material-plant combination. A = excellent (>98% acceptance); B = good (95-98%); C = acceptable (90-95%); D = marginal (85-90%); F = failing (<85%). Derived from quality inspection results.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reEvaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Evaluation Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier performance review or qualification audit. Drives proactive supplier management activities.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for this material-plant combination. True = sole source (supply risk); False = multiple sources available.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Unique identifier for the contract line item. Primary key for this entity.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeInvoicedValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Invoiced Value' ;
    rdfs:comment 'Total invoiced value for all purchase orders released against this contract line to date. Used for spend tracking and budget management.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeOrderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Ordered Quantity' ;
    rdfs:comment 'Total quantity ordered against this contract line to date. Used for tracking contract utilization and remaining commitment.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Received Quantity' ;
    rdfs:comment 'Total quantity received against this contract line to date. Used for tracking actual fulfillment and supplier performance.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'International Commercial Terms code defining the division of costs and risks between buyer and supplier for this line item. Governs shipping, insurance, and transfer of ownership responsibilities. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'Named place or port associated with the Incoterm. Specifies the geographic point where cost and risk transfer occurs (e.g., supplier factory, destination port, buyer warehouse).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Textual description of the material or service being procured. Provides human-readable context for the line item beyond the material code.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Classification code grouping similar materials for procurement analysis and reporting. Enables spend analysis by category (e.g., raw materials, packaging, indirect goods).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered per purchase order release against this contract line. May reflect supplier capacity constraints or buyer inventory limits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for minimum and maximum order quantities. Defines the measurement basis for order quantity constraints.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationFormula rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Formula' ;
    rdfs:comment 'Formula or reference to index-based pricing adjustment mechanism. Defines how unit price will be adjusted over time based on commodity indices, inflation, or other agreed factors.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity of the material to which the unit price applies. For example, if price is per 100 units, this field would be 100. Used in conjunction with unit_price to calculate effective per-unit cost.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure for the price unit. Defines the measurement basis for pricing (e.g., EA for each, KG for kilogram, L for liter, M for meter).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the procurement team or buyer responsible for managing this contract line. Used for workload distribution and accountability tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned or target quantity of material to be procured over the contract validity period. Used for volume commitment tracking and supplier capacity planning.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Target Quantity Uom' ;
    rdfs:comment 'Unit of measure for the target quantity. Defines how the target volume is measured (e.g., EA, KG, L, M).' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery schedule line. Primary key for this entity.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Reference to the material (raw material, packaging component, or indirect good) being scheduled for delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:atpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Atp Relevant Flag' ;
    rdfs:comment 'Indicates whether this schedule line is considered in Available to Promise (ATP) calculations for downstream order promising.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Status indicating whether the supplier has confirmed, rejected, or revised this schedule line.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier, which may differ from the scheduled date based on supplier capacity or logistics constraints.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryInstruction rdf:type rdf:Property ;
    rdfs:label 'Delivery Instruction' ;
    rdfs:comment 'Special handling or delivery instructions for this schedule line (e.g., dock requirements, unloading equipment, temperature control).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-provided delivery note or packing slip number accompanying this shipment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Business priority level assigned to this delivery schedule line, used for expediting and resource allocation decisions.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Percentage' ;
    rdfs:comment 'Acceptable over-delivery or under-delivery tolerance as a percentage of scheduled quantity, per contract terms.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Blocked Flag' ;
    rdfs:comment 'Indicates whether goods receipt is blocked for this schedule line due to quality, compliance, or commercial issues.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Three-letter Incoterms code defining the responsibilities, costs, and risks between buyer and supplier for this delivery (e.g., FOB, CIF, DDP).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpElementFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Element Flag' ;
    rdfs:comment 'Indicates whether this schedule line is an active MRP element used in material requirements planning calculations.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'The remaining quantity yet to be received, calculated as confirmed quantity minus received quantity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number within the purchase order identifying this specific delivery schedule. Used for ordering and referencing individual schedule lines.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'The quantity of material originally scheduled for delivery on this schedule line as per the purchase order or scheduling agreement.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided Certificate of Analysis was received with the shipment. Required for GMP compliance and quality assurance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this goods receipt transaction. Used for audit trails, supplier communication, and three-way match processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Gr Reversal Flag' ;
    rdfs:comment 'Indicates whether this goods receipt has been reversed (cancelled). True means the inventory posting has been negated due to return-to-vendor or data correction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt. Indicates whether the receipt is active, has been reversed, or is awaiting quality inspection clearance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'The manufacturing plant or distribution center where the goods were physically received. Aligns with organizational hierarchy and inventory segmentation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for capturing additional notes, exceptions, or special handling instructions related to this goods receipt. Used for operational communication and audit context.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainableSourcingCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainable Sourcing Certification' ;
    rdfs:comment 'The sustainability certification standard under which the received material was sourced (e.g., FSC for paper/packaging, RSPO for palm oil). Supports ESG reporting and sustainable sourcing initiatives.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Primary key for invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceEntrySheetLineId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Line Id' ;
    rdfs:comment 'Reference to the service entry sheet line for service-based invoices. Used when the invoice line corresponds to a service rather than a material.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEntrySheetLine .

ind:amountVariance rdf:type rdf:Property ;
    rdfs:label 'Amount Variance' ;
    rdfs:comment 'Total amount variance for this line calculated as the difference between invoiced amount and expected amount based on PO and GR.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Line-level discount percentage applied by the supplier. Reduces the net amount before tax calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Quantity of material or service units invoiced on this line. Used for three-way match comparison against PO quantity and GR quantity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Total gross amount for this invoice line including taxes and charges. Sum of line_net_amount and line_tax_amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to this invoice line. Calculated based on the tax code and net amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineText rdf:type rdf:Property ;
    rdfs:label 'Line Text' ;
    rdfs:comment 'Free-form text field for additional notes, comments, or special instructions related to this invoice line. May include supplier remarks or internal annotations.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between invoiced unit price and PO unit price. Used to identify pricing discrepancies and trigger approval workflows.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Document Number' ;
    rdfs:comment 'Reference number for the Safety Data Sheet associated with this material. Required for hazardous materials and chemical ingredients per OSHA and REACH regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Tax rate percentage applied to this line. Derived from the tax code configuration.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Withholding tax code for this invoice line. Applicable in jurisdictions requiring tax withholding at source for certain supplier payments.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Po Confirmation Id' ;
    rdfs:comment 'Unique identifier for the purchase order confirmation record. Primary key for the po_confirmation product.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Date' ;
    rdfs:comment 'Date when the buyer approved or rejected the confirmation. Null if approval is not required or still pending.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyerApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Notes' ;
    rdfs:comment 'Notes or comments entered by the buyer during the approval or rejection process. Captures buyer feedback on variances or special conditions.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Required Flag' ;
    rdfs:comment 'Indicates whether the confirmation requires explicit buyer approval before proceeding. True when there are significant variances, substitutions, or price changes that need buyer review.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Status' ;
    rdfs:comment 'Status of buyer approval for confirmations that require review. Tracks whether the buyer has accepted or rejected the supplier\'s confirmed terms.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the supplier issued the confirmation acknowledgement. Represents the business date of confirmation, not the system receipt timestamp.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Unique confirmation number assigned by the supplier to this order acknowledgement. Used for supplier reference and tracking.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDateVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Variance Days' ;
    rdfs:comment 'Number of days difference between confirmed delivery date and requested delivery date. Positive values indicate delay, negative values indicate early delivery commitment.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Specific delivery location or dock within the plant where goods should be delivered. May be a warehouse, storage location, or receiving dock identifier.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Number' ;
    rdfs:comment 'Unique EDI transaction identifier for confirmations received via EDI 855. Null for non-EDI confirmations. Used for EDI audit and reconciliation.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Risk Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a risk to OTIF performance. True when confirmed delivery date is later than requested or confirmed quantity is less than requested, signaling potential supply disruption.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Number' ;
    rdfs:comment 'Line item number within the purchase order that this confirmation applies to. Enables line-level confirmation tracking.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityVariancePct rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Pct' ;
    rdfs:comment 'Percentage variance between confirmed and requested quantity, calculated as (quantity_variance / requested_quantity) * 100. Used for supplier performance tracking and OTIF analysis.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed text description of the rejection reason provided by the supplier. Provides additional context beyond the standardized rejection reason code.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional instructions or notes from the supplier regarding the confirmation, delivery requirements, handling instructions, or other special conditions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Substitute Material Code' ;
    rdfs:comment 'Material code of the substitute product proposed by the supplier. Populated only when substitution_flag is True. Requires buyer approval before acceptance.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether the supplier is proposing a substitute material or product in place of the originally requested item. True if substitution is proposed, False otherwise.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Code' ;
    rdfs:comment 'Supplier\'s material code or part number for the item. Used for cross-reference and supplier catalog mapping.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'Supplier\'s internal reference number for this order or line item. May be a sales order number, production order number, or other supplier-side tracking identifier.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'Total amount for this confirmation line, calculated as confirmed_quantity * unit_price. Used for financial reconciliation and invoice matching.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether the material on this line is subject to batch management. When true, batch number must be assigned during goods receipt for traceability.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center to which the expense for this purchase order line will be charged. Used for financial accounting and budget tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order line has been marked for deletion. When true, the line is logically deleted but retained for audit purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested or confirmed delivery date for this purchase order line. Target date by which the supplier should deliver the material to the receiving plant.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether goods receipt is required for this purchase order line. When true, physical receipt must be posted before invoice can be processed.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Received Quantity' ;
    rdfs:comment 'Cumulative quantity of material received against this purchase order line. Updated with each goods receipt posting. Used for delivery tracking and invoice matching.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this line. When true, supplier invoice must be matched and verified against this PO line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original manufacturer\'s part number for the material. Important for quality assurance and regulatory compliance tracking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification code grouping similar materials for procurement analysis and reporting. Used for spend categorization and supplier segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value of this purchase order line calculated as ordered quantity multiplied by net price. Excludes taxes and freight.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may over-deliver beyond the ordered quantity. Used to control goods receipt tolerances.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the procurement team or buyer responsible for this purchase order line. Used for workload distribution and performance tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or department that requested this material through a purchase requisition. Provides accountability and cost center traceability.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Additional short text or notes specific to this purchase order line. Provides supplementary information for procurement and receiving teams.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'Supplier\'s own material or part number for this item. Used for cross-referencing and communication with the supplier.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may under-deliver below the ordered quantity. Used to control goods receipt tolerances and automatic PO closure.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceConditionId rdf:type rdf:Property ;
    rdfs:label 'Price Condition Id' ;
    rdfs:comment 'Unique identifier for the price condition record. Primary key for the price condition entity.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Reference to the RFQ process that resulted in this price condition. Null for non-RFQ pricing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Indicates whether this price condition has been formally approved for use in purchase orders (True/False).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Method used to calculate the condition value (fixed amount, percentage, quantity-based scale, value-based scale).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionClass rdf:type rdf:Property ;
    rdfs:label 'Condition Class' ;
    rdfs:comment 'High-level classification of the condition (price, discount, surcharge, freight, tax) for grouping and reporting purposes.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Record Number' ;
    rdfs:comment 'The unique business identifier for this price condition record in the source procurement system.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionSequence rdf:type rdf:Property ;
    rdfs:label 'Condition Sequence' ;
    rdfs:comment 'The order in which this condition is applied within the pricing procedure (lower numbers applied first).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the price condition (active, inactive, pending approval, expired, superseded by newer condition).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The category of pricing element this condition represents (base price, freight, surcharge, discount, tax, rebate, duty, handling, insurance, packaging). [ENUM-REF-CANDIDATE: base_price|freight|surcharge|discount|tax|rebate|duty|handling|insurance|packaging — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Unit' ;
    rdfs:comment 'The unit of measure for the condition value (e.g., per kilogram, per piece, per liter, percentage).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionValue rdf:type rdf:Property ;
    rdfs:label 'Condition Value' ;
    rdfs:comment 'The numeric value of the price condition (price per unit, discount percentage, surcharge amount, etc.).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The specific location or port associated with the Incoterms rule (e.g., FOB Shanghai, CIF New York).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'The unit of measure for the minimum order quantity (e.g., EA, KG, L).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Per Unit Quantity' ;
    rdfs:comment 'The quantity basis for the condition value (e.g., price per 100 units, per 1000 kg).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perUnitUom rdf:type rdf:Property ;
    rdfs:label 'Per Unit Uom' ;
    rdfs:comment 'The unit of measure corresponding to the per unit quantity (e.g., EA, KG, L).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDeterminationRule rdf:type rdf:Property ;
    rdfs:label 'Price Determination Rule' ;
    rdfs:comment 'The business rule or formula used to determine the final price when multiple conditions apply (e.g., lowest price, weighted average, last price).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'The origin or method by which this price condition was established (contract, RFQ, supplier catalog, negotiated, spot purchase, market index).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingProcedure rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure' ;
    rdfs:comment 'The pricing procedure schema that determines the sequence and calculation logic for applying this condition.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'The organizational unit responsible for procurement activities under this price condition.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'The basis for tiered pricing scales (none for flat pricing, quantity, value, weight, volume for scale-based pricing).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'The minimum quantity threshold for this price scale tier. Null for non-scaled pricing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'The maximum quantity threshold for this price scale tier. Null for open-ended tiers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleUom rdf:type rdf:Property ;
    rdfs:label 'Scale Uom' ;
    rdfs:comment 'The unit of measure for scale quantity thresholds (e.g., EA, KG, L).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The geographic tax jurisdiction applicable to this price condition (country, state, or local tax authority).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementVmiAgreement2Id rdf:type rdf:Property ;
    rdfs:label 'Procurement Vmi Agreement2 Id' ;
    rdfs:comment 'Primary key for the vmi_agreement association' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementVmiAgreement2 .

ind:procurementVmiAgreementId rdf:type rdf:Property ;
    rdfs:label 'Procurement Vmi Agreement Id' ;
    rdfs:comment 'Unique identifier for the VMI agreement record.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleBuyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Buyer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Flag' ;
    rdfs:comment 'Indicates whether inventory under this VMI agreement is held on consignment, where the supplier retains ownership until consumption by Consumer Goods.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the master procurement contract or purchase agreement that governs the commercial terms underlying this VMI arrangement.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Edi Message Types' ;
    rdfs:comment 'The specific EDI message types used for VMI transactions (e.g., 846 Inventory Inquiry, 852 Product Activity Data, 850 Purchase Order).' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUom rdf:type rdf:Property ;
    rdfs:label 'Inventory Uom' ;
    rdfs:comment 'The unit of measure used for inventory levels in this VMI agreement (e.g., kilograms, liters, pallets, cases, each).' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedLocationCode rdf:type rdf:Property ;
    rdfs:label 'Managed Location Code' ;
    rdfs:comment 'Code identifying the Consumer Goods plant, warehouse, or distribution center where the supplier manages inventory under this VMI agreement.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedLocationName rdf:type rdf:Property ;
    rdfs:label 'Managed Location Name' ;
    rdfs:comment 'Name of the Consumer Goods facility where VMI inventory is managed by the supplier.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialScope rdf:type rdf:Property ;
    rdfs:label 'Material Scope' ;
    rdfs:comment 'Description of the materials, SKUs, or product categories covered under this VMI agreement, defining what the supplier is responsible for replenishing.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxInventoryLevel rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Level' ;
    rdfs:comment 'The maximum inventory quantity allowed at the managed location, defining the upper limit for supplier replenishment to avoid overstocking.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minInventoryLevel rdf:type rdf:Property ;
    rdfs:label 'Min Inventory Level' ;
    rdfs:comment 'The minimum inventory quantity that must be maintained at the managed location, triggering replenishment when stock falls below this threshold.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipTransferTrigger rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Trigger' ;
    rdfs:comment 'The event that triggers transfer of inventory ownership from the supplier to Consumer Goods (e.g., goods receipt, consumption, withdrawal, invoice receipt, or time-based).' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementVmiAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Vmi Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the VMI agreement indicating whether it is in draft, actively managing inventory, suspended, terminated, or expired.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentModel rdf:type rdf:Property ;
    rdfs:label 'Replenishment Model' ;
    rdfs:comment 'The inventory replenishment strategy used by the supplier under this VMI agreement (min/max levels, forecast-driven, consumption-based, kanban, or continuous replenishment).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Rate Target Pct' ;
    rdfs:comment 'The target fill rate percentage the supplier must achieve under this VMI agreement, representing the percentage of demand that must be met from available inventory.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOtifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Otif Target Pct' ;
    rdfs:comment 'The target OTIF percentage the supplier must achieve for VMI replenishments, measuring the percentage of deliveries that arrive on time and in full quantity.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaStockoutToleranceDays rdf:type rdf:Property ;
    rdfs:label 'Sla Stockout Tolerance Days' ;
    rdfs:comment 'The maximum number of days per period that stockouts are tolerated under this VMI agreement before SLA penalties apply.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Email' ;
    rdfs:comment 'Email address of the primary supplier contact for VMI operations.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactName rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Name' ;
    rdfs:comment 'Name of the primary supplier contact responsible for VMI operations and replenishment under this agreement.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactPhone rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Phone' ;
    rdfs:comment 'Phone number of the primary supplier contact for VMI operations and issue escalation.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetInventoryLevel rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Level' ;
    rdfs:comment 'The optimal inventory quantity the supplier should maintain at the managed location, balancing availability and carrying costs.' ;
    rdfs:domain ind:ProcurementVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason for termination if the VMI agreement status is terminated, providing context for the end of the supplier-managed inventory arrangement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Status' ;
    rdfs:comment 'Status of EDI transmission to the supplier. Tracks whether PO was successfully sent via EDI 850, acknowledged via EDI 855, or encountered transmission errors. Critical for automated supplier integration.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionDate rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Date' ;
    rdfs:comment 'Timestamp when the purchase order was transmitted to the supplier via EDI. Used for supplier response time tracking and transmission audit.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Transportation and logistics charges associated with this purchase order. May be supplier-charged or third-party logistics costs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required' ;
    rdfs:comment 'Indicator whether physical goods receipt posting is required for this purchase order. True for materials, false for services or non-stock items. Controls three-way match process.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required' ;
    rdfs:comment 'Indicator whether invoice verification is required before payment. Controls accounts payable workflow and three-way match completion.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order. Used for supplier communication, EDI transactions, and cross-system reference.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks progression from creation through approval, supplier confirmation, goods receipt, and closure. Critical for procurement workflow management and OTIF tracking. [ENUM-REF-CANDIDATE: draft|submitted|approved|confirmed|in_transit|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order based on procurement strategy. Standard for one-time orders, blanket for recurring deliveries against a master agreement, contract for long-term commitments, subcontracting for external manufacturing, consignment for supplier-owned inventory, framework for multi-release agreements.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Confirmation Date' ;
    rdfs:comment 'Timestamp when the supplier confirmed acceptance of the purchase order. Used for supplier responsiveness measurement and order commitment tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Supplier Confirmation Method' ;
    rdfs:comment 'Channel through which the supplier acknowledged the purchase order. EDI 855 for automated acknowledgment, supplier portal for web-based confirmation, email/phone/fax for manual confirmation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiIndicator rdf:type rdf:Property ;
    rdfs:label 'Vmi Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order is part of a VMI program where the supplier manages inventory levels and replenishment. True for VMI orders, false for buyer-managed procurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Identifier of the preferred or recommended supplier for this requisition, based on contracts or sourcing strategy.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'Identifier of the employee who created the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Requesting Cost Center Id' ;
    rdfs:comment 'Identifier of the cost center that initiated the purchase requisition and will bear the expense.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Current approval level in the multi-tier approval workflow (e.g., 1 for manager, 2 for director, 3 for VP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Reference' ;
    rdfs:comment 'Identifier of the approval workflow instance governing this requisition, based on value thresholds and organizational rules.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition (quantity × estimated unit price), used for budget control and approval routing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the requested material or service, used for budgeting and approval thresholds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account number to which the purchase requisition expense will be posted.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_ordered|fully_ordered|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code of the purchasing organization responsible for procuring the requested materials or services.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of material or service units requested in the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted by the requesting department.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the employee who created the requisition, used for notifications and approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the employee who created the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, typically system-generated and externally visible to requesters and procurement teams.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer, service procurement, or third-party order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Required Flag' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet is required for the requested material due to hazardous or regulated chemical content.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Recommended or assigned source for fulfilling the requisition (preferred supplier, existing contract, stock transfer, external procurement, internal production).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Flag' ;
    rdfs:comment 'Indicates whether the requisition is for sustainably sourced materials (FSC-certified, RSPO-certified, or other sustainability standards).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project work breakdown structure element for project-related requisitions, used for project cost tracking.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Id' ;
    rdfs:comment 'Identifier of the supplier selected and awarded the business based on evaluation criteria. Null if RFQ not yet awarded or cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:rfqCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfq Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the RFQ record. Audit trail for accountability and process compliance.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfq Employee Id' ;
    rdfs:comment 'Identifier of the procurement professional responsible for managing this RFQ, coordinating supplier communications, and evaluating responses.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfq Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the RFQ record. Audit trail for change accountability.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Rfq Org Unit Id' ;
    rdfs:comment 'Identifier of the business unit, plant, or department that initiated the sourcing request and will consume the procured materials or services.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:rfqPurchasingOrganizationOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Rfq Purchasing Organization Org Unit Id' ;
    rdfs:comment 'Identifier of the procurement organization responsible for executing the sourcing event and negotiating with suppliers.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the supplier selection decision was finalized and communicated. Marks the transition from evaluation to contracting phase.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardJustification rdf:type rdf:Property ;
    rdfs:label 'Award Justification' ;
    rdfs:comment 'Business rationale for the supplier selection decision. Documents evaluation results, scoring, and strategic considerations for audit and compliance purposes.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'High-level classification of the materials or services being sourced (e.g., raw materials, packaging, indirect goods, services). Aligns with procurement category management structure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySubcategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Subcategory' ;
    rdfs:comment 'Detailed classification within the commodity category (e.g., fragrances, surfactants, bottles, labels, MRO supplies). Enables granular spend analysis and category strategy execution.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total monetary value of the procurement. Used for budget planning, approval routing, and supplier qualification thresholds.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume' ;
    rdfs:comment 'Anticipated quantity or volume of materials or services to be procured. Used by suppliers to calculate economies of scale and pricing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaDeliveryWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Delivery Weight' ;
    rdfs:comment 'Percentage weight assigned to delivery performance (lead time, OTIF history, flexibility) in the supplier evaluation scorecard.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaPriceWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Price Weight' ;
    rdfs:comment 'Percentage weight assigned to price in the supplier evaluation scorecard. Part of multi-criteria decision analysis for supplier selection.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaQualityWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Quality Weight' ;
    rdfs:comment 'Percentage weight assigned to quality factors (certifications, defect rates, compliance) in the supplier evaluation scorecard.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteriaSustainabilityWeight rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria Sustainability Weight' ;
    rdfs:comment 'Percentage weight assigned to sustainability factors (FSC certification, RSPO compliance, carbon footprint, ethical sourcing) in the supplier evaluation scorecard.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresQualityCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Quality Certification' ;
    rdfs:comment 'Indicates whether suppliers must provide quality management system certifications (e.g., ISO 9001, GMP, ISO 22716 for cosmetics).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSds rdf:type rdf:Property ;
    rdfs:label 'Requires Sds' ;
    rdfs:comment 'Indicates whether suppliers must provide Safety Data Sheets for the materials being sourced. Mandatory for chemicals, fragrances, and hazardous substances.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSustainabilityDeclaration rdf:type rdf:Property ;
    rdfs:label 'Requires Sustainability Declaration' ;
    rdfs:comment 'Indicates whether suppliers must provide sustainability certifications or declarations (e.g., FSC for paper/packaging, RSPO for palm oil derivatives, conflict minerals disclosure).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business identifier for the RFQ, externally visible and used in supplier communications and procurement documentation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Draft indicates preparation phase, issued means sent to suppliers, open indicates active response period, closed means submission deadline passed, awarded indicates supplier selected, cancelled means RFQ withdrawn.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on procurement strategy and urgency. Standard for routine sourcing, spot buy for one-time purchases, framework for long-term agreements, emergency for urgent needs, global sourcing for multi-region procurement, strategic for high-value category sourcing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which suppliers must submit their quotations. No responses accepted after this timestamp.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierCountInvited rdf:type rdf:Property ;
    rdfs:label 'Supplier Count Invited' ;
    rdfs:comment 'Number of suppliers invited to participate in this RFQ. Used to assess competitive intensity and sourcing strategy effectiveness.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierCountResponded rdf:type rdf:Property ;
    rdfs:label 'Supplier Count Responded' ;
    rdfs:comment 'Number of suppliers who submitted quotations by the deadline. Used to calculate response rate and assess market interest.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalSpecificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Document Url' ;
    rdfs:comment 'Reference to the detailed technical specification document shared with suppliers. Contains material requirements, quality standards, packaging specifications, and testing protocols.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfq Response Id' ;
    rdfs:comment 'Unique identifier for the RFQ response record. Primary key.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedFlag rdf:type rdf:Property ;
    rdfs:label 'Awarded Flag' ;
    rdfs:comment 'Indicates whether this RFQ response was awarded the business.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Name of the supplier contact person who submitted the response.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Specified delivery location or plant code for the quoted materials.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Procurement teams evaluation score for this response based on defined criteria.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management certifications held by the supplier (e.g., ISO 9001, GMP, ISO 22716).' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quoted Lead Time Days' ;
    rdfs:comment 'Number of days from order placement to delivery as quoted by the supplier.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Unit price quoted by the supplier for the requested material or service.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Additional notes or comments provided by the supplier with the quotation response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'Business identifier for the RFQ response, typically assigned by the supplier or procurement system.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Available Flag' ;
    rdfs:comment 'Indicates whether the supplier can provide a sample for evaluation.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sample Lead Time Days' ;
    rdfs:comment 'Number of days required to provide a sample if available.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Provided Flag' ;
    rdfs:comment 'Indicates whether the supplier has provided a Safety Data Sheet with the response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the supplier submitted the RFQ response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalSpecificationCompliance rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Compliance' ;
    rdfs:comment 'Suppliers declared compliance level with the technical specifications in the RFQ.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'Total amount quoted for the entire RFQ line item or package.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Warranty period offered by the supplier in months.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Unique identifier for the sourcing event. Primary key.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySourcingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Employee Id' ;
    rdfs:comment 'Identifier of the procurement professional or category manager responsible for managing this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardedSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Savings Amount' ;
    rdfs:comment 'Actual savings amount achieved based on awarded supplier bids compared to baseline spend. Null until event is awarded.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Spend Amount' ;
    rdfs:comment 'Historical or current annual spend amount for the commodity or category being sourced, used as the baseline for calculating savings. Expressed in the reporting currency.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidCloseDate rdf:type rdf:Property ;
    rdfs:label 'Bid Close Date' ;
    rdfs:comment 'Date when the bidding window closes and no further supplier responses are accepted.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidOpenDate rdf:type rdf:Property ;
    rdfs:label 'Bid Open Date' ;
    rdfs:comment 'Date when the bidding window opens and suppliers can begin submitting responses.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveBiddingFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Bidding Flag' ;
    rdfs:comment 'Indicates whether this sourcing event involves competitive bidding among multiple suppliers (true) or is a sole-source/single-source procurement (false).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventOutcome rdf:type rdf:Property ;
    rdfs:label 'Event Outcome' ;
    rdfs:comment 'Final outcome of the sourcing event: awarded (supplier selected), no_award (no suitable bids), cancelled (event terminated), extended (timeline extended), or rebid (reissued).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementOrganization rdf:type rdf:Property ;
    rdfs:label 'Procurement Organization' ;
    rdfs:comment 'Procurement organization or business unit conducting the sourcing event (e.g., \'Global Procurement\', \'Regional Procurement - EMEA\', \'Category Management - Raw Materials\').' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'Date when the sourcing event was published and made available to invited suppliers.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soleSourceJustification rdf:type rdf:Property ;
    rdfs:label 'Sole Source Justification' ;
    rdfs:comment 'Business justification for sole-source or single-source procurement when competitive bidding is not used. Required for audit and compliance purposes.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Spend Category Code' ;
    rdfs:comment 'Standardized spend category classification code used for procurement analytics and reporting. Links to enterprise spend taxonomy.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicInitiativeFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative Flag' ;
    rdfs:comment 'Indicates whether this sourcing event is part of a strategic procurement initiative or transformation program (e.g., supplier consolidation, dual sourcing, regionalization).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppliersAwardedCount rdf:type rdf:Property ;
    rdfs:label 'Suppliers Awarded Count' ;
    rdfs:comment 'Number of suppliers awarded business as a result of this sourcing event. May be greater than 1 for multi-award scenarios.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppliersInvitedCount rdf:type rdf:Property ;
    rdfs:label 'Suppliers Invited Count' ;
    rdfs:comment 'Total number of suppliers invited to participate in the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppliersParticipatedCount rdf:type rdf:Property ;
    rdfs:label 'Suppliers Participated Count' ;
    rdfs:comment 'Number of suppliers who submitted bids or responses to the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria' ;
    rdfs:comment 'Description of specific sustainability requirements or certifications required for this sourcing event (e.g., \'FSC-certified packaging\', \'RSPO-certified palm oil\', \'carbon-neutral shipping\').' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirement Flag' ;
    rdfs:comment 'Indicates whether this sourcing event includes mandatory sustainability criteria such as FSC certification, RSPO compliance, or other environmental/social governance requirements.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Target Savings Amount' ;
    rdfs:comment 'Target cost savings or cost avoidance amount that the sourcing event aims to achieve, expressed in the reporting currency.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Spend Category Id' ;
    rdfs:comment 'Primary key for spend_category' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:categoryOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Category Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the procurement category manager responsible for strategy, supplier relationships, and performance for this category.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentCategorySpendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Spend Category Id' ;
    rdfs:comment 'Reference to the parent spend category in the hierarchical taxonomy. Null for top-level (L1) categories.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:annualSpendBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Budget Amount' ;
    rdfs:comment 'Planned annual procurement spend budget for this category in base currency (USD). Used for budget tracking and variance analysis.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the spend category in procurement systems. Used as the business identifier for category classification and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the spend category scope, including materials, services, and goods covered under this classification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Hierarchical level of the category in the spend taxonomy (L1=top level, L2=sub-category, L3=detailed category, L4=granular classification).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the spend category in the procurement taxonomy (active=in use, inactive=deprecated, under_review=being evaluated, consolidating=merging with other categories, phasing_out=being eliminated).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'High-level classification of the commodity type covered by this category (raw materials, packaging, maintenance/repair/operations, capital expenditure, indirect services, logistics, professional services). [ENUM-REF-CANDIDATE: raw_material|packaging|mro|capex|indirect_service|logistics|professional_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Percentage' ;
    rdfs:comment 'Percentage of category spend covered by formal contracts or pricing agreements (0-100). Higher coverage indicates better spend management.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSavingsTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Savings Target Percentage' ;
    rdfs:comment 'Annual cost reduction target for this category as a percentage of baseline spend. Used for procurement performance management.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDaysTypical rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Typical' ;
    rdfs:comment 'Average procurement lead time in days for materials in this category from purchase order to goods receipt.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moqApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Applicable Flag' ;
    rdfs:comment 'Indicates whether minimum order quantity constraints typically apply to materials in this category.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Preferred Sourcing Strategy' ;
    rdfs:comment 'Recommended sourcing approach for this category (single source, dual source, multi-source, spot buy, strategic partnership, vendor managed inventory, consignment). [ENUM-REF-CANDIDATE: single_source|dual_source|multi_source|spot_buy|strategic_partnership|vmi|consignment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProfile rdf:type rdf:Property ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Supply risk assessment for this category considering supplier concentration, market volatility, geopolitical factors, and regulatory complexity.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Spend Visibility Level' ;
    rdfs:comment 'Classification of spend data visibility and tracking maturity for this category (high=fully tracked and managed, medium=partially tracked, low=limited visibility).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Business criticality classification of this category to operations and product quality (critical=business-critical materials, strategic=high-value/high-risk, tactical=moderate importance, non-critical=low impact).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConsolidationTarget rdf:type rdf:Property ;
    rdfs:label 'Supplier Consolidation Target' ;
    rdfs:comment 'Target number of preferred suppliers for this category as part of supplier rationalization strategy.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainableSourcingFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainable Sourcing Flag' ;
    rdfs:comment 'Indicates whether this category is subject to sustainable sourcing requirements (e.g., FSC-certified paper, RSPO-certified palm oil, conflict-free minerals).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit UNSPSC code for global commodity classification alignment and cross-industry spend benchmarking.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current master supply agreement or contract with the supplier expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Classification indicating if the supplier qualifies as a diverse supplier (e.g., minority-owned, women-owned, veteran-owned, small business).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI identifier or interchange ID used for electronic document exchange with the supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier maintains ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current stage of the supplier onboarding process tracking progress from initial registration through final approval.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Overall performance score for the supplier based on quality, delivery, cost, and service metrics, typically on a 0-100 scale.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk assessment classification for the supplier based on financial stability, geopolitical factors, compliance history, and supply continuity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Rspo Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds RSPO certification for sustainable palm oil sourcing practices.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Internal business identifier or code assigned to the supplier for procurement and ERP system reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'The full legal name of the supplier or vendor organization as registered with governing authorities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship indicating whether the supplier is eligible for procurement activities.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Strategic classification of the supplier indicating their relationship status and procurement priority level with the organization.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on the category of goods or services provided to the business.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number for the supplier (e.g., EIN in USA, VAT number in EU) used for tax reporting and compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract Management process assigns a responsible employee; linking contract_owner to employee enables ownership tracking and compliance reporting.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Total monetary value committed under this contract across all line items and periods, used for spend tracking and budget allocation.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Agreed delivery conditions including lead times, delivery windows, and logistics requirements.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the contract is interpreted and enforced (e.g., State of Delaware, English Law).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Terms defining financial penalties for supplier non-compliance, late delivery, quality failures, or other contractual breaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMechanism rdf:type rdf:Property ;
    rdfs:label 'Pricing Mechanism' ;
    rdfs:comment 'Method by which prices are determined: fixed price for static rates, cost plus for markup on supplier costs, market indexed for commodity-linked pricing, volume tiered for quantity-based discounts, or rebate based for retrospective incentives.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySpecification rdf:type rdf:Property ;
    rdfs:label 'Quality Specification' ;
    rdfs:comment 'Reference to quality standards, specifications, or inspection criteria that supplied materials must meet (e.g., GMP, ISO 9001, internal spec codes).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateTerms rdf:type rdf:Property ;
    rdfs:label 'Rebate Terms' ;
    rdfs:comment 'Description of volume-based or performance-based rebate conditions, including thresholds, percentages, and settlement periods.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to expiry that either party must provide notice to prevent auto-renewal or initiate renewal negotiations.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetQuantityTotal rdf:type rdf:Property ;
    rdfs:label 'Target Quantity Total' ;
    rdfs:comment 'Aggregate quantity commitment across all materials and line items over the contract period, used for volume-based pricing and rebate calculations.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Unique identifier for the supplier invoice record. Primary key.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Code' ;
    rdfs:comment 'Code indicating why the invoice is blocked from payment, if applicable. Empty if not blocked.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Description' ;
    rdfs:comment 'Detailed description of the reason the invoice is blocked from payment.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Days' ;
    rdfs:comment 'The number of days within which payment must be made to qualify for the cash discount.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Percentage' ;
    rdfs:comment 'The percentage discount available for early payment per payment terms.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Date' ;
    rdfs:comment 'The date the invoice was received by the organization.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way match validation comparing purchase order, goods receipt, and invoice at header level.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceCheckResult rdf:type rdf:Property ;
    rdfs:label 'Tolerance Check Result' ;
    rdfs:comment 'Indicates whether the invoice passed tolerance checks for price and quantity variances.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the quality manager or procurement director who formally approved the qualification result and authorized the supplier status change.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMaterialCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Material Categories' ;
    rdfs:comment 'Comma-separated list or description of material categories or product types that the supplier is qualified to provide based on this assessment. Examples include raw materials, packaging components, finished goods, indirect materials.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit End Timestamp' ;
    rdfs:comment 'Precise date and time when the audit concluded. Used to calculate total audit duration and resource allocation.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method used to conduct the qualification audit. On-site for physical facility visits, remote for virtual assessments, hybrid for combination, document review for paper-based evaluation, self-assessment for supplier-submitted questionnaires.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Document Reference' ;
    rdfs:comment 'Reference identifier for the detailed audit report document stored in the document management system. Links to the full audit findings, evidence, and supporting documentation.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Description of the areas, processes, and systems covered in the qualification audit. May include manufacturing facilities, quality systems, environmental controls, documentation practices, and specific product categories.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Start Timestamp' ;
    rdfs:comment 'Precise date and time when the on-site or remote audit commenced. Used for detailed audit scheduling and duration tracking.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditorCertification rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification' ;
    rdfs:comment 'Professional certifications held by the lead auditor, such as Certified Quality Auditor (CQA), Lead Auditor ISO 9001, or other relevant credentials.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or assessment team leader who conducted the qualification. May be internal quality personnel or third-party auditor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Organization or company that the auditor represents. May be internal (company name) or external third-party audit firm.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date when all required corrective actions were verified as complete and closed. Null if corrective actions are still open or not required.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the supplier must complete and submit evidence of corrective actions for identified findings. Null if no corrective actions are required.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether the supplier must implement corrective actions to address findings before full qualification is granted. True for conditional qualifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical non-conformances identified during the audit. Critical findings represent severe quality or compliance issues that pose immediate risk and typically result in failed qualification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the supplier demonstrated compliance with Good Manufacturing Practice standards during the qualification audit. Critical for suppliers of ingredients, packaging, and finished goods in regulated consumer goods categories.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Compliant Flag' ;
    rdfs:comment 'Indicates whether the supplier demonstrated compliance with ISO 9001 Quality Management System standards during the qualification audit.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major findings represent significant quality system gaps that require corrective action but may allow conditional qualification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or observations identified during the audit. Minor findings represent opportunities for improvement that do not prevent qualification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic re-qualification or audit. Typically set based on qualification type and risk rating, commonly 1-3 years from current qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of general observations or recommendations noted during the audit that are not formal non-conformances but represent best practice suggestions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Numerical score representing the overall qualification assessment result, typically on a 0-100 scale. Used for supplier performance benchmarking and comparison.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes and comments from the auditor regarding the qualification assessment, including strengths, concerns, special conditions, or context for the qualification decision.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the qualification event. Externally visible reference number used in audit documentation and supplier communications.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationResult rdf:type rdf:Property ;
    rdfs:label 'Qualification Result' ;
    rdfs:comment 'Overall outcome of the qualification assessment. Qualified indicates full approval, conditional indicates approval with corrective actions required, failed indicates supplier did not meet requirements, pending indicates assessment incomplete, not assessed indicates qualification was cancelled or not performed.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of the qualification process. Tracks the workflow state from scheduling through completion.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification assessment being performed. Initial for new supplier onboarding, periodic for scheduled re-assessments, for-cause for triggered audits due to quality issues, re-qualification for suppliers returning after suspension, pre-qualification for preliminary assessment, special for ad-hoc evaluations.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Valid From Date' ;
    rdfs:comment 'Effective start date of the qualification status. Date from which the supplier is considered qualified to supply materials or services.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Valid Until Date' ;
    rdfs:comment 'Expiration date of the qualification status. Date after which the qualification is no longer valid and re-qualification is required. Null for indefinite qualifications pending periodic review.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the supplier demonstrated compliance with applicable regulatory requirements such as FDA, EPA, REACH, or other jurisdiction-specific regulations relevant to the materials or services being qualified.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsDocumentationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Documentation Verified Flag' ;
    rdfs:comment 'Indicates whether the supplier provided complete and compliant Safety Data Sheets for all chemical materials and ingredients. Critical for raw material and packaging suppliers.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria Met Flag' ;
    rdfs:comment 'Indicates whether the supplier met sustainability and responsible sourcing criteria during qualification, including certifications such as FSC, RSPO, or environmental management practices.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierScorecardId rdf:type rdf:Property ;
    rdfs:label 'Supplier Scorecard Id' ;
    rdfs:comment 'Unique identifier for the supplier scorecard record. Primary key.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Employee Id' ;
    rdfs:comment 'Reference to the procurement professional or category manager who conducted the scorecard evaluation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal corrective action plan or performance improvement plan is required based on scorecard results.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCompetitivenessScore rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Score' ;
    rdfs:comment 'Score evaluating supplier pricing competitiveness relative to market benchmarks and alternative suppliers.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationCollaborationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Collaboration Score' ;
    rdfs:comment 'Score evaluating supplier contribution to new product development, process improvements, and collaborative innovation initiatives.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Score' ;
    rdfs:comment 'Normalized score for invoice accuracy performance, weighted to contribute to overall score.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Otif Delivery Rate Pct' ;
    rdfs:comment 'Percentage of purchase orders delivered on time and in full during the evaluation period. Key supply chain reliability metric.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallWeightedScore rdf:type rdf:Property ;
    rdfs:label 'Overall Weighted Score' ;
    rdfs:comment 'Composite weighted score aggregating all KPI scores, typically on a 0-100 scale. Primary metric for supplier performance ranking.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodOverallScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Overall Score' ;
    rdfs:comment 'Overall weighted score from the previous evaluation period, used for trend analysis and performance tracking.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRejectionRatePpm rdf:type rdf:Property ;
    rdfs:label 'Quality Rejection Rate Ppm' ;
    rdfs:comment 'Defect rate measured in parts per million, indicating the number of rejected units per million units received. Critical quality metric.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Normalized score for quality performance based on rejection rates and quality incidents, weighted to contribute to overall score.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Strategic recommendation for supplier relationship management based on scorecard results: maintain current relationship, develop capabilities, monitor closely, escalate issues, or delist supplier.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAdherenceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Adherence Score' ;
    rdfs:comment 'Score evaluating supplier compliance with regulatory requirements including SDS documentation, GMP standards, FDA regulations, EPA requirements, and REACH compliance.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Score evaluating supplier responsiveness to inquiries, requests for quotation, change orders, and issue resolution. Based on response time and communication quality.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Score' ;
    rdfs:comment 'Score evaluating supplier adherence to sustainability requirements including FSC certification, RSPO compliance, environmental standards, and ethical sourcing practices.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Count' ;
    rdfs:comment 'Total number of purchase orders issued to this supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Value' ;
    rdfs:comment 'Total monetary value of purchases from this supplier during the evaluation period, used for spend-weighted analysis.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendVsPriorPeriod rdf:type rdf:Property ;
    rdfs:label 'Trend Vs Prior Period' ;
    rdfs:comment 'Directional indicator showing whether overall performance improved, declined, or remained stable compared to the previous evaluation period.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Most recent audit score for this site, typically on a 0-100 scale, reflecting compliance and quality performance.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the site capacity metric (e.g., units_per_month, pallets, square_meters, kilograms_per_day).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the primary site certifications expire and require renewal. Used for compliance monitoring and supplier audit scheduling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fscCertified rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified' ;
    rdfs:comment 'Indicates whether this site holds FSC certification for sustainable forestry and paper sourcing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22716Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 22716 Certified' ;
    rdfs:comment 'Indicates whether this site holds ISO 22716 Good Manufacturing Practices for Cosmetics certification.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity (e.g., units, cases, pallets, kilograms).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Site Flag' ;
    rdfs:comment 'Indicates whether this site is designated as a preferred sourcing location based on performance, cost, or strategic criteria.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rspoCertified rdf:type rdf:Property ;
    rdfs:label 'Rspo Certified' ;
    rdfs:comment 'Indicates whether this site is certified by RSPO for sustainable palm oil sourcing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCapacity rdf:type rdf:Property ;
    rdfs:label 'Site Capacity' ;
    rdfs:comment 'Maximum production or storage capacity of the site, measured in units relevant to the site type (e.g., units per month for manufacturing, pallets for warehouse).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Internal or supplier-assigned unique code identifying this site location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerName rdf:type rdf:Property ;
    rdfs:label 'Site Manager Name' ;
    rdfs:comment 'Name of the site manager or primary contact person responsible for this location.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Business name or designation of the supplier site facility.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational status of the supplier site in the procurement system.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site based on its primary business function.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabled rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled' ;
    rdfs:comment 'Indicates whether this site participates in a VMI program where the supplier manages inventory levels at the buyer\'s location.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeBom rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom' ;
    rdfs:comment 'Alternative BOM identifier (SAP STLAL) allowing multiple BOM variants for the same material and plant combination. Used to manage seasonal formulations, regional variants, or cost-optimized alternatives within the same SKU.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'Unit of measure for the BOM base quantity (e.g., KG, L, EA, G). Defines the unit in which the finished good is expressed for component ratio calculations. Aligns with SAP base unit of measure (MARA-MEINS) and GS1 unit codes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Category' ;
    rdfs:comment 'SAP BOM category indicating the object type the BOM is assigned to. \'material\' is the standard category for product BOMs in CPG/FMCG. \'equipment\' and \'functional_location\' apply to plant maintenance BOMs. Aligns with SAP STKO-STLTY.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomDescription rdf:type rdf:Property ;
    rdfs:label 'Bom Description' ;
    rdfs:comment 'Human-readable description of the BOM, typically including the product name, formulation variant, and intended use. Used in PLM, engineering change orders, and regulatory documentation.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Indicates the level of the BOM in a multi-level product structure. Level 0 is the finished good, level 1 represents direct components, level 2 represents sub-components, etc. Used for multi-level BOM explosion in MRP and costing roll-ups.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Engineering Change Number (ECN) or Engineering Change Order (ECO) reference that authorized the creation or modification of this BOM version. Provides traceability from BOM changes back to the formal change management process in PLM.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of active component line items in this BOM. Provides a quick indicator of BOM complexity and is used in BOM completeness validation checks during PLM review and quality audits.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costingRelevance rdf:type rdf:Property ;
    rdfs:label 'Costing Relevance' ;
    rdfs:comment 'Indicates whether this BOM is relevant for product costing (COGS calculation and standard cost roll-up). \'relevant\' means the BOM is included in cost estimates, \'not_relevant\' excludes it, \'conditional\' applies under specific costing scenarios. Critical for financial reporting and EBITDA analysis.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this BOM has been flagged for deletion in SAP. A deletion flag marks the BOM as logically deleted without physically removing the record, preserving audit history. Aligns with SAP STKO-LOEKZ.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulationCode rdf:type rdf:Property ;
    rdfs:label 'Formulation Code' ;
    rdfs:comment 'R&D or regulatory formulation code that uniquely identifies the product formula associated with this BOM. Links the manufacturing BOM to the R&D formulation record in Veeva Vault or PLM system. Critical for INCI ingredient declaration and regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether this BOM has been validated as compliant with Good Manufacturing Practice (GMP) standards. Required for health, hygiene, and personal care products. Compliance is verified during quality review before BOM activation.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether this BOM supports variant configuration, allowing different component selections based on product characteristics (e.g., fragrance variant, pack size). Used for configurable products in CPG where a single BOM covers multiple SKU variants.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantom rdf:type rdf:Property ;
    rdfs:label 'Is Phantom' ;
    rdfs:comment 'Indicates whether this BOM represents a phantom assembly — a logical grouping of components that does not physically exist as a stocked item but is used to simplify BOM structures. Phantom assemblies are exploded through in MRP without generating production orders.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'User ID or name of the person who last modified this BOM record. Part of the change audit trail required for GMP, engineering change management, and SOX compliance.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this BOM record in the source system. Used for incremental data loading, change detection, and audit trail maintenance.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'Minimum lot size for which this BOM is valid. BOMs can be lot-size dependent in process manufacturing, where component quantities vary based on batch size. Used in conjunction with lot_size_to to define the valid production quantity range.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'Maximum lot size for which this BOM is valid. Defines the upper bound of the production quantity range for lot-size-dependent BOMs. Null indicates no upper limit.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUom rdf:type rdf:Property ;
    rdfs:label 'Lot Size Uom' ;
    rdfs:comment 'Unit of measure for the lot size range (lot_size_from and lot_size_to). Typically matches the base UOM of the finished good (e.g., KG, L, EA).' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRelevance rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevance' ;
    rdfs:comment 'Indicates whether this BOM is used in Material Requirements Planning (MRP) runs for procurement and production scheduling. When true, MRP will explode this BOM to generate dependent requirements for components and raw materials.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmStatus rdf:type rdf:Property ;
    rdfs:label 'Plm Status' ;
    rdfs:comment 'Current lifecycle state of the BOM as managed in the PLM process. \'draft\' indicates initial creation, \'in_review\' is under engineering/regulatory review, \'approved\' is signed off but not yet released to production, \'active\' is in use for manufacturing, \'obsolete\' is retired, \'superseded\' has been replaced by a newer BOM version.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates whether all chemical substances in this BOM are compliant with EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation. Mandatory for products sold in the European Union.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval for this BOM/formulation. Indicates whether the ingredient composition has been reviewed and approved by relevant regulatory bodies (FDA, EU REACH, CPSC). Required before a BOM can be released to active production status.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemBomCode rdf:type rdf:Property ;
    rdfs:label 'Source System Bom Code' ;
    rdfs:comment 'The native primary key or document number of this BOM record in the originating source system (e.g., SAP internal BOM header key combining MATNR+WERKS+STLAL+STLAN). Enables traceability back to the system of record.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativePriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Priority' ;
    rdfs:comment 'Numeric priority rank within an alternative item group, determining the preferred order of substitution when multiple alternatives exist. Lower numbers indicate higher preference (e.g., 1 = first choice).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomItemCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Item Category' ;
    rdfs:comment 'SAP BOM item category code that controls how the component is procured and managed. Determines whether the item is stocked, non-stocked, variable-size, or a document/text item. [ENUM-REF-CANDIDATE: stock|non_stock|variable_size|document|text|class — promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Flag' ;
    rdfs:comment 'Indicates whether this component is a bulk material that is not individually picked or issued but is consumed from a bulk supply point on the shop floor. Bulk materials are typically excluded from individual goods issue postings.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coProductFlag rdf:type rdf:Property ;
    rdfs:label 'Co Product Flag' ;
    rdfs:comment 'Indicates whether this BOM line represents a co-product or by-product that is produced alongside the primary output. Co-products have positive quantities and receive a portion of the production cost allocation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentCostUsd rdf:type rdf:Property ;
    rdfs:label 'Component Cost Usd' ;
    rdfs:comment 'The standard cost per unit of measure for this component in USD, used for COGS (Cost of Goods Sold) calculation and product costing. Sourced from the material master standard price or moving average price.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Human-readable description of the component material, such as \'HDPE Bottle 500ml Natural\' or \'Fragrance Blend XY-204\'. Used in procurement, quality, and manufacturing documentation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component indicating its role in the manufacturing process. Drives MRP planning logic and COGS categorization. [ENUM-REF-CANDIDATE: raw_material|packaging|semi_finished|finished_good|co_product|by_product — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Fixed Quantity Flag' ;
    rdfs:comment 'Indicates whether the component quantity is fixed regardless of the parent order quantity (True) or scales proportionally with the production order size (False). Fixed quantities are common for setup materials, catalysts, or tooling items.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAlternativeItem rdf:type rdf:Property ;
    rdfs:label 'Is Alternative Item' ;
    rdfs:comment 'Indicates whether this BOM line represents an alternative or substitute component that can be used in place of the primary component. Alternative items are used when the primary component is unavailable, supporting supply continuity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalComponent rdf:type rdf:Property ;
    rdfs:label 'Is Critical Component' ;
    rdfs:comment 'Indicates whether this component is designated as critical to the production of the parent SKU. Critical components trigger priority procurement actions and are subject to enhanced supply chain monitoring and safety stock policies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueMethod rdf:type rdf:Property ;
    rdfs:label 'Issue Method' ;
    rdfs:comment 'The method by which this component is issued from inventory to the production order. Backflush automatically posts consumption upon order confirmation; manual requires explicit goods issue; pick list generates a picking document; kanban uses replenishment signals.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'The number of days before or after the parent order start date that this component must be available. Positive values indicate the component is needed before production start; negative values indicate it is needed after. Used in MRP scheduling.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phantomItemFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Item Flag' ;
    rdfs:comment 'Indicates whether this BOM line represents a phantom assembly — a logical grouping of components that is not physically stocked or produced as a discrete item but is exploded through in MRP planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Number' ;
    rdfs:comment 'The EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) registration number for this chemical component. Required for substances manufactured or imported into the EU above threshold quantities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recursiveBomFlag rdf:type rdf:Property ;
    rdfs:label 'Recursive Bom Flag' ;
    rdfs:comment 'Indicates whether this component itself has a subordinate BOM (i.e., it is a sub-assembly or semi-finished good with its own BOM structure). Used to identify multi-level BOM explosion requirements in MRP planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'The quantity of the component required to produce one unit of the parent SKU at the base quantity defined in the BOM header. Satisfies TRANSACTION_LINE LINE_QUANTITY category. Supports MRP and COGS calculation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'The expected percentage of this component that will be lost or wasted during the manufacturing process. Used to inflate the planned component quantity in MRP runs and COGS calculations. Expressed as a percentage (e.g., 2.5 = 2.5%).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Usage Probability Pct' ;
    rdfs:comment 'The probability (expressed as a percentage, 0–100) that this alternative component will actually be used in production. Used by MRP to calculate weighted component requirements across alternative item groups.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFormulationId rdf:type rdf:Property ;
    rdfs:label 'Product Formulation Id' ;
    rdfs:comment 'Unique surrogate identifier for the formulation master record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductFormulation .

ind:activeIngredientName rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Name' ;
    rdfs:comment 'Name of the primary active ingredient in the formulation (e.g., \'Salicylic Acid\', \'Zinc Pyrithione\', \'Fluoride\'). Required for OTC drug product regulatory filings with FDA and for consumer-facing efficacy claims.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredientPct rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Pct' ;
    rdfs:comment 'Concentration of the primary active ingredient expressed as a weight percentage (w/w%) of the total formulation. Proprietary trade secret data. Governs regulatory classification (OTC drug vs. cosmetic), label claims, and dosage compliance.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Free-text or structured declaration of regulated allergens present in the formulation above threshold concentrations (e.g., EU 26 listed fragrance allergens, FDA major food allergens for food-contact products). Required for consumer safety labeling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Bom Reference Code' ;
    rdfs:comment 'Reference code linking this formulation to the corresponding Bill of Materials (BOM) in SAP S/4HANA PP/MM. Enables traceability between the approved formulation recipe and the manufacturing BOM used for production planning and Material Requirements Planning (MRP).' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorDescription rdf:type rdf:Property ;
    rdfs:label 'Color Description' ;
    rdfs:comment 'Standardized color description of the finished formulation as specified in the quality standard (e.g., \'White to off-white\', \'Clear colorless\', \'Pale yellow\'). Used in visual QC inspection and consumer safety documentation.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationName rdf:type rdf:Property ;
    rdfs:label 'Formulation Name' ;
    rdfs:comment 'Human-readable descriptive name of the formulation as registered in the PLM system (e.g., \'Moisturizing Body Lotion Base v2 - Fragrance Free\'). Used in regulatory submissions, quality documents, and R&D reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationType rdf:type rdf:Property ;
    rdfs:label 'Formulation Type' ;
    rdfs:comment 'Physical form classification of the formulation describing its physicochemical structure. Drives manufacturing process selection, packaging requirements, and stability testing protocols. [ENUM-REF-CANDIDATE: emulsion|solution|suspension|gel|powder|foam|aerosol|solid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceCode rdf:type rdf:Property ;
    rdfs:label 'Fragrance Code' ;
    rdfs:comment 'Proprietary or supplier-assigned code identifying the fragrance ingredient blend used in this formulation. Required for IFRA compliance assessment, allergen declaration, and INCI ingredient listing on product labels.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inciDeclaration rdf:type rdf:Property ;
    rdfs:label 'Inci Declaration' ;
    rdfs:comment 'Full International Nomenclature of Cosmetic Ingredients (INCI) ingredient list for the formulation in descending order of concentration, as required for product label compliance. Sourced from Veeva Vault regulatory submissions.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Declared intended use or application of the formulation (e.g., \'Rinse-off body wash for daily use\', \'Leave-on facial moisturizer\', \'Hard surface disinfectant cleaner\'). Determines regulatory classification pathway and labeling requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrueltyFree rdf:type rdf:Property ;
    rdfs:label 'Is Cruelty Free' ;
    rdfs:comment 'Indicates whether the formulation and its constituent ingredients have not been tested on animals. Supports cruelty-free certification claims and compliance with EU animal testing ban under Cosmetics Regulation 1223/2009.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragranceFree rdf:type rdf:Property ;
    rdfs:label 'Is Fragrance Free' ;
    rdfs:comment 'Indicates whether the formulation contains no added fragrance ingredients. Drives consumer-facing label claims, regulatory declarations, and product positioning for sensitive-skin or hypoallergenic product lines.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegan rdf:type rdf:Property ;
    rdfs:label 'Is Vegan' ;
    rdfs:comment 'Indicates whether the formulation contains no animal-derived ingredients or by-products. Supports consumer-facing vegan label claims and retailer listing requirements for vegan-certified product ranges.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labNotebookReference rdf:type rdf:Property ;
    rdfs:label 'Lab Notebook Reference' ;
    rdfs:comment 'Reference identifier for the electronic laboratory notebook (ELN) entry or physical lab notebook record documenting the original formulation development experiments. Provides scientific traceability for regulatory submissions and IP protection.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which this formulation version was or is scheduled to be retired and replaced by a newer version. Null for currently active formulations. Used in manufacturing planning to manage version transitions.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phMax rdf:type rdf:Property ;
    rdfs:label 'Ph Max' ;
    rdfs:comment 'Maximum acceptable pH value of the formulation as defined in the approved specification. Together with ph_min, defines the pH range tolerance band for quality control (QC) release testing and in-process checks.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phMin rdf:type rdf:Property ;
    rdfs:label 'Ph Min' ;
    rdfs:comment 'Minimum acceptable pH value of the formulation as defined in the approved specification. Used in quality control (QC) testing and stability assessments. pH range is a critical quality attribute (CQA) for consumer safety and product efficacy.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preservativeSystem rdf:type rdf:Property ;
    rdfs:label 'Preservative System' ;
    rdfs:comment 'Description or code identifying the preservative system used in the formulation (e.g., \'Phenoxyethanol/Ethylhexylglycerin\', \'Benzalkonium Chloride\', \'Paraben-free system\'). Critical for regulatory compliance, challenge testing, and consumer safety claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdProjectCode rdf:type rdf:Property ;
    rdfs:label 'Rd Project Code' ;
    rdfs:comment 'Reference code linking this formulation to the originating Research and Development (R&D) / New Product Development (NPD) project in the PLM system. Enables traceability from commercial formulation back to the innovation pipeline.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory product classification determining the applicable compliance framework and submission pathway. Drives FDA, EPA, or CPSC filing requirements and labeling obligations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Stability Period Months' ;
    rdfs:comment 'Approved shelf-life stability period of the formulation expressed in months, as determined by accelerated and real-time stability studies. Drives product expiry date calculation, FEFO inventory management, and label \'best before\' declarations.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Specified storage conditions required to maintain formulation integrity and stability (e.g., \'Store below 25°C, away from direct sunlight\', \'Refrigerate at 2-8°C\'). Used in warehouse management (WMS), logistics planning, and label compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSolidContentPct rdf:type rdf:Property ;
    rdfs:label 'Total Solid Content Pct' ;
    rdfs:comment 'Total solid content of the formulation expressed as weight percentage (w/w%). Key physical property used in manufacturing process design, packaging compatibility assessment, and stability testing protocols.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityMaxCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Max Cps' ;
    rdfs:comment 'Maximum acceptable viscosity of the formulation measured in centipoise (cPs) at the specified test temperature. Together with viscosity_min_cps, defines the viscosity tolerance band for quality control (QC) release and in-process testing.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityMinCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Min Cps' ;
    rdfs:comment 'Minimum acceptable viscosity of the formulation measured in centipoise (cPs) at the specified test temperature. Critical quality attribute (CQA) governing product texture, pourability, and consumer experience. Used in QC release testing.' ;
    rdfs:domain ind:ProductFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFormulationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Product Formulation Ingredient Id' ;
    rdfs:comment 'Unique surrogate identifier for each ingredient line within a formulation record. Primary key for the formulation_ingredient entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawMaterialSpecId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Spec Id' ;
    rdfs:comment 'Reference to the raw material master record corresponding to this ingredient, linking to procurement and supplier management data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterialSpec .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service (CAS) to every chemical substance. Required for EU REACH registration, SDS documentation, and regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMaxPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Max Pct' ;
    rdfs:comment 'Maximum allowable concentration of the ingredient (% w/w) within the approved formulation range. Critical for safety compliance with regulatory concentration limits (e.g., EU Annex III restricted substances). Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationMinPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Min Pct' ;
    rdfs:comment 'Minimum allowable concentration of the ingredient (% w/w) within the approved formulation range. Used for in-process quality control and batch release decisions. Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationNominalPct rdf:type rdf:Property ;
    rdfs:label 'Concentration Nominal Pct' ;
    rdfs:comment 'Target or nominal concentration of the ingredient expressed as a weight/weight percentage (% w/w) in the finished formulation. Represents the standard manufacturing target. Classified as confidential due to proprietary formulation IP.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationUom rdf:type rdf:Property ;
    rdfs:label 'Concentration Uom' ;
    rdfs:comment 'Unit of measure used to express ingredient concentration values (nominal, min, max). Standard is % w/w (weight by weight) for most cosmetic and personal care formulations; ppm or ppb may apply for trace ingredients or contaminants.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'Seven-digit EC number (EINECS, ELINCS, or NLP list) assigned to chemical substances regulated under EU REACH. Mandatory for REACH registration dossiers and EU market compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Status' ;
    rdfs:comment 'Regulatory status of the ingredient under U.S. FDA regulations. Indicates whether the ingredient is approved, Generally Recognized as Safe (GRAS), permitted with restrictions, or prohibited for use in the applicable product category (cosmetics, OTC drug, food contact).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHazardClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Hazard Classification' ;
    rdfs:comment 'GHS hazard classification codes for this ingredient (e.g., Flam. Liq. 3, Skin Irrit. 2, Aquatic Chronic 1). Drives SDS authoring, workplace safety controls, transport classification, and environmental risk assessment.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeSpecification rdf:type rdf:Property ;
    rdfs:label 'Grade Specification' ;
    rdfs:comment 'Quality grade or purity specification required for this ingredient (e.g., USP, NF, Ph.Eur., cosmetic grade, food grade, technical grade). Defines the minimum quality standard for procurement and incoming quality control.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalStatus rdf:type rdf:Property ;
    rdfs:label 'Halal Status' ;
    rdfs:comment 'Halal certification status of this ingredient, indicating compliance with Islamic dietary and product standards. Required for halal-certified product lines sold in Muslim-majority markets and for halal labeling claims.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Status' ;
    rdfs:comment 'Compliance status of this ingredient against the current IFRA Standards for fragrance materials. Applicable to fragrance ingredients and fragrance-containing raw materials. Non-compliant ingredients require reformulation or removal.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientFunction rdf:type rdf:Property ;
    rdfs:label 'Ingredient Function' ;
    rdfs:comment 'Functional role or purpose of the ingredient within the product formula (e.g., surfactant, preservative, fragrance, colorant, emollient, emulsifier, pH adjuster, solvent, active). Drives regulatory classification and labeling requirements. [ENUM-REF-CANDIDATE: surfactant|preservative|fragrance|colorant|emollient|emulsifier|pH adjuster|solvent|active|thickener|chelating agent|antioxidant — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientName rdf:type rdf:Property ;
    rdfs:label 'Ingredient Name' ;
    rdfs:comment 'Common or trade name of the ingredient as used internally within the organization, which may differ from the INCI name. Used for internal formulation documentation and procurement communication.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientStatus rdf:type rdf:Property ;
    rdfs:label 'Ingredient Status' ;
    rdfs:comment 'Current lifecycle status of this ingredient line within the formulation. Drives PLM workflow gates, regulatory review processes, and manufacturing authorization. Active ingredients are cleared for production use.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveIngredient rdf:type rdf:Property ;
    rdfs:label 'Is Active Ingredient' ;
    rdfs:comment 'Indicates whether this ingredient is classified as an active ingredient (e.g., OTC drug active, sunscreen active, anti-dandruff active) requiring specific regulatory declaration and concentration compliance under FDA OTC monograph or equivalent regulations.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFragranceAllergen rdf:type rdf:Property ;
    rdfs:label 'Is Fragrance Allergen' ;
    rdfs:comment 'Indicates whether this ingredient is a declared fragrance allergen requiring mandatory labeling disclosure under EU Cosmetics Regulation 1223/2009 (Annex III) when present above threshold concentrations (0.001% in rinse-off, 0.01% in leave-on products).' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNaturalOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Natural Origin' ;
    rdfs:comment 'Indicates whether this ingredient is of natural origin as defined by ISO 16128 (Guidelines on definitions and criteria for natural and organic cosmetic ingredients). Supports natural/organic product claims and consumer transparency labeling.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPalmDerived rdf:type rdf:Property ;
    rdfs:label 'Is Palm Derived' ;
    rdfs:comment 'Indicates whether this ingredient is derived from palm oil or palm kernel oil. Triggers RSPO (Roundtable on Sustainable Palm Oil) sourcing compliance requirements and sustainability reporting obligations.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProhibitedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Prohibited Substance' ;
    rdfs:comment 'Indicates whether this ingredient is classified as a prohibited substance under applicable regulations (e.g., EU Cosmetics Regulation Annex II, FDA prohibited ingredients list). Prohibited substances must not appear in finished products.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Substance' ;
    rdfs:comment 'Indicates whether this ingredient is classified as a restricted substance under applicable regulations (e.g., EU Cosmetics Regulation Annex III, IFRA restricted list, EPA restricted chemicals). Restricted substances may be used within defined concentration limits.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naturalOriginIndex rdf:type rdf:Property ;
    rdfs:label 'Natural Origin Index' ;
    rdfs:comment 'Quantitative natural origin index (0.0000 to 1.0000) calculated per ISO 16128-2 methodology, representing the proportion of the ingredient derived from natural sources. Used to compute product-level natural origin index for claims substantiation.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalForm rdf:type rdf:Property ;
    rdfs:label 'Physical Form' ;
    rdfs:comment 'Physical state or form of the ingredient as received from the supplier (e.g., liquid, solid, powder, paste, gel). Relevant for handling, storage, and manufacturing process design. [ENUM-REF-CANDIDATE: liquid|solid|powder|paste|gel|emulsion|suspension|gas — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Status' ;
    rdfs:comment 'Registration status of this ingredient under EU REACH Regulation (EC) No 1907/2006. Indicates whether the substance has been registered with ECHA, is pre-registered, exempt from registration, or registration is pending. Mandatory for EU market access.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Reference' ;
    rdfs:comment 'Citation of the specific regulatory provision or standard that establishes the maximum concentration limit for this ingredient (e.g., \'EU Cosmetics Reg. 1223/2009 Annex III Entry 98\', \'FDA 21 CFR 352.10\'). Provides audit traceability for compliance decisions.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMaxConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Regulatory Max Concentration Pct' ;
    rdfs:comment 'Maximum concentration limit (% w/w) for this ingredient as mandated by applicable regulations (e.g., EU Cosmetics Regulation Annex III, FDA OTC monograph limits, IFRA usage limits). Formulation concentration_max_pct must not exceed this value.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Document reference number for the Safety Data Sheet (SDS) associated with this ingredient, as maintained in the document management system (Veeva Vault). Required under OSHA Hazard Communication Standard (HCS) 29 CFR 1910.1200 and EU REACH.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsVersion rdf:type rdf:Property ;
    rdfs:label 'Sds Version' ;
    rdfs:comment 'Version identifier of the Safety Data Sheet currently associated with this ingredient. Ensures traceability to the correct SDS revision used during formulation approval and manufacturing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcFlag rdf:type rdf:Property ;
    rdfs:label 'Svhc Flag' ;
    rdfs:comment 'Indicates whether this ingredient is listed as a Substance of Very High Concern (SVHC) on the ECHA Candidate List under EU REACH Article 59. SVHC presence above 0.1% w/w in articles triggers communication and notification obligations.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veganStatus rdf:type rdf:Property ;
    rdfs:label 'Vegan Status' ;
    rdfs:comment 'Vegan classification of this ingredient, indicating whether it is free from animal-derived components. Supports vegan product claims, certification (e.g., The Vegan Society), and consumer labeling requirements.' ;
    rdfs:domain ind:ProductFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Unique surrogate primary key for each GTIN registry record in the Databricks Silver layer. Assigned by the platform upon ingestion from SAP S/4HANA MM or GS1 registration source.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which the GTIN was activated and made available for commercial use, EDI transactions, and retailer catalog publication. May differ from assignment_date when a GTIN is pre-assigned during NPD but activated at product launch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:barcodeSymbology rdf:type rdf:Property ;
    rdfs:label 'Barcode Symbology' ;
    rdfs:comment 'The barcode symbology used to encode this GTIN on the physical product or packaging (e.g., UPC-A for consumer units, ITF-14 for cases, GS1-128 for logistic labels). Determines scanner compatibility at POS, warehouse, and DSD delivery points. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|GS1_DataBar|QR_Code — promote to reference product]' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwnerGln rdf:type rdf:Property ;
    rdfs:label 'Brand Owner Gln' ;
    rdfs:comment 'The 13-digit GS1 Global Location Number (GLN) identifying the legal entity that owns the brand and is responsible for the GTIN assignment. Required for GS1 Data Source (1WorldSync/Salsify) product data syndication and retailer onboarding.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casesPerPallet rdf:type rdf:Property ;
    rdfs:label 'Cases Per Pallet' ;
    rdfs:comment 'The standard number of cases stacked on one pallet (logistic unit). Used for transportation planning, warehouse slotting in Blue Yonder WMS, and pallet-level GTIN-14 assignment. Drives DRP and S&OP capacity calculations in SAP IBP.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The single trailing check digit of the GTIN, calculated using the GS1 modulo-10 algorithm. Used to validate GTIN integrity during barcode scanning, EDI processing, and retailer catalog ingestion. Stored explicitly to support validation workflows.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPoolPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Data Pool Publication Date' ;
    rdfs:comment 'The date on which the product data for this GTIN was first published to the GS1 data pool (GDSN). Used to track compliance with retailer new item setup timelines and GS1 sunrise date requirements.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPoolPublished rdf:type rdf:Property ;
    rdfs:label 'Data Pool Published' ;
    rdfs:comment 'Indicates whether the full product data record for this GTIN has been published to a GS1-certified data pool (e.g., 1WorldSync, Salsify) for retailer catalog synchronization. True = published and available to subscribers; False = not yet published.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eanValue rdf:type rdf:Property ;
    rdfs:label 'Ean Value' ;
    rdfs:comment 'The 13-digit EAN-13 barcode value used for international retail scanning and cross-border trade. Populated when gtin_format is GTIN-13. Required for EU, APAC, and LATAM retailer catalog submissions and EDI transactions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediEligible rdf:type rdf:Property ;
    rdfs:label 'Edi Eligible' ;
    rdfs:comment 'Indicates whether this GTIN is set up and approved for EDI transactions (850 Purchase Order, 856 ASN, 832 Price/Sales Catalog) with trading partners. False when the GTIN is pending retailer item setup or has failed EDI validation. Managed in SAP S/4HANA SD and Oracle Cloud EDI.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpcBrickCode rdf:type rdf:Property ;
    rdfs:label 'Gpc Brick Code' ;
    rdfs:comment 'The 8-digit GS1 Global Product Classification (GPC) Brick Code that categorizes the product into a standardized product segment, family, class, and brick. Required for GS1 data pool submissions and used by retailers for category management and planogram (POG) optimization.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1CompanyPrefix rdf:type rdf:Property ;
    rdfs:label 'Gs1 Company Prefix' ;
    rdfs:comment 'The GS1-assigned company prefix (6–12 digits) that identifies the brand owner within the GTIN structure. Issued by GS1 US or a GS1 Member Organization. Determines the number of GTINs available to the company and is embedded in every GTIN assigned by the company.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1MemberOrg rdf:type rdf:Property ;
    rdfs:label 'Gs1 Member Org' ;
    rdfs:comment 'The name of the GS1 Member Organization (e.g., GS1 US, GS1 UK, GS1 Germany) through which the company prefix was licensed. Relevant for multi-national CPG companies that hold prefixes from multiple GS1 member organizations across different markets.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1RegistrationReference rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registration Reference' ;
    rdfs:comment 'The reference number or confirmation identifier issued by GS1 (or a GS1 Member Organization) upon formal registration of this GTIN in the GS1 registry. Used for audit, dispute resolution, and regulatory submissions requiring proof of GS1 registration.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1RegistryPublished rdf:type rdf:Property ;
    rdfs:label 'Gs1 Registry Published' ;
    rdfs:comment 'Indicates whether this GTIN has been published to the GS1 Registry Platform (formerly GEPIR) and is visible to trading partners and retailers for catalog synchronization. True = published; False = not yet published or withheld.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtinFormat rdf:type rdf:Property ;
    rdfs:label 'Gtin Format' ;
    rdfs:comment 'Identifies the GTIN format variant: GTIN-8 (EAN-8 short barcode), GTIN-12 (UPC-A, North American standard), GTIN-13 (EAN-13, international standard), or GTIN-14 (ITF-14, used for cases and pallets). Determines barcode symbology and EDI transaction set usage.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinValue rdf:type rdf:Property ;
    rdfs:label 'Gtin Value' ;
    rdfs:comment 'The full numeric GTIN string including the check digit. Supports GTIN-8, GTIN-12 (UPC-A), GTIN-13 (EAN-13), and GTIN-14 (shipping container/case) formats as defined by GS1 General Specifications. Used in barcode scanning, EDI transactions, and retailer catalog synchronization.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorDigit rdf:type rdf:Property ;
    rdfs:label 'Indicator Digit' ;
    rdfs:comment 'Single leading digit (0–9) used in GTIN-14 to indicate the packaging level of a trade item. A value of 0 indicates a consumer unit; values 1–8 indicate inner packs or cases; value 9 is reserved for variable-measure trade items. Applicable only when gtin_format is GTIN-14.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innerPacksPerCase rdf:type rdf:Property ;
    rdfs:label 'Inner Packs Per Case' ;
    rdfs:comment 'The number of inner packs (display shippers or multi-packs) contained within one case. Populated only when an intermediate inner-pack packaging level exists in the hierarchy. Used in SAP S/4HANA MM BOM and GS1 packaging hierarchy declarations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isConsumerUnit rdf:type rdf:Property ;
    rdfs:label 'Is Consumer Unit' ;
    rdfs:comment 'Indicates whether this GTIN represents the consumer-facing sellable unit (each/each pack) as opposed to an inner pack, case, or pallet. True = consumer unit eligible for POS scanning; False = logistic/trade unit. Drives OSA monitoring and POS data matching in Nielsen IQ and TradeEdge.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Indicates whether this GTIN is currently eligible to be ordered by retail customers via EDI or Salesforce Consumer Goods Cloud order management. False when the GTIN is retired, pending, or restricted to specific channels.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isScannable rdf:type rdf:Property ;
    rdfs:label 'Is Scannable' ;
    rdfs:comment 'Indicates whether a valid, scannable barcode (UPC/EAN/ITF-14) has been verified and approved for this GTIN. False when the barcode artwork is pending verification or has failed GS1 barcode quality verification. Used in retail execution and DSD workflows in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableMeasure rdf:type rdf:Property ;
    rdfs:label 'Is Variable Measure' ;
    rdfs:comment 'Indicates whether this GTIN represents a variable-measure trade item (e.g., catch-weight products sold by weight). True = variable measure; False = fixed measure. Variable-measure GTINs use indicator digit 9 in GTIN-14 and require special POS and EDI handling per GS1 specifications.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Item Reference Number' ;
    rdfs:comment 'The item reference portion of the GTIN, assigned by the brand owner to uniquely identify the product within the company prefix. Together with the company prefix and check digit, it forms the complete GTIN. Sourced from SAP S/4HANA MM material master EAN/UPC segment.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentUom rdf:type rdf:Property ;
    rdfs:label 'Net Content Uom' ;
    rdfs:comment 'The unit of measure for the net content value (e.g., ml, L, g, kg, oz, fl_oz, ct, ea). Required for FDA label compliance, GS1 data pool submissions, and retailer catalog item setup. Follows GS1 Recommendation on Unit of Measure codes. [ENUM-REF-CANDIDATE: ml|L|g|kg|oz|fl_oz|ct|ea — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'The numeric net content quantity of the consumer unit (e.g., 400 for a 400ml shampoo bottle). Combined with net_content_uom to express the full net content declaration required on product labels per FDA and FTC labeling regulations.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'Identifies the packaging hierarchy level to which this GTIN is assigned: each (consumer unit), inner pack (multi-pack or display shipper), case (master carton), or pallet (logistic unit). Drives EDI order management, warehouse scanning, and DRP/MRP planning in SAP S/4HANA and Blue Yonder WMS.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Plm Lifecycle Stage' ;
    rdfs:comment 'The current PLM lifecycle stage of the product associated with this GTIN: concept, development, commercialization, active (in market), end_of_life (phase-out initiated), or discontinued. Sourced from the PLM system and used to govern GTIN activation, EDI eligibility, and retailer catalog status.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the GTIN registration: active (in use and published to trading partners), pending (assigned but not yet published), inactive (temporarily suspended), retired (permanently discontinued), or cancelled (assigned in error and voided). Governs EDI eligibility and retailer catalog synchronization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date on which the GTIN was retired or discontinued from active commercial use. Per GS1 GTIN Management Standard, a retired GTIN must not be reassigned for a minimum of 48 months. Null when the GTIN is still active.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural key or internal identifier of this GTIN record in the originating source system (e.g., SAP material number + EAN category combination). Used for delta-load reconciliation, deduplication, and lineage tracing in the Databricks Silver layer ingestion pipeline.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketCountry rdf:type rdf:Property ;
    rdfs:label 'Target Market Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market for which this GTIN is intended. A single SKU may have different GTINs for different target markets due to regulatory labeling, language, or formulation differences. Used in GS1 data pool syndication and Veeva Vault regulatory submissions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerCase rdf:type rdf:Property ;
    rdfs:label 'Units Per Case' ;
    rdfs:comment 'The number of consumer units (eaches) contained within one case (master carton). Used in SAP S/4HANA MM for BOM/packaging hierarchy, DRP/MRP planning, and EDI order quantity validation. Also referenced in Blue Yonder WMS for receiving and putaway.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upcValue rdf:type rdf:Property ;
    rdfs:label 'Upc Value' ;
    rdfs:comment 'The 12-digit UPC-A barcode value assigned to the consumer unit (each). Derived from the GTIN-12 and used primarily for North American retail POS scanning and retailer item setup. Populated only when gtin_format is GTIN-12.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelSpecId rdf:type rdf:Property ;
    rdfs:label 'Label Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for each label specification record. Primary key for the label_spec data product in the product domain.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artworkFileReference rdf:type rdf:Property ;
    rdfs:label 'Artwork File Reference' ;
    rdfs:comment 'Document management system reference or file path to the approved artwork file for this label specification (e.g., Veeva Vault document ID or DAM asset reference). Links label spec to the physical artwork asset.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodePlacement rdf:type rdf:Property ;
    rdfs:label 'Barcode Placement' ;
    rdfs:comment 'Specification of the physical placement zone for the barcode on the label or packaging (e.g., \'bottom-right back panel\', \'base of container\'). Ensures retail scanner readability and planogram compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'Type of barcode symbology specified for placement on the label (e.g., UPC-A, EAN-13, ITF-14, GS1-128, QR Code, DataMatrix). Governs scanner compatibility at retail POS and logistics. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|QR_Code|DataMatrix — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationMarks rdf:type rdf:Property ;
    rdfs:label 'Certification Marks' ;
    rdfs:comment 'Third-party certification marks and logos authorized for display on this label (e.g., \'USDA Organic\', \'NSF Certified\', \'Leaping Bunny\', \'RSPO\', \'FSC\', \'CE Mark\'). Subject to certification body licensing requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimText rdf:type rdf:Property ;
    rdfs:label 'Claim Text' ;
    rdfs:comment 'Marketing and regulatory claims printed on the label (e.g., \'Dermatologist Tested\', \'Cruelty-Free\', \'Hypoallergenic\', \'Organic\', \'Clinically Proven\'). Subject to FTC advertising substantiation requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color management profile and ink specification for the label (e.g., \'CMYK + 2 Pantone\', \'Pantone 485C + Black\'). Ensures brand color consistency across print runs and suppliers.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWatermarkEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Watermark Enabled' ;
    rdfs:comment 'Indicates whether a digital watermark (e.g., GS1 Digital Link, Digimarc) is embedded in the label artwork to support connected packaging, consumer engagement, and supply chain traceability.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributorName rdf:type rdf:Property ;
    rdfs:label 'Distributor Name' ;
    rdfs:comment 'Legal name of the distributor or importer as printed on the label, where different from the manufacturer. Required in markets where the responsible party is the local distributor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientDeclarationText rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration Text' ;
    rdfs:comment 'Full ingredient declaration text as it appears on the label, including INCI (International Nomenclature of Cosmetic Ingredients) names for cosmetics or common/scientific names for food and household products. Mandatory for regulatory compliance.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryLabel rdf:type rdf:Property ;
    rdfs:label 'Is Primary Label' ;
    rdfs:comment 'Indicates whether this label specification is the primary (master) label for the SKU-market-language combination, as opposed to a supplementary or promotional label variant.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Label Approval Date' ;
    rdfs:comment 'Date on which the label specification received final regulatory and quality approval, authorizing use in production. Key milestone in the PLM artwork approval workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelDimensions rdf:type rdf:Property ;
    rdfs:label 'Label Dimensions' ;
    rdfs:comment 'Physical dimensions of the label (width x height in mm, e.g., \'120x80mm\'). Required for print production specifications and packaging line setup.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'Version number of the label specification (e.g., 1.0, 2.1, 3.0). Used to track label revisions and manage artwork lifecycle in PLM and Veeva Vault.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCodeFormat rdf:type rdf:Property ;
    rdfs:label 'Lot Code Format' ;
    rdfs:comment 'Format specification for the lot/batch code printed on the label (e.g., \'YYYYMMDD-XXXX\', \'Julian date + shift code\'). Enables product traceability and recall management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryRegulatoryStatements rdf:type rdf:Property ;
    rdfs:label 'Mandatory Regulatory Statements' ;
    rdfs:comment 'Concatenated text of all mandatory regulatory statements required by the applicable regulatory framework (e.g., FDA required statements, EU mandatory disclosures, CPSC safety notices). Stored as structured text for label artwork population.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Full address of the manufacturer or responsible party as printed on the label. Mandatory for consumer contact and regulatory traceability in most jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the market or country for which this label specification is valid (e.g., USA, GBR, DEU, FRA). Supports multi-market regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentDeclaration rdf:type rdf:Property ;
    rdfs:label 'Net Content Declaration' ;
    rdfs:comment 'Net content statement as printed on the label, including quantity and unit of measure (e.g., \'500 mL\', \'16 fl oz (473 mL)\', \'250 g\'). Mandatory per weights and measures regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionFactsRequired rdf:type rdf:Property ;
    rdfs:label 'Nutrition Facts Required' ;
    rdfs:comment 'Indicates whether a Nutrition Facts panel or equivalent nutritional information table is required on this label per applicable regulatory framework. Applies to food, beverage, and dietary supplement categories.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Plm Change Order Number' ;
    rdfs:comment 'Change order or engineering change notice (ECN) number from the PLM system that authorized this label specification version. Provides traceability to the formal change management process.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printProcess rdf:type rdf:Property ;
    rdfs:label 'Print Process' ;
    rdfs:comment 'Printing technology specified for producing this label (e.g., flexographic, digital, offset, gravure, screen). Determines supplier qualification and color reproduction requirements.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingSymbolCode rdf:type rdf:Property ;
    rdfs:label 'Recycling Symbol Code' ;
    rdfs:comment 'Recycling and environmental symbol codes required on the label (e.g., Mobius loop resin identification code, Green Dot, Tidyman, FSC logo). Supports sustainability compliance and consumer communication.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Number' ;
    rdfs:comment 'Product registration or notification number assigned by the regulatory authority for the target market (e.g., FDA Facility Registration, EU Cosmetic Product Notification Portal reference, CPNP number). Required on label in certain markets.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeStatement rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Statement' ;
    rdfs:comment 'Shelf life or best-before/expiry date format statement as printed on the label (e.g., \'Best Before: see base\', \'Use By: MM/YYYY\', \'PAO 12M\'). Supports FEFO inventory management and consumer safety.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateMaterial rdf:type rdf:Property ;
    rdfs:label 'Substrate Material' ;
    rdfs:comment 'Material specification for the label substrate (e.g., \'White BOPP\', \'Kraft Paper\', \'Clear PET\', \'Foil\'). Drives procurement of label stock and sustainability reporting.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageInstructions rdf:type rdf:Property ;
    rdfs:label 'Usage Instructions' ;
    rdfs:comment 'Directions for use as printed on the label (e.g., application method, dosage, frequency, preparation instructions). Required for regulated product categories and consumer safety.' ;
    rdfs:domain ind:LabelSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningStatements rdf:type rdf:Property ;
    rdfs:label 'Warning Statements' ;
    rdfs:comment 'All warning and precautionary statements required on the label (e.g., \'Keep out of reach of children\', \'Flammable\', allergen warnings, GHS hazard statements). Mandatory for consumer safety compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Pack Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the pack hierarchy record. Primary key.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Quantity' ;
    rdfs:comment 'The total number of consumer units (eaches) contained in this packaging level. For a case containing 6 inner packs of 12 eaches, this would be 72.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Display Ready Flag' ;
    rdfs:comment 'Indicates whether this packaging level is designed as a retail-ready display unit that can be placed directly on the sales floor without unpacking.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment 'The 13-digit EAN barcode identifier for this packaging level, used internationally for consumer units.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiCount rdf:type rdf:Property ;
    rdfs:label 'Hi Count' ;
    rdfs:comment 'The number of layers stacked on a pallet (Hi in Ti-Hi configuration). Used for pallet configuration and warehouse planning.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStackHeight rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height' ;
    rdfs:comment 'The maximum number of units of this packaging level that can be safely stacked vertically.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this packaging level can be ordered by customers or retailers through EDI or other ordering systems.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packHierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Hierarchy Status' ;
    rdfs:comment 'The current lifecycle status of this pack hierarchy configuration: active (in use), inactive (temporarily suspended), pending (awaiting approval), or discontinued (permanently retired).' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterial rdf:type rdf:Property ;
    rdfs:label 'Packaging Material' ;
    rdfs:comment 'The primary material used for packaging at this level: corrugated cardboard, plastic, wood, metal, composite, or shrink wrap.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletType rdf:type rdf:Property ;
    rdfs:label 'Pallet Type' ;
    rdfs:comment 'The type of pallet used for this packaging level: standard (48x40 inches), euro (1200x800 mm), block, custom, half, or quarter pallet.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerLevel rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Level' ;
    rdfs:comment 'The number of units from the next lower hierarchy level contained in this level (e.g., 12 eaches per inner pack, 6 inner packs per case).' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether the packaging material at this level is recyclable according to local recycling standards.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recycledContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percentage' ;
    rdfs:comment 'The percentage of recycled material content in the packaging at this level, supporting sustainability reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippableFlag rdf:type rdf:Property ;
    rdfs:label 'Shippable Flag' ;
    rdfs:comment 'Indicates whether this packaging level is suitable for direct shipment to customers or distribution centers.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this packaging level can be safely stacked on top of similar units during storage and transportation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'The weight of the packaging materials only at this level, excluding product content, measured in kilograms.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tiCount rdf:type rdf:Property ;
    rdfs:label 'Ti Count' ;
    rdfs:comment 'The number of cases or units per layer on a pallet (Ti in Ti-Hi configuration). Used for pallet configuration and warehouse planning.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCubicCm rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Cm' ;
    rdfs:comment 'The cubic volume of the packaging at this level, measured in cubic centimeters. Used for warehouse slotting and transportation cube optimization.' ;
    rdfs:domain ind:PackHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productPackagingSpecId rdf:type rdf:Property ;
    rdfs:label 'Product Packaging Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for each packaging specification record. One record represents one packaging level for one SKU. MASTER_RESOURCE role — primary key.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artworkRef rdf:type rdf:Property ;
    rdfs:label 'Artwork Ref' ;
    rdfs:comment 'Reference code linking to the approved artwork file for this packaging specification in the digital asset management or PLM system. Ensures the correct print-ready artwork version is used in production.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Primary color of the packaging component as specified in the brand design brief (e.g., \'Pantone 485 C Red\', \'White\', \'Transparent\'). Used for brand compliance, print production, and planogram visual merchandising.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finish rdf:type rdf:Property ;
    rdfs:label 'Finish' ;
    rdfs:comment 'Surface finish specification of the packaging component. Impacts print quality, consumer perception, and manufacturing process selection. [ENUM-REF-CANDIDATE: gloss|matte|satin|soft_touch|metallic|frosted|clear — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightG rdf:type rdf:Property ;
    rdfs:label 'Gross Weight G' ;
    rdfs:comment 'Total weight of the packaging component including product contents in grams. Used for freight cost calculations, transportation planning, and customs documentation.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightMm rdf:type rdf:Property ;
    rdfs:label 'Height Mm' ;
    rdfs:comment 'External height dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, Ti-Hi pallet configuration, and transportation cube optimization.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hi rdf:type rdf:Property ;
    rdfs:label 'Hi' ;
    rdfs:comment 'Number of tiers (layers) stacked on a pallet — the \'Hi\' component of the Ti-Hi pallet configuration. Combined with Ti to determine total units per pallet for DRP/MRP and transportation planning.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFscCertified rdf:type rdf:Property ;
    rdfs:label 'Is Fsc Certified' ;
    rdfs:comment 'Indicates whether the packaging material is sourced from FSC-certified forests or recycled sources. Required for sustainability claims, retailer compliance programs, and ESG reporting.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRspoCertified rdf:type rdf:Property ;
    rdfs:label 'Is Rspo Certified' ;
    rdfs:comment 'Indicates whether palm oil-derived materials in the packaging component are RSPO-certified. Relevant for packaging components containing palm-based inks, coatings, or adhesives. Supports ESG and sustainability reporting.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthMm rdf:type rdf:Property ;
    rdfs:label 'Length Mm' ;
    rdfs:comment 'External length dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, transportation cube optimization, and retailer shelf-space calculations.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary material(s) used in the packaging component (e.g., HDPE, PET, glass, paperboard, aluminum, polypropylene, PCR blend). Supports sustainability reporting, EPR compliance, and plastic tax calculations. [ENUM-REF-CANDIDATE: HDPE|PET|glass|paperboard|aluminum|polypropylene|PCR_blend|cardboard|bioplastic — promote to reference product]' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrContentPct rdf:type rdf:Property ;
    rdfs:label 'Pcr Content Pct' ;
    rdfs:comment 'Percentage of post-consumer recycled material in the packaging component by weight (0.00–100.00). Critical for sustainability reporting, EPR obligations, and plastic tax compliance across EU and US jurisdictions.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:printMethod rdf:type rdf:Property ;
    rdfs:label 'Print Method' ;
    rdfs:comment 'Printing technology used to apply graphics and text to the packaging component. Determines supplier capability requirements, cost structure, and minimum order quantities. [ENUM-REF-CANDIDATE: flexography|offset_lithography|digital|gravure|screen_printing|hot_stamping|label — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qtyPerParent rdf:type rdf:Property ;
    rdfs:label 'Qty Per Parent' ;
    rdfs:comment 'Number of units of this packaging level contained within the next higher packaging level (e.g., 12 eaches per case, 48 cases per pallet). Core input for DRP/MRP quantity calculations and order processing.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclabilityCode rdf:type rdf:Property ;
    rdfs:label 'Recyclability Code' ;
    rdfs:comment 'How2Recycle label code assigned to this packaging component indicating recyclability instructions for consumers (e.g., \'Widely Recycled\', \'Check Locally\', \'Not Yet Recycled\'). Required for EPR compliance and sustainability reporting.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this packaging specification within the PLM or ERP system. Used for cross-system reference and EDI communication.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name describing this packaging specification (e.g., \'500ml HDPE Bottle Primary Pack — SKU XYZ\'). Used in PLM, procurement, and supplier communications.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierToolingRef rdf:type rdf:Property ;
    rdfs:label 'Supplier Tooling Ref' ;
    rdfs:comment 'Supplier-assigned tooling or mold reference number for this packaging component. Used to track proprietary tooling ownership, maintenance schedules, and supplier change management in procurement.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightG rdf:type rdf:Property ;
    rdfs:label 'Tare Weight G' ;
    rdfs:comment 'Weight of the empty packaging component without product contents in grams. Used for net weight labeling compliance, material cost calculations, and sustainability reporting on packaging material mass.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ti rdf:type rdf:Property ;
    rdfs:label 'Ti' ;
    rdfs:comment 'Number of cases or units per tier (layer) on a pallet — the \'Ti\' component of the Ti-Hi pallet configuration. Used for warehouse slotting, transportation cube optimization, and retailer receiving compliance.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widthMm rdf:type rdf:Property ;
    rdfs:label 'Width Mm' ;
    rdfs:comment 'External width dimension of the packaging component in millimeters. Used for planogram compliance, warehouse slotting, and transportation cube optimization.' ;
    rdfs:domain ind:ProductPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmTransitionId rdf:type rdf:Property ;
    rdfs:label 'Plm Transition Id' ;
    rdfs:comment 'Unique surrogate identifier for each PLM stage transition event record. Primary key of the plm_transition table.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Reference to the brand under which the SKU or formulation is being developed or managed. Supports brand-level NPD pipeline reporting and portfolio analytics.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerGoods .

ind:primaryPlmEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Plm Employee Id' ;
    rdfs:comment 'Reference to the internal user (employee or system account) who initiated or triggered this lifecycle stage transition. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'The formal approval document number, change control reference, or gate review authorization code associated with this transition. Used for cross-referencing with quality management and regulatory submission records in Veeva Vault.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromStageCode rdf:type rdf:Property ;
    rdfs:label 'From Stage Code' ;
    rdfs:comment 'The PLM lifecycle stage from which the SKU or formulation is transitioning. Standard stage codes: Ideation, Concept, Feasibility, Development, Pilot, Scale-Up, Launch, Active, Renovation, Discontinuation, Archived. [ENUM-REF-CANDIDATE: Ideation|Concept|Feasibility|Development|Pilot|Scale-Up|Launch|Active|Renovation|Discontinuation|Archived — promote to reference product]' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaDetail rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Detail' ;
    rdfs:comment 'Detailed breakdown of individual gate criteria evaluation results, capturing which specific criteria passed, failed, or were waived during the stage-gate review. Supports granular NPD governance reporting.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaValidationResult rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Validation Result' ;
    rdfs:comment 'Overall outcome of the gate criteria checklist validation performed at the stage-gate review. Pass: all mandatory criteria met; Conditional Pass: approved with conditions or waivers; Fail: one or more mandatory criteria not met; Not Evaluated: gate review not yet conducted.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Gate Review Notes' ;
    rdfs:comment 'Structured or free-text notes recorded during the stage-gate review meeting, capturing key decisions, conditions of approval, open action items, and reviewer commentary. Provides the qualitative audit trail for NPD governance.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFastTrack rdf:type rdf:Property ;
    rdfs:label 'Is Fast Track' ;
    rdfs:comment 'Indicates whether this lifecycle transition was processed under an expedited or fast-track NPD process, bypassing standard gate review timelines. Common for regulatory-driven reformulations or urgent market responses.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'The reference number or docket identifier for the regulatory submission associated with this lifecycle transition (e.g., FDA 510(k) number, EU REACH dossier ID). Populated when regulatory_submission_required is True.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this lifecycle stage transition triggers a mandatory regulatory submission or notification (e.g., FDA pre-market notification, EU REACH registration update, CPSC safety report). Drives regulatory workflow routing.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Revised Launch Date' ;
    rdfs:comment 'Updated target commercial launch date if the original target has been revised as a result of this or a prior transition. Enables tracking of schedule slippage across the NPD pipeline.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemTransitionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transition Code' ;
    rdfs:comment 'The native identifier of this transition record in the originating source system (e.g., SAP change request ID, Veeva Vault workflow instance ID). Enables reconciliation between the lakehouse Silver layer and the system of record.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageEntryDate rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Date' ;
    rdfs:comment 'The date on which the SKU or formulation formally entered the to_stage_code as a result of this transition. Used to calculate stage duration and cycle time KPIs for NPD efficiency reporting.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageExitDate rdf:type rdf:Property ;
    rdfs:label 'Stage Exit Date' ;
    rdfs:comment 'The date on which the SKU or formulation exited the from_stage_code. Together with stage_entry_date of the prior transition, enables calculation of time-in-stage for NPD cycle time analytics.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'The planned commercial launch date for the SKU as recorded at the time of this lifecycle transition. Used for NPD pipeline milestone tracking and S&OP alignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toStageCode rdf:type rdf:Property ;
    rdfs:label 'To Stage Code' ;
    rdfs:comment 'The PLM lifecycle stage to which the SKU or formulation is transitioning. Standard stage codes: Ideation, Concept, Feasibility, Development, Pilot, Scale-Up, Launch, Active, Renovation, Discontinuation, Archived. [ENUM-REF-CANDIDATE: Ideation|Concept|Feasibility|Development|Pilot|Scale-Up|Launch|Active|Renovation|Discontinuation|Archived — promote to reference product]' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDate rdf:type rdf:Property ;
    rdfs:label 'Transition Date' ;
    rdfs:comment 'The calendar date on which the lifecycle stage transition was formally executed and recorded. Represents the principal business event date for NPD pipeline reporting and regulatory submission timelines.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized reason code classifying why this lifecycle stage transition was initiated. NPD_PROGRESSION: normal new product development advancement; RENOVATION: product renovation or restage; REFORMULATION: ingredient or formula change; REGULATORY: compliance-driven change; DISCONTINUATION: product end-of-life; ROLLBACK: reversion to prior stage.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional business context for the lifecycle stage transition beyond the standardized reason code. Captures nuances such as market conditions, consumer insights, or regulatory findings that drove the transition.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transition Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this transition event, typically generated by the PLM or ERP system (e.g., SAP change request number or Veeva Vault workflow ID). Used for cross-system traceability.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionStatus rdf:type rdf:Property ;
    rdfs:label 'Transition Status' ;
    rdfs:comment 'Current workflow status of this lifecycle stage transition event. Pending indicates awaiting gate review approval; Approved indicates the transition has been formally authorized; Rejected indicates the gate review denied the transition; Withdrawn indicates the request was retracted; Superseded indicates replaced by a subsequent transition.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'Precise date and time at which the lifecycle stage transition event was triggered in the source PLM system. Provides audit-grade temporal precision for regulatory submissions and compliance traceability.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Classifies the direction and nature of the lifecycle stage transition. Forward: normal progression to the next stage; Backward: reversion to a prior stage; Parallel: simultaneous multi-stage activity; Bypass: skipping one or more intermediate stages with documented justification.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Reference' ;
    rdfs:comment 'Reference number for any formal waiver granted to allow progression despite unmet gate criteria. Populated when gate_criteria_validation_result is Conditional Pass. Required for regulatory audit trail.' ;
    rdfs:domain ind:PlmTransition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productBrandId rdf:type rdf:Property ;
    rdfs:label 'Product Brand Id' ;
    rdfs:comment 'Unique surrogate identifier for each brand master record in the Consumer Goods portfolio. Primary key for the product_brand dimension, referenced by all downstream domains including marketing, trade promotion, and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBrand .

ind:architectureType rdf:type rdf:Property ;
    rdfs:label 'Architecture Type' ;
    rdfs:comment 'Classification of the brand\'s role within the overall brand architecture strategy. Master brands are umbrella identities; sub-brands extend a master brand; endorsed brands carry a parent endorsement; standalone brands operate independently; house_of_brands indicates a portfolio brand with no visible corporate parent.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Market positioning tier of the brand within the CPG/FMCG portfolio, indicating price-value positioning relative to competition. Drives RSP/MSRP strategy, trade promotion investment levels, and retail channel prioritization. [ENUM-REF-CANDIDATE: premium|mass|value|super_premium|private_label — promote to reference product if tiers expand]' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divestitureDate rdf:type rdf:Property ;
    rdfs:label 'Divestiture Date' ;
    rdfs:comment 'Date on which the brand was officially divested, sold, or licensed to a third party. Populated only when brand_status is \'divested\'. Required for SOX financial reporting and portfolio restructuring audit trails.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eanPrefix rdf:type rdf:Property ;
    rdfs:label 'Ean Prefix' ;
    rdfs:comment 'GS1 company prefix assigned to the brand owner, forming the first digits of all EAN/GTIN barcodes for products under this brand. Enables GS1-compliant product identification and EDI transactions across the global supply chain.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityMethodology rdf:type rdf:Property ;
    rdfs:label 'Equity Methodology' ;
    rdfs:comment 'Methodology or framework used to measure and track brand equity over time. Determines which external measurement partner (Nielsen IQ, Kantar BrandZ, Ipsos) or internal scorecard approach is applied for brand health KPI reporting. [ENUM-REF-CANDIDATE: nielsen_brand_health|kantar_brandz|ipsos_brand_value|internal_scorecard|bav|none — promote to reference product if methodologies expand]' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationRef rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Ref' ;
    rdfs:comment 'Reference number or identifier for the GMP certification applicable to the brand\'s manufacturing operations. Required for FDA-regulated brands (21 CFR Parts 110/111/210/211) and cosmetics brands under ISO 22716. Stored in Veeva Vault Quality Documents.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchYear rdf:type rdf:Property ;
    rdfs:label 'Launch Year' ;
    rdfs:comment 'Calendar year in which the brand was first commercially launched in any market. Used for brand age analytics, heritage positioning, and portfolio vintage analysis in brand equity tracking.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the brand licensing agreement expires, applicable only when is_licensed_brand is True. Critical for contract renewal planning, financial risk management, and SOX disclosure requirements. Null for wholly-owned brands.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msrpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the MSRP/RSP defined at the brand level. Provides the currency context for brand-level pricing strategy and trade promotion ROI calculations.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nps Tracking Enabled' ;
    rdfs:comment 'Indicates whether active NPS (Net Promoter Score) consumer sentiment tracking is configured for this brand. When True, the brand is enrolled in periodic consumer surveys and NPS measurement programs linked to the consumer domain\'s nps_response product.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerDivision rdf:type rdf:Property ;
    rdfs:label 'Owner Division' ;
    rdfs:comment 'Internal business division or strategic business unit (SBU) within the Consumer Goods organization that owns and manages the brand. Used for financial reporting, EBITDA attribution, and S&OP planning alignment in SAP S/4HANA CO module.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEntity rdf:type rdf:Property ;
    rdfs:label 'Owner Entity' ;
    rdfs:comment 'Legal entity name of the company or subsidiary that owns the brand trademark and bears regulatory responsibility for the brand. Critical for SOX financial reporting, regulatory submissions to FDA/EPA/CPSC, and inter-company transfer pricing.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandCode rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Code' ;
    rdfs:comment 'Brand code of the parent or umbrella brand for sub-brands and brand extensions. Enables hierarchical brand architecture modeling (e.g., a skincare sub-brand under a master personal care brand). Null for top-level master brands with no parent.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmStage rdf:type rdf:Property ;
    rdfs:label 'Plm Stage' ;
    rdfs:comment 'Current stage of the brand in the PLM lifecycle framework. Drives resource allocation, marketing investment levels, and supply chain planning priorities. Concept and development stages are pre-commercial; growth through decline stages are active commercial phases; end_of_life triggers discontinuation planning. [ENUM-REF-CANDIDATE: concept|development|launch|growth|maturity|decline|end_of_life — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Category' ;
    rdfs:comment 'Primary GS1 or internal product category to which the brand belongs (e.g., Household Cleaning, Personal Care, Health & Hygiene, Baby Care). Used for category management, Nielsen IQ market measurement, ACV/TDP reporting, and trade promotion planning.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market or country of origin for the brand. Used for regulatory compliance (FDA, EU REACH), customs documentation, and market-level financial reporting.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the brand (e.g., @BrandName on Instagram/Twitter/TikTok). Used for SOV (Share of Voice) measurement, digital marketing analytics, and consumer engagement tracking in Nielsen IQ and Salesforce.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemBrandCode rdf:type rdf:Property ;
    rdfs:label 'Source System Brand Code' ;
    rdfs:comment 'Native brand identifier as stored in the originating operational system (e.g., SAP S/4HANA brand master ID, Salesforce Consumer Goods Cloud brand record ID). Enables reverse lookup and reconciliation between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationRef rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Ref' ;
    rdfs:comment 'Official trademark registration number or reference identifier issued by the relevant intellectual property authority (e.g., USPTO, EUIPO, WIPO). Used for legal protection verification, brand licensing agreements, and regulatory labeling compliance.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official consumer-facing website URL for the brand. Used for DTC channel management, digital marketing attribution, and e-commerce integration. Referenced in Salesforce Consumer Goods Cloud for omnichannel campaign tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the product certification record. Primary key.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Certification responsibility is assigned to an employee; needed for audit trails and renewal management.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Comma-separated list of sales channels where this certification applies and can be claimed. Examples: retail, e-commerce, DTC (Direct to Consumer), food service, professional, wholesale.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets or countries where this certification is recognized and can be claimed. Uses ISO 3166-1 alpha-3 country codes (e.g., USA, GBR, DEU, FRA, JPN).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'The outcome of the most recent audit. Passed indicates full compliance. Passed with conditions indicates minor non-conformances that must be addressed. Failed indicates major non-conformances.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The name of the third-party organization or authority that issued the certification. Examples: RSPO Secretariat, Forest Stewardship Council, Cruelty Free International, Ecocert, NSF International, Islamic Food and Nutrition Council of America, Orthodox Union.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'Reference path or identifier to the official certificate document in the document management system (e.g., Veeva Vault). Used for regulatory submissions and retailer compliance requests.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate or license number assigned by the certification body. Used for verification and audit trail purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of what the certification covers. May specify ingredients, packaging materials, manufacturing processes, supply chain stages, or product categories included in the certification scope.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Active indicates the certification is valid and in force. Expired means the certification has passed its expiry date. Suspended indicates temporary hold. Revoked means the certification has been withdrawn. Pending and under_review indicate application or renewal in progress.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or name of the third-party certification or compliance attestation. Examples include RSPO (Roundtable on Sustainable Palm Oil), FSC (Forest Stewardship Council), Leaping Bunny (cruelty-free), COSMOS Organic, NSF, Halal, Kosher, EPA Safer Choice, ISO 22716 GMP (Good Manufacturing Practice). [ENUM-REF-CANDIDATE: RSPO|FSC|Leaping Bunny|COSMOS Organic|NSF|Halal|Kosher|EPA Safer Choice|ISO 22716|Fair Trade|Rainforest Alliance|USDA Organic|Ecocert|Vegan Society|B Corp|Carbon Neutral|Cradle to Cradle|EWG Verified|Non-GMO Project|PETA Cruelty-Free|Other — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Facing Flag' ;
    rdfs:comment 'Indicates whether this certification is actively promoted to consumers on packaging, advertising, and digital channels. True means the certification is part of the brand\'s consumer value proposition.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoFileReference rdf:type rdf:Property ;
    rdfs:label 'Logo File Reference' ;
    rdfs:comment 'Reference path or identifier to the approved certification logo file in the digital asset management system. Used by packaging and marketing teams.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUsageApproved rdf:type rdf:Property ;
    rdfs:label 'Logo Usage Approved' ;
    rdfs:comment 'Indicates whether the company is authorized to display the certification body\'s logo or seal on product packaging and marketing materials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date by which the certification must be renewed to maintain continuous compliance. May differ from expiry date to allow for renewal processing time.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailerRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Retailer Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is required by one or more key retail customers as a condition of distribution. True means at least one retailer mandates this certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'The version or edition of the certification standard under which the product was certified. Important for tracking compliance with evolving standards.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPillar rdf:type rdf:Property ;
    rdfs:label 'Sustainability Pillar' ;
    rdfs:comment 'The primary sustainability or ESG (Environmental Social Governance) pillar that this certification supports. Used for sustainability reporting and ESG disclosure alignment.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'Public URL where consumers, retailers, or auditors can verify the authenticity of this certification using the certificate number. Supports transparency and claim substantiation.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productClaimId rdf:type rdf:Property ;
    rdfs:label 'Product Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each product claim record in the master claim registry. Primary key for the product_claim data product.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimSubstantiationId rdf:type rdf:Property ;
    rdfs:label 'Claim Substantiation Id' ;
    rdfs:comment 'Identifier of the supporting study, clinical trial, laboratory test report, or audit document that substantiates the claim. Cross-references the document management system (Veeva Vault) or internal R&D study registry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClaimSubstantiation .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the third-party certification organization that issued or validates the claim (e.g., NSF International, Leaping Bunny, USDA Organic, Rainforest Alliance, RSPO, FSC). Applicable only for certification-type claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The official certificate or license number issued by the certification body for third-party certified claims. Used for audit trail and regulatory verification purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCode rdf:type rdf:Property ;
    rdfs:label 'Claim Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the claim, used in regulatory submissions, PLM systems, and cross-functional references. Sourced from Veeva Vault claim registration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimScope rdf:type rdf:Property ;
    rdfs:label 'Claim Scope' ;
    rdfs:comment 'Defines the level at which the claim applies: Product (specific SKU), Brand (entire brand portfolio), Range (product line/sub-brand), or Ingredient (specific INCI ingredient within the formulation).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Categorical classification of the claim by its business and regulatory nature. Efficacy: performance-based claims; Environmental: green/sustainability claims; Certification: third-party certified claims; Nutritional: nutrient content or health claims; Safety: dermatological or toxicological safety claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimValue rdf:type rdf:Property ;
    rdfs:label 'Claim Value' ;
    rdfs:comment 'The specific numeric value or percentage cited in a quantitative claim (e.g., \'99.9\', \'30\', \'100\'). Stored as STRING to accommodate ranges and non-numeric qualifiers. Null for qualitative claims.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalClaimStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Claim Standard' ;
    rdfs:comment 'The specific environmental standard or framework under which an environmental claim is made (e.g., ISO 14021 for self-declared environmental claims, ISO 14024 for Type I eco-labels, EPA Safer Choice). Applicable only for environmental claim types.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaReviewed rdf:type rdf:Property ;
    rdfs:label 'Fda Reviewed' ;
    rdfs:comment 'Indicates whether the claim has been reviewed for compliance with FDA labeling regulations (21 CFR Part 101 for food/nutrition claims or 21 CFR Part 701 for cosmetics). Applicable for health, nutritional, and drug-related claims.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Compliant' ;
    rdfs:comment 'Indicates whether the claim has been reviewed and confirmed compliant with FTC advertising guidelines, including the requirement for competent and reliable scientific evidence. True = FTC compliant; False = non-compliant or not yet reviewed.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciIngredientRef rdf:type rdf:Property ;
    rdfs:label 'Inci Ingredient Ref' ;
    rdfs:comment 'The INCI (International Nomenclature of Cosmetic Ingredients) name of the specific ingredient referenced in an ingredient-scoped claim. Applicable when claim_scope is \'ingredient\'. Ensures regulatory alignment with EU Cosmetics Regulation and FDA cosmetic labeling.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewed rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed' ;
    rdfs:comment 'Indicates whether the claim has been reviewed and cleared by the internal legal counsel for advertising law compliance, IP considerations, and litigation risk. True = legal sign-off obtained.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or employee identifier of the legal counsel who reviewed and approved the claim. Provides audit trail for legal sign-off accountability.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingApproved rdf:type rdf:Property ;
    rdfs:label 'Marketing Approved' ;
    rdfs:comment 'Indicates whether the marketing team has approved the claim copy for consumer-facing deployment. Part of the multi-functional claim approval workflow (R&D, Legal, Regulatory, Marketing).' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantitativeClaim rdf:type rdf:Property ;
    rdfs:label 'Quantitative Claim' ;
    rdfs:comment 'Indicates whether the claim contains a specific quantitative assertion (e.g., \'99.9% effective\', \'reduces wrinkles by 30%\'). Quantitative claims require a higher standard of substantiation evidence under FTC guidelines.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The primary regulatory authority governing this claim in its applicable market(s) (e.g., FDA, EPA, CPSC, EU REACH, IFRA). Drives the compliance review process and substantiation requirements. [ENUM-REF-CANDIDATE: FDA|EPA|CPSC|EU_REACH|IFRA|FTC|OSHA|ISO|RSPO|FSC — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scientificReviewer rdf:type rdf:Property ;
    rdfs:label 'Scientific Reviewer' ;
    rdfs:comment 'Name or employee identifier of the R&D scientist or regulatory affairs specialist who validated the substantiation evidence for the claim.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemClaimCode rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Code' ;
    rdfs:comment 'The native identifier of this claim record in the originating operational system (e.g., Veeva Vault document ID, SAP object ID). Enables traceability and reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationMethod rdf:type rdf:Property ;
    rdfs:label 'Substantiation Method' ;
    rdfs:comment 'The scientific or evidentiary method used to substantiate the claim per FTC competent and reliable scientific evidence standard. Determines the rigor and defensibility of the claim in regulatory or legal proceedings.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within the claim type (e.g., \'anti-bacterial\', \'biodegradable\', \'cruelty-free\', \'hypoallergenic\', \'organic\', \'fair-trade\'). [ENUM-REF-CANDIDATE: anti-bacterial|biodegradable|cruelty-free|hypoallergenic|organic|fair-trade|recyclable|vegan|gluten-free|non-gmo — promote to reference product]' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueUnit rdf:type rdf:Property ;
    rdfs:label 'Value Unit' ;
    rdfs:comment 'Unit of measure for the quantitative claim value (e.g., \'%\', \'mg\', \'CFU\', \'hours\'). Required when claim_value is populated to provide full context for the quantitative assertion.' ;
    rdfs:domain ind:ProductClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date on which the claim was formally withdrawn from consumer-facing use. Populated only when claim_status is \'withdrawn\'. Critical for regulatory audit trail and litigation defense.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text explanation for why a claim was withdrawn or rejected. Populated when claim_status is \'withdrawn\' or \'under_review\'. Captures regulatory challenge, substantiation failure, reformulation, or voluntary removal rationale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each node in the product classification hierarchy. Serves as the primary key for this record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:parentHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Id' ;
    rdfs:comment 'Reference to the immediate parent node in the product hierarchy tree. NULL for root-level nodes (e.g., Division). Enables recursive traversal of the Division → Category → Sub-Category → Brand → Sub-Brand → Product Form → SKU hierarchy.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hierarchy .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Distribution channels through which products in this hierarchy node are sold (e.g., \'Retail\', \'E-Commerce\', \'DTC\', \'Wholesale\', \'DSD\'). Supports channel management, trade promotion planning, and distribution requirements planning (DRP). [ENUM-REF-CANDIDATE: Retail|E-Commerce|DTC|Wholesale|DSD|Club|Drug — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscRegulated rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated' ;
    rdfs:comment 'Indicates whether products in this hierarchy node are subject to CPSC (Consumer Product Safety Commission) regulations. True = product safety testing, labeling, and reporting requirements under CPSA apply.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External partner or retailer-specific category code mapped to this hierarchy node (e.g., Walmart category code, Amazon browse node ID). Supports EDI (Electronic Data Interchange) transactions, retailer data synchronization, and VMI (Vendor Managed Inventory) programs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpStandard rdf:type rdf:Property ;
    rdfs:label 'Gmp Standard' ;
    rdfs:comment 'Applicable GMP (Good Manufacturing Practice) standard for manufacturing products in this hierarchy node. Drives quality management requirements in Siemens Opcenter MES and Veeva Vault QMS. ISO 22716 applies to cosmetics; 21 CFR 111 to dietary supplements; 21 CFR 210/211 to pharmaceuticals.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpcBrickName rdf:type rdf:Property ;
    rdfs:label 'Gpc Brick Name' ;
    rdfs:comment 'Descriptive name of the GS1 GPC brick code associated with this hierarchy node (e.g., \'Shampoo/Conditioner - Non-Medicated\'). Supports regulatory submissions, retailer onboarding, and GS1 data pool synchronization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibpPlanningLevel rdf:type rdf:Property ;
    rdfs:label 'Ibp Planning Level' ;
    rdfs:comment 'Indicates whether this hierarchy node is a designated planning level in SAP IBP (Integrated Business Planning) for demand forecasting and S&OP (Sales and Operations Planning). True = this node is an active planning aggregation point.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inciApplicable rdf:type rdf:Property ;
    rdfs:label 'Inci Applicable' ;
    rdfs:comment 'Indicates whether products in this hierarchy node require INCI (International Nomenclature of Cosmetic Ingredients) ingredient declaration on labeling. True = cosmetic/personal care products subject to EU Cosmetics Regulation and FDA cosmetic labeling requirements.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iriCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Iri Category Code' ;
    rdfs:comment 'IRI (now Circana) proprietary category code mapped to this hierarchy node. Supports market share reporting, TDP (Total Distribution Points) analysis, and SOM (Share of Market) calculations using IRI syndicated data.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this node is a terminal leaf in the hierarchy (True = no children exist, typically the SKU level). Used to filter for assignable product nodes in demand forecasting, inventory management, and trade promotion planning.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Business label for the hierarchy depth of this node. Enumerated values correspond to the CPG/FMCG standard classification spine: Division, Category, Sub-Category, Brand, Sub-Brand, Product Form, SKU (Stock Keeping Unit). Drives display logic in reporting tools and S&OP dashboards. [ENUM-REF-CANDIDATE: Division|Category|Sub-Category|Brand|Sub-Brand|Product Form|SKU — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareReportable rdf:type rdf:Property ;
    rdfs:label 'Market Share Reportable' ;
    rdfs:comment 'Indicates whether this hierarchy node is included in external market share reporting via Nielsen IQ or IRI/Circana syndicated data. True = node is mapped to a syndicated data category for SOM (Share of Market) and ACV (All Commodity Volume) reporting.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Category Code' ;
    rdfs:comment 'Nielsen IQ proprietary category code mapped to this hierarchy node. Enables direct linkage between internal product classification and Nielsen IQ retail measurement data for market share reporting, ACV (All Commodity Volume) analysis, and competitive benchmarking.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy node within its level. Used as the business key in SAP S/4HANA MM product group structures and referenced in EDI transactions and trade promotion planning systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Extended business description of the hierarchy node providing additional context about the product grouping, its scope, and intended use in classification. Supports regulatory categorization and PLM documentation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable business name of this hierarchy node (e.g., \'Personal Care\', \'Shampoo\', \'Head & Shoulders\', \'Classic Clean\'). Used in OLAP drill-down reports, trade promotion planning, and market share dashboards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of this hierarchy node. \'active\' nodes are available for use in planning, trade promotion, and reporting. \'discontinued\' nodes are retained for historical analysis. \'pending\' nodes are awaiting approval in the PLM (Product Lifecycle Management) workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Materialized full path string from root to this node using a delimiter (e.g., \'Consumer Goods / Personal Care / Hair Care / Shampoo / Head & Shoulders / Classic Clean\'). Enables fast string-based filtering and display in BI tools without recursive joins.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegulated rdf:type rdf:Property ;
    rdfs:label 'Reach Regulated' ;
    rdfs:comment 'Indicates whether products in this hierarchy node are subject to EU REACH Regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals). True = chemical substance registration and SDS (Safety Data Sheet) requirements apply.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemNodeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Node Code' ;
    rdfs:comment 'Native identifier of this hierarchy node in the originating operational system (e.g., SAP product hierarchy node ID, Veeva Vault record ID). Enables reverse traceability from the Silver Layer back to the system of record for reconciliation and audit.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code assigned to this hierarchy node for VAT/GST determination in SAP S/4HANA FI/CO. Drives correct tax treatment in sales orders, invoicing, and financial reporting across jurisdictions.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Default Supply Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Required for assigning each SKU to its primary distribution node used in supply planning, ATP calculations, and network optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:innovationBriefId rdf:type rdf:Property ;
    rdfs:label 'Innovation Brief Id' ;
    rdfs:comment 'Foreign key linking to research.innovation_brief. Business justification: Tracks which Innovation Brief generated the SKU, supporting pipeline reporting and ROI analysis of innovation initiatives.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InnovationBrief .

ind:originatingRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Originating Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.rd_project. Business justification: Needed for product development cost allocation and regulatory traceability linking each SKU to its originating R&D project.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdProject .

ind:primarySupplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Designating a primary supplier site per SKU supports logistics planning, VMI inventory control, and OTIF performance tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:productOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for PLM Product Owner assignment; ownership reports need employee responsible for each SKU.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:skuCategoryId rdf:type rdf:Property ;
    rdfs:label 'Sku Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: SKU belongs to a product category; linking SKU to category eliminates silo and consolidates category data.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:skuGroupId rdf:type rdf:Property ;
    rdfs:label 'Sku Group Id' ;
    rdfs:comment 'Foreign key linking to product.sku_group. Business justification: SKU can be grouped; linking SKU to sku_group provides hierarchy and eliminates silo for sku_group.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuGroup .

ind:fefoThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Fefo Threshold Pct' ;
    rdfs:comment 'Minimum remaining shelf life percentage (of total shelf life) required at the time of shipment to a customer or retailer. Below this threshold, the product is considered non-shippable. Used in Blue Yonder WMS and SAP IBP inventory optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the SKU is classified as a hazardous material requiring special handling, storage, or transportation documentation (e.g., Safety Data Sheet / SDS). Triggers compliance workflows in logistics and warehouse management.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecyclablePackaging rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable Packaging' ;
    rdfs:comment 'Indicates whether the primary packaging of the SKU is designed to be recyclable. Used in sustainability reporting, ESG disclosures, and consumer-facing labeling claims per FTC Green Guides.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatedProduct rdf:type rdf:Property ;
    rdfs:label 'Is Regulated Product' ;
    rdfs:comment 'Indicates whether the SKU is subject to regulatory approval or registration requirements (e.g., FDA OTC drug, EPA-registered disinfectant, CPSC-regulated product). Triggers regulatory submission workflows in Veeva Vault.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSustainable rdf:type rdf:Property ;
    rdfs:label 'Is Sustainable' ;
    rdfs:comment 'Indicates whether the SKU meets the company\'s sustainability criteria, such as FSC-certified packaging, RSPO-certified palm oil, or ISO 14001-aligned manufacturing. Used in sustainability reporting and ESG disclosures.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer Suggested Retail Price (MSRP) in the base currency. Represents the recommended consumer selling price (RSP) set by the manufacturer. Used in trade promotion planning (TPM), pricing strategy, and retailer negotiations. Confidential commercial data.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContent rdf:type rdf:Property ;
    rdfs:label 'Net Content' ;
    rdfs:comment 'Numeric net content quantity of the product as declared on packaging (e.g., 500, 1.5, 200). Must be paired with net_content_uom. Regulated by FDA and FTC for accurate labeling. Used in COGS calculation and logistics weight/volume planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of individual consumer units contained within a single sellable pack (e.g., 1 for single unit, 2 for twin pack, 6 for multipack). Used in trade promotion planning (TPM), pricing, and distribution requirements planning (DRP).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingMaterialType rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Type' ;
    rdfs:comment 'Material type of the primary consumer packaging (e.g., plastic, glass, aluminum, paper, cardboard). Used in sustainability reporting, EU REACH compliance, and packaging specification management in Veeva Vault. [ENUM-REF-CANDIDATE: plastic|glass|aluminum|paper|cardboard|composite|biodegradable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioClassification rdf:type rdf:Property ;
    rdfs:label 'Portfolio Classification' ;
    rdfs:comment 'Strategic classification of the SKU within the brand portfolio (e.g., core, strategic, tail, innovation, seasonal, limited_edition). Used in S&OP (Sales and Operations Planning) prioritization, resource allocation, and SKU rationalization decisions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productForm rdf:type rdf:Property ;
    rdfs:label 'Product Form' ;
    rdfs:comment 'Physical or chemical form of the product (e.g., liquid, powder, gel, cream, spray). Critical for manufacturing process routing in Siemens Opcenter MES, packaging specification, and regulatory classification. [ENUM-REF-CANDIDATE: liquid|powder|gel|cream|foam|spray|bar|tablet|capsule|wipe|stick|sheet — promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Regulatory classification of the SKU determining the applicable regulatory framework and labeling requirements (e.g., cosmetic, OTC drug, household chemical, food). Drives compliance workflows in Veeva Vault and regulatory reporting. [ENUM-REF-CANDIDATE: cosmetic|otc_drug|household_chemical|food|dietary_supplement|medical_device|general_merchandise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scent rdf:type rdf:Property ;
    rdfs:label 'Scent' ;
    rdfs:comment 'Consumer-facing scent or fragrance descriptor for the SKU (e.g., \'Fresh\', \'Lavender\', \'Unscented\'). Relevant for personal care and household products. Used in consumer engagement, marketing, and IFRA fragrance compliance tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated product description (typically 40–80 characters) used in ERP transactions, warehouse management systems, and EDI communications where full product names are truncated. Maps to SAP MM short text field.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current operational status of the SKU in the ERP system (SAP S/4HANA material status). Controls whether the SKU can be procured, manufactured, sold, or shipped. \'blocked\' prevents all transactions; \'pending_launch\' indicates pre-commercialization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the SKU throughout the supply chain (e.g., ambient, refrigerated, frozen, controlled_temperature). Drives warehouse slotting in Blue Yonder WMS, transportation lane requirements, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subBrand rdf:type rdf:Property ;
    rdfs:label 'Sub Brand' ;
    rdfs:comment 'Sub-brand or product line within the parent brand (e.g., \'Dove Men+Care\', \'Tide PODS\'). Enables granular brand portfolio analysis and targeted trade promotion management (TPM).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary consumer demographic segment this SKU is designed and marketed for (e.g., adult, baby, male, female, professional). Drives consumer segmentation, marketing investment allocation, and shelf placement strategy. [ENUM-REF-CANDIDATE: adult|baby|child|teen|senior|unisex|male|female|professional|family — promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the SKU in days from the date of manufacture to the expiry date as declared on packaging. Used in FEFO (First Expired First Out) inventory management, Blue Yonder WMS configuration, and regulatory compliance.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variant rdf:type rdf:Property ;
    rdfs:label 'Variant' ;
    rdfs:comment 'Specific variant descriptor distinguishing this SKU from others within the same product line (e.g., \'Original\', \'Sensitive Skin\', \'Extra Strength\', \'2-in-1\'). Used in PLM lifecycle management and consumer segmentation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeMl rdf:type rdf:Property ;
    rdfs:label 'Volume Ml' ;
    rdfs:comment 'Volume of the consumer unit in millilitres, used for liquid and semi-liquid products. Supports logistics cube utilization calculations, warehouse slotting, and transportation planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuSubstitutionId rdf:type rdf:Property ;
    rdfs:label 'Sku Substitution Id' ;
    rdfs:comment 'Unique surrogate identifier for each SKU substitution or supersession relationship record in the product master. Primary key for this entity.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpSubstitutionEnabled rdf:type rdf:Property ;
    rdfs:label 'Atp Substitution Enabled' ;
    rdfs:comment 'Indicates whether this substitution relationship is active for ATP (Available to Promise) and CTP (Capable to Promise) calculations in supply planning. When True, the to-SKU inventory is considered when confirming availability for orders requesting the from-SKU.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Auto Substitution Allowed' ;
    rdfs:comment 'Indicates whether the substitution can be executed automatically by order management or ERP systems without manual intervention. False requires a customer service representative or account manager to confirm the substitution before order processing proceeds.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsImpactPct rdf:type rdf:Property ;
    rdfs:label 'Cogs Impact Pct' ;
    rdfs:comment 'Estimated percentage change in COGS (Cost of Goods Sold) resulting from this substitution. Used by finance for COGS bridge analysis across product transitions, particularly for cost optimization and renovation-driven substitutions. Positive values indicate cost increase; negative values indicate cost savings.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether explicit customer or retailer approval is required before this substitution can be executed on an order. True for key account or contractual SKU commitments where the buyer must consent to any product change. Drives workflow routing in Salesforce Consumer Goods Cloud account management.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandHistoryNormalization rdf:type rdf:Property ;
    rdfs:label 'Demand History Normalization' ;
    rdfs:comment 'Indicates whether demand planning systems should normalize historical sales data by mapping the from-SKU demand history to the to-SKU when the substitution represents a supersession. True enables SAP IBP to consolidate demand signals across the product transition for accurate forecasting.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBidirectional rdf:type rdf:Property ;
    rdfs:label 'Is Bidirectional' ;
    rdfs:comment 'Indicates whether the substitution relationship is bidirectional (True) — meaning either SKU can substitute for the other — or directional (False) — meaning only the from-SKU can be replaced by the to-SKU. Bidirectional substitutions are common for size-equivalent or reformulation-equivalent products.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the market or geography where this substitution is applicable. Null when the substitution is global. Used to manage region-specific regulatory substitutions (e.g., EU REACH-driven reformulations) and market-specific product availability.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmChangeOrderRef rdf:type rdf:Property ;
    rdfs:label 'Plm Change Order Ref' ;
    rdfs:comment 'Reference to the PLM (Product Lifecycle Management) engineering change order or NPD (New Product Development) project that authorized this substitution. Links the substitution record back to the formal product change governance process in Veeva Vault or the PLM system.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Pct' ;
    rdfs:comment 'Percentage price adjustment applied when the substitute SKU carries a different RSP (Recommended Selling Price) or MSRP than the original SKU. Positive values indicate a price increase; negative values indicate a price reduction. Used by finance for COGS bridge analysis and by customer service for order repricing during substitution.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Quantity Conversion Factor' ;
    rdfs:comment 'Numeric multiplier applied to convert the ordered quantity of the from-SKU to the equivalent quantity of the to-SKU. For example, a factor of 2.0 means 1 unit of the from-SKU is substituted by 2 units of the to-SKU (e.g., a size change from 500ml to 250ml). Factor of 1.0 indicates a one-for-one substitution.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryChangeRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Ref' ;
    rdfs:comment 'Reference identifier for the regulatory mandate, compliance ruling, or governing body directive that triggered this substitution when reason_code is regulatory_change. Examples include FDA 21 CFR section references, EU REACH substance restriction IDs, EPA compliance notices, or CPSC safety recall numbers.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native primary key or record identifier of this substitution record in the originating operational system (e.g., SAP S/4HANA material substitution record number). Enables traceability and reconciliation between the lakehouse Silver layer and the system of record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionNotes rdf:type rdf:Property ;
    rdfs:label 'Substitution Notes' ;
    rdfs:comment 'Free-text field for additional business context, operational instructions, or caveats associated with this substitution relationship. May include customer communication guidance, handling instructions for customer service teams, or supply chain execution notes.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionScope rdf:type rdf:Property ;
    rdfs:label 'Substitution Scope' ;
    rdfs:comment 'Defines the commercial scope within which this substitution is applicable. Global applies across all markets and channels; regional restricts to a geographic region; customer_specific applies only to a named account; channel_specific applies only to a defined distribution channel (e.g., DTC, retail, wholesale).' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionStatus rdf:type rdf:Property ;
    rdfs:label 'Substitution Status' ;
    rdfs:comment 'Current lifecycle status of the substitution record. Active indicates the substitution is in effect; pending_approval indicates awaiting customer or commercial sign-off; expired indicates the effective date range has passed; suspended indicates temporarily halted.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classifies the nature of the substitution relationship between the from-SKU and to-SKU. Direct replacement indicates a like-for-like swap; reformulation indicates a change in product formula; repack indicates a packaging change; size_change indicates a net content or pack size change; promotional_swap indicates a temporary trade promotion substitution; supersession indicates a permanent product lifecycle transition.' ;
    rdfs:domain ind:SkuSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineVolumeId rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume Id' ;
    rdfs:comment 'Unique identifier for the baseline volume record. Primary key for this entity.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBaselineEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Baseline Employee Id' ;
    rdfs:comment 'Foreign key reference to the user who performed the manual override of the baseline estimate.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryBaselineLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Baseline Last Modified By User Employee Id' ;
    rdfs:comment 'Foreign key reference to the user who last modified this baseline volume record.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBaselineCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Baseline Created By User Employee Id' ;
    rdfs:comment 'Foreign key reference to the user who created this baseline volume record.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether the baseline volume estimate was manually overridden by an analyst (True) or is system-generated (False).' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineMethodology rdf:type rdf:Property ;
    rdfs:label 'Baseline Methodology' ;
    rdfs:comment 'The statistical methodology used to calculate the baseline volume estimate (e.g., moving average, regression, Nielsen IQ panel, Bayesian structural time series).' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End Date' ;
    rdfs:comment 'The end date of the period for which this baseline volume estimate applies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start Date' ;
    rdfs:comment 'The start date of the period for which this baseline volume estimate applies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Revenue Amount' ;
    rdfs:comment 'The estimated baseline revenue for the SKU-retailer-period combination at regular pricing, absent promotional activity.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Status' ;
    rdfs:comment 'The current lifecycle status of the baseline volume record (e.g., draft, approved, active, archived, superseded, rejected).' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cases rdf:type rdf:Property ;
    rdfs:label 'Cases' ;
    rdfs:comment 'The estimated baseline sales volume in cases, representing expected sales absent any promotional activity.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the baseline volume estimate, representing statistical uncertainty.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the baseline volume estimate, representing statistical uncertainty.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'The confidence level percentage for the confidence interval (e.g., 95.00 for 95% confidence).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:historicalLookbackWeeks rdf:type rdf:Property ;
    rdfs:label 'Historical Lookback Weeks' ;
    rdfs:comment 'The number of historical weeks of data used in the baseline volume calculation methodology.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Model Accuracy Score' ;
    rdfs:comment 'A statistical measure of the baseline model accuracy, such as R-squared or Mean Absolute Percentage Error (MAPE), represented as a decimal value.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outlierExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Outlier Exclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether statistical outliers were excluded from the baseline calculation (True) or included (False).' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'The date and time when the analyst override was applied to the baseline estimate.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionalPeriodsExcludedCount rdf:type rdf:Property ;
    rdfs:label 'Promotional Periods Excluded Count' ;
    rdfs:comment 'The number of promotional periods that were excluded from the historical data when calculating the baseline volume.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalityAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Adjustment Factor' ;
    rdfs:comment 'The multiplicative factor applied to adjust for seasonal patterns in the baseline volume calculation.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpmSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Tpm System Reference Code' ;
    rdfs:comment 'External reference identifier from the source Trade Promotion Management system (e.g., Salesforce TPM) for traceability.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Trend Adjustment Factor' ;
    rdfs:comment 'The multiplicative factor applied to adjust for long-term trend patterns in the baseline volume calculation.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:units rdf:type rdf:Property ;
    rdfs:label 'Units' ;
    rdfs:comment 'The estimated baseline sales volume in units, representing expected sales absent any promotional activity.' ;
    rdfs:domain ind:BaselineVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumerOfferId rdf:type rdf:Property ;
    rdfs:label 'Consumer Offer Id' ;
    rdfs:comment 'Unique identifier for the consumer-facing promotional offer. Primary key.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tertiaryConsumerLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Consumer Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this consumer offer record. Links to the user or employee master data entity.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostIncurred rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Incurred' ;
    rdfs:comment 'Actual total cost incurred from all redemptions of this offer to date. Used for budget variance analysis and financial reconciliation.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Actual Redemption Count' ;
    rdfs:comment 'Actual number of times this offer has been redeemed by consumers to date. Updated in near real-time from POS (Point of Sale) and e-commerce systems.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode value associated with the consumer offer for scanning at POS (Point of Sale). May be UPC (Universal Product Code), EAN (European Article Number), or proprietary coupon barcode format.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerOfferDescription rdf:type rdf:Property ;
    rdfs:label 'Consumer Offer Description' ;
    rdfs:comment 'Detailed description of the consumer offer including terms, conditions, and value proposition. Used for consumer communication and internal reference.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Fixed monetary discount amount provided by the offer in the specified currency. Null if discount is percentage-based.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCostPerRedemption rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Redemption' ;
    rdfs:comment 'Projected cost to the business for each redemption of this offer, including discount value and administrative costs. Used for budget planning and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Entity responsible for funding the consumer offer discount. Brand = manufacturer-funded; Trade = trade promotion budget; Co-op = cooperative funding between manufacturer and retailer; Retailer = retailer-funded.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRedemptionPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this offer during the validity period. Null indicates unlimited redemptions.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum purchase value required to qualify for the offer. Null if no minimum purchase requirement exists.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Quantity' ;
    rdfs:comment 'Minimum number of qualifying units or SKUs (Stock Keeping Units) that must be purchased to redeem the offer. Null if no quantity requirement exists.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the consumer offer for redemption tracking and identification. Used by consumers at point of sale or digital checkout.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name or title of the consumer offer as displayed to consumers in promotional materials and digital channels.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the consumer offer. Draft = under development; Approved = ready for activation; Active = currently redeemable; Paused = temporarily suspended; Expired = validity period ended; Cancelled = terminated before expiration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the consumer offer mechanism. Coupon = physical or digital coupon; Digital Offer = app-based or online promotion; Loyalty Reward = points-based redemption; Instant Rebate = immediate price reduction; Free Goods = complimentary product with purchase; BOGO = Buy One Get One; Bundle Discount = multi-product savings. [ENUM-REF-CANDIDATE: coupon|digital_offer|loyalty_reward|instant_rebate|free_goods|bogo|bundle_discount — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingSkuList rdf:type rdf:Property ;
    rdfs:label 'Qualifying Sku List' ;
    rdfs:comment 'Comma-separated list of SKU identifiers or product codes that qualify for this offer. May reference specific products, product families, or categories. Null if offer applies to all products.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'Channel where the consumer can redeem the offer. In-Store = physical retail; Online = e-commerce website; Mobile App = DTC (Direct-to-Consumer) mobile application; Call Center = phone order; Any = omnichannel redemption allowed.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions governing the use and redemption of this consumer offer. Includes restrictions, exclusions, and compliance requirements.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Budget Allocated' ;
    rdfs:comment 'Total budget amount allocated for this consumer offer across all redemptions. Used for financial planning and spend tracking.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Limit' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all customers for this offer. Null indicates no aggregate limit.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the offer can be transferred or shared between consumers. True = transferable; False = non-transferable, tied to original recipient.' ;
    rdfs:domain ind:ConsumerOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionSettlementId rdf:type rdf:Property ;
    rdfs:label 'Deduction Settlement Id' ;
    rdfs:comment 'Unique identifier for the deduction settlement record. Primary key for the deduction settlement entity.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Funding Agreement Id' ;
    rdfs:comment 'Reference to the trade promotion funding agreement or contract that governs the terms under which this deduction was taken and settled.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:parentSettlementDeductionSettlementId rdf:type rdf:Property ;
    rdfs:label 'Parent Settlement Deduction Settlement Id' ;
    rdfs:comment 'Reference to a parent settlement record if this is a follow-up or partial settlement. Enables tracking of multi-stage settlement processes for complex deductions.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeductionSettlement .

ind:primaryDeductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Deduction Employee Id' ;
    rdfs:comment 'Reference to the employee or user who approved this deduction settlement. Provides accountability and audit trail for settlement decisions.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionDeductionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Deduction Id' ;
    rdfs:comment 'Reference to the originating retailer deduction that this settlement resolves. Links to the deduction record in the trade promotion management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionDeduction .

ind:tertiaryDeductionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Deduction Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this settlement record. Provides accountability for changes and supports audit requirements.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'The business unit or division responsible for this settlement. Used for organizational reporting and trade spend allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionClaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Claimed Amount' ;
    rdfs:comment 'The original amount claimed by the retailer in the deduction. Represents the initial disputed or taken amount before settlement negotiation.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The approach used to resolve any disputes between the claimed and approved amounts. Documents the resolution process for compliance and process improvement.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The portion of the deduction claimed amount that was disputed or rejected by the manufacturer. Represents the difference between claimed and approved amounts when not fully approved.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPartialSettlement rdf:type rdf:Property ;
    rdfs:label 'Is Partial Settlement' ;
    rdfs:comment 'Boolean flag indicating whether this settlement represents a partial resolution of the deduction. True if the deduction requires additional settlements; false if fully resolved.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'The final amount paid or credited to the retailer as part of this settlement. This is the actual financial transaction amount and may include adjustments beyond the approved amount.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Time Days' ;
    rdfs:comment 'The number of days elapsed from deduction claim date to settlement completion. Used for process efficiency measurement and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the deduction settlement was finalized and agreed upon by both parties. Represents the business event date for settlement completion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'The mechanism used to resolve and pay the deduction. Indicates how the settlement amount was transferred or credited to the retailer.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementNotes rdf:type rdf:Property ;
    rdfs:label 'Settlement Notes' ;
    rdfs:comment 'Free-form text field for additional comments, negotiation details, or special circumstances related to the settlement. Provides context for future reference and audit.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Number' ;
    rdfs:comment 'Business-readable unique identifier for the settlement transaction. Used for external communication and audit trails. Format: STL- followed by 8-12 digits.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason or category for the settlement. Used for classification and root cause analysis of deductions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Settlement Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for the settlement, including any specific circumstances, negotiations, or justifications documented during the settlement process.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle status of the deduction settlement. Tracks the settlement through approval, payment, and closure workflows. [ENUM-REF-CANDIDATE: pending|approved|rejected|paid|cancelled|under_review|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this settlement was completed within the agreed Service Level Agreement (SLA) timeframe. Used for performance monitoring and retailer relationship management.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousAgreementFundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Previous Agreement Funding Agreement Id' ;
    rdfs:comment 'Reference to the prior funding agreement that this agreement renews or replaces, if applicable.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to accrue trade spend liability over the agreement period: straight-line (evenly over time), event-based (per promotional event), scan-based (per unit sold), or milestone-based (upon achievement of targets).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued To Date Amount' ;
    rdfs:comment 'Cumulative amount of trade spend accrued under this agreement as of the current date, based on the accrual method.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionSettlementTerms rdf:type rdf:Property ;
    rdfs:label 'Deduction Settlement Terms' ;
    rdfs:comment 'Terms and conditions governing how retailer deductions are validated, matched, and settled against this funding agreement (e.g., backup documentation requirements, dispute resolution process, settlement timeline).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Funding Period End Date' ;
    rdfs:comment 'The date when the funding agreement expires and the funding period ends. Nullable for open-ended agreements.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Funding Period Start Date' ;
    rdfs:comment 'The date when the funding agreement becomes effective and the funding period begins.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target gross margin return on investment for this funding agreement, measuring gross profit generated per dollar of trade spend invested.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signatory Name' ;
    rdfs:comment 'Full name of the manufacturer representative who signed the funding agreement on behalf of the CPG company.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signatory Title' ;
    rdfs:comment 'Job title or role of the manufacturer signatory (e.g., VP of Sales, Director of Trade Marketing, Key Account Manager).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signature Date' ;
    rdfs:comment 'Date when the manufacturer signatory signed the funding agreement.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paidToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Paid To Date Amount' ;
    rdfs:comment 'Cumulative amount of funding actually paid out to the retailer under this agreement as of the current date.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which payments are made under this agreement: one-time (lump sum), monthly, quarterly, semi-annual, annual, or event-based (triggered by specific promotional events).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceConditions rdf:type rdf:Property ;
    rdfs:label 'Performance Conditions' ;
    rdfs:comment 'Detailed description of performance metrics, targets, or conditions that must be met for funding to be released or for rebates to be earned (e.g., minimum sales volume, market share targets, display compliance).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Amount' ;
    rdfs:comment 'Remaining uncommitted or unpaid funding balance available under this agreement (total committed minus paid to date).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this funding agreement is a renewal of a previous agreement (true) or a new agreement (false).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retailerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Retailer Signatory Name' ;
    rdfs:comment 'Full name of the retailer representative who signed the funding agreement on behalf of the retail account.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Retailer Signatory Title' ;
    rdfs:comment 'Job title or role of the retailer signatory (e.g., Category Manager, Buyer, VP of Merchandising).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Retailer Signature Date' ;
    rdfs:comment 'Date when the retailer signatory signed the funding agreement.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roiTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percentage' ;
    rdfs:comment 'Target return on investment percentage for this funding agreement, used to measure promotional effectiveness and justify trade spend allocation.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Committed Amount' ;
    rdfs:comment 'Total funding amount committed by the manufacturer to the retailer under this agreement, in the agreement currency.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Lift Measurement Id' ;
    rdfs:comment 'Unique identifier for the promotional lift measurement record.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPromotedVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Promoted Volume Units' ;
    rdfs:comment 'The actual volume in units sold during the promotional period.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Baseline Calculation Method' ;
    rdfs:comment 'The specific method used to calculate the baseline volume for comparison.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePeriodWeeks rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Weeks' ;
    rdfs:comment 'The number of weeks of historical data used to establish the baseline trend.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume Units' ;
    rdfs:comment 'The expected volume in units based on pre-promotion trend analysis, representing what would have sold without the promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cannibalizationRate rdf:type rdf:Property ;
    rdfs:label 'Cannibalization Rate' ;
    rdfs:comment 'The percentage of incremental lift that came from other SKUs within the same brand or category, indicating internal sales transfer.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'The statistical confidence level of the lift measurement, typically 90%, 95%, or 99%.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVintageDate rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Date' ;
    rdfs:comment 'The date when the source data used for this lift measurement was extracted or made available.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:haloEffectUnits rdf:type rdf:Property ;
    rdfs:label 'Halo Effect Units' ;
    rdfs:comment 'The additional volume lift observed in related non-promoted SKUs due to the promotion, representing positive spillover effects.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Percentage' ;
    rdfs:comment 'The percentage lift over baseline, calculated as (incremental lift units / baseline volume units) * 100.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftUnits rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Units' ;
    rdfs:comment 'The incremental volume in units attributable to the promotion, calculated as actual promoted volume minus baseline volume.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalRevenue rdf:type rdf:Property ;
    rdfs:label 'Incremental Revenue' ;
    rdfs:comment 'The incremental revenue generated by the promotion, calculated as incremental lift units multiplied by promotional price.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftSource rdf:type rdf:Property ;
    rdfs:label 'Lift Source' ;
    rdfs:comment 'The data source used to measure promotional lift.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text notes documenting any anomalies, data quality issues, or special considerations for this lift measurement.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Week End Date' ;
    rdfs:comment 'The end date of the week for which lift is measured.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Week Start Date' ;
    rdfs:comment 'The start date of the week for which lift is measured, typically aligned with retailer calendar weeks.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The p-value from the statistical test of lift significance, where values below 0.05 typically indicate statistical significance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postPromotionDipUnits rdf:type rdf:Property ;
    rdfs:label 'Post Promotion Dip Units' ;
    rdfs:comment 'The volume decline observed in the weeks immediately following the promotion, indicating pantry loading or forward buying effects.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'The actual selling price during the promotional period.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPrice rdf:type rdf:Property ;
    rdfs:label 'Regular Price' ;
    rdfs:comment 'The regular non-promotional selling price used as baseline for price comparison.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalSignificanceFlag rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Flag' ;
    rdfs:comment 'Indicates whether the measured lift is statistically significant at the specified confidence level.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when the lift measurement was validated and approved for use in ROI calculations.' ;
    rdfs:domain ind:LiftMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:posRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Pos Redemption Id' ;
    rdfs:comment 'Unique identifier for the point-of-sale redemption transaction record.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearinghouseName rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Name' ;
    rdfs:comment 'Name of the coupon clearinghouse that processed the manufacturer coupon redemption, if applicable.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Transaction Code' ;
    rdfs:comment 'Transaction identifier assigned by the coupon clearinghouse for tracking and settlement.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Received Timestamp' ;
    rdfs:comment 'Timestamp when the redemption data was received from the source system or data feed.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:handlingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Fee Amount' ;
    rdfs:comment 'Handling fee paid to the retailer or clearinghouse for processing the coupon redemption.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Code' ;
    rdfs:comment 'Identifier for the POS terminal or register where the redemption was processed.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Promoted Unit Price' ;
    rdfs:comment 'Final unit price paid by the consumer after the promotional discount was applied.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'The date when the promotional offer was redeemed at point of sale.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Redemption Quantity' ;
    rdfs:comment 'Number of units of the SKU purchased with the promotional offer applied.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current processing status of the redemption record in the settlement workflow.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Precise timestamp when the redemption occurred at the point of sale, including time zone information.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Transaction Number' ;
    rdfs:comment 'Business identifier for the redemption transaction, typically sourced from retailer POS system or coupon clearinghouse.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Redemption Value Amount' ;
    rdfs:comment 'Total monetary value of the discount or savings provided through the redemption.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Regular Unit Price' ;
    rdfs:comment 'Regular shelf price per unit before the promotional discount was applied.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Amount paid by the manufacturer to the retailer or clearinghouse for this redemption.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Total Amount' ;
    rdfs:comment 'Total transaction amount for the basket or order containing the redeemed offer.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Discount Amount' ;
    rdfs:comment 'Discount amount applied per unit of the SKU redeemed.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Flag' ;
    rdfs:comment 'Indicates whether the redemption has been validated against promotion rules and eligibility criteria.' ;
    rdfs:domain ind:PosRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postEventAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Post Event Analysis Id' ;
    rdfs:comment 'Unique identifier for the post-event analysis record. Primary key for this analytical entity capturing promotion performance measurement at SKU-retailer-period granularity.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Post Employee Id' ;
    rdfs:comment 'Reference to the trade marketing analyst or data scientist who conducted this post-event analysis. Enables accountability and quality tracking.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Trade Spend Amount' ;
    rdfs:comment 'Total trade spend actually incurred for this promotion event, including all accruals, deductions, and settlements. Used for actual ROI and GMROI calculation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Completed Timestamp' ;
    rdfs:comment 'Date and time when the post-event analysis was completed and results finalized. Marks the transition to approved or archived status.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period End Date' ;
    rdfs:comment 'End date of the promotional period being analyzed. Completes the temporal boundary for performance measurement window.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period Start Date' ;
    rdfs:comment 'Start date of the promotional period being analyzed. Defines the temporal boundary for lift measurement and baseline comparison.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle status of the post-event analysis. Tracks progression from initial draft through approval and archival.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text commentary from the analyst conducting the post-event review. Captures qualitative insights, contextual factors, and recommendations for future planning.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineConfidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Baseline Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the statistical confidence interval for baseline estimate. Quantifies uncertainty in baseline calculation.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineConfidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Baseline Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the statistical confidence interval for baseline estimate. Completes the uncertainty quantification for baseline.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDataSource rdf:type rdf:Property ;
    rdfs:label 'Baseline Data Source' ;
    rdfs:comment 'Primary data source used for baseline estimation. Identifies whether baseline was derived from POS scan data, syndicated panels, or internal systems.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineEstimationMethodology rdf:type rdf:Property ;
    rdfs:label 'Baseline Estimation Methodology' ;
    rdfs:comment 'Statistical or analytical method used to calculate the baseline volume estimate. Critical for understanding confidence and reproducibility of lift measurements. [ENUM-REF-CANDIDATE: moving_average|exponential_smoothing|regression|causal_model|nielsen_iq|tradeedge|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerIncrementalCase rdf:type rdf:Property ;
    rdfs:label 'Cost Per Incremental Case' ;
    rdfs:comment 'Trade spend divided by incremental lift in case-equivalent units. Measures cost efficiency of generating incremental volume.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Flag' ;
    rdfs:comment 'Indicates whether the retailer executed the agreed in-store display (end cap, shipper, pallet) as planned. True if compliant, False if not.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Feature Compliance Flag' ;
    rdfs:comment 'Indicates whether the retailer executed the agreed feature advertising (circular, flyer, digital ad) as planned. True if compliant, False if not.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmroi rdf:type rdf:Property ;
    rdfs:label 'Gmroi' ;
    rdfs:comment 'Gross margin return on investment, calculated as incremental gross margin divided by actual trade spend. Measures profitability efficiency of promotional investment.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:learningClassification rdf:type rdf:Property ;
    rdfs:label 'Learning Classification' ;
    rdfs:comment 'Categorical assessment of promotion performance used to feed TPO learning loops. Enables pattern recognition and future optimization.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Lift Measurement Methodology' ;
    rdfs:comment 'Analytical approach used to isolate and measure promotional lift. Determines rigor and defensibility of lift claims.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftMeasurementSource rdf:type rdf:Property ;
    rdfs:label 'Lift Measurement Source' ;
    rdfs:comment 'Primary data source used to measure actual promoted volume and calculate lift. Critical for understanding data quality and measurement reliability.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosImpactEstimatedUnits rdf:type rdf:Property ;
    rdfs:label 'Oos Impact Estimated Units' ;
    rdfs:comment 'Estimated sales volume lost due to out-of-stock incidents during the promotion. Quantifies the opportunity cost of poor availability.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Oos Incident Count' ;
    rdfs:comment 'Number of out-of-stock incidents detected during the promotional period. Critical for understanding lost sales opportunity and execution quality.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Trade Spend Amount' ;
    rdfs:comment 'Total trade spend budgeted for this promotion event at planning time. Baseline for variance analysis and ROI calculation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prePromotionTrend rdf:type rdf:Property ;
    rdfs:label 'Pre Promotion Trend' ;
    rdfs:comment 'Observed sales trend in the period immediately preceding the promotion. Contextualizes baseline and helps explain lift performance.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Compliance Flag' ;
    rdfs:comment 'Indicates whether the retailer maintained the agreed promotional price throughout the event period. True if compliant, False if not.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalRoi rdf:type rdf:Property ;
    rdfs:label 'Promotional Roi' ;
    rdfs:comment 'Return on investment for this promotion, calculated as (incremental gross profit - actual trade spend) / actual trade spend. Primary financial effectiveness metric.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendationForFuture rdf:type rdf:Property ;
    rdfs:label 'Recommendation For Future' ;
    rdfs:comment 'Strategic recommendation for how this promotion type should be treated in future planning cycles based on performance results.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Retailer Compliance Score' ;
    rdfs:comment 'Composite score (0-100) measuring retailer adherence to promotional execution requirements including pricing, display, feature, and inventory. Higher scores indicate better execution quality.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of promoted inventory that sold through to consumers during the promotional period. Indicates promotional velocity and inventory efficiency.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeSpendVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Variance Amount' ;
    rdfs:comment 'Difference between actual and planned trade spend (actual minus planned). Highlights budget adherence and cost control effectiveness.' ;
    rdfs:domain ind:PostEventAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedPriceId rdf:type rdf:Property ;
    rdfs:label 'Promoted Price Id' ;
    rdfs:comment 'Primary key for promoted_price' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPromotedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Promoted Employee Id' ;
    rdfs:comment 'Reference to the user or manager who approved this promotional price. Used for audit trail and accountability in trade spend governance.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPromotedLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Promoted Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this promotional pricing record. Used for change tracking and audit trail purposes.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:estimatedVolumeLift rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Lift' ;
    rdfs:comment 'The projected percentage increase in sales volume expected from this promotional price compared to baseline sales. Used for demand planning and promotional forecasting.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdvertised rdf:type rdf:Property ;
    rdfs:label 'Is Advertised' ;
    rdfs:comment 'Boolean flag indicating whether this promotional price is featured in retailer advertising, circulars, or marketing campaigns. True if advertised, False if unadvertised in-store promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Boolean flag indicating whether this promotional price can be combined (stacked) with other promotions, coupons, or discounts. True if stackable, False if exclusive.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Purchase Quantity' ;
    rdfs:comment 'The maximum number of units eligible for this promotional price per transaction or per customer. Used to cap promotional exposure and manage trade spend. Nullable if no cap applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Percentage' ;
    rdfs:comment 'The percentage discount from the regular shelf price, calculated as ((regular_shelf_price - promotional_price_amount) / regular_shelf_price) * 100. Represents the depth of the promotional discount.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategyType rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Type' ;
    rdfs:comment 'Classification of the promotional pricing strategy. Hi-Lo (High-Low temporary price reduction), EDLP (Everyday Low Price), multi-buy (e.g., 2 for $5), BOGO (Buy One Get One), scan-back (retailer scans at checkout for discount), temporary price reduction, rebate, or coupon-based pricing. [ENUM-REF-CANDIDATE: hi_lo|edlp|multi_buy|bogo|scan_back|temporary_price_reduction|rebate|coupon — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Amount' ;
    rdfs:comment 'The per-unit allowance or funding provided by the manufacturer to the retailer to support this promotional price. Used for trade spend accrual and settlement calculations.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Amount' ;
    rdfs:comment 'The promoted price point for the SKU during the promotional period. This is the actual selling price offered to consumers or retailers during the promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Code' ;
    rdfs:comment 'Business identifier or code for this promotional price record. Used for external reference and integration with TPM systems.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPriceDescription rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Description' ;
    rdfs:comment 'Detailed description of the promotional price offer, including terms, conditions, and any special instructions for retail execution or consumer communication.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPriceName rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Name' ;
    rdfs:comment 'Human-readable name or label for this promotional price configuration, used for identification and reporting purposes.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularShelfPrice rdf:type rdf:Property ;
    rdfs:label 'Regular Shelf Price' ;
    rdfs:comment 'The standard or recommended selling price (RSP/MSRP) for the SKU before the promotional discount is applied. Used as the baseline for calculating price reduction depth.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailerMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Retailer Margin Percentage' ;
    rdfs:comment 'The target or agreed-upon margin percentage for the retailer when selling at this promotional price. Used for trade negotiation and pricing strategy analysis.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scanBackRate rdf:type rdf:Property ;
    rdfs:label 'Scan Back Rate' ;
    rdfs:comment 'The per-unit reimbursement rate paid to the retailer for each unit sold at the promotional price under a scan-back pricing model. Nullable if not a scan-back promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Tpm System Code' ;
    rdfs:comment 'External system identifier from the source Trade Promotion Management system (e.g., Salesforce TPM, SAP TPM). Used for data lineage and system integration.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionAccrualId rdf:type rdf:Property ;
    rdfs:label 'Promotion Accrual Id' ;
    rdfs:comment 'Unique identifier for the promotion accrual record. Primary key.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Business-readable unique identifier for the accrual record, used for tracking and reconciliation.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineVolume rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume' ;
    rdfs:comment 'Expected sales volume without the promotion, used to calculate incremental lift and accrual accuracy. Nullable for non-lift-based accruals.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Claim Number' ;
    rdfs:comment 'Reference number for the retailer deduction claim associated with this accrual, used for deduction management and reconciliation. Nullable if no claim submitted.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalVolume rdf:type rdf:Property ;
    rdfs:label 'Incremental Volume' ;
    rdfs:comment 'Additional sales volume generated by the promotion above the baseline, used for ROI and GMROI analysis. Nullable for non-lift-based accruals.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Flag indicating whether the accrual is under dispute with the retailer or customer (true if disputed, false otherwise).' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'Total quantity of product units sold during the promotional period that triggered the accrual. Nullable for non-volume-based accruals.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Rate or percentage applied to calculate the accrual amount (e.g., discount percentage, rebate rate per unit). Nullable for lump-sum accruals.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Calculated return on investment for the promotional spend, expressed as a percentage. Nullable if not yet calculated.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Co Document Number' ;
    rdfs:comment 'SAP CO document number for the controlling posting of the accrual, used for cost allocation and internal reporting.' ;
    rdfs:domain ind:PromotionAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP FI document number for the financial posting of the accrual, used for audit trail and reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPromotionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Promotion Employee Id' ;
    rdfs:comment 'Identifier of the employee or user who approved the deduction settlement. Links to the workforce employee master.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPromotionModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Promotion Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this deduction record. Links to the workforce employee master for audit purposes.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether this deduction impacts trade promotion accruals. True indicates the deduction should be reconciled against accrued trade spend, false indicates it is outside accrual scope.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the deduction has been open since the deduction date. Used for aging analysis and prioritization of dispute resolution activities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionDate rdf:type rdf:Property ;
    rdfs:label 'Deduction Date' ;
    rdfs:comment 'Date on which the retailer took the deduction from the invoice payment. Represents the business event timestamp for the deduction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Number' ;
    rdfs:comment 'Business-facing unique deduction number assigned by the retailer or internal system. Used for external communication and dispute tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionSource rdf:type rdf:Property ;
    rdfs:label 'Deduction Source' ;
    rdfs:comment 'Source system or channel through which the deduction was received. Retailer portal indicates web-based submission, EDI 846 indicates electronic data interchange, manual entry indicates internal creation, bank reconciliation indicates discovery during payment matching, and automated matching indicates system-generated from remittance data.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionType rdf:type rdf:Property ;
    rdfs:label 'Deduction Type' ;
    rdfs:comment 'Classification of the deduction based on the reason for the short-payment. Promotional deductions relate to trade promotions, pricing deductions to price discrepancies, shortage to quantity issues, compliance to retailer policy violations, quality to product defects, freight to shipping issues, and administrative to processing errors. [ENUM-REF-CANDIDATE: promotional|pricing|shortage|compliance|quality|freight|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Gmroi Impact Percentage' ;
    rdfs:comment 'Percentage impact of this deduction on the gross margin return on investment for the associated promotion. Used for profitability analysis and promotional effectiveness measurement.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailerClaimDate rdf:type rdf:Property ;
    rdfs:label 'Retailer Claim Date' ;
    rdfs:comment 'Date on which the retailer filed the deduction claim in their system. May differ from the deduction date.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Retailer Contact Email' ;
    rdfs:comment 'Email address of the retailer contact person for this deduction. Used for electronic communication during dispute resolution.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerContactName rdf:type rdf:Property ;
    rdfs:label 'Retailer Contact Name' ;
    rdfs:comment 'Name of the retailer contact person responsible for this deduction claim. Used for communication and relationship management during dispute resolution.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Roi Impact Amount' ;
    rdfs:comment 'Calculated impact of this deduction on the promotional return on investment. Represents the reduction in promotional effectiveness due to the deduction. Used for post-event analysis and promotional optimization.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Date' ;
    rdfs:comment 'Target date by which the deduction should be resolved based on internal service level agreements or retailer contractual terms. Used for performance tracking and escalation management.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Url' ;
    rdfs:comment 'URL or file path to supporting documentation for the deduction claim, such as proof of performance, promotional materials, or retailer correspondence. Used for audit and dispute resolution.' ;
    rdfs:domain ind:PromotionDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Units' ;
    rdfs:comment 'The realized sales volume in units achieved during the promotional event, used for post-event analysis and lift measurement.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiRatio rdf:type rdf:Property ;
    rdfs:label 'Gmroi Ratio' ;
    rdfs:comment 'The gross margin return on investment for this promotional event, calculated as Gross Margin / Average Inventory Investment, measuring profitability efficiency.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Volume Units' ;
    rdfs:comment 'The forecasted sales volume in units expected during the promotional event, used for planning and ROI estimation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postEventAnalysisCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Event Analysis Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether post-event analysis has been completed for this promotional event, including lift measurement and ROI calculation.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postEventAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Post Event Analysis Date' ;
    rdfs:comment 'The date when post-event analysis was completed for this promotional event.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Promotional Lift Percentage' ;
    rdfs:comment 'The percentage increase in sales volume attributable to the promotional event, calculated as (Actual Volume - Baseline Volume) / Baseline Volume * 100.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'The total rebate amount paid to the retailer for this promotional event, typically calculated post-event based on performance metrics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceTpmEventCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Tpm Event Code' ;
    rdfs:comment 'The unique identifier from Salesforce Consumer Goods Cloud Trade Promotion Management system for this event record, used for system integration and data lineage.' ;
    rdfs:domain ind:PromotionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerFundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retailer Funding Agreement Id' ;
    rdfs:comment 'Reference to the retailer funding agreement or trade contract governing the promotional terms for this SKU.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:actualPromotionalVolumeCases rdf:type rdf:Property ;
    rdfs:label 'Actual Promotional Volume Cases' ;
    rdfs:comment 'Actual volume of cases sold during the promotion period for this SKU. Captured post-event from POS or shipment data.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPromotionalVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Promotional Volume Units' ;
    rdfs:comment 'Actual volume of consumer units sold during the promotion period for this SKU. Used for promotional lift and ROI analysis.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineVolumeEstimateUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume Estimate Units' ;
    rdfs:comment 'Estimated volume of units that would have been sold without the promotion. Used to calculate incremental lift. Typically derived from historical sales trends.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of promotional pricing compliance verification for this SKU. Ensures promotional pricing was executed as agreed with the retailer.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date when promotional pricing compliance was verified for this SKU through retail execution audits or POS data validation.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayLocationType rdf:type rdf:Property ;
    rdfs:label 'Display Location Type' ;
    rdfs:comment 'Type of in-store display location where this promotional SKU is merchandised. Impacts visibility and promotional lift. [ENUM-REF-CANDIDATE: Shelf|End Cap|Free Standing Display|Pallet|Cooler|Checkout|Secondary Placement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Type of promotional feature or advertising support provided for this SKU during the promotion event. [ENUM-REF-CANDIDATE: Circular Ad|Digital Ad|In-Store Signage|Shelf Talker|Coupon|Loyalty Offer|None — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Percent' ;
    rdfs:comment 'Percentage lift in volume due to the promotion. Calculated as (incremental_lift_volume_units / baseline_volume_estimate_units) * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Volume Units' ;
    rdfs:comment 'Incremental volume of units sold above baseline due to the promotion. Calculated as actual_promotional_volume_units - baseline_volume_estimate_units.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFeaturedSku rdf:type rdf:Property ;
    rdfs:label 'Is Featured Sku' ;
    rdfs:comment 'Indicates whether this SKU is a featured hero product in the promotion event. Featured SKUs typically receive premium merchandising and advertising support.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedPromotionalVolumeCases rdf:type rdf:Property ;
    rdfs:label 'Planned Promotional Volume Cases' ;
    rdfs:comment 'Forecasted volume of cases expected to be sold during the promotion period for this SKU. Used for trade spend budgeting and supply planning.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPromotionalVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Promotional Volume Units' ;
    rdfs:comment 'Forecasted volume of consumer units expected to be sold during the promotion period for this SKU.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceReductionDepthPercent rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Depth Percent' ;
    rdfs:comment 'Percentage discount from regular shelf price to promoted price. Calculated as ((regular_shelf_price - promoted_price) / regular_shelf_price) * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Approval Status' ;
    rdfs:comment 'Current approval status of the promotional pricing for this SKU. Tracks the workflow state from draft through execution to completion. [ENUM-REF-CANDIDATE: Draft|Pending Approval|Approved|Rejected|Active|Completed|Cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Approved Timestamp' ;
    rdfs:comment 'Date and time when the promotional pricing for this SKU was approved.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotedPrice rdf:type rdf:Property ;
    rdfs:label 'Promoted Price' ;
    rdfs:comment 'The temporary promotional price offered to consumers during the promotion event. Expressed in the base currency of the business.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedPriceType rdf:type rdf:Property ;
    rdfs:label 'Promoted Price Type' ;
    rdfs:comment 'Type of promotional pricing mechanism applied to this SKU. Hi-Lo: temporary price reduction; EDLP: everyday low price; Multi-Buy: quantity discount; BOGO: buy-one-get-one; Scan-Back: retailer scanned rebate; Off-Invoice: deduction at invoice; Bill-Back: post-event settlement. [ENUM-REF-CANDIDATE: Hi-Lo|EDLP|Multi-Buy|BOGO|Scan-Back|Off-Invoice|Bill-Back — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Effective End Date' ;
    rdfs:comment 'The date when the promotional pricing for this SKU expires and regular pricing resumes.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Effective Start Date' ;
    rdfs:comment 'The date when the promotional pricing for this SKU becomes effective at retail.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalDiscountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Per Unit' ;
    rdfs:comment 'Absolute discount amount per unit (regular_shelf_price - promoted_price). Represents the per-unit trade spend investment.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalGmroi rdf:type rdf:Property ;
    rdfs:label 'Promotional Gmroi' ;
    rdfs:comment 'Gross margin return on investment for this promotional SKU. Calculated as incremental_gross_margin / total_trade_spend_amount.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Roi Percent' ;
    rdfs:comment 'Return on investment for this promotional SKU. Calculated as (incremental_gross_profit - total_trade_spend_amount) / total_trade_spend_amount * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Trade Spend Amount' ;
    rdfs:comment 'Total trade spend investment for this SKU in this promotion event. Calculated as promotional_discount_per_unit * actual_promotional_volume_units.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionRebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Promotion Rebate Agreement Id' ;
    rdfs:comment 'Unique identifier for the promotion rebate agreement. Primary key for this entity.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionRebateAgreement .

ind:quaternaryPromotionLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Promotion Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this rebate agreement record.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPromotionCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Promotion Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created this rebate agreement record.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoSettlementEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Settlement Enabled' ;
    rdfs:comment 'Indicates whether rebate settlements are calculated and processed automatically at the end of each measurement period (true) or require manual review and approval (false).' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Method used to calculate the rebate amount. Percent of net sales applies a percentage to net revenue, dollar per case applies a fixed amount per shipping case, dollar per unit applies per individual unit, percent of gross sales applies to pre-discount revenue, and fixed amount is a predetermined lump sum.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionTerms rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Terms' ;
    rdfs:comment 'Contractual terms defining the process for resolving disputes over rebate calculations, including escalation procedures and arbitration clauses.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days after settlement calculation when payment is due to the retailer. Standard terms are 30, 45, or 60 days.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'The percentage rate or dollar amount used in rebate calculation. For percentage-based rebates, this is the percentage (e.g., 2.5000 for 2.5%). For dollar-based rebates, this is the dollar amount per unit of measure.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate agreement based on the performance criteria or strategic objective. Volume tier rewards purchase volume thresholds, growth incentive rewards year-over-year growth, category captain rewards merchandising leadership, compliance bonus rewards adherence to terms, market development funds new market expansion, and promotional support funds joint promotional activities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Rebate Agreement Number' ;
    rdfs:comment 'SAP SD rebate agreement number for financial integration and payment processing. Links to SAP FI/CO for accrual and settlement posting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for tier thresholds. Cases refers to shipping cases, units to individual consumer units, dollars to net sales revenue, and physical measures to product weight or volume.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate' ;
    rdfs:comment 'Rebate rate applicable when tier 1 threshold is achieved. Format matches calculation_basis (percentage or dollar amount).' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold' ;
    rdfs:comment 'Minimum qualifying volume or revenue required to earn the first tier rebate rate. Unit of measure defined by threshold_unit field.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate' ;
    rdfs:comment 'Rebate rate applicable when tier 2 threshold is achieved. Null if agreement has only one tier.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold' ;
    rdfs:comment 'Minimum qualifying volume or revenue required to earn the second tier rebate rate. Null if agreement has only one tier.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Rate' ;
    rdfs:comment 'Rebate rate applicable when tier 3 threshold is achieved. Null if agreement has fewer than three tiers.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Threshold' ;
    rdfs:comment 'Minimum qualifying volume or revenue required to earn the third tier rebate rate. Null if agreement has fewer than three tiers.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierStructure rdf:type rdf:Property ;
    rdfs:label 'Tier Structure' ;
    rdfs:comment 'Defines how rebate tiers are applied. Single tier has one rate for all qualifying volume, multi-tier has different rates at different thresholds, progressive applies higher rates only to incremental volume above each threshold, and retroactive applies the highest achieved rate to all volume.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative rebate amount accrued across all settlement periods to date. Updated with each settlement calculation.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative rebate amount paid to the retailer across all settlement periods to date. Updated when payments are processed.' ;
    rdfs:domain ind:PromotionRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateSettlementId rdf:type rdf:Property ;
    rdfs:label 'Rebate Settlement Id' ;
    rdfs:comment 'Unique identifier for the rebate settlement transaction. Primary key for the rebate settlement record.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRebateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rebate Employee Id' ;
    rdfs:comment 'Reference to the user or employee who approved this rebate settlement for payment. Nullable until approval is completed.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRebateLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Rebate Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user or system process that last modified this rebate settlement record. Audit field for data governance.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRebateCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rebate Created By Employee Id' ;
    rdfs:comment 'Reference to the user or system process that created this rebate settlement record. Audit field for data governance.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Flag' ;
    rdfs:comment 'Indicates whether this settlement reverses a previously accrued rebate liability. True if the settlement clears an accrual; False if it represents a new liability.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Manual adjustment applied to the calculated rebate amount. May represent corrections, dispute resolutions, or contractual modifications. Positive or negative value.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date on which the trade partner raised a dispute against this settlement. Nullable unless a dispute has been filed.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnedRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Rebate Amount' ;
    rdfs:comment 'Total rebate amount earned by the trade partner for the settlement period. Calculated based on qualifying revenue/volume and applicable rebate rate or tier.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net amount to be paid to the trade partner after all adjustments. Equals earned_rebate_amount plus adjustment_amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingRevenue rdf:type rdf:Property ;
    rdfs:label 'Qualifying Revenue' ;
    rdfs:comment 'Total revenue amount that qualifies for rebate calculation during the settlement period. Represents the base upon which rebate percentage or tier is applied.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingVolume rdf:type rdf:Property ;
    rdfs:label 'Qualifying Volume' ;
    rdfs:comment 'Total volume (units, cases, or other measure) that qualifies for rebate calculation during the settlement period. Used for volume-based rebate agreements.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which a disputed settlement was resolved. Nullable until dispute resolution is completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'End date of the performance period for which this rebate settlement is calculated. Defines the close of the qualifying transaction window.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'Start date of the performance period for which this rebate settlement is calculated. Defines the beginning of the qualifying transaction window.' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierAchieved rdf:type rdf:Property ;
    rdfs:label 'Tier Achieved' ;
    rdfs:comment 'Rebate tier level achieved by the trade partner during the settlement period. Identifies which performance threshold was met (e.g., Bronze, Silver, Gold, Platinum).' ;
    rdfs:domain ind:RebateSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for the qualifying volume. Defines how volume is quantified for rebate calculation purposes.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerComplianceId rdf:type rdf:Property ;
    rdfs:label 'Retailer Compliance Id' ;
    rdfs:comment 'Unique identifier for the retailer compliance record. Primary key for this transactional compliance audit entity.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Actual Retail Price' ;
    rdfs:comment 'The actual price observed at the retail location during the compliance audit. Compared against agreed promotional price to determine price compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adFeatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Feature Compliant Flag' ;
    rdfs:comment 'Indicates whether the retailer included the promoted product in their feature advertisement or circular as agreed. True = compliant, False = non-compliant.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreedPromotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Promotional Price' ;
    rdfs:comment 'The promotional price point that was contractually agreed between the manufacturer and retailer. Used as the benchmark for price compliance verification.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Date' ;
    rdfs:comment 'The date when the compliance audit or field check was performed. Represents the business event timestamp for this compliance observation.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Score Percentage' ;
    rdfs:comment 'The overall compliance score expressed as a percentage (0.00 to 100.00). Represents the degree to which the retailer met the agreed promotional execution terms. Used for funding adjustments and future negotiation leverage.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Data Source Reference Code' ;
    rdfs:comment 'The unique identifier from the originating system (e.g., SFA visit ID, third-party audit ticket number, POS transaction batch ID). Enables traceability back to source system for dispute resolution.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Display Compliant Flag' ;
    rdfs:comment 'Indicates whether the retailer set up the agreed in-store promotional display (end cap, floor stand, shipper display). True = compliant, False = non-compliant.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Adjustment Amount' ;
    rdfs:comment 'The net adjustment to trade spend funding based on compliance performance. Positive values indicate additional funding earned through over-compliance; negative values indicate funding clawback due to non-compliance.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonComplianceCategory rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Category' ;
    rdfs:comment 'Standardized classification of the non-compliance root cause. Enables aggregated analysis of compliance failure patterns across retailers and promotions.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Free-text explanation of why the retailer failed to meet compliance requirements. Captures root cause details such as inventory shortage, operational error, pricing system failure, or deliberate non-execution.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Osa Compliant Flag' ;
    rdfs:comment 'Indicates whether the promoted product was in stock and available on shelf during the promotional period. True = compliant (in stock), False = non-compliant (out of stock).' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Url' ;
    rdfs:comment 'URL or file path to photographic evidence captured during the compliance audit. Supports visual verification of display presence, pricing signage, shelf placement, and ad feature inclusion.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogPlacementCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Placement Compliant Flag' ;
    rdfs:comment 'Indicates whether the product was placed according to the agreed planogram specifications (shelf position, facings, adjacency). True = compliant, False = non-compliant.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Price Compliant Flag' ;
    rdfs:comment 'Indicates whether the retailer honored the agreed promotional price point (Hi-Lo or EDLP pricing strategy). True = compliant, False = non-compliant.' ;
    rdfs:domain ind:RetailerCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'The final outcome of a disputed compliance record. Upheld = original non-compliance finding stands, overturned = retailer dispute accepted and compliance restored, partial adjustment = compromise reached with reduced penalty, withdrawn = manufacturer withdrew the compliance claim.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpoScenarioId rdf:type rdf:Property ;
    rdfs:label 'Tpo Scenario Id' ;
    rdfs:comment 'Unique identifier for the TPO scenario. Primary key.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineScenarioId rdf:type rdf:Property ;
    rdfs:label 'Baseline Scenario Id' ;
    rdfs:comment 'Reference to the baseline or control TPO scenario against which this scenario is compared for incremental analysis.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TpoScenario .

ind:parentScenarioTpoScenarioId rdf:type rdf:Property ;
    rdfs:label 'Parent Scenario Tpo Scenario Id' ;
    rdfs:comment 'Reference to the parent TPO scenario if this scenario is a variant or iteration derived from another scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TpoScenario .

ind:primaryTpoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tpo Employee Id' ;
    rdfs:comment 'Reference to the trade marketing analyst or manager who owns and is responsible for this TPO scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTpoApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tpo Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved this TPO scenario for execution or further analysis.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tradeCalendarId rdf:type rdf:Property ;
    rdfs:label 'Trade Calendar Id' ;
    rdfs:comment 'Reference to the promotional calendar that defines the planning period and promotional events covered by this scenario.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeCalendar .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the TPO scenario was evaluated and optimization calculations were completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBaselineScenario rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Scenario' ;
    rdfs:comment 'Boolean flag indicating whether this scenario serves as the baseline control scenario for comparison purposes.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary business goal the TPO scenario is designed to achieve: maximize volume, maximize ROI, maximize GMROI, minimize out-of-stock events, maximize profit, or balanced growth.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'Last date of the planning period covered by this TPO scenario.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'First date of the planning period covered by this TPO scenario.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedBaselineRevenue rdf:type rdf:Property ;
    rdfs:label 'Projected Baseline Revenue' ;
    rdfs:comment 'Forecasted gross revenue expected without promotional activity, serving as the baseline for incremental revenue calculation.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedBaselineVolume rdf:type rdf:Property ;
    rdfs:label 'Projected Baseline Volume' ;
    rdfs:comment 'Forecasted sales volume in units expected without any promotional activity, serving as the baseline for lift calculation.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedGmroi rdf:type rdf:Property ;
    rdfs:label 'Projected Gmroi' ;
    rdfs:comment 'Expected gross margin return on investment, calculated as gross margin dollars generated per dollar of trade spend invested.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedGrossProfit rdf:type rdf:Property ;
    rdfs:label 'Projected Gross Profit' ;
    rdfs:comment 'Forecasted gross profit (revenue minus COGS) expected from this TPO scenario after accounting for trade spend.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedIncrementalRevenue rdf:type rdf:Property ;
    rdfs:label 'Projected Incremental Revenue' ;
    rdfs:comment 'Additional gross revenue expected to be generated by the promotional activities in this scenario, above the baseline.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedIncrementalVolume rdf:type rdf:Property ;
    rdfs:label 'Projected Incremental Volume' ;
    rdfs:comment 'Additional sales volume in units expected to be generated by the promotional activities defined in this TPO scenario, above the baseline.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedPromotionalLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Promotional Lift Percentage' ;
    rdfs:comment 'Expected percentage increase in sales volume compared to baseline, calculated as (incremental volume / baseline volume) * 100.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Roi Percentage' ;
    rdfs:comment 'Expected return on investment expressed as a percentage, calculated as (incremental profit / total scenario spend) * 100.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedTotalRevenue rdf:type rdf:Property ;
    rdfs:label 'Projected Total Revenue' ;
    rdfs:comment 'Total forecasted gross revenue including both baseline and incremental revenue for this scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedTotalVolume rdf:type rdf:Property ;
    rdfs:label 'Projected Total Volume' ;
    rdfs:comment 'Total forecasted sales volume in units including both baseline and incremental volume for this scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, assumptions, and strategic intent of the TPO scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Descriptive name assigned to the TPO scenario for easy identification and reference by trade marketing teams.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioNumber rdf:type rdf:Property ;
    rdfs:label 'Scenario Number' ;
    rdfs:comment 'Business-facing unique identifier for the TPO scenario, typically system-generated with a TPO prefix.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioStatus rdf:type rdf:Property ;
    rdfs:label 'Scenario Status' ;
    rdfs:comment 'Current lifecycle state of the TPO scenario indicating its readiness for execution or decision-making.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalScenarioSpend rdf:type rdf:Property ;
    rdfs:label 'Total Scenario Spend' ;
    rdfs:comment 'Total trade promotion investment allocated across all promotions and accounts in this TPO scenario.' ;
    rdfs:domain ind:TpoScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCalendarTradeCalendarId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Trade Calendar Id' ;
    rdfs:comment 'Identifier of the parent promotional calendar if this is a sub-calendar or regional variant. Links to another promotional calendar entity.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeCalendar .

ind:primaryTradeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Employee Id' ;
    rdfs:comment 'Identifier of the brand manager, category manager, or trade marketing manager who owns and is accountable for this promotional calendar. Links to the employee entity.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryTradeLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Trade Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user or system that last modified this promotional calendar record. Links to the employee or system user entity.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTradeCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Trade Created By Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this promotional calendar record. Links to the employee or system user entity.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEventCount rdf:type rdf:Property ;
    rdfs:label 'Actual Event Count' ;
    rdfs:comment 'The actual number of promotional events executed or in-flight within this calendar period.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Short alphanumeric code for the promotional calendar used in reporting and system integration (e.g., \'FY24Q1-RET\', \'CAL-2024-BRX\').' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Business name of the promotional calendar (e.g., \'FY2024 Q1 Retail Promo Calendar\', \'Annual Brand X Trade Plan\').' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the promotional calendar (draft, submitted, approved, locked, active, closed).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaselineCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Calendar' ;
    rdfs:comment 'Flag indicating whether this is the baseline or master promotional calendar for the fiscal year (true) or a variant/supplemental calendar (false).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when this promotional calendar was locked to prevent further changes, typically after approval and before execution.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEventCount rdf:type rdf:Property ;
    rdfs:label 'Planned Event Count' ;
    rdfs:comment 'The total number of promotional events planned within this calendar period.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The planning frequency or cycle for this promotional calendar (annual, semi-annual, quarterly, monthly).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedTradeSpend rdf:type rdf:Property ;
    rdfs:label 'Total Planned Trade Spend' ;
    rdfs:comment 'The total budgeted trade spend envelope allocated for all promotional events within this calendar, in the base currency.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeCalendarDescription rdf:type rdf:Property ;
    rdfs:label 'Trade Calendar Description' ;
    rdfs:comment 'Detailed business description or purpose of this promotional calendar, including strategic objectives and key initiatives.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner User Employee Id' ;
    rdfs:comment 'Identifier of the business user responsible for planning, executing, and analyzing this trade promotion. Typically a trade marketing manager or category manager. Links to the user or employee master entity.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Budget Amount' ;
    rdfs:comment 'Total authorized trade spend budget allocated for this promotion, including all funding mechanisms (off-invoice, scan-back, display allowances, etc.). Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponFlag rdf:type rdf:Property ;
    rdfs:label 'Coupon Flag' ;
    rdfs:comment 'Indicates whether this promotion includes manufacturer or retailer coupons (print, digital, or mobile). True if coupons are part of the promotion, false otherwise.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayType rdf:type rdf:Property ;
    rdfs:label 'Display Type' ;
    rdfs:comment 'Type of in-store merchandising display associated with this promotion. End-cap (end of aisle), free-standing (floor display), shelf-talker (shelf signage), pallet (bulk display), cooler (refrigerated display), none (no special display).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Roi Percentage' ;
    rdfs:comment 'Expected return on investment for this promotion, calculated as (incremental profit / trade spend) * 100. Used for pre-event planning and approval.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureAdFlag rdf:type rdf:Property ;
    rdfs:label 'Feature Ad Flag' ;
    rdfs:comment 'Indicates whether this promotion includes feature advertising in retailer circulars, flyers, or digital media. True if featured, false otherwise.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingType rdf:type rdf:Property ;
    rdfs:label 'Funding Type' ;
    rdfs:comment 'Mechanism by which trade funds are provided to the retailer. Off-invoice (deducted at purchase), scan-back (reimbursed based on POS sales), bill-back (invoiced after event), lump-sum (fixed payment), accrual (reserved funds).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Descriptive name of the trade promotion program for business user identification and reporting purposes.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionNumber rdf:type rdf:Property ;
    rdfs:label 'Promotion Number' ;
    rdfs:comment 'Business-facing unique identifier for the trade promotion program, typically generated by the TPM system. Format: TPM-YYYYNNNN where YYYY is year and NNNN is sequence.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionObjective rdf:type rdf:Property ;
    rdfs:label 'Promotion Objective' ;
    rdfs:comment 'Primary business objective driving the trade promotion strategy. Volume growth (increase unit sales), market share gain (capture competitor share), new product launch (trial generation), competitive defense (respond to competitor activity), inventory clearance (reduce excess stock), seasonal event (holiday/event-driven).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle status of the trade promotion. Planned (in design), approved (authorized for execution), active (currently running), closed (completed with results finalized), cancelled (terminated before completion), on-hold (temporarily suspended).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the trade promotion mechanism. Temporary price reduction (Hi-Lo), feature ad (retailer circular), display (end-cap/shelf), BOGO (buy-one-get-one), multi-buy (quantity discount), scan-back (post-sale rebate). [ENUM-REF-CANDIDATE: temporary_price_reduction|feature_ad|display|bogo|multi_buy|scan_back|off_invoice|coupon|loyalty_reward|edlp|slotting_allowance|markdown_allowance — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Target Volume Units' ;
    rdfs:comment 'Target sales volume in units expected to be achieved during the promotion period, including baseline and incremental lift.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeSpendAllocationId rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Allocation Id' ;
    rdfs:comment 'Unique identifier for the trade spend allocation record. Primary key for this transactional entity capturing budget allocation to promotion events.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual amount of trade spend executed or paid out. Populated post-event for variance analysis and reconciliation with accounts payable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'The actual sales volume achieved during the promotion period. Populated post-event from POS or shipment data for lift analysis and ROI calculation.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount of trade spend allocated to this promotion event, account, brand, or SKU group. Represents the planned or budgeted spend.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-readable unique identifier for the trade spend allocation. Used for external communication, audit trails, and reconciliation with finance systems.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the trade spend allocation. Tracks progression from planning through approval, execution, and final settlement with retailer. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|committed|executed|settled|cancelled|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of trade spend formally committed after approval. May differ from allocated amount due to negotiation or budget adjustments.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiPercentage rdf:type rdf:Property ;
    rdfs:label 'Gmroi Percentage' ;
    rdfs:comment 'The gross margin return on investment for this trade spend allocation. Measures gross margin dollars generated per dollar of trade spend invested.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'The end date of the promotion event to which this spend is allocated. Defines the promotional activity window for ROI measurement and post-event analysis.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'The start date of the promotion event to which this spend is allocated. Used for temporal analysis and matching spend to promotional activity periods.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'High-level classification of trade spend for strategic analysis and reporting. Groups spend types into broader business categories for executive dashboards.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendType rdf:type rdf:Property ;
    rdfs:label 'Spend Type' ;
    rdfs:comment 'Classification of the trade spend mechanism. [ENUM-REF-CANDIDATE: off_invoice_discount|scan_back|bill_back|lump_sum|coop_advertising|slotting_fee|display_allowance|free_goods|volume_rebate|growth_incentive — promote to reference product]' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'The target sales volume expected with this trade spend allocation. Used for performance measurement and ROI calculation.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpAuditId rdf:type rdf:Property ;
    rdfs:label 'Gmp Audit Id' ;
    rdfs:comment 'Reference to the parent GMP audit event during which this finding was raised.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmpAudit .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record if this is identified as a repeat finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:affectedProcessArea rdf:type rdf:Property ;
    rdfs:label 'Affected Process Area' ;
    rdfs:comment 'The manufacturing or quality process area where the finding was identified (e.g., Raw Material Receiving, Mixing, Filling, Packaging, Quality Control Laboratory, Warehouse).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents, photos, or evidence files attached to the finding record (e.g., photos of non-conformance, lab reports, procedure documents).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By' ;
    rdfs:comment 'Name or identifier of the quality manager or authorized personnel who approved the closure of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary of the corrective actions taken or planned to remediate the finding and prevent recurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the audit finding. Critical: immediate risk to product safety or regulatory compliance; Major: significant deviation from GMP requiring prompt correction; Minor: isolated deviation with low impact; Observation: opportunity for improvement without regulatory breach.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date when the audit finding was identified and documented during the audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including observed deviation, evidence collected, and context of the non-conformance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the audit finding, typically formatted as audit prefix followed by sequential number (e.g., FDA-000123, INT-002456).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSourceDocument rdf:type rdf:Property ;
    rdfs:label 'Finding Source Document' ;
    rdfs:comment 'Reference to the source audit report, inspection form, or document where the finding was originally recorded.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding in the remediation workflow.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Brief summary title of the audit finding for quick identification and reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulatory requirement, GMP guideline, or standard that was violated or not met (e.g., 21 CFR 211.100, EU GMP Chapter 4, ISO 22716 Section 5.3).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the finding was formally reported to the regulatory authority, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this finding must be reported to regulatory authorities such as FDA (Food and Drug Administration) or EU competent authorities per regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Received Date' ;
    rdfs:comment 'Date when a formal response or acknowledgment was received from the regulatory authority regarding the reported finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat observation from a previous audit, suggesting ineffective corrective action or systemic issue.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the organization must submit a formal response or corrective action plan to address the finding.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the formal response or corrective action plan was submitted to the auditor or regulatory authority.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Responsible Person' ;
    rdfs:comment 'Name or identifier of the individual assigned ownership for addressing the finding and implementing corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause analysis conducted to determine the underlying reason for the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the effectiveness of corrective actions (e.g., follow-up audit, document review, process validation, trend analysis).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Id' ;
    rdfs:comment 'Unique identifier for the batch release decision record. Primary key for the batch release entity.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchReleaseCertificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: Link batch_release to the Certificate of Analysis that documents the released batch, removing redundant reference number.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the batch release record. Required for audit trail and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Total quantity of finished goods produced in this batch. Used for yield calculation and inventory planning.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., kilograms, liters, units). Aligns with GS1 standards for trade item measurement. [ENUM-REF-CANDIDATE: kg|lbs|liters|gallons|units|cases|pallets — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a CAPA investigation is required based on deviations or non-conformances identified during batch production or testing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of manufacturing or quality deviations recorded during the production and testing of this batch. Used for quality trend analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Date' ;
    rdfs:comment 'Date when the regulatory or business hold was placed on the batch. Nullable if no hold exists.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Code identifying the manufacturing facility or plant where the batch was produced. Used for site-level quality tracking and regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Product Registration Number' ;
    rdfs:comment 'Regulatory registration or approval number for the product in the target market. Required for FDA NDC, EU product registration, or equivalent.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the batch manufacturing was completed. Critical for shelf-life calculation and FEFO inventory management.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Overall status of QC inspection and testing for this batch. Summarizes results from multiple QC test records.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qp Signature Timestamp' ;
    rdfs:comment 'Timestamp when the Qualified Person electronically signed the batch release decision. Part of 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualifiedPersonName rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Name' ;
    rdfs:comment 'Full name of the Qualified Person who signed off on the batch release. Required for regulatory audit trail.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Status' ;
    rdfs:comment 'Indicates if the batch is under any regulatory or business hold that prevents distribution. Holds may be imposed by FDA, EPA, internal quality, customer complaint, or recall investigation.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'Primary regulatory market or jurisdiction for which this batch was released. Different markets may have different release requirements and QP sign-off rules. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|CHN|JPN|AUS|BRA|IND — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDecision rdf:type rdf:Property ;
    rdfs:label 'Release Decision' ;
    rdfs:comment 'Final disposition decision for the batch: released for distribution, rejected for destruction, quarantine for further testing, conditional release with restrictions, pending review, or on hold pending investigation. Critical GMP control point.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes and comments from the Qualified Person regarding the release decision. May include justification for conditional release or special handling instructions.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the batch release decision was recorded in the system. Used for audit trail and regulatory compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Quantity of the batch that was approved for release and distribution. May be less than batch size if partial rejection occurred.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this batch release. Links to SAP S/4HANA QM module for detailed inspection results and usage decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityStudyReference rdf:type rdf:Property ;
    rdfs:label 'Stability Study Reference' ;
    rdfs:comment 'Reference number linking to the stability study protocol and results that support the assigned shelf life and expiry date for this batch.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Closed By Employee Id' ;
    rdfs:comment 'Identifier of the employee who formally closed the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Created By Employee Id' ;
    rdfs:comment 'Identifier of the employee who created the CAPA record in the system.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Employee Id' ;
    rdfs:comment 'Identifier of the employee or team member assigned as the primary owner responsible for executing and closing the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Verified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when all CAPA actions were completed and verified, prior to formal closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed description of the nonconformance, audit finding, complaint, or stability failure that triggered the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-facing unique identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external communication and audit trails.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record, tracking progression from initiation through closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments or notes recorded at the time of CAPA closure, summarizing outcomes and lessons learned.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action(s) taken to address the existing nonconformance and eliminate its cause.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost impact of the CAPA issue, including costs of investigation, rework, scrap, recall, or other remediation activities.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'The method or approach used to verify that the corrective and preventive actions were effective in resolving the issue and preventing recurrence (e.g., follow-up audit, process monitoring, trend analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Result' ;
    rdfs:comment 'The outcome of the effectiveness verification, indicating whether the CAPA actions successfully resolved the issue and prevented recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the CAPA record was formally initiated and opened in the quality management system.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive action(s) implemented to prevent recurrence of the issue or occurrence of similar issues.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The specific process, department, or functional area where the issue occurred (e.g., Manufacturing, Packaging, Quality Control, Supply Chain).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The methodology used to identify the root cause of the issue, such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, Pareto Analysis, or Failure Mode and Effects Analysis (FMEA).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the CAPA issue based on impact to product quality, safety, regulatory compliance, or business operations.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the originating event (e.g., nonconformance ID, audit finding ID, complaint ID) that triggered this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The origin or trigger event that initiated the CAPA, such as nonconformance, audit finding, customer complaint, supplier quality issue, stability study failure, or regulatory inspection finding.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or target date by which all CAPA actions should be completed and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the CAPA issue or focus area.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Unique identifier for the certificate of analysis record. Primary key.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateOfAnalysisLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Laboratory Id' ;
    rdfs:comment 'Foreign key linking to quality.laboratory. Business justification: Link certificate_of_analysis to the laboratory that issued it, removing redundant name/code fields.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the quality assurance professional authorized to approve and sign this certificate. Must have appropriate delegation of authority.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized signatory (e.g., QA Manager, Quality Director, Laboratory Supervisor).' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total quantity produced in the manufacturing batch. Used to assess sample representativeness and for statistical quality control.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the certificate based on the material type being certified. Determines applicable test parameters and regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this certificate is intended for external distribution to trade customers or is for internal use only. True if customer-facing.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the digitally signed PDF or scanned image of the certificate stored in Veeva Vault or document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Name' ;
    rdfs:comment 'Full name and location of the manufacturing site. Supports multi-site operations and regulatory site registration requirements.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResultStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Result Status' ;
    rdfs:comment 'Aggregate pass/fail status for all test parameters on this certificate. Determines batch release decision and customer distribution eligibility.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTested rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested' ;
    rdfs:comment 'The quantity of material sampled and tested for this certificate. Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTestedUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested Uom' ;
    rdfs:comment 'Unit of measure for the quantity tested (e.g., kilograms, liters, units). Aligns with material master UOM.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this certificate is required for regulatory submissions or compliance filings with FDA, EPA, or other governing bodies. True if required for submission.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of the product specification or quality standard used for testing. Ensures traceability to the correct specification limits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the analytical test methods used (e.g., USP, ASTM, internal method codes). May be a comma-separated list for multiple methods.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlId rdf:type rdf:Property ;
    rdfs:label 'Change Control Id' ;
    rdfs:comment 'Unique identifier for the change control request record. Primary key for the change control entity.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeId rdf:type rdf:Property ;
    rdfs:label 'Change Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_change. Business justification: Regulatory changes often drive change controls; linking records which change control addresses which regulatory amendment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Change .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key reference to a nonconformance record if this change control request was triggered by a quality deviation or defect.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the change was implemented in production or operations, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedFacilities rdf:type rdf:Property ;
    rdfs:label 'Affected Facilities' ;
    rdfs:comment 'Manufacturing sites, warehouses, or laboratories impacted by the change, identified by facility code or name.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMarkets rdf:type rdf:Property ;
    rdfs:label 'Affected Markets' ;
    rdfs:comment 'Geographic markets or regulatory jurisdictions where the change will be implemented, using ISO 3166-1 alpha-3 country codes or region names.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProducts rdf:type rdf:Property ;
    rdfs:label 'Affected Products' ;
    rdfs:comment 'Comma-separated list or narrative description of product SKUs, GTINs, or product families impacted by the change control request.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current stage in the multi-level approval workflow, indicating which functional area or authority is currently reviewing the change control request.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the proposed change, including rationale, scope, and expected outcomes. Critical for regulatory review and approval workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeJustification rdf:type rdf:Property ;
    rdfs:label 'Change Justification' ;
    rdfs:comment 'Business and technical rationale for the proposed change, including benefits, risk mitigation, or compliance drivers.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changePriority rdf:type rdf:Property ;
    rdfs:label 'Change Priority' ;
    rdfs:comment 'Business priority level assigned to the change control request, influencing review and implementation timelines.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Business identifier for the change control request, typically formatted as CR-NNNNNN. Used for external communication and tracking.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the change control request in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|on_hold|implemented|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the change control request for quick identification and reporting.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change control request by the type of change being proposed: formulation (product recipe), process (manufacturing method), equipment (machinery or tooling), facility (building or infrastructure), specification (quality standards), or quality_system (QMS procedures).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled or actual date for conducting the effectiveness review of the implemented change, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Result of the effectiveness review, indicating whether the change achieved its intended objectives.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a formal effectiveness review is required after a defined period to assess long-term impact of the change.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when final approval was granted, authorizing implementation of the change, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApproverName rdf:type rdf:Property ;
    rdfs:label 'Final Approver Name' ;
    rdfs:comment 'Full name of the senior authority who provided final approval for the change control request, typically a Quality Director or Plant Manager.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Organizational department or functional area of the change control request initiator.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the individual who originated the change control request.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postChangeVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Change Verification Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether post-implementation verification activities are required to confirm the change achieved its intended outcome without adverse effects.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Date' ;
    rdfs:comment 'Date when Quality Assurance approval was granted, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApproverName rdf:type rdf:Property ;
    rdfs:label 'Qa Approver Name' ;
    rdfs:comment 'Full name of the Quality Assurance representative who approved or rejected the change control request.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Assessment' ;
    rdfs:comment 'Detailed evaluation of the potential impact of the change on product quality attributes, safety, efficacy, and GMP compliance. Documents risk analysis and mitigation strategies.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when Regulatory Affairs approval was granted, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApproverName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approver Name' ;
    rdfs:comment 'Full name of the Regulatory Affairs representative who approved or rejected the change control request.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Classification' ;
    rdfs:comment 'Assessment of the regulatory significance of the change. Major changes require regulatory authority notification or approval; minor changes may be managed internally per validated change control procedures.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Impact Assessment' ;
    rdfs:comment 'Evaluation of the change\'s impact on supply chain operations, including material sourcing, production capacity, lead times, and distribution.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Target Implementation Date' ;
    rdfs:comment 'Planned date for implementing the approved change, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Verification Completion Date' ;
    rdfs:comment 'Date when post-change verification activities were completed, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlChartId rdf:type rdf:Property ;
    rdfs:label 'Control Chart Id' ;
    rdfs:comment 'Unique identifier for the Statistical Process Control (SPC) control chart record. Primary key for the control chart entity.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlChartSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Control Chart Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Link control_chart to the specification that defines the monitored characteristic limits.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:baselineSampleCount rdf:type rdf:Property ;
    rdfs:label 'Baseline Sample Count' ;
    rdfs:comment 'The number of samples or subgroups used in the baseline period to calculate initial control limits. Typically requires 20-25 subgroups minimum for reliable limits.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centerLine rdf:type rdf:Property ;
    rdfs:label 'Center Line' ;
    rdfs:comment 'The center line or process mean for the control chart, representing the target or average value of the monitored characteristic under stable process conditions.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Standardized code or identifier for the monitored characteristic, typically aligned with SAP QM inspection characteristic master data or quality specification codes.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartNumber rdf:type rdf:Property ;
    rdfs:label 'Chart Number' ;
    rdfs:comment 'Business identifier for the control chart, used for external reference and reporting. Typically follows plant or quality system numbering conventions.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Chart Review Frequency' ;
    rdfs:comment 'The frequency at which this control chart is formally reviewed by quality management. Examples include daily, weekly, monthly, or quarterly reviews.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartStatus rdf:type rdf:Property ;
    rdfs:label 'Chart Status' ;
    rdfs:comment 'Current lifecycle status of the control chart. Active charts are in use for real-time monitoring, inactive charts are retired, suspended charts are temporarily paused, under review charts are being evaluated for control limit recalculation.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartType rdf:type rdf:Property ;
    rdfs:label 'Chart Type' ;
    rdfs:comment 'Type of Statistical Process Control chart used for monitoring. X-bar/R for variable data with range, X-bar/S for variable data with standard deviation, p-chart for proportion defective, c-chart for count of defects, u-chart for defects per unit, CUSUM for cumulative sum, EWMA for exponentially weighted moving average. [ENUM-REF-CANDIDATE: x_bar_r|x_bar_s|p_chart|c_chart|u_chart|cusum|ewma — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Control Limit Calculation Date' ;
    rdfs:comment 'The date when the current control limits were calculated or last recalculated based on process data.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlLimitCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Control Limit Calculation Method' ;
    rdfs:comment 'The statistical method or formula used to calculate control limits. Examples include 3-sigma method, probability limits, or custom calculation procedures.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRuleSet rdf:type rdf:Property ;
    rdfs:label 'Control Rule Set' ;
    rdfs:comment 'The set of statistical control rules applied to detect out-of-control conditions. Common rule sets include Western Electric rules (1-4), Nelson rules (1-8), or custom rule combinations defined by the quality system.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpValue rdf:type rdf:Property ;
    rdfs:label 'Cp Value' ;
    rdfs:comment 'The process capability index Cp, measuring the potential capability of the process if it were perfectly centered between specification limits. Does not account for process centering.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpkValue rdf:type rdf:Property ;
    rdfs:label 'Cpk Value' ;
    rdfs:comment 'The process capability index Cpk, measuring how well the process fits within specification limits while accounting for process centering. Values above 1.33 typically indicate capable processes in GMP environments.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The lower specification limit defined by product quality specifications or regulatory requirements. Represents the minimum acceptable value for the characteristic.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoredCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Monitored Characteristic' ;
    rdfs:comment 'The Critical Quality Attribute (CQA) or process parameter being monitored by this control chart. Examples include fill weight, pH level, viscosity, tablet hardness, dissolution rate, or any measurable quality attribute.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocapReference rdf:type rdf:Property ;
    rdfs:label 'Ocap Reference' ;
    rdfs:comment 'Reference to the Out-of-Control Action Plan document or procedure that defines the response actions when control chart violations are detected. Links to quality management system procedures.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppkValue rdf:type rdf:Property ;
    rdfs:label 'Ppk Value' ;
    rdfs:comment 'The process performance index Ppk, measuring long-term process performance relative to specification limits. Calculated using overall process variation rather than within-subgroup variation.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Reference' ;
    rdfs:comment 'Reference to specific regulatory requirements or guidance documents that mandate or recommend this control chart. Examples include FDA guidance, ICH guidelines, or pharmacopeial requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'The frequency at which samples are collected for control chart monitoring. Examples include every 15 minutes, hourly, per batch, or per shift.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlanCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Code' ;
    rdfs:comment 'Code or identifier for the sampling plan used to collect data for this control chart. Links to quality management system sampling procedures.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmInspectionCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Characteristic' ;
    rdfs:comment 'SAP QM inspection characteristic code that this control chart monitors. Links to SAP QM master data for inspection planning and results recording.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupSize rdf:type rdf:Property ;
    rdfs:label 'Subgroup Size' ;
    rdfs:comment 'The number of samples or observations collected in each subgroup for control chart analysis. Typical values range from 2 to 10 for variable control charts.' ;
    rdfs:domain ind:ControlChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The upper specification limit defined by product quality specifications or regulatory requirements. Represents the maximum acceptable value for the characteristic.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditChecklistId rdf:type rdf:Property ;
    rdfs:label 'Audit Checklist Id' ;
    rdfs:comment 'Reference to the audit checklist or protocol used during the audit to ensure consistent evaluation criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditChecklist .

ind:auditProgramId rdf:type rdf:Property ;
    rdfs:label 'Audit Program Id' ;
    rdfs:comment 'Reference to the audit program or audit plan under which this audit was conducted (e.g., annual internal audit program, supplier qualification program).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:affectedProcessAreas rdf:type rdf:Property ;
    rdfs:label 'Affected Process Areas' ;
    rdfs:comment 'Comma-separated list of process areas or departments affected by audit findings (e.g., production, quality control, warehouse, documentation, cleaning validation).' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional audit notes, context, or observations not captured in structured fields.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique identifier for the audit event, used for tracking and regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'Date when the final audit report was issued to the facility or organization.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of additional audit team members who participated in the audit.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on the auditing party: internal (self-assessment), regulatory (FDA, EU authority), third-party (certification body), supplier (vendor qualification), or customer (buyer audit).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Status of audit closure: open (findings not yet addressed), pending_response (awaiting facility response), under_review (response being evaluated), closed (all findings resolved), escalated (unresolved findings escalated to management or regulatory authority).' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions (True) or not (False).' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action effectiveness.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpStandardReference rdf:type rdf:Property ;
    rdfs:label 'Gmp Standard Reference' ;
    rdfs:comment 'Reference to the GMP standard or regulation against which the audit was conducted (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ICH Q7).' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Summary rating assigned to the facility based on audit findings: compliant (no significant issues), acceptable (minor issues), needs_improvement (major issues requiring action), non_compliant (critical GMP violations), critical (immediate regulatory risk).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings (observations, deviations, non-conformances) identified during the audit.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Identifier of the quality manager or authorized person who made the final usage decision for this inspection lot.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInspectionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inspection Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who last modified the inspection lot record. Maintains accountability for changes to quality data.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issue Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was formally issued for this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the formal usage decision was made and recorded in the quality management system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time when the usage decision was recorded. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances identified during inspection. Used for quality metrics and trend analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome status of the lot after disposition decision and stock posting. Confirms the actual inventory movement executed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection End Date' ;
    rdfs:comment 'Date when all inspection and testing activities were completed for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location or quality lab where the inspection was performed. May be different from the plant code for centralized testing facilities.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for inspector comments, observations, or special conditions noted during the inspection process.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPriority rdf:type rdf:Property ;
    rdfs:label 'Inspection Priority' ;
    rdfs:comment 'Priority level assigned to the inspection lot. Determines the sequence and urgency of inspection execution in the quality lab.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Date when the physical inspection and testing activities began for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot. Tracks progression from creation through inspection execution to final disposition decision.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection lot based on the triggering event. Determines the inspection plan template and sampling strategy applied.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Number' ;
    rdfs:comment 'Document number of the originating transaction (production order number, purchase order number, delivery number, etc.) that triggered this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginType rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Type' ;
    rdfs:comment 'Source document type that triggered the creation of this inspection lot. Links the quality inspection to the originating business transaction.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material in the inspection lot. Represents the population from which samples are drawn for inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the lot quantity (each, kilogram, liter, meter, etc.). Aligns with material master UOM. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material drawn as a sample for inspection testing. Determined by the inspection plan sampling procedure.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity drawn for testing. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingInstruction rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Instruction' ;
    rdfs:comment 'Instruction for inventory movement based on the usage decision. Determines the target stock type for material posting in warehouse management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Final disposition decision for the inspected lot. Determines whether material can be released for use, must be reworked, or should be rejected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'Standardized code representing the usage decision. Used for automated stock posting and reporting in SAP QM.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleLabId rdf:type rdf:Property ;
    rdfs:label 'Responsible Lab Id' ;
    rdfs:comment 'Reference to the quality control laboratory or testing facility responsible for executing this inspection plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as a percentage. Maximum percent defective that is considered acceptable for the inspection plan. Used in acceptance sampling decisions.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required Flag' ;
    rdfs:comment 'Indicates whether a formal Certificate of Analysis document must be generated upon successful completion of inspections under this plan. Typically required for finished goods and customer-facing materials.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the change control request or document that authorized the creation or last modification of this inspection plan. Required for GMP compliance and audit trail.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicCount rdf:type rdf:Property ;
    rdfs:label 'Characteristic Count' ;
    rdfs:comment 'Number of quality characteristics (test parameters) defined in this inspection plan. Each characteristic has its own specification limits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days required to complete all inspections and testing defined in this plan. Used for production scheduling and inventory planning.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Primary method used to perform the inspection: manual measurement, automated testing, laboratory analysis, visual examination, destructive testing, or non-destructive testing.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSeverity rdf:type rdf:Property ;
    rdfs:label 'Inspection Severity' ;
    rdfs:comment 'Severity level of inspection based on supplier quality history and risk assessment. Tightened inspection applies stricter acceptance criteria.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Production or supply chain stage at which this inspection is triggered. Aligns with GMP critical control points.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material subject to inspection. Determines applicable GMP requirements and inspection rigor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the inspection plan including scope, objectives, and special instructions for quality control personnel.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to the regulatory requirement, standard, or guideline that mandates this inspection (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ISO 22716). Critical for compliance audits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleInspectorRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Inspector Role' ;
    rdfs:comment 'Job role or qualification level required for personnel authorized to perform inspections under this plan (e.g., QC Technician, QC Analyst, QC Manager). Ensures competency requirements are met.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of this inspection plan. Incremented each time the plan is updated. Part of change control and audit trail.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Unit' ;
    rdfs:comment 'Unit of measure for the sample (e.g., pieces, kg, liters, containers). Defines what constitutes one sample unit.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code identifying the sampling procedure to be followed: sample size, sampling frequency, sampling method (random, systematic, stratified). References approved sampling SOP.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether skip-lot inspection (reduced frequency based on consistent quality history) is permitted for this plan. Not allowed for GMP-critical inspections.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Required' ;
    rdfs:comment 'List or description of test equipment, instruments, or laboratory apparatus required to execute this inspection plan. Ensures resource availability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the inspection result record. Primary key for granular QC (Quality Control) measurement and test result records captured at the characteristic level within an inspection lot.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionResultSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Link inspection_result to its governing specification for easy access to spec limits and versioning.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier of the physical sample from which this measurement was taken. Enables traceability back to the specific sample unit within the inspection lot.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Flag indicating whether this result should be included in the Certificate of Analysis (COA) document for the batch. True indicates inclusion; false indicates internal-only result.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Description of the specific SPC control chart rule that was violated (e.g., point beyond control limit, 7 consecutive points above centerline, 2 of 3 points beyond 2-sigma). Populated when control_chart_violation_flag is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Flag indicating whether this measurement violates SPC (Statistical Process Control) control chart rules (e.g., out of control limits, run rules, trend rules). True indicates a violation requiring investigation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code classifying the type of defect or non-conformance observed when result_status is fail. Used for defect trending and root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the severity of the non-conformance. Critical defects pose safety or regulatory risk; major defects affect functionality; minor defects are cosmetic or non-functional.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Code' ;
    rdfs:comment 'Reference to an approved deviation or waiver document that authorizes acceptance of a non-conforming result. Populated when result_status is waived.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditionHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Humidity' ;
    rdfs:comment 'Relative humidity (percentage) at the time of measurement. Critical for tests sensitive to moisture levels.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Temperature' ;
    rdfs:comment 'Ambient temperature (in degrees Celsius) at the time of measurement. Critical for tests sensitive to environmental conditions.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Unique code identifying the specific quality characteristic being measured (e.g., pH level, viscosity, weight, color, microbial count). Corresponds to the master inspection characteristic definition.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the quality characteristic being tested (e.g., Product pH, Net Weight, Microbial Load, Color Consistency).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the standardized test method or procedure used to perform this measurement (e.g., ASTM method, USP method, internal SOP number).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when this specific characteristic measurement was performed. Critical for time-sensitive tests and GMP audit trails.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier of the measurement instrument or equipment used to capture this result (e.g., balance ID, pH meter ID, spectrophotometer ID). Required for GMP (Good Manufacturing Practice) audit trails and instrument calibration traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Identifier of the laboratory or testing facility where this measurement was performed. May be an internal QC lab or an external contract lab.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual quantitative measurement or test result value recorded during inspection. For qualitative characteristics, this may be encoded numerically or stored as a code.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Quantified estimate of the uncertainty or error margin associated with the measured value. Required for ISO 17025 compliance and advanced SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Pass/fail status of this individual characteristic measurement. Pass indicates the measured value is within specification limits; fail indicates non-conformance; conditional indicates acceptance with restrictions; pending indicates awaiting review; waived indicates non-conformance accepted by authorized deviation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestIndicator rdf:type rdf:Property ;
    rdfs:label 'Retest Indicator' ;
    rdfs:comment 'Flag indicating whether this result is a retest of a previously failed or inconclusive measurement. True indicates this is a retest; false indicates initial test.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestReasonCode rdf:type rdf:Property ;
    rdfs:label 'Retest Reason Code' ;
    rdfs:comment 'Code indicating the reason for retesting this characteristic. Applicable only when retest_indicator is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Sequence Number' ;
    rdfs:comment 'Sequential number of this sample within the inspection lot (e.g., 1, 2, 3). Used to track sampling order and support statistical sampling plans.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Test Batch Number' ;
    rdfs:comment 'Batch or run number of the test reagents or consumables used during this measurement. Required for traceability in regulated environments.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labTestRequestId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Request Id' ;
    rdfs:comment 'Unique identifier for the laboratory test request record. Primary key.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Id' ;
    rdfs:comment 'Identifier linking this test request to a formal stability study protocol for shelf-life determination and expiry date validation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityStabilityStudy .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'Employee identifier of the individual who submitted the laboratory test request.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Time Hours' ;
    rdfs:comment 'Measured elapsed time in hours from request submission to result receipt. Used for laboratory performance monitoring and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedLabCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Lab Code' ;
    rdfs:comment 'Code identifying the internal or external laboratory facility assigned to perform the testing.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedLabName rdf:type rdf:Property ;
    rdfs:label 'Assigned Lab Name' ;
    rdfs:comment 'Full name of the laboratory facility assigned to perform the testing (internal QC lab or external contract lab).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAssignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lab Assignment Timestamp' ;
    rdfs:comment 'Date and time when the test request was assigned to a specific laboratory facility and analyst.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labType rdf:type rdf:Property ;
    rdfs:label 'Lab Type' ;
    rdfs:comment 'Classification of the assigned laboratory as internal company facility, external third-party lab, or contract testing organization.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this laboratory test is mandated by regulatory authority (FDA, EPA, EU REACH) for product registration, batch release, or ongoing compliance.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNotes rdf:type rdf:Property ;
    rdfs:label 'Request Notes' ;
    rdfs:comment 'Free-text field for additional context, special instructions, or background information relevant to the laboratory test request.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the laboratory test request, typically formatted as LTR-YYYYNNNN for external reference and tracking.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the laboratory test request in the workflow from submission through completion. [ENUM-REF-CANDIDATE: draft|submitted|assigned|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the laboratory test request was officially submitted to the laboratory for processing. Marks the start of turnaround time measurement.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Category of laboratory testing requested: physical properties, chemical composition, microbiological safety, sensory evaluation, stability study, or regulatory compliance testing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Requested Completion Date' ;
    rdfs:comment 'Target date by which laboratory test results must be received to support business decisions (batch release, regulatory submission, etc.).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name of the business department or functional area that initiated the laboratory test request (e.g., Quality Assurance, Research and Development, Manufacturing, Regulatory Affairs).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the laboratory test request.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Required Turnaround Time Hours' ;
    rdfs:comment 'Maximum number of hours allowed from request submission to result receipt based on business priority and operational requirements.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Receipt Timestamp' ;
    rdfs:comment 'Date and time when laboratory test results were received and recorded in the quality management system. Marks the end of turnaround time measurement.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stabilityTimePoint rdf:type rdf:Property ;
    rdfs:label 'Stability Time Point' ;
    rdfs:comment 'Specific time point in the stability study protocol when this sample was pulled for testing (e.g., T0, 3 months, 6 months, 12 months, 24 months).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPanelCode rdf:type rdf:Property ;
    rdfs:label 'Test Panel Code' ;
    rdfs:comment 'Code identifying the predefined set of analytical tests to be performed (e.g., full release panel, stability panel, microbial panel).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPanelDescription rdf:type rdf:Property ;
    rdfs:label 'Test Panel Description' ;
    rdfs:comment 'Detailed description of the test panel including specific analytical methods and parameters to be measured.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPurpose rdf:type rdf:Property ;
    rdfs:label 'Test Purpose' ;
    rdfs:comment 'Business reason for requesting the laboratory test (e.g., batch release, stability monitoring, complaint investigation, supplier qualification, regulatory submission, method validation).' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Testing Start Timestamp' ;
    rdfs:comment 'Date and time when laboratory analytical work began on the sample.' ;
    rdfs:domain ind:LabTestRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionId rdf:type rdf:Property ;
    rdfs:label 'Action Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_action. Business justification: Nonconformance findings can lead to regulatory enforcement actions; linking supports audit trails.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Action .

ind:nonconformanceClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Closed By User Employee Id' ;
    rdfs:comment 'User identifier of the quality professional who closed the nonconformance record after verification. Links to workforce/employee master data.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:nonconformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Employee Id' ;
    rdfs:comment 'User identifier of the quality professional or team member assigned to investigate and resolve the nonconformance. Links to workforce/employee master data.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was formally closed after verification of corrective actions and effectiveness checks. Null if still open.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment actions taken to prevent further occurrence or distribution of nonconforming product. Describes short-term corrective measures implemented before root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed and verified effective. Critical for regulatory reporting and OTIF compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'Technical classification of the defect type: appearance (cosmetic defect), functionality (performance issue), safety (consumer safety risk), labeling (incorrect or missing label information), packaging (packaging integrity issue), contamination (foreign material or microbial contamination), specification_failure (out-of-specification test result), or process_deviation (manufacturing process non-conformance). [ENUM-REF-CANDIDATE: appearance|functionality|safety|labeling|packaging|contamination|specification_failure|process_deviation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed narrative description of the nonconformance, including observed symptoms, affected characteristics, and initial assessment. Captures the what, where, and when of the quality event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was first detected or observed. Represents the real-world event time of quality issue identification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'User identifier of the quality authority who approved the disposition decision. Links to workforce/employee master data for audit trail and GMP compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved by quality authority. Critical for GMP audit trail and batch release decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nonconformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record: open (newly created), in_investigation (root cause analysis underway), containment_active (immediate containment actions in progress), capa_assigned (corrective and preventive action assigned), closed (resolved and verified), or cancelled (invalidated).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'External business identifier for the quality notification or nonconformance event. Corresponds to SAP QM notification number or Veeva Vault quality event identifier.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePlantCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Plant Code' ;
    rdfs:comment 'Manufacturing plant or facility code where the nonconformance originated or is being managed. Links to distribution_facility for organizational accountability.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed findings from root cause investigation, including methodology used (5-Why, Fishbone, Fault Tree Analysis) and identified root causes. Supports CAPA development.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Complaint Investigation Assignment links each complaint to the responsible investigator employee for tracking and regulatory reporting.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complainantAddress rdf:type rdf:Property ;
    rdfs:label 'Complainant Address' ;
    rdfs:comment 'Mailing address of the complainant for correspondence and product sample return.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantCountryCode rdf:type rdf:Property ;
    rdfs:label 'Complainant Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the complainant location.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantEmail rdf:type rdf:Property ;
    rdfs:label 'Complainant Email' ;
    rdfs:comment 'Email address of the complainant for follow-up communication.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantName rdf:type rdf:Property ;
    rdfs:label 'Complainant Name' ;
    rdfs:comment 'Full name of the individual or organization filing the complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantPhone rdf:type rdf:Property ;
    rdfs:label 'Complainant Phone' ;
    rdfs:comment 'Contact phone number of the complainant.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the quality issue reported.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the complainant, including symptoms, observations, and circumstances.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible unique complaint reference number used for tracking and communication with consumers and regulatory bodies.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Timestamp' ;
    rdfs:comment 'Date and time when the complaint was first received by the organization.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin channel through which the complaint was received.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle state of the complaint investigation and resolution process.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSubcategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Subcategory' ;
    rdfs:comment 'Detailed sub-classification providing additional granularity to the complaint category.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the consumer or customer experienced the quality issue or adverse event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was concluded and findings documented.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of the complaint was initiated.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current state of the internal quality investigation process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAnalysisResult rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Result' ;
    rdfs:comment 'Summary of laboratory test results conducted on the returned product sample.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive actions implemented to prevent recurrence of similar issues.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency to which the complaint was reported (e.g., FDA, EPA, CPSC).' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the quality issue based on investigation findings.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date when the returned product sample was received by the quality assurance team.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleReturnedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Returned Flag' ;
    rdfs:comment 'Indicates whether the complainant returned a physical product sample for laboratory analysis.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Unique identifier for the quality notification record. Primary key.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Closed By User Employee Id' ;
    rdfs:comment 'User identifier of the person who formally closed the quality notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:notificationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Employee Id' ;
    rdfs:comment 'User identifier of the quality engineer or specialist assigned to investigate and resolve this notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedToName rdf:type rdf:Property ;
    rdfs:label 'Assigned To Name' ;
    rdfs:comment 'Full name of the person assigned to handle this quality notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the quality notification was initially created in the system.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectClass rdf:type rdf:Property ;
    rdfs:label 'Defect Class' ;
    rdfs:comment 'Severity classification of the defect based on its impact on product safety, functionality, and regulatory compliance.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDescription rdf:type rdf:Property ;
    rdfs:label 'Notification Description' ;
    rdfs:comment 'Detailed textual description of the quality issue, defect, or improvement opportunity documented in this notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the quality notification indicating its position in the resolution workflow.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classification of the quality notification indicating the nature of the issue: customer complaint, internal defect, improvement request, process deviation, audit finding, or supplier quality issue.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Name of the manufacturing plant or facility associated with the quality notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSkuId rdf:type rdf:Property ;
    rdfs:label 'Material Sku Id' ;
    rdfs:comment 'Reference to the material or product this specification applies to. Links to the master material record in SAP MM.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:specificationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Specification Approved By Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:specificationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Specification Employee Id' ;
    rdfs:comment 'Employee identifier of the person who approved this specification. Links to workforce management system for accountability.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededBySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Id' ;
    rdfs:comment 'Reference to the newer specification that replaces this one when status is superseded. Maintains specification version lineage.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:criticalQualityAttributeFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Quality Attribute Flag' ;
    rdfs:comment 'Indicates whether this characteristic is a Critical Quality Attribute that directly impacts product safety, efficacy, or regulatory compliance. CQAs require enhanced controls and documentation.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Requirement Flag' ;
    rdfs:comment 'Indicates whether this specification is driven by specific customer contractual requirements rather than internal or regulatory standards.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'How often this specification must be reviewed and revalidated, expressed in months. Ensures specifications remain current and appropriate.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'Description of the sampling methodology and sample size requirements for this test (e.g., AQL 2.5, n=10, ANSI/ASQ Z1.4). Ensures statistical validity of test results.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCategory rdf:type rdf:Property ;
    rdfs:label 'Specification Category' ;
    rdfs:comment 'High-level classification of the type of quality attribute being specified. Groups related test characteristics for reporting and analysis.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Business identifier for the quality specification, used for external reference and documentation. Unique across the organization.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification. Only active specifications are used for quality control and Certificate of Analysis (CoA) generation.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the specification based on the material or product stage it applies to. Determines the applicable quality control procedures.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityIndicatingFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Indicating Flag' ;
    rdfs:comment 'Indicates whether this test characteristic is used in stability studies to monitor product degradation over time. Critical for shelf-life determination.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Test Characteristic' ;
    rdfs:comment 'The specific quality attribute or property being measured or tested (e.g., pH, viscosity, color, weight, purity, microbial count). Defines what is being inspected.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'How often this test characteristic must be measured during production or quality control. Drives inspection plan scheduling. [ENUM-REF-CANDIDATE: per_batch|per_lot|hourly|daily|weekly|monthly|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Id' ;
    rdfs:comment 'Unique identifier for the regulatory hold event record. Primary key.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedComplaintProductComplaintId rdf:type rdf:Property ;
    rdfs:label 'Related Complaint Product Complaint Id' ;
    rdfs:comment 'Identifier linking this regulatory hold to a consumer or customer complaint that triggered the investigation.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductComplaint .

ind:relatedRecallProductRecallId rdf:type rdf:Property ;
    rdfs:label 'Related Recall Product Recall Id' ;
    rdfs:comment 'Identifier linking this regulatory hold to a product recall event if the hold escalated to a recall.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductRecall .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The actual date when the regulatory hold was lifted and the affected product, batch, or material was released or dispositioned.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'The precise date and time when the regulatory hold was lifted and the affected product, batch, or material was released or dispositioned.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Affected Material Code' ;
    rdfs:comment 'The raw material or component code placed under regulatory hold. May be null if hold applies to finished goods.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'The anticipated date when the regulatory hold review and assessment is expected to be completed and a release decision made.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdNotes rdf:type rdf:Property ;
    rdfs:label 'Hold Notes' ;
    rdfs:comment 'Additional notes, observations, and context related to the regulatory hold event, investigation, and resolution.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdScope rdf:type rdf:Property ;
    rdfs:label 'Hold Scope' ;
    rdfs:comment 'The level at which the regulatory hold is applied, defining the breadth of affected inventory or operations.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingAuthority rdf:type rdf:Property ;
    rdfs:label 'Initiating Authority' ;
    rdfs:comment 'The organization or entity that initiated or mandated the regulatory hold event. [ENUM-REF-CANDIDATE: FDA|CPSC|EPA|internal_qa|internal_regulatory|supplier|customer|third_party_lab — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Initiating Authority Reference' ;
    rdfs:comment 'External reference number or case identifier provided by the initiating regulatory authority or organization.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure for the affected quantity (EA=Each, CS=Case, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon, MT=Metric Ton). [ENUM-REF-CANDIDATE: EA|CS|KG|LB|L|GAL|MT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether this regulatory hold event requires formal notification to external regulatory authorities.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseAuthorizationName rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Name' ;
    rdfs:comment 'The full name of the authorized individual who approved the release or disposition of the regulatory hold.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorizationTitle rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Title' ;
    rdfs:comment 'The job title or role of the individual who authorized the release or disposition decision.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseJustification rdf:type rdf:Property ;
    rdfs:label 'Release Justification' ;
    rdfs:comment 'Detailed explanation and supporting evidence for the release or disposition decision, including test results and risk assessment findings.' ;
    rdfs:domain ind:RegulatoryHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityResultId rdf:type rdf:Property ;
    rdfs:label 'Stability Result Id' ;
    rdfs:comment 'Unique identifier for the stability test result record. Primary key for the stability result entity.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalResultStabilityResultId rdf:type rdf:Property ;
    rdfs:label 'Original Result Stability Result Id' ;
    rdfs:comment 'Reference to the original stability result record if this is a retest.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityResult .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Name of the laboratory analyst who performed the test.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryLocation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Location' ;
    rdfs:comment 'Physical location or site code of the laboratory where the test was performed.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfSpecificationFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Specification Flag' ;
    rdfs:comment 'Boolean indicator that the result is out of specification and requires investigation per GMP requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the measured value meets the specification limits. Pass indicates conformance, fail indicates non-conformance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pullDate rdf:type rdf:Property ;
    rdfs:label 'Pull Date' ;
    rdfs:comment 'Date when the sample was pulled from stability storage for testing at this time point.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this result is a retest following an initial out-of-specification result or laboratory investigation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the quality professional who reviewed and approved the test result.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Impact Flag' ;
    rdfs:comment 'Indicates whether this result impacts the determination of product shelf life or expiration dating.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for this test characteristic as defined in the product specification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationTarget rdf:type rdf:Property ;
    rdfs:label 'Specification Target' ;
    rdfs:comment 'Target or nominal value for this test characteristic as defined in the product specification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for this test characteristic as defined in the product specification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testIntervalNumber rdf:type rdf:Property ;
    rdfs:label 'Test Interval Number' ;
    rdfs:comment 'Sequential interval number within the stability study protocol (e.g., 0, 1, 3, 6, 9, 12, 18, 24 months).' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of this stability test result.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendFlag rdf:type rdf:Property ;
    rdfs:label 'Trend Flag' ;
    rdfs:comment 'Indicates whether this result shows a statistically significant trend toward specification limits that may predict future failure.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityStabilityStudySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Link quality_stability_study to the specification it validates, eliminating the free-text reference column.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:approvedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Approved Shelf Life Months' ;
    rdfs:comment 'Regulatory-approved or final determined shelf life in months based on stability study results. May differ from proposed shelf life if data does not support full duration.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Due Date' ;
    rdfs:comment 'Regulatory deadline by which stability study results must be submitted to the health authority. Applicable only when stability_commitment_flag is true.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerClosureSystem rdf:type rdf:Property ;
    rdfs:label 'Container Closure System' ;
    rdfs:comment 'Detailed specification of the container and closure materials and design used in the stability study. Critical for assessing barrier properties and product protection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichClimaticZone rdf:type rdf:Property ;
    rdfs:label 'Ich Climatic Zone' ;
    rdfs:comment 'International Council for Harmonisation (ICH) climatic zone classification for the intended market. Zone I (temperate), Zone II (subtropical/Mediterranean), Zone III (hot/dry), Zone IV (hot/humid). Determines required storage conditions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSite rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site' ;
    rdfs:comment 'Identifier or name of the manufacturing facility where the batch being tested was produced. Important for site-specific stability commitments.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfTrendFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Trend Flag' ;
    rdfs:comment 'Indicates whether any test results showed unexpected trends or deviations from expected stability behavior, even if within specification. True if any OOT results occurred.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Description of the primary and secondary packaging used for the stability samples (e.g., HDPE bottle with child-resistant cap, aluminum tube with flip-top cap). Packaging can significantly impact product stability.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Shelf Life Months' ;
    rdfs:comment 'Intended or claimed shelf life in months that this stability study is designed to support. Final shelf life determination is based on study results.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Reference' ;
    rdfs:comment 'Reference identifier for the approved stability study protocol document that defines test methods, sampling schedule, acceptance criteria, and storage conditions. Links to protocol management system or Veeva Vault.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPurpose rdf:type rdf:Property ;
    rdfs:label 'Regulatory Purpose' ;
    rdfs:comment 'Primary regulatory or business purpose for conducting the stability study. Registration studies support new product applications. Post-approval studies fulfill ongoing commitments. Change-control studies assess impact of manufacturing or formulation changes.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Geographic region or regulatory authority for which this stability study is being conducted (e.g., USA, EU, Japan, Global). Different regions may have different storage condition requirements per ICH climatic zones.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Report Approval Date' ;
    rdfs:comment 'Date when the final stability study report was reviewed and approved by quality assurance. Marks formal completion of the study.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document identifier for the final stability study report. Links to document management system or Veeva Vault for full study documentation.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleLaboratory rdf:type rdf:Property ;
    rdfs:label 'Responsible Laboratory' ;
    rdfs:comment 'Name or identifier of the laboratory facility conducting the stability testing. May be internal quality control (QC) lab or external contract testing laboratory.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Commitment Flag' ;
    rdfs:comment 'Indicates whether this study is part of a formal stability commitment made to a regulatory authority. True if this is a committed study that must be completed and reported per regulatory agreement.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Pct' ;
    rdfs:comment 'Target relative humidity percentage for the stability study storage condition.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageInstruction rdf:type rdf:Property ;
    rdfs:label 'Storage Instruction' ;
    rdfs:comment 'Consumer-facing storage instructions that will appear on product labeling, derived from stability study results (e.g., Store at room temperature, Do not freeze, Protect from light).' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Target storage temperature in degrees Celsius for the stability study chamber or condition.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyConclusion rdf:type rdf:Property ;
    rdfs:label 'Study Conclusion' ;
    rdfs:comment 'Summary conclusion of the stability study results, including whether the product met all acceptance criteria throughout the study duration and any recommendations for shelf life or storage conditions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCoordinator rdf:type rdf:Property ;
    rdfs:label 'Study Coordinator' ;
    rdfs:comment 'Name or employee identifier of the person responsible for coordinating and overseeing the stability study execution.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Planned total duration of the stability study in months. Typical durations are 6 months for accelerated studies, 12-36 months for real-time studies, and up to 60 months for long-term studies.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Planned or actual completion date of the stability study. For ongoing studies, represents the projected completion date based on protocol duration.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Business identifier for the stability study, typically assigned by the quality management system or laboratory information management system (LIMS). Used for external reference and regulatory submissions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Date when the stability study was initiated and samples were placed on stability storage. Marks the beginning of the study timeline for time-point calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the stability study protocol. Accelerated studies use elevated temperature/humidity to predict shelf life. Real-time studies use recommended storage conditions. Intermediate studies bridge accelerated and real-time. Stress studies test extreme conditions. Photostability studies assess light exposure impact. In-use studies simulate consumer usage conditions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'List of quality attributes and test methods included in the stability protocol (e.g., appearance, pH, assay, impurities, microbial limits, viscosity). Comma-separated or structured list.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'Schedule of time points at which samples are pulled and tested (e.g., 0, 3, 6, 9, 12, 18, 24, 36 months). Defined in the study protocol and varies by study type.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supplier Assessment Id' ;
    rdfs:comment 'Primary key for supplier_assessment' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAssessmentSupplierAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Previous Assessment Supplier Assessment Id' ;
    rdfs:comment 'Reference to the prior supplier quality assessment record for tracking assessment history and trends.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierAssessment .

ind:approvalValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Approval Valid From Date' ;
    rdfs:comment 'Effective start date of the supplier approval status resulting from this assessment.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalValidToDate rdf:type rdf:Property ;
    rdfs:label 'Approval Valid To Date' ;
    rdfs:comment 'Expiration date of the supplier approval status, after which re-assessment is required.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aslStatus rdf:type rdf:Property ;
    rdfs:label 'Asl Status' ;
    rdfs:comment 'Current status of the supplier on the Approved Supplier List based on this assessment outcome.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentComments rdf:type rdf:Property ;
    rdfs:label 'Assessment Comments' ;
    rdfs:comment 'Additional notes, observations, or context provided by the assessment team regarding the supplier evaluation.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the supplier quality assessment was conducted or completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency Months' ;
    rdfs:comment 'Number of months between required assessments for this supplier based on risk rating and business criticality.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method or approach used to conduct the supplier quality assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the supplier quality assessment, typically generated by the quality management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportReference rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Reference' ;
    rdfs:comment 'Document identifier for the detailed supplier quality assessment report stored in the document management system.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Description of the scope of the assessment including materials, processes, facilities, or systems evaluated.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the supplier quality assessment process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'Comma-separated list of team members who participated in the supplier quality assessment.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Category of supplier quality assessment indicating the trigger or purpose of the evaluation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Deadline by which the supplier must submit their CAPA response to address identified deficiencies.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityLocation rdf:type rdf:Property ;
    rdfs:label 'Facility Location' ;
    rdfs:comment 'Geographic location or address of the supplier facility that was assessed.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Score' ;
    rdfs:comment 'Score evaluating the supplier\'s adherence to Good Manufacturing Practice standards and requirements.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementTrend rdf:type rdf:Property ;
    rdfs:label 'Improvement Trend' ;
    rdfs:comment 'Trend indicator comparing current assessment results to previous evaluations.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAssessorName rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Name' ;
    rdfs:comment 'Full name of the lead quality assessor responsible for conducting the evaluation.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCategoriesAssessed rdf:type rdf:Property ;
    rdfs:label 'Material Categories Assessed' ;
    rdfs:comment 'Comma-separated list of material categories or product types covered in this supplier assessment.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic supplier quality assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualitySystemScore rdf:type rdf:Property ;
    rdfs:label 'Quality System Score' ;
    rdfs:comment 'Score assessing the maturity and effectiveness of the supplier\'s quality management system.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Score' ;
    rdfs:comment 'Score evaluating the supplier\'s compliance with applicable regulatory requirements including FDA, EPA, REACH, and other governing body standards.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreScaleMax rdf:type rdf:Property ;
    rdfs:label 'Score Scale Max' ;
    rdfs:comment 'Maximum possible score on the assessment scale used for this evaluation.' ;
    rdfs:domain ind:SupplierAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Unique identifier for the quality control usage decision record. Primary key.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryUsageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Usage Employee Id' ;
    rdfs:comment 'Reference to the quality control inspector or authorized personnel who made the usage decision. Required for accountability and audit trails.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'The formal quality control usage decision code. A=Accept (Unrestricted Use), R=Reject, Q=Quality Hold, S=Restricted Use (Sample/Scrap), X=Rework Required. Drives downstream inventory disposition.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Full name of the quality control inspector or authorized personnel who made the usage decision. Captured for audit and traceability purposes.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionText rdf:type rdf:Property ;
    rdfs:label 'Decision Text' ;
    rdfs:comment 'Detailed textual description or rationale for the usage decision. Captures the quality assessor\'s reasoning and any special conditions or instructions.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current status of the material disposition action following the usage decision. pending=Decision made but stock not yet moved, completed=Stock posting completed, cancelled=Decision reversed or voided.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material accepted for unrestricted use based on the usage decision. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected and not suitable for use. Measured in the material\'s base unit of measure. May trigger disposal or return to supplier.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRework rdf:type rdf:Property ;
    rdfs:label 'Quantity Rework' ;
    rdfs:comment 'The quantity of material designated for rework or reprocessing to meet quality standards. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'The sampling method or procedure used during the inspection (e.g., random sampling, statistical sampling, 100% inspection). Ensures inspection validity.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Id' ;
    rdfs:comment 'Primary key for compliance_assessment' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryComplianceAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Assessor Employee Id' ;
    rdfs:comment 'Employee identifier for the individual who conducted the compliance assessment.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Employee identifier for the individual who reviewed and approved the compliance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual or team who conducted the compliance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFinding rdf:type rdf:Property ;
    rdfs:label 'Compliance Finding' ;
    rdfs:comment 'Detailed narrative of the compliance assessment finding, including observations, test results, and rationale for the compliance determination.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionOwner rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Owner' ;
    rdfs:comment 'Name of the individual or department responsible for implementing the corrective action.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action implementation (not started, in progress, completed, verified, overdue).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the supporting documentation, test reports, certificates, or dossiers that substantiate the compliance assessment finding.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the regulatory jurisdiction under which the compliance assessment applies (e.g., USA, DEU, GBR, CHN).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed description of the specific regulatory requirement being assessed for compliance.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementReference rdf:type rdf:Property ;
    rdfs:label 'Requirement Reference' ;
    rdfs:comment 'Specific citation or reference to the regulatory requirement being assessed (e.g., 21 CFR 701.3, IFRA Standard 49, REACH Annex XVII Entry 23).' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Unique identifier for the laboratory test report or analytical certificate supporting the compliance assessment, if applicable.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each compliance obligation is owned by a specific employee; linking enables ownership tracking and audit.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Period Days' ;
    rdfs:comment 'The number of days in advance that the business must be notified or begin preparation to meet this compliance obligation.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'The product category or categories to which this compliance obligation applies (e.g., cosmetics, household cleaners, personal care, food contact materials).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The date by which the compliance obligation must be fulfilled to avoid regulatory penalties or non-compliance.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'The estimated financial cost to fulfill this compliance obligation, including registration fees, testing costs, documentation, and labor.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority or governing body that enforces this obligation (e.g., FDA, EPA, CPSC, EU Commission).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulation rdf:type rdf:Property ;
    rdfs:label 'Governing Regulation' ;
    rdfs:comment 'The specific regulation, directive, or legal framework that mandates this obligation (e.g., CFR 21 Part 701, EU Directive 2009/48/EC, REACH Article 33).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Verification Date' ;
    rdfs:comment 'The date when compliance with this obligation was last verified or audited.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The date when the next renewal or re-certification of this obligation is due.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the compliance obligation, used for external reference and reporting.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full descriptive name of the compliance obligation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the compliance obligation by regulatory action required.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of the penalties, fines, or consequences for failing to meet this compliance obligation (e.g., product recall, market withdrawal, monetary fines, legal action).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'The frequency at which this compliance obligation must be renewed or re-certified.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List or description of the documentation required to fulfill this compliance obligation (e.g., Safety Data Sheet (SDS), ingredient declaration, test reports, certificates of analysis).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The method by which compliance documentation or filings must be submitted to the governing body.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'The web address of the electronic portal or system where compliance submissions must be filed, if applicable.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingRequirement rdf:type rdf:Property ;
    rdfs:label 'Testing Requirement' ;
    rdfs:comment 'Description of any laboratory testing or analytical work required to demonstrate compliance (e.g., stability testing, microbial testing, heavy metals analysis, allergen testing).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscFilingId rdf:type rdf:Property ;
    rdfs:label 'Cpsc Filing Id' ;
    rdfs:comment 'Unique identifier for the CPSC filing record. Primary key.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitted By Employee Id' ;
    rdfs:comment 'Employee identifier of the person who submitted the filing. Links to HR system for accountability.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctiveActionType rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Type' ;
    rdfs:comment 'Type of corrective action proposed or implemented to address the product hazard. May include multiple remedies. [ENUM-REF-CANDIDATE: recall|repair|replacement|refund|warning|product_modification|none_proposed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Cpsc Case Number' ;
    rdfs:comment 'Official case number assigned by CPSC upon receipt and acceptance of the filing. Used for all subsequent correspondence and tracking.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscResponseDescription rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Description' ;
    rdfs:comment 'Detailed description of CPSC response, including any requirements, recommendations, or determinations made by the agency.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Received Date' ;
    rdfs:comment 'Date CPSC provided official response to the filing, including acceptance, request for additional information, or determination.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpscResponseType rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Type' ;
    rdfs:comment 'Type of response received from CPSC regarding the filing. Indicates regulatory action required or determination made.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalityCount rdf:type rdf:Property ;
    rdfs:label 'Fatality Count' ;
    rdfs:comment 'Number of deaths associated with the product hazard. Triggers immediate CPSC notification and investigation.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date the filing was officially submitted to CPSC. Must be within 24 hours of knowledge of substantial product hazard per Section 15(b) requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Externally-known unique filing number assigned by CPSC or internally generated for tracking. Format: CPSC-YYYY-NNNNNN.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the CPSC filing. Tracks progression from draft through submission, CPSC review, and final disposition. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|rejected|closed|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Type of CPSC filing. Section 15(b) reports are mandatory substantial product hazard reports; incident reports capture consumer complaints; SaferProducts.gov submissions are public database entries; voluntary corrective actions and recall notifications document remediation efforts.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed narrative description of the product hazard, defect, or safety issue. Explains how the product can cause harm to consumers.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Primary type of hazard posed by the product defect. Categorizes the nature of risk to consumers. [ENUM-REF-CANDIDATE: fire|burn|laceration|choking|chemical_exposure|electrical_shock|fall|entrapment|suffocation|poisoning|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Total number of reported incidents involving the product hazard, including those without injury.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Number of reported injuries associated with the product hazard. Includes both confirmed and alleged injuries.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Narrative description of injuries sustained by consumers, including medical treatment required. May include multiple incident summaries.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Highest severity level of injuries reported. Used to assess risk level and prioritize regulatory response.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeDate rdf:type rdf:Property ;
    rdfs:label 'Knowledge Date' ;
    rdfs:comment 'Date the company first obtained information reasonably supporting the conclusion that a product contains a defect which could create a substantial product hazard. Triggers 24-hour reporting obligation under Section 15(b).' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether legal counsel has reviewed and approved the filing before submission. Required for Section 15(b) reports.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name of the legal counsel who reviewed the filing.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the affected product units. Essential for determining scope of hazard and recall.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationAtRisk rdf:type rdf:Property ;
    rdfs:label 'Population At Risk' ;
    rdfs:comment 'Description of consumer population particularly vulnerable to the hazard (e.g., children under 3, elderly, pregnant women). Used for targeted warnings and recalls.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productModelNumber rdf:type rdf:Property ;
    rdfs:label 'Product Model Number' ;
    rdfs:comment 'Specific model or SKU number of the product involved in the incident. Critical for identifying affected units.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallAnnouncedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Announced Flag' ;
    rdfs:comment 'Indicates whether a public recall has been announced in conjunction with this filing. True if recall press release issued.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Recall Announcement Date' ;
    rdfs:comment 'Date the product recall was publicly announced via CPSC press release and website posting.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the regulatory contact for official CPSC correspondence.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Name of the primary regulatory affairs contact responsible for managing this filing and CPSC communications.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saferproductsReportNumber rdf:type rdf:Property ;
    rdfs:label 'Saferproducts Report Number' ;
    rdfs:comment 'Unique identifier assigned to the report in the SaferProducts.gov public database if the filing resulted in a public posting.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByEmail rdf:type rdf:Property ;
    rdfs:label 'Submitted By Email' ;
    rdfs:comment 'Email address of the submitter for CPSC correspondence and follow-up communications.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByName rdf:type rdf:Property ;
    rdfs:label 'Submitted By Name' ;
    rdfs:comment 'Name of the individual who submitted the filing to CPSC on behalf of the company.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'Number of supporting documents attached to the filing (test reports, photos, consumer complaints, medical records, etc.).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsAffected rdf:type rdf:Property ;
    rdfs:label 'Units Affected' ;
    rdfs:comment 'Estimated number of product units in commerce that are subject to the reported hazard. Used to assess population at risk.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of units of the affected product sold to consumers. Helps determine recall scope and consumer notification requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Vault Reference Code' ;
    rdfs:comment 'Reference identifier to the document management system (Veeva Vault) where all filing documentation is stored.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Dossier primary contact is an employee responsible for dossier management; needed for responsibility reporting.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Reference to the regulatory submission that this dossier supports. One dossier may support multiple submissions across jurisdictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:cfrReference rdf:type rdf:Property ;
    rdfs:label 'Cfr Reference' ;
    rdfs:comment 'Specific CFR title and part number(s) that govern the regulatory requirements addressed by this dossier, applicable for U.S. FDA and EPA submissions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compilationDate rdf:type rdf:Property ;
    rdfs:label 'Compilation Date' ;
    rdfs:comment 'Date when the dossier compilation was completed and finalized for submission or review.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'Numeric representation of dossier completeness, calculated as the percentage of required sections and documents that have been compiled and approved.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completenessStatus rdf:type rdf:Property ;
    rdfs:label 'Completeness Status' ;
    rdfs:comment 'Assessment of whether all required documentation sections and supporting materials have been compiled and verified for regulatory submission readiness.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions for the dossier content.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents included in this regulatory dossier package.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dossierNumber rdf:type rdf:Property ;
    rdfs:label 'Dossier Number' ;
    rdfs:comment 'Business identifier for the regulatory dossier, used for external reference and tracking across regulatory affairs teams and submissions.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory dossier indicating its stage in the compilation and submission process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierType rdf:type rdf:Property ;
    rdfs:label 'Dossier Type' ;
    rdfs:comment 'Classification of the regulatory dossier format and submission standard. CTD (Common Technical Document), eCTD (Electronic Common Technical Document), IECIC (International Cooperation on Cosmetics Regulation), CPNP (Cosmetic Products Notification Portal), FDA 510K (Medical Device Premarket Notification), EPA FIFRA (Federal Insecticide Fungicide and Rodenticide Act).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Flag' ;
    rdfs:comment 'Indicator of whether the dossier includes documentation demonstrating compliance with IFRA standards for fragrance ingredients.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientDeclarationIncluded rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration Included' ;
    rdfs:comment 'Indicator of whether a complete ingredient declaration (INCI list or equivalent) is included in the dossier.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country or region code representing the regulatory jurisdiction for which this dossier applies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Included' ;
    rdfs:comment 'Indicator of whether post-market surveillance data, adverse event reports, or vigilance documentation is included in the dossier.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyAssessmentIncluded rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Included' ;
    rdfs:comment 'Indicator of whether a formal safety assessment report is included in the dossier, as required for cosmetic and personal care product registrations.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsIncluded rdf:type rdf:Property ;
    rdfs:label 'Sds Included' ;
    rdfs:comment 'Indicator of whether Safety Data Sheets (SDS) or Material Safety Data Sheets (MSDS) are included in the dossier for hazardous substances or mixtures.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vaultFolderPath rdf:type rdf:Property ;
    rdfs:label 'Vault Folder Path' ;
    rdfs:comment 'Hierarchical folder path within Veeva Vault where the dossier documents are stored, enabling navigation and retrieval.' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Id' ;
    rdfs:comment 'Unique identifier for the EPA registration record. Primary key for this product.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeIngredientList rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient List' ;
    rdfs:comment 'Comma-separated list of active ingredient(s) in the registered product. Each active ingredient is the chemical substance responsible for the pesticidal or antimicrobial effect. Format: Chemical Name (CAS Number); Chemical Name (CAS Number).' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredientPercentage rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Percentage' ;
    rdfs:comment 'Percentage concentration of each active ingredient in the formulation. Corresponds to the active_ingredient_list. Format: percentage values separated by semicolons matching the ingredient list order.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyNumber rdf:type rdf:Property ;
    rdfs:label 'Company Number' ;
    rdfs:comment 'Five-digit EPA company number assigned to the registrant. This is the first component of the EPA registration number and identifies the company holding the registration.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCallInDueDate rdf:type rdf:Property ;
    rdfs:label 'Data Call In Due Date' ;
    rdfs:comment 'Date by which the registrant must submit data or studies in response to an EPA data call-in. Failure to meet this deadline may result in registration cancellation.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCallInRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Call In Requirement' ;
    rdfs:comment 'Description of any outstanding data call-in requirements issued by EPA. Data call-ins require registrants to submit additional studies or data to support continued registration. Includes requirement reference number and due date.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Establishment Number' ;
    rdfs:comment 'EPA establishment number identifying the facility where the product is manufactured. Format: Company Number-State Code-Facility Number (e.g., 12345-CA-001). Required on product labels.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Number' ;
    rdfs:comment 'Official EPA registration number assigned under FIFRA. Format: Company Number-Product Number-Supplemental Number (e.g., 12345-67 or 12345-67-890). This is the externally-known unique identifier for the registered pesticide or antimicrobial product.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Label Approval Status' ;
    rdfs:comment 'Current status of the EPA-approved product label. The label must be approved before the product can be marketed. Approved = label accepted by EPA, Pending Review = submitted awaiting EPA review, Conditionally Approved = approved with minor changes required, Rejected = label not acceptable, Revision Required = EPA requested changes.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the next renewal application must be submitted to EPA to maintain continuous registration status. Critical for compliance planning.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productBrandName rdf:type rdf:Property ;
    rdfs:label 'Product Brand Name' ;
    rdfs:comment 'Commercial brand name under which the product is marketed to consumers. May differ from the registered product name.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantName rdf:type rdf:Property ;
    rdfs:label 'Registrant Name' ;
    rdfs:comment 'Legal name of the company or entity holding the EPA registration. This is the party legally responsible for the registered product.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the EPA registration was officially granted or approved by the Environmental Protection Agency. This is the principal business event timestamp for this registration record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationReviewCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Review Case Number' ;
    rdfs:comment 'EPA case number for the periodic registration review process. EPA reviews all pesticide registrations on a 15-year cycle to ensure they continue to meet safety standards.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationReviewDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Registration Review Decision Date' ;
    rdfs:comment 'Date when EPA issued the most recent registration review decision for this product. Used to track compliance with periodic review requirements.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Type of EPA registration action. New = initial registration, Amendment = modification to existing registration, Renewal = periodic renewal, Reregistration = compliance with updated data requirements, Cancellation = voluntary or involuntary termination, Conditional = approved pending additional data, Emergency Exemption = Section 18 emergency use. [ENUM-REF-CANDIDATE: new|amendment|renewal|reregistration|cancellation|conditional|emergency_exemption — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reregistrationEligibilityDecision rdf:type rdf:Property ;
    rdfs:label 'Reregistration Eligibility Decision' ;
    rdfs:comment 'EPA determination of whether the product is eligible for reregistration under updated safety and environmental standards. Eligible = meets current standards, Ineligible = does not meet standards and requires reformulation or cancellation, Pending = under EPA review, Not Applicable = not subject to reregistration.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalWord rdf:type rdf:Property ;
    rdfs:label 'Signal Word' ;
    rdfs:comment 'Required signal word on the product label indicating relative acute toxicity. Danger = highest toxicity (Category I), Warning = moderate toxicity (Category II), Caution = lower toxicity (Category III), None = minimal toxicity (Category IV).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPestList rdf:type rdf:Property ;
    rdfs:label 'Target Pest List' ;
    rdfs:comment 'List of target pests, pathogens, or organisms that the product is registered to control (e.g., bacteria, viruses, mold, ants, cockroaches). Defines the approved efficacy claims.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useClassification rdf:type rdf:Property ;
    rdfs:label 'Use Classification' ;
    rdfs:comment 'EPA classification determining who may purchase and apply the product. General Use = available to general public, Restricted Use = requires certified applicator due to potential hazards to environment or applicator.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useSiteDescription rdf:type rdf:Property ;
    rdfs:label 'Use Site Description' ;
    rdfs:comment 'Description of approved use sites and application locations for the registered product (e.g., household surfaces, food contact surfaces, hospitals, schools, outdoor residential). Defines where the product may legally be applied.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'Reference identifier to the EPA registration documents stored in the regulatory document vault system (e.g., Veeva Vault). Links to approved labels, safety data sheets, and registration correspondence.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the IFRA compliance record. Primary key for tracking fragrance ingredient compliance assessments against IFRA standards.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Employee identifier of the assessor who performed the IFRA compliance evaluation. Links to HR system for audit trail.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFormulatedUsageLevel rdf:type rdf:Property ;
    rdfs:label 'Actual Formulated Usage Level' ;
    rdfs:comment 'Actual concentration of the fragrance ingredient in the finished product formulation. Expressed in the same unit as maximum_permitted_usage_level. Used to determine compliance status.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclarationRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Required' ;
    rdfs:comment 'Indicates whether the fragrance ingredient is a recognized allergen requiring declaration on product labeling per EU Cosmetics Regulation or other jurisdictional requirements.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Allergen Threshold Exceeded' ;
    rdfs:comment 'Indicates whether the fragrance ingredient concentration exceeds the allergen labeling threshold (0.001% for leave-on, 0.01% for rinse-off products per EU regulation).' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Due Date' ;
    rdfs:comment 'Date by which the next IFRA compliance reassessment is required. Triggered by IFRA standard updates or product reformulation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionJustification rdf:type rdf:Property ;
    rdfs:label 'Exemption Justification' ;
    rdfs:comment 'Detailed justification text if an exemption or deviation from IFRA standard is claimed. Must include scientific rationale and risk assessment summary.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationVersion rdf:type rdf:Property ;
    rdfs:label 'Formulation Version' ;
    rdfs:comment 'Version identifier of the product formulation for which this IFRA compliance assessment applies. Links to PLM system for formulation change tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceIngredientName rdf:type rdf:Property ;
    rdfs:label 'Fragrance Ingredient Name' ;
    rdfs:comment 'Name of the specific fragrance ingredient being assessed for IFRA compliance. May be a chemical name, INCI name, or proprietary fragrance component identifier.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Ifra Certificate Number' ;
    rdfs:comment 'Certificate number issued by fragrance supplier confirming IFRA compliance of the fragrance compound. Required for audit and regulatory submissions.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraProductCategory rdf:type rdf:Property ;
    rdfs:label 'Ifra Product Category' ;
    rdfs:comment 'IFRA product category classification determining usage restrictions. Categories range from 1 (toys) to 12 (air fresheners), with subcategories for leave-on vs rinse-off products. Each category has specific maximum permitted usage levels. [ENUM-REF-CANDIDATE: Category 1|Category 2|Category 3|Category 4|Category 5A|Category 5B|Category 5C|Category 5D|Category 6|Category 7A|Category 7B|Category 8|Category 9|Category 10A|Category 10B|Category 11A|Category 11B|Category 12 — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Ifra Standard Version' ;
    rdfs:comment 'Version of the IFRA standard applied for this compliance assessment (e.g., 49th Amendment, 50th Amendment). IFRA publishes amendments periodically with updated usage restrictions.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPermittedUsageLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Usage Level' ;
    rdfs:comment 'Maximum permitted concentration of the fragrance ingredient as defined by IFRA standard for the specified product category. Expressed as percentage (e.g., 0.5 = 0.5%). Null if no restriction applies.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level product type classification determining IFRA category assignment and usage restrictions. Leave-on products have stricter limits than rinse-off products.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qraReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Qra Reference Number' ;
    rdfs:comment 'Reference number to the Quantitative Risk Assessment document supporting the safety substantiation of this fragrance ingredient usage. Required for regulatory defense.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Type of IFRA restriction applied to the ingredient. Prohibited means banned entirely; specification means allowed with purity/quality requirements; restricted means usage level limits apply.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Reference number to the detailed risk assessment document or safety dossier supporting this IFRA compliance determination. Links to document management system.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Safety Margin Percentage' ;
    rdfs:comment 'Calculated safety margin between actual usage level and maximum permitted level, expressed as percentage. Positive values indicate compliance buffer; negative values indicate non-compliance.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageLevelUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Level Unit' ;
    rdfs:comment 'Unit of measure for usage levels. Typically percentage (%) for most fragrance ingredients, or ppm/mg/kg for trace components.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientListId rdf:type rdf:Property ;
    rdfs:label 'Ingredient List Id' ;
    rdfs:comment 'Primary key for ingredient_list' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Classification of the allergen type if allergen_flag is true. Used for consumer safety labeling and regulatory compliance.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commonName rdf:type rdf:Property ;
    rdfs:label 'Common Name' ;
    rdfs:comment 'Common or trade name of the ingredient used for internal reference and non-regulated communications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Max Percent' ;
    rdfs:comment 'Maximum concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for regulatory submissions and formulation specifications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationMinPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Min Percent' ;
    rdfs:comment 'Minimum concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for regulatory submissions and formulation specifications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationTypicalPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Typical Percent' ;
    rdfs:comment 'Typical or target concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for quality control and manufacturing guidance.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationNameOverride rdf:type rdf:Property ;
    rdfs:label 'Declaration Name Override' ;
    rdfs:comment 'Alternative name to be used on the product label if different from INCI name, as permitted by jurisdiction-specific regulations (e.g., trade name, common name).' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Declaration Required Flag' ;
    rdfs:comment 'Indicates whether this ingredient must be declared on the product label per regulatory requirements. Some processing aids or trace contaminants may be exempt.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:einecsNumber rdf:type rdf:Property ;
    rdfs:label 'Einecs Number' ;
    rdfs:comment 'EINECS (European Inventory of Existing Commercial Chemical Substances) number for substances marketed in the EU before September 1981. Required for EU REACH compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Ifra Amendment Number' ;
    rdfs:comment 'IFRA (International Fragrance Association) amendment number that governs the use restrictions for this ingredient if IFRA restricted.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Restricted Flag' ;
    rdfs:comment 'Indicates whether this ingredient is subject to IFRA (International Fragrance Association) restrictions or standards for use in fragrance compounds.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientSequence rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence' ;
    rdfs:comment 'Order in which this ingredient appears on the product label declaration. Typically sorted by descending concentration per regulatory requirements (FDA 21 CFR, EU Cosmetics Regulation).' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nanomaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Nanomaterial Flag' ;
    rdfs:comment 'Indicates whether the ingredient is in nanomaterial form, requiring special labeling per EU Cosmetics Regulation (nano) designation.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naturalOriginFlag rdf:type rdf:Property ;
    rdfs:label 'Natural Origin Flag' ;
    rdfs:comment 'Indicates whether the ingredient is derived from natural sources (plant, mineral, animal) as opposed to synthetic or petrochemical sources. Used for natural product claims and marketing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether the ingredient is certified organic by a recognized certification body (e.g., USDA Organic, COSMOS, ECOCERT). Used for organic product claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palmOilDerivativeFlag rdf:type rdf:Property ;
    rdfs:label 'Palm Oil Derivative Flag' ;
    rdfs:comment 'Indicates whether the ingredient is derived from palm oil. Used for sustainable sourcing tracking and RSPO (Roundtable on Sustainable Palm Oil) compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Flag' ;
    rdfs:comment 'Indicates whether this ingredient is subject to regulatory restrictions, concentration limits, or prohibited use conditions in certain jurisdictions.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Restriction Jurisdiction' ;
    rdfs:comment 'Comma-separated list of jurisdictions or regulatory bodies where restrictions apply (e.g., EU, USA, CAN, JPN). Used for multi-jurisdictional compliance management.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of this record in the source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veganFlag rdf:type rdf:Property ;
    rdfs:label 'Vegan Flag' ;
    rdfs:comment 'Indicates whether the ingredient is free from animal-derived substances and suitable for vegan product claims.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Foreign key reference to a parent jurisdiction if this jurisdiction is a sub-jurisdiction (e.g., a state within a country, or a country within a regional bloc). Null for top-level jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:animalTestingBanFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Testing Ban Flag' ;
    rdfs:comment 'Indicates whether the jurisdiction prohibits the sale of products tested on animals (True) or allows it (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Required Flag' ;
    rdfs:comment 'Indicates whether Good Manufacturing Practice (GMP) certification or compliance is mandatory for products sold in this jurisdiction (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifraComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Required Flag' ;
    rdfs:comment 'Indicates whether compliance with IFRA standards for fragrance ingredients is required (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientDeclarationFormat rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration Format' ;
    rdfs:comment 'The required format for ingredient listing on labels: INCI (International Nomenclature of Cosmetic Ingredients), CAS (Chemical Abstracts Service number), common name, or proprietary (brand-specific naming).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full official name of the regulatory jurisdiction (e.g., United States Food and Drug Administration, European Union REACH).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current lifecycle status of the jurisdiction record: active (in use), inactive (no longer applicable), pending (awaiting activation), superseded (replaced by newer version).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Classification of the jurisdiction scope: national (country-level), regional (multi-country bloc), supranational (international treaty), state/provincial (sub-national), or municipal (city-level).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingLanguagePrimary rdf:type rdf:Property ;
    rdfs:label 'Labeling Language Primary' ;
    rdfs:comment 'ISO 639 two- or three-letter code for the primary language required on product labels in this jurisdiction (e.g., en, fr, de, zh).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingLanguageSecondary rdf:type rdf:Property ;
    rdfs:label 'Labeling Language Secondary' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for additional languages required or recommended on labels (e.g., fr,nl for Belgium).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketEntryRequirementType rdf:type rdf:Property ;
    rdfs:label 'Market Entry Requirement Type' ;
    rdfs:comment 'The type of regulatory requirement for market entry: notification (simple filing), registration (formal registration), pre-market approval (full dossier review before sale), post-market surveillance (monitoring after launch), or voluntary (no mandatory requirement).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether a formal notification to the regulatory authority is required before product launch (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postMarketSurveillanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Required Flag' ;
    rdfs:comment 'Indicates whether ongoing post-market surveillance (adverse event reporting, product monitoring) is mandatory (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preMarketApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Market Approval Required Flag' ;
    rdfs:comment 'Indicates whether pre-market approval (full dossier review and authorization before sale) is required (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productInformationFileRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Product Information File Required Flag' ;
    rdfs:comment 'Indicates whether a Product Information File (PIF) or dossier must be maintained and made available to authorities (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Required Flag' ;
    rdfs:comment 'Indicates whether REACH registration for chemical substances is required for this jurisdiction (True) or not (False). Primarily applicable to EU and EEA jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePersonRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Required Flag' ;
    rdfs:comment 'Indicates whether a designated Responsible Person (RP) within the jurisdiction is required for regulatory compliance (True) or not (False). Common in EU jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Label approvals are signed off by a regulatory employee; FK records who approved each label version.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousVersionLabelVersionId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Label Version Id' ;
    rdfs:comment 'Reference to the immediately preceding label version that this version supersedes, enabling version lineage tracking.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:allergenDeclarations rdf:type rdf:Property ;
    rdfs:label 'Allergen Declarations' ;
    rdfs:comment 'Allergen declarations required on the label (e.g., \'Contains: milk, soy, tree nuts\'). Applicable for food and cosmetic products.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the regulatory approval expires and the label version can no longer be used, if applicable.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Official reference or registration number assigned by the regulatory authority for this label approval.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name of the regulatory body or authority that approved this label version (e.g., FDA, EPA, EU Commission, Health Canada).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkChecksum rdf:type rdf:Property ;
    rdfs:label 'Artwork Checksum' ;
    rdfs:comment 'SHA-256 checksum hash of the artwork file to ensure file integrity and detect unauthorized modifications.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkFileName rdf:type rdf:Property ;
    rdfs:label 'Artwork File Name' ;
    rdfs:comment 'File name of the approved label artwork file (e.g., PDF, AI, or other format) stored in the document management system.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeValue rdf:type rdf:Property ;
    rdfs:label 'Barcode Value' ;
    rdfs:comment 'The encoded value of the barcode printed on this label version (e.g., UPC number, GTIN, serialized data).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason for creating this new label version (e.g., \'Regulatory requirement change\', \'Ingredient reformulation\', \'Packaging redesign\', \'Correction of error\').' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactInformation rdf:type rdf:Property ;
    rdfs:label 'Contact Information' ;
    rdfs:comment 'Consumer contact information displayed on the label (phone number, website, email) for inquiries and customer service.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDateFormat rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Format' ;
    rdfs:comment 'Format specification for how the expiry or best-before date will be printed on the label (e.g., \'MM/YYYY\', \'DD-MMM-YYYY\', \'EXP: YYYY-MM-DD\').' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientList rdf:type rdf:Property ;
    rdfs:label 'Ingredient List' ;
    rdfs:comment 'Full ingredient list as declared on the label in descending order of predominance, following regulatory naming conventions (INCI for cosmetics, common names for food).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active label version for the SKU in the specified market. True if current, False if historical.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelClaims rdf:type rdf:Property ;
    rdfs:label 'Label Claims' ;
    rdfs:comment 'Marketing claims and statements appearing on the label (e.g., \'organic\', \'hypoallergenic\', \'dermatologist tested\', \'cruelty-free\'). Pipe-separated list if multiple.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Content Quantity' ;
    rdfs:comment 'Numeric value of the net content quantity declared on the label.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContentUnit rdf:type rdf:Property ;
    rdfs:label 'Net Content Unit' ;
    rdfs:comment 'Unit of measure for the net content quantity (e.g., ml, g, oz, fl_oz, count). [ENUM-REF-CANDIDATE: ml|l|g|kg|oz|lb|fl_oz|gal|count|each — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productNameOnLabel rdf:type rdf:Property ;
    rdfs:label 'Product Name On Label' ;
    rdfs:comment 'The exact product name as it appears on the label artwork, which may differ from internal product names due to marketing or regulatory requirements.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingSymbols rdf:type rdf:Property ;
    rdfs:label 'Recycling Symbols' ;
    rdfs:comment 'Recycling symbols and sustainability marks displayed on the label (e.g., \'Recyclable\', \'FSC Certified\', \'Green Dot\', resin identification codes).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Code' ;
    rdfs:comment 'Reference identifier to the label artwork document stored in Veeva Vault regulatory document management system.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Recall coordination is managed by a specific employee; FK supports recall project management.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedChannels rdf:type rdf:Property ;
    rdfs:label 'Affected Channels' ;
    rdfs:comment 'Comma-separated list of distribution channels impacted by recall (e.g., Retail, E-commerce, Wholesale, DSD, DTC). Defines which go-to-market channels received affected product.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCountries rdf:type rdf:Property ;
    rdfs:label 'Affected Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where recalled products were distributed (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLotBatchNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Batch Numbers' ;
    rdfs:comment 'Comma-separated list of manufacturing lot or batch numbers included in the recall. Enables traceability to specific production runs.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductionDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Production Date Range End' ;
    rdfs:comment 'End date of the production date range for affected products. Used when recall spans multiple production dates.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProductionDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Affected Production Date Range Start' ;
    rdfs:comment 'Start date of the production date range for affected products. Used when recall spans multiple production dates.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedStatesProvinces rdf:type rdf:Property ;
    rdfs:label 'Affected States Provinces' ;
    rdfs:comment 'Comma-separated list of state or province codes where recalled products were distributed within countries. Used for regional recalls.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Date' ;
    rdfs:comment 'Date when the company notified the relevant regulatory authority of the recall. FDA requires notification within 24 hours of recall initiation.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerHotlineNumber rdf:type rdf:Property ;
    rdfs:label 'Consumer Hotline Number' ;
    rdfs:comment 'Toll-free or dedicated phone number for consumers to call with questions about the recall or to request remedies.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerRemedyInstructions rdf:type rdf:Property ;
    rdfs:label 'Consumer Remedy Instructions' ;
    rdfs:comment 'Detailed instructions for consumers on how to return, dispose of, or obtain remedy for recalled products. Includes contact information and process steps.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerRemedyType rdf:type rdf:Property ;
    rdfs:label 'Consumer Remedy Type' ;
    rdfs:comment 'Type of corrective action or compensation offered to consumers who purchased recalled products. Defines how consumers are made whole.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference to the Corrective and Preventive Action (CAPA) plan implemented to prevent recurrence of the issue that caused the recall.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date when the recall effectiveness check was conducted to verify that all consignees were notified and appropriate action taken. FDA requires effectiveness checks at specified intervals.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Result of the recall effectiveness check. Effective: recall objectives met. Partially Effective: some objectives met. Ineffective: recall objectives not met. Pending: check in progress.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial cost of the recall including product value, logistics, disposal, consumer remedies, and administrative costs. Reported in company reporting currency.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressReleaseReference rdf:type rdf:Property ;
    rdfs:label 'Press Release Reference' ;
    rdfs:comment 'Reference number, URL, or document identifier for the official press release or public announcement of the recall.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Public Notification Date' ;
    rdfs:comment 'Date when the recall was publicly announced through press release, media, or regulatory agency posting.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityRecalledUnits rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled Units' ;
    rdfs:comment 'Total number of product units subject to recall. Represents the volume of affected inventory across all distribution levels.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecoveredUnits rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered Units' ;
    rdfs:comment 'Number of recalled product units successfully recovered and removed from distribution. Used to calculate recall effectiveness.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Recall Completion Date' ;
    rdfs:comment 'Date when the recall was officially closed after all corrective actions were completed and effectiveness verified. Nullable for ongoing recalls.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Email' ;
    rdfs:comment 'Email address of the recall coordinator for internal and external communications regarding the recall event.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Phone' ;
    rdfs:comment 'Phone number of the recall coordinator for urgent communications regarding the recall event.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiation Date' ;
    rdfs:comment 'Date when the company officially initiated the recall action. Marks the beginning of the recall event lifecycle.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause of the recall (e.g., contamination, mislabeling, undeclared allergen, packaging defect, microbial contamination, foreign material).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the defect, hazard, or violation that triggered the recall. Includes specific product issue, potential health risk, and circumstances of discovery.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic scope of the recall action. Defines the market territories affected by the recall.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Recall Website Url' ;
    rdfs:comment 'URL of the dedicated webpage providing detailed recall information, consumer instructions, and remedy request forms.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether the recall was mandated by a regulatory authority (True) or initiated voluntarily by the company (False).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Reference' ;
    rdfs:comment 'Reference to the formal root cause analysis document or investigation report that identified the underlying cause of the product defect or contamination.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Reach Substance Id' ;
    rdfs:comment 'Unique identifier for the REACH substance record. Primary key.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the granted authorization expires and the substance can no longer be used unless renewed.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique authorization number granted by the European Commission for use of an Annex XIV substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Authorization Required Flag' ;
    rdfs:comment 'Indicates whether the substance is subject to authorization requirements under REACH Annex XIV before it can be placed on the market or used.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmrClassification rdf:type rdf:Property ;
    rdfs:label 'Cmr Classification' ;
    rdfs:comment 'Classification indicating whether the substance is carcinogenic, mutagenic, or toxic for reproduction, and its category level. [ENUM-REF-CANDIDATE: carcinogenic|mutagenic|reprotoxic|cmr_category_1a|cmr_category_1b|cmr_category_2|not_cmr — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelUnit rdf:type rdf:Property ;
    rdfs:label 'Dnel Unit' ;
    rdfs:comment 'Unit of measure for the DNEL value.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelValue rdf:type rdf:Property ;
    rdfs:label 'Dnel Value' ;
    rdfs:comment 'The level of exposure to the substance above which humans should not be exposed, expressed in mg/kg body weight/day or mg/m³.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downstreamUserNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downstream User Notification Required Flag' ;
    rdfs:comment 'Indicates whether downstream users must be notified of specific obligations or restrictions related to this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endocrineDisruptorFlag rdf:type rdf:Property ;
    rdfs:label 'Endocrine Disruptor Flag' ;
    rdfs:comment 'Indicates whether the substance is identified as an endocrine disruptor under EU criteria.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exposureScenarioRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Exposure Scenario Required Flag' ;
    rdfs:comment 'Indicates whether exposure scenarios must be developed and communicated in the extended Safety Data Sheet for this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsPictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictogram Codes' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes required on labels (e.g., GHS02, GHS05, GHS07, GHS09).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hStatements rdf:type rdf:Property ;
    rdfs:label 'H Statements' ;
    rdfs:comment 'Comma-separated list of standardized hazard statement codes describing the nature of hazards (e.g., H302, H315, H400).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Classification and Labelling (CLP) hazard class and category codes assigned to the substance (e.g., Acute Tox. 3, Skin Corr. 1B, Aquatic Chronic 2).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Date' ;
    rdfs:comment 'Date when the substance was last evaluated by ECHA or competent authorities for compliance or risk assessment purposes.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketAccessStatusEu rdf:type rdf:Property ;
    rdfs:label 'Market Access Status Eu' ;
    rdfs:comment 'Current market access status for placing the substance on the EU market.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pStatements rdf:type rdf:Property ;
    rdfs:label 'P Statements' ;
    rdfs:comment 'Comma-separated list of standardized precautionary statement codes describing recommended measures to minimize or prevent adverse effects (e.g., P264, P280, P301+P312).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbtAssessment rdf:type rdf:Property ;
    rdfs:label 'Pbt Assessment' ;
    rdfs:comment 'Assessment result indicating whether the substance meets the criteria for being Persistent, Bioaccumulative and Toxic (PBT) or very Persistent and very Bioaccumulative (vPvB).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnecUnit rdf:type rdf:Property ;
    rdfs:label 'Pnec Unit' ;
    rdfs:comment 'Unit of measure for the PNEC value.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnecValue rdf:type rdf:Property ;
    rdfs:label 'Pnec Value' ;
    rdfs:comment 'The concentration of the substance below which adverse effects in the environmental sphere of concern are not expected to occur.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current REACH registration expires and renewal is required.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionConditions rdf:type rdf:Property ;
    rdfs:label 'Restriction Conditions' ;
    rdfs:comment 'Detailed description of the specific conditions, limitations, or prohibitions applied to the substance under REACH Annex XVII restrictions.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Restriction Entry Number' ;
    rdfs:comment 'The entry number in REACH Annex XVII that specifies the restriction applicable to this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Indicates whether the substance is subject to restrictions under REACH Annex XVII limiting or prohibiting its manufacture, use, or placing on the market.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most recent revision of the Safety Data Sheet.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:substanceName rdf:type rdf:Property ;
    rdfs:label 'Substance Name' ;
    rdfs:comment 'The common or chemical name of the substance as registered under REACH.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceOriginCountryCode rdf:type rdf:Property ;
    rdfs:label 'Substance Origin Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary country of origin or manufacture for this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcInclusionDate rdf:type rdf:Property ;
    rdfs:label 'Svhc Inclusion Date' ;
    rdfs:comment 'Date when the substance was added to the SVHC Candidate List by ECHA.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:svhcStatus rdf:type rdf:Property ;
    rdfs:label 'Svhc Status' ;
    rdfs:comment 'Classification status indicating whether the substance is identified as a Substance of Very High Concern under REACH Article 57, requiring special authorization or restriction.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnageBand rdf:type rdf:Property ;
    rdfs:label 'Tonnage Band' ;
    rdfs:comment 'Annual quantity band (in metric tonnes per year) of the substance manufactured or imported into the EU, determining registration requirements and data submission obligations.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useDescriptorCodes rdf:type rdf:Property ;
    rdfs:label 'Use Descriptor Codes' ;
    rdfs:comment 'Comma-separated list of standardized use descriptor codes (SU, PC, PROC, ERC, AC) describing identified uses of the substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredients rdf:type rdf:Property ;
    rdfs:label 'Active Ingredients' ;
    rdfs:comment 'List of active ingredients or substances covered by this registration, using INCI (International Nomenclature of Cosmetic Ingredients) or CAS (Chemical Abstracts Service) numbers where applicable. Critical for EPA pesticide and antimicrobial registrations.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Due Date' ;
    rdfs:comment 'Date by which annual registration reports or updates must be submitted to the regulatory authority. Used for compliance tracking and reporting calendar management.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cfrCitation rdf:type rdf:Property ;
    rdfs:label 'Cfr Citation' ;
    rdfs:comment 'Specific CFR (Code of Federal Regulations) citation or section under which the product is registered (e.g., 21 CFR 314 for NDAs, 40 CFR 152 for pesticides). Applicable primarily to US registrations.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscTrackingLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Cpsc Tracking Label Required' ;
    rdfs:comment 'Indicates whether CPSC tracking label requirements apply to this registered product. True if tracking labels are required, False otherwise. Applicable to children\'s products and certain consumer goods.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total fee amount paid or payable for this registration in the registration holder\'s reporting currency. Includes initial registration fees and any applicable renewal fees.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the registration fee amount (e.g., USD, EUR, GBP, CAD).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderAddress rdf:type rdf:Property ;
    rdfs:label 'Holder Address' ;
    rdfs:comment 'Full business address of the registration holder as registered with the regulatory authority. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'Legal name of the company or entity that holds the registration. This is the registrant of record with the regulatory authority.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where the registration is valid (e.g., USA, DEU, GBR, CAN, BRA, JPN, AUS, CHN).' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Specific region, state, or province within the country where the registration applies (e.g., California, Ontario, Bavaria). Used for sub-national regulatory requirements.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Label Approval Number' ;
    rdfs:comment 'Approval number for the product label as reviewed and accepted by the regulatory authority. Critical for EPA pesticide registrations where label claims are strictly regulated.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillanceRequired rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Required' ;
    rdfs:comment 'Indicates whether post-market surveillance or pharmacovigilance reporting is required for this registration. True if surveillance is required, False otherwise.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Description of the product scope covered by this registration, including specific formulations, SKUs (Stock Keeping Units), or product variants included under this registration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Registering Authority' ;
    rdfs:comment 'Name of the regulatory authority or governing body with which the product is registered (e.g., FDA, EPA, EU Commission, Health Canada, ANVISA). [ENUM-REF-CANDIDATE: FDA|EPA|CPSC|EU_REACH|Health_Canada|ANVISA|PMDA|TGA|SFDA|MHRA|BfR — promote to reference product]' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCategory rdf:type rdf:Property ;
    rdfs:label 'Registration Category' ;
    rdfs:comment 'Regulatory category or class of the registration as defined by the authority (e.g., OTC drug, prescription drug, general use pesticide, restricted use pesticide, cosmetic product, biocidal product).' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration number or identifier issued by the regulatory authority. This is the externally-known unique identifier for the registration (e.g., FDA registration number, EPA registration number, EU REACH registration number).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Phone' ;
    rdfs:comment 'Phone number of the primary regulatory affairs contact person for this registration. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sds Document Reference' ;
    rdfs:comment 'Reference identifier or document number for the Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) associated with this registered product. Links to safety documentation repository.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the registration application or dossier was submitted to the regulatory authority.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'Internal or external reference number for the regulatory submission dossier associated with this registration. Links to detailed submission documentation.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionResponsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory actions assign a responsible employee for follow-up; FK enables tracking of accountability.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Official date the regulatory authority issued or published the enforcement action. This is the business event timestamp representing when the action became effective.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory authority to this enforcement action (e.g., warning letter number, import alert number, consent decree docket number).' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory action. Tracks progression from initial receipt through company response, corrective action implementation, and final resolution or closure by the authority. [ENUM-REF-CANDIDATE: received|under_review|response_submitted|corrective_action_in_progress|resolved|closed|appealed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the regulatory enforcement action received. Warning letters address violations; import alerts restrict product entry; consent decrees are legal settlements; Form 483 observations document inspection findings; recalls remove products from market; injunctions halt operations; seizures confiscate products; penalties impose fines; prosecutions pursue criminal charges. [ENUM-REF-CANDIDATE: warning_letter|import_alert|consent_decree|form_483|mandatory_recall|voluntary_recall|injunction|seizure|civil_penalty|criminal_prosecution — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedFacilityList rdf:type rdf:Property ;
    rdfs:label 'Affected Facility List' ;
    rdfs:comment 'Comma-separated list of facility names or codes affected by this regulatory action when multiple sites are involved. Used for multi-site enforcement actions or consent decrees covering multiple locations.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductList rdf:type rdf:Property ;
    rdfs:label 'Affected Product List' ;
    rdfs:comment 'Comma-separated list of product names, SKUs (Stock Keeping Units), or GTINs (Global Trade Item Numbers) affected by this regulatory action when multiple products are involved. Used when action spans multiple products or product families.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date the mandated external audit was completed and final audit report submitted to the regulatory authority. Null if no external audit is required or if audit is still in progress.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date the Board of Directors was formally notified of this regulatory action. Required for material enforcement actions that could impact financial statements, stock price, or corporate reputation. Null if board notification was not required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'Specific legal or regulatory code sections cited in the enforcement action (e.g., 21 CFR 211.110 for GMP violations, 40 CFR 261 for hazardous waste, 16 CFR Part 1500 for CPSC). Provides the legal basis for the action.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Required Flag' ;
    rdfs:comment 'Indicates whether the regulatory action mandates an independent third-party audit or inspection to verify corrective actions. True when authority requires external verification; False when internal verification is sufficient.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the independent third-party auditing firm or consultant engaged to verify corrective actions as required by the regulatory authority. Null if no external audit is required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'Monetary fine or civil penalty assessed by the regulatory authority as part of the enforcement action. Expressed in the currency specified in penalty_currency_code. Null if no financial penalty was imposed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number for any insurance claim filed to recover costs associated with this regulatory action (e.g., recall expenses, legal fees, penalties). Links to the insurance claims management system. Null if no claim was filed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to advise on this regulatory action. Critical for consent decrees, injunctions, civil penalties, and criminal prosecutions where legal strategy is required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousActionReference rdf:type rdf:Property ;
    rdfs:label 'Previous Action Reference' ;
    rdfs:comment 'Reference to the earlier regulatory action that cited the same or related violations. Used to track repeat violations and enforcement escalation patterns. Null if this is a first-time violation.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the regulatory action has been publicly disclosed by the authority (e.g., published on FDA warning letters database, EPA enforcement actions website). True if publicly available; False if confidential or under seal.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicDisclosureUrl rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Url' ;
    rdfs:comment 'Web address where the regulatory action is publicly published by the issuing authority. Typically links to FDA warning letters database, EPA enforcement actions, CPSC recall notices, or equivalent public registries. Null if not publicly disclosed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA recall classification indicating the health hazard level. Class I: dangerous or defective products that could cause serious health problems or death; Class II: products that might cause temporary health problem or slight threat of serious nature; Class III: products unlikely to cause adverse health reaction but violate FDA regulations. Null if no recall is involved.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Required Flag' ;
    rdfs:comment 'Indicates whether the regulatory action mandates a product recall. True for mandatory recalls ordered by the authority; False for actions that do not require recall or for voluntary recalls initiated by the company.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Violation Flag' ;
    rdfs:comment 'Indicates whether this regulatory action cites violations that were previously identified in earlier inspections or enforcement actions. True for repeat violations, which typically result in escalated enforcement and higher penalties; False for first-time violations.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Corporate email address of the internal executive or department head accountable for this regulatory action. Used for escalation and executive reporting.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Primary classification of the regulatory violation cited in the action. GMP (Good Manufacturing Practice) violations relate to production standards; labeling violations involve packaging claims or ingredient declarations; safety violations concern product hazards; environmental violations address EPA compliance; advertising violations involve FTC rules; ingredient violations relate to prohibited or undeclared substances; quality system violations concern QMS (Quality Management System) deficiencies; record-keeping violations involve documentation failures; reporting violations concern mandatory disclosure failures. [ENUM-REF-CANDIDATE: gmp_violation|labeling_violation|safety_violation|environmental_violation|advertising_violation|ingredient_violation|quality_system_violation|record_keeping_violation|reporting_violation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryChangeResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory change implementation is owned by a specific employee; linking records ownership for change management.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Affected Product Category' ;
    rdfs:comment 'Product category or categories impacted by the regulatory change.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductScope rdf:type rdf:Property ;
    rdfs:label 'Affected Product Scope' ;
    rdfs:comment 'Scope description of the products impacted (e.g., all SKUs in a brand, specific formulations).' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'High-level category of the regulatory change.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSource rdf:type rdf:Property ;
    rdfs:label 'Change Source' ;
    rdfs:comment 'Origin of the change (regulatory authority, industry body, court decision).' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Risk rating associated with non-compliance to the change.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Date' ;
    rdfs:comment 'Date the impact assessment was completed or recorded.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Status' ;
    rdfs:comment 'Current status of the impact assessment process.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationEndDate rdf:type rdf:Property ;
    rdfs:label 'Implementation End Date' ;
    rdfs:comment 'Date when implementation activities were completed.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'Date when implementation activities began.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the implementation of required actions.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether compliance with the change is mandatory (true) or optional (false).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Required Action Deadline' ;
    rdfs:comment 'Latest date by which required compliance actions must be taken.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'Name of the regulatory authority issuing the change (e.g., FDA, EPA).' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceBody rdf:type rdf:Property ;
    rdfs:label 'Source Body' ;
    rdfs:comment 'Governing body or standard organization responsible for the change.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Link to the official document or announcement describing the change.' ;
    rdfs:domain ind:Change ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClaimId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Claim Id' ;
    rdfs:comment 'Unique identifier for the regulatory claim record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryClaim .

ind:complianceReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Claims are reviewed by a designated employee; FK supports claim review audit and reporting.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reporting Required' ;
    rdfs:comment 'Indicates whether adverse events related to the claim must be reported to regulatory authorities. True if reporting is required, False otherwise.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedMarkets rdf:type rdf:Property ;
    rdfs:label 'Approved Markets' ;
    rdfs:comment 'Comma-separated list of market codes or regions where the claim is approved for use (e.g., USA, EU, LATAM, APAC). Enables market-specific claim deployment.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Business identifier for the regulatory claim, formatted as RC- followed by 8 digits. Used for external reference and tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the internal compliance review was completed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Outcome' ;
    rdfs:comment 'Result of internal FTC/FDA compliance review: compliant (meets all requirements), non-compliant (violates regulations), requires modification (needs changes before use), pending review (under evaluation), or not reviewed (not yet assessed).' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Required Flag' ;
    rdfs:comment 'Indicates whether a disclaimer statement must accompany the claim on labels or marketing materials. True if disclaimer is required, False otherwise.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Full text of the required disclaimer that must accompany the claim. Null if no disclaimer is required. Must be displayed in accordance with regulatory guidelines.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Eu Regulation Reference' ;
    rdfs:comment 'Specific EU regulation or directive that governs the claim (e.g., Regulation 1223/2009 for cosmetics, Regulation 1924/2006 for nutrition and health claims). Null if not applicable to EU markets.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewals for the claim. Null if no renewal is required. Common values: 12, 24, 36, 60.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the claim requires periodic renewal with the regulatory authority. True if renewal is required, False if approval is indefinite.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingStudyReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Study Reference' ;
    rdfs:comment 'Reference identifier or citation for the study, test report, or documentation that substantiates the claim. May include internal study IDs, published journal citations, or third-party certification numbers.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCertification rdf:type rdf:Property ;
    rdfs:label 'Third Party Certification' ;
    rdfs:comment 'Name of third-party certification body or seal that validates the claim (e.g., USDA Organic, Leaping Bunny, EcoCert, NSF, Rainforest Alliance). Null if no third-party certification applies.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestriction rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction' ;
    rdfs:comment 'Any restrictions or conditions on the use of the claim, such as required disclaimers, context limitations, or co-claim requirements. Free text field for detailed restriction documentation.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Id' ;
    rdfs:comment 'Unique identifier for the restricted substance record. Primary key.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or SKU families in which this substance is restricted or prohibited (e.g., cosmetics, household cleaners, food contact materials, children\'s products).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeSubstanceRecommendations rdf:type rdf:Property ;
    rdfs:label 'Alternative Substance Recommendations' ;
    rdfs:comment 'Comma-separated list of CAS numbers or substance names recommended as safer alternatives for formulation substitution.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of all regulations, directives, or legal frameworks under which this substance is restricted (e.g., EU REACH, California Prop 65, FDA 21 CFR 700, EPA FIFRA, CPSC regulations).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current status of regulatory authorization for use of the substance in specific applications or markets.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the maximum permitted concentration: percent by weight, percent by volume, parts per million (ppm), parts per billion (ppb), or milligrams per kilogram.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Downstream Notification Required' ;
    rdfs:comment 'Indicates whether manufacturers and importers must notify downstream users (formulators, distributors, retailers) of the presence of this substance in articles or mixtures.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Restricted Flag' ;
    rdfs:comment 'Indicates whether the substance is subject to EPA restrictions under TSCA, FIFRA, or other environmental regulations.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaProhibitedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Prohibited Flag' ;
    rdfs:comment 'Indicates whether the substance is explicitly prohibited by the FDA for use in cosmetics, drugs, or food contact materials under CFR Title 21.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifraProhibitionCategory rdf:type rdf:Property ;
    rdfs:label 'Ifra Prohibition Category' ;
    rdfs:comment 'IFRA product category (1-11) in which the substance is prohibited or restricted, ranging from Category 1 (lip products) to Category 11 (non-skin contact products).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraStandardReference rdf:type rdf:Property ;
    rdfs:label 'Ifra Standard Reference' ;
    rdfs:comment 'Reference to the applicable IFRA Standard number and amendment that governs the use of this substance in fragrance compounds.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPermittedConcentration rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Concentration' ;
    rdfs:comment 'Maximum allowable concentration of the substance in finished products, expressed as a percentage by weight or volume, as defined by applicable regulations.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prop65Listing rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Listing' ;
    rdfs:comment 'Indicates whether the substance is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm, requiring warning labels for California sales.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rspoComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Rspo Compliance Flag' ;
    rdfs:comment 'Indicates whether the substance (if palm-derived) meets RSPO certification requirements for sustainable sourcing.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Required' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet (formerly MSDS) must be maintained and provided to downstream users for this substance.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Date after which the use of the substance is prohibited unless a specific authorization has been granted, applicable primarily under REACH authorization provisions.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accidentalReleaseMeasures rdf:type rdf:Property ;
    rdfs:label 'Accidental Release Measures' ;
    rdfs:comment 'Personal precautions, protective equipment, emergency procedures, and methods for containment and cleanup of spills or releases.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appearance rdf:type rdf:Property ;
    rdfs:label 'Appearance' ;
    rdfs:comment 'Visual description of the substance including color and form.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringChemist rdf:type rdf:Property ;
    rdfs:label 'Authoring Chemist' ;
    rdfs:comment 'Name of the qualified chemist or toxicologist who authored or reviewed this SDS for technical accuracy.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoignitionTemperature rdf:type rdf:Property ;
    rdfs:label 'Autoignition Temperature' ;
    rdfs:comment 'Temperature at which the substance will spontaneously ignite without an external ignition source.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Disposal Considerations' ;
    rdfs:comment 'Guidance on proper disposal methods, waste treatment, and applicable regulations for the substance and contaminated packaging.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Ecological Information' ;
    rdfs:comment 'Environmental impact data including aquatic toxicity, persistence and degradability, bioaccumulative potential, and mobility in soil.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Phone Number' ;
    rdfs:comment '24-hour emergency contact telephone number for chemical emergency response (e.g., CHEMTREC, poison control).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimits rdf:type rdf:Property ;
    rdfs:label 'Exposure Limits' ;
    rdfs:comment 'Occupational exposure limits (OELs), permissible exposure limits (PELs), threshold limit values (TLVs), and biological exposure indices.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firefightingMeasures rdf:type rdf:Property ;
    rdfs:label 'Firefighting Measures' ;
    rdfs:comment 'Suitable extinguishing media, unsuitable extinguishing media, and special hazards arising from the substance or mixture during fire.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAidMeasures rdf:type rdf:Property ;
    rdfs:label 'First Aid Measures' ;
    rdfs:comment 'Detailed first aid instructions for different exposure routes (inhalation, skin contact, eye contact, ingestion) as required by GHS Section 4.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPoint rdf:type rdf:Property ;
    rdfs:label 'Flash Point' ;
    rdfs:comment 'Lowest temperature at which vapors of the substance will ignite when given an ignition source, typically in degrees Celsius.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification' ;
    rdfs:comment 'GHS hazard classification codes assigned to this substance or mixture (e.g., Flam. Liq. 2, Acute Tox. 3, Skin Corr. 1B).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingPrecautions rdf:type rdf:Property ;
    rdfs:label 'Handling Precautions' ;
    rdfs:comment 'Safe handling practices and precautions for use to prevent exposure and ensure worker safety.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatements rdf:type rdf:Property ;
    rdfs:label 'Hazard Statements' ;
    rdfs:comment 'Standardized GHS hazard statements (H-codes) describing the nature and degree of hazards (e.g., H225: Highly flammable liquid and vapor).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousDecompositionProducts rdf:type rdf:Property ;
    rdfs:label 'Hazardous Decomposition Products' ;
    rdfs:comment 'Hazardous substances that may be formed under fire conditions or other decomposition scenarios.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleMaterials rdf:type rdf:Property ;
    rdfs:label 'Incompatible Materials' ;
    rdfs:comment 'Materials or substances that should not be stored or used with this product due to potential hazardous reactions.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odor rdf:type rdf:Property ;
    rdfs:label 'Odor' ;
    rdfs:comment 'Characteristic odor of the substance or mixture, if detectable.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'UN packing group indicating degree of danger for transport: I (high danger), II (medium danger), III (low danger).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalProtectiveEquipment rdf:type rdf:Property ;
    rdfs:label 'Personal Protective Equipment' ;
    rdfs:comment 'Required personal protective equipment for safe handling: respiratory protection, hand protection, eye protection, skin protection.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'pH measurement of the substance or mixture, indicating acidity or alkalinity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical form of the substance or mixture at ambient conditions.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictograms rdf:type rdf:Property ;
    rdfs:label 'Pictograms' ;
    rdfs:comment 'List of GHS pictogram codes required on the label (e.g., GHS02 Flame, GHS07 Exclamation Mark, GHS08 Health Hazard).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatements rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statements' ;
    rdfs:comment 'Standardized GHS precautionary statements (P-codes) describing recommended measures to minimize or prevent adverse effects (e.g., P210: Keep away from heat/sparks/open flames).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Internal product code or SKU (Stock Keeping Unit) for the material covered by this SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official shipping name for transport documentation as specified by UN/DOT regulations.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInformation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Information' ;
    rdfs:comment 'Applicable regulatory requirements including TSCA status, REACH registration, California Prop 65, SARA Title III, and other jurisdiction-specific regulations.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when this version of the SDS was last revised or updated.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this SDS, used for regulatory submissions and cross-referencing.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsStatus rdf:type rdf:Property ;
    rdfs:label 'Sds Status' ;
    rdfs:comment 'Current lifecycle status of the SDS document within the regulatory document management system.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stability rdf:type rdf:Property ;
    rdfs:label 'Stability' ;
    rdfs:comment 'Chemical stability information and conditions to avoid that may cause instability or hazardous reactions.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Toxicological Information' ;
    rdfs:comment 'Comprehensive toxicology data including acute toxicity, skin corrosion/irritation, eye damage/irritation, sensitization, mutagenicity, carcinogenicity, reproductive toxicity, and target organ effects.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportHazardClass rdf:type rdf:Property ;
    rdfs:label 'Transport Hazard Class' ;
    rdfs:comment 'UN/DOT hazard class for transportation (e.g., Class 3 Flammable Liquids, Class 8 Corrosives).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number for hazardous materials transport classification.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory submission review is performed by a specific employee; FK supports reviewer assignment tracking.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Previous Submission Id' ;
    rdfs:comment 'Foreign key reference to the prior submission record that this submission amends, supersedes, or follows up on.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:actualDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Decision Date' ;
    rdfs:comment 'Actual date on which the regulatory authority issued a final decision (approval, rejection, or other outcome) on the submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Authority Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction of the regulatory authority (e.g., USA, DEU, GBR, CAN).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address of the internal regulatory affairs contact person for correspondence related to this submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Phone number of the internal regulatory affairs contact person for inquiries related to this submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Final outcome or decision rendered by the regulatory authority (approved, approved with conditions, rejected, withdrawn, pending).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierReference rdf:type rdf:Property ;
    rdfs:label 'Dossier Reference' ;
    rdfs:comment 'Reference identifier linking this submission to the master regulatory dossier or product registration file maintained in the regulatory document management system.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'Payment status of the regulatory filing fee (paid, pending, waived, refunded).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the primary language in which the submission was prepared and filed (e.g., en for English, de for German, fr for French).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known unique submission number or dossier reference assigned by the regulatory authority or internal tracking system (e.g., 510(k) number, PMA number, REACH registration number).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory submission (draft, submitted, under review, additional information requested, approved, rejected, withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|under_review|additional_info_requested|approved|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Type of regulatory submission filed (510(k) premarket notification, PMA premarket approval, GRAS generally recognized as safe, TSCA toxic substances control act, cosmetic notification, CPSC Section 15(b) report, SaferProducts.gov incident report, REACH registration). [ENUM-REF-CANDIDATE: 510k|pma|gras|tsca|cosmetic_notification|cpsc_section_15b|saferproducts_gov|reach_registration — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Target Decision Date' ;
    rdfs:comment 'Expected or target date by which the regulatory authority is anticipated to issue a decision on the submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveillanceEventId rdf:type rdf:Property ;
    rdfs:label 'Surveillance Event Id' ;
    rdfs:comment 'Primary key for surveillance_event' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveillanceEvent .

ind:investigationAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Post-market surveillance investigations are assigned to an employee; FK enables investigation tracking.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consumerComplaintDescription rdf:type rdf:Property ;
    rdfs:label 'Consumer Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the consumer complaint or adverse event as reported, capturing symptoms, circumstances, and product usage context.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Event Occurrence Date' ;
    rdfs:comment 'Date when the adverse event or product issue actually occurred or was first observed by the consumer or reporter.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Received Timestamp' ;
    rdfs:comment 'Date and time when the surveillance signal was first received by the organization, marking the start of the regulatory clock for reporting obligations.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the surveillance event including investigation costs, corrective actions, potential recall costs, and liability exposure in USD.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Three-letter ISO country codes indicating the geographic markets where the affected product was distributed, pipe-separated for multiple countries.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Reported Flag' ;
    rdfs:comment 'Indicates whether the surveillance event involved a reported consumer injury or adverse health effect.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalTreatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Required Flag' ;
    rdfs:comment 'Indicates whether the reported injury required medical treatment or healthcare intervention.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Flag' ;
    rdfs:comment 'Indicates whether the surveillance event resulted in a product recall or market withdrawal action.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference Number' ;
    rdfs:comment 'Official reference or tracking number assigned by the regulatory authority upon submission of the surveillance report.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'Date when the mandatory regulatory report was submitted to the applicable authority.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the surveillance event triggers a mandatory regulatory reporting obligation to FDA, CPSC, EPA, or other authorities.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterContactEmail rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Email' ;
    rdfs:comment 'Email address of the reporter for written communication and documentation exchange.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterContactPhone rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Phone' ;
    rdfs:comment 'Primary phone number of the reporter for follow-up investigation and clarification.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Full name of the individual who reported the surveillance event, required for follow-up and regulatory submissions.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentified rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified' ;
    rdfs:comment 'Documented root cause of the surveillance event as determined through investigation, including manufacturing defect, formulation issue, packaging failure, or misuse.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Risk-based severity rating of the surveillance event based on potential harm to consumers and regulatory impact.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalSource rdf:type rdf:Property ;
    rdfs:label 'Signal Source' ;
    rdfs:comment 'Origin channel through which the post-market surveillance signal was received. [ENUM-REF-CANDIDATE: consumer_direct|call_center|retailer|distributor|regulatory_authority|social_media|healthcare_provider|internal_audit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceNumber rdf:type rdf:Property ;
    rdfs:label 'Surveillance Number' ;
    rdfs:comment 'Business identifier for the surveillance event, externally referenced in regulatory submissions and internal tracking systems.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAffectedEstimate rdf:type rdf:Property ;
    rdfs:label 'Units Affected Estimate' ;
    rdfs:comment 'Estimated number of product units potentially affected by the surveillance event, used for recall scope and risk assessment.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerTestId rdf:type rdf:Property ;
    rdfs:label 'Consumer Test Id' ;
    rdfs:comment 'Reference to the consumer test record that provides supporting evidence for this claim.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerTest .

ind:primaryClaimOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Claim Owner Employee Id' ;
    rdfs:comment 'Reference to the business owner (typically from marketing or brand management) responsible for this claim and its usage.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryClaimResponsibleScientistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Claim Responsible Scientist Employee Id' ;
    rdfs:comment 'Reference to the principal scientist or researcher responsible for generating and validating the substantiation evidence.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyProtocolId rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Id' ;
    rdfs:comment 'Reference to the formal study protocol document that defines the testing methodology used for substantiation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyProtocol .

ind:tertiaryClaimRegulatoryReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Claim Regulatory Reviewer Employee Id' ;
    rdfs:comment 'Reference to the regulatory affairs specialist who reviewed this claim for compliance with applicable regulations.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advertisingStandardCompliance rdf:type rdf:Property ;
    rdfs:label 'Advertising Standard Compliance' ;
    rdfs:comment 'Comma-separated list of advertising standards and self-regulatory bodies that this claim complies with (e.g., \'NAD,ASA,ASRC,CARU\').' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeHistory rdf:type rdf:Property ;
    rdfs:label 'Challenge History' ;
    rdfs:comment 'Summary of any historical challenges, complaints, or disputes related to this claim from regulatory bodies, competitors, or consumer advocacy groups.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Approval Status' ;
    rdfs:comment 'Current approval status of the claim substantiation within the internal governance process. [ENUM-REF-CANDIDATE: draft|under_review|approved|rejected|conditional_approval|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'Broader categorization of the claim for organizational and reporting purposes.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Claim Effective Date' ;
    rdfs:comment 'Date from which this claim substantiation becomes valid and the claim may be used in marketing materials.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Claim Expiry Date' ;
    rdfs:comment 'Date when this claim substantiation expires and the claim must be re-substantiated or withdrawn from use.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalStudyReference rdf:type rdf:Property ;
    rdfs:label 'Clinical Study Reference' ;
    rdfs:comment 'Citation or reference number for the clinical study that substantiates this claim (e.g., internal study ID, ClinicalTrials.gov identifier, published journal article DOI).' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyResultSummary rdf:type rdf:Property ;
    rdfs:label 'Efficacy Result Summary' ;
    rdfs:comment 'Brief summary of the key efficacy findings from the substantiation study (e.g., \'87% of users reported smoother skin after 4 weeks\').' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when the legal review was completed and the claim was approved or rejected by legal counsel.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Status of legal department review to ensure the claim is defensible and compliant with advertising standards.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Comma-separated list of geographic markets or regions where this claim is approved for use (e.g., \'USA,CAN,GBR,DEU,FRA\' using ISO 3166-1 alpha-3 country codes).' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Date' ;
    rdfs:comment 'Date when the regulatory review was completed.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Assessment of the legal and regulatory risk associated with using this claim, based on strength of evidence and potential for challenge.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Substantiation Cost Amount' ;
    rdfs:comment 'Total cost incurred to substantiate this claim, including study costs, testing fees, and expert consultation fees.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substantiationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Substantiation Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the substantiation cost amount.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReferences rdf:type rdf:Property ;
    rdfs:label 'Supporting Document References' ;
    rdfs:comment 'Comma-separated list of document IDs, file paths, or references to all supporting evidence documents (test reports, certificates, expert opinions, published papers) that substantiate this claim.' ;
    rdfs:domain ind:ClaimSubstantiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDurationDays rdf:type rdf:Property ;
    rdfs:label 'Test Duration Days' ;
    rdfs:comment 'Duration of the substantiation study or test period measured in days.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consumer test oversight mandates assigning a principal investigator (employee) to ensure scientific integrity and regulatory documentation.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:respondentId rdf:type rdf:Property ;
    rdfs:label 'Respondent Id' ;
    rdfs:comment 'Anonymized or pseudonymized identifier for individual test participants to enable respondent-level analysis while protecting privacy.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Respondent .

ind:adverseEventDescription rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Description' ;
    rdfs:comment 'Detailed description of any adverse events reported during the consumer test, including symptoms and severity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseEventReported rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reported' ;
    rdfs:comment 'Boolean flag indicating whether any adverse events (skin irritation, allergic reaction, etc.) were reported by the respondent during the test.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimSubstantiationOutcome rdf:type rdf:Property ;
    rdfs:label 'Claim Substantiation Outcome' ;
    rdfs:comment 'Outcome of claim validation for this specific respondent or data point, indicating whether the claim was supported by the results.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyPerceptionRating rdf:type rdf:Property ;
    rdfs:label 'Efficacy Perception Rating' ;
    rdfs:comment 'Consumer rating of perceived product efficacy or performance on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicsCommitteeApproval rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Approval' ;
    rdfs:comment 'Boolean flag indicating whether the study received ethics committee or institutional review board (IRB) approval.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fragranceRating rdf:type rdf:Property ;
    rdfs:label 'Fragrance Rating' ;
    rdfs:comment 'Consumer rating of product fragrance appeal on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latherRating rdf:type rdf:Property ;
    rdfs:label 'Lather Rating' ;
    rdfs:comment 'Consumer rating of product lather quality on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openTextVerbatim rdf:type rdf:Property ;
    rdfs:label 'Open Text Verbatim' ;
    rdfs:comment 'Free-text consumer feedback or comments captured during the test, providing qualitative insights.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Overall Satisfaction Rating' ;
    rdfs:comment 'Consumer overall satisfaction rating with the product on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallStudyOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Study Outcome' ;
    rdfs:comment 'Summary outcome of the consumer test indicating whether the primary claim was successfully validated.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryClaimTested rdf:type rdf:Property ;
    rdfs:label 'Primary Claim Tested' ;
    rdfs:comment 'The main product claim or benefit being validated through this consumer test (e.g., \'reduces wrinkles in 4 weeks\', \'long-lasting fragrance\').' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeCode rdf:type rdf:Property ;
    rdfs:label 'Prototype Code' ;
    rdfs:comment 'Internal code for the prototype or formulation variant tested, used during New Product Development (NPD) before commercial SKU assignment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseIntentScore rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Score' ;
    rdfs:comment 'Consumer purchase intent rating indicating likelihood to buy the product after testing, typically on a standardized scale.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScaleMax rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Max' ;
    rdfs:comment 'Maximum value of the rating scale used in the study (e.g., 5.00 for a 1-5 scale).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingScaleMin rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Min' ;
    rdfs:comment 'Minimum value of the rating scale used in the study (e.g., 1.00 for a 1-5 scale).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryClaimsTested rdf:type rdf:Property ;
    rdfs:label 'Secondary Claims Tested' ;
    rdfs:comment 'Additional product claims or benefits evaluated during the test, stored as comma-separated list.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skinFeelRating rdf:type rdf:Property ;
    rdfs:label 'Skin Feel Rating' ;
    rdfs:comment 'Consumer rating of product skin feel or texture on a standardized scale (e.g., 1.00 to 5.00).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Study Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the consumer test study, including participant compensation, facility fees, and analysis costs.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Study Cost Currency' ;
    rdfs:comment 'Currency code for the study cost amount, using ISO 4217 3-letter currency codes.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesign rdf:type rdf:Property ;
    rdfs:label 'Study Design' ;
    rdfs:comment 'Methodological design of the study including blinding and control structure.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEndDate rdf:type rdf:Property ;
    rdfs:label 'Test End Date' ;
    rdfs:comment 'Date when the consumer test study concluded and final data collection was completed.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testFacilityName rdf:type rdf:Property ;
    rdfs:label 'Test Facility Name' ;
    rdfs:comment 'Name of the laboratory, clinic, or research facility where the consumer test was conducted.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testGeography rdf:type rdf:Property ;
    rdfs:label 'Test Geography' ;
    rdfs:comment 'Geographic region or country where the consumer test was conducted, using 3-letter ISO country codes (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPanel rdf:type rdf:Property ;
    rdfs:label 'Test Panel' ;
    rdfs:comment 'Panel or cohort assignment for the respondent (e.g., control group, test group A, test group B) used in comparative studies.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when the consumer test study commenced and participants began product usage or evaluation.' ;
    rdfs:domain ind:ConsumerTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerTestResultId rdf:type rdf:Property ;
    rdfs:label 'Consumer Test Result Id' ;
    rdfs:comment 'Unique identifier for the consumer test result record. Primary key.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productPrototypeId rdf:type rdf:Property ;
    rdfs:label 'Product Prototype Id' ;
    rdfs:comment 'Identifier for the product prototype or formulation being tested.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prototype .

ind:attributeTested rdf:type rdf:Property ;
    rdfs:label 'Attribute Tested' ;
    rdfs:comment 'Specific product attribute or characteristic being evaluated (e.g., lather, fragrance, skin feel, efficacy perception, texture, absorption, irritation).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkComparison rdf:type rdf:Property ;
    rdfs:label 'Benchmark Comparison' ;
    rdfs:comment 'Comparison of test result to a benchmark or control product (e.g., better than benchmark, equal to benchmark, worse than benchmark, no benchmark).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRate rdf:type rdf:Property ;
    rdfs:label 'Compliance Rate' ;
    rdfs:comment 'Percentage indicating respondent adherence to the test protocol (e.g., 95.00 for 95% compliance).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Flag indicating the quality or validity of the test result data (e.g., valid, invalid, suspect, missing data).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Number' ;
    rdfs:comment 'Ethics committee or institutional review board (IRB) approval number for the consumer test study.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Name or identifier of the principal investigator or lead researcher responsible for the consumer test.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseIntent rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent' ;
    rdfs:comment 'Respondent stated intention to purchase the product after testing.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingLabel rdf:type rdf:Property ;
    rdfs:label 'Rating Label' ;
    rdfs:comment 'Qualitative label corresponding to the rating value (e.g., strongly agree, neutral, dislike extremely).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingScaleType rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Type' ;
    rdfs:comment 'Type of rating scale used for the evaluation (e.g., Likert 5-point, Likert 7-point, numeric 0-10, hedonic 9-point, binary yes/no, visual analog scale).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'Numeric rating value provided by the respondent for the tested attribute.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySubmissionIncluded rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Included' ;
    rdfs:comment 'Boolean flag indicating whether this test result is included in regulatory submission dossiers (True) or not (False).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentDemographicSegment rdf:type rdf:Property ;
    rdfs:label 'Respondent Demographic Segment' ;
    rdfs:comment 'Demographic segment or profile of the respondent (e.g., age group, gender, skin type, hair type) relevant to the test.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Geographic location or facility where the consumer test was conducted (e.g., lab, home, central location).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProtocolCode rdf:type rdf:Property ;
    rdfs:label 'Test Protocol Code' ;
    rdfs:comment 'Standardized code identifying the test protocol or methodology used.' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Category of consumer or clinical test conducted (e.g., clinical use test, consumer use test, home use test, central location test, sensory evaluation, claim substantiation, safety assessment). [ENUM-REF-CANDIDATE: clinical_use_test|consumer_use_test|home_use_test|central_location_test|sensory_evaluation|claim_substantiation|safety_assessment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency' ;
    rdfs:comment 'Frequency with which the respondent used the product during the test period (e.g., once daily, twice daily, as needed).' ;
    rdfs:domain ind:ConsumerTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inciLibraryId rdf:type rdf:Property ;
    rdfs:label 'Inci Library Id' ;
    rdfs:comment 'Unique identifier for the INCI ingredient library record. Primary key for the enterprise master reference library of all INCI ingredients and raw materials used across R&D formulations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InciLibrary .

ind:approvedConcentrationMaxPercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Concentration Max Percentage' ;
    rdfs:comment 'Maximum approved concentration level for use in formulations, expressed as a percentage. Based on safety assessments, regulatory limits, and stability considerations.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedConcentrationMinPercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Concentration Min Percentage' ;
    rdfs:comment 'Minimum approved concentration level for use in formulations, expressed as a percentage. Based on efficacy requirements and regulatory guidance.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalFamily rdf:type rdf:Property ;
    rdfs:label 'Chemical Family' ;
    rdfs:comment 'Broad chemical classification grouping of the ingredient (e.g., surfactants, emollients, polymers, preservatives, colorants, fragrances, botanical extracts, minerals, vitamins). Used for formulation planning and ingredient substitution analysis.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorSpecification rdf:type rdf:Property ;
    rdfs:label 'Color Specification' ;
    rdfs:comment 'Acceptable color range or specification for the raw material, often described using visual standards, Lovibond scale, or spectrophotometric values. Important for maintaining product appearance consistency.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionClass rdf:type rdf:Property ;
    rdfs:label 'Function Class' ;
    rdfs:comment 'Primary functional role of the ingredient in formulations (e.g., emulsifier, thickener, moisturizer, active ingredient, pH adjuster, antioxidant, UV filter, fragrance component). Multiple functions may be comma-separated.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeQualityLevel rdf:type rdf:Property ;
    rdfs:label 'Grade Quality Level' ;
    rdfs:comment 'Quality grade designation of the raw material (e.g., cosmetic grade, pharmaceutical grade, technical grade, food grade, USP, NF, BP, EP). Indicates purity level and intended application.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Halal Certified Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient has been certified as Halal-compliant for use in products targeting Muslim consumers. True indicates Halal certification.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kosherCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kosher Certified Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient has been certified as Kosher-compliant for use in products targeting Jewish consumers. True indicates Kosher certification.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPermittedConcentrationPercentage rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Concentration Percentage' ;
    rdfs:comment 'The most restrictive maximum concentration limit imposed by any regulatory authority across all jurisdictions. Used as the global ceiling for formulation development.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentMaxPercentage rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Max Percentage' ;
    rdfs:comment 'Maximum allowable moisture content expressed as a percentage. Excess moisture can affect stability, microbial growth, and formulation performance.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odorSpecification rdf:type rdf:Property ;
    rdfs:label 'Odor Specification' ;
    rdfs:comment 'Acceptable odor characteristics of the raw material (e.g., characteristic, mild, odorless, specific odor profile). Critical for fragrance-sensitive formulations and consumer acceptance.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:particleSizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Particle Size Specification' ;
    rdfs:comment 'Specification for particle size distribution, typically expressed as a range in microns or mesh size. Critical for powder ingredients affecting texture, dispersion, and sensory properties.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Protected Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient or its specific grade/formulation is protected by active patents. True indicates patent protection exists, requiring licensing or IP clearance.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient is prohibited for use in cosmetic or personal care products in any major jurisdiction. True indicates prohibition exists.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purityPercentage rdf:type rdf:Property ;
    rdfs:label 'Purity Percentage' ;
    rdfs:comment 'Minimum purity level of the active ingredient expressed as a percentage. Critical specification parameter for quality control and formulation accuracy.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Raw Material Code' ;
    rdfs:comment 'Internal enterprise code used to identify and track the raw material in procurement, inventory, and manufacturing systems. Links to ERP material master records.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Rd Approval Status' ;
    rdfs:comment 'Current approval status of the ingredient for use in R&D formulation development. Approved ingredients are cleared for use in new product development projects.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusAsean rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Asean' ;
    rdfs:comment 'Current regulatory approval status of the ingredient for use in cosmetic and personal care products within ASEAN member countries under the ASEAN Cosmetic Directive.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusCanada rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Canada' ;
    rdfs:comment 'Current regulatory approval status of the ingredient for use in cosmetic and personal care products within Canada under Health Canada Cosmetic Ingredient Hotlist and regulations.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusEu rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Eu' ;
    rdfs:comment 'Current regulatory approval status of the ingredient for use in cosmetic and personal care products within the European Union under REACH and Cosmetics Regulation.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatusUsa rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status Usa' ;
    rdfs:comment 'Current regulatory approval status of the ingredient for use in cosmetic and personal care products within the United States under FDA regulations and GRAS status where applicable.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient has any regulatory restrictions, concentration limits, or usage conditions in any major jurisdiction. True indicates restrictions apply.' ;
    rdfs:domain ind:InciLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veganCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Vegan Compliant Flag' ;
    rdfs:comment 'Boolean indicator whether the ingredient is free from animal-derived components and suitable for vegan product formulations. True indicates vegan compliance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Linked Rd Project Id' ;
    rdfs:comment 'Reference to the R&D project that was created as a result of this approved innovation brief, establishing traceability from commercial trigger to execution.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdProject .

ind:primaryInnovationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Innovation Employee Id' ;
    rdfs:comment 'Reference to the commercial or marketing leader who is sponsoring the innovation brief and will champion it through the approval process.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryInnovationCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Innovation Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the innovation brief record.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryInnovationLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Innovation Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the innovation brief record.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInnovationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Innovation Approved By Employee Id' ;
    rdfs:comment 'Reference to the executive or committee member who granted final approval for the innovation brief.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attachmentsReference rdf:type rdf:Property ;
    rdfs:label 'Attachments Reference' ;
    rdfs:comment 'Reference or URI to supporting documents attached to the innovation brief (market research reports, consumer insights, competitive analysis, financial models).' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefCode rdf:type rdf:Property ;
    rdfs:label 'Brief Code' ;
    rdfs:comment 'Externally-known unique business identifier for the innovation brief, typically following a standardized format for tracking and reference across commercial and R&D teams.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefStatus rdf:type rdf:Property ;
    rdfs:label 'Brief Status' ;
    rdfs:comment 'Current lifecycle status of the innovation brief document in the approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|on_hold|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefTitle rdf:type rdf:Property ;
    rdfs:label 'Brief Title' ;
    rdfs:comment 'Descriptive title of the innovation brief that summarizes the product concept or business opportunity being proposed.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefType rdf:type rdf:Property ;
    rdfs:label 'Brief Type' ;
    rdfs:comment 'Classification of the innovation brief based on the nature of the NPD initiative (new product development, line extension, reformulation, etc.).' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated development budget.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOpportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Business Opportunity Description' ;
    rdfs:comment 'Detailed narrative describing the market opportunity, consumer need gap, competitive landscape, and strategic rationale for pursuing this innovation.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkProducts rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Products' ;
    rdfs:comment 'List of key competitor products that serve as performance, sensory, and pricing benchmarks for the proposed innovation.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredProductBenefits rdf:type rdf:Property ;
    rdfs:label 'Desired Product Benefits' ;
    rdfs:comment 'List of key functional, emotional, and sensory benefits that the product must deliver to meet consumer needs and differentiate from competitors.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDevelopmentBudget rdf:type rdf:Property ;
    rdfs:label 'Estimated Development Budget' ;
    rdfs:comment 'Estimated total budget required for R&D, formulation development, testing, regulatory submission, and pilot production to bring the innovation to market.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMarketSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Market Size' ;
    rdfs:comment 'Estimated total addressable market size in monetary value for the target category and consumer segment.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNpv rdf:type rdf:Property ;
    rdfs:label 'Estimated Npv' ;
    rdfs:comment 'Estimated net present value of the innovation project, representing the discounted future cash flows minus the initial investment.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Estimated Roi Percent' ;
    rdfs:comment 'Projected return on investment percentage for the innovation project over a defined time horizon, used for financial justification and prioritization.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Innovation Priority Tier' ;
    rdfs:comment 'Strategic priority classification assigned to the innovation brief, determining resource allocation and executive sponsorship level.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'List of measurable success criteria and KPIs that will be used to evaluate the innovation project (e.g., market share target, NPS score, repeat purchase rate).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSizeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Market Size Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated market size figure.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npvCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Npv Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated NPV figure.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'Expected regulatory approval pathway required for the product based on category, claims, and jurisdiction (e.g., FDA notification, EU cosmetic registration).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of key risks identified for the innovation (technical feasibility, regulatory, supply chain, competitive response) and proposed mitigation strategies.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicFitRationale rdf:type rdf:Property ;
    rdfs:label 'Strategic Fit Rationale' ;
    rdfs:comment 'Explanation of how this innovation aligns with corporate strategy, brand positioning, portfolio gaps, and long-term business objectives.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityTargetScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Target Score' ;
    rdfs:comment 'Target sustainability score or rating that the product must achieve, based on corporate sustainability commitments (e.g., carbon footprint, recyclability, natural content).' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCogs rdf:type rdf:Property ;
    rdfs:label 'Target Cogs' ;
    rdfs:comment 'Target manufacturing cost per unit that R&D must achieve to meet profitability objectives. Critical constraint for formulation development.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGrossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Percent' ;
    rdfs:comment 'Target gross margin percentage calculated from target RSP and COGS, representing the profitability threshold for project approval.' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLaunchGeography rdf:type rdf:Property ;
    rdfs:label 'Target Launch Geography' ;
    rdfs:comment 'Geographic markets or regions where the product is intended to launch initially (e.g., USA, EUR, APAC).' ;
    rdfs:domain ind:InnovationBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRsp rdf:type rdf:Property ;
    rdfs:label 'Target Rsp' ;
    rdfs:comment 'Target retail selling price that the product is expected to command in the market, used to calculate margin and assess commercial viability.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labTestId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Id' ;
    rdfs:comment 'Unique identifier for the laboratory test record. Primary key for the lab test entity.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTestLabTestId rdf:type rdf:Property ;
    rdfs:label 'Original Test Lab Test Id' ;
    rdfs:comment 'Reference to the original laboratory test record if this is a retest. Links retest results back to the initial test for investigation tracking.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTest .

ind:primaryLabEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Employee Id' ;
    rdfs:comment 'Reference to the employee or analyst who conducted the laboratory test.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration of the test equipment used. Ensures test results are obtained using properly calibrated instruments per ISO 17025 requirements.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labLocation rdf:type rdf:Property ;
    rdfs:label 'Lab Location' ;
    rdfs:comment 'Physical location or facility where the laboratory test was conducted. May reference internal R&D labs or external contract testing laboratories.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Boolean indicator that this test result is required for regulatory submission or compliance purposes (FDA, EPA, EU REACH, etc.). True indicates regulatory significance.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultText rdf:type rdf:Property ;
    rdfs:label 'Result Text' ;
    rdfs:comment 'Qualitative or descriptive result for tests that do not produce numeric values, such as visual observations, color assessments, odor evaluations, or pass/fail determinations.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measurement for the test result value, such as pH units, cP (centipoise) for viscosity, CFU/g (colony forming units per gram) for microbial count, percentage, ppm (parts per million), or other industry-standard units.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Numeric result value obtained from the laboratory test. Represents the measured quantity or concentration of the test parameter.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationMax rdf:type rdf:Property ;
    rdfs:label 'Specification Max' ;
    rdfs:comment 'Maximum acceptable value for the test parameter as defined in the product specification or regulatory requirement. Used to determine pass/fail status.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationMin rdf:type rdf:Property ;
    rdfs:label 'Specification Min' ;
    rdfs:comment 'Minimum acceptable value for the test parameter as defined in the product specification or regulatory requirement. Used to determine pass/fail status.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityTimepoint rdf:type rdf:Property ;
    rdfs:label 'Stability Timepoint' ;
    rdfs:comment 'Timepoint designation for stability testing, such as initial, 1 month, 3 months, 6 months, 12 months, 24 months, or 36 months. Critical for tracking product stability over time.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the laboratory test execution was completed and results were recorded.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testEquipment rdf:type rdf:Property ;
    rdfs:label 'Test Equipment' ;
    rdfs:comment 'Identification of the laboratory equipment or instrument used to perform the test, such as pH meter, viscometer, spectrophotometer, or microbiological incubator. Used for equipment calibration tracking and audit purposes.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Business identifier for the laboratory test, typically assigned by the Laboratory Information Management System (LIMS) or Quality Management (QM) module.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'Specific parameter or property being measured in the test, such as pH, viscosity, microbial count, irritation index, color stability, fragrance retention, or active ingredient concentration.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPriority rdf:type rdf:Property ;
    rdfs:label 'Test Priority' ;
    rdfs:comment 'Priority classification for the laboratory test. Determines scheduling and resource allocation. Critical and regulatory tests receive highest priority.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Precise date and time when the laboratory test execution began. Used for time-sensitive tests and audit trail purposes.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patentFilingId rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Id' ;
    rdfs:comment 'Unique identifier for the patent filing record. Primary key for the patent filing entity.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Patent Family Id' ;
    rdfs:comment 'Identifier linking related patent applications filed in multiple jurisdictions claiming the same priority. Used to track global patent family coverage.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:primaryPatentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Patent Employee Id' ;
    rdfs:comment 'User identifier of the person who created this patent filing record in the system. Used for audit trail and data stewardship accountability.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'Brief technical summary of the invention as filed with the patent office. Typically 150-250 words describing the problem solved, the solution, and key technical features.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Official application number assigned by the patent office upon filing. Unique identifier used for tracking prosecution status with the patent authority.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Assignee Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the assignee\'s country of incorporation or residence. Used for IP portfolio geographic analysis. [ENUM-REF-CANDIDATE: USA|GBR|DEU|FRA|JPN|CHN|KOR|CAN|AUS|BRA|IND|MEX — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Legal entity that owns the patent rights, typically the employer of the inventors. For Consumer Goods patents, this is usually the company name or a subsidiary.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwardCitationsCount rdf:type rdf:Property ;
    rdfs:label 'Backward Citations Count' ;
    rdfs:comment 'Number of prior art patents and publications cited by this patent application. Indicates the breadth of prior art landscape and novelty assessment complexity.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsCount rdf:type rdf:Property ;
    rdfs:label 'Claims Count' ;
    rdfs:comment 'Total number of claims in the patent application. Claims define the legal scope of protection. Higher claim counts typically indicate broader or more complex inventions.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialValueTier rdf:type rdf:Property ;
    rdfs:label 'Commercial Value Tier' ;
    rdfs:comment 'Internal assessment of the patent\'s commercial importance to the business. Strategic patents protect core technologies or blockbuster products. High-value patents have clear revenue impact. Low-value or exploratory patents may be defensive or speculative.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClass rdf:type rdf:Property ;
    rdfs:label 'Cpc Class' ;
    rdfs:comment 'Primary CPC classification code. CPC is a joint classification system developed by EPO and USPTO, providing more granular technology classification than IPC.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Maintenance Cost' ;
    rdfs:comment 'Projected annual cost to maintain the patent in force, including official fees, agent fees, and translation costs across all jurisdictions. Used for IP portfolio cost-benefit analysis.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardCitationsCount rdf:type rdf:Property ;
    rdfs:label 'Forward Citations Count' ;
    rdfs:comment 'Number of times this patent has been cited by subsequent patent applications. High forward citation count indicates influential or foundational technology.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Assessment of whether the patented technology can be commercialized without infringing third-party patents. Cleared indicates no blocking patents found. Risk identified or blocked indicates potential infringement issues requiring licensing or design-around.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date the patent was officially granted by the patent office. Marks the beginning of enforceable patent rights. Null if patent has not yet been granted.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claims Count' ;
    rdfs:comment 'Number of independent claims in the patent. Independent claims stand alone and define the broadest scope of protection. Typically 1-5 independent claims per patent.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Internal Reference Code' ;
    rdfs:comment 'Company-specific internal tracking code or docket number for the patent filing. Used for cross-referencing with R&D project records and financial systems.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorsList rdf:type rdf:Property ;
    rdfs:label 'Inventors List' ;
    rdfs:comment 'Semicolon-separated list of inventors named on the patent application. Inventors are the individuals who conceived the invention. Format: LastName, FirstName; LastName, FirstName.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Status' ;
    rdfs:comment 'Current legal standing of the granted patent. Active indicates patent is in force and enforceable. Lapsed indicates failure to pay maintenance fees. Revoked or invalidated indicates patent rights have been terminated by legal action.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingStatus rdf:type rdf:Property ;
    rdfs:label 'Licensing Status' ;
    rdfs:comment 'Indicates whether the patent is subject to licensing agreements. Licensed out means the company has granted rights to third parties. Licensed in means the company has acquired rights from others. Cross-licensed indicates mutual licensing with another party.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFeeDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Due Date' ;
    rdfs:comment 'Next scheduled date for payment of patent maintenance or renewal fees to keep the patent in force. Failure to pay results in patent lapse. Applicable only to granted patents in jurisdictions requiring periodic fees.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentAttorneyFirm rdf:type rdf:Property ;
    rdfs:label 'Patent Attorney Firm' ;
    rdfs:comment 'Name of the external law firm or patent agent representing the company for this patent filing. Used for managing outside counsel relationships and costs.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'Official patent number assigned upon grant by the patent office. Null until patent is granted. Used for citation and enforcement purposes.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentTitle rdf:type rdf:Property ;
    rdfs:label 'Patent Title' ;
    rdfs:comment 'Official title of the patent as filed with the patent office. Describes the invention in concise legal language.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentType rdf:type rdf:Property ;
    rdfs:label 'Patent Type' ;
    rdfs:comment 'Classification of the patent by legal type. Utility patents cover functional inventions, design patents cover ornamental designs, composition of matter covers chemical formulations, process covers manufacturing methods, plant covers new plant varieties, and reissue covers corrections to previously granted patents.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Pct Application Flag' ;
    rdfs:comment 'Indicates whether this filing was made under the Patent Cooperation Treaty, which allows a single international application to seek protection in multiple countries simultaneously.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'PCT international application number if this filing was made under PCT. Format: PCT/CC/YYYY/NNNNNN where CC is country code, YYYY is year, NNNNNN is serial number.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIpcClass rdf:type rdf:Property ;
    rdfs:label 'Primary Ipc Class' ;
    rdfs:comment 'Primary IPC classification code assigned to the patent. IPC is a hierarchical system for classifying patents by technology area. Format: Section-Class-Subclass-Group (e.g., A61K-008/00 for cosmetic preparations).' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'Earliest filing date claimed for priority purposes, typically from a provisional application or foreign filing. Used to establish prior art cutoff date.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Current status of the patent application in the prosecution process. Tracks the lifecycle from drafting through grant or abandonment. Office action pending indicates examiner has issued objections requiring response. [ENUM-REF-CANDIDATE: draft|filed|published|under examination|office action pending|allowed|granted|abandoned|expired|withdrawn — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date the patent application was published by the patent office, typically 18 months after filing. Makes the invention publicly disclosed.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryIpcClasses rdf:type rdf:Property ;
    rdfs:label 'Secondary Ipc Classes' ;
    rdfs:comment 'Semicolon-separated list of additional IPC classification codes applicable to the patent. Used when invention spans multiple technology domains.' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDomain rdf:type rdf:Property ;
    rdfs:label 'Technology Domain' ;
    rdfs:comment 'High-level categorization of the patent\'s technology area within consumer goods. Used for portfolio management and strategic IP planning. [ENUM-REF-CANDIDATE: formulation|packaging|manufacturing process|delivery system|ingredient|fragrance|preservation|sustainability|biotechnology — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PatentFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPrototypeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Prototype Id' ;
    rdfs:comment 'Reference to the newer prototype that supersedes this one, if applicable. Used to track prototype evolution and version history.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prototype .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Type of closure mechanism used to seal the primary container. Critical for product integrity, user experience, and safety compliance. [ENUM-REF-CANDIDATE: screw_cap|flip_top|pump_dispenser|spray|dropper|twist_off|press_on|child_resistant — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibilityTestCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Compatibility Test Completion Date' ;
    rdfs:comment 'Date when formulation-packaging compatibility testing was completed.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerTestEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Consumer Test Eligible Flag' ;
    rdfs:comment 'Indicates whether the prototype has been approved for consumer testing based on safety, stability, and quality criteria.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerCapacityMl rdf:type rdf:Property ;
    rdfs:label 'Container Capacity Ml' ;
    rdfs:comment 'Total volumetric capacity of the primary container, measured in milliliters.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Container Diameter Mm' ;
    rdfs:comment 'Diameter dimension of the primary container, measured in millimeters. Applicable to cylindrical containers.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerHeightMm rdf:type rdf:Property ;
    rdfs:label 'Container Height Mm' ;
    rdfs:comment 'Height dimension of the primary container, measured in millimeters.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Container Weight Grams' ;
    rdfs:comment 'Weight of the empty primary container, measured in grams. Used for packaging cost analysis and sustainability metrics.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decorationMethod rdf:type rdf:Property ;
    rdfs:label 'Decoration Method' ;
    rdfs:comment 'Method used to apply branding, graphics, and regulatory information to the packaging. [ENUM-REF-CANDIDATE: screen_print|label|heat_transfer|in_mold_label|embossing|direct_print|sleeve — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedPackagingCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Packaging Cost' ;
    rdfs:comment 'Estimated total cost of the packaging configuration per unit, including all components and decoration. Used for target COGS analysis.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Fill Volume Ml' ;
    rdfs:comment 'Net volume of the product formulation filled into the prototype packaging, measured in milliliters.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillWeight rdf:type rdf:Property ;
    rdfs:label 'Fill Weight' ;
    rdfs:comment 'Net weight of the product formulation filled into the prototype packaging, measured in grams.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formulationCompatibilityTestStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Compatibility Test Status' ;
    rdfs:comment 'Status of compatibility testing between the formulation and packaging materials to ensure no chemical interaction, leaching, or degradation occurs.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generation rdf:type rdf:Property ;
    rdfs:label 'Generation' ;
    rdfs:comment 'Generation or iteration number of the prototype (e.g., P1 for first generation, P2 for second, etc.). Indicates the stage of prototype refinement.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingScale rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Scale' ;
    rdfs:comment 'Scale at which the prototype was manufactured, indicating the production environment and batch size capability.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Packaging Approval Date' ;
    rdfs:comment 'Date when the packaging configuration received R&D approval.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Packaging Approved By' ;
    rdfs:comment 'Name or identifier of the R&D team member who approved the packaging configuration.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration Code' ;
    rdfs:comment 'Unique identifier for the complete packaging configuration used in this prototype, including all components and assembly specifications.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated packaging cost.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerMaterial rdf:type rdf:Property ;
    rdfs:label 'Primary Container Material' ;
    rdfs:comment 'Material composition of the primary container. Critical for compatibility testing, recyclability assessment, and regulatory compliance. [ENUM-REF-CANDIDATE: HDPE|PET|PETG|PP|glass|aluminum|paperboard|biodegradable_plastic|recycled_PET — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerType rdf:type rdf:Property ;
    rdfs:label 'Primary Container Type' ;
    rdfs:comment 'Type of primary packaging component that directly contains the product formulation. [ENUM-REF-CANDIDATE: bottle|jar|tube|pouch|sachet|can|aerosol|pump|stick|compact — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeName rdf:type rdf:Property ;
    rdfs:label 'Prototype Name' ;
    rdfs:comment 'Descriptive name assigned to the prototype for identification and communication purposes.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeStatus rdf:type rdf:Property ;
    rdfs:label 'Prototype Status' ;
    rdfs:comment 'Current lifecycle status of the prototype indicating its approval state and usability for further testing or production.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeType rdf:type rdf:Property ;
    rdfs:label 'Prototype Type' ;
    rdfs:comment 'Classification of the prototype based on its purpose and fidelity level in the development process.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdPackagingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Rd Packaging Approval Status' ;
    rdfs:comment 'Approval status from the R&D team indicating whether the packaging configuration meets technical and functional requirements for the prototype.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclabilityClassification rdf:type rdf:Property ;
    rdfs:label 'Recyclability Classification' ;
    rdfs:comment 'Classification of the packaging recyclability based on material composition and local recycling infrastructure availability. Critical for sustainability reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recycledContentPercent rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percent' ;
    rdfs:comment 'Percentage of recycled material content in the packaging. Used for sustainability metrics and regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Status' ;
    rdfs:comment 'Status of safety assessment and toxicological evaluation for the prototype, ensuring compliance with regulatory requirements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPackagingType rdf:type rdf:Property ;
    rdfs:label 'Secondary Packaging Type' ;
    rdfs:comment 'Type of secondary packaging used to protect and display the primary container at retail.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityTestStatus rdf:type rdf:Property ;
    rdfs:label 'Stability Test Status' ;
    rdfs:comment 'Status of stability testing to assess the prototypes shelf life, performance under various environmental conditions, and formulation integrity over time.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date when this prototype was superseded by a newer version.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainableMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainable Material Flag' ;
    rdfs:comment 'Indicates whether the packaging uses sustainable materials such as recycled content, bio-based plastics, or FSC-certified paperboard.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetLaunchMarket rdf:type rdf:Property ;
    rdfs:label 'Target Launch Market' ;
    rdfs:comment 'Three-letter ISO country code representing the primary geographic market for which this prototype is being developed.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the physical prototype was created or manufactured. Represents the principal business event timestamp for this entity.' ;
    rdfs:domain ind:Prototype ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedConcentrationMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Approved Concentration Max Percent' ;
    rdfs:comment 'Maximum allowable concentration of this raw material in formulations as approved by R&D and regulatory for safety and compliance.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedConcentrationMinPercent rdf:type rdf:Property ;
    rdfs:label 'Approved Concentration Min Percent' ;
    rdfs:comment 'Minimum allowable concentration of this raw material in formulations as approved by R&D for efficacy and safety.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerKg rdf:type rdf:Property ;
    rdfs:label 'Cost Per Kg' ;
    rdfs:comment 'Standard cost of the raw material per kilogram for R&D costing and formulation budget estimation. Used for target COGS calculations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euMaximumConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Eu Maximum Concentration Percent' ;
    rdfs:comment 'Maximum allowable concentration of this raw material in finished products as mandated by EU regulations. Null if no EU restriction applies.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Restricted Flag' ;
    rdfs:comment 'Indicates whether the raw material is subject to restrictions or prohibitions under EU cosmetics regulations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Common or trade name of the raw material as used in R&D documentation and formulation records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'Maximum allowable moisture content expressed as a percentage. Important for stability and shelf life of formulations.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeMicrons rdf:type rdf:Property ;
    rdfs:label 'Particle Size Microns' ;
    rdfs:comment 'Average or target particle size measured in microns. Relevant for powders and solid materials affecting texture and performance.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'Minimum purity level of the active ingredient or material expressed as a percentage. Critical specification parameter for formulation consistency.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Available Flag' ;
    rdfs:comment 'Indicates whether a current Safety Data Sheet is available for this raw material in the document management system.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Expected shelf life of the raw material in months under specified storage conditions before quality degradation.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum storage temperature in degrees Celsius to prevent degradation or safety hazards.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum storage temperature in degrees Celsius required to maintain raw material stability and quality.' ;
    rdfs:domain ind:RawMaterialSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usFdaMaximumConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Us Fda Maximum Concentration Percent' ;
    rdfs:comment 'Maximum allowable concentration of this raw material in finished products as mandated by US FDA regulations. Null if no FDA restriction applies.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usFdaRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Us Fda Restricted Flag' ;
    rdfs:comment 'Indicates whether the raw material is subject to restrictions or prohibitions under US FDA regulations for cosmetics or OTC drugs.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rd Employee Id' ;
    rdfs:comment 'Identifier of the executive or business leader sponsoring this R&D project, linking to the employee or workforce master.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rdManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rd Manager Employee Id' ;
    rdfs:comment 'Identifier of the project manager or R&D lead responsible for day-to-day execution of this project.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date the product was launched commercially, if the project has reached commercialization.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated to this R&D project for all phases, including formulation, testing, regulatory, and scale-up activities.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpent rdf:type rdf:Property ;
    rdfs:label 'Budget Spent' ;
    rdfs:comment 'Cumulative budget spent to date on this R&D project across all cost categories.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessOpportunityContext rdf:type rdf:Property ;
    rdfs:label 'Business Opportunity Context' ;
    rdfs:comment 'Description of the originating business opportunity, market gap, or consumer insight that triggered this R&D project.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmark rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark' ;
    rdfs:comment 'Description of key competitive products or market benchmarks this innovation is designed to compete against or differentiate from.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMilestone rdf:type rdf:Property ;
    rdfs:label 'Current Milestone' ;
    rdfs:comment 'Description of the current stage-gate milestone or deliverable the project team is working toward.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredBenefits rdf:type rdf:Property ;
    rdfs:label 'Desired Benefits' ;
    rdfs:comment 'Key consumer benefits or product claims the innovation aims to deliver (e.g., moisturizing, long-lasting, eco-friendly, allergen-free).' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of key learnings, best practices, and insights captured from this project for future R&D initiatives.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDueDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Due Date' ;
    rdfs:comment 'Target completion date for the current milestone in the project timeline.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Status' ;
    rdfs:comment 'Status of intellectual property protection for this innovation: not applicable, planned, filed, granted, or rejected.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business-assigned alphanumeric code for the R&D project, used for external communication and cross-functional reference.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Project Completion Date' ;
    rdfs:comment 'Date the R&D project was completed, either through successful commercialization or formal closure.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name or title of the R&D project, typically reflecting the innovation brief or product concept.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Date the R&D project was officially initiated and entered the innovation pipeline.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the R&D project: active, on hold, cancelled, completed, or archived.' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the R&D project by innovation category: new product development, reformulation, line extension, cost optimization, packaging innovation, or sustainability initiative.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGatePhase rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Phase' ;
    rdfs:comment 'Current stage-gate phase of the project in the NPD process: ideation, concept, feasibility, development, validation, scale-up, launch, or post-launch review. [ENUM-REF-CANDIDATE: ideation|concept|feasibility|development|validation|scale_up|launch|post_launch — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Quantitative sustainability assessment score for this project, measuring environmental impact, renewable sourcing, and circular economy alignment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDossierId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Dossier Id' ;
    rdfs:comment 'Unique identifier for the regulatory submission dossier record. Primary key for the regulatory dossier entity.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Approval Date' ;
    rdfs:comment 'Actual date when the regulatory authority granted approval for the product. Null if not yet approved.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Actual date when the dossier was submitted to the regulatory authority. Null if not yet submitted.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:additionalInformationDueDate rdf:type rdf:Property ;
    rdfs:label 'Additional Information Due Date' ;
    rdfs:comment 'Deadline date by which additional information requested by the regulatory authority must be submitted to avoid rejection or withdrawal.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:additionalInformationRequested rdf:type rdf:Property ;
    rdfs:label 'Additional Information Requested' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory authority has requested additional information or clarification on the submitted dossier.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenDeclarationComplete rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Complete' ;
    rdfs:comment 'Boolean flag indicating whether all allergen declarations required by the target market regulations have been completed and included in the dossier.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:animalTestingStatement rdf:type rdf:Property ;
    rdfs:label 'Animal Testing Statement' ;
    rdfs:comment 'Declaration regarding animal testing status for the product and ingredients, required for compliance with EU and other market regulations.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Reference Number' ;
    rdfs:comment 'Official reference or tracking number assigned by the regulatory authority upon receipt of the submission.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubstantiationStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Substantiation Status' ;
    rdfs:comment 'Status of the claim substantiation documentation and testing required to support product claims in the regulatory submission.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmrSubstancePresent rdf:type rdf:Property ;
    rdfs:label 'Cmr Substance Present' ;
    rdfs:comment 'Boolean flag indicating whether the formulation contains any CMR (Carcinogenic, Mutagenic, or Reprotoxic) substances that require special regulatory attention.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpnpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cpnp Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the EU CPNP system for cosmetic product notifications. Applicable only for EU submissions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dossier Reference Number' ;
    rdfs:comment 'Business identifier for the regulatory dossier, used for tracking and communication with regulatory authorities and internal stakeholders.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierVersion rdf:type rdf:Property ;
    rdfs:label 'Dossier Version' ;
    rdfs:comment 'Version number or identifier for the dossier document, tracking revisions and updates throughout the preparation and submission process.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Approval Date' ;
    rdfs:comment 'Estimated date for receiving regulatory approval based on standard review timelines and authority guidance.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Status' ;
    rdfs:comment 'Status indicating whether the manufacturing facility and processes meet GMP requirements for the target market.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inciListingComplete rdf:type rdf:Property ;
    rdfs:label 'Inci Listing Complete' ;
    rdfs:comment 'Boolean flag indicating whether the complete INCI ingredient listing has been prepared and verified for regulatory compliance.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intendedUseDescription rdf:type rdf:Property ;
    rdfs:label 'Intended Use Description' ;
    rdfs:comment 'Detailed description of the intended use, application, and consumer benefits of the product as stated in the regulatory submission.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Label Compliance Status' ;
    rdfs:comment 'Status indicating whether the product labeling meets all regulatory requirements for the target market, including INCI listing, warnings, and claims.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nanomaterialPresent rdf:type rdf:Property ;
    rdfs:label 'Nanomaterial Present' ;
    rdfs:comment 'Boolean flag indicating whether the product formulation contains nanomaterials, which require special regulatory notification and safety assessment.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pifDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Pif Document Reference' ;
    rdfs:comment 'Reference identifier for the Product Information File document that contains all supporting documentation for the regulatory submission.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationStartDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Start Date' ;
    rdfs:comment 'Date when the preparation of the regulatory dossier was initiated by the R&D or regulatory affairs team.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preservativeSystemApproved rdf:type rdf:Property ;
    rdfs:label 'Preservative System Approved' ;
    rdfs:comment 'Boolean flag indicating whether the preservative system used in the formulation has been approved for use in the target market.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAffairsContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Affairs Contact Email' ;
    rdfs:comment 'Primary email address for the regulatory affairs contact responsible for this dossier, used for communication with regulatory authorities.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory body or agency to which this dossier is submitted (e.g., FDA, European Commission, Health Canada, NMPA).' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the regulatory authority officially began their review of the submitted dossier.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyAssessorName rdf:type rdf:Property ;
    rdfs:label 'Safety Assessor Name' ;
    rdfs:comment 'Name of the qualified safety assessor who prepared or reviewed the product safety assessment for this dossier.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCategory rdf:type rdf:Property ;
    rdfs:label 'Submission Category' ;
    rdfs:comment 'Category of regulatory submission indicating whether this is a new product, modification, renewal, or other type of regulatory filing.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Target Market Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the primary target market jurisdiction for this regulatory submission.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketRegion rdf:type rdf:Property ;
    rdfs:label 'Target Market Region' ;
    rdfs:comment 'Geographic region or regulatory zone for the submission (e.g., European Union, ASEAN, North America).' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Submission Date' ;
    rdfs:comment 'Planned date for submitting the completed dossier to the regulatory authority, aligned with project milestones and launch timelines.' ;
    rdfs:domain ind:RegulatoryDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchSizeKg rdf:type rdf:Property ;
    rdfs:label 'Batch Size Kg' ;
    rdfs:comment 'Standard production batch size in kilograms for manufacturing scale-up planning. Based on pilot plant or commercial production capacity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimSupportRequired rdf:type rdf:Property ;
    rdfs:label 'Claim Support Required' ;
    rdfs:comment 'Indicates whether the formulation requires clinical or consumer testing to substantiate marketing claims (e.g., anti-aging, moisturizing efficacy).' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerTestScore rdf:type rdf:Property ;
    rdfs:label 'Consumer Test Score' ;
    rdfs:comment 'Average consumer acceptance score from home-use testing or clinical trials. Scale typically 0-10 or 0-100 depending on protocol.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingRateCelsiusPerMin rdf:type rdf:Property ;
    rdfs:label 'Cooling Rate Celsius Per Min' ;
    rdfs:comment 'Controlled cooling rate in degrees Celsius per minute after mixing. Important for emulsion stability and crystal formation control.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costTargetPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Target Per Unit' ;
    rdfs:comment 'Target manufacturing cost per unit for the formulation. Used for feasibility assessment and margin analysis during NPD.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crueltyFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Cruelty Free Flag' ;
    rdfs:comment 'Indicates whether the formulation and its ingredients have not been tested on animals, meeting cruelty-free certification standards.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentStatus rdf:type rdf:Property ;
    rdfs:label 'Development Status' ;
    rdfs:comment 'Current stage of the formulation in the R&D lifecycle. Tracks progression through stage-gate process from ideation to commercialization approval. [ENUM-REF-CANDIDATE: concept|experimental|prototype|pilot|validation|approved|discontinued|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuedDate rdf:type rdf:Property ;
    rdfs:label 'Discontinued Date' ;
    rdfs:comment 'Date when the formulation was discontinued or archived. Null if still active in the development pipeline.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulationDescription rdf:type rdf:Property ;
    rdfs:label 'Formulation Description' ;
    rdfs:comment 'Detailed technical description of the formulation including intended use, key benefits, and distinguishing characteristics. Used for internal documentation and regulatory submissions.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceType rdf:type rdf:Property ;
    rdfs:label 'Fragrance Type' ;
    rdfs:comment 'Classification of fragrance used in the formulation. Important for allergen labeling and consumer preference targeting.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbiologicalChallengeTestPassed rdf:type rdf:Property ;
    rdfs:label 'Microbiological Challenge Test Passed' ;
    rdfs:comment 'Indicates whether the formulation passed preservative efficacy testing (challenge test) demonstrating adequate antimicrobial protection.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixingTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Mixing Temperature Celsius' ;
    rdfs:comment 'Optimal mixing temperature in degrees Celsius for formulation processing. Affects ingredient solubility and stability.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Mixing Time Minutes' ;
    rdfs:comment 'Required mixing duration in minutes to achieve homogeneous formulation. Critical process parameter for manufacturing instructions.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:naturalContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Natural Content Percentage' ;
    rdfs:comment 'Percentage of ingredients derived from natural sources per ISO 16128 standard. Used for natural/organic product claims.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Patent Filed Flag' ;
    rdfs:comment 'Indicates whether a patent application has been filed for this formulation or its novel components.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensoryEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Sensory Evaluation Score' ;
    rdfs:comment 'Composite score from trained panel sensory evaluation assessing appearance, texture, fragrance, and application properties. Scale typically 0-10.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeTargetMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Target Months' ;
    rdfs:comment 'Target shelf life duration in months from manufacturing date. Based on stability testing and regulatory requirements for the product category.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPhMax rdf:type rdf:Property ;
    rdfs:label 'Target Ph Max' ;
    rdfs:comment 'Maximum acceptable pH value for the formulation. Defines upper bound of acceptable pH range for quality control.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhMin rdf:type rdf:Property ;
    rdfs:label 'Target Ph Min' ;
    rdfs:comment 'Minimum acceptable pH value for the formulation. Critical for product stability, efficacy, and skin compatibility.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetViscosityCps rdf:type rdf:Property ;
    rdfs:label 'Target Viscosity Cps' ;
    rdfs:comment 'Target viscosity measurement in centipoise (cps) for the formulation. Critical quality parameter for product consistency and manufacturing processability.' ;
    rdfs:domain ind:ResearchFormulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchFormulationIngredientId rdf:type rdf:Property ;
    rdfs:label 'Research Formulation Ingredient Id' ;
    rdfs:comment 'Unique identifier for each ingredient line within a formulation. Primary key for the formulation bill of materials (BOM) at ingredient level.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionOrder rdf:type rdf:Property ;
    rdfs:label 'Addition Order' ;
    rdfs:comment 'Order in which the ingredient is added within its assigned phase. Critical for process control and product quality.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aseanMaximumConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Asean Maximum Concentration Percent' ;
    rdfs:comment 'Maximum allowable concentration percentage for this ingredient under ASEAN regulations. Null if no ASEAN-specific restriction applies.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aseanRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Asean Restricted Flag' ;
    rdfs:comment 'Indicates whether the ingredient is subject to restrictions or prohibitions under ASEAN cosmetic regulations. True if restricted or prohibited.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionBasis rdf:type rdf:Property ;
    rdfs:label 'Inclusion Basis' ;
    rdfs:comment 'Unit basis for ingredient concentration measurement (w/w = weight/weight, w/v = weight/volume, v/v = volume/volume, ppm = parts per million, ppb = parts per billion). Critical for accurate formulation and manufacturing.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence Number' ;
    rdfs:comment 'Sequential ordering of ingredients within the formulation BOM. Used for manufacturing process order and documentation.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Concentration Percent' ;
    rdfs:comment 'Maximum allowable concentration percentage for the ingredient. Defines upper bound for manufacturing tolerance and regulatory compliance.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Concentration Percent' ;
    rdfs:comment 'Minimum allowable concentration percentage for the ingredient. Defines lower bound for manufacturing tolerance and quality control.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseAssignment rdf:type rdf:Property ;
    rdfs:label 'Phase Assignment' ;
    rdfs:comment 'Manufacturing phase in which the ingredient is added during production (e.g., aqueous phase, oil phase, emulsion phase). Guides manufacturing process execution.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether alternative ingredients may be substituted for this ingredient during manufacturing. True if substitution is permitted.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Target Concentration Percent' ;
    rdfs:comment 'Target concentration percentage of the ingredient in the formulation. Represents the intended formulation specification.' ;
    rdfs:domain ind:ResearchFormulationIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchPackagingSpecId rdf:type rdf:Property ;
    rdfs:label 'Research Packaging Spec Id' ;
    rdfs:comment 'Unique identifier for the R&D packaging specification record. Primary key for this entity.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barrierProperties rdf:type rdf:Property ;
    rdfs:label 'Barrier Properties' ;
    rdfs:comment 'Description of the packaging materials barrier characteristics, including oxygen barrier, moisture barrier, light barrier, or UV protection properties critical for product stability.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityMl rdf:type rdf:Property ;
    rdfs:label 'Capacity Ml' ;
    rdfs:comment 'Nominal fill capacity of the packaging component in milliliters, representing the target product volume for primary containers.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:childResistantCertified rdf:type rdf:Property ;
    rdfs:label 'Child Resistant Certified' ;
    rdfs:comment 'Indicates whether the packaging component has been certified as child-resistant per regulatory requirements for hazardous products.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibilityTestDate rdf:type rdf:Property ;
    rdfs:label 'Compatibility Test Date' ;
    rdfs:comment 'Date when the formulation-packaging compatibility testing was completed or last reviewed.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compatibilityTestResult rdf:type rdf:Property ;
    rdfs:label 'Compatibility Test Result' ;
    rdfs:comment 'Summary of the compatibility test findings, including any observed interactions, leaching, discoloration, or structural changes.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentHeightMm rdf:type rdf:Property ;
    rdfs:label 'Component Height Mm' ;
    rdfs:comment 'Height dimension of the packaging component in millimeters, measured per the specification drawing.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentLengthMm rdf:type rdf:Property ;
    rdfs:label 'Component Length Mm' ;
    rdfs:comment 'Length dimension of the packaging component in millimeters, measured per the specification drawing.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Component Weight Grams' ;
    rdfs:comment 'Weight of the empty packaging component in grams, used for sustainability calculations and shipping cost estimation.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWidthMm rdf:type rdf:Property ;
    rdfs:label 'Component Width Mm' ;
    rdfs:comment 'Width dimension of the packaging component in millimeters, measured per the specification drawing.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euReachCompliant rdf:type rdf:Property ;
    rdfs:label 'Eu Reach Compliant' ;
    rdfs:comment 'Indicates whether the packaging material complies with EU REACH regulation for chemical substance registration and restriction.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaFoodContactApproved rdf:type rdf:Property ;
    rdfs:label 'Fda Food Contact Approved' ;
    rdfs:comment 'Indicates whether the packaging material is approved for direct food contact per FDA regulations.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulationCompatibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Compatibility Status' ;
    rdfs:comment 'Status of compatibility testing between the packaging material and the product formulation, indicating whether the packaging is suitable for the intended product.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGrade rdf:type rdf:Property ;
    rdfs:label 'Material Grade' ;
    rdfs:comment 'Specific grade or quality designation of the material, including food-grade, pharmaceutical-grade, or recycled content specifications.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Prototype Batch Number' ;
    rdfs:comment 'Batch or lot number of the prototype packaging samples produced for evaluation, linking to physical samples in R&D inventory.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Overall regulatory compliance status of the packaging specification against applicable FDA, EU, and regional packaging regulations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCode rdf:type rdf:Property ;
    rdfs:label 'Specification Code' ;
    rdfs:comment 'Unique business identifier for the packaging specification, used for cross-referencing in R&D documentation and prototype builds.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Descriptive name of the packaging specification, typically including component type and material summary.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidentFeature rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Feature' ;
    rdfs:comment 'Indicates whether the packaging includes tamper-evident features such as breakable seals, shrink bands, or induction seals.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Technical Drawing Reference' ;
    rdfs:comment 'Reference identifier or file path to the detailed technical drawing or CAD file for the packaging component.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchStabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Research Stability Study Id' ;
    rdfs:comment 'Unique identifier for the stability study record. Primary key for the research stability study entity.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchStabilityStudy .

ind:chamberCode rdf:type rdf:Property ;
    rdfs:label 'Chamber Code' ;
    rdfs:comment 'Identifier of the stability chamber or environmental room where samples are stored. Used for equipment qualification tracking and data integrity.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStabilityMethod rdf:type rdf:Property ;
    rdfs:label 'Color Stability Method' ;
    rdfs:comment 'Analytical method used to assess color stability. Visual for subjective assessment; colorimeter for L*a*b* values; spectrophotometer for detailed spectral analysis.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichCondition rdf:type rdf:Property ;
    rdfs:label 'Ich Condition' ;
    rdfs:comment 'Standardized storage condition per ICH guidelines. 25°C/60%RH is long-term for temperate climates; 30°C/65%RH for subtropical; 40°C/75%RH for accelerated testing; 5°C for refrigerated; -20°C for frozen; light_exposure for photostability; cycling for freeze-thaw. [ENUM-REF-CANDIDATE: 25C_60RH|30C_65RH|40C_75RH|5C|minus_20C|light_exposure|cycling — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inciIngredientList rdf:type rdf:Property ;
    rdfs:label 'Inci Ingredient List' ;
    rdfs:comment 'Comma-separated list of key active ingredients using INCI nomenclature. Used to assess ingredient stability and degradation pathways.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microbialLimitCfuPerG rdf:type rdf:Property ;
    rdfs:label 'Microbial Limit Cfu Per G' ;
    rdfs:comment 'Maximum acceptable microbial count in colony-forming units per gram as defined in the product specification. Used to evaluate microbiological stability.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallStabilityConclusion rdf:type rdf:Property ;
    rdfs:label 'Overall Stability Conclusion' ;
    rdfs:comment 'Final assessment of product stability based on all time-point data. Stable indicates all parameters within specification; unstable indicates failure; marginally_stable indicates borderline performance; pending for incomplete studies.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phTargetRange rdf:type rdf:Property ;
    rdfs:label 'Ph Target Range' ;
    rdfs:comment 'Acceptable pH range for the formulation as defined in the product specification (e.g., 5.0-6.0). Used to evaluate pH stability over time.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Months' ;
    rdfs:comment 'Total planned duration of the stability study in months. Typical values: 6 months for accelerated, 12-36 months for real-time studies.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Recommended Shelf Life Months' ;
    rdfs:comment 'Shelf life recommendation in months based on stability study results. Derived from trend analysis and specification compliance across time points.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Unique identifier for the final stability study report. Used for document management and regulatory traceability.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleOrientation rdf:type rdf:Property ;
    rdfs:label 'Sample Orientation' ;
    rdfs:comment 'Physical orientation of samples during storage. Inverted orientation tests product contact with closure; horizontal tests side-wall contact; as_marketed mimics consumer storage.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the product specification document or quality standard used to evaluate pass/fail criteria for each test parameter.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Description' ;
    rdfs:comment 'Detailed description of storage conditions including temperature range, humidity range, light exposure, and any special handling requirements beyond standard ICH conditions.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'Date when the final time point was tested and the study was closed. Null for in-progress studies.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyObjective rdf:type rdf:Property ;
    rdfs:label 'Study Objective' ;
    rdfs:comment 'Business purpose and scientific objective of the stability study (e.g., shelf-life determination for new product launch, package compatibility assessment, reformulation validation, regulatory submission support).' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Number' ;
    rdfs:comment 'Unique business identifier for the stability study protocol. Used for regulatory submissions and cross-referencing.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timePointSchedule rdf:type rdf:Property ;
    rdfs:label 'Time Point Schedule' ;
    rdfs:comment 'Planned sampling schedule for the study (e.g., T=0, 1M, 2M, 3M, 6M, 9M, 12M, 18M, 24M). Defines when samples will be pulled and tested.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityTargetRangeCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Target Range Cps' ;
    rdfs:comment 'Acceptable viscosity range in centipoise (cPs) as defined in the product specification. Used to evaluate rheological stability.' ;
    rdfs:domain ind:ResearchStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Id' ;
    rdfs:comment 'Primary key for safety_assessment' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersedesAssessmentSafetyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Assessment Safety Assessment Id' ;
    rdfs:comment 'Reference to the previous safety assessment record that this version supersedes, maintaining audit trail of assessment history.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyAssessment .

ind:applicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Application Frequency' ;
    rdfs:comment 'Recommended frequency of product application (e.g., once daily, twice daily, as needed, weekly).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSite rdf:type rdf:Property ;
    rdfs:label 'Application Site' ;
    rdfs:comment 'Body site(s) where the product is intended to be applied (e.g., face, hands, scalp, body, mucous membranes).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Unique business identifier for the safety assessment, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the safety assessment work commenced.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorQualification rdf:type rdf:Property ;
    rdfs:label 'Assessor Qualification' ;
    rdfs:comment 'Professional qualifications and credentials of the safety assessor (e.g., PhD Toxicology, Registered Pharmacist, Diploma in Pharmaceutical Medicine).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Assessor Registration Number' ;
    rdfs:comment 'Professional registration or license number of the safety assessor, as required by regulatory authorities.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfUse rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Use' ;
    rdfs:comment 'Specific conditions under which the product is deemed safe, including application site, frequency, duration, and target population (e.g., adults only, rinse-off only, not for use on damaged skin).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contraindications rdf:type rdf:Property ;
    rdfs:label 'Contraindications' ;
    rdfs:comment 'Specific conditions or populations for which the product should not be used (e.g., not for use on broken skin, avoid if allergic to fragrance, not suitable for children under 3).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpnpNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Cpnp Notification Required' ;
    rdfs:comment 'Flag indicating whether this assessment supports a product requiring notification in the EU CPNP system.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path or document management system reference where the full safety assessment report is stored (e.g., Veeva Vault document ID).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDuration rdf:type rdf:Property ;
    rdfs:label 'Exposure Duration' ;
    rdfs:comment 'Duration of product contact with skin or mucous membranes (e.g., rinse-off, leave-on, brief contact).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Required' ;
    rdfs:comment 'Flag indicating whether this assessment supports a product requiring FDA registration or notification in the United States.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelWarningsRequired rdf:type rdf:Property ;
    rdfs:label 'Label Warnings Required' ;
    rdfs:comment 'Mandatory label warnings and precautionary statements required based on the safety assessment (e.g., avoid contact with eyes, for external use only, keep out of reach of children).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginOfSafety rdf:type rdf:Property ;
    rdfs:label 'Margin Of Safety' ;
    rdfs:comment 'Calculated margin of safety ratio (NOAEL/SED), indicating the safety buffer between the no observed adverse effect level and systemic exposure dose.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the safety assessment, typically required every 3-5 years or when formulation changes occur.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noaelValue rdf:type rdf:Property ;
    rdfs:label 'Noael Value' ;
    rdfs:comment 'No Observed Adverse Effect Level in mg/kg body weight/day, derived from toxicological studies.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMarketScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Scope' ;
    rdfs:comment 'Geographic markets and regulatory jurisdictions for which this safety assessment is intended (e.g., EU, USA, ASEAN, China, Brazil).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstancesCompliance rdf:type rdf:Property ;
    rdfs:label 'Restricted Substances Compliance' ;
    rdfs:comment 'Flag indicating whether the formulation complies with all restricted substance regulations (EU Annexes II-VI, FDA prohibited ingredients).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstancesFindings rdf:type rdf:Property ;
    rdfs:label 'Restricted Substances Findings' ;
    rdfs:comment 'Details of any restricted substances identified in the formulation and their compliance status with maximum concentration limits.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyConclusion rdf:type rdf:Property ;
    rdfs:label 'Safety Conclusion' ;
    rdfs:comment 'Overall safety conclusion reached by the assessor: safe for intended use, unsafe, conditionally safe (with restrictions), or insufficient data to conclude.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingStudiesSummary rdf:type rdf:Property ;
    rdfs:label 'Supporting Studies Summary' ;
    rdfs:comment 'Summary of key toxicological and clinical studies used to support the safety assessment, including study types and outcomes.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemicExposureEstimate rdf:type rdf:Property ;
    rdfs:label 'Systemic Exposure Estimate' ;
    rdfs:comment 'Estimated systemic exposure dose in mg/kg body weight/day, calculated from dermal absorption and usage patterns.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Intended consumer population for the product (e.g., adults, children over 3 years, infants, pregnant women, general population).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicologicalEndpointsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Toxicological Endpoints Evaluated' ;
    rdfs:comment 'List of toxicological endpoints assessed (e.g., acute toxicity, skin irritation, eye irritation, skin sensitization, repeated dose toxicity, mutagenicity, carcinogenicity, reproductive toxicity).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:undesirableEffectsReported rdf:type rdf:Property ;
    rdfs:label 'Undesirable Effects Reported' ;
    rdfs:comment 'Description of any undesirable effects observed in toxicological studies or post-market surveillance that are relevant to the safety assessment.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpTrialId rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Id' ;
    rdfs:comment 'Unique identifier for the manufacturing scale-up trial record. Primary key for the scale-up trial entity.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryScaleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Scale Employee Id' ;
    rdfs:comment 'Reference to the manufacturing manager or technical authority who signed off on the scale-up trial and manufacturing readiness.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualOutputKg rdf:type rdf:Property ;
    rdfs:label 'Actual Output Kg' ;
    rdfs:comment 'Actual quantity of finished product produced during the scale-up trial measured in kilograms.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appearanceAssessment rdf:type rdf:Property ;
    rdfs:label 'Appearance Assessment' ;
    rdfs:comment 'Visual evaluation of product appearance including texture, homogeneity, and any defects observed during the trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorMeasurement rdf:type rdf:Property ;
    rdfs:label 'Color Measurement' ;
    rdfs:comment 'Objective color measurement of the scaled-up batch using colorimetry or visual assessment against standard.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any process deviations, non-conformances, or unexpected observations during the scale-up trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Deviation Impact Assessment' ;
    rdfs:comment 'Assessment of the impact of observed deviations on product quality, safety, and manufacturing readiness.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Observed Flag' ;
    rdfs:comment 'Boolean indicator of whether any process deviations from the standard manufacturing procedure were observed during the trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentConfiguration rdf:type rdf:Property ;
    rdfs:label 'Equipment Configuration' ;
    rdfs:comment 'Description of the manufacturing equipment setup used during the trial, including mixer type, vessel capacity, and auxiliary equipment.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heatingRateCelsiusPerMin rdf:type rdf:Property ;
    rdfs:label 'Heating Rate Celsius Per Min' ;
    rdfs:comment 'Rate at which the batch was heated during processing, important for thermal-sensitive formulations.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inProcessTestResults rdf:type rdf:Property ;
    rdfs:label 'In Process Test Results' ;
    rdfs:comment 'Summary of all in-process quality control tests performed during the scale-up trial, including pass/fail status for each checkpoint.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Readiness Level' ;
    rdfs:comment 'Assessment of manufacturing readiness for commercial production based on trial outcomes and technology transfer completion.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Sign Off Date' ;
    rdfs:comment 'Date when manufacturing operations formally approved the scale-up trial results and confirmed readiness for commercial production.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mixingSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Mixing Speed Rpm' ;
    rdfs:comment 'Rotational speed of the mixing equipment during the trial, critical process parameter for scale-up consistency.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextSteps rdf:type rdf:Property ;
    rdfs:label 'Next Steps' ;
    rdfs:comment 'Documented next actions required following the scale-up trial, such as additional trials, process optimization, or commercial launch preparation.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odorAssessment rdf:type rdf:Property ;
    rdfs:label 'Odor Assessment' ;
    rdfs:comment 'Sensory evaluation of the product fragrance and odor profile compared to bench-scale formulation.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderOfAddition rdf:type rdf:Property ;
    rdfs:label 'Order Of Addition' ;
    rdfs:comment 'Documented sequence in which raw materials and ingredients were added during the manufacturing process, critical for formulation reproducibility.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailRationale rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Rationale' ;
    rdfs:comment 'Detailed justification for the trial status decision, including quality assessment, process performance, and readiness for commercial production.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Celsius' ;
    rdfs:comment 'Target processing temperature maintained during the scale-up trial, critical for formulation stability and quality.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitySignOffDate rdf:type rdf:Property ;
    rdfs:label 'Quality Sign Off Date' ;
    rdfs:comment 'Date when quality assurance formally approved the scale-up trial results and confirmed product quality meets specifications.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scaleFactor rdf:type rdf:Property ;
    rdfs:label 'Scale Factor' ;
    rdfs:comment 'Multiplication factor representing the scale-up ratio from bench scale to pilot or commercial scale (e.g., 10x, 100x, 1000x).' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyTransferChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Checklist Status' ;
    rdfs:comment 'Completion status of the formal technology transfer checklist documenting all required activities and sign-offs.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCode rdf:type rdf:Property ;
    rdfs:label 'Trial Code' ;
    rdfs:comment 'Business identifier code assigned to the scale-up trial for external reference and tracking across R&D and manufacturing systems.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Trial Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the scale-up trial including raw materials, labor, equipment time, and testing.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDate rdf:type rdf:Property ;
    rdfs:label 'Trial Date' ;
    rdfs:comment 'The date on which the scale-up trial was conducted at the manufacturing facility.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Status' ;
    rdfs:comment 'Overall outcome status of the scale-up trial: pass (successful), fail (unsuccessful), conditional_pass (passed with minor issues), in_progress (ongoing), or cancelled.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialType rdf:type rdf:Property ;
    rdfs:label 'Trial Type' ;
    rdfs:comment 'Classification of the scale-up trial based on production scale: pilot (small-scale test), semi-commercial (intermediate scale), commercial (full production scale), or validation (qualification run).' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityCps rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cps' ;
    rdfs:comment 'Measured viscosity of the scaled-up batch, key quality attribute for product consistency and consumer experience.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensoryEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Sensory Evaluation Id' ;
    rdfs:comment 'Unique identifier for the sensory evaluation record. Primary key.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelSessionId rdf:type rdf:Property ;
    rdfs:label 'Panel Session Id' ;
    rdfs:comment 'Identifier for the specific panel session, used to group multiple evaluations conducted in the same session.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PanelSession .

ind:primarySensoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sensory Employee Id' ;
    rdfs:comment 'Identifier of the sensory scientist or lead evaluator responsible for conducting and overseeing the evaluation session.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:afterFeelScore rdf:type rdf:Property ;
    rdfs:label 'After Feel Score' ;
    rdfs:comment 'Numerical score for the after-feel attribute, measuring the sensation after product use (e.g., moisturization, residue, stickiness).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributesAssessed rdf:type rdf:Property ;
    rdfs:label 'Attributes Assessed' ;
    rdfs:comment 'Comma-separated list of sensory attributes evaluated during the session (e.g., color, odor, texture, spreadability, rinse-off feel, after-feel, viscosity, foam quality, fragrance intensity).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkProductCode rdf:type rdf:Property ;
    rdfs:label 'Benchmark Product Code' ;
    rdfs:comment 'Code identifying the benchmark or competitive product used for comparison in the evaluation, if applicable.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMethod rdf:type rdf:Property ;
    rdfs:label 'Blinding Method' ;
    rdfs:comment 'Method used to prevent bias: single-blind (panelists do not know product identity), double-blind (neither panelists nor administrators know), or open-label (product identity known).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorScore rdf:type rdf:Property ;
    rdfs:label 'Color Score' ;
    rdfs:comment 'Numerical score for the color attribute, typically on a scale defined by the evaluation methodology (e.g., 1-9 scale).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the sensory evaluation session was completed and results finalized.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Quality score assessing the reliability and validity of the evaluation data, based on factors such as panelist consistency, response completeness, and adherence to protocol.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCode rdf:type rdf:Property ;
    rdfs:label 'Evaluation Code' ;
    rdfs:comment 'Unique business identifier for the sensory evaluation session, typically formatted as SE-NNNNNN.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationMethodology rdf:type rdf:Property ;
    rdfs:label 'Evaluation Methodology' ;
    rdfs:comment 'Sensory testing methodology used: QDA (Quantitative Descriptive Analysis), hedonic scale (liking/preference), JAR scale (Just About Right), duo-trio test, triangle test, ranking, or descriptive analysis. [ENUM-REF-CANDIDATE: qda|hedonic_scale|jar_scale|duo_trio|triangle_test|ranking|descriptive_analysis|paired_comparison|acceptance_test|discrimination_test — promote to reference product]' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes capturing qualitative observations, panelist comments, unexpected findings, or contextual information from the evaluation session.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current status of the sensory evaluation: scheduled (planned but not started), in progress (currently being conducted), completed (finished and results recorded), cancelled (not conducted), or on hold (temporarily paused).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odorScore rdf:type rdf:Property ;
    rdfs:label 'Odor Score' ;
    rdfs:comment 'Numerical score for the odor/fragrance attribute.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallLikingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Liking Score' ;
    rdfs:comment 'Overall hedonic score representing panelists\' overall liking or preference for the product sample.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Type of sensory panel used for the evaluation: trained expert panel (highly trained sensory experts), consumer panel (target consumers), QC panel (quality control team), internal panel (company employees), or external panel (third-party evaluators).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelistCount rdf:type rdf:Property ;
    rdfs:label 'Panelist Count' ;
    rdfs:comment 'Number of panelists who participated in this sensory evaluation session.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSampleCode rdf:type rdf:Property ;
    rdfs:label 'Product Sample Code' ;
    rdfs:comment 'Unique code identifying the product prototype or formulation sample being evaluated. May be blinded to prevent bias.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinseOffFeelScore rdf:type rdf:Property ;
    rdfs:label 'Rinse Off Feel Score' ;
    rdfs:comment 'Numerical score for the rinse-off feel attribute, relevant for products that are washed off (e.g., shampoos, body washes).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensoryProfileOutcome rdf:type rdf:Property ;
    rdfs:label 'Sensory Profile Outcome' ;
    rdfs:comment 'Overall outcome classification of the sensory evaluation: acceptable (meets standards), unacceptable (fails standards), needs improvement (requires reformulation), exceeds expectations (superior performance), or benchmark equivalent (matches competitive standard).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadabilityScore rdf:type rdf:Property ;
    rdfs:label 'Spreadability Score' ;
    rdfs:comment 'Numerical score for the spreadability attribute, measuring ease of application.' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalSignificance rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance' ;
    rdfs:comment 'Indication of whether the evaluation results are statistically significant based on predefined confidence levels (e.g., p<0.05).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testConditions rdf:type rdf:Property ;
    rdfs:label 'Test Conditions' ;
    rdfs:comment 'Description of environmental and procedural conditions under which the evaluation was conducted (e.g., temperature, lighting, sample presentation order).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textureScore rdf:type rdf:Property ;
    rdfs:label 'Texture Score' ;
    rdfs:comment 'Numerical score for the texture attribute (e.g., smoothness, creaminess, grittiness).' ;
    rdfs:domain ind:SensoryEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stabilityTimepointId rdf:type rdf:Property ;
    rdfs:label 'Stability Timepoint Id' ;
    rdfs:comment 'Unique identifier for the stability timepoint measurement record.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStabilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stability Employee Id' ;
    rdfs:comment 'The unique identifier of the laboratory analyst or technician who performed this measurement. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataIntegrityHash rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Hash' ;
    rdfs:comment 'A cryptographic hash or checksum of the measurement record to ensure data integrity and detect unauthorized modifications. Supports 21 CFR Part 11 compliance for electronic records.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this measurement result triggered a deviation or out-of-specification (OOS) event requiring investigation.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Reference Number' ;
    rdfs:comment 'The unique identifier of the deviation or OOS investigation record if this measurement triggered a quality event. Null if no deviation occurred.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'The current lifecycle status of this timepoint measurement record (draft, pending review, approved, rejected, archived). Governs workflow and data release.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestReason rdf:type rdf:Property ;
    rdfs:label 'Retest Reason' ;
    rdfs:comment 'The documented justification or root cause for performing a retest of this measurement (e.g., instrument malfunction, analyst error, out-of-specification result requiring confirmation).' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodCode rdf:type rdf:Property ;
    rdfs:label 'Test Method Code' ;
    rdfs:comment 'The standardized code or identifier of the analytical method or procedure used to perform this measurement (e.g., USP method, ASTM standard, internal SOP number).' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodVersion rdf:type rdf:Property ;
    rdfs:label 'Test Method Version' ;
    rdfs:comment 'The version or revision number of the test method used, ensuring traceability and compliance with the correct procedure at the time of testing.' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timepointInterval rdf:type rdf:Property ;
    rdfs:label 'Timepoint Interval' ;
    rdfs:comment 'The scheduled time interval at which this measurement was taken within the stability study lifecycle (e.g., T=0 for initial, T=1M for one month, T=3M for three months, T=6M for six months, T=12M for twelve months, T=24M for twenty-four months). [ENUM-REF-CANDIDATE: T=0|T=1W|T=2W|T=1M|T=2M|T=3M|T=6M|T=9M|T=12M|T=18M|T=24M|T=36M — promote to reference product]' ;
    rdfs:domain ind:StabilityTimepoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageGateMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Milestone Id' ;
    rdfs:comment 'Unique identifier for the stage gate milestone record. Primary key.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stage Employee Id' ;
    rdfs:comment 'Identifier of the executive or senior leader responsible for chairing the gate review and making the final gate decision.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryStageModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Stage Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who last modified this stage gate milestone record, used for audit and accountability purposes.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Summary of key action items, conditions, and follow-up tasks assigned during the gate review that must be completed before proceeding or for the next gate.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerAcceptanceScore rdf:type rdf:Property ;
    rdfs:label 'Consumer Acceptance Score' ;
    rdfs:comment 'Quantitative score from consumer testing and sensory evaluation reflecting target consumer acceptance, purchase intent, and preference versus competitive products.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Detailed explanation of the business reasoning, risk assessment, and strategic considerations that led to the gate decision outcome.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Explanation of the root cause for any delay in the gate review milestone, such as incomplete deliverables, resource constraints, technical challenges, or regulatory issues.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverables Checklist Status' ;
    rdfs:comment 'Overall completion status of the mandatory deliverables checklist required for this gate. Complete indicates all deliverables met, incomplete indicates gaps, partial indicates some deliverables met.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Deliverables Completion Percentage' ;
    rdfs:comment 'Percentage of mandatory gate deliverables that have been completed and approved at the time of review, expressed as a value between 0.00 and 100.00.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateAttendees rdf:type rdf:Property ;
    rdfs:label 'Gate Attendees' ;
    rdfs:comment 'Comma-separated list of names or identifiers of executives and stakeholders who attended the gate review meeting.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteriaMetCount rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Met Count' ;
    rdfs:comment 'Number of mandatory gate criteria that were successfully met and approved during the review process.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateCriteriaTotalCount rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria Total Count' ;
    rdfs:comment 'Total number of mandatory gate criteria defined for this stage gate review, used to calculate criteria fulfillment rate.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateDecision rdf:type rdf:Property ;
    rdfs:label 'Gate Decision' ;
    rdfs:comment 'The formal decision outcome of the stage gate review. Go indicates approval to proceed to next stage, kill terminates the project, hold pauses for additional information, recycle returns to previous stage for rework.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDurationDays rdf:type rdf:Property ;
    rdfs:label 'Gate Duration Days' ;
    rdfs:comment 'Number of calendar days between the previous gate review date and this gate review date, used to track stage cycle time and NPD velocity.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateName rdf:type rdf:Property ;
    rdfs:label 'Gate Name' ;
    rdfs:comment 'Descriptive name of the stage gate milestone (e.g., Concept Review, Business Case Approval, Launch Readiness).' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateNumber rdf:type rdf:Property ;
    rdfs:label 'Gate Number' ;
    rdfs:comment 'The formal stage gate identifier in the NPD (New Product Development) process. G0 represents concept ideation, G1 scoping, G2 business case, G3 development, G4 testing and validation, G5 launch.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Status' ;
    rdfs:comment 'Current lifecycle status of the stage gate milestone. Scheduled indicates future gate, in_review indicates active review in progress, completed indicates decision made, cancelled indicates gate no longer required.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Investment Approved Amount' ;
    rdfs:comment 'The financial investment amount approved by the gate review committee to fund activities in the next stage of the project, expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Investment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved investment amount.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestoneDelayed rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Delayed' ;
    rdfs:comment 'Boolean flag indicating whether this gate milestone was delayed beyond its originally scheduled review date. True indicates delay occurred, False indicates on-time or early completion.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketAttractivenessScore rdf:type rdf:Property ;
    rdfs:label 'Market Attractiveness Score' ;
    rdfs:comment 'Quantitative score reflecting the commercial attractiveness of the target market, considering market size, growth rate, competitive intensity, and strategic fit.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextGateTargetDate rdf:type rdf:Property ;
    rdfs:label 'Next Gate Target Date' ;
    rdfs:comment 'The planned target date for the next stage gate review milestone in the project lifecycle, used for forward planning and resource allocation.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npvEstimate rdf:type rdf:Property ;
    rdfs:label 'Npv Estimate' ;
    rdfs:comment 'The estimated net present value of the project calculated at this gate, used for portfolio prioritization and go/kill decision making.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roiEstimatePercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Estimate Percentage' ;
    rdfs:comment 'The estimated return on investment percentage for the project at this gate, calculated as expected return divided by investment cost.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Review Date' ;
    rdfs:comment 'The originally planned date for the stage gate review, used to track schedule adherence and milestone slippage.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalFeasibilityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Score' ;
    rdfs:comment 'Quantitative score assessing the technical feasibility of the project, considering R&D capability, technology maturity, formulation complexity, and manufacturing readiness.' ;
    rdfs:domain ind:StageGateMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activitiesCompleted rdf:type rdf:Property ;
    rdfs:label 'Activities Completed' ;
    rdfs:comment 'Summary of activities performed during the store visit, such as shelf audits, order placement, merchandising, training, or promotional setup. Free-text field capturing execution details.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The calendar date on which the store visit occurred. Used for daily sales activity tracking and field sales Key Performance Indicator (KPI) reporting.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Call Duration Minutes' ;
    rdfs:comment 'Total time spent at the store location in minutes. Key metric for field sales productivity analysis and route optimization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative completed the store visit. Used to calculate call duration and productivity metrics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNotes rdf:type rdf:Property ;
    rdfs:label 'Call Notes' ;
    rdfs:comment 'Additional free-text notes and observations captured by the sales representative during the store visit. Provides qualitative context for the call record.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Business identifier for the account call, typically generated by the Sales Force Automation (SFA) system. Used for external reference and tracking.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjective rdf:type rdf:Property ;
    rdfs:label 'Call Objective' ;
    rdfs:comment 'Primary business objective or goal for the store visit. Free-text description of what the sales representative intended to accomplish during the call.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOutcome rdf:type rdf:Property ;
    rdfs:label 'Call Outcome' ;
    rdfs:comment 'Overall outcome assessment of the store visit. Indicates whether call objectives were achieved and execution was successful.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative began the store visit. Captured via mobile Sales Force Automation (SFA) application for time-in-store analytics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the account call. Tracks progression from scheduled visit through completion or cancellation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the account call purpose. Distinguishes between routine visits, promotional activities, merchandising support, compliance audits, New Product Development (NPD) launches, and issue resolution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorActivityObserved rdf:type rdf:Property ;
    rdfs:label 'Competitor Activity Observed' ;
    rdfs:comment 'Free-text notes on competitor promotional activities, new product launches, pricing changes, or merchandising observed during the store visit. Competitive intelligence capture.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Pricing Flag' ;
    rdfs:comment 'Indicates whether competitor pricing information was collected during the store visit. Used to trigger pricing analysis and response.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completed Flag' ;
    rdfs:comment 'Indicates whether identified corrective actions were completed during the same store visit. Tracks immediate issue resolution effectiveness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of corrective actions identified during the visit, such as restocking Out of Stock (OOS) items, fixing Planogram (POG) violations, or addressing pricing discrepancies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingsActual rdf:type rdf:Property ;
    rdfs:label 'Facings Actual' ;
    rdfs:comment 'Actual number of product facings observed during the store visit. Used to calculate facing compliance and identify shelf space gaps.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facingsRequired rdf:type rdf:Property ;
    rdfs:label 'Facings Required' ;
    rdfs:comment 'Total number of product facings specified in the Planogram (POG) for this store. Represents the target shelf presence.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Code' ;
    rdfs:comment 'Identifier of the mobile device used to capture the account call record. Used for Sales Force Automation (SFA) system audit and device management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Call Date' ;
    rdfs:comment 'Scheduled date for the next store visit. Used for call frequency planning and route optimization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosItemsCount rdf:type rdf:Property ;
    rdfs:label 'Oos Items Count' ;
    rdfs:comment 'Number of Stock Keeping Units (SKUs) found to be Out of Stock (OOS) during the store visit. Key metric for On Shelf Availability (OSA) tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosItemsList rdf:type rdf:Property ;
    rdfs:label 'Oos Items List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes or product names that were Out of Stock (OOS) during the visit. Used for replenishment prioritization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photos captured during the store visit via mobile Sales Force Automation (SFA) application. Used for visual compliance verification and audit trails.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoStorageReference rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Reference' ;
    rdfs:comment 'Reference identifier or Uniform Resource Locator (URL) to the location where call photos are stored. Links to external document management or cloud storage system.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Score' ;
    rdfs:comment 'Overall compliance score for Planogram (POG) execution at the store, typically expressed as a percentage. Measures how well the actual shelf layout matches the planned POG.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPositionCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Position Compliant Flag' ;
    rdfs:comment 'Indicates whether products are placed in the correct shelf position as specified in the Planogram (POG). Critical for optimal product visibility and sales.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a digital signature was captured from the store contact to confirm the visit and any agreements made. Used for audit and compliance purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeContactName rdf:type rdf:Property ;
    rdfs:label 'Store Contact Name' ;
    rdfs:comment 'Name of the store manager or key contact person met during the visit. Used for relationship tracking and follow-up coordination.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Synchronization status of the call record between the mobile Sales Force Automation (SFA) application and the central system. Tracks data integration completeness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPointId rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Id' ;
    rdfs:comment 'Unique identifier for the distribution point record. Primary key.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:energyConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Id' ;
    rdfs:comment 'Foreign key linking to sustainability.energy_consumption. Business justification: Energy consumption of distribution points is tracked for sustainability KPIs and must be linked to the distribution point entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyConsumption .

ind:acvPercentage rdf:type rdf:Property ;
    rdfs:label 'Acv Percentage' ;
    rdfs:comment 'The ACV percentage contribution of this retail location to the total category volume, used for weighted distribution metrics.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvWeightedFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Weighted Flag' ;
    rdfs:comment 'Indicates whether this distribution point is included in ACV-weighted distribution calculations (True/False). ACV-weighted stores represent a significant portion of category sales volume.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionSource rdf:type rdf:Property ;
    rdfs:label 'Distribution Source' ;
    rdfs:comment 'Source system or method used to confirm distribution at this point (sell-in confirmed from ERP, POS verified from transaction data, syndicated data from Nielsen/IRI, field audit from sales force, retailer feed from EDI).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the SKU at this distribution point. Active indicates the product is currently distributed and available for sale; authorized indicates approval but not yet active; delisted indicates removal from distribution; inactive indicates temporary suspension.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Verification Date' ;
    rdfs:comment 'Date when the distribution status was last verified or confirmed through the distribution source.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'SAP division code representing the product line or business unit for this distribution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Number of product facings (front-facing units) allocated to this SKU on the retail shelf at this location.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPosSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Pos Sale Date' ;
    rdfs:comment 'Most recent date when a POS transaction was recorded for this SKU at this location, used to verify active distribution.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'Manufacturer suggested retail price for this SKU at this distribution point.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newProductFlag rdf:type rdf:Property ;
    rdfs:label 'New Product Flag' ;
    rdfs:comment 'Indicates whether this distribution point represents a new product introduction (True/False). Used for NPD distribution tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osaStatus rdf:type rdf:Property ;
    rdfs:label 'Osa Status' ;
    rdfs:comment 'Current on-shelf availability status of the SKU at this location, indicating whether the product is physically available for purchase.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramSlotReference rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Reference' ;
    rdfs:comment 'Reference to the planogram slot or shelf position where this SKU is merchandised at the store.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Flag' ;
    rdfs:comment 'Indicates whether the SKU placement at this location is compliant with the authorized planogram (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rspPrice rdf:type rdf:Property ;
    rdfs:label 'Rsp Price' ;
    rdfs:comment 'Manufacturer recommended selling price for this SKU at this distribution point.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Vertical and horizontal shelf position classification for the SKU at this location (eye level, top shelf, middle shelf, bottom shelf, end cap, promotional display).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCountFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Count Flag' ;
    rdfs:comment 'Indicates whether this distribution point is counted in TDP metrics (True/False). Used to calculate numeric distribution reach.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmiFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Flag' ;
    rdfs:comment 'Indicates whether this distribution point operates under a Vendor Managed Inventory agreement (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.pricing_agreement. Business justification: Invoice billing often follows a pricing agreement; linking provides traceability.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for period-based billing and revenue allocation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for subscription, service, or recurring billing scenarios.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of the invoice document type: standard invoice for goods/services, credit memo for returns/adjustments, debit memo for additional charges, proforma for advance notice, intercompany for internal transfers, or consignment for stock-based billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Total standard cost of all products billed on this invoice. Used for gross margin calculation and profitability analysis at invoice level.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Number of days between invoice date and payment date (or current date if unpaid). Key metric for working capital management and customer payment behavior analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ediDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Document Number' ;
    rdfs:comment 'Unique EDI transaction control number assigned when invoice is transmitted via EDI 810. Used for EDI audit trail and error resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI 810 invoice transmission to customer\'s system. Tracks electronic invoice delivery for large retail and distributor accounts.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross profit on this invoice, calculated as net_amount minus cost_of_goods_sold_amount. Key profitability metric for customer and product analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for aging analysis and collections prioritization.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received against this invoice across all payment transactions. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification determining how revenue from this invoice is recognized per accounting standards (ASC 606 / IFRS 15). Drives financial reporting and revenue allocation logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative (field sales, key account manager, or territory manager) responsible for managing this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:competitiveDisplacementContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement Context' ;
    rdfs:comment 'Description of competitive dynamics: which competitor\'s product(s) this opportunity aims to displace, or whether this is a net-new distribution gain without displacement. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAcvGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Acv Gain' ;
    rdfs:comment 'Projected gain in ACV (All Commodity Volume) if this opportunity closes successfully. ACV measures the total retail sales volume of stores carrying the product.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected incremental annual revenue from this opportunity if closed-won, in the base currency. Used for pipeline value calculation and sales forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Sku Count' ;
    rdfs:comment 'Number of SKUs (Stock Keeping Units) expected to be authorized or listed if this opportunity closes successfully. Used for distribution point forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTdpGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Tdp Gain' ;
    rdfs:comment 'Projected gain in TDP (Total Distribution Points) if this opportunity closes successfully. TDP measures the number of stores carrying the product weighted by store importance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity will reach closed-won or closed-lost stage. Used for sales pipeline forecasting and quota planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category for pipeline management: pipeline (early stage, low confidence), best_case (possible upside), commit (high confidence, included in quota forecast), or closed (deal finalized).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft-delete flag indicating whether this opportunity record has been logically deleted. True if deleted, False if active. Used for audit trail and data retention compliance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jbpAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Jbp Alignment Flag' ;
    rdfs:comment 'Indicates whether this opportunity is aligned with a formal JBP (Joint Business Planning) agreement with the retailer or distributor. True if aligned, False otherwise.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin of the opportunity: inbound inquiry from retailer, field sales prospecting, trade show contact, referral, marketing campaign, or expansion within existing account.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-lost: price (not competitive), product fit (product did not meet needs), competitive loss (lost to competitor), timing (wrong time for buyer), budget constraints, no decision made, or other. Null if not closed-lost. [ENUM-REF-CANDIDATE: price|product_fit|competitive_loss|timing|budget_constraints|no_decision|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDescription rdf:type rdf:Property ;
    rdfs:label 'Next Step Description' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity (e.g., \'Schedule buyer meeting\', \'Submit pricing proposal\', \'Finalize contract terms\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name describing the opportunity (e.g., \'Q2 2024 SKU Authorization - Retailer X\', \'New DTC Channel Launch - Product Line Y\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by business objective: new retail account acquisition, SKU (Stock Keeping Unit) authorization/listing expansion, new channel entry (e.g., e-commerce, DSD), distribution gain with retailer/distributor, shelf space expansion, or promotional program. [ENUM-REF-CANDIDATE: new_account_acquisition|sku_authorization|sku_listing_expansion|channel_entry|distribution_gain|shelf_space_expansion|promotional_program — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Product Category Focus' ;
    rdfs:comment 'Primary product category or brand family targeted by this opportunity (e.g., \'Personal Care - Skincare\', \'Household Cleaning\', \'Health & Wellness\'). Free-text field for flexibility.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales opportunity lifecycle: prospecting (initial contact), qualification (fit assessment), needs analysis (requirements gathering), proposal (offer submitted), negotiation (terms discussion), closed-won (deal secured), or closed-lost (deal not secured). [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReason rdf:type rdf:Property ;
    rdfs:label 'Win Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-won: price advantage, product quality, brand strength, relationship with buyer, innovation/differentiation, service level, or other. Null if not closed-won. [ENUM-REF-CANDIDATE: price|product_quality|brand_strength|relationship|innovation|service_level|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of goods sold for all items on this order. Used for gross margin calculation and profitability analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The system or channel through which the order was originally captured. Used for channel attribution and system integration tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'The sales office or branch that originated this order. Used for territory management and sales force performance tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Document Number' ;
    rdfs:comment 'The native SAP SD sales order document number. Used for system-to-system integration and ERP traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceId rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Id' ;
    rdfs:comment 'Primary key for planogram_compliance' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Reference to the sales representative or merchandiser who conducted the planogram compliance audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFacingsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Facings Count' ;
    rdfs:comment 'The actual number of product facings observed during the audit for the audited category or SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Minutes' ;
    rdfs:comment 'The total time spent conducting the planogram compliance audit, measured in minutes.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'The precise date and time when the planogram compliance audit was conducted, including time zone information.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceTrend rdf:type rdf:Property ;
    rdfs:label 'Compliance Trend' ;
    rdfs:comment 'Indicates the trend in planogram compliance for this account compared to previous audits (improving, stable, declining).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPriority rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Priority' ;
    rdfs:comment 'The priority level assigned to the corrective action based on business impact and urgency (critical, high, medium, low).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Score' ;
    rdfs:comment 'Overall compliance score for the planogram audit, typically expressed as a percentage (0.00 to 100.00) indicating adherence to the planogram specifications.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facingsVariance rdf:type rdf:Property ;
    rdfs:label 'Facings Variance' ;
    rdfs:comment 'The difference between required and actual facings count (actual minus required), indicating over- or under-representation on shelf.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosSkuList rdf:type rdf:Property ;
    rdfs:label 'Oos Sku List' ;
    rdfs:comment 'Comma-separated list of SKU (Stock Keeping Unit) codes that were identified as out of stock during the audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Osa Compliance Flag' ;
    rdfs:comment 'Indicates whether the audit met the minimum On Shelf Availability (OSA) threshold for the category (True = compliant, False = non-compliant).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'The number of photos captured during the planogram compliance audit for documentation and evidence purposes.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Reference identifier or URI to photographic evidence captured during the audit, stored in the document management system.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Pog Effective Date' ;
    rdfs:comment 'The date from which the audited planogram version became effective at the retail location.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pogVersionCode rdf:type rdf:Property ;
    rdfs:label 'Pog Version Code' ;
    rdfs:comment 'The version identifier of the planogram being audited against, indicating the specific layout and merchandising plan.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAuditScore rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Score' ;
    rdfs:comment 'The display compliance score from the most recent previous audit for comparison and trend analysis.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredFacingsCount rdf:type rdf:Property ;
    rdfs:label 'Required Facings Count' ;
    rdfs:comment 'The number of product facings (shelf positions) required by the planogram for the audited category or SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLevel rdf:type rdf:Property ;
    rdfs:label 'Shelf Level' ;
    rdfs:comment 'The vertical shelf position where the product is placed (eye level, top shelf, middle shelf, bottom shelf, end cap).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeManagerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Store Manager Notified Flag' ;
    rdfs:comment 'Indicates whether the store manager was notified of the planogram compliance findings during or after the audit (True = notified, False = not notified).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unauthorizedSkuList rdf:type rdf:Property ;
    rdfs:label 'Unauthorized Sku List' ;
    rdfs:comment 'Comma-separated list of unauthorized SKU (Stock Keeping Unit) codes found on the shelf that are not part of the approved planogram.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unauthorizedSubstitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Unauthorized Substitution Flag' ;
    rdfs:comment 'Indicates whether unauthorized product substitutions were found in place of the planogram-specified SKUs (Stock Keeping Units) (True = substitutions found, False = no substitutions).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Unique identifier for the point-of-sale transaction record. Primary key for the POS transaction entity.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cashier Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: POS transactions record the cashier employee for labor tracking, shift reporting, and audit of sales.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acvFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Flag' ;
    rdfs:comment 'Indicates whether this store is included in the All Commodity Volume (ACV) universe for weighted distribution calculations. Used for Total Distribution Points (TDP) and ACV metrics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineSalesFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Sales Flag' ;
    rdfs:comment 'Indicates whether the transaction represents baseline (non-promotional) sales. Used to separate baseline from incremental promotional volume in Trade Promotion Management (TPM) analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceFileCode rdf:type rdf:Property ;
    rdfs:label 'Data Source File Code' ;
    rdfs:comment 'The identifier of the source data file or feed from which this transaction record was extracted. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedRetailValue rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Value' ;
    rdfs:comment 'The total retail sales value for this transaction line (units sold multiplied by retail selling price). Core metric for revenue and market share analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfStockFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Stock Flag' ;
    rdfs:comment 'Indicates whether an out-of-stock condition was detected at the store during the transaction period. Used for On-Shelf Availability (OSA) monitoring.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The timestamp when the POS transaction record was processed and loaded into the lakehouse silver layer. Used for data pipeline monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The granularity or aggregation period of the POS data as provided by the source (e.g., Daily, Weekly, Monthly). Varies by syndicated data provider.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Selling Price' ;
    rdfs:comment 'The per-unit retail price at which the product was sold to the consumer. Used for price compliance monitoring against Recommended Selling Price (RSP) and Manufacturer Suggested Retail Price (MSRP).' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCity rdf:type rdf:Property ;
    rdfs:label 'Store City' ;
    rdfs:comment 'The city where the retail store is located. Used for geographic sales analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Store Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code where the retail store is located.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePostalCode rdf:type rdf:Property ;
    rdfs:label 'Store Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the retail store location. Used for micro-market analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Store State Province' ;
    rdfs:comment 'The state or province where the retail store is located. Used for regional sales analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The calendar date when the consumer purchase transaction occurred at the retail outlet. Primary business event date for demand sensing and On-Shelf Availability (OSA) monitoring.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekEndingDate rdf:type rdf:Property ;
    rdfs:label 'Week Ending Date' ;
    rdfs:comment 'The Saturday date marking the end of the reporting week for weekly aggregated POS data. Standard for Nielsen IQ and IRI/Circana weekly reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersededByPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price List Id' ;
    rdfs:comment 'Reference to the newer price list that replaces this one when status is superseded. Enables price list succession tracking and historical pricing analysis.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:freightInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Inclusion Flag' ;
    rdfs:comment 'Indicates whether freight costs are included in the prices in this list. True when prices are freight-inclusive (delivered pricing), false when prices are ex-works or FOB.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrpFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Flag' ;
    rdfs:comment 'Indicates whether this price list contains manufacturer suggested retail prices (MSRP). True when prices represent official MSRP for consumer-facing pricing and promotional compliance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Pricing methodology or basis used to establish prices in this list. List price indicates standard published pricing, cost plus indicates markup over cost, market based indicates alignment with market rates, competitive indicates positioning relative to competitors, value based indicates pricing tied to customer value perception.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Unique business identifier code for the price list used in SAP SD pricing procedures and condition records. Externally-known identifier used in pricing agreements and sales documents.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Detailed description of the price list purpose, scope, and applicability including target customer segments and product categories covered.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Descriptive business name of the price list for identification and reporting purposes.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle status of the price list. Draft indicates under development, pending approval indicates awaiting authorization, active indicates currently in use, inactive indicates temporarily disabled, expired indicates past validity period, superseded indicates replaced by newer version.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its business purpose and application context. Standard lists provide baseline pricing, promotional lists support time-limited campaigns, contract lists support negotiated agreements, channel-specific lists apply to distribution channels, seasonal lists support seasonal pricing strategies, and clearance lists support inventory liquidation.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionDays rdf:type rdf:Property ;
    rdfs:label 'Price Protection Days' ;
    rdfs:comment 'Number of days of price protection coverage offered under this price list. Defines the lookback period for retroactive price adjustments when price protection is enabled.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Flag' ;
    rdfs:comment 'Indicates whether price protection provisions apply to this price list. When true, customers who purchased at higher prices may be eligible for retroactive credits if prices decrease during the protection period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceRoundingRule rdf:type rdf:Property ;
    rdfs:label 'Price Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated prices from this list. Supports psychological pricing strategies and currency denomination constraints.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD condition type code that defines how prices from this list are applied in pricing procedures (e.g., PR00 for base price, K004 for material price). Links price list to SAP pricing schema configuration.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspFlag rdf:type rdf:Property ;
    rdfs:label 'Rsp Flag' ;
    rdfs:comment 'Indicates whether this price list contains recommended selling prices (RSP) for retail partners. True when prices represent manufacturer-suggested retail pricing guidance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax category or classification code applicable to prices in this list. Determines tax treatment for products priced under this list in compliance with jurisdictional tax regulations.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeClass rdf:type rdf:Property ;
    rdfs:label 'Trade Class' ;
    rdfs:comment 'Customer trade class or customer pricing group to which this price list applies. Used to segment pricing by customer type such as mass merchandisers, drug stores, grocery chains, convenience stores, or specialty retailers.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Unique identifier for the price list item record. Primary key for this entity.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The standard cost or COGS for this SKU in the specified currency. Used for margin analysis and profitability calculations. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer segment or pricing group for which this price applies (e.g., national accounts, regional chains, independent retailers). Supports segment-based pricing.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Sequential line number of this item within the parent price list. Used for ordering and display purposes.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The base list price for this SKU in the specified currency and unit of measure. Represents the standard selling price before any discounts or promotions.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'The target gross margin percentage for this price list item, calculated as (list_price - cost_price) / list_price * 100. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this price list item represents a manual override of standard pricing logic. True if this is an exception price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListItemStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Item Status' ;
    rdfs:comment 'Current lifecycle status of this price list item. Controls whether the item can be used in pricing calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit Quantity' ;
    rdfs:comment 'The quantity of base units represented by one pricing unit. For example, if price is per case and a case contains 12 units, this value is 12.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapConditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Number' ;
    rdfs:comment 'The unique SAP SD condition record number for this price list item. Enables traceability back to the source ERP system.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseListPrice rdf:type rdf:Property ;
    rdfs:label 'Base List Price' ;
    rdfs:comment 'Standard manufacturer list price before any discounts, allowances, or negotiated reductions are applied.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedNetPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Net Price' ;
    rdfs:comment 'Agreed net price per unit after applying all negotiated discounts and allowances as defined in the pricing agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required per order to qualify for the contracted pricing terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalAllowance rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance' ;
    rdfs:comment 'Additional allowance or discount provided to support trade promotions, in-store displays, or marketing activities.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate granted to the customer upon achieving volume thresholds or other performance criteria defined in the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Quantity' ;
    rdfs:comment 'Minimum order or cumulative purchase quantity required to qualify for the contracted pricing tier or volume-based discount.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUom rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Uom' ;
    rdfs:comment 'Unit of measure for the volume threshold quantity (e.g., EA for each, CS for case, PAL for pallet).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota assignment record.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Identifier of the account team to which this quota is assigned.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTeam .

ind:incentivePlanId rdf:type rdf:Property ;
    rdfs:label 'Incentive Plan Id' ;
    rdfs:comment 'Identifier of the incentive compensation plan linked to this quota.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:acceleratorRate rdf:type rdf:Property ;
    rdfs:label 'Accelerator Rate' ;
    rdfs:comment 'Enhanced commission rate applied when stretch target is exceeded.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission percentage rate applied when quota is achieved.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month within the year (1-12) for which the quota is assigned.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold' ;
    rdfs:comment 'Minimum performance threshold required for quota credit or commission eligibility.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaName rdf:type rdf:Property ;
    rdfs:label 'Quota Name' ;
    rdfs:comment 'Descriptive name for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Business identifier or reference number for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaSource rdf:type rdf:Property ;
    rdfs:label 'Quota Source' ;
    rdfs:comment 'Method by which the quota was determined. Top-down = allocated from corporate targets, Bottom-up = aggregated from field input, Negotiated = agreed between management and rep, Algorithmic = calculated by predictive model.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota assignment. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Type of quota being assigned. Revenue = monetary sales target, Volume = unit/case target, New Distribution = new store/outlet target, TDP (Total Distribution Points) = weighted distribution target, ACV (All Commodity Volume) = market coverage target, Unit Sales = individual unit target, Gross Margin = profitability target. [ENUM-REF-CANDIDATE: revenue|volume|new_distribution|tdp|acv|unit_sales|gross_margin — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaValue rdf:type rdf:Property ;
    rdfs:label 'Quota Value' ;
    rdfs:comment 'Target value for the quota. Interpretation depends on quota_type: monetary amount for revenue quotas, unit count for volume quotas, store count for distribution quotas.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stretchTarget rdf:type rdf:Property ;
    rdfs:label 'Stretch Target' ;
    rdfs:comment 'Aspirational or stretch goal beyond the base quota value, used for incentive compensation.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure for the quota value (e.g., USD, cases, units, stores, points).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Reference to the sales representative record of this rep\'s direct manager. Supports hierarchical reporting and approval workflows in the sales organization.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: HR reporting aligns each sales rep with an org unit for headcount, budgeting, and compensation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Sales rep\'s position defines role, grade, and compensation; needed for payroll and career path tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Physical security badge or identification number issued to the sales representative. Used for facility access and field audit verification.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSpecialization rdf:type rdf:Property ;
    rdfs:label 'Channel Specialization' ;
    rdfs:comment 'Primary sales channel focus for this representative. Retail covers traditional grocery and drug stores; wholesale covers distributors; DTC (Direct to Consumer) covers company-owned stores and online; e-commerce covers digital marketplaces; foodservice covers restaurants and institutions; convenience covers c-stores and gas stations; mass merchandise covers big-box retailers. [ENUM-REF-CANDIDATE: retail|wholesale|dtc|ecommerce|foodservice|convenience|mass_merchandise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Identifier for the commission or incentive compensation plan assigned to this sales representative. Links to the compensation management system for payout calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Current Quota Amount' ;
    rdfs:comment 'Current sales quota target amount for the active quota period. Measured in the sales organization\'s reporting currency. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired into the sales organization. Used for tenure calculations, commission eligibility, and performance benchmarking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Date' ;
    rdfs:comment 'Date the sales representative last completed required certifications or training. Used to track recertification schedules and compliance status.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number of the sales representative. Used for SFA mobile app authentication, emergency contact, and field communication.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the quota amount. Typically matches the sales organization\'s reporting currency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Frequency at which sales quotas are assigned and measured for this representative. Monthly quotas are typical for field sales; quarterly for key accounts; annual for national accounts.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repNumber rdf:type rdf:Property ;
    rdfs:label 'Rep Number' ;
    rdfs:comment 'Business identifier for the sales representative, typically assigned by the sales organization. Used in Salesforce Consumer Goods Cloud and SAP S/4HANA SD module for sales force automation and order capture.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current lifecycle status of the sales representative. Active reps are assigned territories and quotas; inactive reps are temporarily not selling; on_leave indicates approved absence; suspended indicates disciplinary hold; terminated indicates employment ended.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repType rdf:type rdf:Property ;
    rdfs:label 'Rep Type' ;
    rdfs:comment 'Classification of the sales representative role. Field sales covers territory-based retail execution; key account manager handles strategic retail accounts; national account manager manages top-tier national chains; inside sales supports telesales and e-commerce; DSD (Direct Store Delivery) driver combines delivery and merchandising; regional manager oversees field teams.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesGroup rdf:type rdf:Property ;
    rdfs:label 'Sales Group' ;
    rdfs:comment 'SAP S/4HANA SD sales group code. Represents the functional team or product line focus within the sales organization (e.g., health and beauty, household care, personal care).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sfaUserCode rdf:type rdf:Property ;
    rdfs:label 'Sfa User Code' ;
    rdfs:comment 'User identifier in the Sales Force Automation system (Salesforce Consumer Goods Cloud). Used to link mobile app activity, retail execution records, and call reports to this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Indicates whether a company vehicle has been assigned to this sales representative. True for DSD drivers and field sales reps with company cars; false for inside sales and office-based roles.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnOrderId rdf:type rdf:Property ;
    rdfs:label 'Return Order Id' ;
    rdfs:comment 'Unique identifier for the return order record. Primary key.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Originating Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order that this return is associated with.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Return processing must capture the employee handling the return for accountability and quality control.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteGenerationId rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_generation. Business justification: Returned goods generate waste; linking return orders to waste generation records enables accurate waste reporting and cost recovery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteGeneration .

ind:creditMemoIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Date' ;
    rdfs:comment 'Date when the credit memo was officially issued to the customer.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoPostedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Posted Date' ;
    rdfs:comment 'Date when the credit memo was posted to the general ledger for financial settlement.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current status of the credit memo in the accounts receivable settlement process. [ENUM-REF-CANDIDATE: not_requested|requested|approved|issued|posted|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponsibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Responsible Flag' ;
    rdfs:comment 'Indicates whether the customer is financially responsible for the return (True) or the business absorbs the cost (False).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for handling the returned goods based on inspection results and business rules. [ENUM-REF-CANDIDATE: return_to_stock|destroy|rework|donate|quarantine|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Goods Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the return processing facility or warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when quality inspection of the returned goods was completed.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the quality inspector who performed the inspection of returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'Original unit price at which the product was sold in the originating sales order.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Date' ;
    rdfs:comment 'Date when the return was officially authorized by the business for processing.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnOrderType rdf:type rdf:Property ;
    rdfs:label 'Return Order Type' ;
    rdfs:comment 'Classification of the return based on the originating channel: retail account, distributor, direct-to-consumer, or wholesale.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRequestDate rdf:type rdf:Property ;
    rdfs:label 'Return Request Date' ;
    rdfs:comment 'Date when the return request was initiated by the customer or account.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost incurred for shipping the returned goods back to the warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueGross rdf:type rdf:Property ;
    rdfs:label 'Return Value Gross' ;
    rdfs:comment 'Gross monetary value of the returned goods before any deductions (returned quantity × original unit price).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueNet rdf:type rdf:Property ;
    rdfs:label 'Return Value Net' ;
    rdfs:comment 'Net monetary value to be credited to the customer after restocking fees and adjustments (gross - restocking fee - adjustments).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the returned quantity (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDeductionId rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Id' ;
    rdfs:comment 'Unique identifier for the sales deduction record. Primary key.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'The total amount claimed or deducted by the customer or distributor from the invoice payment.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionStatus rdf:type rdf:Property ;
    rdfs:label 'Deduction Status' ;
    rdfs:comment 'Current lifecycle status of the deduction: open, under review, approved, rejected, written off, or partially approved.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Valid Claim Flag' ;
    rdfs:comment 'Indicates whether the deduction claim was determined to be valid based on investigation and supporting documentation.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesDsdDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Sales Dsd Delivery Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery record. Primary key for the sales_dsd_delivery product.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesDsdRouteId rdf:type rdf:Property ;
    rdfs:label 'Sales Dsd Route Id' ;
    rdfs:comment 'Reference to the DSD route this delivery is part of. Links to the route master for planning and optimization.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesDsdRoute .

ind:deliveryAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Amount' ;
    rdfs:comment 'Gross monetary value of products delivered in this transaction before adjustments. Base amount for settlement calculation.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Timestamp' ;
    rdfs:comment 'Timestamp when the delivery was confirmed and signed off by the store receiver. Marks the completion of the delivery transaction.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Flag' ;
    rdfs:comment 'Indicates whether any exceptions or issues occurred during this delivery. True if exceptions were recorded, false for clean deliveries.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Time' ;
    rdfs:comment 'The precise timestamp when the delivery was completed at the store. Used for route optimization and On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for delivery exception. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAmount rdf:type rdf:Property ;
    rdfs:label 'Return Amount' ;
    rdfs:comment 'Monetary value of products returned during this delivery. Deducted from the delivery amount in settlement.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapSdDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Delivery Number' ;
    rdfs:comment 'SAP SD system delivery document number for integration and traceability. Links this DSD delivery to the source ERP transaction.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time' ;
    rdfs:comment 'The planned delivery time as scheduled in the route plan. Used to measure delivery punctuality and OTIF compliance.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureImageReference rdf:type rdf:Property ;
    rdfs:label 'Signature Image Reference' ;
    rdfs:comment 'Reference to the stored signature image file or document. Links to document management system for proof of delivery retrieval.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeReceiverName rdf:type rdf:Property ;
    rdfs:label 'Store Receiver Name' ;
    rdfs:comment 'Name of the store employee who received and accepted the delivery. Captured for proof of delivery and accountability.' ;
    rdfs:domain ind:SalesDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLaneId rdf:type rdf:Property ;
    rdfs:label 'Network Lane Id' ;
    rdfs:comment 'Foreign key linking to supply.network_lane. Business justification: DSD Route Planning tracks which network lane (origin-destination, carrier, lead time) a route follows; lane attributes are needed for cost and service calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkLane .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual time in hours taken to complete a specific delivery execution on this route, including all stops and travel time.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStopCount rdf:type rdf:Property ;
    rdfs:label 'Actual Stop Count' ;
    rdfs:comment 'Actual number of retail store stops completed during a specific delivery execution on this route.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Status' ;
    rdfs:comment 'Status of delivery confirmation for a specific route execution, indicating whether deliveries were accepted by store receivers.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Delivery Day Of Week' ;
    rdfs:comment 'Scheduled day of the week when deliveries are executed on this route. Multiple days may be represented in separate route records or via custom schedule.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Execution Date' ;
    rdfs:comment 'Actual date when a specific delivery execution event occurred on this route. Captures the real-world delivery event timestamp for execution tracking.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Standard frequency pattern for deliveries on this DSD route, defining how often stores on the route receive deliveries.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Estimated Distance Km' ;
    rdfs:comment 'Total estimated distance in kilometers for completing all stops on this DSD route.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Total estimated time in hours required to complete all deliveries on this DSD route, including travel and stop time.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Number of delivery exceptions encountered during route execution (e.g., store closed, access denied, damaged goods, shortages).' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicTerritory rdf:type rdf:Property ;
    rdfs:label 'Geographic Territory' ;
    rdfs:comment 'Geographic territory or region code that this DSD route covers, used for sales territory management and planning.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Planned Stop Count' ;
    rdfs:comment 'Number of retail store stops planned on this DSD route during a standard delivery cycle.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiverSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature Captured Flag' ;
    rdfs:comment 'Indicates whether store receiver signatures were captured electronically during delivery execution for proof of delivery.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeEndTime rdf:type rdf:Property ;
    rdfs:label 'Route End Time' ;
    rdfs:comment 'Scheduled end time for route execution, typically when the driver returns to the warehouse. Format HH:mm.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeStartTime rdf:type rdf:Property ;
    rdfs:label 'Route Start Time' ;
    rdfs:comment 'Scheduled start time for route execution, typically when the driver departs from the warehouse. Format HH:mm.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sapSdRouteNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Route Number' ;
    rdfs:comment 'Route number reference in SAP S/4HANA SD module for integration and cross-system reconciliation.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Delivered' ;
    rdfs:comment 'Total quantity of products delivered across all stops during a specific route execution, measured in base unit of measure.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityReturned rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Returned' ;
    rdfs:comment 'Total quantity of products returned (empties, unsold, damaged) collected during a specific route execution, measured in base unit of measure.' ;
    rdfs:domain ind:SalesDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Id' ;
    rdfs:comment 'Unique identifier for the sales rebate agreement record. Primary key.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accruedRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Rebate Amount' ;
    rdfs:comment 'Total rebate amount accrued to date under this agreement but not yet settled or paid.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent rebate settlement payment made under this agreement.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Rebate Amount' ;
    rdfs:comment 'Cap on the total rebate amount that can be earned under this agreement during its term. Nullable if no cap applies.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQualificationAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualification Amount' ;
    rdfs:comment 'Minimum purchase amount or volume required for the customer to qualify for any rebate under this agreement.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether rebate rate increases apply retroactively to all prior purchases when a higher tier is reached.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRebateAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the rebate agreement indicating its operational state.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settledRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Rebate Amount' ;
    rdfs:comment 'Total rebate amount that has been settled and paid to the customer under this agreement.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which rebate payments are calculated and settled with the customer.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Termination Timestamp' ;
    rdfs:comment 'Date and time when the rebate agreement was terminated before its scheduled end date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tierStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Flag' ;
    rdfs:comment 'Indicates whether this rebate agreement uses a tiered threshold structure with escalating rebate rates.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of retail trade accounts assigned to this territory. Used for workload balancing and territory design.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvCoverage rdf:type rdf:Property ;
    rdfs:label 'Acv Coverage' ;
    rdfs:comment 'Estimated All Commodity Volume (ACV) represented by the retail accounts in this territory, expressed in currency. ACV measures the total sales volume of all products sold through the retail outlets in the territory, used for market potential assessment.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota or revenue target assigned to this territory, expressed in the company\'s reporting currency. Used for sales performance management and incentive compensation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Days' ;
    rdfs:comment 'Standard call frequency in days for sales representative visits to accounts in this territory (e.g., 7 for weekly, 14 for bi-weekly, 30 for monthly). Used for SFA route planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Assignment' ;
    rdfs:comment 'Primary retail channel or trade class that this territory covers. Aligns with consumer goods distribution channels including grocery, drug, mass merchandiser, club, convenience, e-commerce, and Direct-to-Consumer (DTC). [ENUM-REF-CANDIDATE: grocery|drug|mass|club|convenience|e_commerce|foodservice|wholesale|dtc|multi_channel — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Mid-level geographic or organizational district within a region. Represents a grouping of territories managed by a district sales manager.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the majority of accounts in this territory support Electronic Data Interchange (EDI) for automated order processing, invoicing, and inventory management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pogComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Required Flag' ;
    rdfs:comment 'Indicates whether field sales representatives in this territory are required to monitor and enforce Planogram (POG) compliance for product placement and shelf merchandising.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeList rdf:type rdf:Property ;
    rdfs:label 'Postal Code List' ;
    rdfs:comment 'Comma-separated or structured list of postal codes included in this territory. Used for precise geographic assignment and routing optimization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Strategic priority classification of the territory based on revenue potential, account importance, or growth opportunity. Tier 1 or Strategic territories receive higher resource allocation and management attention.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Higher-level geographic or organizational region to which this territory belongs (e.g., \'Northeast\', \'West Coast\', \'EMEA\'). Used for regional sales rollup and management hierarchy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceList rdf:type rdf:Property ;
    rdfs:label 'State Province List' ;
    rdfs:comment 'Comma-separated list of states or provinces covered by this territory (e.g., \'NY,NJ,CT\' or \'CA,NV,AZ\'). Used for state-level sales reporting and compliance.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Total number of retail store locations (points of distribution) within this territory. Key metric for coverage planning and Sales Force Automation (SFA) routing.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tdpCoverage rdf:type rdf:Property ;
    rdfs:label 'Tdp Coverage' ;
    rdfs:comment 'Total Distribution Points (TDP) covered by this territory, representing the number of stores where the company\'s products are authorized for distribution. Critical metric for distribution reach and On-Shelf Availability (OSA).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory, typically reflecting geographic region or account grouping (e.g., \'Northeast Metro\', \'California Key Accounts\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory. Active territories are operational and assigned to sales representatives; inactive territories are no longer in use; pending territories are being set up.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory based on sales coverage model. Field territories cover geographic regions with multiple accounts; key account territories focus on strategic retail partners; national account territories manage enterprise-wide relationships.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpRecordId rdf:type rdf:Property ;
    rdfs:label 'Atp Record Id' ;
    rdfs:comment 'Primary key for atp_record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpRuleId rdf:type rdf:Property ;
    rdfs:label 'Atp Rule Id' ;
    rdfs:comment 'Identifier for the specific ATP business rule or configuration applied during calculation, enabling traceability of ATP logic.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtpRule .

ind:atpCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Atp Calculation Method' ;
    rdfs:comment 'The method used to calculate ATP. Simple ATP considers only on-hand inventory minus allocations. Cumulative ATP includes planned receipts over time. Multi-level ATP considers BOM components. Product allocation ATP applies allocation rules across customer segments.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpCheckHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Atp Check Horizon Days' ;
    rdfs:comment 'The number of days into the future that the ATP check considers for availability. Defines the planning horizon for promise calculations.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Number' ;
    rdfs:comment 'Unique confirmation number generated when ATP is reserved for a sales order, providing traceability between ATP records and order promising.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpDate rdf:type rdf:Property ;
    rdfs:label 'Atp Date' ;
    rdfs:comment 'The date for which ATP quantity is calculated. Represents the promise date for order fulfillment.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'The confirmed quantity available to promise to customers for the given SKU, location, and date. Represents uncommitted inventory available for new orders.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Status' ;
    rdfs:comment 'The current status of the ATP record. Available indicates positive ATP. Constrained indicates limited availability. Blocked indicates ATP is not available for promising. Expired indicates the ATP date has passed.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Backorder Quantity' ;
    rdfs:comment 'The quantity of unfulfilled demand from previous periods that impacts current ATP availability.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctpQuantity rdf:type rdf:Property ;
    rdfs:label 'Ctp Quantity' ;
    rdfs:comment 'The quantity that can be promised considering both current inventory and planned production or supply receipts. Extends ATP by including future supply.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAtpQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Atp Quantity' ;
    rdfs:comment 'The cumulative ATP quantity calculated across multiple time periods, showing total available quantity from current date through the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Customer Priority Tier' ;
    rdfs:comment 'The priority tier of the customer or channel for which ATP is being calculated, used in allocation scenarios where high-priority customers receive preferential ATP.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPeggingReference rdf:type rdf:Property ;
    rdfs:label 'Demand Pegging Reference' ;
    rdfs:comment 'Reference identifier linking ATP consumption to specific demand sources such as sales orders, forecasts, or customer reservations.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConsumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Consumption Quantity' ;
    rdfs:comment 'The quantity of forecast demand consumed by actual sales orders, used in ATP calculations to avoid double-counting demand.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Shelf Life Days' ;
    rdfs:comment 'The minimum remaining shelf life in days required for the product to be available for promising, ensuring customers receive products with adequate shelf life.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandInventory rdf:type rdf:Property ;
    rdfs:label 'On Hand Inventory' ;
    rdfs:comment 'The physical inventory quantity available at the location at the time of ATP calculation.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Quantity' ;
    rdfs:comment 'The quantity expected to be received from production orders, purchase orders, or transfers by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'The planning scenario or version identifier in SAP IBP under which this ATP calculation was performed, enabling what-if analysis and scenario planning.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productAllocationGroup rdf:type rdf:Property ;
    rdfs:label 'Product Allocation Group' ;
    rdfs:comment 'The allocation group or priority segment assigned to this ATP calculation, used when ATP is allocated across customer tiers or channels.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Order Quantity' ;
    rdfs:comment 'The quantity scheduled for production that will be available by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Quantity' ;
    rdfs:comment 'The quantity on open purchase orders expected to be received by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyPeggingReference rdf:type rdf:Property ;
    rdfs:label 'Supply Pegging Reference' ;
    rdfs:comment 'Reference identifier linking ATP availability to specific supply sources such as production orders, purchase orders, or stock transfers.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusDemandId rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Id' ;
    rdfs:comment 'Unique identifier for the consensus demand record. Primary key for this entity representing a single agreed demand signal from the S&OP demand review process.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consensusPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Consensus Planner Employee Id' ;
    rdfs:comment 'Reference to the demand planner responsible for preparing and maintaining this consensus demand record. Primary point of contact for demand questions.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'FK to supply.demand_plan.demand_plan_id — Links consensus demand records to demand plan header. Required for S&OP process tracking and forecast accuracy measurement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:planningPeriodId rdf:type rdf:Property ;
    rdfs:label 'Planning Period Id' ;
    rdfs:comment 'Reference to the time bucket (week, month, quarter) for which this consensus demand is valid. Links to the planning calendar.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningPeriod .

ind:primaryConsensusEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Consensus Employee Id' ;
    rdfs:comment 'Reference to the business user (demand manager, S&OP lead, or executive) who approved this consensus demand record. Establishes accountability for the demand signal.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Reference to the specific S&OP or IBP cycle during which this consensus demand was agreed. Enables tracking of demand evolution across planning cycles.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:tertiaryConsensusLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Consensus Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this consensus demand record. Enables tracking of who made the most recent changes.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:biasIndicator rdf:type rdf:Property ;
    rdfs:label 'Bias Indicator' ;
    rdfs:comment 'Indicator of systematic forecasting bias based on historical performance. Over-forecast indicates consistent overestimation; under-forecast indicates consistent underestimation; neutral indicates balanced accuracy.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Commercial Overlay Quantity' ;
    rdfs:comment 'The demand adjustment applied by commercial teams based on market intelligence, customer commitments, and sales insights. Can be positive or negative.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusQuantity rdf:type rdf:Property ;
    rdfs:label 'Consensus Quantity' ;
    rdfs:comment 'The final agreed demand volume for this SKU/location/period after all inputs and overlays have been applied. This is the single demand signal passed to supply planning and represents the official forecast.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Constrained Flag' ;
    rdfs:comment 'Indicates whether the consensus demand has been adjusted downward due to known supply constraints. True means demand was constrained; false means demand is unconstrained.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintReason rdf:type rdf:Property ;
    rdfs:label 'Constraint Reason' ;
    rdfs:comment 'Explanation of the supply constraint that limited consensus demand (e.g., production capacity, raw material shortage, distribution capacity). Populated only when constrained_flag is true.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Customer Commitment Quantity' ;
    rdfs:comment 'Demand volume backed by firm customer orders, contracts, or commitments for this planning period. Represents the most reliable component of consensus demand.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of the demand type to enable segmented planning and analysis. Base demand represents ongoing business; promotional and seasonal reflect event-driven spikes; new launch and phase-out support lifecycle transitions.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandDriverCode rdf:type rdf:Property ;
    rdfs:label 'Demand Driver Code' ;
    rdfs:comment 'Code identifying the primary business driver or causal factor influencing this demand (e.g., holiday season, weather pattern, competitive action, regulatory change). Supports root-cause analysis.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandDriverDescription rdf:type rdf:Property ;
    rdfs:label 'Demand Driver Description' ;
    rdfs:comment 'Detailed explanation of the demand driver or business rationale behind the consensus demand figure. Captures qualitative insights from demand planners and commercial teams.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVolatilityIndex rdf:type rdf:Property ;
    rdfs:label 'Demand Volatility Index' ;
    rdfs:comment 'Statistical measure of demand variability for this SKU/location combination, typically expressed as coefficient of variation. Higher values indicate greater uncertainty and require higher safety stock.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPreviousPeriod rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Previous Period' ;
    rdfs:comment 'The forecast accuracy percentage achieved for this SKU/location combination in the previous planning period. Used to assess forecasting performance trends and adjust confidence levels.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModelCode rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Code' ;
    rdfs:comment 'Identifier of the statistical forecasting model or algorithm used to generate the baseline statistical forecast (e.g., exponential smoothing, ARIMA, machine learning model).' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEventUpliftQuantity rdf:type rdf:Property ;
    rdfs:label 'Marketing Event Uplift Quantity' ;
    rdfs:comment 'Incremental demand volume expected from planned marketing campaigns, promotions, or trade events during this planning period.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newProductLaunchQuantity rdf:type rdf:Property ;
    rdfs:label 'New Product Launch Quantity' ;
    rdfs:comment 'Demand volume attributed to new product introductions or product launches scheduled for this planning period. Typically based on launch plans and market sizing.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonType rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Type' ;
    rdfs:comment 'Classification of the planning time horizon for this demand record. Short-term (0-3 months) is firm; medium-term (3-12 months) is flexible; long-term (12+ months) is strategic.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Flag' ;
    rdfs:comment 'Indicates whether this consensus demand includes uplift from planned trade promotions or marketing events. True means promotional activity is planned; false means base demand only.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplicative factor representing seasonal demand patterns for this planning period. Values above 1.0 indicate peak season; below 1.0 indicate off-season.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Quantity' ;
    rdfs:comment 'The baseline demand forecast generated by statistical forecasting algorithms before any manual adjustments or commercial overlays. Serves as the starting point for consensus demand.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unconstrainedDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Unconstrained Demand Quantity' ;
    rdfs:comment 'The theoretical demand volume if all supply constraints (capacity, materials, inventory) were removed. Used for capacity planning and investment decisions.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToStatistical rdf:type rdf:Property ;
    rdfs:label 'Variance To Statistical' ;
    rdfs:comment 'The difference between consensus demand quantity and statistical forecast quantity. Positive values indicate upward adjustments; negative values indicate downward adjustments. Key metric for forecast bias analysis.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintId rdf:type rdf:Property ;
    rdfs:label 'Constraint Id' ;
    rdfs:comment 'Primary key for constraint' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningRunId rdf:type rdf:Property ;
    rdfs:label 'Planning Run Id' ;
    rdfs:comment 'Identifier of the Integrated Business Planning (IBP) or Sales and Operations Planning (S&OP) run during which this constraint was identified.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningRun .

ind:constrainedResourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Constrained Resource Identifier' ;
    rdfs:comment 'Business identifier of the specific resource that is constrained, such as production line code, warehouse zone, labor pool identifier, or material code. Provides granular traceability to the bottleneck.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the constraint: identified (newly detected), active (currently impacting supply), mitigated (workaround applied), resolved (constraint removed), or escalated (requires executive intervention).' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Classification of the constraint by root cause: capacity (production or storage capacity limitation), material (raw material or component shortage), labor (workforce availability), regulatory (compliance or certification limitation), supplier (external supplier constraint), or transportation (logistics capacity constraint).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'The calculated number of days the constraint is expected to persist, derived from start and end dates. Used for prioritization and impact assessment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identified Timestamp' ;
    rdfs:comment 'The date and time when the constraint was first detected by the planning system or planner. Represents the constraint discovery event in the planning lifecycle.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'The date and time when the constraint record was last reviewed or updated by a planner. Used to track active management and ensure constraints are not stale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Description of the action plan or workaround implemented to address the constraint, such as alternate sourcing, production rescheduling, expedited shipping, or demand shaping. Free-text field for planner notes.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Mitigation Effectiveness Score' ;
    rdfs:comment 'Quantitative assessment of how effectively the mitigation action reduced the constraint impact, expressed as a percentage (0-100). Used for continuous improvement and mitigation strategy evaluation.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'The quantity of the resource or material required to meet demand without constraint. Represents the unconstrained demand signal.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShortfall rdf:type rdf:Property ;
    rdfs:label 'Quantity Shortfall' ;
    rdfs:comment 'The calculated gap between required and available quantities (required minus available). Represents the magnitude of the constraint impact.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the constraint was fully resolved and supply capacity restored. Nullable for constraints that remain active or unresolved.' ;
    rdfs:domain ind:Constraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demandEventId rdf:type rdf:Property ;
    rdfs:label 'Demand Event Id' ;
    rdfs:comment 'Unique identifier for the demand event record. Primary key.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDemandEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Demand Employee Id' ;
    rdfs:comment 'Reference to the demand planner or business user responsible for creating and maintaining this demand event.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDemandSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Demand Sku Id' ;
    rdfs:comment 'Reference to the specific SKU affected by this demand event. For multi-SKU events, this may reference a product family or be null with SKU scope defined elsewhere.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:cannibalizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Cannibalization Rate Percent' ;
    rdfs:comment 'For new product launches, the percentage of new product demand that is expected to cannibalize existing SKU demand rather than represent net-new volume.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'For product discontinuation events, the business rationale for discontinuing the SKU (e.g., low sales, regulatory, reformulation, portfolio rationalization).' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndDate rdf:type rdf:Property ;
    rdfs:label 'Event End Date' ;
    rdfs:comment 'The date when the demand event ceases to impact demand. Null for indefinite events such as permanent price changes or discontinuations.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text field for planner comments, assumptions, risks, or additional context about the demand event.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartDate rdf:type rdf:Property ;
    rdfs:label 'Event Start Date' ;
    rdfs:comment 'The date when the demand event begins to impact demand. For promotions, this is the promotion start date. For launches, this is the market availability date.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialStockingQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Stocking Quantity' ;
    rdfs:comment 'For new product launches, the initial pipeline fill quantity required to stock distribution centers and retail shelves before consumer demand begins.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Ship Date' ;
    rdfs:comment 'For product discontinuation events, the final date on which the SKU will be shipped to customers.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchChannelScope rdf:type rdf:Property ;
    rdfs:label 'Launch Channel Scope' ;
    rdfs:comment 'For new product launches, describes which distribution channels and customer segments are included in the launch (e.g., DTC-only, mass retail, specialty, omnichannel).' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketGeographyCode rdf:type rdf:Property ;
    rdfs:label 'Market Geography Code' ;
    rdfs:comment 'Three-letter ISO country code or market region code where the demand event applies. For new product launches, indicates launch market scope.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningRunCode rdf:type rdf:Property ;
    rdfs:label 'Planning Run Code' ;
    rdfs:comment 'Reference to the demand planning run or Sales and Operations Planning (S&OP) cycle in which this event was incorporated into the forecast.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'For price change events, the absolute change in unit price. Positive for price increases, negative for price decreases.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercent rdf:type rdf:Property ;
    rdfs:label 'Price Change Percent' ;
    rdfs:comment 'For price change events, the percentage change in unit price relative to the previous price.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceElasticityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Price Elasticity Coefficient' ;
    rdfs:comment 'For price change events, the estimated price elasticity of demand used to calculate volume impact. Negative values indicate normal goods (price up, demand down).' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Promotion Funding Amount' ;
    rdfs:comment 'For trade promotion events, the total budget allocated to fund the promotion, including trade spend, discounts, and allowances.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rampUpWeeks rdf:type rdf:Property ;
    rdfs:label 'Ramp Up Weeks' ;
    rdfs:comment 'For new product launches, the number of weeks over which demand is expected to ramp from zero to steady-state volume.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'The unique identifier of this demand event in the source system, used for traceability and reconciliation.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Readiness Status' ;
    rdfs:comment 'For new product launches, indicates whether manufacturing, procurement, and supply chain are ready to support the launch volume. Critical gate for launch approval.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Volume Impact Percent' ;
    rdfs:comment 'Percentage change in demand relative to the statistical baseline forecast. Positive for uplift, negative for downlift.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeImpactUnits rdf:type rdf:Property ;
    rdfs:label 'Volume Impact Units' ;
    rdfs:comment 'Absolute incremental or decremental demand volume attributed to this event, expressed in base units. Positive for uplift events, negative for downlift events.' ;
    rdfs:domain ind:DemandEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByPersona rdf:type rdf:Property ;
    rdfs:label 'Created By Persona' ;
    rdfs:comment 'Role or persona of the user who created this demand plan version, used for accountability and collaboration tracking.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPatternType rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern Type' ;
    rdfs:comment 'Classification of historical demand behavior pattern used to select appropriate statistical forecasting algorithm.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSensingSignal rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Signal' ;
    rdfs:comment 'Short-term demand trend indicator derived from real-time POS data, shipment data, and market signals to enable rapid forecast adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Historical forecast accuracy metric for this SKU/location/channel combination, used for forecast quality benchmarking and continuous improvement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBiasPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias Percentage' ;
    rdfs:comment 'Systematic tendency to over-forecast or under-forecast, calculated as average percentage deviation from actual demand.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsensusVersion rdf:type rdf:Property ;
    rdfs:label 'Is Consensus Version' ;
    rdfs:comment 'Flag indicating whether this version represents the official consensus demand plan approved through the S&OP process and used for supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npdLaunchVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Npd Launch Volume Quantity' ;
    rdfs:comment 'Forecasted demand quantity for new product launches or product line extensions during the planning period.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text comments and annotations from demand planners explaining assumptions, adjustments, risks, or special considerations for this forecast.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBucket rdf:type rdf:Property ;
    rdfs:label 'Planning Bucket' ;
    rdfs:comment 'Time granularity of the demand plan (daily, weekly, monthly, quarterly) used for aggregation and reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Promotional Overlay Quantity' ;
    rdfs:comment 'Demand uplift quantity attributed to trade promotions, price discounts, and retail execution activities.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Flag' ;
    rdfs:comment 'Indicator that this demand plan carries elevated supply risk due to capacity constraints, material shortages, or demand volatility.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Baseline Quantity' ;
    rdfs:comment 'Unconstrained demand forecast quantity generated by statistical forecasting algorithms before any commercial overlays or adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance To Baseline Quantity' ;
    rdfs:comment 'Difference between consensus quantity and statistical baseline quantity, indicating the net impact of all commercial adjustments and overlays.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name of the demand plan version (e.g., \'Statistical Baseline Q1 2024\', \'Consensus Final March 2024\').' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Version Sequence Number' ;
    rdfs:comment 'Sequential version number within the planning cycle, used to track iteration history and version progression.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the demand plan version indicating its stage in the S&OP process. Statistical baseline represents unconstrained forecast; consensus represents agreed demand signal passed to supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyId rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Id' ;
    rdfs:comment 'Unique identifier for the forecast accuracy measurement record. Primary key for this transactional measurement entity.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absolutePercentError rdf:type rdf:Property ;
    rdfs:label 'Absolute Percent Error' ;
    rdfs:comment 'Absolute percentage error calculated as |Actual - Forecast| / Actual. Used as input for Mean Absolute Percentage Error (MAPE) aggregation.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyStatus rdf:type rdf:Property ;
    rdfs:label 'Accuracy Status' ;
    rdfs:comment 'Status indicating whether the measured forecast accuracy met, exceeded, or fell short of the target. Used for exception-based management and continuous improvement prioritization.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Target Percent' ;
    rdfs:comment 'The target forecast accuracy percentage established for this SKU/location/period combination. Used for performance benchmarking and KPI tracking.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'The actual demand quantity realized during the planning period. Sourced from shipments, sales orders, or Point of Sale (POS) data depending on the measurement level.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biasPercent rdf:type rdf:Property ;
    rdfs:label 'Bias Percent' ;
    rdfs:comment 'Forecast bias expressed as a percentage: (Forecast - Actual) / Actual. Positive bias indicates systematic over-forecasting; negative bias indicates under-forecasting.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSensingAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Applied Flag' ;
    rdfs:comment 'Boolean flag indicating whether demand sensing corrections were applied to the statistical forecast for this SKU/location/period. True if near-term demand signals were incorporated.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandVolatilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Volatility Coefficient' ;
    rdfs:comment 'Coefficient of variation representing demand volatility for the SKU/location combination. Calculated as standard deviation divided by mean demand. Higher values indicate more volatile demand patterns and typically correlate with lower forecast accuracy.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastError rdf:type rdf:Property ;
    rdfs:label 'Forecast Error' ;
    rdfs:comment 'The absolute difference between forecast quantity and actual quantity (Actual - Forecast). Positive values indicate under-forecast; negative values indicate over-forecast.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModelType rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Type' ;
    rdfs:comment 'The type of forecasting model used to generate the original forecast. Identifies whether the forecast was produced by statistical algorithms, machine learning models, consensus planning, manual planner input, or a hybrid approach.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Quantity' ;
    rdfs:comment 'The forecasted demand quantity for the SKU/location/period as predicted by the statistical model or demand planning system at the time of forecast creation.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Version identifier of the forecast used for accuracy measurement. Enables tracking of accuracy across multiple forecast iterations and scenario planning versions within the Integrated Business Planning (IBP) cycle.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error for the SKU/location/period. Primary forecast accuracy metric expressed as a percentage. Lower values indicate better accuracy.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementCycle rdf:type rdf:Property ;
    rdfs:label 'Measurement Cycle' ;
    rdfs:comment 'Identifier of the Sales and Operations Planning (S&OP) or Integrated Business Planning (IBP) cycle during which this accuracy measurement was performed. Typically formatted as YYYY-MM or cycle name.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfStockDays rdf:type rdf:Property ;
    rdfs:label 'Out Of Stock Days' ;
    rdfs:comment 'Number of days during the planning period when the SKU was out of stock at the location. Out of Stock (OOS) events distort accuracy measurement as actual demand is constrained by availability.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percent rdf:type rdf:Property ;
    rdfs:label 'Percent' ;
    rdfs:comment 'Forecast accuracy percentage calculated as 100% - MAPE. Represents the complement of error, where higher values indicate better accuracy. Commonly used for executive reporting.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'The lifecycle stage of the SKU at the time of forecast measurement. Accuracy expectations and benchmarks vary by lifecycle stage, with new product introductions (NPD) typically having lower accuracy than mature products.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Period Flag' ;
    rdfs:comment 'Boolean flag indicating whether the planning period included promotional activity for this SKU/location. Promotional periods typically exhibit different accuracy patterns than baseline demand periods.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensedQuantity rdf:type rdf:Property ;
    rdfs:label 'Sensed Quantity' ;
    rdfs:comment 'The demand-sensed quantity after incorporating near-term signals such as Point of Sale (POS) data, syndicated market data from Nielsen IQ, or secondary sales from TradeEdge. Null if demand sensing was not applied.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Sensing Confidence Score' ;
    rdfs:comment 'Confidence score (0.0 to 1.0) representing the reliability of the demand sensing signal. Higher scores indicate stronger signal quality and greater confidence in the sensed adjustment.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensingHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Sensing Horizon Days' ;
    rdfs:comment 'The number of days into the future for which demand sensing was applied. Typically ranges from 7 to 90 days depending on product velocity and signal availability.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensingSignalSource rdf:type rdf:Property ;
    rdfs:label 'Sensing Signal Source' ;
    rdfs:comment 'The primary data source used for demand sensing correction. Identifies whether the signal came from Point of Sale (POS) data, Nielsen IQ syndicated feeds, TradeEdge secondary sales, shipment actuals, order backlog, promotional lift models, or manual planner override. [ENUM-REF-CANDIDATE: pos_data|nielsen_iq|trade_edge|shipment_data|order_backlog|promotional_lift|manual_override — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensingUpliftPercent rdf:type rdf:Property ;
    rdfs:label 'Sensing Uplift Percent' ;
    rdfs:comment 'Percentage uplift or downlift applied by demand sensing relative to the statistical forecast. Calculated as (Sensed Quantity - Forecast Quantity) / Forecast Quantity. Positive values indicate uplift; negative values indicate downlift.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmape rdf:type rdf:Property ;
    rdfs:label 'Wmape' ;
    rdfs:comment 'Weighted Mean Absolute Percentage Error, calculated as sum of absolute errors divided by sum of actuals. Preferred metric for aggregated accuracy measurement across product hierarchies.' ;
    rdfs:domain ind:ForecastAccuracy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVersionId rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Id' ;
    rdfs:comment 'Unique identifier for the forecast version record. Primary key.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineVersionId rdf:type rdf:Property ;
    rdfs:label 'Baseline Version Id' ;
    rdfs:comment 'Reference to the parent or baseline forecast version from which this version was derived (e.g., statistical baseline that was then adjusted). Nullable for original baseline versions.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForecastVersion .

ind:planningCycleId rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle Id' ;
    rdfs:comment 'Reference to the Sales and Operations Planning (S&OP) or Integrated Business Planning (IBP) cycle to which this forecast version belongs.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:primaryForecastEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Forecast Employee Id' ;
    rdfs:comment 'Reference to the user or persona who created this forecast version (e.g., demand planner, sales analyst, system batch job).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryForecastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Forecast Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this forecast version record.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Aggregation Level' ;
    rdfs:comment 'The level of aggregation at which this forecast version is maintained: Stock Keeping Unit (SKU) level, product family, brand, category, sales channel, customer account, geographic region, or global total. [ENUM-REF-CANDIDATE: sku|product_family|brand|category|channel|customer|region|global — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments or notes provided by the approver during the approval process, documenting any conditions, concerns, or guidance related to this forecast version. Nullable if not yet approved or no notes provided.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when this forecast version was archived and moved out of active planning use. Nullable if not yet archived.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:biasPercentage rdf:type rdf:Property ;
    rdfs:label 'Bias Percentage' ;
    rdfs:comment 'Forecast bias percentage indicating systematic over-forecasting (positive bias) or under-forecasting (negative bias). A value near zero indicates an unbiased forecast. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSensingApplied rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Applied' ;
    rdfs:comment 'Boolean flag indicating whether demand sensing algorithms (short-term forecast adjustments based on real-time Point of Sale (POS) data, shipment data, or other leading indicators) were applied to this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Forecast Source System' ;
    rdfs:comment 'Name or identifier of the source system or application that generated or contributed to this forecast version (e.g., \'SAP IBP\', \'TradeEdge\', \'Excel Upload\', \'Salesforce CG Cloud\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveVersion rdf:type rdf:Property ;
    rdfs:label 'Is Active Version' ;
    rdfs:comment 'Boolean flag indicating whether this forecast version is currently active and being used for planning and execution. Only one version per planning cycle should typically be active at a time.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinalApprovedVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Approved Version' ;
    rdfs:comment 'Boolean flag indicating whether this version is the final approved forecast that will be used for operational execution, Material Requirements Planning (MRP), and Distribution Requirements Planning (DRP).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanAbsolutePercentageError rdf:type rdf:Property ;
    rdfs:label 'Mean Absolute Percentage Error' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) metric for this forecast version, measuring the average magnitude of forecast errors as a percentage. Lower values indicate better forecast accuracy. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newProductIntroductionIncluded rdf:type rdf:Property ;
    rdfs:label 'New Product Introduction Included' ;
    rdfs:comment 'Boolean flag indicating whether New Product Development (NPD) or New Product Introduction (NPI) launches were incorporated into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalEventsIncluded rdf:type rdf:Property ;
    rdfs:label 'Promotional Events Included' ;
    rdfs:comment 'Boolean flag indicating whether trade promotions, marketing campaigns, and promotional events were factored into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalModelApplied rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Applied' ;
    rdfs:comment 'Name or identifier of the statistical forecasting model or algorithm applied to generate or adjust this forecast version (e.g., \'Exponential Smoothing\', \'ARIMA\', \'Machine Learning Ensemble\', \'Holt-Winters\'). Nullable if no statistical model was used.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'The time granularity or bucket size used for this forecast version: daily, weekly, monthly, quarterly, or annual periods.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Short alphanumeric code or identifier for the forecast version used in system integrations and reporting (e.g., \'STAT_BASE\', \'CONS_V1\', \'FINAL_APR\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Detailed textual description or notes about this forecast version, including assumptions, adjustments made, special considerations, or rationale for key changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the forecast version: draft (under construction), in review (submitted for approval), approved (validated and accepted), rejected (not accepted), archived (historical record), or active (currently in use for planning).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPolicyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Policy Id' ;
    rdfs:comment 'Unique identifier for the inventory policy record. Primary key for this entity.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Inventory Policy Governance requires a policy owner employee to approve and maintain each policy.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerOtifCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Customer Otif Commitment Percent' ;
    rdfs:comment 'Specific OTIF performance level committed to a customer or channel, which may differ from internal targets and may be contractually binding.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Cycle Stock Target Units' ;
    rdfs:comment 'Target cycle stock quantity representing the average inventory held to meet expected demand between replenishments, excluding safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percent' ;
    rdfs:comment 'Target percentage of customer demand that should be fulfilled from available inventory without backorders or stockouts.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation or variance of replenishment lead time in days, used to account for supply uncertainty in safety stock calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Units' ;
    rdfs:comment 'Maximum inventory level allowed at this location for this SKU, used to prevent overstocking and manage warehouse capacity constraints.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Time period in days over which service level performance is measured and evaluated against targets (e.g., rolling 30 days, 90 days, quarterly).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level Units' ;
    rdfs:comment 'Minimum inventory level that should be maintained at this location for this SKU, typically aligned with safety stock or regulatory requirements.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryTargetPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Percent' ;
    rdfs:comment 'Target percentage of orders that should be delivered by the customer-requested or committed delivery date.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompositeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Composite Target Percent' ;
    rdfs:comment 'Composite OTIF (On Time In Full) target percentage representing orders delivered both on time and in full quantity, a critical customer service metric.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseIndicator rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Indicator' ;
    rdfs:comment 'Indicates whether failure to meet the defined service level targets will result in financial penalties, chargebacks, or other contractual consequences.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the inventory policy indicating its approval and operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointUnits rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Units' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered, calculated as lead time demand plus safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied: MRP (Material Requirements Planning), DRP (Distribution Requirements Planning), VMI (Vendor Managed Inventory), JIT (Just In Time), Kanban, or Fixed Order Quantity.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerMandatedTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Retailer Mandated Target Flag' ;
    rdfs:comment 'Indicates whether the service level targets are mandated by a retail customer as part of their supplier requirements or vendor compliance program.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'Frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU-location combination.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockCalculatedUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculated Units' ;
    rdfs:comment 'System-calculated safety stock quantity based on demand variability, lead time variability, and service level inputs before manual approval or adjustment.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculation Method' ;
    rdfs:comment 'The methodology used to calculate safety stock: fixed value, forecast error-based, demand variability, lead time variability, combined variability, or service level-driven calculation.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days Of Supply' ;
    rdfs:comment 'Safety stock expressed as the number of days of average demand coverage, providing a time-based view of inventory buffer.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target Units' ;
    rdfs:comment 'Target safety stock quantity in base units of measure, representing the buffer inventory to protect against demand and supply variability.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryProjectionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Projection Id' ;
    rdfs:comment 'Unique identifier for the inventory projection record. Primary key for this transactional projection entity.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'Projected number of days the available inventory balance will cover forecasted demand. Critical metric for inventory health and service level assessment.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSource rdf:type rdf:Property ;
    rdfs:label 'Demand Source' ;
    rdfs:comment 'Source system or process that provided the demand forecast used in this projection (e.g., statistical forecast, demand sensing, customer orders, consensus demand).' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Inventory Flag' ;
    rdfs:comment 'Indicator that the projected available balance exceeds maximum stock levels or days-of-supply targets, signaling potential overstock risk.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planning Run Timestamp' ;
    rdfs:comment 'Timestamp when the supply planning run that generated this projection was executed. Distinct from record creation; represents the business event time.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:projectedAvailableBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Available Balance' ;
    rdfs:comment 'Net projected inventory balance after accounting for on-hand, receipts, and demand. Key metric for Available-to-Promise (ATP) calculations.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Projected Demand Quantity' ;
    rdfs:comment 'Forecasted demand (consumption, sales, or shipments) expected to occur on the projection date. Input from demand planning or demand sensing.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedOnHandQuantity rdf:type rdf:Property ;
    rdfs:label 'Projected On Hand Quantity' ;
    rdfs:comment 'Forecasted physical inventory quantity expected to be available on-hand at the location on the projection date. Core output of supply planning calculation.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedOnOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Projected On Order Quantity' ;
    rdfs:comment 'Forecasted quantity of inventory currently on order (in-transit or planned receipts) expected to arrive by or on the projection date.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Projected Receipt Quantity' ;
    rdfs:comment 'Forecasted quantity of planned receipts (production output, purchase orders, or replenishment) expected to arrive on the projection date.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectionConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Projection Confidence Level' ;
    rdfs:comment 'Qualitative assessment of confidence in this projection based on demand volatility, forecast accuracy, and supply reliability.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionDate rdf:type rdf:Property ;
    rdfs:label 'Projection Date' ;
    rdfs:comment 'The specific future date for which this inventory projection applies. Core dimension for time-series inventory planning.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectionNotes rdf:type rdf:Property ;
    rdfs:label 'Projection Notes' ;
    rdfs:comment 'Free-text notes or comments from the planner regarding assumptions, exceptions, or special considerations for this projection.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionStatus rdf:type rdf:Property ;
    rdfs:label 'Projection Status' ;
    rdfs:comment 'Current lifecycle status of this projection record. Indicates whether the projection is in draft, approved for execution, published to downstream systems, or superseded by a newer version.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionType rdf:type rdf:Property ;
    rdfs:label 'Projection Type' ;
    rdfs:comment 'Classification of the projection methodology. Baseline uses unconstrained demand; constrained applies capacity limits; optimized applies optimization algorithms; scenario and simulation support what-if analysis.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionVersion rdf:type rdf:Property ;
    rdfs:label 'Projection Version' ;
    rdfs:comment 'Version identifier for this projection scenario. Supports multiple what-if scenarios and plan iterations within the same planning cycle.' ;
    rdfs:domain ind:InventoryProjection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'Quantitative risk score assessing supply chain vulnerabilities (supplier reliability, lead time variability, geopolitical risk) that may impact this projection.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplySource rdf:type rdf:Property ;
    rdfs:label 'Supply Source' ;
    rdfs:comment 'Source of supply for projected receipts (e.g., internal production, external procurement, transfer from another location).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Network Node Id' ;
    rdfs:comment 'Identifier of the originating supply network node (plant, distribution center, warehouse, or external supplier) from which goods are sourced.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:capacityQuantity rdf:type rdf:Property ;
    rdfs:label 'Capacity Quantity' ;
    rdfs:comment 'Maximum throughput capacity of this lane per planning period (day, week, month), representing the upper limit of goods that can be moved. Used by Supply Planning and Sales and Operations Planning (S&OP) for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure for the capacity quantity field, indicating how lane capacity is measured and constrained. [ENUM-REF-CANDIDATE: EA|CS|PL|TU|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory or business compliance requirements applicable to this lane, such as temperature control (Good Manufacturing Practice - GMP), hazardous materials handling (Environmental Protection Agency - EPA), or cross-border customs (Food and Drug Administration - FDA).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryLane rdf:type rdf:Property ;
    rdfs:label 'Is Primary Lane' ;
    rdfs:comment 'Boolean flag indicating whether this lane is the primary (preferred) sourcing route for the destination. True if this is the default lane used under normal conditions; false for backup or secondary lanes.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the supply network lane based on the nature of the sourcing relationship: production (from manufacturing plant), transfer (between internal facilities), external procurement (from supplier), direct shipment (plant to customer), cross-dock (no storage), or drop-ship (supplier to customer).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Standard batch or lot size for replenishment orders on this lane. Orders are typically rounded to multiples of this quantity for operational efficiency (e.g., full pallet, full truckload).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkLaneStatus rdf:type rdf:Property ;
    rdfs:label 'Network Lane Status' ;
    rdfs:comment 'Current lifecycle status of the supply network lane: active (operational), inactive (temporarily disabled), suspended (on hold), planned (future activation), or decommissioned (permanently closed).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Lead Time Days' ;
    rdfs:comment 'Time in days required for order processing, picking, packing, and loading at the source location before shipment begins.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Number of days of safety stock coverage recommended at the destination to buffer against variability in this lanes lead time and demand. Used by Inventory Optimization to calculate safety stock targets.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Sourcing Priority' ;
    rdfs:comment 'Numeric ranking indicating the preference order for this lane when multiple sourcing options exist for the same destination. Lower numbers indicate higher priority (1 = primary, 2 = secondary, etc.). Used by Distribution Requirements Planning (DRP) and Integrated Business Planning (IBP) to determine replenishment routing.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Total planned lead time in days from order placement to goods receipt at destination, including processing time, transportation time, and buffer. Used by Material Requirements Planning (MRP) and Distribution Requirements Planning (DRP) for replenishment calculations.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transportation Lead Time Days' ;
    rdfs:comment 'Transit time in days for goods to move from source to destination, excluding processing and handling time. Component of the total standard lead time.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary method of transportation used for moving goods along this lane: truck (road freight), rail (train), ocean (sea freight), air (air cargo), intermodal (combination), or parcel (small package delivery).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Node Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Node Operations Management Dashboard tracks the manager responsible for each warehouse/distribution node.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityClass rdf:type rdf:Property ;
    rdfs:label 'Capacity Class' ;
    rdfs:comment 'Classification of the supply network node storage and throughput capacity used in IBP supply planning for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the supply network node indicating its role in the supply chain (manufacturing plant, regional distribution center, forward distribution center, co-manufacturer, third-party logistics warehouse, cross-dock facility, or supplier location). [ENUM-REF-CANDIDATE: manufacturing_plant|regional_dc|forward_dc|co_manufacturer|3pl_warehouse|cross_dock|supplier_location — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Units' ;
    rdfs:comment 'Maximum storage capacity of the supply network node measured in standard storage units (pallets, cases, or cubic meters). Used for inventory optimization and DRP planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Uom' ;
    rdfs:comment 'Unit of measure for the storage capacity (pallets, cases, cubic meters, square meters). Aligns with WMS and IBP planning units.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityDaily rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Daily' ;
    rdfs:comment 'Maximum daily throughput capacity of the supply network node measured in standard units (cases, pallets, or production units per day). Used for production and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Uom' ;
    rdfs:comment 'Unit of measure for the daily throughput capacity. Used in production scheduling and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetId rdf:type rdf:Property ;
    rdfs:label 'Otif Target Id' ;
    rdfs:comment 'Unique identifier for the OTIF service level target record.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: OTIF Performance Ownership assigns a responsible employee for each OTIF target in the OTIF Management Dashboard.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Code identifying the customer segment (e.g., national retailers, regional chains, independent stores) to which this OTIF target applies.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryToleranceHours rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Hours' ;
    rdfs:comment 'Acceptable time window variance (in hours) before or after the scheduled delivery time within which delivery is still considered on-time.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Percent' ;
    rdfs:comment 'Performance threshold below which OTIF failures trigger escalation to senior management or customer service recovery actions.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullFillRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'In Full Fill Rate Target Percent' ;
    rdfs:comment 'Target percentage for in-full order fulfillment, representing the proportion of orders that must be delivered with 100% of requested quantity.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Frequency at which OTIF performance against this target is measured and reported to stakeholders.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether financial penalties or chargebacks apply when OTIF performance falls below the target threshold.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Percent' ;
    rdfs:comment 'Percentage rate applied to calculate financial penalties when OTIF targets are not met, typically applied to order value or invoice amount.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Quantity Tolerance Percent' ;
    rdfs:comment 'Acceptable variance percentage for order quantity fulfillment. Orders within this tolerance are considered in-full (e.g., 98% fulfillment may be acceptable).' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Number' ;
    rdfs:comment 'Reference number of the formal SLA document or contract section that defines this OTIF commitment.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Business identifier code for the OTIF target definition, used for external reference and reporting.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Descriptive name of the OTIF target configuration, typically indicating the customer segment or channel it applies to.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetNotes rdf:type rdf:Property ;
    rdfs:label 'Target Notes' ;
    rdfs:comment 'Free-text notes providing additional context, special conditions, or business rationale for this OTIF target definition.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwnerName rdf:type rdf:Property ;
    rdfs:label 'Target Owner Name' ;
    rdfs:comment 'Name of the business owner or supply chain manager accountable for achieving this OTIF target.' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the OTIF target definition (active, inactive, pending approval, expired, suspended).' ;
    rdfs:domain ind:OtifTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningExceptionId rdf:type rdf:Property ;
    rdfs:label 'Planning Exception Id' ;
    rdfs:comment 'Unique identifier for the planning exception record. Primary key for the planning exception entity.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPlanningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Planning Employee Id' ;
    rdfs:comment 'Reference to the supply planner or demand planner assigned to resolve this exception.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPlanningLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Planning Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the planning exception record.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Flag' ;
    rdfs:comment 'Indicates whether the exception was automatically resolved by the system without planner intervention.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Business Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the exception if not resolved, expressed in the reporting currency.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Quantity' ;
    rdfs:comment 'The forecasted demand quantity for the affected SKU-location during the exception period.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionDate rdf:type rdf:Property ;
    rdfs:label 'Exception Date' ;
    rdfs:comment 'The date when the planning exception was identified or when the exception condition is projected to occur.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Exception Quantity' ;
    rdfs:comment 'The magnitude of the exception expressed as a quantity (e.g., shortage quantity, excess quantity, unmet demand quantity).' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionRecurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Exception Recurrence Count' ;
    rdfs:comment 'Number of times this type of exception has occurred for the same SKU-location combination within a defined time window.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'Severity classification of the planning exception indicating the urgency and business impact of the issue.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapQuantity rdf:type rdf:Property ;
    rdfs:label 'Gap Quantity' ;
    rdfs:comment 'The calculated gap between demand and supply that triggered the exception (positive for shortage, negative for excess).' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Date' ;
    rdfs:comment 'The specific date within the planning horizon where the exception condition manifests.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Calculated priority score used to rank exceptions in the planner workbench, based on severity, business impact, and urgency.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedInventoryBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Inventory Balance' ;
    rdfs:comment 'The projected inventory balance at the time of the exception, used to assess the severity of stock-out or excess inventory conditions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Hours' ;
    rdfs:comment 'The elapsed time in hours from exception detection to resolution, used for performance tracking.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTarget rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target' ;
    rdfs:comment 'The target safety stock level for the SKU-location combination at the time of the exception.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyPlanQuantity rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Quantity' ;
    rdfs:comment 'The planned supply quantity (production or replenishment) for the affected SKU-location during the exception period.' ;
    rdfs:domain ind:PlanningException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Primary key for risk_register' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRiskLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Risk Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this risk record, linking to the workforce master data for change tracking and accountability.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRiskCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this risk record in the system, linking to the workforce master data for audit trail and accountability.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the risk was closed or fully mitigated, enabling risk resolution cycle time analysis and mitigation effectiveness measurement.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedNodeList rdf:type rdf:Property ;
    rdfs:label 'Affected Node List' ;
    rdfs:comment 'Comma-separated list of supply network node identifiers (plants, distribution centers, suppliers) that are exposed to this risk, supporting network resilience analysis.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedDate rdf:type rdf:Property ;
    rdfs:label 'Assessed Date' ;
    rdfs:comment 'Date when the risk assessment (probability and impact scoring) was completed, establishing the baseline for risk monitoring.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Contingency Cost Estimate' ;
    rdfs:comment 'Estimated financial cost of implementing the contingency plan, including expedited freight, alternative sourcing premiums, and safety stock carrying costs, measured in the base currency.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Reactive response plan to be executed if the risk materializes, including alternative sourcing strategies, safety stock deployment, and business continuity procedures.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Contingency Stock Quantity' ;
    rdfs:comment 'Additional safety stock quantity recommended to buffer against this risk, expressed in the base unit of measure. Used for inventory optimization and DRP planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyStockUom rdf:type rdf:Property ;
    rdfs:label 'Contingency Stock Uom' ;
    rdfs:comment 'Unit of measure for the contingency stock quantity (e.g., EA, CS, KG, LB), aligned with the SKU base UOM for consistency.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the risk was escalated to higher management levels, tracking the escalation timeline for governance and audit purposes.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the supply chain risk was first identified and entered into the risk register, supporting risk aging and trend analysis.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Quantitative financial estimate of potential loss or cost if the risk event occurs, measured in the base currency. Used for risk prioritization and contingency budget planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Detailed description of the proactive actions and controls implemented to reduce the probability or impact of the risk, including timelines and responsible parties.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Start Date' ;
    rdfs:comment 'Date when mitigation activities commenced, tracking the timeline of risk response execution.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Quantitative assessment of the likelihood that the risk event will occur, expressed as a percentage (0.00 to 100.00) based on historical data, expert judgment, and predictive analytics.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the supply chain risk, including context, potential triggers, and business impact scenarios.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Notes' ;
    rdfs:comment 'Free-form text field for additional context, updates, or observations related to the risk, supporting collaborative risk management and knowledge sharing.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Number' ;
    rdfs:comment 'Business-facing unique identifier for the supply chain risk, formatted as RISK-NNNNNNNN for external communication and tracking.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk: identified (newly discovered), assessed (analysis complete), active (currently impacting operations), mitigated (controls in place), closed (no longer a threat), or monitoring (under observation).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the primary risk category for more precise risk segmentation and analysis.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short descriptive title summarizing the nature of the supply chain risk for quick identification and reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned date by which the risk is expected to be fully mitigated or closed, used for risk management performance tracking and SLA monitoring.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Id' ;
    rdfs:comment 'Unique identifier for the safety stock calculation record. Primary key for the safety stock entity.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Safety Stock Units' ;
    rdfs:comment 'The final approved safety stock quantity in base units of measure after planner review and adjustment. This is the target value used for inventory policy execution and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand Units' ;
    rdfs:comment 'The mean daily demand quantity in base units of measure. Used as input to safety stock calculations and represents expected consumption rate.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'The mean replenishment lead time in days from order placement to receipt. Used in safety stock calculations to determine the exposure period for demand and supply variability.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Calculated Safety Stock Units' ;
    rdfs:comment 'The system-calculated safety stock quantity in base units of measure. This is the raw output from the calculation engine before any manual adjustments or approvals.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply Target' ;
    rdfs:comment 'The target safety stock coverage expressed in days of average demand. Used when calculation method is days-of-supply based. Represents the buffer duration to protect against stockouts.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'The demand pattern category for this SKU-location. Steady indicates consistent demand; seasonal shows periodic peaks; erratic has high variability; lumpy has infrequent large orders; intermittent has sporadic demand; obsolete indicates phase-out. Influences calculation method selection.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit' ;
    rdfs:comment 'The annual cost to hold one unit of inventory including warehousing, insurance, obsolescence, and capital cost. Used in inventory optimization to balance service level against carrying cost. Expressed in local currency.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Review Timestamp' ;
    rdfs:comment 'The date and time when the safety stock record was last reviewed by a planner, regardless of whether changes were made. Used to track planner engagement and ensure regular review cycles.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideNotes rdf:type rdf:Property ;
    rdfs:label 'Override Notes' ;
    rdfs:comment 'Free-text explanation provided by the planner when manually overriding the calculated safety stock. Documents the business context and rationale for the adjustment.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'The business reason code when approved safety stock differs from calculated safety stock. Captures planner judgment factors such as promotional events, seasonal peaks, supply chain risks, new product introductions, product phase-outs, or quality concerns.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'The approval workflow status of the safety stock calculation. Pending review indicates awaiting planner action; approved means active for execution; rejected requires recalculation; under revision is being adjusted; expired indicates the planning period has passed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetServiceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Target Service Level Percent' ;
    rdfs:comment 'The desired in-stock probability or fill rate target expressed as a percentage (e.g., 95.00, 98.50). Drives the safety stock buffer size to achieve the specified On Shelf Availability (OSA) or Service Level Agreement (SLA).' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The standard normal distribution value corresponding to the target service level. Used in statistical safety stock formulas to translate service level percentage into buffer quantity.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backorderAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Allowed Flag' ;
    rdfs:comment 'Indicates whether backorders are permitted for this SKU when inventory is insufficient. True allows demand to be backordered, false requires immediate fulfillment or cancellation.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageProfileDays rdf:type rdf:Property ;
    rdfs:label 'Coverage Profile Days' ;
    rdfs:comment 'Target days of supply to maintain in inventory. Represents desired inventory coverage horizon based on demand forecast and replenishment frequency.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalPartFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Part Flag' ;
    rdfs:comment 'Indicates whether this SKU is classified as a critical part requiring special planning attention. Critical parts may have higher service levels or expedited replenishment.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedLotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size Quantity' ;
    rdfs:comment 'Fixed production or procurement lot size quantity when using fixed lot size method. Represents standard batch size for manufacturing or ordering.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'Time required for quality inspection and goods receipt processing after physical delivery. Adds to total replenishment lead time.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Size Method' ;
    rdfs:comment 'Method used to calculate production or procurement lot sizes. Determines how order quantities are calculated in MRP and supply planning runs.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevelQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Quantity' ;
    rdfs:comment 'Maximum inventory level target for this SKU. Used in min-max planning to cap inventory investment and prevent overstock situations.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for this SKU. Used for workload assignment and exception management routing.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure that controls how the planning system generates procurement proposals. Determines planning logic and automation level.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultipleQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Multiple Quantity' ;
    rdfs:comment 'Quantity increment in which orders must be placed. All order quantities must be multiples of this value due to packaging or production constraints.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterNotes rdf:type rdf:Property ;
    rdfs:label 'Parameter Notes' ;
    rdfs:comment 'Free-text notes documenting special planning considerations, parameter rationale, or exceptions for this SKU. Provides context for planning decisions.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle status of the planning parameter record. Active parameters are used in planning runs, inactive parameters are ignored.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'Standard lead time in days from order placement to goods receipt. Used for MRP scheduling and supply plan timing calculations.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Number of days into the future for which demand and supply planning is performed. Defines the forward-looking planning window for this SKU.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningStrategy rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy' ;
    rdfs:comment 'Manufacturing planning strategy that determines how the SKU is planned and produced. Make-to-stock produces to forecast, make-to-order produces against customer orders.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Planning Time Fence Days' ;
    rdfs:comment 'Number of days within which the planning system cannot automatically change planned orders without planner approval. Protects near-term production schedule stability.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundingProfileCode rdf:type rdf:Property ;
    rdfs:label 'Rounding Profile Code' ;
    rdfs:comment 'Code defining rounding rules for planned order quantities. Ensures quantities align with packaging units, pallet configurations, or production batch constraints.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'Method used to calculate safety stock levels. Fixed quantity uses static buffer, service level based uses demand variability and lead time uncertainty.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityProfileCode rdf:type rdf:Property ;
    rdfs:label 'Seasonality Profile Code' ;
    rdfs:comment 'Code identifying the seasonality pattern applied to this SKU for demand forecasting. Links to predefined seasonal index curves (e.g., summer peak, holiday spike).' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySopEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sop Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for orchestrating and governing this S&OP cycle (typically the Demand Planning Manager or S&OP Manager).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySopExecutiveSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Sop Executive Sponsor Employee Id' ;
    rdfs:comment 'Identifier of the executive sponsor who chairs the executive S&OP meeting and provides final sign-off (typically VP of Supply Chain or COO).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinarySopLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Sop Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this S&OP cycle record.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySopSupplyPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sop Supply Planner Employee Id' ;
    rdfs:comment 'Identifier of the lead supply planner responsible for the supply review phase of this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineDemandVolume rdf:type rdf:Property ;
    rdfs:label 'Baseline Demand Volume' ;
    rdfs:comment 'The total baseline demand volume (in units) across all SKUs for the planning horizon at the start of this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDemandVolume rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Volume' ;
    rdfs:comment 'The total consensus demand volume (in units) across all SKUs after demand review adjustments.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constrainedSupplyVolume rdf:type rdf:Property ;
    rdfs:label 'Constrained Supply Volume' ;
    rdfs:comment 'The total constrained supply volume (in units) that can be delivered given capacity and material constraints.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the cycle for external reference and system integration (e.g., \'SOP-2024-01\', \'IBP-Q1-24\').' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Cycle End Date' ;
    rdfs:comment 'The date when this S&OP cycle is scheduled to complete and be locked (typically before the start of the planning month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleLockedDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Locked Date' ;
    rdfs:comment 'The date when this S&OP cycle was locked and finalized.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Cycle Locked Flag' ;
    rdfs:comment 'Indicates whether this S&OP cycle has been locked and no further changes are permitted (True if locked, False if still open for edits).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Business-friendly name or label for the S&OP cycle (e.g., \'January 2024 S&OP Cycle\', \'Q1 FY2024 IBP\').' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNotes rdf:type rdf:Property ;
    rdfs:label 'Cycle Notes' ;
    rdfs:comment 'General free-text notes or comments about this S&OP cycle, including special circumstances, deviations from standard process, or other relevant context.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclePhase rdf:type rdf:Property ;
    rdfs:label 'Cycle Phase' ;
    rdfs:comment 'Current phase of the S&OP cycle: statistical_forecast (initial statistical forecast generation), demand_review (demand planning team review), supply_review (supply planning team review), pre_sop (pre-S&OP reconciliation meeting), executive_sop (executive S&OP decision meeting), closed (cycle completed and locked).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Start Date' ;
    rdfs:comment 'The date when this S&OP cycle officially begins (typically the first day of the cycle month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'The cadence or type of S&OP cycle: monthly (standard monthly cadence), quarterly (quarterly review), annual (annual planning), rolling (continuous rolling horizon), event_driven (triggered by specific business events).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandConsensusAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Demand Consensus Achieved Flag' ;
    rdfs:comment 'Indicates whether demand consensus was achieved during the demand review phase (True if consensus reached, False otherwise).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Demand Review Due Date' ;
    rdfs:comment 'Target date by which the demand review phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Date' ;
    rdfs:comment 'The date when the executive sponsor formally approved the S&OP plan for this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Flag' ;
    rdfs:comment 'Indicates whether the executive S&OP meeting approved the plan (True if approved, False if rejected or pending).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executiveApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Notes' ;
    rdfs:comment 'Free-text notes or comments from the executive sponsor regarding the approval decision, including any conditions or action items.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Executive Sop Meeting Date' ;
    rdfs:comment 'Scheduled date for the executive S&OP meeting where senior leadership reviews and approves the plan.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frozenPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Frozen Period Months' ;
    rdfs:comment 'The number of months at the start of the planning horizon that are frozen and not subject to change (typically 0-3 months).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Free-text field capturing the key business assumptions underlying this S&OP cycle (e.g., promotional plans, market trends, supply constraints, new product launches).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRisks rdf:type rdf:Property ;
    rdfs:label 'Key Risks' ;
    rdfs:comment 'Free-text field documenting the key risks identified during this S&OP cycle (e.g., supplier reliability, demand volatility, capacity constraints).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActions rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions' ;
    rdfs:comment 'Free-text field describing the mitigation actions agreed upon to address identified risks and supply gaps.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Status of the current cycle phase: not_started (phase has not begun), in_progress (phase is actively underway), completed (phase finished and approved), on_hold (phase temporarily paused), cancelled (phase or cycle cancelled).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'The number of months into the future that this S&OP cycle plans (e.g., 18 months, 24 months).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMonth rdf:type rdf:Property ;
    rdfs:label 'Planning Month' ;
    rdfs:comment 'The target month for which this S&OP cycle is planning demand and supply (typically the first day of the planning month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Meeting Date' ;
    rdfs:comment 'Scheduled date for the pre-S&OP reconciliation meeting where demand and supply teams align on recommendations.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statisticalForecastDueDate rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Due Date' ;
    rdfs:comment 'Target date by which the statistical forecast phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyConsensusAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Consensus Achieved Flag' ;
    rdfs:comment 'Indicates whether supply consensus was achieved during the supply review phase (True if consensus reached, False otherwise).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyGapVolume rdf:type rdf:Property ;
    rdfs:label 'Supply Gap Volume' ;
    rdfs:comment 'The total supply gap (in units) representing the difference between consensus demand and constrained supply (positive indicates shortfall, negative indicates surplus).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Supply Review Due Date' ;
    rdfs:comment 'Target date by which the supply review phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Unique identifier for the supply plan record. Primary key for the supply plan entity.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether the supply plan is constrained by production or distribution capacity limitations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date when this supply plan was executed or committed, triggering downstream production orders or purchase requisitions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Material Constraint Flag' ;
    rdfs:comment 'Indicates whether the supply plan is constrained by raw material or component availability.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedOrderReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Order Release Date' ;
    rdfs:comment 'The date when the production order or purchase order should be released to meet the planned receipt date, accounting for lead times.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedProductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Production Quantity' ;
    rdfs:comment 'The quantity of the SKU planned to be produced at the specified plant during the planning period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The date when the planned supply quantity is expected to be received or available at the destination location.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReplenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Replenishment Quantity' ;
    rdfs:comment 'The quantity of the SKU planned to be replenished or transferred to the distribution center during the planning period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Constraint Flag' ;
    rdfs:comment 'Indicates whether the supply plan is constrained by transportation or logistics capacity limitations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyReplenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the supply replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drpRunId rdf:type rdf:Property ;
    rdfs:label 'Drp Run Id' ;
    rdfs:comment 'Identifier of the DRP execution run that generated this replenishment order, used for traceability and audit.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrpRun .

ind:primarySupplyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that created this replenishment order record.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date the goods were received at the destination location.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Drp Run Timestamp' ;
    rdfs:comment 'Date and time when the DRP execution run that generated this order was executed.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'Forecasted demand quantity at the destination location that drove the replenishment calculation.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCostAmount rdf:type rdf:Property ;
    rdfs:label 'Order Cost Amount' ;
    rdfs:comment 'Total cost associated with this replenishment order, including product cost, transportation cost, and handling fees.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Lead Time Days' ;
    rdfs:comment 'Planned number of days for goods to travel from source to destination location.' ;
    rdfs:domain ind:SupplyReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biodiversityImpactId rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Impact Id' ;
    rdfs:comment 'System-generated unique identifier for each biodiversity impact assessment record.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Unique identifier of the geographic sourcing region associated with the assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'Version number of the assessment methodology applied.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorEmail rdf:type rdf:Property ;
    rdfs:label 'Assessor Email' ;
    rdfs:comment 'Email address of the assessor for follow-up or verification.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Impact Category' ;
    rdfs:comment 'Primary category describing the nature of the biodiversity impact.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityScoreMethod rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Score Method' ;
    rdfs:comment 'Method used to calculate the net biodiversity impact score.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landUseAreaHa rdf:type rdf:Property ;
    rdfs:label 'Land Use Area Ha' ;
    rdfs:comment 'Total area in hectares covered by the land use type within the assessment scope.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landUseType rdf:type rdf:Property ;
    rdfs:label 'Land Use Type' ;
    rdfs:comment 'Classification of the land use category for the area assessed. [ENUM-REF-CANDIDATE: agriculture|forestry|mining|urban|wetland|grassland|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Narrative description of mitigation actions implemented to address the identified impact.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBiodiversityImpactScore rdf:type rdf:Property ;
    rdfs:label 'Net Biodiversity Impact Score' ;
    rdfs:comment 'Calculated score representing the overall net effect on biodiversity after mitigation, on a standardized scale.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proximityToProtectedAreaKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Protected Area Km' ;
    rdfs:comment 'Linear distance in kilometers from the facility or sourcing region to the nearest protected area or biodiversity hotspot.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tnfdDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Tnfd Disclosure Flag' ;
    rdfs:comment 'Indicates whether the assessment is included in TNFD disclosures.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tnfdRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Tnfd Risk Classification' ;
    rdfs:comment 'Risk level as defined by the Taskforce on Nature-related Financial Disclosures (TNFD) framework.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainActivityId rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Activity Id' ;
    rdfs:comment 'Identifier of the upstream or downstream activity (e.g., raw material extraction, logistics) linked to the emission.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyChainActivity .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Methodology used to calculate the emission (e.g., GHG Protocol, ISO 14064, or custom model).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonIntensityFactor rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Factor' ;
    rdfs:comment 'Ratio of emissions to production output (e.g., tonnes CO₂e per unit produced).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdprReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Cdpr Reporting Flag' ;
    rdfs:comment 'Indicates whether the emission record must be disclosed to CDP.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Co2e Quantity Tonnes' ;
    rdfs:comment 'Measured or calculated greenhouse gas emissions expressed as carbon dioxide equivalent in metric tonnes.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Factor applied in the calculation, expressed in CO₂e per unit of activity (e.g., kg CO₂e per kWh).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorDate rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Date' ;
    rdfs:comment 'Effective date of the emission factor applied.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Source' ;
    rdfs:comment 'Reference or provider of the emission factor used.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorVersion rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Version' ;
    rdfs:comment 'Version identifier of the emission factor dataset.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Source Category' ;
    rdfs:comment 'Category of emission source such as combustion, electricity use, transport, raw material processing, waste, or other.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Emission Timestamp' ;
    rdfs:comment 'Date and time when the emission measurement or calculation was recorded.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:energyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Mwh' ;
    rdfs:comment 'Total energy consumed associated with the emission event, expressed in megawatt-hours.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReportingStandard rdf:type rdf:Property ;
    rdfs:label 'External Reporting Standard' ;
    rdfs:comment 'Standard used for external ESG reporting of this emission.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Three-letter ISO country code where the emission occurred.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalProjectCode rdf:type rdf:Property ;
    rdfs:label 'Internal Project Code' ;
    rdfs:comment 'Code of the internal sustainability project linked to the emission.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measurement for the emission quantity; default is tonnes of CO₂e.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Offset Quantity Tonnes' ;
    rdfs:comment 'Quantity of CO₂e offset, in metric tonnes.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetType rdf:type rdf:Property ;
    rdfs:label 'Offset Type' ;
    rdfs:comment 'Category of carbon offset applied.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Fiscal or calendar year for which the emission is reported.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'GHG accounting scope: Scope 1 (direct), Scope 2 (purchased energy), or Scope 3 (value chain).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Water Consumption M3' ;
    rdfs:comment 'Volume of water used in the process linked to the emission, in cubic metres.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alignmentType rdf:type rdf:Property ;
    rdfs:label 'Alignment Type' ;
    rdfs:comment 'Strategic alignment of the credit (temporary offset vs. permanent removal).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetStatus rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Status' ;
    rdfs:comment 'Current lifecycle status of the offset record.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the offset complies with relevant ESG and regulatory frameworks (e.g., ISO 14064).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerTonne rdf:type rdf:Property ;
    rdfs:label 'Cost Per Tonne' ;
    rdfs:comment 'Purchase price per tonne of CO₂e in US dollars.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditQuantityPurchased rdf:type rdf:Property ;
    rdfs:label 'Credit Quantity Purchased' ;
    rdfs:comment 'Total tonnes of CO₂ equivalent purchased.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditQuantityRetired rdf:type rdf:Property ;
    rdfs:label 'Credit Quantity Retired' ;
    rdfs:comment 'Total tonnes of CO₂ equivalent retired (used for offsetting).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative describing the offset project\'s objectives and activities.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocation rdf:type rdf:Property ;
    rdfs:label 'Project Location' ;
    rdfs:comment 'Geographic location (city, region) where the offset project is implemented.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Certificate Number' ;
    rdfs:comment 'Unique identifier of the purchase certificate issued by the registry.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registry rdf:type rdf:Property ;
    rdfs:label 'Registry' ;
    rdfs:comment 'Standard registry that validates and tracks the offset credits.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Retirement Certificate Number' ;
    rdfs:comment 'Registry-issued certificate number confirming retirement.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Aggregate cost = cost_per_tonne × credit_quantity_purchased.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which the carbon credits were generated.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circularInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Circular Initiative Id' ;
    rdfs:comment 'Unique system-generated identifier for the circular initiative.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CircularInitiative .

ind:carbonFootprintAvoidedTonnes rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Avoided Tonnes' ;
    rdfs:comment 'Estimated tonnes of CO₂ emissions avoided due to the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circularInitiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Circular Initiative Status' ;
    rdfs:comment 'Current lifecycle state of the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFscCertified rdf:type rdf:Property ;
    rdfs:label 'Compliance Fsc Certified' ;
    rdfs:comment 'True if the initiative meets Forest Stewardship Council (FSC) certification requirements.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRspoCertified rdf:type rdf:Property ;
    rdfs:label 'Compliance Rspo Certified' ;
    rdfs:comment 'True if the initiative meets Roundtable on Sustainable Palm Oil (RSPO) certification requirements.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerParticipationRatePct rdf:type rdf:Property ;
    rdfs:label 'Consumer Participation Rate Pct' ;
    rdfs:comment 'Percentage of target consumers who have participated in the program.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityStatus rdf:type rdf:Property ;
    rdfs:label 'Data Quality Status' ;
    rdfs:comment 'Assessment of the data quality for this record.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energySavingsMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Savings Mwh' ;
    rdfs:comment 'Energy saved (megawatt-hours) as a result of the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativeBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Initiative Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the investment amount.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Business code used to reference the initiative in external systems and reports.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Human-readable name of the circular economy program.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeOwner rdf:type rdf:Property ;
    rdfs:label 'Initiative Owner' ;
    rdfs:comment 'Name of the internal business owner responsible for the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Initiative Owner Email' ;
    rdfs:comment 'Email address of the initiative owner.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Investment Amount Usd' ;
    rdfs:comment 'Capital invested in the initiative, expressed in US dollars.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPublicReportable rdf:type rdf:Property ;
    rdfs:label 'Is Public Reportable' ;
    rdfs:comment 'Indicates whether the initiative data may be disclosed publicly.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Compliance rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Compliance' ;
    rdfs:comment 'True if the initiative complies with ISO 14001 environmental management standards.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastProgressDate rdf:type rdf:Property ;
    rdfs:label 'Last Progress Date' ;
    rdfs:comment 'Date of the most recent progress update.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialDivertedTonnes rdf:type rdf:Property ;
    rdfs:label 'Material Diverted Tonnes' ;
    rdfs:comment 'Total tonnes of material diverted from landfill or virgin feedstock.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialRecoveredTonnes rdf:type rdf:Property ;
    rdfs:label 'Material Recovered Tonnes' ;
    rdfs:comment 'Total tonnes of material recovered through the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerOrganizations rdf:type rdf:Property ;
    rdfs:label 'Partner Organizations' ;
    rdfs:comment 'List of external partners (e.g., recyclers, NGOs) involved in the initiative.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Category of circular initiative (e.g., take-back program, refillable packaging).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressStatus rdf:type rdf:Property ;
    rdfs:label 'Progress Status' ;
    rdfs:comment 'Current progress indicator against defined KPIs.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'External sustainability reporting framework used for disclosure.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderGroup rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Group' ;
    rdfs:comment 'Primary stakeholder group(s) impacted by the initiative (e.g., consumers, suppliers).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEndDate rdf:type rdf:Property ;
    rdfs:label 'Target End Date' ;
    rdfs:comment 'Planned end or sunset date for the initiative.' ;
    rdfs:domain ind:CircularInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMaterial rdf:type rdf:Property ;
    rdfs:label 'Target Material' ;
    rdfs:comment 'Primary material or product category the initiative aims to address.' ;
