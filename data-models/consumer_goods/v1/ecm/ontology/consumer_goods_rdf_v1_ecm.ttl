ind:contentPreference rdf:type rdf:Property ;
    rdfs:label 'Content Preference' ;
    rdfs:comment 'Types of marketing content that resonate with this segment (e.g., educational, promotional, user-generated, influencer, video).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Level' ;
    rdfs:comment 'Level of digital channel engagement and activity for consumers in this segment (social media, email, mobile app, e-commerce).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
