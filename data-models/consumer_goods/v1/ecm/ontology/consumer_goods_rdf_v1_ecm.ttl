ind:priceSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Level' ;
    rdfs:comment 'Degree of price sensitivity and responsiveness to promotions and discounts for consumers in this segment.' ;
    rdfs:domain ind:ConsumerSegment ;
