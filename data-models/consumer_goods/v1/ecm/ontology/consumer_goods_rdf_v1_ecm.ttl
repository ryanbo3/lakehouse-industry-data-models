    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingBoundary rdf:type rdf:Property ;
    rdfs:label 'Reporting Boundary' ;
    rdfs:comment 'Geographic or organizational scope of the measurement (facility-level, regional, or global).' ;
