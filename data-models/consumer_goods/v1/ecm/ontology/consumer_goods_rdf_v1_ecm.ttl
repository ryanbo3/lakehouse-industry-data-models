    rdfs:range xsd:decimal .

ind:supplierEsgEvalStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Esg Eval Status' ;
    rdfs:comment 'Current lifecycle status of the ESG assessment.' ;
    rdfs:domain ind:SupplierEsgEval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierRiskLevel rdf:type rdf:Property ;
