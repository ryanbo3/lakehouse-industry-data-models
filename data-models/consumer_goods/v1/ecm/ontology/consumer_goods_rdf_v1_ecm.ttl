    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carbonEmissionEstimateTonnes rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Estimate Tonnes' ;
    rdfs:comment 'Estimated CO₂ emissions (tonnes) linked to the commodity\'s production.' ;
    rdfs:domain ind:DeforestationAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Certification Coverage Percent' ;
    rdfs:comment 'Proportion of the supply chain covered by recognized sustainability certifications.' ;
