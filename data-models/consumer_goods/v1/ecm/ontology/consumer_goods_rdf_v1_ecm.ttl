ind:materialCompositionGlassPercent rdf:type rdf:Property ;
    rdfs:label 'Material Composition Glass Percent' ;
    rdfs:comment 'Proportion of glass material in the packaging component.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCompositionPaperPercent rdf:type rdf:Property ;
    rdfs:label 'Material Composition Paper Percent' ;
    rdfs:comment 'Proportion of paper or cardboard material in the packaging component.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCompositionPcrPercent rdf:type rdf:Property ;
    rdfs:label 'Material Composition Pcr Percent' ;
    rdfs:comment 'Percentage of the material that is post-consumer recycled content.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCompositionVirginPercent rdf:type rdf:Property ;
    rdfs:label 'Material Composition Virgin Percent' ;
    rdfs:comment 'Percentage of virgin (non-recycled) plastic in the packaging.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialPrimary rdf:type rdf:Property ;
    rdfs:label 'Material Primary' ;
    rdfs:comment 'Main material used for the packaging component.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSource rdf:type rdf:Property ;
    rdfs:label 'Material Source' ;
    rdfs:comment 'Narrative description of the material source (e.g., "recycled PET from post-consumer bottles").' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingHeightCm rdf:type rdf:Property ;
    rdfs:label 'Packaging Height Cm' ;
    rdfs:comment 'External height of the packaging component in centimeters.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLengthCm rdf:type rdf:Property ;
    rdfs:label 'Packaging Length Cm' ;
    rdfs:comment 'External length of the packaging component in centimeters.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingName rdf:type rdf:Property ;
    rdfs:label 'Packaging Name' ;
    rdfs:comment 'Human-readable name describing the packaging configuration (e.g., "Eco-Lite Primary Bottle").' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Profile Status' ;
    rdfs:comment 'Current lifecycle state of the packaging profile.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingSupplier rdf:type rdf:Property ;
    rdfs:label 'Packaging Supplier' ;
    rdfs:comment 'Name of the external supplier providing the packaging component.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Packaging Weight Grams' ;
    rdfs:comment 'Total weight of the packaging component in grams.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingWidthCm rdf:type rdf:Property ;
    rdfs:label 'Packaging Width Cm' ;
    rdfs:comment 'External width of the packaging component in centimeters.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'SKU of the product that uses this packaging configuration.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclabilityRating rdf:type rdf:Property ;
    rdfs:label 'Recyclability Rating' ;
    rdfs:comment 'Indicates whether the packaging is recyclable, non-recyclable, or rating unknown.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusable rdf:type rdf:Property ;
    rdfs:label 'Reusable' ;
    rdfs:comment 'True if the packaging is designed for multiple use cycles.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitsPerPackage rdf:type rdf:Property ;
    rdfs:label 'Units Per Package' ;
    rdfs:comment 'Number of individual product units contained in a single packaging unit.' ;
    rdfs:domain ind:PackagingProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterUsageLiters rdf:type rdf:Property ;
    rdfs:label 'Water Usage Liters' ;
    rdfs:comment 'Volume of water consumed in the production of the packaging component.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationFsc rdf:type rdf:Property ;
    rdfs:label 'Certification Fsc' ;
    rdfs:comment 'Indicates whether the product’s raw material sourcing is FSC-certified.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationRspo rdf:type rdf:Property ;
    rdfs:label 'Certification Rspo' ;
    rdfs:comment 'Indicates whether the product’s palm oil sourcing complies with RSPO standards.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Functional Unit Quantity' ;
    rdfs:comment 'Numeric amount defining the functional unit (e.g., 1, 100).' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalUnitUom rdf:type rdf:Property ;
    rdfs:label 'Functional Unit Uom' ;
    rdfs:comment 'Unit of measure for the functional unit (e.g., kg, litre, unit).' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hotspotStages rdf:type rdf:Property ;
    rdfs:label 'Hotspot Stages' ;
    rdfs:comment 'Comma-separated list of life-cycle stages that contribute the most to environmental impact. [ENUM-REF-CANDIDATE: raw_material|manufacturing|distribution|use|end_of_life — promote to reference product]' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14040ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14040 Compliance Flag' ;
    rdfs:comment 'Indicates whether the study complies with ISO 14040/14044 methodology.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcaPractitioner rdf:type rdf:Property ;
    rdfs:label 'Lca Practitioner' ;
    rdfs:comment 'Name or identifier of the analyst or team that performed the LCA.' ;
    rdfs:domain ind:ProductLca ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcaStudyType rdf:type rdf:Property ;
    rdfs:label 'Lca Study Type' ;
    rdfs:comment 'Scope of the LCA study indicating the system boundaries.' ;
