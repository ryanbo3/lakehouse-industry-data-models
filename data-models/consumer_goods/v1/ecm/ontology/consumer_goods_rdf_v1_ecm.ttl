    rdfs:comment 'Score for the ethics pillar of the ESG assessment.' ;
    rdfs:domain ind:SupplierEsgEval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentation rdf:type rdf:Property ;
    rdfs:label 'Evidence Documentation' ;
    rdfs:comment 'Reference (e.g., URL or document ID) to supporting evidence uploaded for the assessment.' ;
    rdfs:domain ind:SupplierEsgEval ;
    rdf:type owl:DatatypeProperty ;
