    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMethodology rdf:type rdf:Property ;
    rdfs:label 'Rating Methodology' ;
    rdfs:comment 'Narrative description of the methodology and weighting used to calculate scores.' ;
    rdfs:domain ind:SupplierEsgEval ;
    rdf:type owl:DatatypeProperty ;
