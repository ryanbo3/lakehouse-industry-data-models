    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExtractDate rdf:type rdf:Property ;
    rdfs:label 'Data Extract Date' ;
    rdfs:comment 'Date when this panel insight data was extracted from the Nielsen IQ source system.' ;
    rdfs:domain ind:NielsenPanelInsight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:householdPenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Household Penetration Rate' ;
    rdfs:comment 'Percentage of panel households that purchased the category, brand, or SKU during the panel period. Expressed as a decimal (e.g., 0.2345 = 23.45%).' ;
    rdfs:domain ind:NielsenPanelInsight ;
