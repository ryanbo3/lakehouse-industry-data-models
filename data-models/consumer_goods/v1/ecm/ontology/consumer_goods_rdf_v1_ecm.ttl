    rdfs:range xsd:string .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Unique identifier for the media plan record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Media planner employee owns the plan; needed for budget approval audit and planner workload tracking.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Percent' ;
    rdfs:comment 'Percentage of total campaign or brand budget allocated to this media plan line.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeFormat rdf:type rdf:Property ;
