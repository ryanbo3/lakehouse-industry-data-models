    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualitySampleId rdf:type rdf:Property ;
    rdfs:label 'Quality Sample Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_sample. Business justification: Influencers receive seeding samples for content creation. Engagement records track which approved samples were sent for inventory control and compliance—ensuring only approved products are publicly sh' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
