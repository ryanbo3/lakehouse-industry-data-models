ind:primaryFiber rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber' ;
    rdfs:comment 'The dominant fiber in the fabric composition (e.g., Cotton, Polyester, Wool, Nylon, Spandex).' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printMethod rdf:type rdf:Property ;
    rdfs:label 'Print Method' ;
    rdfs:comment 'The technique used to apply patterns or designs to the fabric surface.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonSuitability rdf:type rdf:Property ;
    rdfs:label 'Season Suitability' ;
    rdfs:comment 'The seasonal collections or climate conditions for which this fabric is most appropriate.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchType rdf:type rdf:Property ;
    rdfs:label 'Stretch Type' ;
    rdfs:comment 'Indicates the directional stretch characteristics of the fabric.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'More granular classification within the fabric category (e.g., jersey, twill, satin, fleece, mesh).' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suitableForProductCategory rdf:type rdf:Property ;
    rdfs:label 'Suitable For Product Category' ;
    rdfs:comment 'Recommended apparel or accessory categories for which this fabric type is best suited (e.g., activewear, outerwear, casualwear, footwear uppers, accessories). [ENUM-REF-CANDIDATE: activewear|outerwear|casualwear|formalwear|footwear|accessories|intimates|swimwear — promote to reference product]' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tearStrengthRating rdf:type rdf:Property ;
    rdfs:label 'Tear Strength Rating' ;
    rdfs:comment 'Assessment of the force required to propagate a tear in the fabric.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:texture rdf:type rdf:Property ;
    rdfs:label 'Texture' ;
    rdfs:comment 'The tactile surface quality of the fabric (e.g., smooth, brushed, ribbed, textured, slub).' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uvProtectionRating rdf:type rdf:Property ;
    rdfs:label 'Uv Protection Rating' ;
    rdfs:comment 'The fabric\'s ability to block ultraviolet radiation, expressed as a UPF value.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
