    rdfs:range xsd:boolean .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The Gregorian calendar month (1-12) in which the majority of this fiscal week falls.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The Gregorian calendar year in which the majority of this fiscal week falls, represented as a four-digit year.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparableWeekPriorYear rdf:type rdf:Property ;
    rdfs:label 'Comparable Week Prior Year' ;
    rdfs:comment 'Reference to the fiscal week identifier from the prior year that is comparable for year-over-year (YoY) analysis, accounting for calendar shifts.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysInWeek rdf:type rdf:Property ;
    rdfs:label 'Days In Week' ;
    rdfs:comment 'The actual number of calendar days in this fiscal week, typically 7 but may vary at fiscal year boundaries or in leap week years.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
