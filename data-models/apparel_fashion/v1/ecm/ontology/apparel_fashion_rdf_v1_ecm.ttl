ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Comma-separated list of quality management certifications held by the 3PL partner (e.g., ISO 9001, WRAP, FLA). [ENUM-REF-CANDIDATE: ISO_9001|ISO_14001|ISO_45001|WRAP|FLA|CTPAT|AEO|TAPA — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsProcessingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Capable Flag' ;
    rdfs:comment 'Indicates whether the 3PL partner has capabilities to process customer returns, including inspection, restocking, and disposition management.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Contractual service level tier defining performance commitments, response times, and quality standards for this 3PL partnership.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether the 3PL partner holds recognized sustainability or environmental certifications (e.g., ISO 14001, SmartWay, LEED).' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Tax identification number (EIN, VAT, GST) for the 3PL partner used for tax reporting and compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWarehouseSqft rdf:type rdf:Property ;
    rdfs:label 'Total Warehouse Sqft' ;
    rdfs:comment 'Total warehouse storage capacity in square feet across all facilities operated by this 3PL partner.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCount rdf:type rdf:Property ;
    rdfs:label 'Warehouse Count' ;
    rdfs:comment 'Total number of warehouse or distribution center facilities operated by this 3PL partner within their coverage regions.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Type' ;
    rdfs:comment 'Technical integration method used to connect the 3PL partner\'s WMS with internal systems. API indicates real-time REST/SOAP integration, EDI 940/945 uses standard warehouse transaction sets, flat file uses CSV/XML batch files, SFTP uses secure file transfer, and none indicates manual processes.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateConversionId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Conversion Id' ;
    rdfs:comment 'Unique identifier for the affiliate conversion event. Primary key for the affiliate conversion record.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliatePartnerId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Partner Id' ;
    rdfs:comment 'Reference to the affiliate partner who drove this conversion event.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliatePartner .

ind:subAffiliateAffiliatePartnerId rdf:type rdf:Property ;
    rdfs:label 'Sub Affiliate Affiliate Partner Id' ;
    rdfs:comment 'Identifier for the sub-affiliate or publisher within the affiliate partner network who generated the conversion.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliatePartner .

ind:affiliateNetworkName rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network Name' ;
    rdfs:comment 'Name of the affiliate network platform managing this conversion (e.g., Commission Junction, ShareASale, Rakuten).' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'Total revenue amount attributed to this affiliate conversion, representing the order value or lead value generated.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Commission amount owed or paid to the affiliate partner for this conversion based on agreed commission structure.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Percentage rate applied to calculate the commission amount for this conversion.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Current status of the conversion in the commission lifecycle: pending validation, approved for payment, paid to affiliate, reversed due to return or fraud, rejected, or cancelled.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Type of conversion event tracked: click, lead generation, completed sale, customer signup, content download, or add to cart action.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieDurationDays rdf:type rdf:Property ;
    rdfs:label 'Cookie Duration Days' ;
    rdfs:comment 'Number of days the affiliate tracking cookie was valid for this conversion, determining the attribution window.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cookieMatchType rdf:type rdf:Property ;
    rdfs:label 'Cookie Match Type' ;
    rdfs:comment 'Attribution model used to credit this conversion: first-click, last-click, linear, time-decay, or position-based attribution.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location of the customer at conversion time.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'Geographic region or state where the conversion occurred, used for regional affiliate performance analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Network Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the affiliate network platform for reconciliation and reporting.' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCustomerFlag rdf:type rdf:Property ;
    rdfs:label 'New Customer Flag' ;
    rdfs:comment 'Indicates whether this conversion represents a new customer acquisition (true) or a repeat customer purchase (false).' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Date and time when the commission was paid to the affiliate partner.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Promotional or coupon code used by the customer during this conversion, often unique to the affiliate partner.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason for conversion reversal if status is reversed: order cancelled, product returned, payment failed, or fraud detected.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the conversion was reversed due to order cancellation, return, or fraud detection.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trackingCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Code' ;
    rdfs:comment 'Unique tracking code or parameter appended to the affiliate link to identify the source and enable conversion tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSource rdf:type rdf:Property ;
    rdfs:label 'Traffic Source' ;
    rdfs:comment 'Specific traffic source or placement within the affiliate channel (e.g., blog post URL, email campaign name, social post ID).' ;
    rdfs:domain ind:AffiliateConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateNetwork rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network' ;
    rdfs:comment 'Name of the affiliate network or platform through which the partner relationship is managed (e.g., CJ Affiliate, Rakuten, ShareASale, Impact).' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandBiddingAllowed rdf:type rdf:Property ;
    rdfs:label 'Brand Bidding Allowed' ;
    rdfs:comment 'Indicates whether the affiliate partner is permitted to bid on brand keywords in paid search campaigns.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for commission payments.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Flat Amount' ;
    rdfs:comment 'Fixed commission amount per conversion for flat-fee commission structures.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionStructure rdf:type rdf:Property ;
    rdfs:label 'Commission Structure' ;
    rdfs:comment 'Type of commission model applied to the affiliate partner (percentage of sale, flat fee per conversion, Cost Per Acquisition, Cost Per Click, tiered rates, or hybrid).' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cookie Window Days' ;
    rdfs:comment 'Number of days after a click during which a conversion can be attributed to this affiliate partner.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deepLinkingEnabled rdf:type rdf:Property ;
    rdfs:label 'Deep Linking Enabled' ;
    rdfs:comment 'Indicates whether the affiliate partner is authorized to create deep links directly to product pages.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the affiliate partner has an exclusive partnership agreement preventing promotion of competitor brands.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Level' ;
    rdfs:comment 'Assessed fraud risk level for this affiliate partner based on traffic quality, conversion patterns, and compliance history.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConversionDate rdf:type rdf:Property ;
    rdfs:label 'Last Conversion Date' ;
    rdfs:comment 'Date of the most recent conversion attributed to this affiliate partner.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPayoutDate rdf:type rdf:Property ;
    rdfs:label 'Last Payout Date' ;
    rdfs:comment 'Date of the most recent commission payout to this affiliate partner.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumPayoutThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Payout Threshold' ;
    rdfs:comment 'Minimum accumulated commission amount required before payout is processed.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the affiliate partner relationship.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Performance-based tier classification of the affiliate partner determining commission rates and benefits.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the affiliate partner by business model and channel type.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Composite performance score (0-100) evaluating the affiliate partner based on conversion rate, revenue quality, fraud risk, and compliance.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategories rdf:type rdf:Property ;
    rdfs:label 'Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories the affiliate partner is authorized to promote (e.g., mens_apparel, womens_footwear, accessories).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarkets rdf:type rdf:Property ;
    rdfs:label 'Target Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets or regions the affiliate partner operates in (e.g., USA, GBR, DEU, FRA).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAttributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Attributed Revenue' ;
    rdfs:comment 'Cumulative revenue attributed to this affiliate partner across all conversions since partnership inception.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommissionPaid rdf:type rdf:Property ;
    rdfs:label 'Total Commission Paid' ;
    rdfs:comment 'Cumulative commission amount paid to this affiliate partner since partnership inception.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalConversionsCount rdf:type rdf:Property ;
    rdfs:label 'Total Conversions Count' ;
    rdfs:comment 'Cumulative number of conversions attributed to this affiliate partner since partnership inception.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingDomain rdf:type rdf:Property ;
    rdfs:label 'Tracking Domain' ;
    rdfs:comment 'Domain or subdomain used for affiliate tracking links and conversion attribution.' ;
    rdfs:domain ind:AffiliatePartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL of the affiliate partner where promotional content is published.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Attribution Touchpoint Id' ;
    rdfs:comment 'Unique identifier for the attribution touchpoint record. Primary key.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Reference to the influencer associated with this touchpoint, if applicable. Links touchpoint to influencer partnership performance and attributed revenue.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Influencer .

ind:promoCodeId rdf:type rdf:Property ;
    rdfs:label 'Promo Code Id' ;
    rdfs:comment 'Foreign key linking to marketing.promo_code. Business justification: attribution_touchpoint currently stores promo_code_used as STRING. When a touchpoint involves a promo code, it should reference the promo_code entity directly for proper attribution tracking. This all' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:attributedOrdersCount rdf:type rdf:Property ;
    rdfs:label 'Attributed Orders Count' ;
    rdfs:comment 'Fractional count of orders attributed to this touchpoint. For example, a touchpoint in a 4-touch linear model receives 0.25 order credit. Used for conversion attribution analysis.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedRevenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for attributed revenue amount. Enables multi-currency attribution reporting.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelApplied rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Applied' ;
    rdfs:comment 'The multi-touch attribution algorithm used to calculate attributed revenue and orders for this touchpoint. Different models distribute credit differently across the journey.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWeight rdf:type rdf:Property ;
    rdfs:label 'Attribution Weight' ;
    rdfs:comment 'Normalized weight assigned to this touchpoint by the attribution model (0.0 to 1.0). Sum of weights across all touchpoints in a journey equals 1.0.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionEventType rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Type' ;
    rdfs:comment 'Type of conversion event this touchpoint contributed to. Enables attribution analysis across different conversion goals and funnel stages. [ENUM-REF-CANDIDATE: purchase|add_to_cart|sign_up|download|lead_form|store_visit|phone_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeReference rdf:type rdf:Property ;
    rdfs:label 'Creative Reference' ;
    rdfs:comment 'Identifier for the specific creative asset (ad copy, image, video) shown at this touchpoint. Enables creative-level performance analysis.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPseudonymCode rdf:type rdf:Property ;
    rdfs:label 'Customer Pseudonym Code' ;
    rdfs:comment 'Pseudonymized customer identifier linking this touchpoint to a customer journey while preserving privacy. Used for multi-touch attribution analysis without exposing PII.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Seconds' ;
    rdfs:comment 'Number of seconds the customer engaged with this touchpoint (time on page, video watch time, etc.). Indicates touchpoint quality and engagement depth.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalPlatformCode rdf:type rdf:Property ;
    rdfs:label 'External Platform Code' ;
    rdfs:comment 'Identifier from the external advertising or analytics platform (Google Ads click ID, Facebook ad ID, etc.). Enables reconciliation with platform-specific reporting.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConversionTouchpoint rdf:type rdf:Property ;
    rdfs:label 'Is Conversion Touchpoint' ;
    rdfs:comment 'Flag indicating whether this touchpoint directly resulted in a conversion event. True for last-touch conversions, false for assisting touchpoints.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'Number of hours elapsed between this touchpoint and the conversion event. Used for time-decay attribution weighting and customer journey velocity analysis.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:touchpointChannel rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Channel' ;
    rdfs:comment 'Marketing channel through which the customer encountered this touchpoint. Used for channel-level attribution and CAC analysis. [ENUM-REF-CANDIDATE: paid_search|organic_search|display|social_paid|social_organic|email|affiliate|direct|referral|video|mobile_app|sms|influencer|offline — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointPosition rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Position' ;
    rdfs:comment 'Position of this touchpoint in the customer journey relative to conversion. First touch drives awareness, mid-funnel nurtures consideration, last touch closes the sale.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Number' ;
    rdfs:comment 'Ordinal position of this touchpoint in the chronological customer journey (1 = first interaction, 2 = second, etc.). Used for path analysis and journey mapping.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Precise date and time when the customer interacted with this marketing touchpoint. Critical for time-decay attribution models and customer journey sequencing.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Unique identifier for the audience segment. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:activationDestinations rdf:type rdf:Property ;
    rdfs:label 'Activation Destinations' ;
    rdfs:comment 'Comma-separated list of downstream systems or platforms where this segment has been activated for campaign execution (e.g., Salesforce Marketing Cloud, Google Ads, Facebook Ads, email service provider).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current state of segment activation to downstream marketing channels: not activated (segment exists but not pushed), activated (successfully synced to destinations), activation pending (in progress), or activation failed (error during sync).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReach rdf:type rdf:Property ;
    rdfs:label 'Actual Reach' ;
    rdfs:comment 'Current count of unique customers or profiles who actively qualify for this segment based on the latest evaluation run.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aovCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Aov Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the AOV target amount.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, target audience characteristics, and intended use cases for campaign planning and execution.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageOrderValueTarget rdf:type rdf:Property ;
    rdfs:label 'Average Order Value Target' ;
    rdfs:comment 'Target Average Order Value expected from customers in this segment, used for campaign ROI planning and performance benchmarking.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAssociation rdf:type rdf:Property ;
    rdfs:label 'Brand Association' ;
    rdfs:comment 'Brand or sub-brand this segment is associated with for targeted brand campaigns and product launches.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'Strategic marketing goal this segment supports: customer acquisition, retention, cross-sell, upsell, win-back, loyalty engagement, seasonal campaign, new product launch.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cac Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the CAC target amount.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacTarget rdf:type rdf:Property ;
    rdfs:label 'Cac Target' ;
    rdfs:comment 'Target Customer Acquisition Cost for campaigns using this segment, representing the maximum acceptable cost to acquire a new customer from this audience.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of marketing channels where this segment can be activated: email, SMS, push notification, display advertising, social media, direct mail, in-store, web personalization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'Business rules or machine learning model logic defining segment membership criteria. May include attribute filters, event conditions, propensity scores, or SQL-like expressions.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionType rdf:type rdf:Property ;
    rdfs:label 'Definition Type' ;
    rdfs:comment 'Method used to define segment membership: rule-based (attribute/event filters), ML-derived (propensity/clustering models), hybrid (rules + ML), or manual upload (static list).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Projected number of unique customers or profiles expected to qualify for this segment based on historical data or model predictions.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedConversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Expected Conversion Rate Percent' ;
    rdfs:comment 'Anticipated percentage of segment members expected to convert (purchase, sign-up, engagement) based on historical performance or predictive models.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when the segment membership was last evaluated and updated.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next segment membership evaluation run.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the marketing team member or business owner responsible for managing and maintaining this segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Business priority level assigned to this segment for resource allocation and campaign sequencing: high (VIP/high-value customers), medium (core audience), low (exploratory/test segments).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryAssociation rdf:type rdf:Property ;
    rdfs:label 'Product Category Association' ;
    rdfs:comment 'Primary product category or collection this segment is aligned with for merchandising and promotional targeting (e.g., athletic footwear, luxury accessories, lifestyle apparel).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which segment membership is re-evaluated and updated: real-time (streaming), hourly, daily, weekly, monthly, or on-demand (manual trigger).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAssetId rdf:type rdf:Property ;
    rdfs:label 'Brand Asset Id' ;
    rdfs:comment 'Unique identifier for the brand asset record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:creatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Creator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When creator_type indicates internal staff (photographer, designer, copywriter), linking to employee enables workload tracking, rights management, performance reviews, and creative team capacity plann' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAssetBrandAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Brand Asset Id' ;
    rdfs:comment 'Reference to the parent or original asset if this is a derivative, localized, or resized version. Enables asset lineage tracking.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:altText rdf:type rdf:Property ;
    rdfs:label 'Alt Text' ;
    rdfs:comment 'Descriptive alternative text for accessibility compliance (WCAG 2.1). Required for web and digital channels to support screen readers and SEO.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Aspect ratio of the image or video (e.g., 16:9, 4:3, 1:1, 9:16). Determines suitability for different digital platforms and display formats.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelEcommerceFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Ecommerce Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for use on e-commerce platforms (website, mobile app, product pages).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelEmailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Email Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for email marketing campaigns and newsletters.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelPrintFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Print Flag' ;
    rdfs:comment 'Indicates whether the asset meets technical specifications for print media (catalogs, magazines, outdoor advertising). Requires high resolution and color profile compliance.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelRetailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Retail Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for use in physical retail store environments (in-store displays, signage, POS materials).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSocialMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Social Media Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and optimized for social media platforms (Instagram, Facebook, TikTok, Pinterest).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelWholesaleFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Wholesale Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for distribution to wholesale partners and third-party retailers.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creatorType rdf:type rdf:Property ;
    rdfs:label 'Creator Type' ;
    rdfs:comment 'Classification of the asset creator. User-Generated Content (UGC) requires special rights management and compliance review.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'External unique identifier from the Digital Asset Management system (Adobe Experience Platform). Used for cross-system asset tracking and retrieval.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the asset file in megabytes. Used for storage management, bandwidth planning, and determining load times for digital channels.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags for asset search and discovery within the DAM system. Includes product categories, colors, styles, and themes.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic market or region the asset is intended for. Used for localization and regional campaign management.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Image or video resolution in pixels (e.g., 1920x1080, 4096x2160). Critical for determining channel suitability and print vs digital usage.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'Cloud storage URL or file path where the asset is stored. Used for programmatic access and integration with content delivery networks.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsDetail rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Detail' ;
    rdfs:comment 'Detailed description of usage rights, restrictions, and licensing terms. Includes geographic restrictions, channel limitations, and exclusivity clauses.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandHealthResultId rdf:type rdf:Property ;
    rdfs:label 'Brand Health Result Id' ;
    rdfs:comment 'Unique identifier for the brand health survey result record. Primary key for the brand health result entity.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandHealthSurveyId rdf:type rdf:Property ;
    rdfs:label 'Brand Health Survey Id' ;
    rdfs:comment 'Identifier linking to the specific survey wave or fielding period during which this brand health metric was captured.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandHealthSurvey .

ind:changeVsPriorWave rdf:type rdf:Property ;
    rdfs:label 'Change Vs Prior Wave' ;
    rdfs:comment 'The absolute change in metric value compared to the prior survey wave. Calculated as current metric value minus prior wave value.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeVsPriorWavePercent rdf:type rdf:Property ;
    rdfs:label 'Change Vs Prior Wave Percent' ;
    rdfs:comment 'The percentage change in metric value compared to the prior survey wave. Calculated as ((current value - prior value) / prior value) * 100.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveBenchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Source' ;
    rdfs:comment 'The source of the competitive benchmark data, such as industry report, syndicated research provider, or internal competitive analysis.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Value' ;
    rdfs:comment 'The benchmark metric value representing competitive performance in the same market and category. Used for competitive positioning assessment.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Data Collection End Date' ;
    rdfs:comment 'The date when data collection for this survey wave was completed.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Collection Start Date' ;
    rdfs:comment 'The date when data collection for this survey wave began.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of data quality status for this survey result. Flags any quality concerns or validation issues identified during data processing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicSegment rdf:type rdf:Property ;
    rdfs:label 'Demographic Segment' ;
    rdfs:comment 'The demographic segment or audience group for which this brand health metric was measured (e.g., age group, gender, income level, lifestyle segment).' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter in which this brand health survey wave was conducted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginOfErrorPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Of Error Percent' ;
    rdfs:comment 'The margin of error for this survey result, expressed as a percentage. Indicates the precision of the metric value.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'The geographic market or country where the brand health survey was conducted, represented by ISO 3166-1 alpha-3 country code. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|FRA|DEU|ITA|ESP|CHN|JPN|KOR|AUS|BRA|IND|SGP|NLD|BEL|SWE|NOR|DNK|AUT|CHE|POL|TUR|ZAF|ARE|SAU|RUS|ARG|CHL|COL|PER|THA|VNM|IDN|MYS|PHL|NZL|IRL|FIN|PRT|GRC|CZE|HUN|ROU|HKG|TWN|ISR|EGY|NGA|KEN|MAR|TUN|PAK|BGD — 55 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'The unit of measure for the metric value. Indicates whether the value is expressed as a percentage, index score, Net Promoter Score (NPS), or rating scale.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'The measured value of the brand health metric for this survey wave. Typically expressed as a percentage, index score, or Net Promoter Score (NPS) value.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Classification of the metric performance relative to target threshold. Indicates whether the brand health metric exceeds, meets, or falls below strategic goals.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorWaveValue rdf:type rdf:Property ;
    rdfs:label 'Prior Wave Value' ;
    rdfs:comment 'The metric value from the previous survey wave for the same brand, market, and metric. Used for trend analysis and change calculation.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchVendor rdf:type rdf:Property ;
    rdfs:label 'Research Vendor' ;
    rdfs:comment 'The name of the market research vendor or agency that conducted the brand health survey.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentSampleSize rdf:type rdf:Property ;
    rdfs:label 'Respondent Sample Size' ;
    rdfs:comment 'The number of survey respondents included in this brand health metric calculation for this wave and market.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyMethodology rdf:type rdf:Property ;
    rdfs:label 'Survey Methodology' ;
    rdfs:comment 'The research methodology used to collect the brand health data (e.g., online panel, telephone interview, in-person interview, mobile survey, mixed mode, social listening). [ENUM-REF-CANDIDATE: online_panel|telephone_interview|in_person_interview|mobile_survey|mixed_mode|social_listening|focus_group — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThreshold rdf:type rdf:Property ;
    rdfs:label 'Target Threshold' ;
    rdfs:comment 'The target or goal value set for this brand health metric. Used to assess performance against strategic brand objectives.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceVsBenchmark rdf:type rdf:Property ;
    rdfs:label 'Variance Vs Benchmark' ;
    rdfs:comment 'The difference between the brand metric value and the competitive benchmark value. Positive values indicate outperformance versus competition.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceVsTarget rdf:type rdf:Property ;
    rdfs:label 'Variance Vs Target' ;
    rdfs:comment 'The difference between the actual metric value and the target threshold. Positive values indicate target achievement or overperformance.' ;
    rdfs:domain ind:BrandHealthResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveDate rdf:type rdf:Property ;
    rdfs:label 'Wave Date' ;
    rdfs:comment 'The date when the survey wave was fielded or completed. Represents the principal business event timestamp for this brand health measurement.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aidedAwarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Aided Awareness Percent' ;
    rdfs:comment 'Percentage of respondents who recognize the brand when prompted with brand name or visual cues. Key Performance Indicator (KPI) for brand recognition.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAffinityScore rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Score' ;
    rdfs:comment 'Composite score measuring emotional connection and loyalty to the brand, typically on a 0-100 scale. Key Performance Indicator (KPI) for brand equity.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveBenchmarkBrand rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Brand' ;
    rdfs:comment 'Name of the primary competitor brand used as benchmark for comparative brand health analysis.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkScore rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Score' ;
    rdfs:comment 'Brand health metric score for the competitive benchmark brand, enabling relative positioning assessment.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationPercent rdf:type rdf:Property ;
    rdfs:label 'Consideration Percent' ;
    rdfs:comment 'Percentage of respondents who would consider purchasing from the brand. Key Performance Indicator (KPI) for brand consideration in purchase funnel.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when data collection fieldwork concluded for this brand health survey wave.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date when data collection fieldwork began for this brand health survey wave.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Perception Score' ;
    rdfs:comment 'Consumer perception score for brand innovation and trend leadership, typically on a 0-100 scale. Important for fashion and lifestyle positioning.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferencePercent rdf:type rdf:Property ;
    rdfs:label 'Preference Percent' ;
    rdfs:comment 'Percentage of respondents who prefer this brand over competitors. Key Performance Indicator (KPI) for brand preference and competitive positioning.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorWaveAidedAwarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Prior Wave Aided Awareness Percent' ;
    rdfs:comment 'Aided awareness percentage from the previous survey wave, used for period-over-period trend analysis.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorWaveUnaidedAwarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Prior Wave Unaided Awareness Percent' ;
    rdfs:comment 'Unaided awareness percentage from the previous survey wave, used for period-over-period trend analysis.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPercent rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Percent' ;
    rdfs:comment 'Percentage of respondents who intend to purchase from the brand in the next 6-12 months. Key Performance Indicator (KPI) for conversion likelihood.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Quality Perception Score' ;
    rdfs:comment 'Consumer perception score for product quality and craftsmanship, typically on a 0-100 scale. Critical for luxury and lifestyle brand positioning.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchAgencyContact rdf:type rdf:Property ;
    rdfs:label 'Research Agency Contact' ;
    rdfs:comment 'Primary contact person or email at the research agency responsible for this brand health study.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchAgencyName rdf:type rdf:Property ;
    rdfs:label 'Research Agency Name' ;
    rdfs:comment 'The name of the external market research agency or vendor conducting the brand health study.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchMethodology rdf:type rdf:Property ;
    rdfs:label 'Research Methodology' ;
    rdfs:comment 'The primary research methodology used for data collection (online survey, telephone interview, in-person interview, mixed mode, mobile survey, panel study).' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeActual rdf:type rdf:Property ;
    rdfs:label 'Sample Size Actual' ;
    rdfs:comment 'The actual number of completed survey responses received for this brand health study wave.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'The planned or target number of survey respondents for this brand health study wave.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Unique business identifier or reference code for the brand health study, used for tracking and reporting purposes.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Study Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting this brand health survey wave, including research agency fees and fieldwork expenses.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'The official name or title of the brand health tracking study (e.g., \'Q1 2024 Luxury Brand Perception Study\', \'Spring Collection Brand Equity Wave\').' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the brand health study (planned, in field, completed, cancelled, on hold, analysis).' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the brand health study methodology and purpose (e.g., brand tracking, perception study, equity monitor, competitive benchmark).' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Perception Score' ;
    rdfs:comment 'Consumer perception score for environmental and social responsibility practices, typically on a 0-100 scale. Increasingly critical for apparel brand equity.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'The consumer segment or demographic profile targeted for the brand health survey (e.g., \'Luxury Consumers 25-45\', \'Athletic Lifestyle Enthusiasts\', \'High-Income Professionals\').' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Value' ;
    rdfs:comment 'The strategic target or threshold value set for the primary brand health metric, used to assess performance against objectives.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unaidedAwarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Unaided Awareness Percent' ;
    rdfs:comment 'Percentage of respondents who spontaneously recall the brand without prompting. Key Performance Indicator (KPI) for top-of-mind brand awareness.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuePerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Value Perception Score' ;
    rdfs:comment 'Consumer perception score for price-to-value ratio and affordability, typically on a 0-100 scale.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Variance To Target Percent' ;
    rdfs:comment 'Percentage variance between actual brand health metric result and target threshold, indicating performance gap or achievement.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Sequential wave number for longitudinal tracking studies, enabling period-over-period comparison of brand health metrics.' ;
    rdfs:domain ind:BrandHealthSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredStyleId rdf:type rdf:Property ;
    rdfs:label 'Featured Style Id' ;
    rdfs:comment 'Foreign key linking to product.style. Business justification: Campaigns feature hero styles (signature sneaker launch, flagship jacket). Required for creative briefing, asset production planning, and campaign performance attribution to specific products. Standar' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Style .

ind:monitoredStockPositionId rdf:type rdf:Property ;
    rdfs:label 'Monitored Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Campaign planning requires real-time inventory visibility to avoid promoting out-of-stock items. Real process: marketing operations teams monitor stock positions for featured SKUs to pause/adjust camp' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:sourcingMaterialSourcingId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Material Sourcing Id' ;
    rdfs:comment 'Foreign key linking to sourcing.material_sourcing. Business justification: Sustainability and innovation campaigns promote specific materials (organic cotton, recycled polyester, BCI cotton). Campaign messaging requires material certifications, sourcing details, and complian' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingMaterialSourcing .

ind:sourcingTnaCalendarId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Tna Calendar Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_tna_calendar. Business justification: Campaign launch dates must align with TNA milestones (ex-factory, in-DC dates). Marketing monitors TNA status to adjust campaign timing, ensure product availability at launch, and coordinate media buy' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingTnaCalendar .

ind:targetSkuLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Sku Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.sku_location. Business justification: Regional campaigns target specific SKUs at specific locations (store events, local launches). Marketing teams need to verify local stock availability when planning geo-targeted campaigns. Real process' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuLocation .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount formally allocated and approved for the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all budget amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlannedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Planned Amount' ;
    rdfs:comment 'Total planned marketing investment budget for the campaign across all channels and fiscal periods.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRemainingAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Remaining Amount' ;
    rdfs:comment 'Remaining unspent budget available for the campaign, calculated as allocated minus spent.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent to date on campaign execution across all channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Target Amount' ;
    rdfs:comment 'Target Customer Acquisition Cost (CAC) per new customer for acquisition-focused campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'Primary call-to-action message or instruction presented to the audience (e.g., Shop Now, Learn More, Sign Up).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign, used across systems and reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign for identification and reporting purposes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by strategic purpose: brand awareness, seasonal launch, performance marketing, influencer partnership, customer acquisition, or retention.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list of marketing channels utilized in this campaign (e.g., email, social_media, paid_search, display, influencer, in_store, direct_mail).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'High-level description of the creative theme, messaging, and visual concept for the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCampaignCode rdf:type rdf:Property ;
    rdfs:label 'External Campaign Code' ;
    rdfs:comment 'Campaign identifier in the external marketing platform or activation system for integration and reconciliation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationPlatform rdf:type rdf:Property ;
    rdfs:label 'Integration Platform' ;
    rdfs:comment 'Name of the marketing platform or system where the campaign is activated and managed (e.g., Adobe Experience Platform, Salesforce Marketing Cloud).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Objective Description' ;
    rdfs:comment 'Detailed description of the campaign\'s strategic objectives, goals, and success criteria.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConversions rdf:type rdf:Property ;
    rdfs:label 'Target Conversions' ;
    rdfs:comment 'Planned number of conversions (purchases, sign-ups, or other defined actions) the campaign aims to drive.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions or views the campaign aims to achieve across all channels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReach rdf:type rdf:Property ;
    rdfs:label 'Target Reach' ;
    rdfs:comment 'Planned number of unique individuals or households the campaign aims to reach.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Unique identifier for the campaign execution record. Primary key for tracking individual campaign flight activations across all paid, owned, and earned channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Foreign key linking to marketing.event. Business justification: campaign_execution currently stores event_name and event_location as STRING attributes. When an execution is tied to a marketing event (runway show, pop-up, etc.), it should reference the event entity' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'Creative format or media type used in the execution. Examples: banner, video, carousel, story, native, sponsored content, interview, product placement, experiential activation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution methodology used to assign credit for conversions and revenue to this execution. Examples: last-click, first-click, linear, time-decay, position-based, data-driven.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStrategy rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy' ;
    rdfs:comment 'Bidding approach used for paid media placements. Examples: CPC (Cost Per Click), CPM (Cost Per Mille), CPA (Cost Per Acquisition), target ROAS (Return on Ad Spend), maximize conversions. Not applicable for owned or earned media.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Specific marketing channel through which the campaign execution is delivered. Includes paid search, display, programmatic, paid social, email, out-of-home (OOH), print, TV, streaming, influencer, public relations (PR), and event activations. [ENUM-REF-CANDIDATE: paid_search|display|programmatic|paid_social|email|ooh|print|tv|streaming|influencer|pr|event — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of user clicks on the creative asset or call-to-action. Applicable to digital paid and owned channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Budget Amount' ;
    rdfs:comment 'Daily spending limit allocated to this execution flight. Applicable primarily to paid media channels. Expressed in campaign currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceTarget rdf:type rdf:Property ;
    rdfs:label 'Device Target' ;
    rdfs:comment 'Device type targeting for digital executions. CTV refers to Connected TV for streaming video placements.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total number of user engagements with the execution. Includes likes, shares, comments, saves, and other interaction types depending on channel. Applicable to digital and social channels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionNotes rdf:type rdf:Property ;
    rdfs:label 'Execution Notes' ;
    rdfs:comment 'Free-text field for operational notes, learnings, or context about this execution. Used by marketing teams to document insights, issues, or special circumstances.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle state of the campaign execution. Tracks progression from planning through completion or cancellation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'Scheduled end date for the campaign execution flight. Nullable for ongoing or evergreen activations.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Business-friendly name for this specific campaign flight or activation wave. Used for operational identification and reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'Scheduled start date for the campaign execution flight. Represents when the activation goes live or when earned media is published.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Average number of times each unique individual was exposed to the campaign execution. Calculated as impressions divided by reach.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoTarget rdf:type rdf:Property ;
    rdfs:label 'Geo Target' ;
    rdfs:comment 'Geographic targeting specification for this execution. May include country codes, regions, DMAs, postal codes, or radius targeting around specific locations.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the creative asset was displayed or the content was viewed. Applicable to paid and owned digital channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalistName rdf:type rdf:Property ;
    rdfs:label 'Journalist Name' ;
    rdfs:comment 'Name of the journalist, editor, or content creator who produced the earned media placement. Applicable to PR and influencer activations.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Budget Amount' ;
    rdfs:comment 'Total budget allocated to this execution flight across its entire duration. Applicable to paid media and event activations. Expressed in campaign currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Media Value Amount' ;
    rdfs:comment 'Estimated advertising equivalency value of earned media placement. Calculated based on comparable paid media rates for the same placement. Expressed in campaign currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'Detailed placement identifier within the platform. For paid media: ad group or placement ID. For earned media: article title or segment name. For events: booth or activation area.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Specific advertising or media platform where the execution is placed. Examples include Google Ads, Meta, TikTok, Vogue, CNN, specific event venue names, or publication names for earned media.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationName rdf:type rdf:Property ;
    rdfs:label 'Publication Name' ;
    rdfs:comment 'Name of the publication, media outlet, or platform where earned media was placed. Applicable to PR and earned media executions. Examples: Vogue, WWD, Business of Fashion.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Unique number of individuals or households exposed to the campaign execution. Deduplicated audience count across the flight period.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on Ad Spend ratio calculated as revenue attributed to this execution divided by spend amount. Key performance indicator for paid media effectiveness.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Actual amount spent on this execution flight. For paid media: media cost. For events: activation cost. For earned media: estimated media value or zero if tracking impressions only.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingParameters rdf:type rdf:Property ;
    rdfs:label 'Targeting Parameters' ;
    rdfs:comment 'Audience targeting criteria applied to this execution. Includes demographic, geographic, behavioral, and contextual targeting specifications. Stored as structured text or JSON.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Percentage of video views that were watched to completion. Calculated as completed views divided by total views, expressed as a percentage.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views for video creative assets. Applicable to video ad formats across paid social, streaming, and TV channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailCampaignId rdf:type rdf:Property ;
    rdfs:label 'Email Campaign Id' ;
    rdfs:comment 'Unique identifier for the email campaign. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailCampaign .

ind:espCampaignId rdf:type rdf:Property ;
    rdfs:label 'Esp Campaign Id' ;
    rdfs:comment 'External identifier assigned by the Email Service Provider system for tracking and reconciliation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Identifier of the email template used for this campaign. References template library in ESP or Adobe Experience Platform.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailTemplate .

ind:abTestEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ab Test Enabled Flag' ;
    rdfs:comment 'Indicates whether this campaign includes A/B testing of subject lines, content, or send times.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abTestVariantCount rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Count' ;
    rdfs:comment 'Number of variants being tested in the A/B test (e.g., 2 for A/B, 3 for A/B/C).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestWinningVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Winning Variant' ;
    rdfs:comment 'Identifier of the winning variant selected based on test results (e.g., A, B, C). Null if test is incomplete.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Send Timestamp' ;
    rdfs:comment 'Actual date and time when the email campaign send was initiated by the Email Service Provider (ESP).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Amount' ;
    rdfs:comment 'Total budget allocated for this email campaign including creative, ESP costs, and promotional discounts.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignGoal rdf:type rdf:Property ;
    rdfs:label 'Campaign Goal' ;
    rdfs:comment 'Primary business objective of the campaign (e.g., drive sales, increase engagement, promote new collection, recover abandoned carts).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this campaign meets CCPA requirements for consumer data rights and opt-out mechanisms.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'Legal basis for sending this email under GDPR and CCPA regulations. Critical for compliance and audit trails.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espName rdf:type rdf:Property ;
    rdfs:label 'Esp Name' ;
    rdfs:comment 'Name of the Email Service Provider platform used to send this campaign (e.g., Adobe Campaign, Salesforce Marketing Cloud, Mailchimp).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this campaign meets GDPR requirements for consent, data processing, and right to unsubscribe.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hardBounceCount rdf:type rdf:Property ;
    rdfs:label 'Hard Bounce Count' ;
    rdfs:comment 'Number of emails that permanently failed delivery due to invalid email addresses or blocked domains.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether dynamic personalization (name, product recommendations, location-based content) is enabled for this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationFields rdf:type rdf:Property ;
    rdfs:label 'Personalization Fields' ;
    rdfs:comment 'Comma-separated list of personalization tokens used in the email (e.g., first_name, last_purchase_date, recommended_products).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preheaderText rdf:type rdf:Property ;
    rdfs:label 'Preheader Text' ;
    rdfs:comment 'Preview text displayed after the subject line in email clients. Used to provide additional context and improve open rates.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Reply To Email Address' ;
    rdfs:comment 'Email address where recipient replies will be directed. May differ from sender address.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'Planned date and time when the email campaign is scheduled to be sent to recipients.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:senderEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Sender Email Address' ;
    rdfs:comment 'Email address used as the from address for the campaign (e.g., marketing@apparelfashion.com).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Display name shown as the sender of the email (e.g., Apparel Fashion, Customer Service Team).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softBounceCount rdf:type rdf:Property ;
    rdfs:label 'Soft Bounce Count' ;
    rdfs:comment 'Number of emails that temporarily failed delivery due to full mailboxes or server issues.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spamComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Count' ;
    rdfs:comment 'Number of recipients who marked this email as spam or junk. Critical metric for sender reputation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The subject line text displayed in recipient inboxes. Critical for open rate optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'Total number of recipients in the target segment at the time of campaign creation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBounceCount rdf:type rdf:Property ;
    rdfs:label 'Total Bounce Count' ;
    rdfs:comment 'Total number of emails that bounced (hard bounces plus soft bounces).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClickCount rdf:type rdf:Property ;
    rdfs:label 'Total Click Count' ;
    rdfs:comment 'Total number of clicks on links within the email (includes multiple clicks by same recipient).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Total Delivered Count' ;
    rdfs:comment 'Total number of emails successfully delivered to recipient inboxes (sent minus bounces).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOpenCount rdf:type rdf:Property ;
    rdfs:label 'Total Open Count' ;
    rdfs:comment 'Total number of times emails in this campaign were opened by recipients (includes multiple opens by same recipient).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSentCount rdf:type rdf:Property ;
    rdfs:label 'Total Sent Count' ;
    rdfs:comment 'Total number of emails successfully sent by the ESP for this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueClickCount rdf:type rdf:Property ;
    rdfs:label 'Unique Click Count' ;
    rdfs:comment 'Number of unique recipients who clicked at least one link in the email.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueOpenCount rdf:type rdf:Property ;
    rdfs:label 'Unique Open Count' ;
    rdfs:comment 'Number of unique recipients who opened the email at least once.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeCount rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Count' ;
    rdfs:comment 'Number of recipients who unsubscribed from the email list after receiving this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailSendEventId rdf:type rdf:Property ;
    rdfs:label 'Email Send Event Id' ;
    rdfs:comment 'Unique identifier for each individual email send event. Primary key for the email send event record.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailTemplateId rdf:type rdf:Property ;
    rdfs:label 'Email Template Id' ;
    rdfs:comment 'Reference to the email template used for this send event.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailTemplate .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'Detailed reason code or message explaining why the email bounced. Sourced from SMTP error response. Null if no bounce occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceType rdf:type rdf:Property ;
    rdfs:label 'Bounce Type' ;
    rdfs:comment 'Classification of bounce event. Hard bounce indicates permanent delivery failure (invalid address), soft bounce indicates temporary issue (mailbox full). Null if no bounce occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedFlag rdf:type rdf:Property ;
    rdfs:label 'Clicked Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient clicked any link within the email. True if at least one click event was tracked, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickedUrl rdf:type rdf:Property ;
    rdfs:label 'Clicked Url' ;
    rdfs:comment 'The first URL clicked by the recipient within the email. Used for primary engagement attribution. Null if no clicks occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the email was successfully delivered to the recipient mail server. Null if delivery failed.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current delivery status of the email indicating whether it successfully reached the recipient inbox or encountered an issue.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailClient rdf:type rdf:Property ;
    rdfs:label 'Email Client' ;
    rdfs:comment 'The email client application used by the recipient to view the email (e.g., Gmail, Outlook, Apple Mail). Derived from user agent string.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espMessageReference rdf:type rdf:Property ;
    rdfs:label 'Esp Message Reference' ;
    rdfs:comment 'Unique message identifier assigned by the Email Service Provider. Used for tracking and troubleshooting delivery issues.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstClickTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Click Timestamp' ;
    rdfs:comment 'The date and time of the first recorded click event for any link in this email. Null if no clicks occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Open Timestamp' ;
    rdfs:comment 'The date and time of the first recorded open event for this email. Null if the email was never opened.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fromAddress rdf:type rdf:Property ;
    rdfs:label 'From Address' ;
    rdfs:comment 'The sender email address displayed in the From field of the email. Used for sender reputation tracking.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromName rdf:type rdf:Property ;
    rdfs:label 'From Name' ;
    rdfs:comment 'The sender name displayed in the From field of the email (e.g., brand name or representative name).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'The city where the recipient opened the email. Derived from IP address geolocation.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedFlag rdf:type rdf:Property ;
    rdfs:label 'Opened Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient opened the email. True if at least one open event was tracked, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Email Address' ;
    rdfs:comment 'The email address to which this message was sent. Personally identifiable information subject to GDPR and CCPA.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendPriority rdf:type rdf:Property ;
    rdfs:label 'Send Priority' ;
    rdfs:comment 'The priority level assigned to this email send event. High priority emails are processed first by the ESP.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'The exact date and time when the email was sent from the Email Service Provider (ESP). Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spamComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient marked this email as spam or junk. True if spam complaint was filed, False otherwise. Critical for sender reputation monitoring.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spamComplaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Timestamp' ;
    rdfs:comment 'The date and time when the spam complaint was registered. Null if no complaint was filed.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'The date and time when the recipient clicked the unsubscribe link. Null if no unsubscribe action occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unsubscribedFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient unsubscribed from the email list as a result of this send event. True if unsubscribe action was taken, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedStockPositionId rdf:type rdf:Property ;
    rdfs:label 'Reserved Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Fashion events (trunk shows, pop-ups, fashion weeks) require specific inventory allocation and reservation. Real process: event planning teams reserve stock positions for event merchandise, tracking w' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:seasonalLaunchId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Launch Id' ;
    rdfs:comment 'Foreign key linking to marketing.seasonal_launch. Business justification: event has season_code (STRING) and collection_name (STRING) fields. Marketing events (runway shows, pop-up activations, launch parties) are often part of seasonal collection launches. While event alre' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonalLaunch .

ind:socialImpactProgramId rdf:type rdf:Property ;
    rdfs:label 'Social Impact Program Id' ;
    rdfs:comment 'Foreign key linking to sustainability.social_impact_program. Business justification: Brand events (fashion shows, pop-ups, community activations) frequently partner with social impact programs (artisan cooperatives, workforce development, community investment) for CSR storytelling, st' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SocialImpactProgram .

ind:targetCustomerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Events target specific customer segments (VIP events, loyalty member exclusives, new customer welcomes). Enables segment-based invitation lists, attendance tracking by segment, and segment-specific ev' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Confirmed number of attendees who participated in the event. Captured post-event for performance analysis and ROI calculation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedOrderCount rdf:type rdf:Property ;
    rdfs:label 'Attributed Order Count' ;
    rdfs:comment 'Number of customer or wholesale orders directly attributed to the event through tracking mechanisms.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetActualAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Actual Amount' ;
    rdfs:comment 'Total actual expenditure for the event after completion. Used for variance analysis and future event budget calibration.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Business identifier code for the event, used for external reference and tracking across systems. Typically alphanumeric code assigned during event planning.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Full descriptive name of the marketing event (e.g., Spring 2024 Runway Show, NYC Pop-Up Launch, Paris Fashion Week Press Day).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the event. Tracks progression from planning through execution to completion.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the marketing event format and purpose. Determines audience, venue requirements, and success metrics. [ENUM-REF-CANDIDATE: runway_show|pop_up_activation|trade_show|press_day|brand_experience|wholesale_preview|influencer_event|product_launch|store_opening|virtual_event|fashion_week|trunk_show — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendance rdf:type rdf:Property ;
    rdfs:label 'Expected Attendance' ;
    rdfs:comment 'Projected number of attendees based on invitations sent and historical response rates. Used for capacity planning and budget forecasting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVirtualEvent rdf:type rdf:Property ;
    rdfs:label 'Is Virtual Event' ;
    rdfs:comment 'Indicates whether the event is conducted entirely online/virtually (True) or has a physical venue component (False).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaImpressions rdf:type rdf:Property ;
    rdfs:label 'Media Impressions' ;
    rdfs:comment 'Total estimated media impressions generated by the event across press coverage, social media, and digital channels. Captured post-event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressCoverageCount rdf:type rdf:Property ;
    rdfs:label 'Press Coverage Count' ;
    rdfs:comment 'Number of press articles, blog posts, or media mentions generated by the event. Indicates earned media success.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationCount rdf:type rdf:Property ;
    rdfs:label 'Registration Count' ;
    rdfs:comment 'Total number of individuals who registered or RSVP\'d for the event. Used to calculate attendance conversion rate.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Social Engagement Count' ;
    rdfs:comment 'Total social media engagements (likes, shares, comments, mentions) attributed to the event across all platforms. Measured during and post-event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the primary external sponsor or partner co-hosting the event. Null if no external sponsorship.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'Level of external sponsorship secured for the event. Impacts budget offset and co-branding requirements.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipValueAmount rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Value Amount' ;
    rdfs:comment 'Monetary value of sponsorship contribution or in-kind services provided by external sponsor. Reduces net event cost.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Primary audience segment the event is designed to engage. Determines invitation strategy, content, and success metrics. [ENUM-REF-CANDIDATE: press|buyers|consumers|vips|influencers|trade|internal|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddress rdf:type rdf:Property ;
    rdfs:label 'Venue Address' ;
    rdfs:comment 'Full street address of the event venue. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCity rdf:type rdf:Property ;
    rdfs:label 'Venue City' ;
    rdfs:comment 'City where the event venue is located. Used for market segmentation and regional performance analysis.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCountryCode rdf:type rdf:Property ;
    rdfs:label 'Venue Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the event venue location (e.g., USA, FRA, GBR, ITA, JPN).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical or virtual venue where the event takes place (e.g., Javits Center, Brand Flagship Store, Zoom Virtual Studio).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venuePostalCode rdf:type rdf:Property ;
    rdfs:label 'Venue Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the event venue. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueStateProvince rdf:type rdf:Property ;
    rdfs:label 'Venue State Province' ;
    rdfs:comment 'State or province of the event venue. Relevant for regional compliance and logistics planning.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatformName rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform Name' ;
    rdfs:comment 'Name of the digital platform used for virtual events (e.g., Zoom, Microsoft Teams, custom branded platform). Null for physical-only events.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateLink rdf:type rdf:Property ;
    rdfs:label 'Affiliate Link' ;
    rdfs:comment 'Unique affiliate tracking URL assigned to the influencer for digital attribution and commission tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Primary email address for the influencers agency or management contact for contract and campaign coordination.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the talent agency or management company representing the influencer, if applicable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambassadorStatus rdf:type rdf:Property ;
    rdfs:label 'Ambassador Status' ;
    rdfs:comment 'Current lifecycle status of the influencer relationship: active (currently engaged), inactive (no recent activity), suspended (temporarily paused), pending (onboarding), terminated (relationship ended).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceAgeRange rdf:type rdf:Property ;
    rdfs:label 'Audience Age Range' ;
    rdfs:comment 'Predominant age range of the influencers audience (e.g., 18-24, 25-34, 35-44). Used for campaign targeting alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGenderSplit rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split' ;
    rdfs:comment 'Gender distribution of the influencers audience (e.g., 60% female, 40% male). Used for product line alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audiencePrimaryGeography rdf:type rdf:Property ;
    rdfs:label 'Audience Primary Geography' ;
    rdfs:comment 'Primary geographic market or country where the majority of the influencers audience is located (e.g., USA, GBR, FRA). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSecondaryGeographies rdf:type rdf:Property ;
    rdfs:label 'Audience Secondary Geographies' ;
    rdfs:comment 'Comma-separated list of secondary geographic markets with significant audience presence. Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Score' ;
    rdfs:comment 'Quantitative score (0.00 to 5.00) assessing the influencers content safety, controversy risk, and alignment with brand values. Higher scores indicate lower risk.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentNiche rdf:type rdf:Property ;
    rdfs:label 'Content Niche' ;
    rdfs:comment 'Primary content category or niche the influencer specializes in (e.g., fashion, lifestyle, fitness, beauty, streetwear, luxury, athleisure, sustainability).' ;
    rdfs:domain ind:Influencer ;
