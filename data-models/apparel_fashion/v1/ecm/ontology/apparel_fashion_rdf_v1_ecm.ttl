    rdfs:comment 'Classification of the restricted substance by chemical family or functional group (e.g., heavy metal, phthalate, flame retardant, azo dye, PFAS). [ENUM-REF-CANDIDATE: heavy_metal|phthalate|flame_retardant|azo_dye|formaldehyde|per_and_polyfluoroalkyl_substance|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceName rdf:type rdf:Property ;
    rdfs:label 'Substance Name' ;
    rdfs:comment 'Common or chemical name of the restricted or prohibited substance (e.g., Lead, Cadmium, Phthalates, Formaldehyde).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sunsetDate rdf:type rdf:Property ;
