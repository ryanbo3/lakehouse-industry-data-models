ind:generalizedSystemPreferencesUtilization rdf:type rdf:Property ;
    rdfs:label 'Generalized System Preferences Utilization' ;
    rdfs:comment 'Indicates whether the contract includes GSP utilization services to reduce or eliminate customs duties.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
