    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Milestone verification requires employee accountability for customs clearance sign-offs, container inspections, and quality gates. Critical for compliance audits and operational performance tracking i' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'The actual date and time when the shipment reached this milestone status, recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:ApparelFashion ;
