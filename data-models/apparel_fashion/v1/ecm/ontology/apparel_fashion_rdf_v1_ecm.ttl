    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month within the fiscal year (1 through 12 or 13 for retailers using 4-5-4 calendar) to which this week belongs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrentWeek rdf:type rdf:Property ;
    rdfs:label 'Is Current Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week is the current active week (True) or not (False).' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayWeek rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week contains major holidays that impact retail operations (True) or not (False).' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMonthEndWeek rdf:type rdf:Property ;
    rdfs:label 'Is Month End Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week is the last week of a fiscal month (True) or not (False), used for month-end reporting and reconciliation.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalWeek rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week is designated for major promotional campaigns or sales events (True) or not (False).' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarterEndWeek rdf:type rdf:Property ;
    rdfs:label 'Is Quarter End Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week is the last week of a fiscal quarter (True) or not (False), used for quarterly reporting and financial close.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndWeek rdf:type rdf:Property ;
    rdfs:label 'Is Year End Week' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal week is the last week of the fiscal year (True) or not (False), used for annual reporting and financial close.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoWeekNumber rdf:type rdf:Property ;
    rdfs:label 'Iso Week Number' ;
    rdfs:comment 'The ISO 8601 week number (1-53) for cross-reference with international calendar standards.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Trading Days Count' ;
    rdfs:comment 'The number of trading days (days stores are open) within this fiscal week, accounting for holidays and closures.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekDescription rdf:type rdf:Property ;
    rdfs:label 'Week Description' ;
    rdfs:comment 'Extended description of the fiscal week, may include notable events, holidays, or business context (e.g., \'Black Friday Week\', \'End of Season Sale Week\').' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekEndDate rdf:type rdf:Property ;
    rdfs:label 'Week End Date' ;
    rdfs:comment 'The calendar date on which this fiscal week ends, typically Saturday or Sunday depending on business convention.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekInMonth rdf:type rdf:Property ;
    rdfs:label 'Week In Month' ;
    rdfs:comment 'The sequential position of this week within its fiscal month (1-5), used in 4-5-4 retail calendar analysis.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekInQuarter rdf:type rdf:Property ;
    rdfs:label 'Week In Quarter' ;
    rdfs:comment 'The sequential position of this week within its fiscal quarter (1-13), used for quarterly trend analysis.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekLabel rdf:type rdf:Property ;
    rdfs:label 'Week Label' ;
    rdfs:comment 'Human-readable label for the fiscal week, typically formatted as \'FY2024-W12\' or \'Week 12, FY2024\' for reporting and display purposes.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekStartDate rdf:type rdf:Property ;
    rdfs:label 'Week Start Date' ;
    rdfs:comment 'The calendar date on which this fiscal week begins, typically Sunday or Monday depending on business convention.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekType rdf:type rdf:Property ;
    rdfs:label 'Week Type' ;
    rdfs:comment 'Classification of the week structure: standard (7 days), short (less than 7 days, typically at year boundaries), long (more than 7 days in leap week years), or split (spans two calendar months).' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Zone Id' ;
    rdfs:comment 'Identifier of the parent zone if this zone is a sub-zone within a larger area. Null for top-level zones.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:planogramId rdf:type rdf:Property ;
    rdfs:label 'Planogram Id' ;
    rdfs:comment 'Reference to the planogram or layout plan currently assigned to this zone.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Planogram .

ind:accessible rdf:type rdf:Property ;
    rdfs:label 'Accessible' ;
    rdfs:comment 'Indicates whether the zone meets accessibility standards for customers with disabilities.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:areaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Area Square Meters' ;
    rdfs:comment 'Total floor area of the zone measured in square meters.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateControlled rdf:type rdf:Property ;
    rdfs:label 'Climate Controlled' ;
    rdfs:comment 'Indicates whether the zone has dedicated climate control for temperature-sensitive merchandise.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixtureCount rdf:type rdf:Property ;
    rdfs:label 'Fixture Count' ;
    rdfs:comment 'Number of display fixtures, racks, or shelving units allocated to this zone.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMerchandisingResetDate rdf:type rdf:Property ;
    rdfs:label 'Last Merchandising Reset Date' ;
    rdfs:comment 'Date when the zone last underwent a full merchandising reset or planogram change.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSalesPerSquareMeter rdf:type rdf:Property ;
    rdfs:label 'Target Sales Per Square Meter' ;
    rdfs:comment 'Target sales productivity metric for this zone measured as revenue per square meter.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficPriority rdf:type rdf:Property ;
    rdfs:label 'Traffic Priority' ;
    rdfs:comment 'Customer traffic priority classification for this zone based on store layout and flow analysis.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualMerchandisingTheme rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Theme' ;
    rdfs:comment 'Current visual merchandising theme or campaign applied to the zone (e.g., Spring Collection, Holiday, Back to School).' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSalesTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Sales Target' ;
    rdfs:comment 'Planned annual sales revenue target for the district, used for performance measurement and incentive calculations.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualTrafficTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Traffic Target' ;
    rdfs:comment 'Planned annual customer traffic target across all stores in the district, used for conversion and productivity analysis.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Bopis Enabled' ;
    rdfs:comment 'Indicates whether Buy Online Pickup In Store capability is enabled for stores in this district.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compStoreSalesTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Comp Store Sales Target Percent' ;
    rdfs:comment 'Year-over-year comparable store sales growth target percentage for the district.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Business identifier code for the district used in operational systems and reporting. Typically follows a regional prefix pattern.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtManagerName rdf:type rdf:Property ;
    rdfs:label 'District Manager Name' ;
    rdfs:comment 'Full name of the district manager for quick reference and reporting purposes.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'Official name of the district used for business communication and reporting.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtType rdf:type rdf:Property ;
    rdfs:label 'District Type' ;
    rdfs:comment 'Classification of the district based on store composition and market characteristics.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 1' ;
    rdfs:comment 'Primary street address line for the district headquarters office.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, or building information for the district headquarters.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Email Address' ;
    rdfs:comment 'Primary email address for district headquarters communications.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Headquarters Phone Number' ;
    rdfs:comment 'Primary contact phone number for the district headquarters office.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelFulfillmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Fulfillment Enabled' ;
    rdfs:comment 'Indicates whether stores in this district are enabled for omnichannel fulfillment capabilities including Buy Online Pickup In Store (BOPIS) and ship-from-store.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapCarIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Sap Car Integration Enabled' ;
    rdfs:comment 'Indicates whether stores in this district are integrated with SAP Customer Activity Repository for traffic and customer analytics.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Target Percent' ;
    rdfs:comment 'Target shrinkage rate as a percentage of sales for the district, used for loss prevention performance measurement.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSellingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Selling Square Footage' ;
    rdfs:comment 'Aggregate selling square footage across all stores in the district, used for productivity and sales per square foot analysis.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualCarbonEmissionsTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Carbon Emissions Tonnes' ;
    rdfs:comment 'Total annual carbon dioxide equivalent emissions produced by the facility measured in metric tonnes, used for carbon footprint tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualEnergyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Annual Energy Consumption Mwh' ;
    rdfs:comment 'Total annual energy consumption by the facility measured in megawatt hours, used for energy efficiency tracking.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualWaterConsumptionCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Annual Water Consumption Cubic Meters' ;
    rdfs:comment 'Total annual water consumption by the facility measured in cubic meters, critical for water stewardship reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bluesignCertified rdf:type rdf:Property ;
    rdfs:label 'Bluesign Certified' ;
    rdfs:comment 'Indicates whether the facility is certified under Bluesign system for sustainable textile production.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chemicalManagementSystemImplemented rdf:type rdf:Property ;
    rdfs:label 'Chemical Management System Implemented' ;
    rdfs:comment 'Indicates whether the facility has implemented a chemical inventory and management system aligned with ZDHC guidelines.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known unique business identifier for the facility used across supply chain systems and partner communications.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteGeneratedTonnes rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Generated Tonnes' ;
    rdfs:comment 'Annual quantity of hazardous waste generated by the facility measured in metric tonnes, required for environmental compliance reporting.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:higgIndexScore rdf:type rdf:Property ;
    rdfs:label 'Higg Index Score' ;
    rdfs:comment 'Higg Index score measuring the facility\'s environmental and social performance, ranging from 0 to 100.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 14001 environmental management system certification.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Level' ;
    rdfs:comment 'LEED green building certification level achieved by the facility, indicating environmental design and construction standards.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:livingWageCompliant rdf:type rdf:Property ;
    rdfs:label 'Living Wage Compliant' ;
    rdfs:comment 'Indicates whether the facility pays workers a living wage as defined by local living wage benchmarks.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date when the facility commenced operations, used for lifecycle tracking and depreciation calculations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Total Area Sqm' ;
    rdfs:comment 'Total physical area of the facility measured in square meters, used for capacity planning and environmental impact calculations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterTreatmentCompliant rdf:type rdf:Property ;
    rdfs:label 'Wastewater Treatment Compliant' ;
    rdfs:comment 'Indicates whether the facility meets local and international wastewater treatment standards.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Unique policy or contract number assigned by the insurance carrier for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of covered expenses the employee pays after meeting the deductible.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are collected for the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for specific covered services (e.g., doctor visits, prescriptions).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Scope of coverage indicating who is eligible under the plan (employee only, family, etc.).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Annual deductible amount the employee must pay before the plan begins coverage. Applicable to health and insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Description of employee eligibility requirements for enrollment in this benefit plan (e.g., full-time status, waiting period).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeGroupCode rdf:type rdf:Property ;
    rdfs:label 'Employee Group Code' ;
    rdfs:comment 'Code identifying the employee group or division eligible for this benefit plan (e.g., corporate, retail, distribution center).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period End Date' ;
    rdfs:comment 'End date of the annual open enrollment period for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period Start Date' ;
    rdfs:comment 'Start date of the annual open enrollment period when employees can elect or change this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Aca Compliant' ;
    rdfs:comment 'Indicates whether this benefit plan meets Affordable Care Act minimum essential coverage and affordability requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCobraEligible rdf:type rdf:Property ;
    rdfs:label 'Is Cobra Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan is subject to COBRA continuation coverage requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFsaEligible rdf:type rdf:Property ;
    rdfs:label 'Is Fsa Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan allows employees to contribute to a Flexible Spending Account for eligible expenses.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHsaEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hsa Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan qualifies as a high-deductible health plan eligible for Health Savings Account contributions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreTaxEligible rdf:type rdf:Property ;
    rdfs:label 'Is Pre Tax Eligible' ;
    rdfs:comment 'Indicates whether employee contributions to this benefit plan are eligible for pre-tax payroll deduction under IRS Section 125.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Type of provider network for health plans (PPO, HMO, EPO, POS, or indemnity).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount the employee will pay out-of-pocket in a plan year before the plan covers 100% of costs.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Email' ;
    rdfs:comment 'Email address of the plan administrator for employee inquiries and plan management.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the individual or department responsible for administering this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorPhone rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Phone' ;
    rdfs:comment 'Phone number of the plan administrator for employee support and plan inquiries.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'Broader classification grouping related benefit types for reporting and administration.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the official plan document, summary plan description, or benefits guide.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'End date of the benefit plan year for coverage and contribution calculations.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'Start date of the benefit plan year for coverage and contribution calculations.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:summaryPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Summary Plan Description' ;
    rdfs:comment 'Brief textual summary of the benefit plan features, coverage, and key terms for employee communication.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days a new employee must wait before becoming eligible to enroll in this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether learners must complete a formal assessment or examination to pass the course.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Indicates whether successful completion of the course results in a formal certification.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Months' ;
    rdfs:comment 'The number of months the certification remains valid before renewal or recertification is required.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or industry compliance framework that mandates this course (e.g., OSHA, SOX, GDPR).' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Indicates whether the course is mandatory for regulatory or organizational compliance purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentOwner rdf:type rdf:Property ;
    rdfs:label 'Content Owner' ;
    rdfs:comment 'The name or identifier of the department, team, or individual responsible for course content and maintenance.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'The standard cost charged or budgeted per learner for course delivery, in USD.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the course, used in catalogs and registration systems.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the course delivery method and format.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'The number of continuing education or professional development credits awarded upon successful completion.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:difficultyLevel rdf:type rdf:Property ;
    rdfs:label 'Difficulty Level' ;
    rdfs:comment 'The skill or knowledge level required or targeted by the course content.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMobileCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Mobile Compatible' ;
    rdfs:comment 'Indicates whether the course content is accessible and optimized for mobile devices.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language in which the course content is delivered, using ISO 639-2 three-letter codes.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Structured list of specific skills, knowledge, or competencies learners will acquire upon completion.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollment rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment' ;
    rdfs:comment 'The maximum number of learners that can be enrolled in a single offering of the course.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minEnrollment rdf:type rdf:Property ;
    rdfs:label 'Min Enrollment' ;
    rdfs:comment 'The minimum number of learners required for a course offering to proceed.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'The minimum percentage score required on assessments to successfully complete the course.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of required prior knowledge, skills, or completed courses necessary before enrolling.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retired Timestamp' ;
    rdfs:comment 'The date and time when the course was retired or archived from active use.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortTitle rdf:type rdf:Property ;
    rdfs:label 'Short Title' ;
    rdfs:comment 'Abbreviated or shortened version of the course title for display in constrained UI spaces.' ;
    rdfs:domain ind:Course ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Department Id' ;
    rdfs:comment 'Reference to the parent department in the organizational hierarchy. Enables multi-level department structures and roll-up reporting. Null for top-level departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Total annual operating budget allocated to this department in the organization\'s base currency. Includes payroll, operating expenses, and capital expenditures.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current number of active employees assigned to this department. Used for staffing analysis and variance reporting against planned headcount.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Approved number of full-time equivalent positions budgeted for this department. Used for workforce planning and budget management.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Indicates whether this department has direct customer interaction. True for retail associates, customer service, and sales; false for back-office functions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Indicates whether this department directly generates revenue for the organization. True for retail stores, sales teams, and e-commerce; false for support functions like HR, IT, and finance.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSeasonalStaffing rdf:type rdf:Property ;
    rdfs:label 'Requires Seasonal Staffing' ;
    rdfs:comment 'Indicates whether this department requires seasonal or temporary workforce augmentation during peak periods such as holidays, back-to-school, or fashion season launches.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required' ;
    rdfs:comment 'Indicates whether employees in this department must complete safety training and certification. Typically true for distribution centers, manufacturing, and warehouse operations.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Representation Flag' ;
    rdfs:comment 'Indicates whether employees in this department are represented by a labor union or collective bargaining agreement. Used for labor relations, contract compliance, and workforce planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Primary work schedule pattern for employees in this department. Standard for 9-5 office work, shift for retail and distribution centers, flexible for variable hours, remote for work-from-home, hybrid for mixed office/remote, and on-call for emergency response.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Workday Department Code' ;
    rdfs:comment 'External identifier for this department in the Workday HCM system. Used for data integration, synchronization, and cross-system reconciliation between the lakehouse and the source HR system.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToRoleId rdf:type rdf:Property ;
    rdfs:label 'Reports To Role Id' ;
    rdfs:comment 'Reference to the supervisory role that this role typically reports to in the organizational hierarchy. Nullable for executive roles.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:compensationBandMaximum rdf:type rdf:Property ;
    rdfs:label 'Compensation Band Maximum' ;
    rdfs:comment 'Maximum salary or hourly wage for this role within the established compensation structure.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationBandMinimum rdf:type rdf:Property ;
    rdfs:label 'Compensation Band Minimum' ;
    rdfs:comment 'Minimum salary or hourly wage for this role within the established compensation structure.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation band values.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountTarget rdf:type rdf:Property ;
    rdfs:label 'Headcount Target' ;
    rdfs:comment 'Planned number of employees to be assigned to this role across the organization for workforce planning purposes.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isSafetySensitive rdf:type rdf:Property ;
    rdfs:label 'Is Safety Sensitive' ;
    rdfs:comment 'Indicates whether the role involves responsibilities that could impact workplace safety, requiring additional screening or compliance measures.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobGrade rdf:type rdf:Property ;
    rdfs:label 'Job Grade' ;
    rdfs:comment 'Compensation grade level assigned to the role for salary band determination and career progression mapping.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Key Responsibilities' ;
    rdfs:comment 'Detailed list of primary duties and accountabilities expected from individuals in this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredQualifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Qualifications' ;
    rdfs:comment 'Additional desirable qualifications that enhance candidate suitability but are not mandatory for the role.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Mandatory education, certifications, experience, and skills necessary to perform the role successfully.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Unique business identifier code for the role used across HR systems and organizational charts.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFamily rdf:type rdf:Property ;
    rdfs:label 'Role Family' ;
    rdfs:comment 'High-level categorization grouping similar roles together for workforce planning and talent management purposes.' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalShiftId rdf:type rdf:Property ;
    rdfs:label 'Original Shift Id' ;
    rdfs:comment 'The shift assignment that the requesting employee wants to swap away from.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:proposedShiftId rdf:type rdf:Property ;
    rdfs:label 'Proposed Shift Id' ;
    rdfs:comment 'The shift assignment that the requesting employee is willing to take in exchange. May be null for one-way swap requests.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:requestingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requesting Employee Id' ;
    rdfs:comment 'Employee who is initiating the shift swap request and seeking to exchange their assigned shift.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Employee Id' ;
    rdfs:comment 'Employee who is being asked to swap shifts with the requesting employee. May be null if request is open to any qualified employee.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the shift swap request was cancelled by the requesting employee. Null if not cancelled.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of automated compliance validation ensuring the swap meets labor law requirements (rest periods, maximum hours, etc.).' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Notes' ;
    rdfs:comment 'Details of any labor compliance violations detected during automated validation of the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactsOvertime rdf:type rdf:Property ;
    rdfs:label 'Impacts Overtime' ;
    rdfs:comment 'Indicates whether approving this shift swap would result in overtime hours for either employee involved.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReciprocalSwap rdf:type rdf:Property ;
    rdfs:label 'Is Reciprocal Swap' ;
    rdfs:comment 'Indicates whether this is a mutual two-way swap where both employees exchange shifts, versus a one-way coverage request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Manager Approval Status' ;
    rdfs:comment 'Whether the manager has approved, rejected, or not yet reviewed the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manager Approval Timestamp' ;
    rdfs:comment 'Date and time when the manager approved or rejected the shift swap request. Null if pending manager review.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managerNotes rdf:type rdf:Property ;
    rdfs:label 'Manager Notes' ;
    rdfs:comment 'Comments or feedback provided by the approving manager regarding their decision on the swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when notification was sent to relevant parties about the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the shift swap request was originally submitted by the requesting employee.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of swap request: direct (specific employee targeted), open (any qualified employee), or partial (portion of shift).' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSeniorityMatch rdf:type rdf:Property ;
    rdfs:label 'Requires Seniority Match' ;
    rdfs:comment 'Indicates whether the target employee must have comparable seniority level for the swap to be approved.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSkillMatch rdf:type rdf:Property ;
    rdfs:label 'Requires Skill Match' ;
    rdfs:comment 'Indicates whether the target employee must possess the same skills or certifications as the requesting employee for the swap to be valid.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Swap Reason Code' ;
    rdfs:comment 'Categorized reason why the employee is requesting the shift swap.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The system or channel through which the shift swap request was submitted (Workday HCM, mobile app, web portal).' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Target Response Status' ;
    rdfs:comment 'Whether the target employee has accepted, declined, or not yet responded to the swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Response Timestamp' ;
    rdfs:comment 'Date and time when the target employee accepted or declined the swap request. Null if no response yet.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competencyModelId rdf:type rdf:Property ;
    rdfs:label 'Competency Model Id' ;
    rdfs:comment 'Reference to the competency model or framework that defines the skills, knowledge, and behaviors required for success in this job family.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyModel .

ind:parentJobFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Job Family Id' ;
    rdfs:comment 'Reference to a parent job family in a hierarchical job family structure, enabling multi-level organizational taxonomy.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobFamily .

ind:careerPathType rdf:type rdf:Property ;
    rdfs:label 'Career Path Type' ;
    rdfs:comment 'The typical career progression model for this job family, indicating whether roles follow an individual contributor, management, or dual-track advancement path.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationGradeMaximum rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade Maximum' ;
    rdfs:comment 'The maximum compensation grade or pay band associated with this job family, defining the upper limit of compensation progression.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationGradeMinimum rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade Minimum' ;
    rdfs:comment 'The minimum compensation grade or pay band associated with this job family, used for salary structure and equity analysis.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalSkillIndicator rdf:type rdf:Property ;
    rdfs:label 'Critical Skill Indicator' ;
    rdfs:comment 'Flag indicating whether this job family represents critical skills or hard-to-fill positions requiring specialized talent acquisition strategies.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeoCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Category' ;
    rdfs:comment 'The Equal Employment Opportunity job category used for regulatory reporting and workforce diversity analysis.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Level Range Maximum' ;
    rdfs:comment 'The maximum job level or grade associated with positions in this job family, defining the career ceiling within this family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:levelRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Level Range Minimum' ;
    rdfs:comment 'The minimum job level or grade associated with positions in this job family, used for compensation and career progression planning.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockOptionEligible rdf:type rdf:Property ;
    rdfs:label 'Stock Option Eligible' ;
    rdfs:comment 'Flag indicating whether positions in this job family are eligible for equity compensation such as stock options or restricted stock units.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successionPlanningPriority rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Priority' ;
    rdfs:comment 'The priority level assigned to this job family for succession planning and leadership development initiatives.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalEducationRequirement rdf:type rdf:Property ;
    rdfs:label 'Typical Education Requirement' ;
    rdfs:comment 'The typical minimum education level required or preferred for positions within this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Typical Experience Years' ;
    rdfs:comment 'The typical number of years of relevant work experience required or preferred for entry into this job family.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionEligible rdf:type rdf:Property ;
    rdfs:label 'Union Eligible' ;
    rdfs:comment 'Flag indicating whether positions in this job family are eligible for union membership or collective bargaining representation.' ;
    rdfs:domain ind:JobFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Parent Period Id' ;
    rdfs:comment 'Reference to the parent budget period in a hierarchical structure (e.g., a quarterly period may reference its parent annual period).' ;
    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPeriod .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active budget period for operational planning and tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date when this budget period was locked to prevent further modifications, typically after approval or period close.' ;
    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business identifier code for the budget period, used for external reference and reporting (e.g., FY2024Q1, BP2024H1).' ;
    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the budget period (e.g., Fiscal Year 2024 Quarter 1, Spring 2024 Budget Cycle).' ;
    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The name or identifier of the broader planning cycle or budget process to which this period belongs (e.g., Annual Operating Plan 2024, Mid-Year Reforecast).' ;
    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntity rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity' ;
