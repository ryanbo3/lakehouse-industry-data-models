    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLimitValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit Value' ;
    rdfs:comment 'Maximum allowable concentration or amount of the substance permitted in materials or finished goods, expressed as a numeric value. Used in conjunction with threshold_unit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold limit value (e.g., ppm - parts per million, mg/kg - milligrams per kilogram, percent by weight).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Trade Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the trade compliance record. Primary key for the trade compliance master record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeComplianceRecord .

ind:carbonEmissionId rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_emission. Business justification: Trade lane emissions (Scope 3 categories 4 & 9: upstream/downstream transportation) require HS code, origin, and trade lane data from customs records. Linking enables accurate supply chain carbon foot' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonEmission .

ind:antidumpingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Antidumping Duty Flag' ;
    rdfs:comment 'Indicates whether antidumping duties are imposed on this product from the origin country.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfOriginRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Required Flag' ;
    rdfs:comment 'Indicates whether a certificate of origin document is required to claim preferential duty treatment or meet import requirements.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfOriginType rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Type' ;
    rdfs:comment 'Type of certificate of origin document required (e.g., GSP Form A, USMCA Certification, EUR.1, Movement Certificate, or self-certification).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date when the HS code classification was determined or last validated.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationMethod rdf:type rdf:Property ;
    rdfs:label 'Classification Method' ;
    rdfs:comment 'Method used to determine the HS code classification for this product.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the trade compliance record was last reviewed or audited for accuracy and regulatory adherence.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Overall trade compliance status of this record, indicating whether all regulatory requirements are met.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Coo Determination Date' ;
    rdfs:comment 'Date when the country of origin determination was made or last validated.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cooDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Coo Determination Method' ;
    rdfs:comment 'Method used to determine the country of origin, such as substantial transformation rule, tariff shift criterion, value-added percentage, or wholly obtained.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countervailingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Flag' ;
    rdfs:comment 'Indicates whether countervailing duties (anti-subsidy duties) are imposed on this product from the origin country.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyOptimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Duty Optimization Strategy' ;
    rdfs:comment 'Strategy employed to minimize duty costs, such as leveraging free trade agreements, GSP, duty drawback programs, foreign trade zones, or bonded warehouses.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export Control Classification Number assigned to the product under the Export Administration Regulations (EAR) or equivalent export control regime.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Export License Required Flag' ;
    rdfs:comment 'Indicates whether an export license is required for this product to the destination country based on export control regulations.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gspBeneficiaryCountry rdf:type rdf:Property ;
    rdfs:label 'Gsp Beneficiary Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the GSP beneficiary developing country from which the product originates.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gspEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gsp Eligible Flag' ;
    rdfs:comment 'Indicates whether the product qualifies for duty-free or reduced-duty treatment under the Generalized System of Preferences program.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Hs Code Description' ;
    rdfs:comment 'Official description of the HS code classification from the Harmonized System nomenclature.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importDutyRate rdf:type rdf:Property ;
    rdfs:label 'Import Duty Rate' ;
    rdfs:comment 'Standard import duty rate (as a percentage) applicable to this product in the destination country under the HS code classification.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedDutyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Landed Duty Paid Amount' ;
    rdfs:comment 'Total landed cost including product cost, freight, insurance, duties, and taxes, representing the full delivered cost in the destination country.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ldp Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the landed duty paid amount.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialDutyRate rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate' ;
    rdfs:comment 'Reduced duty rate (as a percentage) available under a preferential trade agreement or program (e.g., USMCA, GSP, EU FTA).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Applicable Flag' ;
    rdfs:comment 'Indicates whether import or export quotas apply to this product in the specified trade lane.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this trade compliance record was first created in the system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User or system identifier of the person or process that last updated this trade compliance record.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this trade compliance record was last modified or updated.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restrictedPartyScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Restricted Party Screening Status' ;
    rdfs:comment 'Status of screening against restricted party lists (OFAC SDN, EU Sanctions, UN Sanctions) for trade partners involved in this transaction.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Expiration Date' ;
    rdfs:comment 'Expiration date of the customs ruling, after which the ruling is no longer valid and a new determination may be required.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rulingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ruling Reference Number' ;
    rdfs:comment 'Reference number of any binding customs ruling or advance ruling obtained for this product classification or origin determination.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionedCountryFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctioned Country Flag' ;
    rdfs:comment 'Indicates whether the origin or destination country is subject to comprehensive trade sanctions or embargoes.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the most recent restricted party screening was performed for this trade compliance record.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialProgramCode rdf:type rdf:Property ;
    rdfs:label 'Special Program Code' ;
    rdfs:comment 'Code identifying any special customs program utilized (e.g., foreign trade zone, bonded warehouse, temporary import, duty drawback program).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textileCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Textile Category Code' ;
    rdfs:comment 'Textile and apparel category code used for quota monitoring and trade agreement compliance (legacy system for quota-restricted products).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Code' ;
    rdfs:comment 'Code identifying the applicable preferential trade agreement (e.g., USMCA, RCEP, EU_FTA, GSP) under which preferential duty treatment is claimed.' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeLaneCode rdf:type rdf:Property ;
    rdfs:label 'Trade Lane Code' ;
    rdfs:comment 'Origin-destination country pair for this trade compliance record, formatted as ISO 3166-1 alpha-3 codes (e.g., CHN-USA for China to United States).' ;
    rdfs:domain ind:TradeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each address record in the customer domain. Serves as the primary key for the address data product across B2C and B2B entities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the customer (B2C consumer or B2B wholesale account) who owns this address. Links the address to the parent customer profile in the CRM and Adobe Experience Platform.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:wholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Account Id' ;
    rdfs:comment 'Foreign key linking to customer.wholesale_account. Business justification: Address table is described as serving \'both B2C profiles and B2B wholesale accounts.\' Currently only has profile_id FK for B2C. Adding wholesale_account_id enables B2B address management. An address b' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'The originating channel or system through which this address was captured. Supports data lineage tracking and quality scoring. EDI-sourced addresses originate from wholesale partner Electronic Data Interchange transactions; POS addresses from SAP Customer Activity Repository in-store capture. [ENUM-REF-CANDIDATE: ecommerce|pos|crm|edi|manual|import|wholesale_portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Functional classification of the address indicating its business purpose. Billing addresses are used for invoicing and payment processing; shipping addresses for DTC order fulfillment and wholesale delivery routing; store_pickup for BOPIS (Buy Online Pick Up In Store) orders; warehouse for distribution center addresses; return for RTV (Return to Vendor) and consumer return processing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRouteCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Route Code' ;
    rdfs:comment 'USPS carrier route code assigned to the address, identifying the specific mail carrier delivery route. Used for bulk mail rate optimization, direct mail marketing campaigns, and last-mile delivery planning.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City, town, or municipality name of the address. Used in order routing, tax jurisdiction determination, and geographic sales analytics for retail store operations and DTC e-commerce.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the country_code. Stored for display and reporting purposes to avoid repeated lookups against reference data.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Composite quality score (0.00–100.00) assigned to the address record based on validation status, standardization, geocoding accuracy, and completeness. Used to prioritize address cleansing campaigns and filter high-confidence addresses for marketing and fulfillment operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text special instructions for carriers and fulfillment teams regarding delivery at this address (e.g., \'Leave at reception\', \'Dock 3 only\', \'Requires appointment\', \'Signature required\'). Passed to Manhattan Associates WMS and 3PL partners during shipment creation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Administrative district, county, or sub-regional area of the address. Used for tax jurisdiction determination (county-level sales tax), regional sales territory assignment, and wholesale distribution zone mapping.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpvConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation Code' ;
    rdfs:comment 'USPS Delivery Point Validation (DPV) confirmation code indicating the deliverability of the address. Y = confirmed deliverable; S = confirmed with secondary number missing; D = confirmed primary but secondary not confirmed; N = not confirmed. Used to assess address quality and reduce undeliverable-as-addressed (UAA) mail.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this address record is considered valid and active for business use. Supports bi-temporal data modeling for address history tracking, enabling accurate reconstruction of customer address state at any point in time for order dispute resolution and compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date until which this address record is valid. Null indicates the address is currently active with no planned expiry. Used for managing temporary addresses (e.g., seasonal warehouse locations, pop-up store addresses) and tracking address change history.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAddressCode rdf:type rdf:Property ;
    rdfs:label 'External Address Code' ;
    rdfs:comment 'Address identifier from the originating source system (e.g., Salesforce Commerce Cloud address ID, SAP S/4HANA partner address number, Adobe Experience Platform profile address key). Enables cross-system reconciliation and deduplication during data integration.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for the storage and processing of this address under GDPR Article 6 and CCPA requirements. Required for EU and California-resident customers. False triggers restricted processing workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoordinates assigned to this address. Rooftop indicates exact parcel-level accuracy; range_interpolated is street-level; geometric_center is centroid of a region; approximate is low-precision. Drives confidence scoring for proximity-based analytics and last-mile routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default billing address used for invoice generation and payment processing. Only one address per customer should have this flag set to true at any given time.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default shipping address for DTC order fulfillment. Pre-populated at checkout to streamline the purchase experience. Only one address per customer should have this flag set to true.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Customer-assigned friendly label for the address (e.g., \'Home\', \'Office\', \'NYC Warehouse\', \'LA Showroom\'). Displayed in the customer\'s address book in the DTC e-commerce storefront and CRM to facilitate address selection at checkout.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude of the address in decimal degrees (WGS 84 datum). Used for store proximity searches, BOPIS (Buy Online Pick Up In Store) routing, last-mile delivery optimization, and geographic clustering in customer analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'Primary street address line including street number, street name, and directional indicators. Required field for all address records used in order fulfillment, wholesale delivery routing, and store operations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Secondary address line for suite, apartment, unit, floor, building, or care-of information. Optional field used to capture additional location detail for B2C consumers and B2B wholesale accounts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line3' ;
    rdfs:comment 'Tertiary address line used for international addresses requiring additional locality, district, or neighborhood detail. Primarily applicable for wholesale accounts in markets with complex addressing conventions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude of the address in decimal degrees (WGS 84 datum). Used alongside latitude for geospatial analytics, delivery zone mapping, and proximity-based store operations reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Contact phone number associated with this address, formatted per E.164 international standard. Used by carriers for delivery notifications, failed delivery callbacks, and customs clearance contact for international wholesale shipments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxFlag rdf:type rdf:Property ;
    rdfs:label 'Po Box Flag' ;
    rdfs:comment 'Indicates whether the address is a Post Office (PO) Box. PO Box addresses are ineligible for certain carrier services (e.g., UPS, FedEx ground) and require USPS routing. Used in carrier selection logic during order fulfillment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the address. Used for carrier rate calculation, delivery zone assignment, tax jurisdiction mapping, and geographic segmentation in marketing analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual or business entity designated to receive deliveries at this address. May differ from the account holder name for gift shipments, B2B receiving departments, or wholesale distribution contacts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Flag' ;
    rdfs:comment 'Indicates whether the address is classified as residential (True) or commercial/business (False). Carrier surcharges differ between residential and commercial deliveries; this flag drives accurate shipping cost calculation and carrier rate shopping.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizedFlag rdf:type rdf:Property ;
    rdfs:label 'Standardized Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal authority format (e.g., USPS CASS normalization, Canada Post, Royal Mail PAF). Standardized addresses improve carrier label accuracy and reduce failed delivery rates.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region code of the address using ISO 3166-2 subdivision codes (e.g., CA, NY, ON, NSW). Used for tax calculation, shipping zone determination, and regulatory compliance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier assigned to this address for sales tax calculation purposes. Used in SAP S/4HANA FI/CO and integrated tax engines (e.g., Vertex, Avalara) to determine applicable state, county, and municipal tax rates for DTC and wholesale transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the address location (e.g., \'America/New_York\', \'Europe/London\'). Used for scheduling delivery windows, store pickup time slots, and localizing customer communications in marketing campaigns.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for address quality management and vendor SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed deliveries and carrier surcharges. Invalid addresses are flagged for customer outreach before order fulfillment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is required based on data freshness policies and carrier compliance requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cltvRecordId rdf:type rdf:Property ;
    rdfs:label 'Cltv Record Id' ;
    rdfs:comment 'Unique identifier for the CLTV record. Primary key.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: cltv_record has segment_code (STRING) which is a business key reference to segment table. Normalizing to FK enables referential integrity and allows JOINing to segment definition, criteria, and metada' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:merchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Merchandise Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to merchandising.merchandise_hierarchy. Business justification: CLTV models segment customers by preferred product category to predict future value. Category affinity (footwear vs apparel vs accessories) significantly impacts lifetime value calculations and retent' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:aov rdf:type rdf:Property ;
    rdfs:label 'Aov' ;
    rdfs:comment 'Average monetary value per order for this customer, calculated as historical revenue divided by historical order count. Key metric for customer spending behavior.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgInterPurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Avg Inter Purchase Days' ;
    rdfs:comment 'Average number of days between consecutive purchases. Used to predict next purchase timing and identify at-risk customers.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which this CLTV calculation was performed. Used to track historical CLTV snapshots and model refresh cycles.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate CLTV for this record. Historical = past revenue only; Predictive = forecasted value; Hybrid = historical + predictive; RFM = recency-frequency-monetary segmentation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnProbability rdf:type rdf:Property ;
    rdfs:label 'Churn Probability' ;
    rdfs:comment 'Predicted probability (0.0000 to 1.0000) that the customer will churn within the next defined period. Generated by churn prediction model; used for proactive retention campaigns.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'Categorical classification of the customer based on their CLTV score. Used for segmentation, prioritization, and targeted marketing strategies.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Statistical confidence level (0.0000 to 1.0000) in the predicted future value. Higher scores indicate more reliable predictions based on data quality and model fit.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerTenureDays rdf:type rdf:Property ;
    rdfs:label 'Customer Tenure Days' ;
    rdfs:comment 'Number of days since the customer\'s first purchase or account creation date. Used in CLTV model to normalize metrics and segment by lifecycle stage.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system from which the customer transaction and behavioral data was extracted for CLTV calculation. Typically Adobe Experience Platform for DTC or Salesforce for B2B wholesale accounts.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountSensitivityScore rdf:type rdf:Property ;
    rdfs:label 'Discount Sensitivity Score' ;
    rdfs:comment 'Score (0.00 to 100.00) indicating the customer\'s responsiveness to promotional pricing and markdowns. High scores indicate price-driven behavior; low scores indicate brand loyalty.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'Date of the customer\'s first completed order. Anchor date for tenure calculation and cohort analysis.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Months' ;
    rdfs:comment 'Number of months into the future for which the predicted future value is calculated (e.g., 12, 24, 36). Defines the time window for CLTV projection.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalOrders rdf:type rdf:Property ;
    rdfs:label 'Historical Orders' ;
    rdfs:comment 'Total number of completed orders placed by the customer from their first purchase to the calculation date.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalRevenue rdf:type rdf:Property ;
    rdfs:label 'Historical Revenue' ;
    rdfs:comment 'Total gross revenue generated by the customer from their first purchase to the calculation date. Excludes returns and discounts unless specified in model logic.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the customer\'s most recent completed order as of the calculation date. Used to calculate recency and identify dormant customers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether the customer is enrolled in the brand\'s loyalty program. Loyalty members typically have higher CLTV.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current tier level in the loyalty program (if enrolled). Higher tiers correlate with higher CLTV and receive differentiated benefits.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the CLTV calculation model or algorithm used (e.g., v2.3, RFM-2024-Q1). Enables tracking of model evolution and comparison across versions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent NPS score provided by the customer (scale -100 to 100 or 0 to 10 depending on survey design). Measures customer satisfaction and likelihood to recommend the brand.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date when the most recent NPS score was collected. Used to assess recency of sentiment data.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predictedFutureValue rdf:type rdf:Property ;
    rdfs:label 'Predicted Future Value' ;
    rdfs:comment 'Forecasted revenue expected from this customer over a defined future period (typically 12-36 months). Generated by predictive CLTV model using historical behavior and cohort analysis.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The channel through which the customer has generated the majority of their revenue. Used for channel-specific CLTV analysis and personalization strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency' ;
    rdfs:comment 'Average number of purchases per time period (typically per year). Calculated as total orders divided by customer tenure in years.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyDays rdf:type rdf:Property ;
    rdfs:label 'Recency Days' ;
    rdfs:comment 'Number of days since the customer\'s last purchase as of the calculation date. Key component of RFM (Recency, Frequency, Monetary) segmentation.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Risk Flag' ;
    rdfs:comment 'Boolean indicator (True/False) marking customers at high risk of churn based on churn probability threshold or behavioral signals. Triggers retention workflow in CRM.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnRate rdf:type rdf:Property ;
    rdfs:label 'Return Rate' ;
    rdfs:comment 'Percentage of orders returned by the customer (returned orders divided by total orders). High return rates may indicate fit issues, quality concerns, or wardrobing behavior.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCltv rdf:type rdf:Property ;
    rdfs:label 'Total Cltv' ;
    rdfs:comment 'Sum of historical revenue and predicted future value. Represents the total expected value of the customer relationship. Primary metric for retention prioritization and marketing investment decisions.' ;
    rdfs:domain ind:CltvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Reference to the loyalty program associated with this consent record, where consent was captured as part of a loyalty enrollment or re-enrollment process. Links to the loyalty program master in the customer domain.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:parentConsentRecordConsentId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Consent Id' ;
    rdfs:comment 'Self-referencing identifier linking this consent record to a prior version or parent consent record. Enables full consent history lineage tracking when a customer updates or re-grants consent under a new policy version.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consent .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the order transaction during which this consent was captured (e.g., checkout opt-in for marketing emails). Links to the order transaction in the order domain. Null if consent was not captured in the context of a purchase.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The touchpoint or channel through which the customer\'s consent was collected. Supports omnichannel compliance tracking across DTC e-commerce (Salesforce Commerce Cloud), POS (SAP CAR), in-store, and wholesale portals. [ENUM-REF-CANDIDATE: web|mobile_app|pos|email|sms|call_center|in_store_kiosk|wholesale_portal — promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The mechanism by which consent was obtained. Explicit = active affirmative action by the customer; Implicit = inferred from behavior; Pre-ticked = checkbox pre-selected (non-compliant under GDPR); Opt-out = consent assumed unless declined.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of the consent record indicating whether the customer has actively granted, withdrawn, or has a pending or expired consent for the specified consent type.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being captured, indicating the specific processing activity or communication channel for which the customer is granting or withdrawing permission. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectAgeVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Age Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s age was verified prior to consent capture to ensure compliance with child data protection requirements (e.g., GDPR Article 8 requires parental consent for children under 16). True = age verified; False = not verified.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The category of device used by the customer when providing consent. Supports channel analytics and helps identify consent collection patterns across DTC digital touchpoints and in-store POS terminals.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the customer completed a double opt-in verification process (e.g., email confirmation link clicked) to confirm their consent. True = double opt-in confirmed; False = single opt-in only. Relevant for marketing email compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The exact date and time when the customer completed the double opt-in verification step. Null if double opt-in was not required or not completed. Supports email marketing compliance audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this consent record is considered active and enforceable. May differ from the granted timestamp if consent is scheduled to take effect at a future date (e.g., post-enrollment cooling-off period).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Granted Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the customer actively granted consent. This is the principal business event timestamp for the consent record and is mandatory for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address of the device from which the customer submitted their consent. Captured at the moment of consent for regulatory audit purposes. May be considered PII under GDPR in certain jurisdictions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under which customer data is being processed, as required by GDPR Article 6. Consent is one of six possible legal bases. Mandatory for GDPR compliance documentation and DPA audit responses.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'The IETF BCP 47 locale code (e.g., en-US, fr-FR, de-DE) representing the language and region in which the consent notice was presented to the customer. Ensures the customer received consent information in their preferred language.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeUrl rdf:type rdf:Property ;
    rdfs:label 'Notice Url' ;
    rdfs:comment 'The URL of the privacy notice, cookie policy, or consent form that was presented to the customer at the time of consent capture. Provides an auditable link to the exact disclosure document shown.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to receiving Net Promoter Score (NPS) survey invitations. Derived from the consent record for survey/feedback consent type. Used by the CRM and customer experience teams to build eligible NPS survey audiences.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained on behalf of a minor customer. Required under GDPR Article 8 for data subjects under the age of digital consent in the applicable jurisdiction.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to data-driven personalization of their shopping experience, including product recommendations and targeted content. Consumed by Adobe Experience Platform personalization workflows.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCenterCode rdf:type rdf:Property ;
    rdfs:label 'Preference Center Code' ;
    rdfs:comment 'Reference to the preference center session or interaction through which the customer managed their consent preferences. Links to the preference management module in Adobe Experience Platform or Salesforce Marketing Cloud.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfConsentReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Consent Reference' ;
    rdfs:comment 'A reference identifier (e.g., document ID, audit log reference, or digital signature hash) pointing to the stored proof of consent artifact. Supports regulatory audit responses and dispute resolution under GDPR Article 7(1) burden-of-proof requirements.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the customer due to a policy change, expiry, or regulatory update. True = re-consent workflow must be triggered; False = consent is current and valid.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Re Consent Sent Timestamp' ;
    rdfs:comment 'The date and time when a re-consent request was dispatched to the customer via the applicable communication channel. Supports SLA tracking for re-consent campaigns and regulatory response timelines.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native identifier of this consent record in the originating source system (e.g., AEP consent event ID, Salesforce consent object ID). Enables traceability and reconciliation between the lakehouse Silver Layer and upstream operational systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record from which this consent record originated. Supports data lineage tracking across Adobe Experience Platform (AEP), Salesforce Commerce Cloud (SFCC), SAP Customer Activity Repository (SAP CAR), and Salesforce CRM.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this customer is suppressed from the specific communication type associated with this consent record. True = customer must not receive communications of this type; False = communications are permitted. Enforced in Salesforce Marketing Cloud and Adobe Experience Platform.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why a customer has been suppressed from communications of this consent type. Supports compliance reporting and operational triage for marketing and CRM teams. [ENUM-REF-CANDIDATE: customer_request|regulatory_requirement|bounce|complaint|deceased|fraud|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textSnapshot rdf:type rdf:Property ;
    rdfs:label 'Text Snapshot' ;
    rdfs:comment 'A verbatim snapshot or hash reference of the consent language presented to the customer at the time of consent. Preserves the exact wording for regulatory audit and dispute resolution purposes.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to their data being shared with third-party partners (e.g., wholesale partners, affiliate marketers, analytics vendors). Critical for CCPA \'Do Not Sell\' compliance and GDPR data sharing agreements.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent submission for digital channels. Used for technical audit trails and device fingerprinting in compliance investigations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the consent notice, privacy policy, or terms and conditions document that was presented to the customer at the time of consent capture. Enables tracking of consent obtained under different policy versions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the customer withdrew or revoked a previously granted consent. Null if consent has not been withdrawn. Required for GDPR right-to-withdraw audit compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the contact person record within the Apparel Fashion customer domain. Primary key for the contact data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:buyingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Buying Authority Level' ;
    rdfs:comment 'Indicates the contact\'s level of purchasing decision-making authority within their organization. Determines the appropriate engagement level for sales and account management teams. Ranges from no authority (none) to full executive sign-off (executive). Critical for B2B sales strategy and PO approval workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this contact has exercised their CCPA right to opt out of the sale or sharing of their personal information. When True, the contact\'s data must not be sold or shared with third parties per California law.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Functional classification of the contact\'s role in the B2B relationship. Buyer contacts are involved in purchasing decisions; merchandiser contacts manage product assortment; finance contacts handle invoicing and payments; logistics contacts manage shipping and fulfillment. [ENUM-REF-CANDIDATE: buyer|merchandiser|finance|logistics|executive|legal|operations|other — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business department or functional area within the wholesale account or enterprise partner organization where the contact works (e.g., Buying, Merchandising, Finance, Logistics). Supports targeted B2B communication routing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address for the contact person. Used for order confirmations, EDI notifications, collection previews, and B2B account communications. Maps to Salesforce Contact Email field.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether this contact has opted in to receive marketing emails, including seasonal collection previews, trade show invitations, and promotional communications. Drives email campaign eligibility in Adobe Experience Platform.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person. Used for personalized communication and salutation in B2B correspondence with wholesale accounts and enterprise partners.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which GDPR consent was most recently granted or withdrawn by this contact. Required for regulatory audit trails demonstrating lawful basis for data processing under GDPR Article 7.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this contact\'s personal data for marketing and communication purposes. \'granted\' indicates explicit consent; \'withdrawn\' triggers suppression from marketing campaigns; \'not_applicable\' for contacts outside GDPR jurisdiction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive invoices, payment reminders, and financial communications for the associated wholesale account. Supports accounts receivable workflows in SAP S/4HANA FI/CO module.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has final decision-making authority for purchasing, contract signing, or strategic partnership agreements. Used by sales and account management teams to prioritize engagement and escalation paths.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary point of contact for the associated wholesale account or enterprise partnership. Only one contact per account should be flagged as primary. Used to route default communications and account management activities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShippingContact rdf:type rdf:Property ;
    rdfs:label 'Is Shipping Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive shipping notifications, delivery confirmations, and logistics communications. Supports OTIF tracking and 3PL coordination for wholesale order fulfillment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact person within their organization (e.g., Head Buyer, VP Merchandising, Procurement Manager). Critical for understanding the contact\'s role in the B2B purchasing process.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code representing the contact\'s preferred language for business communications (e.g., en, fr, de, zh-CN). Drives localization of email templates, product catalogs, and collection presentations sent to wholesale buyers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent business interaction with this contact, including calls, emails, meetings, or trade show engagements. Used by account managers to monitor relationship health and identify contacts requiring re-engagement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person. Combined with first_name to form the full display name for B2B relationship management and CRM records.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact. Used by account managers and sales teams for relationship intelligence, pre-meeting research, and social selling in B2B wholesale and enterprise partnership contexts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in conjunction with mailing_street for physical correspondence and geographic segmentation of wholesale accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address country (e.g., USA, GBR, DEU). Used for international shipping, customs documentation, and regional account management assignment.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address line for the contact\'s mailing address. Used for sending physical samples, lookbooks, seasonal collection materials, and formal correspondence to wholesale buyers and enterprise partners.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact person in E.164 international format. Supports SMS notifications, WhatsApp business communications, and urgent B2B outreach for wholesale account management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next planned follow-up interaction with this contact. Used by account managers and sales representatives to manage their B2B outreach cadence and ensure timely engagement with wholesale buyers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred channel for business communications. Drives outreach strategy for account managers and sales representatives managing wholesale and enterprise partnerships. Supports personalization in CRM workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current status of the business relationship with this contact. Drives CRM workflows, outreach eligibility, and account management prioritization. \'do_not_contact\' enforces opt-out compliance under GDPR and CCPA.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'External identifier from the Salesforce CRM system corresponding to the Contact object. Used for cross-system reconciliation and data lineage between the lakehouse silver layer and Salesforce.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or salutation prefix for the contact person (e.g., Mr., Ms., Dr.). Used in formal written and email correspondence with wholesale buyers and enterprise partners.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate or secondary business email address for the contact. Used as a fallback communication channel when the primary email is unresponsive or for routing specific communication types such as invoices or shipping notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s location (e.g., America/New_York, Europe/London). Used to schedule calls, meetings, and automated communications at appropriate local times for global wholesale account management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique surrogate identifier for the household unit within the Apparel Fashion customer data platform. Serves as the primary key for all household-level analytics, loyalty aggregation, and personalization targeting. Role: MASTER_PARTY.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:acquisitionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Households are acquired through specific campaigns (family promotions, household bundles). Enables household-level acquisition attribution, family-targeted campaign effectiveness measurement, and hous' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:storeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Store Associate Id' ;
    rdfs:comment 'Identifier of the personal stylist or client advisor assigned to this household for VIP and high-value customer relationship management. Supports personalized styling services and clienteling programs in luxury and premium apparel segments.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the household was first acquired as a customer entity, typically aligned with the first qualifying purchase or loyalty enrollment event. Used for cohort analysis, tenure-based segmentation, and CAC (Customer Acquisition Cost) reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'The marketing channel or business event through which the household was first acquired (e.g., \'paid_search\', \'retail_store\', \'referral\', \'loyalty_signup\', \'wholesale_partner\'). Used for CAC (Customer Acquisition Cost) analysis and channel attribution reporting. [ENUM-REF-CANDIDATE: paid_search|retail_store|referral|loyalty_signup|wholesale_partner|organic_social|email_campaign|affiliate — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Household-level CLTV segment classification derived from predictive modeling in Adobe Experience Platform. Segments households into value tiers to prioritize marketing investment, retention efforts, and personalization depth. CLTV = Customer Lifetime Value.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinedAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Combined Annual Spend' ;
    rdfs:comment 'Total gross spend across all household members within the current fiscal year, aggregated from DTC, retail store (POS), and e-commerce channels. Used for household-level CLTV analysis, loyalty tier qualification, and personalization strategy. Expressed in the business\'s operating currency (USD).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentCaptureDate rdf:type rdf:Property ;
    rdfs:label 'Consent Capture Date' ;
    rdfs:comment 'The date on which the household\'s most recent marketing consent preferences were recorded or last updated. Required for GDPR and CCPA audit trails to demonstrate lawful basis for processing household-level personal data.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint through which the household\'s marketing consent was originally captured. Used for GDPR/CCPA audit compliance and to assess the quality and reliability of consent records across DTC, retail, and digital channels.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'The external account identifier assigned to this household in Salesforce CRM. Used for bi-directional synchronization between the Databricks Silver Layer and Salesforce, enabling CRM-driven campaign execution and service case management at the household level.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The calendar date on which the household unit was dissolved or deactivated. Null for active households. Used for lifecycle analysis, churn reporting, and regulatory data retention compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'The calendar date on which the household unit was formally created in the CRM or customer data platform. Used to calculate household tenure, cohort analysis, and loyalty program anniversary milestones.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/region code representing the household\'s primary geographic location. Used for regional assortment personalization, geo-targeted marketing campaigns, and compliance with jurisdiction-specific data privacy regulations (GDPR, CCPA).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'The display name assigned to the household unit, typically derived from the primary member\'s surname (e.g., \'The Johnson Household\'). Used for personalized communications, loyalty program correspondence, and CRM segmentation in Salesforce and Adobe Experience Platform.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record. \'active\' indicates an operational household with at least one active member; \'merged\' indicates the household was consolidated into another; \'dissolved\' indicates all members have been disassociated; \'pending\' indicates formation in progress.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household composition for segmentation and personalization strategies. \'family\' denotes multi-generational or parent-child units; \'couple\' denotes two-adult units; \'individual\' denotes a single-person household; \'shared_residence\' denotes non-family cohabitants; \'corporate\' denotes a business account grouped as a household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityResolutionCode rdf:type rdf:Property ;
    rdfs:label 'Identity Resolution Code' ;
    rdfs:comment 'The unique identity graph node identifier assigned by Adobe Experience Platform\'s identity resolution service, linking the household to its constituent individual identity fragments across devices, channels, and touchpoints. Used for cross-channel attribution and personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current accumulated loyalty points balance at the household level, reflecting the combined earning activity of all associated members. Used for redemption eligibility, tier qualification, and household-level reward management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the household has consented to receive marketing communications at the household level. True = opted in; False = opted out. Governs household-level campaign eligibility in compliance with GDPR and CCPA consent requirements.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of individual customer profiles currently associated with this household unit. Used for household-size-based segmentation, family apparel category targeting, and loyalty tier qualification. Reflects active members only.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredApparelCategory rdf:type rdf:Property ;
    rdfs:label 'Preferred Apparel Category' ;
    rdfs:comment 'The primary apparel category (e.g., athletic, lifestyle, luxury, footwear, accessories) most frequently purchased by household members. Derived from purchase history and used to drive personalized product recommendations, collection previews, and targeted marketing campaigns.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'The primary shopping channel through which the household most frequently transacts, as identified from purchase history analysis. DTC = Direct-to-Consumer. Used for channel-specific personalization, targeted promotions, and omnichannel engagement strategies.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Indicates whether the household has opted into RFID-based in-store personalization services, enabling smart fitting room experiences and automated loyalty point capture at RFID-equipped retail locations. RFID = Radio Frequency Identification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the household has provided explicit consent to receive SMS/text marketing communications. True = consented; False = not consented or withdrawn. Managed in compliance with TCPA, GDPR Article 6, and CCPA.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether the household has been designated as a VIP account, qualifying for exclusive services such as personal styling appointments, early collection access, private sale invitations, and dedicated client advisor support.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityLinkId rdf:type rdf:Property ;
    rdfs:label 'Identity Link Id' ;
    rdfs:comment 'Unique identifier for the identity link record. Primary key for cross-channel identity resolution.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Boolean flag indicating whether this identity link is currently active and should be used in identity resolution. True indicates active link, false indicates inactive or deprecated link.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSource rdf:type rdf:Property ;
    rdfs:label 'Channel Source' ;
    rdfs:comment 'The customer interaction channel where this identifier was captured. Indicates the touchpoint origin (web, mobile app, POS, call center, email, social media, wholesale portal, partner system). [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|email|social|wholesale|partner — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp when consent status was last updated. Required for GDPR and CCPA compliance to demonstrate when customer consent was obtained or withdrawn.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crossDeviceClusterCode rdf:type rdf:Property ;
    rdfs:label 'Cross Device Cluster Code' ;
    rdfs:comment 'Identifier for the cross-device cluster or household that this identity belongs to. Used to link multiple devices and identifiers to the same person or household for unified customer view.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days this identity link should be retained based on regulatory requirements and business policies. Used to enforce GDPR right to erasure and data minimization principles.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deletionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has requested deletion of this identifier under GDPR right to erasure or CCPA right to deletion. True indicates pending deletion, false indicates normal retention.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Deletion Scheduled Date' ;
    rdfs:comment 'Date when this identity link is scheduled for deletion. Null if no deletion is scheduled. Used to manage GDPR and CCPA deletion requests and automated data retention policies.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstSeenDate rdf:type rdf:Property ;
    rdfs:label 'First Seen Date' ;
    rdfs:comment 'The date when this identifier was first observed in any system. Helps establish customer relationship timeline and identifier age.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Geographic region code where this identifier was first captured or is primarily used. Supports regional identity resolution rules and compliance requirements (e.g., GDPR for EU, CCPA for California).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierNamespace rdf:type rdf:Property ;
    rdfs:label 'Identifier Namespace' ;
    rdfs:comment 'The namespace or domain context for the identifier. Used to disambiguate identifiers that may have the same value across different systems (e.g., Email, Phone_SHA256, ECID, IDFA, GAID).' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type of identifier being linked. Indicates the category of identity data (email, phone, cookie ID, device ID, loyalty card number, POS customer ID, Salesforce contact ID, Adobe ECID).' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual value of the identifier (e.g., email address, phone number, cookie string, device UUID, loyalty card number). This is the raw identity data point being resolved.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPiiFlag rdf:type rdf:Property ;
    rdfs:label 'Is Pii Flag' ;
    rdfs:comment 'Boolean flag indicating whether this identifier contains personally identifiable information (PII) subject to GDPR, CCPA, or other privacy regulations. True for email, phone, name; false for anonymous cookies or device IDs.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identifier' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary identifier of its type for the customer. True indicates this is the preferred identifier for communication and identification, false indicates secondary or alternate identifier.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSeenDate rdf:type rdf:Property ;
    rdfs:label 'Last Seen Date' ;
    rdfs:comment 'The most recent date when this identifier was observed in any system activity. Used to identify stale or inactive identifiers.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Link Confidence Score' ;
    rdfs:comment 'Confidence score (0.0000 to 1.0000) indicating the certainty of the identity link. Deterministic links typically score 1.0, while probabilistic links have lower scores based on matching algorithm confidence.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Created Timestamp' ;
    rdfs:comment 'Timestamp when this identity link was first established in the identity graph. Represents when the resolution process connected this identifier to the customer profile.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Expiry Timestamp' ;
    rdfs:comment 'Timestamp when this identity link expires or should be re-verified. Null for permanent links. Used for time-bound identifiers like session cookies or temporary device IDs.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkPriority rdf:type rdf:Property ;
    rdfs:label 'Link Priority' ;
    rdfs:comment 'Priority ranking of this identity link when multiple identifiers of the same type exist for a customer. Lower numbers indicate higher priority. Used to determine the primary identifier for each type.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the identity link. Active links are used in identity resolution, inactive links are historical, pending links await verification, disputed links require review, merged links have been consolidated, split links have been separated.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this identity link record. Tracks when link attributes (status, confidence, priority) were last modified.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Verified Timestamp' ;
    rdfs:comment 'Timestamp when this identity link was last verified or validated. Used for links that require periodic confirmation (e.g., email verification, phone validation).' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchAttributes rdf:type rdf:Property ;
    rdfs:label 'Match Attributes' ;
    rdfs:comment 'Comma-separated list of attributes used to establish this identity link (e.g., email+last_name, phone+postal_code). Documents the matching logic for audit and troubleshooting.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchWeight rdf:type rdf:Property ;
    rdfs:label 'Match Weight' ;
    rdfs:comment 'Numeric weight assigned to this identity link based on the strength of matching attributes. Higher weights indicate stronger matches. Used in probabilistic identity resolution scoring.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Resolution Algorithm Version' ;
    rdfs:comment 'Version identifier of the identity resolution algorithm or model used to create this link. Enables tracking of resolution logic changes over time and supports reprocessing when algorithms are updated.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The method used to establish this identity link. Deterministic uses exact matches (e.g., same email across systems), probabilistic uses statistical matching, manual indicates human review, third-party uses external identity resolution services, machine learning uses AI/ML models.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the system of record that provided this identity link (e.g., SAP_CAR for POS, SFCC for e-commerce, AEP for CDP, SFDC for CRM, LOYALTY for loyalty platform).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyReference rdf:type rdf:Property ;
    rdfs:label 'Third Party Reference' ;
    rdfs:comment 'Identifier assigned by the third-party identity resolution provider. Used for reconciliation and audit with external identity graphs.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySource rdf:type rdf:Property ;
    rdfs:label 'Third Party Source' ;
    rdfs:comment 'Name of the third-party identity resolution provider or data enrichment service that contributed to this identity link (e.g., LiveRamp, Neustar, Experian). Null for first-party links.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for the customer interaction event.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associateId rdf:type rdf:Property ;
    rdfs:label 'Associate Id' ;
    rdfs:comment 'Reference to the store associate or agent who facilitated the interaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign associated with this interaction, if applicable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:circularProgramId rdf:type rdf:Property ;
    rdfs:label 'Circular Program Id' ;
    rdfs:comment 'Foreign key linking to sustainability.circular_program. Business justification: Customer interactions (inquiries, in-store participation events, digital engagement) related to specific circular programs. Tracks engagement for program effectiveness measurement, customer education ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CircularProgram .

ind:digitalStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Digital Storefront Id' ;
    rdfs:comment 'Identifier for the digital property (website, app, portal) where the interaction occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalStorefront .

ind:interactionProfileId rdf:type rdf:Property ;
    rdfs:label 'Interaction Profile Id' ;
    rdfs:comment 'Reference to the customer who initiated or was the subject of this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:interactionReferredCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Interaction Referred Customer Profile Id' ;
    rdfs:comment 'Reference to the customer who was referred, applicable for referral-type interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:interactionReferrerCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Interaction Referrer Customer Profile Id' ;
    rdfs:comment 'Reference to the customer who made the referral, applicable for referral-type interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Reference to the promotion or offer that triggered or was presented during the interaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to order.quote. Business justification: Sales teams track customer interactions during wholesale quote negotiation process. Enables quote-related interaction analysis, sales cycle tracking, and touchpoint measurement for B2B quote conversio' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:referralProgramId rdf:type rdf:Property ;
    rdfs:label 'Referral Program Id' ;
    rdfs:comment 'Reference to the referral program under which this referral interaction occurred.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:retailStoreId rdf:type rdf:Property ;
    rdfs:label 'Retail Store Id' ;
    rdfs:comment 'Reference to the retail store where the interaction occurred, if applicable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Unique session identifier for web or app interactions, used for journey tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Reference to the Point of Sale (POS) transaction associated with this interaction, if applicable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApparelFashion .

ind:ccpaOptOutRequested rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Requested' ;
    rdfs:comment 'Flag indicating whether the customer requested CCPA opt-out during this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel or medium through which the interaction took place. [ENUM-REF-CANDIDATE: in_store|web|mobile_app|email|phone|chat|social_media|sms|direct_mail — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Customer Satisfaction score captured for this interaction, typically on a scale of 1 to 5.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The length of the interaction in seconds, applicable for sessions, calls, and visits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprConsentCaptured rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Captured' ;
    rdfs:comment 'Flag indicating whether GDPR consent was captured or confirmed during this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate of the customer location during the interaction, if captured.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate of the customer location during the interaction, if captured.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction event.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the interaction occurred in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The category of customer touchpoint or engagement event. [ENUM-REF-CANDIDATE: store_visit|website_session|app_open|email_open|email_click|chat_session|call_center_contact|stylist_consultation|referral|social_media_engagement|sms_interaction — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The business result or resolution of the interaction. [ENUM-REF-CANDIDATE: purchase|inquiry|complaint|support_resolved|support_escalated|no_action|referral_sent|appointment_booked|abandoned — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'The URL of the web page where the interaction occurred, applicable for digital interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productViewedSku rdf:type rdf:Property ;
    rdfs:label 'Product Viewed Sku' ;
    rdfs:comment 'The SKU of the product viewed or discussed during the interaction, if applicable.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralChannel rdf:type rdf:Property ;
    rdfs:label 'Referral Channel' ;
    rdfs:comment 'The channel through which the referral was made, applicable for referral-type interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'The unique referral code used or generated during this interaction, applicable for referral-type interactions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralConversionDate rdf:type rdf:Property ;
    rdfs:label 'Referral Conversion Date' ;
    rdfs:comment 'The date when the referred customer completed the conversion action in format yyyy-MM-dd.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralConversionStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Conversion Status' ;
    rdfs:comment 'The status of the referral conversion, indicating whether the referred customer completed the desired action.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRewardIssued rdf:type rdf:Property ;
    rdfs:label 'Referral Reward Issued' ;
    rdfs:comment 'Flag indicating whether a reward was issued to the referrer for this referral.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Numeric sentiment score derived from interaction content, ranging from -1.00 (negative) to 1.00 (positive).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemInteractionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Interaction Code' ;
    rdfs:comment 'The unique identifier for this interaction in the source operational system.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief subject or title describing the purpose or topic of the interaction.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each loyalty program enrollment record. One record per customer-program combination.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentTierId rdf:type rdf:Property ;
    rdfs:label 'Current Tier Id' ;
    rdfs:comment 'Reference to the loyalty tier definition the customer currently holds (e.g., Bronze, Silver, Gold, Platinum). Drives benefit entitlements and earn rate multipliers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTier .

ind:primaryLoyaltyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Profile Id' ;
    rdfs:comment 'Reference to the customer who is enrolled in the loyalty program. Links to the customer master record in the CRM/CDP.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the member has exercised their California Consumer Privacy Act (CCPA) right to opt out of the sale or sharing of their personal information. Applicable to California-resident members.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Retention Flag' ;
    rdfs:comment 'Indicates whether this enrollment record is subject to a legal hold or data retention requirement that prevents deletion even after termination. Set by legal or compliance teams.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'The Direct-to-Consumer (DTC) or wholesale channel through which the customer enrolled in the loyalty program. Supports channel attribution and omnichannel analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the customer formally enrolled in the loyalty program. Used for anniversary calculations, tenure segmentation, and cohort analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally visible, human-readable enrollment reference number used in customer communications, receipts, and CRM lookups. Follows the format LYL-XXXXXXXXXX.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty enrollment. Active = earning and redeeming; Suspended = temporarily blocked; Terminated = permanently closed; Pending = awaiting verification; Frozen = points locked pending investigation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent qualifying loyalty activity (earn, redeem, or bonus event) by this member. Used to identify inactive members, trigger re-engagement campaigns, and enforce inactivity-based points expiry policies.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase transaction that generated a loyalty points earn event. Distinct from last_activity_date which may include non-purchase activities such as profile updates or bonus events.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total cumulative points earned by the customer since enrollment inception, including all earn, bonus, and adjustment credits. Used for Customer Lifetime Value (CLTV) analysis and VIP qualification.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Total cumulative points that have expired due to inactivity or program policy since enrollment inception. Used for program liability management and customer re-engagement targeting.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total cumulative points redeemed by the customer since enrollment inception. Used to measure program engagement and redemption rate analytics.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCardNumber rdf:type rdf:Property ;
    rdfs:label 'Member Card Number' ;
    rdfs:comment 'Physical or virtual loyalty card number issued to the member. Used for in-store Point of Sale (POS) identification, RFID scanning, and customer service lookups. Classified as confidential PII identifier.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCardType rdf:type rdf:Property ;
    rdfs:label 'Member Card Type' ;
    rdfs:comment 'Format of the loyalty card issued to the member. Physical = plastic card; Virtual = app-based barcode; RFID = contactless chip card; Digital Wallet = Apple/Google Wallet pass.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty-related email communications including points statements, tier upgrade notifications, and exclusive member offers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the member has opted in to receive mobile push notifications for loyalty events such as points earned, tier changes, and reward availability.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty-related SMS/text message communications including points alerts and promotional offers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pendingPoints rdf:type rdf:Property ;
    rdfs:label 'Pending Points' ;
    rdfs:comment 'Points earned from recent transactions that are not yet confirmed as redeemable, typically held during a return window or fraud review period before being credited to the redeemable balance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current redeemable points balance available to the customer for redemption against purchases, rewards, or experiences. Reflects all earned, redeemed, adjusted, and expired points.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'Date on which the current redeemable points balance (or the oldest tranche of points) will expire if no qualifying activity occurs. Drives expiry notification campaigns.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSourceCode rdf:type rdf:Property ;
    rdfs:label 'Referral Source Code' ;
    rdfs:comment 'Campaign or referral code used at enrollment to attribute the sign-up to a specific marketing campaign, influencer, or existing member referral. Supports Customer Acquisition Cost (CAC) and campaign ROI analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemMemberCode rdf:type rdf:Property ;
    rdfs:label 'Source System Member Code' ;
    rdfs:comment 'The member or enrollment identifier as recorded in the originating source system (e.g., AEP profile ID, Salesforce Contact ID). Used for cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which the loyalty enrollment was terminated or closed, either by customer request, program policy, or fraud investigation outcome. Null for active enrollments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the loyalty enrollment was terminated. Used for compliance reporting, program analytics, and customer win-back strategy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the customer\'s current tier status became effective. Used to calculate tier tenure and determine when the next tier review is due.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date on which the customer\'s current tier qualification expires and is subject to re-evaluation based on qualifying spend or activity. Null for lifetime tiers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Spend' ;
    rdfs:comment 'Cumulative qualifying spend amount (in program currency) accumulated by the customer within the current tier qualification period. Compared against tier thresholds to determine tier status.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualFee rdf:type rdf:Property ;
    rdfs:label 'Annual Fee' ;
    rdfs:comment 'Recurring annual fee charged to maintain active membership in the loyalty program. A value of 0.00 indicates no annual fee. Used for subscription-based program revenue recognition.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:birthdayBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Birthday Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to a member during their birthday month or on their birthday date as a program benefit. A value of 0 indicates no birthday bonus.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOutSupported rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Supported' ;
    rdfs:comment 'Indicates whether this loyalty program supports the California Consumer Privacy Act (CCPA) right to opt out of the sale of personal information, applicable to members in California.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvSegmentEligible rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment Eligible' ;
    rdfs:comment 'Indicates whether members enrolled in this program are included in Customer Lifetime Value (CLTV) segmentation models run through Adobe Experience Platform for personalization and targeted marketing.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes identifying the geographic markets where this loyalty program is available for enrollment (e.g., \'USA,CAN,GBR\'). Null indicates global availability.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentFee rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee' ;
    rdfs:comment 'One-time fee charged to a customer upon joining the loyalty program. A value of 0.00 indicates the program is free to join. Applicable primarily to subscription-type programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether explicit GDPR consent must be captured from members at enrollment for this program, applicable to programs operating in EU jurisdictions. Drives consent management workflows.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDtcEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dtc Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points through the Direct-to-Consumer (DTC) channel, including brand-owned retail stores and owned digital storefronts.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points through the e-commerce channel, including the brand\'s online store and digital marketplace integrations.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartnerEarnEligible rdf:type rdf:Property ;
    rdfs:label 'Is Partner Earn Eligible' ;
    rdfs:comment 'Indicates whether members can earn loyalty points through purchases or activities with third-party partner brands or co-branded programs affiliated with Apparel Fashion.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetailStoreEligible rdf:type rdf:Property ;
    rdfs:label 'Is Retail Store Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points at physical retail store locations via POS transactions tracked through SAP Customer Activity Repository.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWholesaleEligible rdf:type rdf:Property ;
    rdfs:label 'Is Wholesale Eligible' ;
    rdfs:comment 'Indicates whether B2B wholesale account holders are eligible to participate in this loyalty program and earn rewards on wholesale purchase volumes.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Calendar date on which the loyalty program became publicly available and open for customer enrollment. Used for program age calculations and anniversary promotions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Max Points Balance' ;
    rdfs:comment 'Maximum cumulative points balance a member may hold at any time. Enforces program liability ceiling and prevents excessive point accumulation. Null indicates no cap.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Points Per Transaction' ;
    rdfs:comment 'Cap on the number of loyalty points that can be earned in a single transaction. Prevents abuse of promotional multipliers and controls program liability exposure per event.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nps Tracking Enabled' ;
    rdfs:comment 'Indicates whether Net Promoter Score (NPS) surveys are triggered for members of this loyalty program to measure customer satisfaction and advocacy. Supports CRM and brand management analytics.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Indicates whether Adobe Experience Platform personalization and AI-driven offer targeting is activated for members of this loyalty program, enabling tailored product recommendations and promotions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsEarningRate rdf:type rdf:Property ;
    rdfs:label 'Points Earning Rate' ;
    rdfs:comment 'Base number of loyalty points awarded per unit of currency spent (e.g., 1.0000 point per USD spent). Tier-specific multipliers may override this base rate at the enrollment level.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Months' ;
    rdfs:comment 'Number of months after which unspent loyalty points expire from a member\'s account if no qualifying activity occurs. A value of 0 or null indicates points do not expire.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Rule governing when points expire: rolling resets the expiry window on each qualifying activity; fixed_anniversary expires points on the member\'s enrollment anniversary; no_expiry means points never expire; calendar_year expires all points at year-end.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsMonetaryValue rdf:type rdf:Property ;
    rdfs:label 'Points Monetary Value' ;
    rdfs:comment 'Monetary value assigned to a single loyalty point at redemption (e.g., 0.010000 USD per point). Used to calculate reward discount amounts and program liability on the balance sheet.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsRedemptionThreshold rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Threshold' ;
    rdfs:comment 'Minimum accumulated points balance a member must hold before they are eligible to redeem points for rewards or discounts. Enforces program economics and prevents micro-redemptions.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the loyalty program across all channels and systems (e.g., \'AF_REWARDS_2024\'). Used in EDI, CRM, and POS integrations as the canonical business identifier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Full marketing and operational description of the loyalty program, including its value proposition, key benefits, and eligibility criteria as communicated to customers and internal stakeholders.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable marketing name of the loyalty program as presented to customers across DTC, retail, and e-commerce channels (e.g., \'Apparel Fashion Rewards\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty program. Active programs accept new enrollments and transactions; draft programs are in configuration; suspended programs are temporarily halted; retired programs are closed to new activity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure. Points-based programs award redeemable points per transaction; tiered programs unlock benefits at spend thresholds; cashback returns a percentage of spend; subscription requires a membership fee; hybrid combines multiple mechanics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIncrement rdf:type rdf:Property ;
    rdfs:label 'Redemption Increment' ;
    rdfs:comment 'Minimum unit of points that can be redeemed in a single transaction (e.g., points must be redeemed in multiples of 100). Ensures redemption amounts align with reward value denominations.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points' ;
    rdfs:comment 'Number of loyalty points awarded to an existing member when they successfully refer a new customer who enrolls in the program. Supports member acquisition through word-of-mouth incentives.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Terms Effective Date' ;
    rdfs:comment 'Date on which the current version of the loyalty program terms and conditions became legally effective. Members enrolled before this date may require re-consent notification.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the loyalty program\'s terms and conditions document currently in effect (e.g., \'v2.1\'). Used to track member consent to specific T&C versions and manage regulatory compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Total number of distinct membership tiers defined within this loyalty program (e.g., 3 for Silver, Gold, Platinum). Drives tier configuration and progression rule setup.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Metric' ;
    rdfs:comment 'The primary metric used to determine a member\'s tier eligibility and progression (e.g., cumulative spend amount, total points earned, number of transactions, or units purchased within the qualification period).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Period Months' ;
    rdfs:comment 'Rolling or fixed window in months over which a member\'s qualifying activity is measured for tier assignment or maintenance (e.g., 12 months for annual tier review).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welcomeBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Welcome Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to a new member upon successful enrollment in the program. A value of 0 indicates no welcome bonus is offered.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Unique identifier for the payment method record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Reference to the billing address associated with this payment method. Links to customer address record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addedChannel rdf:type rdf:Property ;
    rdfs:label 'Added Channel' ;
    rdfs:comment 'The channel or interface through which the customer added this payment method (web storefront, mobile app, physical store, call center, API integration).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'The date when the customer added this payment method to their account.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoUpdateEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Update Enabled' ;
    rdfs:comment 'Flag indicating whether this payment method is enrolled in automatic card updater services that refresh expiry dates and card numbers when cards are reissued.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bnplProvider rdf:type rdf:Property ;
    rdfs:label 'Bnpl Provider' ;
    rdfs:comment 'The buy-now-pay-later service provider when payment_type is buy_now_pay_later (Klarna, Afterpay, Affirm, Sezzle, Zip, QuadPay). Null for non-BNPL payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The card network or brand (Visa, Mastercard, American Express, Discover, JCB, Diners Club). Null for non-card payment types.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardFundingType rdf:type rdf:Property ;
    rdfs:label 'Card Funding Type' ;
    rdfs:comment 'The funding mechanism of the card (credit, debit, prepaid, charge card, or deferred debit). Null for non-card payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the cardholder as it appears on the payment instrument. Used for verification and display purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Date' ;
    rdfs:comment 'The date when this payment method record is scheduled for deletion or archival according to data retention policies and regulatory requirements.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalWalletType rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Type' ;
    rdfs:comment 'The specific digital wallet provider when payment_type is digital_wallet (Apple Pay, Google Pay, PayPal, Samsung Pay, Venmo, Alipay, WeChat Pay). Null for non-wallet payment types. [ENUM-REF-CANDIDATE: apple_pay|google_pay|paypal|samsung_pay|venmo|alipay|wechat_pay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1-12). Null for non-expiring payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The expiration year of the payment card (four-digit year). Null for non-expiring payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'The total number of failed or declined transaction attempts using this payment method. High failure counts may trigger automatic suspension.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudCheckDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Date' ;
    rdfs:comment 'The date when the most recent fraud risk assessment was performed on this payment method.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'A risk score (0.00 to 100.00) assigned by fraud detection systems indicating the likelihood that this payment method is associated with fraudulent activity. Higher scores indicate higher risk.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the customers default payment method for one-click checkout and recurring billing. Only one payment method per customer should be marked as default.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'The name of the financial institution that issued the card or payment instrument. Derived from Bank Identification Number (BIN) lookup.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the country where the payment instrument was issued. Used for fraud detection and regional compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the card number or account number, used for customer identification and display purposes. PCI-DSS compliant truncated value.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this payment method was last successfully used for a transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Optional customer-defined nickname or label for this payment method to help identify it in their account (e.g., \'Work Visa\', \'Personal Amex\').' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Method Status' ;
    rdfs:comment 'Current lifecycle status of the payment method. Active methods are available for transactions; expired methods have passed their expiry date; suspended methods are temporarily blocked; pending or failed verification indicates incomplete validation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'The category of payment instrument (credit card, debit card, digital wallet such as Apple Pay or Google Pay, gift card, buy-now-pay-later services such as Klarna or Afterpay, or store credit).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Flag' ;
    rdfs:comment 'Flag confirming that this payment method record complies with PCI-DSS requirements (no raw card data stored, only tokenized references).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurringBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Recurring Billing Enabled' ;
    rdfs:comment 'Flag indicating whether this payment method is authorized for recurring billing or subscription charges without additional customer authentication.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeDSecureEnrolled rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Enrolled' ;
    rdfs:comment 'Flag indicating whether this payment method is enrolled in 3D Secure authentication (Verified by Visa, Mastercard SecureCode, etc.) for enhanced transaction security.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'The tokenized reference to the actual payment instrument, provided by the payment gateway or tokenization service. No raw card data is stored. PCI-DSS compliant token.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationProvider rdf:type rdf:Property ;
    rdfs:label 'Tokenization Provider' ;
    rdfs:comment 'The name of the payment gateway or tokenization service that issued the token (e.g., Stripe, Adyen, Braintree, Salesforce Commerce Cloud Payment Gateway).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'The total number of successful transactions processed using this payment method since it was added.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique system-generated identifier for each customer preference or measurement record. Serves as the primary key for the preference data product.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Previous Preference Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior version of this preference record when it was superseded or updated. Enables preference history chaining and change tracking without a separate history table. Null for the initial version of a preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:sustainableMaterialId rdf:type rdf:Property ;
    rdfs:label 'Sustainable Material Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainable_material. Business justification: Customers express material preferences (organic cotton, recycled polyester, Tencel). Drives personalized product recommendations, sustainability-focused marketing segmentation, and preference-based fi' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainableMaterial .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The brand to which the preferred_brand_size or brand preference applies. Enables brand-specific size mapping and brand affinity tracking for personalization and assortment planning.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelOfCapture rdf:type rdf:Property ;
    rdfs:label 'Channel Of Capture' ;
    rdfs:comment 'The business channel through which this preference was captured or inferred. Supports omnichannel preference reconciliation and channel-specific personalization strategies. Distinct from source_system (technical system) — this represents the customer-facing channel. [ENUM-REF-CANDIDATE: ecommerce|retail_store|mobile_app|style_quiz|loyalty_portal|wholesale|call_center|social_commerce|pop_up_event — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPalette rdf:type rdf:Property ;
    rdfs:label 'Color Palette' ;
    rdfs:comment 'Customer\'s preferred color palette or specific color preferences (e.g., \'neutrals\', \'earth tones\', \'navy,white,grey\', \'bold primaries\'). Used to filter product recommendations and personalize marketing communications. May store comma-separated color values.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Customer\'s preferred channel for receiving marketing communications, personalized recommendations, and promotional offers. Drives omnichannel campaign orchestration in Adobe Experience Platform and Salesforce CRM. Null indicates no stated preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Communication Frequency' ;
    rdfs:comment 'Customer\'s preferred frequency for receiving marketing and personalization communications. Used to govern outreach cadence in campaign management and suppress over-communication. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the customer provided consent for this preference data to be collected and used. Required for GDPR and CCPA audit trails. Null for preferences captured prior to consent framework implementation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for this preference data to be collected, stored, and used for personalization purposes. Mandatory for GDPR and CCPA compliance. False values trigger suppression from personalization pipelines.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fitPreference rdf:type rdf:Property ;
    rdfs:label 'Fit Preference' ;
    rdfs:comment 'Customer\'s preferred garment fit silhouette for the associated apparel category. Drives fit-based filtering in recommendation engines and reduces return rates by surfacing appropriately fitted products. [ENUM-REF-CANDIDATE: slim|regular|relaxed|oversized|athletic|tailored|skinny|straight|wide_leg — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'Version identifier of the AI/ML model used to infer this preference from behavioral data (e.g., \'style_affinity_v2.3\', \'fit_inference_v1.1\'). Null for self-declared or manually assigned preferences. Supports model governance, A/B testing, and reproducibility audits.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this preference record, whether from customer self-service, behavioral re-inference, stylist update, or system refresh. Critical for staleness detection and preference freshness scoring in recommendation engines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'IETF BCP 47 locale code representing the language and regional context in which this preference was captured (e.g., \'en-US\', \'fr-FR\', \'de-DE\'). Ensures size system and communication preferences are interpreted in the correct regional context.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialPreference rdf:type rdf:Property ;
    rdfs:label 'Material Preference' ;
    rdfs:comment 'Customer\'s preferred fabric or material types (e.g., \'organic cotton\', \'merino wool\', \'recycled polyester\', \'linen\'). Supports sustainability-aligned personalization and allergy/sensitivity filtering. May store comma-separated material values.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericValue rdf:type rdf:Property ;
    rdfs:label 'Numeric Value' ;
    rdfs:comment 'Parsed numeric representation of the preference value for body measurements and quantitative preferences (e.g., chest circumference 92.50, inseam 76.00, shoe size 10.5). Null for non-numeric preferences. Used by recommendation engines for size matching algorithms.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occasionPreference rdf:type rdf:Property ;
    rdfs:label 'Occasion Preference' ;
    rdfs:comment 'Customer\'s preferred occasions or use cases for apparel (e.g., \'workwear\', \'casual\', \'formal\', \'activewear\', \'evening\'). Supports occasion-based product filtering and targeted collection recommendations. May store comma-separated occasion values.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this preference record was manually overridden by a stylist, customer service agent, or the customer themselves, superseding a previously inferred value. When true, the record takes precedence over behavioral inference for the same preference type.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level category classifying the type of preference or measurement captured. Drives segmentation and personalization routing in Adobe Experience Platform. [ENUM-REF-CANDIDATE: style|fit|color|size|brand|communication|sustainability|material|fragrance|occasion|price_range — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Lifecycle status of this preference record. Active records are used in personalization; superseded records have been replaced by a newer version; expired records have passed their validity window; withdrawn records reflect customer opt-out; pending_verification awaits confirmation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Specific type of preference or measurement within the category (e.g., \'neckline_style\', \'waist_fit\', \'chest_circumference_cm\', \'preferred_color_palette\', \'inseam_length_cm\'). Provides granular classification for recommendation engine targeting.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The actual value of the preference or measurement (e.g., \'slim fit\', \'navy blue\', \'92.5\', \'XL\', \'Nike\'). For numeric measurements, this stores the string representation; numeric_value stores the parsed decimal. Supports both categorical and quantitative preference data.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredBrandSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Brand Size' ;
    rdfs:comment 'Customer\'s preferred size label as used by a specific brand for the associated apparel category (e.g., \'M\', \'L\', \'32x30\', \'10.5\'). Captures brand-specific sizing conventions which differ from standardized measurements, enabling brand-aware size recommendations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRangePreference rdf:type rdf:Property ;
    rdfs:label 'Price Range Preference' ;
    rdfs:comment 'Customer\'s preferred price tier for apparel purchases, aligned to the brand\'s pricing architecture. Informs personalized product recommendations and promotional targeting. Derived from purchase history behavioral inference or self-declared via style profile.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Method by which this preference or measurement was captured. Drives confidence scoring and consent management. Self-declared data from customer profiles, behavioral inference from purchase/browse history, stylist-assigned from in-store consultations, in-store body scan from 3D measurement technology, virtual try-on from digital fitting tools.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleAffinity rdf:type rdf:Property ;
    rdfs:label 'Style Affinity' ;
    rdfs:comment 'Customer\'s preferred aesthetic style or fashion archetype (e.g., \'minimalist\', \'streetwear\', \'classic\', \'bohemian\', \'athleisure\'). Captured via style quiz, behavioral inference from browse/purchase patterns, or stylist assessment. Feeds personalization and collection recommendation engines.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPreference rdf:type rdf:Property ;
    rdfs:label 'Sustainability Preference' ;
    rdfs:comment 'Indicates whether the customer has expressed a preference for sustainably sourced, ethically produced, or eco-certified products. When true, recommendation engines prioritize GOTS-certified, BCI cotton, and OEKO-TEX certified products.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit associated with the numeric preference value (e.g., \'cm\' for body measurements, \'in\' for imperial measurements, \'EU\'/\'UK\'/\'US\' for shoe sizing systems). Null for non-numeric or unitless preferences. [ENUM-REF-CANDIDATE: cm|in|mm|kg|lbs|EU|UK|US|JP — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Date after which this preference record expires and should no longer be applied in personalization. Null indicates an open-ended preference with no expiry. Supports seasonal preference windows and time-limited style profiles.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this preference record is considered valid and applicable for personalization. Supports temporal preference management, enabling seasonal or time-bounded preferences (e.g., summer color preferences).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmContactId rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Id' ;
    rdfs:comment 'Native contact identifier from Salesforce CRM (Salesforce Contact ID). Used to cross-reference the golden profile with the operational CRM record for campaign management, service interactions, and sales activity tracking.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:loyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Id' ;
    rdfs:comment 'FK to customer.loyalty_tier' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTier .

ind:mergedIntoProfileId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Profile Id' ;
    rdfs:comment 'When profile_status = \'merged\', this field contains the profile_id of the surviving golden master profile into which this record was consolidated. Enables identity resolution audit trails and supports data subject access requests (DSAR) under GDPR Article 15 by tracing merged identities.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the consumer profile was first created or acquired. Tracks whether the consumer originated from e-commerce (Salesforce Commerce Cloud), a retail store (SAP CAR POS), wholesale partnership, mobile app, social media campaign, or loyalty program signup. Used for Customer Acquisition Cost (CAC) analysis and channel attribution. [ENUM-REF-CANDIDATE: ecommerce|retail_store|wholesale|mobile_app|social_media|loyalty_signup|referral|pop_up — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCity rdf:type rdf:Property ;
    rdfs:label 'Address City' ;
    rdfs:comment 'City component of the consumer\'s primary residential address. Used for geographic market segmentation, store proximity analysis, and regional campaign targeting.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressCountry rdf:type rdf:Property ;
    rdfs:label 'Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the consumer\'s primary residential address. Determines applicable data residency requirements, shipping eligibility, and regulatory jurisdiction for data processing.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the consumer\'s primary residential address (street number and street name). Used for direct mail campaigns, order shipping, loyalty card delivery, and geographic segmentation analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the consumer\'s primary residential address. Used for geographic segmentation, trade area analysis, store proximity scoring, and regional assortment planning insights.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adobeEcid rdf:type rdf:Property ;
    rdfs:label 'Adobe Ecid' ;
    rdfs:comment 'Adobe Experience Cloud Identity (ECID) assigned by Adobe Experience Platform (AEP) for cross-channel identity stitching, personalization, and real-time audience segmentation. Core identifier in the identity resolution graph.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Consumer\'s date of birth in yyyy-MM-dd format. Used for age verification, birthday loyalty reward triggers, demographic segmentation, and compliance with COPPA (Children\'s Online Privacy Protection Act) for consumers under 13.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the consumer\'s country of residence. Determines applicable privacy regulations (GDPR for EU residents, CCPA for California residents), tax jurisdiction, and eligible product catalog.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of the consumer profile by relationship type. Distinguishes Direct-to-Consumer (DTC) retail shoppers, Business-to-Business (B2B) wholesale account contacts, VIP/high-value consumers, employee accounts, brand influencers, and anonymous guest profiles. Drives differential pricing, service levels, and personalization strategies. [ENUM-REF-CANDIDATE: b2c_consumer|b2b_wholesale|vip|employee|influencer|anonymous — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Consumer\'s legal family name (last name or surname) as captured at registration or point of sale. Combined with given_name to form the full display name for communications and identity resolution.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Consumer\'s self-reported gender identity. Used for personalized product recommendations, size guidance, targeted marketing, and assortment planning analytics. Collected with explicit consent per GDPR and CCPA requirements.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'Consumer\'s legal given name (first name) as captured at registration or point of sale. Used for personalized communications, loyalty program enrollment, and CRM record matching.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Numeric confidence score (0.0000 to 1.0000) representing the certainty of the identity resolution linking multiple cross-channel identifiers to this golden profile. Higher scores indicate stronger deterministic signal overlap. Used to prioritize profile merge decisions and flag low-confidence profiles for manual review in Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Resolution Method' ;
    rdfs:comment 'The method used to resolve and stitch cross-channel identifiers into this golden profile. \'deterministic\' uses exact-match signals (email, loyalty card); \'probabilistic\' uses statistical inference (device fingerprint, behavioral signals); \'hybrid\' combines both; \'manual\' indicates agent-assisted resolution. Sourced from Adobe Experience Platform Identity Service.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s identity has been verified through email confirmation, phone OTP, or document verification. True = identity verified; False = unverified or pending. Verified profiles receive higher identity confidence scores and are eligible for full loyalty benefits and personalization features.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedIdentifierCount rdf:type rdf:Property ;
    rdfs:label 'Linked Identifier Count' ;
    rdfs:comment 'Total number of cross-channel identifiers (email, phone, cookie ID, device ID, loyalty card, POS customer ID, Salesforce contact ID, Adobe ECID) currently linked to this golden profile in the identity resolution graph. Higher counts indicate a more complete omnichannel view of the consumer.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyCardNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Number' ;
    rdfs:comment 'Physical or digital loyalty program card number issued to the consumer. Used as a cross-channel identifier linking in-store POS transactions, e-commerce orders, and loyalty reward accruals to the golden profile.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the consumer enrolled in the brand\'s loyalty program. Used to calculate loyalty tenure, anniversary reward triggers, and cohort-based loyalty program performance analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posCustomerCode rdf:type rdf:Property ;
    rdfs:label 'Pos Customer Code' ;
    rdfs:comment 'Customer identifier assigned within the SAP Customer Activity Repository (CAR) POS system for in-store transaction linkage. Enables reconciliation of retail store purchases to the golden consumer profile.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Consumer\'s preferred communication language expressed as an IETF BCP 47 language tag (e.g., en-US, fr-FR, de-DE). Drives localized content delivery, email template selection, and customer service routing in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShoeSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Shoe Size' ;
    rdfs:comment 'Consumer\'s self-reported or purchase-history-derived preferred footwear size including size system notation (e.g., US 10, EU 44, UK 9). Used for footwear product recommendations, inventory allocation, and size curve analytics in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSizeBottom rdf:type rdf:Property ;
    rdfs:label 'Preferred Size Bottom' ;
    rdfs:comment 'Consumer\'s self-reported or algorithmically inferred preferred size for bottoms/lower body apparel (e.g., waist/inseam measurements or S/M/L sizing). Used for personalized product recommendations, size-based filtering, and returns reduction analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSizeTop rdf:type rdf:Property ;
    rdfs:label 'Preferred Size Top' ;
    rdfs:comment 'Consumer\'s self-reported or algorithmically inferred preferred size for tops/upper body apparel (e.g., XS, S, M, L, XL, XXL, or numeric sizing). Used for personalized product recommendations, size-based filtering, and fit analytics in Salesforce Commerce Cloud and Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the consumer profile record. \'active\' indicates a verified, engaged consumer; \'merged\' indicates the record has been consolidated into a master golden profile; \'pending_verification\' indicates email or identity not yet confirmed. Drives CRM suppression lists and data governance workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the consumer has enabled push notifications on their registered mobile device(s) for the brand\'s mobile application. True = enabled; False = disabled. Drives mobile engagement campaign eligibility in Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'The operational system of record from which this consumer profile was originally created or first ingested. Identifies whether the profile originated from Salesforce Commerce Cloud (e-commerce), Adobe Experience Platform (digital), SAP Customer Activity Repository (POS/in-store), mobile app, or manual entry. Critical for data lineage and source system reconciliation. [ENUM-REF-CANDIDATE: salesforce_commerce_cloud|adobe_aep|sap_car_pos|mobile_app|in_store_tablet|wholesale_portal|manual_entry — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique identifier for the referral event. Primary key for the referral data product.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Profile Id' ;
    rdfs:comment 'Identifier of the existing customer who initiated the referral. Links to the customer profile who is advocating for the brand.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:referralReferredCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Referred Customer Profile Id' ;
    rdfs:comment 'Identifier of the new customer who was referred. Links to the customer profile who received the referral and may convert.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'The date when the referred customer accepted the referral by clicking the link or entering the code. Null if not yet accepted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Amount' ;
    rdfs:comment 'The monetary value of the conversion order placed by the referred customer. Used to calculate reward eligibility and track referral program ROI.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when the referred customer completed their first qualifying purchase or conversion event. Null if conversion has not yet occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Boolean indicator of whether the referred customer completed a qualifying conversion event, typically their first purchase. True indicates successful conversion; False indicates no conversion yet.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysToConversion rdf:type rdf:Property ;
    rdfs:label 'Days To Conversion' ;
    rdfs:comment 'The number of days between the referral date and the conversion date. Measures the time lag from referral to purchase. Null if not yet converted.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Boolean indicator of whether this referral has been flagged as potentially fraudulent. True indicates suspected fraud; False indicates legitimate referral.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReason rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason' ;
    rdfs:comment 'Description of the reason why this referral was flagged as fraudulent. Null if fraud_flag is False. Used for fraud pattern analysis and prevention.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkUrl rdf:type rdf:Property ;
    rdfs:label 'Link Url' ;
    rdfs:comment 'The unique URL generated for the referrer to share with potential customers. Contains tracking parameters to attribute conversions back to this referral.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'The date when the referral event was initiated by the referrer. Represents the business event timestamp when the referral code was generated or shared.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral. Tracks whether the referred customer has accepted the referral, made a qualifying purchase, or if the referral has expired or been declined.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralTier rdf:type rdf:Property ;
    rdfs:label 'Referral Tier' ;
    rdfs:comment 'The tier or level of the referral program under which this referral was made. Different tiers may offer different reward structures or benefits.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralTimestamp rdf:type rdf:Property ;
    rdfs:label 'Referral Timestamp' ;
    rdfs:comment 'The precise timestamp when the referral event was recorded in the system. Captures the exact moment the referral was logged, including time zone information.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referredCustomerEmail rdf:type rdf:Property ;
    rdfs:label 'Referred Customer Email' ;
    rdfs:comment 'The email address of the referred customer at the time of referral. Used for tracking and communication purposes. May be null if referral was made without email capture.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referredCustomerPhone rdf:type rdf:Property ;
    rdfs:label 'Referred Customer Phone' ;
    rdfs:comment 'The phone number of the referred customer at the time of referral. Used for tracking and communication purposes. May be null if referral was made without phone capture.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Reward Expiry Date' ;
    rdfs:comment 'The date when the issued reward expires and can no longer be redeemed by the referrer. Null for rewards with no expiration.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rewardIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Reward Issued Date' ;
    rdfs:comment 'The date when the reward was issued to the referrer. Null if reward has not yet been issued.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rewardIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Reward Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether the referrer has been issued their reward for this successful referral. True indicates reward has been granted; False indicates pending or not eligible.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'The type of reward issued to the referrer for the successful referral. Indicates the form of incentive provided as part of the referral program.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardValue rdf:type rdf:Property ;
    rdfs:label 'Reward Value' ;
    rdfs:comment 'The monetary or points value of the reward issued to the referrer. Quantifies the incentive amount granted for the successful referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCampaign rdf:type rdf:Property ;
    rdfs:label 'Source Campaign' ;
    rdfs:comment 'The marketing campaign or initiative that prompted the referrer to make this referral. Used for campaign attribution and effectiveness analysis.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent segment when this segment is a sub-segment or refinement of a broader segment hierarchy (e.g., \'High-Value Female Loyalists\' as a child of \'High-Value Loyalists\'). Supports hierarchical segment structures for nested targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:ageBandMax rdf:type rdf:Property ;
    rdfs:label 'Age Band Max' ;
    rdfs:comment 'Maximum age (in years) of the target demographic for this segment. Used in demographic segmentation to define the upper bound of the age range for personalization and marketing targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageBandMin rdf:type rdf:Property ;
    rdfs:label 'Age Band Min' ;
    rdfs:comment 'Minimum age (in years) of the target demographic for this segment. Used in demographic segmentation to define the lower bound of the age range for personalization and marketing targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Usd' ;
    rdfs:comment 'Planned marketing spend budget allocated to campaigns targeting this segment, expressed in USD. Used for marketing financial planning in Anaplan and ROI measurement. Classified as confidential as it reflects internal budget allocation strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'The commerce channel(s) this segment is scoped to. DTC (Direct-to-Consumer) covers owned e-commerce and retail stores; wholesale covers B2B accounts; omnichannel covers all channels. Drives channel-specific activation in Salesforce Commerce Cloud and SAP Customer Activity Repository.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Status' ;
    rdfs:comment 'Current synchronization status of this segment to Salesforce CRM for campaign activation. Synced indicates the segment definition and membership are current in CRM; pending indicates a sync is queued; failed indicates a sync error requiring investigation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of this segment to Salesforce CRM. Used to monitor data freshness and SLA compliance for campaign activation pipelines.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerClass rdf:type rdf:Property ;
    rdfs:label 'Customer Class' ;
    rdfs:comment 'Indicates whether the segment targets B2C (individual consumers), B2B (wholesale accounts), household-level groupings, or enterprise partnerships. Drives different activation logic and CRM workflows in Salesforce and Adobe Experience Platform.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Data Consent Required' ;
    rdfs:comment 'Indicates whether activation of this segment requires verified customer consent under GDPR or CCPA regulations. When true, only profiles with explicit consent records in Adobe Experience Platform may be included in segment activations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Data Sensitivity Level' ;
    rdfs:comment 'Data classification level assigned to this segment definition based on the sensitivity of its qualifying criteria and the customer data it processes. Restricted segments may involve sensitive demographic or behavioral data requiring heightened access controls per GDPR and CCPA.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Human-readable description of the business rules and logic used to qualify customers into this segment (e.g., \'Customers with 3+ purchases in last 90 days, AOV > $150, active loyalty member\'). Serves as the business specification for technical implementation in Adobe Experience Platform.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionExpression rdf:type rdf:Property ;
    rdfs:label 'Definition Expression' ;
    rdfs:comment 'Structured query expression or rule set (e.g., PQL — Profile Query Language from Adobe Experience Platform) that technically defines segment membership criteria. Enables automated re-evaluation and sync to CRM activation systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this segment definition expires and is no longer used for active targeting. Nullable for evergreen segments with no planned expiry. Supports time-bound campaign segments tied to seasonal promotions or collection launches.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this segment definition becomes active and eligible for campaign targeting and personalization activation. Supports seasonal and campaign-specific segment scheduling aligned with collection launches and promotional calendars.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Estimated count of customer profiles qualifying for this segment at the last evaluation run. Used for campaign reach planning, budget allocation, and marketing ROI forecasting. Sourced from Adobe Experience Platform segment evaluation output.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'How frequently the segment membership is re-evaluated and refreshed. Real-time segments update continuously via streaming; daily/weekly/monthly segments are refreshed on a scheduled batch cadence. Impacts campaign activation timeliness and system resource planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Evaluation Method' ;
    rdfs:comment 'Method by which Adobe Experience Platform evaluates segment membership. Batch evaluation runs on a scheduled cadence; streaming evaluation updates membership in near-real-time as profile events occur; edge evaluation enables on-device personalization at the point of interaction.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderAffinity rdf:type rdf:Property ;
    rdfs:label 'Gender Affinity' ;
    rdfs:comment 'Gender affinity profile of the segment used for product assortment targeting, personalization, and marketing creative selection. Informs merchandising allocation and collection planning for gender-specific product lines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic market scope for this segment expressed as ISO 3166-1 alpha-3 country codes or region identifiers (e.g., \'USA\', \'GBR\', \'DEU\'). Supports geo-targeted campaign activation and regional merchandising decisions. Multiple values stored as comma-separated codes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The customer lifecycle stage this segment targets. Acquisition segments target new prospects; activation targets first-time buyers; retention targets active loyal customers; reactivation targets declining customers; winback targets lapsed customers. Aligns with CRM and CLTV (Customer Lifetime Value) strategy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Linked' ;
    rdfs:comment 'Indicates whether this segment is linked to a loyalty program tier or reward structure. Loyalty-linked segments receive differentiated offers, early access to collections, and exclusive promotions managed through Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Target Flag' ;
    rdfs:comment 'Indicates whether this segment is designated as a target population for NPS (Net Promoter Score) survey distribution. NPS-targeted segments are used to measure customer satisfaction and brand loyalty across DTC and wholesale channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerFunction rdf:type rdf:Property ;
    rdfs:label 'Owner Function' ;
    rdfs:comment 'The business function responsible for defining, maintaining, and activating this segment. Marketing-owned segments drive campaign targeting; merchandising-owned segments inform assortment and OTB planning; CRM-owned segments support loyalty and NPS programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the individual business owner or manager accountable for this segment\'s definition, quality, and activation. Supports data stewardship and governance workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationUseCase rdf:type rdf:Property ;
    rdfs:label 'Personalization Use Case' ;
    rdfs:comment 'Primary personalization or activation use case this segment supports (e.g., \'Email re-engagement campaign\', \'Homepage product recommendation\', \'Loyalty tier upgrade offer\', \'Wholesale reorder reminder\'). Guides campaign brief creation and Adobe Experience Platform activation configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking of this segment relative to other segments within the same owner function or campaign cycle. Lower numbers indicate higher priority. Used to resolve conflicts when a customer qualifies for multiple segments and to sequence campaign activation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmTier rdf:type rdf:Property ;
    rdfs:label 'Rfm Tier' ;
    rdfs:comment 'RFM (Recency, Frequency, Monetary) classification tier assigned to this segment when segment_type is \'rfm\'. Champions are highest-value active buyers; loyal are consistent purchasers; at_risk are declining in engagement; lapsed have not purchased recently; prospects are new or low-activity customers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the segment (e.g., \'LOYAL_VIP_B2C\', \'WHOLESALE_TIER1\'). Used as the stable reference key across Adobe Experience Platform, Salesforce CRM, and campaign activation systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable display name of the customer segment (e.g., \'High-Value Loyalists\', \'Lapsed Wholesale Accounts\', \'Gen-Z Streetwear Enthusiasts\'). Used in campaign briefs, merchandising plans, and personalization dashboards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment. Active segments are available for campaign targeting and personalization. Draft segments are under construction. Inactive segments are paused. Archived segments are retained for historical analysis but not used in live activations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the methodology used to define the segment. Behavioral segments are based on purchase/browse actions; demographic on age/gender/location; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; channel_based on preferred shopping channel (DTC, wholesale, retail).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeLastEvaluatedDate rdf:type rdf:Property ;
    rdfs:label 'Size Last Evaluated Date' ;
    rdfs:comment 'Date on which the segment membership count (estimated_size) was last computed by Adobe Experience Platform. Indicates data freshness for campaign planning and audience activation decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Segment Code' ;
    rdfs:comment 'The native identifier of this segment in the originating source system (e.g., Adobe Experience Platform Segment GUID, Salesforce CRM Segment Record ID). Enables bidirectional traceability and sync reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagsList rdf:type rdf:Property ;
    rdfs:label 'Tags List' ;
    rdfs:comment 'Comma-separated list of free-form business tags applied to this segment for discoverability, governance, and cross-functional search (e.g., \'loyalty,high-value,email-only,seasonal\'). Supports segment catalog management in Adobe Experience Platform and internal data governance portals.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Unique identifier for the customer service request case. Primary key.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circularEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Circular Enrollment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.circular_enrollment. Business justification: Service cases related to circular program enrollments (item condition disputes, incentive redemption issues, collection logistics problems). Links support tickets to specific enrollments for resolutio' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CircularEnrollment .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Service requests (returns, warranty claims, complaints) incur customer service costs that must be allocated to cost centers for departmental cost accounting, chargeback analysis to stores/channels, an' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:handlingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Handling Associate Id' ;
    rdfs:comment 'Foreign key linking to store.associate. Business justification: Service requests handled by store associates (in-store returns, complaints, styling consultations) require associate-level tracking for performance reviews, training needs identification, customer sat' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to order.rma. Business justification: Customer service tracks service cases related to returns. Links service requests to RMAs for return case management, resolution tracking, and customer satisfaction analysis on return-related issues.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sample_request. Business justification: Customer service requests for fit issues, quality defects, or product inquiries trigger sourcing sample requests to evaluate construction, measurements, or material specifications. Quality team reques' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleRequest .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_shipment. Business justification: Customer service requests for damaged, lost, or delayed items require direct reference to the specific shipment for carrier claims, insurance filing, and root cause analysis. Service teams need shipme' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:supplierFactoryId rdf:type rdf:Property ;
    rdfs:label 'Supplier Factory Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_factory. Business justification: Factory-level traceability for quality issues enables targeted corrective actions, factory-specific audits, and compliance remediation. Essential for apparel industry quality management systems, regul' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierFactory .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name or identifier of the customer service team responsible for handling this case type. Used for workload distribution and routing.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible case number provided to the customer for tracking and reference purposes. Human-readable identifier.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the service request. Tracks progression from initial submission through resolution and closure.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the service request type. Categorizes the nature of the customer inquiry or issue.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the service request was formally closed. May differ from resolved timestamp if additional administrative steps were required.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address used by the customer for this specific service request. May differ from primary customer email if submitted by alternate contact.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number used by the customer for this specific service request. Used for follow-up communication and case resolution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer after case resolution. Typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the first response was provided to the customer by a service agent. Used for Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyPointsAdjustment rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Adjustment' ;
    rdfs:comment 'Number of loyalty program points added or deducted as part of the service request resolution. Positive for credits, negative for deductions.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the service request based on urgency and business impact. Determines Service Level Agreement (SLA) targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier of the product related to this service request, if applicable. Used for product-specific complaints or inquiries.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount refunded to the customer as part of the service request resolution, if applicable. Excludes currency code.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionCategory rdf:type rdf:Property ;
    rdfs:label 'Resolution Category' ;
    rdfs:comment 'Classification of how the service request was resolved. Used for analytics on resolution patterns and customer satisfaction drivers.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the actions taken and resolution provided to the customer. Captures final outcome and customer satisfaction details.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the service request was marked as resolved. Indicates when the issue was addressed to customer satisfaction.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Detailed description of the customer issue, inquiry, or complaint as initially reported. Captures full context of the service request.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Hours' ;
    rdfs:comment 'Target number of hours within which the case should be resolved based on case priority and Service Level Agreement (SLA) rules.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Hours' ;
    rdfs:comment 'Target number of hours within which the first response should be provided based on case priority and Service Level Agreement (SLA) rules.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the customer submitted the service request. Tracks customer contact preferences and channel effectiveness. [ENUM-REF-CANDIDATE: store|email|chat|phone|web|mobile_app|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Survey Response Date' ;
    rdfs:comment 'Date when the customer completed the satisfaction or Net Promoter Score (NPS) survey related to this service request.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sizeProfileId rdf:type rdf:Property ;
    rdfs:label 'Size Profile Id' ;
    rdfs:comment 'Unique identifier for the customer size profile record. Primary key.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyShapeType rdf:type rdf:Property ;
    rdfs:label 'Body Shape Type' ;
    rdfs:comment 'Optional classification of the customer\'s body shape (e.g., \'athletic\', \'pear\', \'rectangle\', \'hourglass\', \'inverted_triangle\'). Used for advanced fit personalization and style recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:braBandSize rdf:type rdf:Property ;
    rdfs:label 'Bra Band Size' ;
    rdfs:comment 'Bra band size measurement (e.g., \'32\', \'34\', \'36\'). Specific to women\'s intimate apparel and activewear.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:braCupSize rdf:type rdf:Property ;
    rdfs:label 'Bra Cup Size' ;
    rdfs:comment 'Bra cup size measurement (e.g., \'A\', \'B\', \'C\', \'D\', \'DD\'). Specific to women\'s intimate apparel and activewear.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chestMeasurement rdf:type rdf:Property ;
    rdfs:label 'Chest Measurement' ;
    rdfs:comment 'Chest circumference measurement. Critical for tops, outerwear, and activewear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The source system or platform from which this size profile data originated (e.g., \'Adobe Experience Platform\', \'Salesforce Commerce Cloud\', \'In-Store Kiosk\', \'Mobile App\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:footLengthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Foot Length Measurement' ;
    rdfs:comment 'Foot length measurement from heel to toe. Critical for footwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:footWidthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Foot Width Measurement' ;
    rdfs:comment 'Foot width measurement at the widest point. Used for footwear width sizing (narrow, medium, wide).' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'The customer\'s height measurement. Critical for inseam, sleeve length, and overall garment length recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightUnit rdf:type rdf:Property ;
    rdfs:label 'Height Unit' ;
    rdfs:comment 'The unit in which height is expressed (inches, centimeters, or feet).' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipMeasurement rdf:type rdf:Property ;
    rdfs:label 'Hip Measurement' ;
    rdfs:comment 'Hip circumference measurement. Critical for bottoms and activewear sizing, particularly for women\'s apparel.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inseamMeasurement rdf:type rdf:Property ;
    rdfs:label 'Inseam Measurement' ;
    rdfs:comment 'Inseam length measurement from crotch to ankle. Critical for pants and jeans sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryProfile rdf:type rdf:Property ;
    rdfs:label 'Is Primary Profile' ;
    rdfs:comment 'Indicates whether this is the customer\'s primary size profile used for default fit recommendations and personalization. Only one profile per customer should be marked as primary.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'The date when the customer last verified or confirmed their size profile measurements. Used to prompt customers to update outdated profiles.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when this measurement was captured or last updated. Body measurements can change over time; recent measurements are prioritized for fit recommendations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The method by which the measurement was captured. Self-reported measurements may be less accurate than professional scans or tailor measurements. Used to weight fit recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'The specific body measurement captured (e.g., chest, waist, hip, inseam, shoulder_width, foot_length, neck, sleeve_length, rise, thigh). Varies by apparel category.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'The numeric value of the body measurement. Precision supports fractional measurements for accurate fit personalization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:neckMeasurement rdf:type rdf:Property ;
    rdfs:label 'Neck Measurement' ;
    rdfs:comment 'Neck circumference measurement. Critical for dress shirts, formal wear, and outerwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Profile Completeness Percentage' ;
    rdfs:comment 'Percentage (0-100) indicating how complete this size profile is based on the number of measurements captured relative to the ideal set for the apparel category. Used to prompt customers to complete their profiles.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRateImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Return Rate Impact Flag' ;
    rdfs:comment 'Indicates whether this size profile has been effective in reducing the customer\'s return rate for sizing-related issues. Used to measure the business impact of fit personalization.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shoulderWidthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Shoulder Width Measurement' ;
    rdfs:comment 'Shoulder width measurement from shoulder point to shoulder point. Critical for tops, outerwear, and formal wear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Size Confidence Score' ;
    rdfs:comment 'A calculated confidence score (0-100) indicating the reliability of this size profile based on measurement source, recency, and consistency with purchase history. Higher scores indicate more reliable fit recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sleeveLengthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Sleeve Length Measurement' ;
    rdfs:comment 'Sleeve length measurement from shoulder to wrist. Critical for tops, outerwear, and formal wear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stylistNotes rdf:type rdf:Property ;
    rdfs:label 'Stylist Notes' ;
    rdfs:comment 'Optional free-text notes from personal stylists or store associates regarding the customer\'s fit preferences, body shape considerations, or special sizing needs. Treated as confidential business data.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualTryOnEnabled rdf:type rdf:Property ;
    rdfs:label 'Virtual Try On Enabled' ;
    rdfs:comment 'Indicates whether this size profile is enabled for virtual try-on experiences in the e-commerce platform. Requires sufficient measurement data and customer consent.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waistMeasurement rdf:type rdf:Property ;
    rdfs:label 'Waist Measurement' ;
    rdfs:comment 'Waist circumference measurement. Critical for bottoms, activewear, and outerwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'The customer\'s weight measurement. Optional field used for advanced fit modeling and size recommendations. Treated as confidential business data.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'The unit in which weight is expressed (pounds or kilograms).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_agreement. Business justification: Major wholesale accounts negotiate dedicated sourcing agreements for capacity allocation, pricing tiers, and exclusive manufacturing windows. Nordstrom, Macy\'s, and other tier-1 accounts secure produc' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Wholesale accounts in multi-entity apparel businesses must be assigned to the contracting legal entity (company code) for statutory reporting, tax compliance, intercompany revenue recognition, and leg' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:parentAccountWholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Wholesale Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent wholesale account record. Supports parent-child hierarchy modeling for franchise networks, buying groups, and corporate group structures. Null for top-level accounts.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor. Business justification: Wholesale accounts (retailers, distributors) often have preferred vendor relationships for private label manufacturing, co-branding, or exclusive production agreements. Critical for vendor allocation,' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to sourcing.rfq. Business justification: Wholesale accounts (department stores, specialty retailers) participate in RFQ processes for private label and exclusive product development programs. Buyers submit design briefs and cost targets thro' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known alphanumeric account number assigned to the wholesale buyer in the ERP system (SAP S/4HANA SD Customer Number). Used as the primary business identifier on purchase orders, invoices, and EDI transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the wholesale account. Controls order acceptance, credit extension, and EDI transaction processing. \'On Hold\' blocks new purchase orders pending credit review.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier classification of the wholesale account reflecting revenue contribution, strategic importance, and service priority. Platinum and Gold accounts receive dedicated sales reps, priority allocation, and preferential credit terms.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the wholesale account by channel and business model. Drives assortment planning, pricing strategy, and service level agreements. [ENUM-REF-CANDIDATE: department_store|specialty_retailer|boutique|online_retailer|franchise|buying_group|distributor|corporate_group — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for the wholesale account\'s billing location. Used on invoices, credit documents, and financial correspondence.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and geographic sales reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the wholesale account\'s billing address. Drives VAT/GST applicability, currency assignment, and cross-border trade compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the wholesale account\'s billing address. Used for tax jurisdiction mapping, freight zone calculation, and geographic analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the current wholesale trading agreement. Null indicates an open-ended agreement. Used to trigger contract renewal workflows and prevent order acceptance on expired terms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current wholesale trading agreement or master service agreement with this account. Defines the period during which agreed pricing, MOQ, and credit terms are binding.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance approved for this wholesale account in the account\'s transaction currency. Enforced by SAP S/4HANA FI credit management to block orders when exceeded.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit risk rating assigned to the wholesale account. Informs credit limit setting, payment term negotiation, and order hold decisions. Aligned with Dun & Bradstreet or internal credit scoring models. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|D — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) identifier uniquely identifying the legal business entity globally. Used for credit risk assessment, EDI partner setup, and supplier onboarding.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the wholesale account is set up for Electronic Data Interchange (EDI) transaction processing (purchase orders, invoices, advance ship notices). True = EDI-enabled; False = manual/portal-based ordering.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Code' ;
    rdfs:comment 'EDI interchange qualifier and sender/receiver ID assigned to the wholesale account for EDI transaction routing. Required for X12 850 (PO), 810 (Invoice), and 856 (ASN) message exchange.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this account within the parent-child hierarchy. Level 1 = top-level corporate group; Level 2 = regional subsidiary; Level 3 = individual franchise or buying office. Used for roll-up reporting and consolidated financial analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibility between Apparel Fashion and the wholesale account. FOB and DDP are most common in apparel wholesale. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'Primary apparel industry segment the wholesale account operates in. Used for targeted collection planning, assortment curation, and marketing alignment. [ENUM-REF-CANDIDATE: athletic|lifestyle|luxury|outdoor|workwear|childrenswear|accessories|footwear — promote to reference product]' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the wholesale account as filed with the relevant government authority. Used for contracts, invoicing, and regulatory compliance. Sourced from SAP S/4HANA SD Customer Master.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnits rdf:type rdf:Property ;
    rdfs:label 'Moq Units' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in units agreed with this wholesale account per purchase order or per style. Enforced during order entry to ensure production viability and margin targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the wholesale account was formally onboarded and activated for trading. Used to calculate account tenure, cohort analysis, and anniversary-based relationship milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key (e.g., NET30, NET60, 2/10NET30) defining the due date and early payment discount structure for invoices issued to this wholesale account. Directly impacts cash flow forecasting and DSO metrics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Comm Channel' ;
    rdfs:comment 'The wholesale account\'s preferred channel for receiving business communications including order confirmations, collection previews, and account updates. Drives outreach strategy in Salesforce and Adobe Experience Platform.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactDepartment rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Department' ;
    rdfs:comment 'Department of the primary contact person within the wholesale account organization. Used to route communications to the correct functional team (e.g., buying team for assortment decisions, logistics for shipment coordination). [ENUM-REF-CANDIDATE: buying|merchandising|logistics|finance|marketing|operations|executive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact person at the wholesale account. Used for order confirmations, collection previews, and account communications. Mapped to Salesforce Contact Email field.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct business phone number of the primary contact person at the wholesale account. Used for urgent order communications, sales calls, and account management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the wholesale account (e.g., Head Buyer, VP Merchandising, Procurement Director). Used to assess buying authority and route communications appropriately.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based sales territory to which this wholesale account is assigned. Used for quota allocation, territory performance reporting, and sales rep assignment.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Unique identifier of the corresponding Account object in Salesforce CRM. Enables bi-directional synchronization between the data lakehouse and Salesforce for sales pipeline, opportunity, and contact management.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the US, VAT registration number in the EU) for the wholesale account. Required for invoicing, customs documentation, and regulatory reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name of the wholesale account, which may differ from the legal entity name. Used for commercial communications and brand recognition.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionId rdf:type rdf:Property ;
    rdfs:label 'Collection Id' ;
    rdfs:comment 'FK to product.collection' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collection .

ind:primaryCadCreatedByDesignerId rdf:type rdf:Property ;
    rdfs:label 'Primary Cad Created By Designer Id' ;
    rdfs:comment 'Reference to the designer or user who originally created this CAD file. Supports accountability and design attribution.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:supersededByCadFileId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Cad File Id' ;
    rdfs:comment 'Reference to the newer CAD file that supersedes this version. Null if this is the current version. Supports version lineage and obsolescence tracking.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CadFile .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when this CAD file was approved. Null if not yet approved. Tracks approval milestone in the design lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when this CAD file was archived or moved to inactive status. Null if the file is still active. Supports lifecycle management and data retention policies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'A cryptographic hash (e.g., MD5, SHA-256) of the CAD file content. Used for file integrity verification, duplicate detection, and change detection.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationNotes rdf:type rdf:Property ;
    rdfs:label 'Collaboration Notes' ;
    rdfs:comment 'Free-text field for collaboration comments, feedback, or discussion notes related to this CAD file. Supports team communication and design iteration.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designComplexity rdf:type rdf:Property ;
    rdfs:label 'Design Complexity' ;
    rdfs:comment 'A qualitative assessment of the design complexity of the CAD file. Used for resource planning, costing, and production feasibility analysis.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designPhase rdf:type rdf:Property ;
    rdfs:label 'Design Phase' ;
    rdfs:comment 'The stage in the product design lifecycle where this CAD file is currently positioned. Tracks progression from concept through production-ready status.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The original file name of the CAD or 3D design file as stored in the system, including extension. Used for file identification and retrieval.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'The size of the CAD file in bytes. Used for storage management, transfer planning, and system capacity planning.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current approval and lifecycle status of the CAD file. Indicates whether the file is in draft, under review, approved for production, rejected, superseded by a newer version, or archived.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:garmentCategory rdf:type rdf:Property ;
    rdfs:label 'Garment Category' ;
    rdfs:comment 'The high-level product category that this CAD file represents (e.g., tops, bottoms, outerwear, footwear, accessories). Supports design taxonomy and filtering.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is3dSimulation rdf:type rdf:Property ;
    rdfs:label 'Is 3d Simulation' ;
    rdfs:comment 'Boolean indicator of whether this CAD file includes 3D simulation capabilities or is a 3D model file (e.g., CLO3D, VStitcher). True indicates 3D simulation support, False indicates 2D CAD only.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProductionReady rdf:type rdf:Property ;
    rdfs:label 'Is Production Ready' ;
    rdfs:comment 'Boolean indicator of whether this CAD file has been finalized and approved for production use. True indicates production-ready, False indicates still in design or development.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationType rdf:type rdf:Property ;
    rdfs:label 'Storage Location Type' ;
    rdfs:comment 'The type of storage system where the CAD file resides. Options include local server, cloud storage (e.g., AWS S3, Azure Blob), PLM system, or network drive.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'The full file system or cloud storage path where the CAD file is stored. Enables file retrieval and access management. Classified as confidential to protect internal storage architecture.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Free-text field for technical notes, design instructions, or special considerations related to this CAD file. Supports collaboration and knowledge transfer among design team members.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailPath rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Path' ;
    rdfs:comment 'The file path or URL to a thumbnail preview image of the CAD file. Supports quick visual identification and browsing in design management systems.' ;
    rdfs:domain ind:CadFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPaletteId rdf:type rdf:Property ;
    rdfs:label 'Color Palette Id' ;
    rdfs:comment 'Unique identifier for the color palette record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColorPalette .

ind:assignedDesignerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Designer Id' ;
    rdfs:comment 'Reference to the lead designer responsible for creating and curating this color palette.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:primaryColorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Color Employee Id' ;
    rdfs:comment 'Reference to the user (typically Creative Director or Merchandising Lead) who approved this color palette for production use.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryColorModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Color Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this color palette record.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval state of the color palette in the design governance workflow: draft (in development), submitted (under review), approved (ready for production), rejected (not approved), archived (historical record).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStoryNarrative rdf:type rdf:Property ;
    rdfs:label 'Color Story Narrative' ;
    rdfs:comment 'Descriptive narrative explaining the inspiration, mood, and strategic intent behind the color palette. Communicates the emotional and aesthetic direction to design, merchandising, and marketing teams.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTeam rdf:type rdf:Property ;
    rdfs:label 'Design Team' ;
    rdfs:comment 'Name or identifier of the design team or studio that developed this palette (e.g., \'Womens Apparel Design\', \'Footwear Innovation Lab\').' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalFilePath rdf:type rdf:Property ;
    rdfs:label 'Digital File Path' ;
    rdfs:comment 'File system path or cloud storage URI where the authoritative digital palette file is stored (e.g., Adobe Swatch Exchange .ase file, Pantone Color Manager file).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Gender category this palette is designed for: mens, womens, unisex, kids, or all genders.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarketFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Focus' ;
    rdfs:comment 'Primary geographic markets or regions this palette is tailored for (e.g., \'North America\', \'EMEA\', \'APAC\'). Reflects regional color preferences and cultural sensitivities.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hexCodesList rdf:type rdf:Property ;
    rdfs:label 'Hex Codes List' ;
    rdfs:comment 'Comma-separated list of all hexadecimal color codes in the palette. Used for digital design, e-commerce product imagery, and web applications.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncsCodesList rdf:type rdf:Property ;
    rdfs:label 'Ncs Codes List' ;
    rdfs:comment 'Comma-separated list of Natural Color System codes for colors in the palette. Used in European markets and for architectural/interior design applications.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfColors rdf:type rdf:Property ;
    rdfs:label 'Number Of Colors' ;
    rdfs:comment 'Total count of distinct colors included in this palette. Typically ranges from 5 to 30 colors depending on palette type and collection scope.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paletteCategory rdf:type rdf:Property ;
    rdfs:label 'Palette Category' ;
    rdfs:comment 'Product category scope for which this palette is intended: apparel, footwear, accessories, or all categories.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paletteCode rdf:type rdf:Property ;
    rdfs:label 'Palette Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the color palette for system identification and cross-referencing in PLM, ERP, and merchandising systems.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paletteName rdf:type rdf:Property ;
    rdfs:label 'Palette Name' ;
    rdfs:comment 'Business name of the color palette (e.g., \'Spring Bloom 2024\', \'Urban Edge Neutrals\'). Human-readable identifier used by design and merchandising teams.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paletteType rdf:type rdf:Property ;
    rdfs:label 'Palette Type' ;
    rdfs:comment 'Classification of the palette\'s strategic role within the collection: core (foundational colors), accent (highlight colors), neutral (base colors), trend (fashion-forward colors), seasonal (time-bound colors), capsule (limited edition).' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pantoneCodesList rdf:type rdf:Property ;
    rdfs:label 'Pantone Codes List' ;
    rdfs:comment 'Comma-separated list of all Pantone codes included in the palette. Authoritative reference for material sourcing and supplier communication.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorName rdf:type rdf:Property ;
    rdfs:label 'Primary Color Name' ;
    rdfs:comment 'Business-friendly name of the primary or hero color in the palette (e.g., \'Sunset Coral\', \'Midnight Navy\'). Used in marketing and merchandising communications.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryHexCode rdf:type rdf:Property ;
    rdfs:label 'Primary Hex Code' ;
    rdfs:comment 'Hexadecimal color code for the primary color, used in digital design, e-commerce, and web applications (e.g., \'#FF6347\').' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPantoneCode rdf:type rdf:Property ;
    rdfs:label 'Primary Pantone Code' ;
    rdfs:comment 'Pantone Matching System (PMS) code for the primary color, ensuring consistent color reproduction across materials and suppliers (e.g., \'18-1664 TPX\').' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRgbCode rdf:type rdf:Property ;
    rdfs:label 'Primary Rgb Code' ;
    rdfs:comment 'RGB color code for the primary color, used in digital rendering and screen-based applications (e.g., \'rgb(255, 99, 71)\').' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ralCodesList rdf:type rdf:Property ;
    rdfs:label 'Ral Codes List' ;
    rdfs:comment 'Comma-separated list of RAL color standard codes for colors in the palette. Used for industrial and hardware applications (e.g., zippers, buttons, trims).' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonYear rdf:type rdf:Property ;
    rdfs:label 'Season Year' ;
    rdfs:comment 'Calendar year associated with the season (e.g., 2024, 2025). Used for multi-year trend analysis and archival.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryColorNames rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Names' ;
    rdfs:comment 'Comma-separated list of business-friendly names for secondary colors in the palette. Supports merchandising and marketing communication.' ;
    rdfs:domain ind:ColorPalette ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFocus rdf:type rdf:Property ;
    rdfs:label 'Sustainability Focus' ;
    rdfs:comment 'Indicates whether this palette prioritizes sustainable or eco-friendly dyeing processes and materials. True if sustainability is a core design principle.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Sustainability Notes' ;
    rdfs:comment 'Free-text notes describing sustainability considerations, such as low-impact dyes, natural pigments, or water-saving processes associated with this palette.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer demographic or psychographic segment this palette is designed for (e.g., \'Gen Z Urban\', \'Active Lifestyle\', \'Luxury Consumer\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to a visual thumbnail or preview image of the color palette, used in PLM systems and design collaboration tools.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAlignmentTags rdf:type rdf:Property ;
    rdfs:label 'Trend Alignment Tags' ;
    rdfs:comment 'Comma-separated tags linking this palette to macro trends, cultural movements, or trend forecasting themes (e.g., \'sustainability\', \'retro revival\', \'digital nomad\').' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerId rdf:type rdf:Property ;
    rdfs:label 'Designer Id' ;
    rdfs:comment 'Reference to the designer responsible for creating and developing this colorway. Links to workforce or user management systems for accountability and collaboration tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:bodyColorHex rdf:type rdf:Property ;
    rdfs:label 'Body Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the body color, used for digital design tools, CAD systems, and e-commerce visualization. Example: \'#1A2B3C\'.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyColorNcs rdf:type rdf:Property ;
    rdfs:label 'Body Color Ncs' ;
    rdfs:comment 'NCS (Natural Color System) code for the body color, used as an alternative or complementary color specification system. Example: \'S 2070-R80B\'.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyColorPantone rdf:type rdf:Property ;
    rdfs:label 'Body Color Pantone' ;
    rdfs:comment 'Pantone color reference for the main body fabric or material. Provides standardized color specification for manufacturing and quality control. Example: \'PANTONE 19-4052 TCX\'.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyColorRal rdf:type rdf:Property ;
    rdfs:label 'Body Color Ral' ;
    rdfs:comment 'RAL color standard code for the body color, commonly used in European manufacturing. Example: \'RAL 5005\'.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the colorway development was cancelled (e.g., \'Failed to meet color standards\', \'Market trend shift\', \'Cost prohibitive\', \'Supplier capability constraints\'). Provides learning for future design decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledDate rdf:type rdf:Property ;
    rdfs:label 'Cancelled Date' ;
    rdfs:comment 'Date when the colorway development was cancelled or rejected. Captures design decisions to discontinue a colorway before production approval.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:colorMatchingTolerance rdf:type rdf:Property ;
    rdfs:label 'Color Matching Tolerance' ;
    rdfs:comment 'Acceptable color deviation tolerance specification (e.g., \'Delta E < 1.0\', \'Grade 4-5 Grey Scale\'). Defines quality standards for lab dip and production approval using industry-standard color measurement systems.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStoryTheme rdf:type rdf:Property ;
    rdfs:label 'Color Story Theme' ;
    rdfs:comment 'Overarching theme or narrative that inspired the colorway palette (e.g., \'Urban Jungle\', \'Coastal Sunset\', \'Nordic Minimalism\'). Provides creative context for the color selection and guides design cohesion across the collection.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorfastnessRequirement rdf:type rdf:Property ;
    rdfs:label 'Colorfastness Requirement' ;
    rdfs:comment 'Required colorfastness performance standards for washing, light, crocking, and perspiration. Example: \'AATCC 61-2A Grade 4 minimum\'. Critical for product quality and compliance with consumer safety standards.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayCode rdf:type rdf:Property ;
    rdfs:label 'Colorway Code' ;
    rdfs:comment 'Internal alphanumeric code assigned to the colorway during development phase. May become part of the SKU (Stock Keeping Unit) structure upon production approval.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayName rdf:type rdf:Property ;
    rdfs:label 'Colorway Name' ;
    rdfs:comment 'Proposed name for the colorway, typically reflecting the color story or theme (e.g., \'Midnight Navy\', \'Desert Sand\', \'Ocean Breeze\'). Used for internal design communication and eventual product marketing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date when the colorway was officially confirmed for production. Marks the transition from design development to production-ready status and triggers creation of the master colorway record in the product domain.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contrastColorHex rdf:type rdf:Property ;
    rdfs:label 'Contrast Color Hex' ;
    rdfs:comment 'Hexadecimal color code for contrast elements, used in digital design and visualization tools.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contrastColorPantone rdf:type rdf:Property ;
    rdfs:label 'Contrast Color Pantone' ;
    rdfs:comment 'Pantone color reference for contrast elements such as piping, stitching, or accent panels. Ensures color consistency across components.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerNotes rdf:type rdf:Property ;
    rdfs:label 'Designer Notes' ;
    rdfs:comment 'Free-text notes from the designer capturing creative intent, inspiration sources, color matching challenges, or special instructions for production. Bridges design vision to manufacturing execution.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStatus rdf:type rdf:Property ;
    rdfs:label 'Development Status' ;
    rdfs:comment 'Current stage in the colorway development and approval lifecycle. Tracks progression from initial proposal through lab dip and strike-off approval to final confirmation or rejection. Critical for Time and Action (TNA) calendar management. [ENUM-REF-CANDIDATE: proposed|lab_dip_requested|lab_dip_approved|lab_dip_rejected|strike_off_requested|strike_off_approved|strike_off_rejected|confirmed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labDipApprovalRound rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Approval Round' ;
    rdfs:comment 'Number of lab dip submission rounds required to achieve approval. Tracks color matching difficulty and supplier capability. Higher numbers indicate color complexity or supplier challenges.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labDipApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Approved Date' ;
    rdfs:comment 'Date when the lab dip sample was approved by the design and technical teams. Milestone date that allows progression to strike-off or bulk production.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labDipReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Received Date' ;
    rdfs:comment 'Date when lab dip samples were received for review and approval. Used to track supplier responsiveness and TNA (Time and Action) adherence.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labDipRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Requested Date' ;
    rdfs:comment 'Date when lab dip samples were requested from the supplier or mill. Lab dips are physical color samples used to approve dye formulations before bulk production.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liningColorHex rdf:type rdf:Property ;
    rdfs:label 'Lining Color Hex' ;
    rdfs:comment 'Hexadecimal color code for lining fabric, used in digital design documentation and tech pack specifications.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liningColorPantone rdf:type rdf:Property ;
    rdfs:label 'Lining Color Pantone' ;
    rdfs:comment 'Pantone color reference for interior lining fabric. Ensures consistency in hidden components that affect overall product quality perception.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardReference rdf:type rdf:Property ;
    rdfs:label 'Mood Board Reference' ;
    rdfs:comment 'Reference identifier or URL to the mood board or design inspiration board that guided this colorway development. Links to digital asset management systems or PLM visual libraries.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikeOffApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Strike Off Approved Date' ;
    rdfs:comment 'Date when the strike-off sample was approved. Critical milestone for printed or patterned colorways before bulk fabric production.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strikeOffRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Strike Off Requested Date' ;
    rdfs:comment 'Date when strike-off samples (printed fabric samples) were requested for colorways involving prints or patterns. Strike-offs validate print quality and color accuracy on actual fabric.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Sustainability or environmental certifications applicable to the colorway dyes and processes (e.g., \'GOTS Certified\', \'OEKO-TEX Standard 100\', \'bluesign approved\'). Supports compliance with environmental standards and brand sustainability commitments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Target Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the target cost (e.g., \'USD\', \'EUR\', \'GBP\'). Ensures accurate cost tracking across global sourcing operations.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Target Cost Per Unit' ;
    rdfs:comment 'Target cost for the colorway components (fabric, dye, trim) per unit. Used for cost estimation during design phase and informs Open-to-Buy (OTB) planning and Initial Markup (IMU) calculations.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendResearchReference rdf:type rdf:Property ;
    rdfs:label 'Trend Research Reference' ;
    rdfs:comment 'Reference to trend research reports or forecasting sources that influenced the colorway selection (e.g., WGSN report ID, Pantone Color of the Year). Provides market validation for design decisions.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimColorHex rdf:type rdf:Property ;
    rdfs:label 'Trim Color Hex' ;
    rdfs:comment 'Hexadecimal color code for trim components, used in digital tech packs and 3D design visualization.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimColorPantone rdf:type rdf:Property ;
    rdfs:label 'Trim Color Pantone' ;
    rdfs:comment 'Pantone color reference for trim components such as zippers, buttons, hardware, and labels. Critical for Bill of Materials (BOM) accuracy and sourcing.' ;
    rdfs:domain ind:ColorwayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Concept Created By Employee Id' ;
    rdfs:comment 'Reference to the user or designer who originally created this concept record. Links to workforce master data for accountability and collaboration tracking.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conceptEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Concept Employee Id' ;
    rdfs:comment 'Reference to the individual (e.g., Creative Director, Design Manager) who approved this concept for progression to the next stage. Links to workforce master data.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conceptModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Concept Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this concept record. Supports audit trail and collaboration workflow visibility.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:packagingSustainabilityId rdf:type rdf:Property ;
    rdfs:label 'Packaging Sustainability Id' ;
    rdfs:comment 'Foreign key linking to sustainability.packaging_sustainability. Business justification: Concept briefs define packaging sustainability requirements for holistic product sustainability. Real process: designers specify FSC-certified, recycled, or plastic-free packaging at concept stage to ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingSustainability .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Collections are planned by brand/channel profit centers for P&L accountability and margin planning. Real process: collection-level profitability forecasting and actual performance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:trendReportId rdf:type rdf:Property ;
    rdfs:label 'Trend Report Id' ;
    rdfs:comment 'Reference to the trend research or trend forecast that inspired or informed this concept. Links to trend analysis and market intelligence data.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrendReport .

ind:colorPaletteDescription rdf:type rdf:Property ;
    rdfs:label 'Color Palette Description' ;
    rdfs:comment 'Narrative description of the intended color palette for this concept (e.g., earthy neutrals with pops of terracotta, monochromatic blues, vibrant neons). Guides colorway development.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptCode rdf:type rdf:Property ;
    rdfs:label 'Concept Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the concept for tracking and reference across systems. Used as the business identifier in design documentation and collaboration tools.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptName rdf:type rdf:Property ;
    rdfs:label 'Concept Name' ;
    rdfs:comment 'The creative name or title assigned to this design concept. Serves as the primary human-readable identifier for the concept throughout the design workflow.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptStatus rdf:type rdf:Property ;
    rdfs:label 'Concept Status' ;
    rdfs:comment 'Current lifecycle status of the design concept. Tracks progression from initial ideation through approval or rejection. Critical for workflow management and design pipeline visibility.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designDirection rdf:type rdf:Property ;
    rdfs:label 'Design Direction' ;
    rdfs:comment 'Detailed description of the design direction, including silhouette, fabrication approach, color philosophy, and intended aesthetic outcome. Serves as the creative brief for downstream design work.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Count' ;
    rdfs:comment 'Estimated number of individual product units (SKUs) expected to be developed from this concept. Used for capacity planning and resource allocation in the design pipeline.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricDirection rdf:type rdf:Property ;
    rdfs:label 'Fabric Direction' ;
    rdfs:comment 'High-level guidance on fabric types, textures, and material characteristics desired for this concept (e.g., sustainable cottons, technical performance fabrics, luxe knits). Guides material sourcing.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspirationSources rdf:type rdf:Property ;
    rdfs:label 'Inspiration Sources' ;
    rdfs:comment 'Comma-separated list or narrative description of the inspiration sources for this concept (e.g., art movements, cultural references, nature, architecture, historical periods). Documents the creative genesis.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardUrl rdf:type rdf:Property ;
    rdfs:label 'Mood Board Url' ;
    rdfs:comment 'URL or file path to the digital mood board or visual inspiration board associated with this concept. Provides visual reference for the design team.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodKeywords rdf:type rdf:Property ;
    rdfs:label 'Mood Keywords' ;
    rdfs:comment 'Comma-separated list of aesthetic and emotional keywords that capture the mood and feeling of the concept (e.g., bold, minimalist, playful, sophisticated, edgy). Used for mood board creation and design alignment.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'The intended price tier or market positioning for products developed from this concept. Guides material selection, construction methods, and target MSRP (Manufacturers Suggested Retail Price) range.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'The fashion season this concept is designed for (e.g., SS24 for Spring/Summer 2024, FW24 for Fall/Winter 2024). Critical for collection planning and merchandising timelines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouetteDirection rdf:type rdf:Property ;
    rdfs:label 'Silhouette Direction' ;
    rdfs:comment 'Description of the intended silhouette and fit direction for this concept (e.g., oversized and relaxed, tailored and structured, body-conscious). Informs pattern development and fit strategy.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerArchetype rdf:type rdf:Property ;
    rdfs:label 'Target Customer Archetype' ;
    rdfs:comment 'Description of the target customer persona or archetype this concept is designed for (e.g., Active Millennial, Luxury Minimalist, Gen-Z Streetwear Enthusiast). Aligns design with customer segmentation strategy.' ;
    rdfs:domain ind:Concept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'The planned market launch date for products developed from this concept. Drives the TNA (Time and Action) calendar and critical path milestones.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'The overarching creative theme or narrative that defines this concept (e.g., Urban Explorer, Coastal Minimalism, Heritage Revival). Guides the aesthetic direction and storytelling.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Unique identifier for the design asset record. Primary key for the design asset entity.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Asset Employee Id' ;
    rdfs:comment 'Reference to the user or approver who granted final approval for this design asset, used for audit trail and accountability.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetUploadedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Asset Uploaded By User Employee Id' ;
    rdfs:comment 'Reference to the user who uploaded or created the design asset record in the DAM system, used for audit trail and accountability.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAssetId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Asset Id' ;
    rdfs:comment 'Reference to the newer design asset that supersedes or replaces this asset, used for version lineage and historical tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or reference code assigned to the design asset for cataloging and cross-referencing across systems.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the design asset content, purpose, and creative intent, used for search, cataloging, and context.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the design asset, used for identification and search within the Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the design asset within the DAM system (active, archived, restricted, pending approval, rejected, expired), controlling visibility and usage.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the design asset by its creative purpose and format within the design workflow (e.g., sketch, CAD export, print file, lookbook image, runway photo, reference imagery).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPaletteHexCodes rdf:type rdf:Property ;
    rdfs:label 'Color Palette Hex Codes' ;
    rdfs:comment 'Comma-separated list of hexadecimal color codes representing the primary color palette featured in the design asset, used for color trend analysis and coordination.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightAttribution rdf:type rdf:Property ;
    rdfs:label 'Copyright Attribution' ;
    rdfs:comment 'Copyright holder or attribution statement for the design asset, required for compliance with intellectual property laws and licensing agreements.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Fabric Reference Code' ;
    rdfs:comment 'Reference code linking the design asset to a specific fabric or material in the material library, used for sourcing and Bill of Materials (BOM) planning.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspirationSource rdf:type rdf:Property ;
    rdfs:label 'Inspiration Source' ;
    rdfs:comment 'Description of the creative inspiration or reference source for the design asset (e.g., cultural movement, art period, geographic region, designer brand).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Boolean flag indicating whether the design asset contains confidential or proprietary information requiring restricted access and handling.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Boolean flag indicating whether the design asset is featured or highlighted for promotional, presentation, or portfolio purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trendTheme rdf:type rdf:Property ;
    rdfs:label 'Trend Theme' ;
    rdfs:comment 'Trend theme or macro trend that the design asset aligns with or illustrates, used for trend tracking and collection planning.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the design asset was first uploaded or ingested into the DAM system, used for audit trail and asset lifecycle tracking.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Legal usage rights and permissions associated with the design asset, defining how and where the asset may be used (internal only, licensed, royalty-free, restricted, public domain).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefId rdf:type rdf:Property ;
    rdfs:label 'Brief Id' ;
    rdfs:comment 'Unique identifier for the design brief record. Primary key.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:briefCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Brief Created By Employee Id' ;
    rdfs:comment 'Identifier of the user who created the design brief record.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:briefEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Brief Employee Id' ;
    rdfs:comment 'Identifier of the user or stakeholder who approved the design brief for execution.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:briefModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Brief Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the design brief record.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Design briefs reference approved collection budgets for design spend authorization and budget consumption tracking. Real process: design budget control and variance reporting by collection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:brandAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Brand Alignment Score' ;
    rdfs:comment 'Qualitative or quantitative score (0.00 to 5.00) assessing how well the design brief aligns with brand identity and positioning.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefCode rdf:type rdf:Property ;
    rdfs:label 'Brief Code' ;
    rdfs:comment 'Externally-known unique business identifier for the design brief, used for cross-functional reference and communication.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefStatus rdf:type rdf:Property ;
    rdfs:label 'Brief Status' ;
    rdfs:comment 'Current lifecycle status of the design brief, tracking its progression from draft through completion. [ENUM-REF-CANDIDATE: draft|issued|in_progress|under_review|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for design development activities under this brief, expressed in the company\'s base currency.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialObjectives rdf:type rdf:Property ;
    rdfs:label 'Commercial Objectives' ;
    rdfs:comment 'Business and commercial goals for the design brief, including revenue targets, market share objectives, or strategic positioning goals.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarks rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmarks' ;
    rdfs:comment 'Competitive products, brands, or market references used as benchmarks or inspiration for positioning and differentiation.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date on which all design work under the brief was completed and delivered.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Concept Submission Deadline' ;
    rdfs:comment 'Deadline by which initial design concepts must be submitted for review.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Milestone Date' ;
    rdfs:comment 'Target date by which the design work under this brief must be completed and delivered.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designTeamSize rdf:type rdf:Property ;
    rdfs:label 'Design Team Size' ;
    rdfs:comment 'Number of designers or team members allocated to work on this design brief.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannelTarget rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Target' ;
    rdfs:comment 'Primary distribution channel or sales channel that the design brief targets (e.g., Direct-to-Consumer, Wholesale, E-Commerce).' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date on which the design brief was formally issued to the design team.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingDepartment rdf:type rdf:Property ;
    rdfs:label 'Issuing Department' ;
    rdfs:comment 'Department or functional area that originated the design brief.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStakeholder rdf:type rdf:Property ;
    rdfs:label 'Issuing Stakeholder' ;
    rdfs:comment 'Name or role of the stakeholder who issued the design brief (e.g., Design Director, Merchandising Lead, Brand Manager).' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyTrendReferences rdf:type rdf:Property ;
    rdfs:label 'Key Trend References' ;
    rdfs:comment 'List or description of key fashion trends, consumer insights, or market movements that inform the design brief.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingFeedback rdf:type rdf:Property ;
    rdfs:label 'Merchandising Feedback' ;
    rdfs:comment 'Feedback or input from merchandising teams on commercial viability, assortment fit, or market alignment.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Sample Delivery Date' ;
    rdfs:comment 'Target date for delivery of physical samples or prototypes developed under this design brief.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirements' ;
    rdfs:comment 'Sustainability goals, material requirements, or environmental standards that must be met in the design execution (e.g., organic cotton, recycled polyester, GOTS certification).' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCategory rdf:type rdf:Property ;
    rdfs:label 'Target Category' ;
    rdfs:comment 'Product category or classification that the design brief targets (e.g., Outerwear, Footwear, Accessories, Activewear).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerPersona rdf:type rdf:Property ;
    rdfs:label 'Target Customer Persona' ;
    rdfs:comment 'Description of the target customer archetype or persona that the design brief is intended to serve, including demographic and psychographic characteristics.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage that products developed under this brief should achieve, used for commercial viability assessment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPricePoint rdf:type rdf:Property ;
    rdfs:label 'Target Price Point' ;
    rdfs:comment 'Target retail price point or price range for products developed under this design brief, expressed in the company\'s base currency.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Target Volume Units' ;
    rdfs:comment 'Target production or sales volume in units that the design brief aims to support.' ;
    rdfs:domain ind:Brief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Unique identifier for the design calendar record. Primary key for the design calendar entity.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:calendarCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Calendar Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created the design calendar record.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calendarDesignerId rdf:type rdf:Property ;
    rdfs:label 'Calendar Designer Id' ;
    rdfs:comment 'Reference to the design director who approves and oversees the calendar at the executive level.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:calendarEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Calendar Employee Id' ;
    rdfs:comment 'Reference to the user who approved the design calendar.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calendarLeadDesignerId rdf:type rdf:Property ;
    rdfs:label 'Calendar Lead Designer Id' ;
    rdfs:comment 'Reference to the lead designer responsible for overseeing the design calendar execution.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:calendarModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Calendar Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the design calendar record.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Reference to the season this design calendar is associated with (e.g., Spring/Summer 2025, Fall/Winter 2025).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:actualSkuCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sku Count' ;
    rdfs:comment 'Actual number of SKUs that were developed and approved through this design calendar.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Unique business identifier code for the design calendar used for external reference and tracking.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Human-readable name for the design calendar (e.g., \'SS25 Women\'s Sportswear Design Calendar\').' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the design calendar indicating its operational state.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of calendar milestones completed (0.00 to 100.00).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conceptKickoffActualDate rdf:type rdf:Property ;
    rdfs:label 'Concept Kickoff Actual Date' ;
    rdfs:comment 'Actual date when the concept kick-off meeting occurred.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptKickoffPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Concept Kickoff Planned Date' ;
    rdfs:comment 'Planned date for the initial concept kick-off meeting to launch the design process.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this calendar is on the critical path for the season launch (True=critical, False=non-critical).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayDays rdf:type rdf:Property ;
    rdfs:label 'Delay Days' ;
    rdfs:comment 'Total number of days the calendar is delayed compared to planned milestones. Negative values indicate ahead of schedule.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineReviewActualDate rdf:type rdf:Property ;
    rdfs:label 'Line Review Actual Date' ;
    rdfs:comment 'Actual date when the line review meeting occurred.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineReviewPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Line Review Planned Date' ;
    rdfs:comment 'Planned date for the line review meeting to evaluate and select designs for the collection.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moodBoardReviewActualDate rdf:type rdf:Property ;
    rdfs:label 'Mood Board Review Actual Date' ;
    rdfs:comment 'Actual date when the mood board review meeting took place.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moodBoardReviewPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Mood Board Review Planned Date' ;
    rdfs:comment 'Planned date for mood board presentation and review with stakeholders.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protoSampleRequestActualDate rdf:type rdf:Property ;
    rdfs:label 'Proto Sample Request Actual Date' ;
    rdfs:comment 'Actual date when prototype sample requests were submitted.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protoSampleRequestPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Proto Sample Request Planned Date' ;
    rdfs:comment 'Planned date for requesting prototype samples from manufacturers.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sketchSubmissionActualDate rdf:type rdf:Property ;
    rdfs:label 'Sketch Submission Actual Date' ;
    rdfs:comment 'Actual date when design sketches were submitted.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sketchSubmissionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Sketch Submission Planned Date' ;
    rdfs:comment 'Planned date for designers to submit initial design sketches.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSkuCount rdf:type rdf:Property ;
    rdfs:label 'Target Sku Count' ;
    rdfs:comment 'Target number of SKUs planned to be developed through this design calendar.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:techPackHandoffActualDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Handoff Actual Date' ;
    rdfs:comment 'Actual date when tech packs were handed off to product development.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:techPackHandoffPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Handoff Planned Date' ;
    rdfs:comment 'Planned date for handing off completed technical design packages to product development and sourcing teams.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collaborationCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Created By Employee Id' ;
    rdfs:comment 'Identifier of the user who created this collaboration record.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collaborationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Employee Id' ;
    rdfs:comment 'Identifier of the executive or decision-maker who approved the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collaborationMerchandisingContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Merchandising Contact Employee Id' ;
    rdfs:comment 'Identifier of the merchandising team member coordinating the commercial aspects of the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collaborationModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this collaboration record.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Collaboration royalty payments, flat fees, and advances are posted to specific GL accounts for financial reporting, accrual accounting, and royalty expense tracking in apparel operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:leadDesignerId rdf:type rdf:Property ;
    rdfs:label 'Lead Designer Id' ;
    rdfs:comment 'Identifier of the internal lead designer responsible for managing the collaboration project.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'The actual date when the collaboration products were launched to market.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'The upfront advance payment made to the partner against future royalties, if applicable.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationCode rdf:type rdf:Property ;
    rdfs:label 'Collaboration Code' ;
    rdfs:comment 'Internal unique code or identifier for the collaboration project used for tracking and reference.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Name' ;
    rdfs:comment 'The official name or title of the design collaboration project (e.g., \'Artist X Spring Collection\', \'Celebrity Y Capsule\').' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Status' ;
    rdfs:comment 'Current lifecycle status of the collaboration project. [ENUM-REF-CANDIDATE: concept|negotiation|contracted|in_design|in_production|launched|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'The category of creative partnership: artist collaboration, guest designer, brand co-branding, celebrity endorsement, influencer co-design, or licensing deal.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed collaboration contract document.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedDeliverables rdf:type rdf:Property ;
    rdfs:label 'Contracted Deliverables' ;
    rdfs:comment 'Description of the agreed-upon deliverables from the partner (e.g., \'Design 12 SKUs\', \'Provide artwork for prints\', \'Attend 3 marketing events\').' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designOwnershipTerms rdf:type rdf:Property ;
    rdfs:label 'Design Ownership Terms' ;
    rdfs:comment 'Legal terms defining intellectual property ownership of the designs created through the collaboration (e.g., \'Joint ownership\', \'Company retains all rights\', \'Partner retains IP\').' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannels rdf:type rdf:Property ;
    rdfs:label 'Distribution Channels' ;
    rdfs:comment 'The sales channels through which collaboration products will be distributed (e.g., \'DTC only\', \'Wholesale + E-commerce\', \'Exclusive retail partners\').' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Sku Count' ;
    rdfs:comment 'The estimated number of unique SKUs (Stock Keeping Units) to be produced as part of this collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of any exclusivity clauses (e.g., \'Partner cannot work with competitors for 12 months\', \'Non-exclusive agreement\').' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the collaboration fees and royalties.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'The fixed fee amount paid to the partner for the collaboration, if applicable.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipRightsStructure rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Structure' ;
    rdfs:comment 'The structure of intellectual property rights granted or licensed through the collaboration.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Code or identifier of the marketing campaign associated with the collaboration launch.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'The minimum guaranteed payment to the partner regardless of sales performance, if applicable.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Partner Legal Entity' ;
    rdfs:comment 'The legal entity name of the partner organization or individual for contractual purposes.' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'The name of the external creative partner, artist, designer, brand, celebrity, or influencer involved in the collaboration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage rate of sales revenue paid as royalty to the partner, if applicable.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyStructure rdf:type rdf:Property ;
    rdfs:label 'Royalty Structure' ;
    rdfs:comment 'The type of royalty or compensation structure agreed upon (percentage of sales, flat fee, hybrid model, or no royalty).' ;
    rdfs:domain ind:Collaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoffId rdf:type rdf:Property ;
    rdfs:label 'Handoff Id' ;
    rdfs:comment 'Unique identifier for the design handoff transaction. Primary key for the design handoff record.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoffApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handoff Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the design handoff. Typically a product development manager or technical design lead.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:handoffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handoff Employee Id' ;
    rdfs:comment 'Identifier of the specific user or team lead who acknowledged receipt of the design handoff package.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:handoffModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handoff Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the design handoff record. Provides accountability for changes.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:submittingDesignerId rdf:type rdf:Property ;
    rdfs:label 'Submitting Designer Id' ;
    rdfs:comment 'Identifier of the designer who submitted the design handoff package. Responsible party from the design team.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date when the receiving team acknowledged receipt of the design handoff package. Marks the start of the product development phase.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bomDraftIncluded rdf:type rdf:Property ;
    rdfs:label 'Bom Draft Included' ;
    rdfs:comment 'Indicates whether a draft Bill of Materials listing all components, fabrics, trims, and hardware is included in the handoff.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomDraftVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Draft Version' ;
    rdfs:comment 'Version identifier for the draft BOM included in the handoff (e.g., draft_v1, draft_v2). Tracks BOM iterations during design phase.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadFileFormat rdf:type rdf:Property ;
    rdfs:label 'Cad File Format' ;
    rdfs:comment 'File format of the CAD files included (e.g., AI for Adobe Illustrator, CLO for CLO3D, ZPRJ for Browzwear). Indicates the software compatibility. [ENUM-REF-CANDIDATE: AI|PDF|DXF|CLO|ZPRJ|OBJ|FBX|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadFilesIncluded rdf:type rdf:Property ;
    rdfs:label 'Cad Files Included' ;
    rdfs:comment 'Indicates whether CAD design files (e.g., Adobe Illustrator, CLO3D, Browzwear) are included in the handoff package.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationPlatform rdf:type rdf:Property ;
    rdfs:label 'Collaboration Platform' ;
    rdfs:comment 'Digital platform or tool used to facilitate the design handoff and collaboration between teams (e.g., Centric PLM, Infor PLM, Microsoft Teams).' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Name of the collection to which this design belongs. Groups related styles under a cohesive theme or brand story.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayCount rdf:type rdf:Property ;
    rdfs:label 'Colorway Count' ;
    rdfs:comment 'Number of colorway variations included in the design handoff. Each colorway represents a different color combination for the same style.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorwaySpecsIncluded rdf:type rdf:Property ;
    rdfs:label 'Colorway Specs Included' ;
    rdfs:comment 'Indicates whether detailed colorway specifications (Pantone codes, fabric swatches, trim colors) are included in the handoff.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'General feedback and comments from the receiving team regarding the design handoff. May include suggestions for improvement or clarification requests.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoffDate rdf:type rdf:Property ;
    rdfs:label 'Handoff Date' ;
    rdfs:comment 'The date when the design package was formally handed off from the design team to the receiving team. Critical gate event marking the end of the design phase.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoffNumber rdf:type rdf:Property ;
    rdfs:label 'Handoff Number' ;
    rdfs:comment 'Business-facing unique identifier for the design handoff, typically formatted as DH-NNNNNN. Used for tracking and reference in cross-functional communications.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoffStatus rdf:type rdf:Property ;
    rdfs:label 'Handoff Status' ;
    rdfs:comment 'Current lifecycle status of the design handoff. Tracks the progression from submission through acknowledgment and approval or rejection.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialLibraryReferences rdf:type rdf:Property ;
    rdfs:label 'Material Library References' ;
    rdfs:comment 'Comma-separated list of material codes or references from the PLM material library that are specified in the design. Links to approved fabric and trim options.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingDesignItems rdf:type rdf:Property ;
    rdfs:label 'Outstanding Design Items' ;
    rdfs:comment 'List of any outstanding design items, open questions, or pending decisions that need to be resolved by the receiving team. Tracks incomplete elements at handoff.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageUrl rdf:type rdf:Property ;
    rdfs:label 'Package Url' ;
    rdfs:comment 'URL or file path to the complete design handoff package stored in the PLM system or shared drive. Provides access to all handoff materials.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printFilesIncluded rdf:type rdf:Property ;
    rdfs:label 'Print Files Included' ;
    rdfs:comment 'Indicates whether print and pattern artwork files are included in the handoff package. Essential for styles with custom prints or graphics.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingTeam rdf:type rdf:Property ;
    rdfs:label 'Receiving Team' ;
    rdfs:comment 'The functional team receiving the design handoff package. Typically product development, sourcing, or technical design team.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the design handoff was rejected by the receiving team. Triggers rework by the design team.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:silhouetteDescription rdf:type rdf:Property ;
    rdfs:label 'Silhouette Description' ;
    rdfs:comment 'Description of the design silhouette and fit (e.g., slim fit, relaxed, oversized, A-line). Key design characteristic communicated to product development.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleCode rdf:type rdf:Property ;
    rdfs:label 'Style Code' ;
    rdfs:comment 'The style or sketch reference code for the design being handed off. Unique identifier for the style within the collection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackIncluded rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Included' ;
    rdfs:comment 'Indicates whether a technical specification package (tech pack) is included in the handoff. Tech packs contain detailed construction, measurement, and material specifications.' ;
    rdfs:domain ind:Handoff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:techPackVersion rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Version' ;
    rdfs:comment 'Version number of the tech pack included in the handoff (e.g., v1.0, v2.3). Tracks iterations and revisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspirationId rdf:type rdf:Property ;
    rdfs:label 'Inspiration Id' ;
    rdfs:comment 'Unique identifier for the design inspiration record. Primary key.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loggedByDesignerId rdf:type rdf:Property ;
    rdfs:label 'Logged By Designer Id' ;
    rdfs:comment 'Identifier of the designer or design team member who logged this inspiration into the system.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:trendItemId rdf:type rdf:Property ;
    rdfs:label 'Trend Item Id' ;
    rdfs:comment 'Identifier of the trend item record to which this inspiration is related, enabling linkage to formal trend analysis.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrendItem .

ind:additionalMediaUrls rdf:type rdf:Property ;
    rdfs:label 'Additional Media Urls' ;
    rdfs:comment 'Comma-separated list of additional image, video, or media URLs that provide further visual context for this inspiration.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionStatus rdf:type rdf:Property ;
    rdfs:label 'Adoption Status' ;
    rdfs:comment 'Current status of this inspiration in the design workflow: logged (newly captured), under review (being evaluated), adopted (incorporated into design), archived (stored for future reference), or rejected (not pursued).' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDetails rdf:type rdf:Property ;
    rdfs:label 'Construction Details' ;
    rdfs:comment 'Key construction techniques or details observed, such as draping, pleating, tailoring, embroidery, appliqué, or innovative seaming.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalInfluence rdf:type rdf:Property ;
    rdfs:label 'Cultural Influence' ;
    rdfs:comment 'Cultural movements, historical periods, or societal themes reflected in the inspiration, such as 1970s revival, minimalism, maximalism, or streetwear culture.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designNotes rdf:type rdf:Property ;
    rdfs:label 'Design Notes' ;
    rdfs:comment 'Internal notes or commentary from the design team regarding how this inspiration might be translated into product design or collection development.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerBrand rdf:type rdf:Property ;
    rdfs:label 'Designer Brand' ;
    rdfs:comment 'Name of the designer or brand associated with the inspiration source, particularly relevant for runway and competitive observations.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricElements rdf:type rdf:Property ;
    rdfs:label 'Fabric Elements' ;
    rdfs:comment 'Notable fabric types, textures, or material characteristics observed, such as silk, denim, leather, knit, woven, technical fabrics, or sustainable materials.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicOrigin rdf:type rdf:Property ;
    rdfs:label 'Geographic Origin' ;
    rdfs:comment 'Geographic location or region where the inspiration was observed or originated (e.g., Paris, Tokyo, New York, Milan).' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Image Reference Url' ;
    rdfs:comment 'URL or file path to the primary image or visual reference associated with this inspiration.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspirationCode rdf:type rdf:Property ;
    rdfs:label 'Inspiration Code' ;
    rdfs:comment 'Unique business code or reference number assigned to this inspiration entry for cataloging and retrieval.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspirationDescription rdf:type rdf:Property ;
    rdfs:label 'Inspiration Description' ;
    rdfs:comment 'Detailed narrative description of the inspiration, capturing the designers observations, creative insights, and potential application ideas.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationDate rdf:type rdf:Property ;
    rdfs:label 'Observation Date' ;
    rdfs:comment 'Date when the inspiration was observed, captured, or logged by the design team.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceTierRelevance rdf:type rdf:Property ;
    rdfs:label 'Price Tier Relevance' ;
    rdfs:comment 'Price tier or market segment to which this inspiration is most applicable.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printPatternTheme rdf:type rdf:Property ;
    rdfs:label 'Print Pattern Theme' ;
    rdfs:comment 'Print or pattern themes observed in the inspiration, such as floral, geometric, abstract, animal print, stripes, or cultural motifs.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryRelevance rdf:type rdf:Property ;
    rdfs:label 'Product Category Relevance' ;
    rdfs:comment 'Product categories to which this inspiration is most applicable, such as outerwear, dresses, activewear, footwear, or accessories.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'Numeric score (0-100) indicating the assessed relevance or importance of this inspiration to current or future collections, assigned by design leadership.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonRelevance rdf:type rdf:Property ;
    rdfs:label 'Season Relevance' ;
    rdfs:comment 'Season or seasonal period to which this inspiration is most relevant (e.g., Spring/Summer 2025, Fall/Winter 2024).' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouetteElements rdf:type rdf:Property ;
    rdfs:label 'Silhouette Elements' ;
    rdfs:comment 'Key silhouette characteristics observed in the inspiration, such as oversized, fitted, A-line, boxy, flowing, structured, asymmetric, or layered.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Name of the specific source, such as the runway show name, exhibition title, competitive brand name, location visited, or publication name.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stylingElements rdf:type rdf:Property ;
    rdfs:label 'Styling Elements' ;
    rdfs:comment 'Notable styling details or accessory elements observed, such as layering techniques, belt usage, footwear style, or jewelry trends.' ;
    rdfs:domain ind:Inspiration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Sustainability Indicator' ;
    rdfs:comment 'Flag indicating whether the inspiration includes sustainable design elements, eco-friendly materials, or circular fashion principles.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trendAlignment rdf:type rdf:Property ;
    rdfs:label 'Trend Alignment' ;
    rdfs:comment 'Key trend themes or macro trends that this inspiration aligns with, linking to broader trend forecasting and market direction.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique identifier for the design milestone record. Primary key for the design milestone entity.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Milestone Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this milestone record. Supports accountability and audit requirements.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:milestoneEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Milestone Employee Id' ;
    rdfs:comment 'Reference to the individual authorized to approve milestone completion. Typically a design director, merchandiser, or product manager.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:milestoneLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Milestone Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this milestone record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the design team responsible for this milestone. Enables team-level workload and performance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:predecessorMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Id' ;
    rdfs:comment 'Reference to the milestone that must be completed before this milestone can begin. Defines dependency relationships in the design critical path.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:responsibleDesignerId rdf:type rdf:Property ;
    rdfs:label 'Responsible Designer Id' ;
    rdfs:comment 'Reference to the lead designer accountable for completing this milestone. Primary owner for milestone deliverables.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:actualDeliverableCount rdf:type rdf:Property ;
    rdfs:label 'Actual Deliverable Count' ;
    rdfs:comment 'Actual number of deliverable items completed at milestone closure. Used to measure scope completion and productivity.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of labor hours spent completing this milestone. Used for productivity analysis and future estimation accuracy.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date for the milestone established at project kickoff. Serves as the reference point for measuring schedule performance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle status of the milestone. Tracks progress through the design critical path and identifies at-risk milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the root cause of milestone delay if overdue. Used for delay pattern analysis and process improvement. [ENUM-REF-CANDIDATE: design_change|material_unavailable|resource_constraint|approval_delay|vendor_delay|technical_issue|scope_change — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Quantitative target for the number of deliverable items expected at this milestone (e.g., 15 designs, 5 mood boards, 3 prototypes).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the expected deliverable or output for this milestone (e.g., 20 concept sketches, approved tech pack, final colorway selection).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Type of scheduling dependency relationship with the predecessor milestone. Defines how the two milestones are linked in the project schedule.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete this milestone. Used for resource planning and capacity management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current forecasted completion date based on project progress and known constraints. Updated regularly to reflect realistic expectations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of the milestone as a formal stage-gate checkpoint. Gates require cross-functional approval before proceeding to next phase.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'Functional category of the milestone indicating which business function owns the checkpoint (creative design, technical development, commercial review, compliance approval).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Short alphanumeric code identifying the milestone type for system integration and reporting (e.g., MS-CONCEPT-01, MS-SKETCH-02).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Descriptive name of the design milestone event (e.g., Concept Presentation, First Sketch Review, Final Design Approval).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone event type. Categorizes the nature of the design phase checkpoint.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of actions planned to mitigate identified risks or recover from delays. Documents contingency strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled target date for milestone completion as defined in the Time and Action (T&A) calendar. Used for baseline planning and variance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Date' ;
    rdfs:comment 'Scheduled date for the formal review meeting associated with this milestone. Used for calendar coordination and stakeholder alignment.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Result of the milestone review meeting. Determines whether the design can proceed to the next phase or requires rework.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Required Flag' ;
    rdfs:comment 'Indicates whether the milestone deliverable requires rework or revision before final approval. True triggers additional design cycles.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderList rdf:type rdf:Property ;
    rdfs:label 'Stakeholder List' ;
    rdfs:comment 'Comma-separated list of stakeholder roles or individuals who must participate in or approve this milestone (e.g., Design Director, Merchandiser, Sourcing Manager).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewId rdf:type rdf:Property ;
    rdfs:label 'Review Id' ;
    rdfs:comment 'Unique identifier for the design review session. Primary key.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Review .

ind:reviewApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Approved By Employee Id' ;
    rdfs:comment 'Reference to the executive or design director who provided final approval for the review outcomes.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created the design review record.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Employee Id' ;
    rdfs:comment 'Reference to the design director or lead reviewer who chaired the session.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the design review record.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewNextActionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Next Action Owner Employee Id' ;
    rdfs:comment 'Reference to the employee or designer responsible for executing the next actions following the review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agenda rdf:type rdf:Property ;
    rdfs:label 'Agenda' ;
    rdfs:comment 'Detailed agenda or objectives for the design review session, outlining topics and focus areas.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialFeedback rdf:type rdf:Property ;
    rdfs:label 'Commercial Feedback' ;
    rdfs:comment 'Feedback from the commercial team on sales potential, customer demand, and distribution strategy.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Timestamp when the design review session concluded.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpReviewDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Date' ;
    rdfs:comment 'Scheduled date for the follow-up design review session, if applicable.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpReviewScheduled rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Scheduled' ;
    rdfs:comment 'Indicates whether a follow-up review session has been scheduled to re-evaluate revised styles.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the design review session was held (e.g., \'Design Studio NYC\', \'Virtual - Zoom\', \'Milan Showroom\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingMinutesUrl rdf:type rdf:Property ;
    rdfs:label 'Meeting Minutes Url' ;
    rdfs:comment 'URL or file path to the detailed meeting minutes document for the design review session.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next actions or revisions must be completed.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantList rdf:type rdf:Property ;
    rdfs:label 'Participant List' ;
    rdfs:comment 'Comma-separated list of participant names or IDs who attended the design review session (design team, merchandising, commercial teams).' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationFilePath rdf:type rdf:Property ;
    rdfs:label 'Presentation File Path' ;
    rdfs:comment 'File path or URL to the presentation materials used during the design review session.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCode rdf:type rdf:Property ;
    rdfs:label 'Review Code' ;
    rdfs:comment 'Business identifier for the design review session, used for external reference and tracking.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which the design review session took place. This is the principal business event timestamp for the review.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewName rdf:type rdf:Property ;
    rdfs:label 'Review Name' ;
    rdfs:comment 'Descriptive name of the design review session (e.g., \'Spring 2025 Concept Review\', \'Fall Line Adoption Review\').' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the design review session (scheduled, in progress, completed, cancelled, postponed).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of design review session indicating the stage in the design calendar (concept review, line review, final adoption review, pre-production review, sample review, technical review).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionInstructions rdf:type rdf:Property ;
    rdfs:label 'Revision Instructions' ;
    rdfs:comment 'Consolidated revision instructions and feedback provided to designers for styles requiring changes.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Timestamp when the design review session started.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stylesAdoptedCount rdf:type rdf:Property ;
    rdfs:label 'Styles Adopted Count' ;
    rdfs:comment 'Number of styles approved for adoption and progression to the next stage.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stylesDroppedCount rdf:type rdf:Property ;
    rdfs:label 'Styles Dropped Count' ;
    rdfs:comment 'Number of styles rejected and removed from the collection pipeline.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stylesReviewedCount rdf:type rdf:Property ;
    rdfs:label 'Styles Reviewed Count' ;
    rdfs:comment 'Total number of styles or designs evaluated during this review session.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stylesRevisedCount rdf:type rdf:Property ;
    rdfs:label 'Styles Revised Count' ;
    rdfs:comment 'Number of styles requiring revisions before re-submission.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Sustainability Assessment' ;
    rdfs:comment 'Assessment of the sustainability aspects of the designs reviewed, including material sourcing, environmental impact, and compliance with sustainability standards (GOTS, BCI, OEKO-TEX).' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalFeedback rdf:type rdf:Property ;
    rdfs:label 'Technical Feedback' ;
    rdfs:comment 'Technical feedback on feasibility, construction, materials, and production considerations.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Trend Alignment Score' ;
    rdfs:comment 'Numeric score (0.00 to 5.00) representing how well the reviewed designs align with current and forecasted market trends.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewItemId rdf:type rdf:Property ;
    rdfs:label 'Review Item Id' ;
    rdfs:comment 'Unique identifier for the design review item record. Primary key for tracking individual style-level decisions within design review sessions.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReviewEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Review Employee Id' ;
    rdfs:comment 'Reference to the lead reviewer or decision-maker who provided the final decision for this item. Typically a design director or merchandising leader.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryReviewLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Review Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this design review item record. Supports change tracking and audit requirements.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:colorStory rdf:type rdf:Property ;
    rdfs:label 'Color Story' ;
    rdfs:comment 'Narrative description of the color palette and colorway strategy for this style. Captures the creative vision and seasonal color direction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmark rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark' ;
    rdfs:comment 'Reference to competitor products or market comparables used to evaluate this styles positioning, pricing, and differentiation strategy.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Detailed explanation of why the reviewer decision was made. Captures strategic, commercial, or creative reasoning behind adopt, revise, drop, or hold outcomes.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the reviewer decision was finalized for this item. Critical for tracking review gate progression and Time and Action (TNA) calendar adherence.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCogs rdf:type rdf:Property ;
    rdfs:label 'Estimated Cogs' ;
    rdfs:comment 'Projected Cost of Goods Sold (COGS) for this style including materials, labor, and manufacturing overhead. Critical for margin analysis and pricing decisions.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Retail Price' ;
    rdfs:comment 'Projected Manufacturers Suggested Retail Price (MSRP) for this style. Used to evaluate price tier positioning and competitive landscape fit.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Volume' ;
    rdfs:comment 'Projected production quantity or sales volume for this style. Used to assess commercial scale and manufacturing feasibility.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedWholesalePrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Wholesale Price' ;
    rdfs:comment 'Projected wholesale price point for this style based on cost estimates and target margin. Used for commercial viability assessment during review.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricType rdf:type rdf:Property ;
    rdfs:label 'Fabric Type' ;
    rdfs:comment 'Primary fabric or material composition for this style. Critical for cost estimation, sustainability assessment, and technical feasibility evaluation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Item Sequence Number' ;
    rdfs:comment 'Sequential ordering of this item within the design review session. Used to maintain presentation order and facilitate discussion flow.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Ranking' ;
    rdfs:comment 'Relative priority of this style within the collection line. Lower numbers indicate higher priority. Used for resource allocation and production sequencing decisions.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresNewTooling rdf:type rdf:Property ;
    rdfs:label 'Requires New Tooling' ;
    rdfs:comment 'Indicates whether this style requires investment in new manufacturing tooling, molds, or equipment. Impacts cost and timeline feasibility.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'General notes and observations captured during the review discussion for this item. Provides context and rationale for future reference.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerDecision rdf:type rdf:Property ;
    rdfs:label 'Reviewer Decision' ;
    rdfs:comment 'Final decision outcome for this style at the review gate. Adopt means approved for production, revise requires design changes, drop means rejected, hold means deferred to future review, pending means decision not yet finalized.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionComments rdf:type rdf:Property ;
    rdfs:label 'Revision Comments' ;
    rdfs:comment 'Specific feedback and instructions for design revisions when decision is revise. Details what changes are required before the style can be adopted.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Overall risk level associated with adopting this style considering technical, commercial, supply chain, and brand factors.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current status of physical sample development for this style. Tracks progression through Sample Management System (SMS) workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouetteType rdf:type rdf:Property ;
    rdfs:label 'Silhouette Type' ;
    rdfs:comment 'Design silhouette classification such as fitted, relaxed, oversized, A-line, or other style-specific shape descriptors. Key design attribute for aesthetic evaluation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Assessment of the styles environmental and social sustainability based on materials, production methods, and supply chain considerations. Aligns with GOTS, BCI, and OEKO-TEX standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percentage' ;
    rdfs:comment 'Expected gross margin percentage for this style based on estimated cost and pricing. Critical metric for commercial decision-making at review gates.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalFeasibilityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Score' ;
    rdfs:comment 'Numeric assessment of how technically feasible this design is to manufacture given current capabilities, materials, and production constraints. Scale typically 1-10.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trendRelevanceScore rdf:type rdf:Property ;
    rdfs:label 'Trend Relevance Score' ;
    rdfs:comment 'Numeric assessment of how well this style captures current or emerging market trends and consumer preferences. Scale typically 1-10.' ;
    rdfs:domain ind:ReviewItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionId rdf:type rdf:Property ;
    rdfs:label 'Revision Id' ;
    rdfs:comment 'Unique identifier for the design revision record. Primary key.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fitSessionId rdf:type rdf:Property ;
    rdfs:label 'Fit Session Id' ;
    rdfs:comment 'Reference to the fit session that generated feedback requiring this revision. Tracks revisions driven by fit and construction issues.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FitSession .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the person responsible for reviewing and approving the completed revision. Typically a senior designer or design director.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revisionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Revision Employee Id' ;
    rdfs:comment 'Identifier of the person or role who requested the design revision. May be a merchandiser, product manager, design director, or technical designer.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:colorwayChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Colorway Change Description' ;
    rdfs:comment 'Detailed description of color palette or colorway modifications. Applicable when revision_type is colorway_change.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the designer completed the revision work and submitted for review. Marks the end of active design work.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:constructionChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Construction Change Description' ;
    rdfs:comment 'Detailed description of changes to garment construction, seaming, or assembly methods. Applicable when revision_type is construction_change.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost impact. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Hours' ;
    rdfs:comment 'Total elapsed time in hours from revision request to approval. Key performance indicator for design process efficiency.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated change in unit cost resulting from this revision. Positive values indicate cost increase, negative values indicate cost reduction.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructions rdf:type rdf:Property ;
    rdfs:label 'Instructions' ;
    rdfs:comment 'Detailed description of the changes requested. Provides specific guidance to the designer on what modifications are needed and why.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalRevision rdf:type rdf:Property ;
    rdfs:label 'Is Final Revision' ;
    rdfs:comment 'Flag indicating whether this is the final approved revision before the design moves to technical design or sampling. True when design is locked for production.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalCadFilePath rdf:type rdf:Property ;
    rdfs:label 'Original Cad File Path' ;
    rdfs:comment 'Full file system path or cloud storage location of the original CAD design file. Enables designers to access the baseline version for comparison.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printPatternChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Print Pattern Change Description' ;
    rdfs:comment 'Detailed description of changes to print designs or patterns. Applicable when revision_type is print_change.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the revision was formally requested. Marks the start of the revision lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorRole rdf:type rdf:Property ;
    rdfs:label 'Requestor Role' ;
    rdfs:comment 'Functional role of the person requesting the revision. Helps analyze which stakeholder groups drive the most design changes.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedCadFilePath rdf:type rdf:Property ;
    rdfs:label 'Revised Cad File Path' ;
    rdfs:comment 'Full file system path or cloud storage location of the revised CAD design file. Captures the output of the revision work.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionStatus rdf:type rdf:Property ;
    rdfs:label 'Revision Status' ;
    rdfs:comment 'Current lifecycle state of the revision request. Tracks progression from initial request through completion or cancellation.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionType rdf:type rdf:Property ;
    rdfs:label 'Revision Type' ;
    rdfs:comment 'Category of design change being requested. Classifies the nature of the revision to track which design elements are most frequently modified.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouetteChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Silhouette Change Description' ;
    rdfs:comment 'Detailed description of changes to the garment silhouette or shape. Applicable when revision_type is silhouette_change.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the designer began working on the revision. Enables cycle time analysis.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sustainabilityImpact rdf:type rdf:Property ;
    rdfs:label 'Sustainability Impact' ;
    rdfs:comment 'Assessment of whether the revision improves, maintains, or reduces the sustainability profile of the design. Tracks alignment with environmental goals.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalFeasibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Assessment' ;
    rdfs:comment 'Evaluation of whether the requested revision can be manufactured with current capabilities and supplier base. Identifies potential production risks.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trigger rdf:type rdf:Property ;
    rdfs:label 'Trigger' ;
    rdfs:comment 'Business event or decision that initiated this revision request. Captures whether the change was driven by design review feedback, fit session results, commercial strategy shift, or other factors.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Trim Change Description' ;
    rdfs:comment 'Detailed description of changes to trims, buttons, zippers, labels, or other embellishments. Applicable when revision_type is trim_change.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousVersionSketchId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Sketch Id' ;
    rdfs:comment 'Identifier of the previous version of this design sketch, if applicable. Enables lineage tracking and comparison of design iterations.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sketch .

ind:collaborationTeam rdf:type rdf:Property ;
    rdfs:label 'Collaboration Team' ;
    rdfs:comment 'Names or identifiers of additional team members who collaborated on the design sketch (e.g., assistant designers, technical designers, merchandisers). Supports attribution and workflow tracking.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPaletteReference rdf:type rdf:Property ;
    rdfs:label 'Color Palette Reference' ;
    rdfs:comment 'Reference code or name of the color palette associated with the design sketch. Links to seasonal color strategy and material libraries.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricSuggestion rdf:type rdf:Property ;
    rdfs:label 'Fabric Suggestion' ;
    rdfs:comment 'Suggested fabric type or material for the design sketch (e.g., cotton jersey, performance polyester, wool blend). Preliminary input for sourcing and costing.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medium rdf:type rdf:Property ;
    rdfs:label 'Medium' ;
    rdfs:comment 'Medium or tool used to create the design sketch (e.g., hand-drawn, CAD 2D software, 3D rendering software). Indicates technical approach and file format expectations.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorCode rdf:type rdf:Property ;
    rdfs:label 'Primary Color Code' ;
    rdfs:comment 'Code for the dominant color in the design sketch, typically from a standardized color library (e.g., Pantone, internal color system).' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printPatternReference rdf:type rdf:Property ;
    rdfs:label 'Print Pattern Reference' ;
    rdfs:comment 'Reference code or name of any print or pattern applied to the design sketch. Links to print library and artwork assets.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Detailed subcategory within the product category (e.g., t-shirt, hoodie, joggers, sneakers, backpack). Provides granular classification for design intent.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sketchNumber rdf:type rdf:Property ;
    rdfs:label 'Sketch Number' ;
    rdfs:comment 'Business identifier for the design sketch, typically following a season-category-sequence pattern (e.g., SS24-001234). Used for cross-functional reference and tracking.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Target' ;
    rdfs:comment 'Target sustainability certification for the design sketch (e.g., GOTS, OEKO-TEX, BCI, Bluesign). Guides material sourcing and compliance requirements.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Flag' ;
    rdfs:comment 'Indicates whether the design sketch incorporates sustainable design principles or materials (e.g., organic cotton, recycled polyester, low-impact dyes). Supports ESG reporting and marketing claims.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:techPackGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Generated Flag' ;
    rdfs:comment 'Indicates whether a technical specification package (tech pack) has been generated from this design sketch. Marks transition from creative to technical phase.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thumbnailImagePath rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Image Path' ;
    rdfs:comment 'File path or URI to a thumbnail preview image of the design sketch. Used for quick visual reference in PLM systems and design review dashboards.' ;
    rdfs:domain ind:Sketch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Designer Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the designer record.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:designerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Designer Employee Id' ;
    rdfs:comment 'Identifier of the design director or manager to whom this designer reports.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:designerLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Designer Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the designer record.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedCategories rdf:type rdf:Property ;
    rdfs:label 'Assigned Categories' ;
    rdfs:comment 'Comma-separated list of product categories the designer is currently assigned to work on, such as tops, bottoms, outerwear, footwear, or accessories.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardsRecognition rdf:type rdf:Property ;
    rdfs:label 'Awards Recognition' ;
    rdfs:comment 'Summary of industry awards, recognitions, or notable achievements earned by the designer throughout their career.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications or accreditations held by the designer, such as OEKO-TEX certification, GOTS training, or technical design credentials.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Financial cost center code to which the designers compensation and expenses are allocated.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTeamAssignment rdf:type rdf:Property ;
    rdfs:label 'Design Team Assignment' ;
    rdfs:comment 'Name or identifier of the design team or studio the designer is assigned to, such as Womens Apparel Team, Footwear Innovation Lab, or Print Studio.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerCode rdf:type rdf:Property ;
    rdfs:label 'Designer Code' ;
    rdfs:comment 'Business identifier code assigned to the designer for internal reference and system integration. Format: three uppercase letters followed by four digits.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerStatus rdf:type rdf:Property ;
    rdfs:label 'Designer Status' ;
    rdfs:comment 'Current lifecycle status of the designer record indicating their availability and engagement state.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerType rdf:type rdf:Property ;
    rdfs:label 'Designer Type' ;
    rdfs:comment 'Classification of the designer based on their primary creative discipline within the design function.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationBackground rdf:type rdf:Property ;
    rdfs:label 'Education Background' ;
    rdfs:comment 'Summary of the designers educational qualifications, including degrees, institutions, and relevant certifications in design or related fields.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for designer communication and collaboration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the designers employment relationship with the organization. Full Time Employee (FTE), freelance, contractor, intern, or consultant.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the designer or creative contributor.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the designer was hired or onboarded into the organization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageSkills rdf:type rdf:Property ;
    rdfs:label 'Language Skills' ;
    rdfs:comment 'Languages the designer is fluent in, supporting global collaboration and market-specific design work.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review conducted for the designer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationOffice rdf:type rdf:Property ;
    rdfs:label 'Location Office' ;
    rdfs:comment 'Primary office or studio location where the designer is based, such as New York HQ, Milan Design Center, or Remote.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the designer, reflecting their contribution and quality of work.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the designer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Portfolio Reference Url' ;
    rdfs:comment 'URL or file path reference to the designers portfolio showcasing their creative work and design projects.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Preferred or professional name used by the designer in creative work and collaboration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Hierarchical level of the designer within the design organization, reflecting experience and responsibility.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareProficiency rdf:type rdf:Property ;
    rdfs:label 'Software Proficiency' ;
    rdfs:comment 'Comma-separated list of design software and tools the designer is proficient in, such as Adobe Illustrator, CLO 3D, Centric PLM, or Browzwear.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Specific area of expertise or focus within the designers discipline, such as menswear, womenswear, activewear, luxury, or sustainable design.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFocusFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Focus Flag' ;
    rdfs:comment 'Indicates whether the designer has specialized expertise or focus on sustainable design practices and eco-friendly materials.' ;
    rdfs:domain ind:Designer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years of professional design experience the designer has in the apparel and fashion industry.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:embellishmentId rdf:type rdf:Property ;
    rdfs:label 'Embellishment Id' ;
    rdfs:comment 'Unique identifier for the embellishment design record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Embellishment .

ind:embellishmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Embellishment Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the embellishment design for production use, used for audit trail and accountability.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:embellishmentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Embellishment Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the embellishment design record, used for audit trail and change management.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:embellishmentSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Embellishment Supplier Vendor Id' ;
    rdfs:comment 'FK to supplier.vendor' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:embellishmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Embellishment Vendor Id' ;
    rdfs:comment 'Reference to the external supplier or vendor providing the embellishment if origin_type is supplier. Used for procurement and vendor management.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:colorSpecification rdf:type rdf:Property ;
    rdfs:label 'Color Specification' ;
    rdfs:comment 'Detailed color specification for the embellishment, including Pantone codes, thread colors, or ink formulations. May include multiple colors for multi-color designs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embellishmentCode rdf:type rdf:Property ;
    rdfs:label 'Embellishment Code' ;
    rdfs:comment 'Unique business identifier code for the embellishment design, used across Product Lifecycle Management (PLM) and Enterprise Resource Planning (ERP) systems for cross-referencing and sourcing.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embellishmentName rdf:type rdf:Property ;
    rdfs:label 'Embellishment Name' ;
    rdfs:comment 'Descriptive name of the embellishment design, used for identification in design briefs, tech packs, and production orders.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embellishmentType rdf:type rdf:Property ;
    rdfs:label 'Embellishment Type' ;
    rdfs:comment 'Classification of the embellishment technique or method applied to the garment or accessory. [ENUM-REF-CANDIDATE: embroidery|applique|beading|screen_print|heat_transfer|woven_label|sequin|rhinestone|patch|foil_print|digital_print — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the embellishment design in centimeters, used for sizing specifications in tech packs and Bill of Materials (BOM).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipOwnership rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership' ;
    rdfs:comment 'Defines the intellectual property rights ownership for the embellishment design, critical for legal compliance and licensing agreements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days required to produce or procure the embellishment from order placement to delivery, critical for Time and Action (TNA) calendar planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseAgreementReference rdf:type rdf:Property ;
    rdfs:label 'License Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the licensing agreement if the embellishment design is licensed from a third party, used for legal and financial tracking.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required by the supplier or production facility for this embellishment, used for procurement planning and inventory management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Indicates whether the embellishment design was created in-house by the design team, sourced from an external supplier, licensed from a third party, or custom-developed for a specific collection.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementPosition rdf:type rdf:Property ;
    rdfs:label 'Placement Position' ;
    rdfs:comment 'Designated location on the garment or accessory where the embellishment is applied, critical for tech pack specifications and production instructions. [ENUM-REF-CANDIDATE: chest_left|chest_right|chest_center|back_upper|back_lower|sleeve_left|sleeve_right|hem|collar|pocket|cuff|hood|side_panel|full_front|full_back — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusableFlag rdf:type rdf:Property ;
    rdfs:label 'Reusable Flag' ;
    rdfs:comment 'Indicates whether the embellishment design is a reusable asset that can be applied across multiple styles and collections, or is specific to a single product.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stitchCount rdf:type rdf:Property ;
    rdfs:label 'Stitch Count' ;
    rdfs:comment 'Total number of stitches in an embroidered embellishment design, used for production time estimation and Cost of Goods Sold (COGS) calculation.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technique rdf:type rdf:Property ;
    rdfs:label 'Technique' ;
    rdfs:comment 'Detailed description of the specific production technique or process used to create the embellishment, including stitch type for embroidery, application method for appliqués, or printing technology for screen prints.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threadCount rdf:type rdf:Property ;
    rdfs:label 'Thread Count' ;
    rdfs:comment 'Number of thread colors or individual threads used in embroidery or stitched embellishments, relevant for costing and production planning.' ;
    rdfs:domain ind:Embellishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit to produce or procure the embellishment, used for Cost of Goods Sold (COGS) calculation and pricing strategy. Expressed in the company\'s base currency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the embellishment design in centimeters, used for sizing specifications in tech packs and Bill of Materials (BOM).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricSwatchId rdf:type rdf:Property ;
    rdfs:label 'Fabric Swatch Id' ;
    rdfs:comment 'Unique identifier for the fabric swatch record. Primary key for the fabric swatch entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricSwatch .

ind:primaryFabricEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fabric Employee Id' ;
    rdfs:comment 'Identifier of the user who created the fabric swatch record in the system.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierMillVendorId rdf:type rdf:Property ;
    rdfs:label 'Supplier Mill Vendor Id' ;
    rdfs:comment 'Identifier of the textile mill or fabric supplier that provided the swatch. Links to the supplier master data for sourcing and procurement workflows.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:adoptionDecision rdf:type rdf:Property ;
    rdfs:label 'Adoption Decision' ;
    rdfs:comment 'Final decision status regarding the fabric swatch\'s inclusion in the collection. Selected indicates approval for production, shortlisted indicates further consideration, rejected indicates exclusion, and pending indicates evaluation in progress.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Standardized color reference code, typically Pantone TPX/TCX code or supplier-specific color code, used for precise color matching and communication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorHexValue rdf:type rdf:Property ;
    rdfs:label 'Color Hex Value' ;
    rdfs:comment 'Hexadecimal color code representing the digital approximation of the fabric color for use in digital design tools and CAD systems.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorName rdf:type rdf:Property ;
    rdfs:label 'Color Name' ;
    rdfs:comment 'Descriptive name of the fabric color as provided by the supplier or assigned by the design team, such as \'Navy Heather\' or \'Sunset Orange\'.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designerEvaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Designer Evaluation Notes' ;
    rdfs:comment 'Detailed notes and observations recorded by the designer during swatch evaluation, including aesthetic assessment, performance considerations, and potential applications.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostPerMeter rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Meter' ;
    rdfs:comment 'Estimated cost of the fabric per linear meter as quoted by the supplier, used for preliminary costing and feasibility analysis during design phase.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricFinish rdf:type rdf:Property ;
    rdfs:label 'Fabric Finish' ;
    rdfs:comment 'Surface treatment or finishing process applied to the fabric, such as enzyme wash, stone wash, coating, lamination, or water repellent finish.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricWeightGsm rdf:type rdf:Property ;
    rdfs:label 'Fabric Weight Gsm' ;
    rdfs:comment 'Weight of the fabric measured in grams per square meter. Critical specification for determining fabric hand, drape, and suitability for specific garment types.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricWidthCm rdf:type rdf:Property ;
    rdfs:label 'Fabric Width Cm' ;
    rdfs:comment 'Width of the fabric in centimeters, measured from selvage to selvage. Important specification for pattern making and material yield calculations.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberComposition rdf:type rdf:Property ;
    rdfs:label 'Fiber Composition' ;
    rdfs:comment 'Detailed breakdown of fiber content by percentage, such as \'60% Cotton, 40% Polyester\'. Required for compliance with FTC Textile Fiber Products Identification Act.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity, such as meters, yards, or kilograms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceAttributes rdf:type rdf:Property ;
    rdfs:label 'Performance Attributes' ;
    rdfs:comment 'Special performance characteristics of the fabric, such as moisture-wicking, stretch recovery, UV protection, antimicrobial, or water resistance. Comma-separated list of attributes.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalSwatchLocation rdf:type rdf:Property ;
    rdfs:label 'Physical Swatch Location' ;
    rdfs:comment 'Storage location or bin reference for the physical fabric swatch within the design studio or material library.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategorySuitability rdf:type rdf:Property ;
    rdfs:label 'Product Category Suitability' ;
    rdfs:comment 'Types of garments or product categories for which the fabric is suitable, such as outerwear, activewear, dresses, or accessories. Comma-separated list.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierFabricReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Fabric Reference' ;
    rdfs:comment 'Supplier\'s own reference code or catalog number for the fabric, used for ordering and communication with the mill.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Numerical score representing the environmental impact and sustainability attributes of the fabric, typically on a scale of 0-100, based on factors such as fiber source, production process, and certifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swatchCode rdf:type rdf:Property ;
    rdfs:label 'Swatch Code' ;
    rdfs:comment 'Unique business identifier code assigned to the fabric swatch for tracking and reference purposes across design and sourcing workflows.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swatchFormat rdf:type rdf:Property ;
    rdfs:label 'Swatch Format' ;
    rdfs:comment 'Indicates whether the swatch is a physical sample, a digital representation, or both formats are available.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swatchName rdf:type rdf:Property ;
    rdfs:label 'Swatch Name' ;
    rdfs:comment 'Descriptive name of the fabric swatch, typically including fabric type, texture, or visual characteristics for easy identification by designers.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swatchReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Swatch Receipt Date' ;
    rdfs:comment 'Date when the physical or digital fabric swatch was received by the design team for evaluation.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:swatchStatus rdf:type rdf:Property ;
    rdfs:label 'Swatch Status' ;
    rdfs:comment 'Current lifecycle status of the fabric swatch record. Active indicates available for use, archived indicates historical reference, discontinued indicates supplier no longer offers, expired indicates evaluation period ended.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textureDescription rdf:type rdf:Property ;
    rdfs:label 'Texture Description' ;
    rdfs:comment 'Qualitative description of the fabric texture and hand feel, such as smooth, brushed, ribbed, slub, or textured. Captures tactile characteristics important for design evaluation.' ;
    rdfs:domain ind:FabricSwatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardId rdf:type rdf:Property ;
    rdfs:label 'Mood Board Id' ;
    rdfs:comment 'Unique identifier for the mood board. Primary key for the mood board entity.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MoodBoard .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the mood board was formally approved by design leadership or merchandising.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardCode rdf:type rdf:Property ;
    rdfs:label 'Board Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the mood board for tracking and reference purposes across design and merchandising teams.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAlignment rdf:type rdf:Property ;
    rdfs:label 'Brand Alignment' ;
    rdfs:comment 'Assessment of how well the mood board aligns with the brand\'s established aesthetic, values, and positioning.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTheme rdf:type rdf:Property ;
    rdfs:label 'Creative Theme' ;
    rdfs:comment 'The overarching creative theme or narrative that the mood board communicates (e.g., \'Sustainable Luxury\', \'Street Culture Fusion\', \'Heritage Revival\').' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalReferences rdf:type rdf:Property ;
    rdfs:label 'Cultural References' ;
    rdfs:comment 'Description of cultural, historical, or lifestyle references that inform the mood board\'s aesthetic and narrative.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Indicates whether the mood board is digital, physical (printed/mounted), or a hybrid of both formats.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderCategory rdf:type rdf:Property ;
    rdfs:label 'Gender Category' ;
    rdfs:comment 'Target gender category or market segment for the design direction represented in the mood board.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the mood board was last updated or modified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardStatus rdf:type rdf:Property ;
    rdfs:label 'Mood Board Status' ;
    rdfs:comment 'Current lifecycle status of the mood board in the design approval workflow.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moodBoardType rdf:type rdf:Property ;
    rdfs:label 'Mood Board Type' ;
    rdfs:comment 'Classification of the mood board by its purpose or scope within the design process.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTool rdf:type rdf:Property ;
    rdfs:label 'Platform Tool' ;
    rdfs:comment 'The software platform or tool used to create and manage the mood board (e.g., \'Milanote\', \'InVision\', \'Miro\', \'Adobe Creative Cloud\', \'Centric PLM\', \'Physical Board\').' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'Date when the mood board was presented to stakeholders, merchandising teams, or executive leadership.' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryColorPalette rdf:type rdf:Property ;
    rdfs:label 'Primary Color Palette' ;
    rdfs:comment 'Comma-separated list or description of the primary colors featured in the mood board (e.g., \'Sage Green, Terracotta, Cream, Charcoal\').' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Product Category Focus' ;
    rdfs:comment 'Primary product categories that the mood board is intended to inspire (e.g., \'Outerwear\', \'Footwear\', \'Accessories\', \'Activewear\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textureReferences rdf:type rdf:Property ;
    rdfs:label 'Texture References' ;
    rdfs:comment 'Description of key textures, materials, and surface treatments referenced in the mood board (e.g., \'Raw Linen, Brushed Metal, Distressed Leather, Organic Cotton\').' ;
    rdfs:domain ind:MoodBoard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the mood board was initially created or started by the designer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moodBoardAssetId rdf:type rdf:Property ;
    rdfs:label 'Mood Board Asset Id' ;
    rdfs:comment 'Unique identifier for the mood board asset record. Primary key for the mood board asset entity.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadedByDesignerId rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Designer Id' ;
    rdfs:comment 'Reference to the designer or user who added the asset to the mood board. Supports collaboration tracking and attribution of creative contributions.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:assetCaption rdf:type rdf:Property ;
    rdfs:label 'Asset Caption' ;
    rdfs:comment 'Descriptive text or annotation provided by the designer to explain the inspiration, context, or relevance of the asset to the design concept. Supports creative storytelling and team collaboration.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFileFormat rdf:type rdf:Property ;
    rdfs:label 'Asset File Format' ;
    rdfs:comment 'File extension or media format of the asset. Indicates the technical format for rendering and compatibility purposes. [ENUM-REF-CANDIDATE: jpg|jpeg|png|gif|bmp|tiff|svg|mp4|mov|avi|pdf|psd|ai — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFileName rdf:type rdf:Property ;
    rdfs:label 'Asset File Name' ;
    rdfs:comment 'Original file name of the uploaded or linked asset. Preserves the source file identifier for traceability and reference.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFilePath rdf:type rdf:Property ;
    rdfs:label 'Asset File Path' ;
    rdfs:comment 'Internal storage location or file system path where the asset is stored within the Product Lifecycle Management (PLM) or Digital Asset Management (DAM) system. Enables retrieval and version control.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Asset File Size Bytes' ;
    rdfs:comment 'Size of the asset file measured in bytes. Used for storage management and performance optimization.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetHeight rdf:type rdf:Property ;
    rdfs:label 'Asset Height' ;
    rdfs:comment 'Height of the asset as displayed on the mood board, measured in pixels or percentage. Controls the visual scale and prominence of the asset within the composition.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sequence Number' ;
    rdfs:comment 'Ordinal position of the asset within the mood board layout. Determines the display order and visual arrangement of assets on the board.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Asset Source Url' ;
    rdfs:comment 'Web address or external link from which the asset was sourced. Captures the original location for reference and attribution purposes.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTags rdf:type rdf:Property ;
    rdfs:label 'Asset Tags' ;
    rdfs:comment 'Comma-separated or pipe-separated list of keywords or labels applied to the asset for search, filtering, and categorization. Examples include trend names, color families, themes, or seasonal references.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetWidth rdf:type rdf:Property ;
    rdfs:label 'Asset Width' ;
    rdfs:comment 'Width of the asset as displayed on the mood board, measured in pixels or percentage. Controls the visual scale and prominence of the asset within the composition.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkedProductSku rdf:type rdf:Property ;
    rdfs:label 'Linked Product Sku' ;
    rdfs:comment 'Stock Keeping Unit (SKU) of a product that was directly inspired by or developed from this mood board asset. Establishes traceability from creative concept to final product.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionXCoordinate rdf:type rdf:Property ;
    rdfs:label 'Position X Coordinate' ;
    rdfs:comment 'Horizontal position of the asset on the mood board canvas, measured in pixels or percentage from the left edge. Enables precise layout control and visual composition.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionYCoordinate rdf:type rdf:Property ;
    rdfs:label 'Position Y Coordinate' ;
    rdfs:comment 'Vertical position of the asset on the mood board canvas, measured in pixels or percentage from the top edge. Enables precise layout control and visual composition.' ;
    rdfs:domain ind:MoodBoardAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patternBlockId rdf:type rdf:Property ;
    rdfs:label 'Pattern Block Id' ;
    rdfs:comment 'Unique identifier for the pattern block record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatternBlock .

ind:primaryPatternEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pattern Employee Id' ;
    rdfs:comment 'Identifier of the pattern maker or technical designer who created or owns this pattern block. Links to workforce/employee master data.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blockCode rdf:type rdf:Property ;
    rdfs:label 'Block Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the pattern block used across PLM and design systems. This is the externally-known code for referencing the block in technical documentation and production systems.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockDescription rdf:type rdf:Property ;
    rdfs:label 'Block Description' ;
    rdfs:comment 'Detailed textual description of the pattern block, including key construction features, design intent, and usage guidelines (e.g., \'Basic bodice block with princess seams, designed for woven fabrics with 2-inch ease at bust\').' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockName rdf:type rdf:Property ;
    rdfs:label 'Block Name' ;
    rdfs:comment 'Human-readable name of the pattern block (e.g., \'Basic Bodice Block\', \'Slim Fit Trouser Block\', \'Oversized Hoodie Block\'). This is the primary identity label for the pattern block.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the pattern block (e.g., draft, approved, active, archived, deprecated). Indicates whether the block is in development, ready for use, or retired.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyMeasurementBasis rdf:type rdf:Property ;
    rdfs:label 'Body Measurement Basis' ;
    rdfs:comment 'Reference body measurement standard or fit model specification used as the foundation for this pattern block (e.g., \'ASTM D5585\', \'ISO 8559-1\', \'Company Fit Model Size 8\', \'US Standard Sizing Chart\').' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easeAllowanceInches rdf:type rdf:Property ;
    rdfs:label 'Ease Allowance Inches' ;
    rdfs:comment 'Standard ease allowance built into the pattern block, measured in inches. Represents the difference between body measurement and garment measurement at key points (e.g., 2.00 inches at bust, 1.50 inches at waist).' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricTypeRecommendation rdf:type rdf:Property ;
    rdfs:label 'Fabric Type Recommendation' ;
    rdfs:comment 'Recommended fabric types or fabric characteristics for which this pattern block is optimized (e.g., \'Woven fabrics with minimal stretch\', \'Knit fabrics with 20-30% stretch\', \'Structured outerwear fabrics\').' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitType rdf:type rdf:Property ;
    rdfs:label 'Fit Type' ;
    rdfs:comment 'Intended fit profile of the pattern block (e.g., slim, regular, relaxed, oversized, athletic, tailored). Defines the silhouette and ease allowance built into the block.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:garmentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Garment Subcategory' ;
    rdfs:comment 'Detailed subcategory within the garment category (e.g., \'T-Shirt\', \'Blouse\', \'Jeans\', \'Chinos\', \'Maxi Dress\', \'Parka\', \'Leggings\', \'Sports Bra\').' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingRulesReference rdf:type rdf:Property ;
    rdfs:label 'Grading Rules Reference' ;
    rdfs:comment 'Reference to the grading rule set or grading specification document that defines how this pattern block scales across sizes (e.g., \'GR-2024-WOMENS-TOPS\', \'Standard 2-inch Grade\', \'Athletic Fit Grade Rule v3\').' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProprietary rdf:type rdf:Property ;
    rdfs:label 'Is Proprietary' ;
    rdfs:comment 'Flag indicating whether this pattern block is proprietary intellectual property developed in-house (True) or based on industry-standard blocks (False).' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementChartUrl rdf:type rdf:Property ;
    rdfs:label 'Measurement Chart Url' ;
    rdfs:comment 'URL or file path to the detailed measurement chart (spec sheet) that documents all key measurements for this pattern block across the size range.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternFileFormat rdf:type rdf:Property ;
    rdfs:label 'Pattern File Format' ;
    rdfs:comment 'Digital file format of the pattern block (e.g., DXF, AAMA, ASTM, PLT, PDF, proprietary CAD format). Indicates the CAD system compatibility.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternFilePath rdf:type rdf:Property ;
    rdfs:label 'Pattern File Path' ;
    rdfs:comment 'File system path or PLM repository location where the digital pattern block file is stored (e.g., CAD file, DXF, AAMA format). Confidential IP asset location.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternVersion rdf:type rdf:Property ;
    rdfs:label 'Pattern Version' ;
    rdfs:comment 'Version number of the pattern block (e.g., \'v1.0\', \'v2.3\'). Incremented when the block is revised or updated. Enables version control and traceability of pattern evolution.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seamAllowanceInches rdf:type rdf:Property ;
    rdfs:label 'Seam Allowance Inches' ;
    rdfs:comment 'Standard seam allowance included in the pattern block, measured in inches (e.g., 0.50 inches, 0.375 inches). Defines the margin added beyond the stitching line for seam construction.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Size Range End' ;
    rdfs:comment 'Ending size in the size range this pattern block covers (e.g., \'XXL\', \'18\', \'42\', \'12\'). Represents the largest size for which this block is graded.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Size Range Start' ;
    rdfs:comment 'Starting size in the size range this pattern block covers (e.g., \'XS\', \'2\', \'28\', \'4T\'). Represents the smallest size for which this block is graded.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSketchUrl rdf:type rdf:Property ;
    rdfs:label 'Technical Sketch Url' ;
    rdfs:comment 'URL or file path to the technical sketch or flat drawing that illustrates the pattern block design. Used for visual reference in PLM and design collaboration.' ;
    rdfs:domain ind:PatternBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printColorwayId rdf:type rdf:Property ;
    rdfs:label 'Print Colorway Id' ;
    rdfs:comment 'Unique identifier for the print colorway record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrintColorway .

ind:azoFree rdf:type rdf:Property ;
    rdfs:label 'Azo Free' ;
    rdfs:comment 'Indicates whether the colorway is produced using azo-free dyes, which are safer and more environmentally friendly.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmykColorFormula rdf:type rdf:Property ;
    rdfs:label 'Cmyk Color Formula' ;
    rdfs:comment 'Cyan, Magenta, Yellow, Black color formula for digital printing and reproduction. Format: C:xx M:xx Y:xx K:xx.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFastnessRating rdf:type rdf:Property ;
    rdfs:label 'Color Fastness Rating' ;
    rdfs:comment 'Color fastness test rating (1-5 scale) indicating resistance to fading from washing, light exposure, and rubbing. Higher numbers indicate better fastness.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayStatus rdf:type rdf:Property ;
    rdfs:label 'Colorway Status' ;
    rdfs:comment 'Current lifecycle status of the colorway in the design and production workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalFileFormat rdf:type rdf:Property ;
    rdfs:label 'Digital File Format' ;
    rdfs:comment 'File format of the digital artwork (e.g., AI for Adobe Illustrator, EPS, PDF, PSD for Photoshop). [ENUM-REF-CANDIDATE: AI|EPS|PDF|PSD|TIFF|PNG|JPG — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hexColorCode rdf:type rdf:Property ;
    rdfs:label 'Hex Color Code' ;
    rdfs:comment 'Hexadecimal color code for web and digital applications. Format: #RRGGBB.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oekoTexCompliant rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Compliant' ;
    rdfs:comment 'Indicates whether the colorway uses dyes and chemicals that meet OEKO-TEX Standard 100 certification for textile safety.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printLayerCount rdf:type rdf:Property ;
    rdfs:label 'Print Layer Count' ;
    rdfs:comment 'Number of distinct color layers or screens required to produce this colorway. Impacts production complexity and cost.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:printTechnique rdf:type rdf:Property ;
    rdfs:label 'Print Technique' ;
    rdfs:comment 'Printing method or technique specified for producing this colorway (e.g., screen print, digital print, sublimation). [ENUM-REF-CANDIDATE: screen_print|digital_print|sublimation|rotary_print|block_print|discharge_print|pigment_print — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rgbColorCode rdf:type rdf:Property ;
    rdfs:label 'Rgb Color Code' ;
    rdfs:comment 'Red, Green, Blue color code for digital display and e-commerce imagery. Format: rgb(r, g, b).' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPantoneCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Pantone Code' ;
    rdfs:comment 'Secondary Pantone color reference for accent or supporting colors in the colorway.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikeOffApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Strike Off Approval Date' ;
    rdfs:comment 'Date when the strike-off sample was approved for bulk production.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strikeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Strike Off Status' ;
    rdfs:comment 'Status of the physical strike-off sample approval process. Strike-offs are physical print samples submitted by mills or printers for color and quality approval before bulk production. [ENUM-REF-CANDIDATE: not_requested|requested|in_progress|submitted|approved|rejected|revision_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strikeOffSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Strike Off Submission Date' ;
    rdfs:comment 'Date when the physical strike-off sample was submitted for approval.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:styleReferenceCodes rdf:type rdf:Property ;
    rdfs:label 'Style Reference Codes' ;
    rdfs:comment 'Comma-separated list of style codes or SKU (Stock Keeping Unit) references that use this colorway. Links the colorway to specific garments or products.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateType rdf:type rdf:Property ;
    rdfs:label 'Substrate Type' ;
    rdfs:comment 'Type of fabric or material substrate this colorway is designed for (e.g., cotton jersey, polyester knit, silk).' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Geographic market or region this colorway is designed for, reflecting regional color preferences and trends.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryPantoneCode rdf:type rdf:Property ;
    rdfs:label 'Tertiary Pantone Code' ;
    rdfs:comment 'Tertiary Pantone color reference for additional accent colors in multi-color prints.' ;
    rdfs:domain ind:PrintColorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPrintEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Print Employee Id' ;
    rdfs:comment 'Identifier of the user who granted final approval for this print design. Typically a design director, merchandising manager, or creative director.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:colorCount rdf:type rdf:Property ;
    rdfs:label 'Color Count' ;
    rdfs:comment 'The total number of distinct colors used in the print design. Impacts printing cost, complexity, and production method selection.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'The color space or profile used in the print design file. Ensures accurate color reproduction across different media and printing technologies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightYear rdf:type rdf:Property ;
    rdfs:label 'Copyright Year' ;
    rdfs:comment 'The year in which copyright protection was established for this print design. Used for intellectual property protection and legal compliance.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designMedium rdf:type rdf:Property ;
    rdfs:label 'Design Medium' ;
    rdfs:comment 'The creative medium or technique used to create the original print artwork. Impacts file format requirements and reproduction quality.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designStatus rdf:type rdf:Property ;
    rdfs:label 'Design Status' ;
    rdfs:comment 'Current lifecycle status of the print design in the approval workflow. Governs visibility and usage permissions across the organization.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTheme rdf:type rdf:Property ;
    rdfs:label 'Design Theme' ;
    rdfs:comment 'The creative theme or inspiration concept behind the print design. Examples include floral, geometric, abstract, animal, nautical, ethnic, or seasonal themes.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricCompatibility rdf:type rdf:Property ;
    rdfs:label 'Fabric Compatibility' ;
    rdfs:comment 'Description of fabric types and compositions that are suitable for this print design. May include restrictions based on print technique or design characteristics.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensedArtwork rdf:type rdf:Property ;
    rdfs:label 'Is Licensed Artwork' ;
    rdfs:comment 'Boolean flag indicating whether this print design uses licensed artwork from an external artist or intellectual property holder versus original in-house creation.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'License Agreement Number' ;
    rdfs:comment 'The contract or agreement reference number governing the use of licensed artwork. Used for royalty tracking and compliance verification.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseHolderName rdf:type rdf:Property ;
    rdfs:label 'License Holder Name' ;
    rdfs:comment 'The name of the individual artist, agency, or organization that holds the intellectual property rights for licensed artwork. Null for original designs.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterFileFormat rdf:type rdf:Property ;
    rdfs:label 'Master File Format' ;
    rdfs:comment 'The file format of the master print design file. Determines compatibility with design software, printing systems, and production workflows. [ENUM-REF-CANDIDATE: AI|PSD|PDF|TIFF|PNG|SVG|EPS — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterFilePath rdf:type rdf:Property ;
    rdfs:label 'Master File Path' ;
    rdfs:comment 'The file system or cloud storage path to the master high-resolution print design file. Used for production, printing, and archival purposes.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Master File Size Mb' ;
    rdfs:comment 'The file size of the master print design file measured in megabytes. Used for storage planning and file transfer optimization.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'The dominant color in the print design represented as a hexadecimal color code. Used for color matching, merchandising, and digital asset management.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printCode rdf:type rdf:Property ;
    rdfs:label 'Print Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the print design for system identification and cross-referencing in Product Lifecycle Management (PLM) and Enterprise Resource Planning (ERP) systems.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printName rdf:type rdf:Property ;
    rdfs:label 'Print Name' ;
    rdfs:comment 'The creative name or title assigned to this print design by the design team. Used for identification and reference in collections and tech packs.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printResolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Print Resolution Dpi' ;
    rdfs:comment 'The resolution of the print design file measured in dots per inch. Higher DPI ensures better print quality and detail reproduction.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:printType rdf:type rdf:Property ;
    rdfs:label 'Print Type' ;
    rdfs:comment 'Classification of the print design based on application method and placement on the garment. Determines manufacturing process and costing.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatHeightCm rdf:type rdf:Property ;
    rdfs:label 'Repeat Height Cm' ;
    rdfs:comment 'The vertical height of one complete pattern repeat measured in centimeters. Used in fabric yield calculations and production planning.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatType rdf:type rdf:Property ;
    rdfs:label 'Repeat Type' ;
    rdfs:comment 'The pattern repeat structure used in the print design. Defines how the design tiles across fabric yardage and impacts fabric utilization and cutting efficiency.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatWidthCm rdf:type rdf:Property ;
    rdfs:label 'Repeat Width Cm' ;
    rdfs:comment 'The horizontal width of one complete pattern repeat measured in centimeters. Critical for fabric ordering and marker making efficiency.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Hex' ;
    rdfs:comment 'The secondary prominent color in the print design represented as a hexadecimal color code. Supports color story development and assortment planning.' ;
    rdfs:domain ind:PrintDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionScore rdf:type rdf:Property ;
    rdfs:label 'Adoption Score' ;
    rdfs:comment 'Numeric score (0.00 to 100.00) representing the estimated market adoption or prevalence of this trend item based on analyst assessment.' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionAdoptionFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Adoption Flag' ;
    rdfs:comment 'Boolean flag indicating whether this trend item has been adopted or incorporated into an internal collection or product line (True/False).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveBrandAdoption rdf:type rdf:Property ;
    rdfs:label 'Competitive Brand Adoption' ;
    rdfs:comment 'Comma-separated list of competitive brand names that have adopted or showcased this trend item in their collections.' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerSegment rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment' ;
    rdfs:comment 'The target consumer segment or demographic for which this trend item is most relevant (e.g., Gen Z, Millennials, Luxury, Athleisure, Streetwear).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastLongevityMonths rdf:type rdf:Property ;
    rdfs:label 'Forecast Longevity Months' ;
    rdfs:comment 'Estimated number of months this trend item is expected to remain relevant in the market based on trend forecasting analysis.' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genderRelevance rdf:type rdf:Property ;
    rdfs:label 'Gender Relevance' ;
    rdfs:comment 'The gender category for which this trend item is most relevant (mens, womens, unisex, kids, all).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRelevance rdf:type rdf:Property ;
    rdfs:label 'Geographic Relevance' ;
    rdfs:comment 'Comma-separated list of 3-letter ISO country codes or region identifiers indicating where this trend item is relevant or observed (e.g., USA, GBR, FRA, JPN).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influenceLevel rdf:type rdf:Property ;
    rdfs:label 'Influence Level' ;
    rdfs:comment 'Qualitative assessment of the influence or impact level of this trend item on the market or collection planning (low, medium, high, critical).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'The name or label of the trend item as observed in the market or documented in the trend report (e.g., \'Oversized Blazers\', \'Neon Green\', \'Utility Pockets\').' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggedByAnalyst rdf:type rdf:Property ;
    rdfs:label 'Logged By Analyst' ;
    rdfs:comment 'The name or identifier of the trend analyst, designer, or merchandiser who logged or documented this trend item.' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Description of the material or fabric composition associated with this trend item if it is fabric or material-related (e.g., \'Organic Cotton\', \'Recycled Polyester\', \'Silk Blend\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTrendItems rdf:type rdf:Property ;
    rdfs:label 'Related Trend Items' ;
    rdfs:comment 'Comma-separated list of related trend item IDs or names that are complementary or frequently co-occur with this trend item.' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayCitation rdf:type rdf:Property ;
    rdfs:label 'Runway Citation' ;
    rdfs:comment 'Reference to the runway show, fashion week, or designer presentation where this trend item was observed (e.g., \'Paris Fashion Week SS24 - Chanel\', \'Milan FW24 - Prada\').' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReference rdf:type rdf:Property ;
    rdfs:label 'Source Reference' ;
    rdfs:comment 'Specific reference or citation to the source material (e.g., URL, publication name, social media handle, event name).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendCategory rdf:type rdf:Property ;
    rdfs:label 'Trend Category' ;
    rdfs:comment 'The category or classification of the trend item indicating what aspect of design it represents (color, silhouette, fabric, print, embellishment, styling, accessory, footwear, texture, finish). [ENUM-REF-CANDIDATE: color|silhouette|fabric|print|embellishment|styling|accessory|footwear|texture|finish — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDescription rdf:type rdf:Property ;
    rdfs:label 'Trend Description' ;
    rdfs:comment 'Detailed textual description of the trend item including design characteristics, styling notes, and contextual information.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendItemStatus rdf:type rdf:Property ;
    rdfs:label 'Trend Item Status' ;
    rdfs:comment 'Current status of the trend item record in the system (active, archived, under_review, rejected).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendStage rdf:type rdf:Property ;
    rdfs:label 'Trend Stage' ;
    rdfs:comment 'The lifecycle stage of the trend item indicating its current adoption and market penetration (emerging, growth, peak, maturity, declining, obsolete).' ;
    rdfs:domain ind:TrendItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Adoption Recommendation' ;
    rdfs:comment 'Strategic recommendation for how the brand should respond to the trend: lead (be first to market, drive the trend), follow (adopt after market validation), monitor (watch for further signals), or avoid (not aligned with brand positioning).' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyTrendThemes rdf:type rdf:Property ;
    rdfs:label 'Key Trend Themes' ;
    rdfs:comment 'A summary of the primary trend themes, concepts, or narratives identified in the report. May include keywords, thematic descriptors, or trend names (e.g., \'Neo-Nostalgia\', \'Sustainable Minimalism\', \'Digital Craft\').' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialFocus rdf:type rdf:Property ;
    rdfs:label 'Material Focus' ;
    rdfs:comment 'Key materials, fabrics, or textile innovations featured in the trend report (e.g., recycled polyester, organic cotton, technical knits, vegan leather).' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportAuthor rdf:type rdf:Property ;
    rdfs:label 'Report Author' ;
    rdfs:comment 'Name of the individual or team within the design organization who compiled, authored, or is responsible for the trend report (if internally generated).' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportCode rdf:type rdf:Property ;
    rdfs:label 'Report Code' ;
    rdfs:comment 'Unique business identifier or reference code assigned to the trend report for cataloging and retrieval purposes.' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'URL or file path to the full trend report document, presentation deck, or digital asset stored in the PLM system or document management system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the trend report within the organization\'s design workflow: draft (initial compilation), under review (being evaluated by design leadership), approved (validated for use in collection planning), archived (historical reference), or obsolete (no longer relevant).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTitle rdf:type rdf:Property ;
    rdfs:label 'Report Title' ;
    rdfs:comment 'The full title or name of the trend research report as published by the design team or trend forecasting agency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or role of the design leadership, creative director, or merchandising executive who reviewed and approved the trend report for use in collection planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAgency rdf:type rdf:Property ;
    rdfs:label 'Source Agency' ;
    rdfs:comment 'The name of the trend forecasting agency or organization that published the report (e.g., WGSN, Trendalytics, Edited, Pantone, Fashion Snoops) or \'Internal\' if compiled by the in-house design team.' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductCategory rdf:type rdf:Property ;
    rdfs:label 'Target Product Category' ;
    rdfs:comment 'The product category or categories (e.g., womenswear, menswear, footwear, accessories) for which this trend report is most applicable. May be a comma-separated list if the trend spans multiple categories.' ;
    rdfs:domain ind:TrendReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Id' ;
    rdfs:comment 'Unique identifier for the A/B or multivariate test. Primary key for the ab_test data product.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: A/B tests are owned by product managers, merchandisers, or UX designers for experimentation programs. Links enable performance tracking, workload management, and accountability for test design/analysi' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:additionalVariantsCount rdf:type rdf:Property ;
    rdfs:label 'Additional Variants Count' ;
    rdfs:comment 'Number of additional treatment variants beyond the primary treatment. Zero for simple A/B tests, one or more for A/B/n or multivariate tests. Detailed variant data stored in related variant detail table.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'Statistical confidence level achieved by the test results, typically 95.00 or 99.00. Represents the probability that the observed difference is not due to random chance. Calculated from p-value: confidence = (1 - p_value) * 100.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlAov rdf:type rdf:Property ;
    rdfs:label 'Control Aov' ;
    rdfs:comment 'Average Order Value (AOV) for orders from the control variant, calculated as total revenue divided by number of orders. Measured in the storefronts default currency.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlConversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Control Conversion Rate Percent' ;
    rdfs:comment 'Conversion rate for the control variant, calculated as (control_conversions / control_impressions) * 100. Baseline performance metric against which treatment variants are compared.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlConversions rdf:type rdf:Property ;
    rdfs:label 'Control Conversions' ;
    rdfs:comment 'Total number of conversions (successful outcomes per primary success metric) from the control variant. For conversion rate tests, this is completed purchases; for CTR tests, this is clicks.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlImpressions rdf:type rdf:Property ;
    rdfs:label 'Control Impressions' ;
    rdfs:comment 'Total number of unique visitors or sessions exposed to the control variant during the test period. Used as denominator in conversion rate calculations.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlRevenuePerVisitor rdf:type rdf:Property ;
    rdfs:label 'Control Revenue Per Visitor' ;
    rdfs:comment 'Revenue per visitor for the control variant, calculated as total revenue divided by impressions. Combines conversion rate and order value into a single metric. Measured in the storefronts default currency.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlTrafficSplitPercent rdf:type rdf:Property ;
    rdfs:label 'Control Traffic Split Percent' ;
    rdfs:comment 'Percentage of test traffic allocated to the control variant. In a 50/50 A/B test this would be 50.00. In multivariate tests may be lower to accommodate multiple treatment variants.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlVariantName rdf:type rdf:Property ;
    rdfs:label 'Control Variant Name' ;
    rdfs:comment 'Name of the control variant (baseline experience). Typically \'Control\' or \'Original\'. This is the existing experience against which treatment variants are compared.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The business hypothesis being tested, describing the expected outcome and rationale. Example: \'Changing the CTA button color from blue to orange will increase click-through rate by 15% because it creates stronger visual contrast.\'' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftPercent rdf:type rdf:Property ;
    rdfs:label 'Lift Percent' ;
    rdfs:comment 'Percentage improvement (or decline if negative) of the treatment variant over the control for the primary success metric. Calculated as ((treatment_metric - control_metric) / control_metric) * 100. Example: 15.50 means the treatment performed 15.5% better than control.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDetectableEffectPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect Percent' ;
    rdfs:comment 'The smallest percentage improvement in the primary metric that the test is designed to detect with statistical confidence. Used in sample size calculation. Example: 5.00 means the test can reliably detect a 5% or greater improvement.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The probability that the observed difference between variants occurred by random chance. Lower values indicate stronger evidence of a real effect. Values below the significance threshold (typically 0.05) indicate statistical significance.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Planned duration of the test in days, determined during test design based on required sample size and traffic volume to achieve statistical significance.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The primary Key Performance Indicator (KPI) used to determine test success. Conversion rate (CVR): percentage of visitors who complete purchase, AOV: Average Order Value, revenue per visitor (RPV): total revenue divided by visitors, click-through rate (CTR): clicks divided by impressions, add-to-cart rate: products added to cart divided by product views, bounce rate: single-page sessions, time on page: average session duration on tested page. [ENUM-REF-CANDIDATE: conversion_rate|aov|revenue_per_visitor|click_through_rate|add_to_cart_rate|bounce_rate|time_on_page — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutDate rdf:type rdf:Property ;
    rdfs:label 'Rollout Date' ;
    rdfs:comment 'Date when the winning variant was or will be rolled out to production for all users. Null if no rollout planned or decision pending.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rolloutDecision rdf:type rdf:Property ;
    rdfs:label 'Rollout Decision' ;
    rdfs:comment 'Business decision on how to implement test results. Full rollout: deploy winning variant to 100% of traffic, Partial rollout: deploy to subset of traffic or segments, No rollout: keep original experience, Pending: decision not yet made, Rollback: reverse a previous rollout.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondarySuccessMetrics rdf:type rdf:Property ;
    rdfs:label 'Secondary Success Metrics' ;
    rdfs:comment 'Comma-separated list of additional metrics monitored to understand broader test impact. Examples: engagement rate, return rate, customer satisfaction score. Used to detect unintended consequences.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Significance Threshold' ;
    rdfs:comment 'The p-value threshold required to declare a statistically significant result, typically 0.0500 (95% confidence) or 0.0100 (99% confidence). Lower values require stronger evidence but reduce false positive risk.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'Category of the test element being optimized: layout (page structure), copy (messaging/text), pricing (price display/strategy), cta (call-to-action buttons), recommendation (product suggestions), navigation (site navigation), checkout (purchase flow), personalization (targeted content). [ENUM-REF-CANDIDATE: layout|copy|pricing|cta|recommendation|navigation|checkout|personalization — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Business-friendly unique code for the test, used for tracking and reporting purposes. Typically follows a naming convention like EXP_HOMEPAGE_CTA_Q1.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name of the A/B test describing the experiment focus, such as \'Homepage Hero Banner CTA Optimization\' or \'Product Detail Page Layout Test\'.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Percent' ;
    rdfs:comment 'Percentage of total site traffic allocated to this test. Remaining traffic sees the default experience. Typical values range from 10% to 100% depending on risk tolerance and traffic volume.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentAov rdf:type rdf:Property ;
    rdfs:label 'Treatment Aov' ;
    rdfs:comment 'Average Order Value (AOV) for orders from the primary treatment variant, calculated as total revenue divided by number of orders. Measured in the storefronts default currency.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentConversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Treatment Conversion Rate Percent' ;
    rdfs:comment 'Conversion rate for the primary treatment variant, calculated as (treatment_conversions / treatment_impressions) * 100. Compared against control to determine test outcome.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentConversions rdf:type rdf:Property ;
    rdfs:label 'Treatment Conversions' ;
    rdfs:comment 'Total number of conversions (successful outcomes per primary success metric) from the primary treatment variant. For conversion rate tests, this is completed purchases; for CTR tests, this is clicks.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentImpressions rdf:type rdf:Property ;
    rdfs:label 'Treatment Impressions' ;
    rdfs:comment 'Total number of unique visitors or sessions exposed to the primary treatment variant during the test period. Used as denominator in conversion rate calculations.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentRevenuePerVisitor rdf:type rdf:Property ;
    rdfs:label 'Treatment Revenue Per Visitor' ;
    rdfs:comment 'Revenue per visitor for the primary treatment variant, calculated as total revenue divided by impressions. Combines conversion rate and order value into a single metric. Measured in the storefronts default currency.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentTrafficSplitPercent rdf:type rdf:Property ;
    rdfs:label 'Treatment Traffic Split Percent' ;
    rdfs:comment 'Percentage of test traffic allocated to the primary treatment variant. In a 50/50 A/B test this would be 50.00. Sum of all variant splits must equal 100.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentVariantName rdf:type rdf:Property ;
    rdfs:label 'Treatment Variant Name' ;
    rdfs:comment 'Name of the primary treatment variant (new experience being tested). Examples: \'Variant A\', \'Orange CTA\', \'New Layout\'. For multivariate tests, this may represent the first treatment; additional variants tracked separately.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winnerVariant rdf:type rdf:Property ;
    rdfs:label 'Winner Variant' ;
    rdfs:comment 'Declared winner of the test based on statistical analysis. Control: original experience wins, Treatment: new experience wins, Inconclusive: no statistically significant difference, Ongoing: test still running or analysis incomplete.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartId rdf:type rdf:Property ;
    rdfs:label 'Cart Id' ;
    rdfs:comment 'Unique identifier for the shopping cart instance. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:fulfillmentDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Carts check real-time inventory availability against specific DC pools to calculate ATP and display accurate stock status. Critical for preventing overselling and enabling DC-specific inventory reserv' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:mergedFromCartId rdf:type rdf:Property ;
    rdfs:label 'Merged From Cart Id' ;
    rdfs:comment 'Reference to another cart that was merged into this cart. Occurs when a guest shopper logs in and their guest cart is merged with their authenticated cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Reference to the customer address selected for shipping. May be null if address not yet selected.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:webSessionId rdf:type rdf:Property ;
    rdfs:label 'Web Session Id' ;
    rdfs:comment 'Unique session identifier from the e-commerce platform tracking the shopper\'s browsing session. Used for abandoned cart recovery and session analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifier for the A/B test variant or experience shown to this shopper. Used for conversion rate optimization and multivariate testing analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Abandoned Timestamp' ;
    rdfs:comment 'Timestamp when the cart was classified as abandoned based on inactivity threshold. Triggers abandoned cart recovery campaigns.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cartStatus rdf:type rdf:Property ;
    rdfs:label 'Cart Status' ;
    rdfs:comment 'Current lifecycle status of the shopping cart. Active = shopper is actively browsing; Abandoned = shopper left without checkout; Converted = cart was successfully checked out; Merged = cart was merged with another; Expired = cart aged out per retention policy; Saved = shopper explicitly saved for later.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartType rdf:type rdf:Property ;
    rdfs:label 'Cart Type' ;
    rdfs:comment 'Classification of cart purpose. Standard = regular shopping cart; Wishlist = saved items for future purchase; Registry = gift registry or wedding registry; Subscription = recurring order cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'Timestamp when the cart was successfully converted to a sales order. Marks the completion of the purchase journey.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to the cart from all promotions, coupon codes, and markdowns. Reduces the subtotal.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Timestamp when the cart will expire and be purged from the system per data retention policy. Typically 30-90 days from last modification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Optional gift message text entered by the customer for gift orders. Printed on packing slip or gift card.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether the customer has requested gift wrapping for items in this cart. May incur additional charges.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestCheckoutFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Checkout Flag' ;
    rdfs:comment 'Indicates whether this cart belongs to a guest (non-authenticated) shopper. Guest carts have limited personalization and no saved payment methods.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of distinct line items (SKUs) in the cart. Does not account for quantity per line.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsApplied rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Applied' ;
    rdfs:comment 'Number of loyalty program points the customer has elected to redeem against this cart. Converted to discount amount based on points-to-currency ratio.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationSegment rdf:type rdf:Property ;
    rdfs:label 'Personalization Segment' ;
    rdfs:comment 'Customer segment code used for personalized pricing, product recommendations, and targeted promotions. Driven by Adobe Experience Platform or similar CDP.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Estimated shipping cost for the cart. Final shipping cost is determined at checkout based on selected shipping method and destination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingMethodCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Method Code' ;
    rdfs:comment 'Code representing the selected or estimated shipping method (e.g., standard, express, overnight). Used to calculate shipping cost and delivery estimate.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item subtotals before discounts, taxes, and shipping. Represents the gross merchandise value in the cart.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Estimated sales tax or VAT amount for the cart. Final tax is calculated at checkout based on shipping address.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total cart value including subtotal, discounts, estimated tax, and estimated shipping. Represents the expected order total if the cart is converted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total quantity of all units across all line items in the cart. Sum of all line item quantities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign tracking parameter from the referring URL. Used for digital marketing campaign attribution and ROI measurement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium tracking parameter identifying the marketing medium (e.g., cpc, email, social). Used for channel attribution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source tracking parameter identifying the traffic source (e.g., google, facebook, newsletter). Used for channel attribution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecommerceCatalogProductListingId rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Catalog Product Listing Id' ;
    rdfs:comment 'Unique identifier for the catalog product listing record. Primary key for this entity representing a specific SKU or style published on a digital storefront.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteCatalogId rdf:type rdf:Property ;
    rdfs:label 'Site Catalog Id' ;
    rdfs:comment 'Reference to the digital storefront or e-commerce site where this product is listed. Supports multi-site catalog management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteCatalog .

ind:sizeScaleId rdf:type rdf:Property ;
    rdfs:label 'Size Scale Id' ;
    rdfs:comment 'Reference to the size chart or fit guide associated with this product listing. Helps customers select appropriate size.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SizeScale .

ind:standardId rdf:type rdf:Property ;
    rdfs:label 'Standard Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_standard. Business justification: Product listings must display applicable quality/sustainability certifications (OEKO-TEX, GOTS, Fair Trade) for regulatory compliance and customer transparency. Quality standards drive product badging' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Standard .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to production.work_order. Business justification: Pre-order catalog listings must reference specific production work orders to calculate accurate expected ship dates, manage inventory promises, and coordinate go-live timing with production completion' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'Calculated average customer rating score for this product listing, typically on a 1-5 scale. Displayed to influence purchase decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badgeColor rdf:type rdf:Property ;
    rdfs:label 'Badge Color' ;
    rdfs:comment 'Hexadecimal color code or predefined color name for the product badge. Controls visual presentation of promotional badges.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeText rdf:type rdf:Property ;
    rdfs:label 'Badge Text' ;
    rdfs:comment 'Optional promotional or informational badge text displayed on the product tile or detail page (e.g., Sale, Limited Edition, Sustainable).' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browsableFlag rdf:type rdf:Property ;
    rdfs:label 'Browsable Flag' ;
    rdfs:comment 'Boolean indicator whether this product listing should appear in category browse pages and navigation menus.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canonicalUrl rdf:type rdf:Property ;
    rdfs:label 'Canonical Url' ;
    rdfs:comment 'The canonical URL path for this product listing. Used for SEO to prevent duplicate content issues and establish the authoritative product page.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPriceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Digital Price Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the digital price override. Required when digital price override is populated.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPriceOverride rdf:type rdf:Property ;
    rdfs:label 'Digital Price Override' ;
    rdfs:comment 'Optional price override specific to the digital channel. When populated, this price supersedes the standard retail price for online transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering value controlling the position of this product in catalog browse and search results. Lower values appear first.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'Expected date when pre-order or back-ordered items will ship to customers. Manages customer expectations for delayed fulfillment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'The date when this product listing becomes active and visible to customers on the digital storefront. Supports scheduled product launches.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryDisplayMode rdf:type rdf:Property ;
    rdfs:label 'Inventory Display Mode' ;
    rdfs:comment 'Controls how inventory availability is displayed to customers on the product listing (exact quantity, low stock warning, simple in-stock indicator, or hidden).' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBestseller rdf:type rdf:Property ;
    rdfs:label 'Is Bestseller' ;
    rdfs:comment 'Boolean indicator whether this product qualifies as a bestseller based on sales velocity and should be merchandised accordingly.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewArrival rdf:type rdf:Property ;
    rdfs:label 'Is New Arrival' ;
    rdfs:comment 'Boolean indicator whether this product should be displayed with new arrival badge or in new arrivals collection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnlineExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Online Exclusive' ;
    rdfs:comment 'Boolean indicator whether this product is available exclusively through the digital channel and not in physical retail stores.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listingCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Listing Created Timestamp' ;
    rdfs:comment 'Timestamp when this catalog product listing record was first created in the system. Audit trail for listing lifecycle.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current publication status of the product listing on the digital storefront. Determines visibility and availability to customers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Listing Updated Timestamp' ;
    rdfs:comment 'Timestamp when this catalog product listing record was last modified. Tracks merchandising changes and content updates.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lowStockThreshold rdf:type rdf:Property ;
    rdfs:label 'Low Stock Threshold' ;
    rdfs:comment 'Inventory quantity threshold below which the low stock warning is displayed to customers. Drives urgency messaging.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Order Flag' ;
    rdfs:comment 'Boolean indicator whether this product is available for pre-order before official release date. Supports launch campaigns.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendationPriority rdf:type rdf:Property ;
    rdfs:label 'Recommendation Priority' ;
    rdfs:comment 'Numeric priority score used by recommendation engines to rank this product in personalized product suggestions and cross-sell opportunities.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'Total number of customer reviews submitted for this product listing. Provides social proof and credibility.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchableFlag rdf:type rdf:Property ;
    rdfs:label 'Searchable Flag' ;
    rdfs:comment 'Boolean indicator whether this product listing should be included in site search results and search engine indexing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and phrases for search engine optimization and internal site search relevance.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Description' ;
    rdfs:comment 'Meta description tag content for search engine results pages. Summarizes product listing in 150-160 characters to drive click-through.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Title' ;
    rdfs:comment 'Optimized page title for search engine indexing and display in search results. Typically 50-60 characters for optimal display.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Restriction Flag' ;
    rdfs:comment 'Boolean indicator whether this product has shipping restrictions (e.g., hazardous materials, oversized, international restrictions).' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code for this product listing. Determines applicable sales tax rates and rules for digital transactions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeSixtyViewUrl rdf:type rdf:Property ;
    rdfs:label 'Three Sixty View Url' ;
    rdfs:comment 'URL to the interactive 360-degree product view asset. Provides immersive product visualization experience.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urlSlug rdf:type rdf:Property ;
    rdfs:label 'Url Slug' ;
    rdfs:comment 'Human-readable URL-friendly identifier derived from product name. Used in constructing the product detail page URL path.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoUrl rdf:type rdf:Property ;
    rdfs:label 'Video Url' ;
    rdfs:comment 'URL to the primary product video showcasing the item. Enhances product presentation and conversion rates.' ;
    rdfs:domain ind:EcommerceCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutSessionId rdf:type rdf:Property ;
    rdfs:label 'Checkout Session Id' ;
    rdfs:comment 'Unique identifier for the checkout session. Primary key for this entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CheckoutSession .

ind:selectedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Selected Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Checkout sessions capture customer-selected carrier for shipping method choice, rate calculation, and delivery promise. Essential for order fulfillment instructions and carrier performance tracking by' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:abandonmentStep rdf:type rdf:Property ;
    rdfs:label 'Abandonment Step' ;
    rdfs:comment 'The specific checkout step where the customer abandoned the session. None if checkout was completed.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserType rdf:type rdf:Property ;
    rdfs:label 'Browser Type' ;
    rdfs:comment 'Web browser type and version used during the checkout session (e.g., Chrome, Safari, Firefox).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutAbandonmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Abandonment Timestamp' ;
    rdfs:comment 'Timestamp when the checkout session was abandoned by the customer or timed out. Null if not abandoned.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkoutCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Completion Timestamp' ;
    rdfs:comment 'Timestamp when the checkout was successfully completed and order was placed. Null if not completed.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkoutDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Checkout Duration Seconds' ;
    rdfs:comment 'Total duration of the checkout session in seconds from start to completion or abandonment.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkoutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Start Timestamp' ;
    rdfs:comment 'Timestamp when the customer initiated the checkout process from the shopping cart.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkoutStatus rdf:type rdf:Property ;
    rdfs:label 'Checkout Status' ;
    rdfs:comment 'Current lifecycle status of the checkout session indicating the final outcome or current state.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'System error code if the checkout session encountered a technical error. Null if no error occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error message describing the technical failure that prevented checkout completion. Null if no error occurred.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Estimated delivery date presented to the customer at checkout based on selected shipping method.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftMessageIncluded rdf:type rdf:Property ;
    rdfs:label 'Gift Message Included' ;
    rdfs:comment 'Indicates whether the customer included a gift message with the order during checkout.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the customer during checkout. Zero if no points used.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingConsentCaptured rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Captured' ;
    rdfs:comment 'Indicates whether the customer provided opt-in consent for marketing communications during checkout.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFailureReason rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Reason' ;
    rdfs:comment 'Reason code or description for payment authorization failure if payment was declined. Null if payment succeeded or was not attempted.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'Payment gateway provider used to process the transaction (e.g., Stripe, Adyen, PayPal, Authorize.Net).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment method used or selected during checkout. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|store_credit|buy_now_pay_later — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeApplied rdf:type rdf:Property ;
    rdfs:label 'Promo Code Applied' ;
    rdfs:comment 'Promotional code entered and applied by the customer during checkout. Null if no promo code used.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionToken rdf:type rdf:Property ;
    rdfs:label 'Session Token' ;
    rdfs:comment 'Unique session token generated by Salesforce Commerce Cloud to track the checkout session across steps.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethodSelected rdf:type rdf:Property ;
    rdfs:label 'Shipping Method Selected' ;
    rdfs:comment 'The shipping method chosen by the customer during checkout.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepsCompleted rdf:type rdf:Property ;
    rdfs:label 'Steps Completed' ;
    rdfs:comment 'Comma-separated list of checkout steps completed by the customer (e.g., address_entry, shipping_selection, payment_entry, order_review).' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionalConsentCaptured rdf:type rdf:Property ;
    rdfs:label 'Transactional Consent Captured' ;
    rdfs:comment 'Indicates whether the customer provided consent for transactional communications (order updates, shipping notifications) during checkout.' ;
    rdfs:domain ind:CheckoutSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalOrderId rdf:type rdf:Property ;
    rdfs:label 'Digital Order Id' ;
    rdfs:comment 'Unique identifier for the digital order placed through the DTC e-commerce channel. Primary key for this entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalOrder .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Digital orders generate AR invoices for revenue recognition, receivables tracking, and financial reporting. Essential for order-to-cash process and revenue reconciliation in apparel e-commerce operati' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:assignedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Assigned Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Orders track assigned carrier for shipment execution, customer tracking notifications, delivery performance monitoring, and carrier cost reconciliation. Fundamental to order fulfillment operations and' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:financePaymentId rdf:type rdf:Property ;
    rdfs:label 'Finance Payment Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_payment. Business justification: Links customer payments to orders for cash application, AR clearing, and payment reconciliation. Critical for order-to-cash cycle completion and accounts receivable management in e-commerce.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancePayment .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Digital channel interface through which the order was placed. Distinguishes between web browser, native mobile app, progressive web app, social commerce, or third-party marketplace.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Email' ;
    rdfs:comment 'Email address provided by the customer for order confirmation and shipping notifications. Required for guest checkout orders.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Notes' ;
    rdfs:comment 'Special delivery instructions or comments provided by the customer at checkout. Communicated to fulfillment and carrier.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Phone' ;
    rdfs:comment 'Phone number provided by the customer for delivery coordination and order updates. May be used by carrier for delivery notifications.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'Status of manual or automated fraud review for this order. Orders flagged for fraud may be held pending investigation.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'Method by which the order will be delivered to the customer. Supports omnichannel fulfillment options.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of order fulfillment operations. Tracks warehouse and logistics progression independent of payment status. [ENUM-REF-CANDIDATE: pending|allocated|picked|packed|shipped|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Grand Total Amount' ;
    rdfs:comment 'Final total amount charged to the customer. Calculated as subtotal minus discounts plus shipping plus tax.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Indicates whether this order was marked as a gift by the customer. Triggers gift wrapping and receipt exclusion.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestCheckout rdf:type rdf:Property ;
    rdfs:label 'Is Guest Checkout' ;
    rdfs:comment 'Indicates whether the order was placed by a guest user without creating an account. Impacts customer acquisition tracking.' ;
    rdfs:domain ind:DigitalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty program points earned by the customer for this purchase. Supports CLTV and retention programs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Internal notes or special instructions added by customer service representatives or automated systems regarding order handling.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Customer-facing order confirmation number displayed in order confirmation emails and customer account portal. Externally-known business identifier for this transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the digital order in the fulfillment workflow. Tracks progression from placement through delivery or cancellation. [ENUM-REF-CANDIDATE: pending|confirmed|processing|shipped|delivered|cancelled|refunded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment processing for this order. Tracks authorization, capture, and refund lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placed Timestamp' ;
    rdfs:comment 'Exact date and time when the customer completed checkout and placed the order. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or coupon code applied by the customer at checkout. Used for discount attribution and campaign tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page or external site that referred the customer to the storefront. Supports marketing attribution and channel analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Digital Order Line Id' ;
    rdfs:comment 'Unique identifier for the digital order line item. Primary key for this entity.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Cogs Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.cogs_entry. Business justification: Each line item sold requires COGS recognition for gross margin calculation, P&L reporting, and inventory valuation. Core requirement for financial close and profitability analysis by product/channel.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: Order lines require inspection linkage for quality-gated fulfillment decisions (hold shipment if inspection failed), customer service escalations when post-shipment defects are reported, and supplier ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:qualityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_certification. Business justification: Order lines for certified products (organic, fair trade) require certification references for customs documentation, customer claim verification, and regulatory audit trails. Supports certificate numb' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCertification .

ind:traceabilityRecordId rdf:type rdf:Property ;
    rdfs:label 'Traceability Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.traceability_record. Business justification: Connects sold items to supply chain traceability data for post-sale transparency (QR codes on receipts, blockchain verification apps). Real business need: premium brands provide customers with blockch' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TraceabilityRecord .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Reference to the warehouse or distribution center assigned to fulfill this line. Null if not yet allocated.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date this line item was shipped. Null if not yet shipped. Used for OTIF measurement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this line item is on backorder due to insufficient inventory at order time. True if backordered.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Reference to the brand of the product on this line. Supports multi-brand DTC operations and brand performance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of goods sold for this line item. Quantity ordered multiplied by unit cost. Confidential financial data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorway rdf:type rdf:Property ;
    rdfs:label 'Colorway' ;
    rdfs:comment 'The color variant of the style ordered. Industry-standard term for color option in apparel.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftWrapCharge rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Charge' ;
    rdfs:comment 'Additional charge for gift wrapping service on this line. Zero if gift wrap was not selected or was complimentary.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total discount applied to this line item. Sum of all promotional and markdown discounts for the line.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the digital order. Determines the display and processing order of line items.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Subtotal for this line before tax. Calculated as (unit_selling_price * quantity_ordered) - line_discount_amount.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'Tax amount applied to this line item. Calculated based on tax jurisdiction and product tax category.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Total amount for this line including tax. Calculated as line_subtotal + line_tax_amount. Contributes to order total.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownCode rdf:type rdf:Property ;
    rdfs:label 'Markdown Code' ;
    rdfs:comment 'Code identifying the markdown reason or campaign applied to this line. Used for markdown tracking and analysis.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationCharge rdf:type rdf:Property ;
    rdfs:label 'Personalization Charge' ;
    rdfs:comment 'Additional charge for personalization service on this line. Zero if personalization was not selected or was complimentary.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalizationText rdf:type rdf:Property ;
    rdfs:label 'Personalization Text' ;
    rdfs:comment 'Custom text for product personalization (e.g., monogram, embroidery). Confidential customer specification.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The number of units of this SKU ordered on this line. Used for inventory allocation and revenue calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Return Eligible Flag' ;
    rdfs:comment 'Indicates whether this line item is eligible for return per business policy. False for final sale or non-returnable items.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from delivery within which this line can be returned. Null if not return eligible.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue for this line item is recognized per accounting policy. Typically ship date or delivery date.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'The size of the item ordered (e.g., XS, S, M, L, XL, or numeric sizing). Captured as ordered by customer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitMsrp rdf:type rdf:Property ;
    rdfs:label 'Unit Msrp' ;
    rdfs:comment 'The manufacturers suggested retail price per unit at the time of order. Used for markdown analysis and pricing strategy.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'The actual selling price per unit charged to the customer. May differ from MSRP due to promotions or markdowns.' ;
    rdfs:domain ind:DigitalOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Digital Payment Id' ;
    rdfs:comment 'Unique identifier for the digital payment transaction. Primary key for the digital payment entity.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment gateway or issuing bank confirming approval of the transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the payment was authorized by the payment gateway or issuing bank.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'Address Verification System result code returned by the payment processor indicating the match status of billing address components.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province component of the billing address associated with the payment method.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Date and time when the authorized payment was captured and funds were committed for settlement.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card used in the transaction, stored for validation and retry logic.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card used in the transaction, stored for validation and retry logic.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Card Last Four Digits' ;
    rdfs:comment 'Last four digits of the payment card number used for customer reference and reconciliation purposes without exposing full card details.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Customer Ip Address' ;
    rdfs:comment 'Internet Protocol address of the customer device at the time of payment submission, used for fraud detection and geographic analysis.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'Card Verification Value result code indicating whether the CVV provided matched the card issuer records.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Code provided by the payment gateway or issuing bank indicating the reason for payment decline or failure.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Description' ;
    rdfs:comment 'Human-readable description of the reason why the payment was declined or failed, used for customer communication and root-cause analysis.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique identifier or hash representing the customer\'s device characteristics, used for fraud detection and device recognition.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Fraud Screening Result' ;
    rdfs:comment 'Outcome of the fraud detection screening process indicating whether the transaction passed, failed, or requires manual review.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway for tracking and reconciliation with external systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Total number of installments for Buy Now Pay Later or installment payment plans, if applicable.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentPlanEnabled rdf:type rdf:Property ;
    rdfs:label 'Installment Plan Enabled' ;
    rdfs:comment 'Indicates whether this payment is part of an installment or Buy Now Pay Later plan.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The total monetary amount processed in this payment transaction, representing the gross payment value before any adjustments.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The digital interface or channel through which the payment was initiated, such as web storefront, mobile app, or call center.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Token' ;
    rdfs:comment 'Tokenized representation of the payment method provided by the payment gateway for secure storage and future transactions without exposing sensitive card data.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the payment gateway or processor for handling this transaction, used for cost analysis and reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed and initiated back to the customer\'s payment method.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the payment was settled and funds were transferred to the merchant account.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'Status of 3D Secure authentication indicating whether the cardholder was successfully authenticated through the issuer\'s authentication process.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally visible unique transaction identifier provided by the payment gateway or internal system for tracking and reconciliation purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalReturnId rdf:type rdf:Property ;
    rdfs:label 'Digital Return Id' ;
    rdfs:comment 'Unique identifier for the digital return request. Primary key for the digital return entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalReturn .

ind:defectId rdf:type rdf:Property ;
    rdfs:label 'Defect Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_defect. Business justification: Returns must link to standardized defect codes for root cause analysis, supplier scorecarding, and defect trend reporting. Maps customer return reasons to quality defect taxonomy, enabling cost-of-qua' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Defect .

ind:nonConformanceId rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Id' ;
    rdfs:comment 'Foreign key linking to quality.non_conformance. Business justification: Customer returns often generate formal NCRs when return reason codes indicate quality failures (defective, not as described). Links return claims to supplier corrective action plans, quality scorecard' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonConformance .

ind:primaryDigitalSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Digital Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order from which this return originated.' ;
    rdfs:domain ind:DigitalReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:salesOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Id' ;
    rdfs:comment 'Reference to the specific order line item being returned.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrderLine .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
