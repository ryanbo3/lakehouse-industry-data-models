ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Executive summary or key highlights from the audit report. Provides high-level overview of audit findings, strengths, and areas for improvement. Confidential business information.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created the audit record in the system. Part of audit trail for accountability and data governance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the compliance audit finding record. Primary key for the compliance audit finding entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
