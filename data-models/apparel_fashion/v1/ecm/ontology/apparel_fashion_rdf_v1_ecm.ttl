    rdfs:comment 'Unique identifier for the restricted substance record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RestrictedSubstance .

ind:alternativeSubstanceRecommendation rdf:type rdf:Property ;
