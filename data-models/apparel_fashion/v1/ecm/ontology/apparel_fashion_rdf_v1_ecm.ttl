ind:pickingMethod rdf:type rdf:Property ;
    rdfs:label 'Picking Method' ;
    rdfs:comment 'Method used for order picking operations within the zone (e.g., manual, voice-directed, pick-to-light, automated).' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority ranking for inventory replenishment operations, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the zone indicating access control requirements and monitoring level.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Physical storage method or infrastructure used within the zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature for the zone in degrees Celsius, applicable for temperature-controlled zones.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature for the zone in degrees Celsius, applicable for temperature-controlled zones.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCategory rdf:type rdf:Property ;
    rdfs:label 'Zone Category' ;
    rdfs:comment 'Storage environment or handling category for the zone, indicating special requirements or conditions.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the zone (e.g., Receiving Zone, Picking Area A, Packing Station 1).' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current operational status of the zone indicating availability for inventory operations.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Functional classification of the zone indicating its primary operational purpose within the warehouse or distribution center.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'The general ledger account number to which inventory value in this valuation area is posted for financial reporting.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAccountDeterminationGroup rdf:type rdf:Property ;
    rdfs:label 'Inventory Account Determination Group' ;
    rdfs:comment 'The account determination group used to automatically assign GL accounts for inventory transactions within this valuation area.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
