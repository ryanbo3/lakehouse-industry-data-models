    rdfs:comment 'Current lifecycle status of the return request in the DTC after-sales workflow. [ENUM-REF-CANDIDATE: requested|approved|rejected|shipped|received|inspected|refunded|completed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
