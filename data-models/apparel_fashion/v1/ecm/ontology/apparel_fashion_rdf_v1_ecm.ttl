ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the sales organization by business model or channel type.' ;
    rdfs:domain ind:SalesOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrasionResistance rdf:type rdf:Property ;
    rdfs:label 'Abrasion Resistance' ;
    rdfs:comment 'The fabric\'s durability against surface wear from friction and rubbing.' ;
