ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'The timestamp when this fiscal week record became effective and active for business use.' ;
    rdfs:domain ind:FiscalWeek ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective To Timestamp' ;
    rdfs:comment 'The timestamp when this fiscal week record ceased to be effective, null if currently active.' ;
