    rdfs:domain ind:BudgetPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The date printed on physical paychecks or used as the effective date for direct deposits.' ;
