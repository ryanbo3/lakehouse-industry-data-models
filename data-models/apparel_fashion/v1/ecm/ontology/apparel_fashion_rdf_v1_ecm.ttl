    rdfs:range xsd:string .

ind:storefrontName rdf:type rdf:Property ;
    rdfs:label 'Storefront Name' ;
    rdfs:comment 'Human-readable name of the digital storefront (e.g., \'Apparel Fashion US\', \'Outlet Store EU\').' ;
    rdfs:domain ind:DigitalStorefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontType rdf:type rdf:Property ;
    rdfs:label 'Storefront Type' ;
    rdfs:comment 'Business classification of the storefront purpose (flagship brand site, regional site, outlet microsite, seasonal campaign site).' ;
    rdfs:domain ind:DigitalStorefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productReviewId rdf:type rdf:Property ;
    rdfs:label 'Product Review Id' ;
    rdfs:comment 'Unique identifier for the product review record. Primary key.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRange rdf:type rdf:Property ;
    rdfs:label 'Age Range' ;
    rdfs:comment 'Age bracket of the reviewer, optionally provided to help other customers assess relevance of the review. [ENUM-REF-CANDIDATE: under_18|18_24|25_34|35_44|45_54|55_64|65_plus — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyType rdf:type rdf:Property ;
    rdfs:label 'Body Type' ;
    rdfs:comment 'Self-reported body type of the reviewer, optionally provided to help other customers with similar body types assess fit.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandResponseText rdf:type rdf:Property ;
    rdfs:label 'Brand Response Text' ;
    rdfs:comment 'Official response from the brand or customer service team addressing the customer\'s review, feedback, or concerns.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Brand Response Timestamp' ;
    rdfs:comment 'Date and time when the brand published their response to the customer review.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:colorPurchased rdf:type rdf:Property ;
    rdfs:label 'Color Purchased' ;
    rdfs:comment 'The color variant of the product that the customer purchased and is reviewing. Helps identify color-specific quality issues.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comfortRating rdf:type rdf:Property ;
    rdfs:label 'Comfort Rating' ;
    rdfs:comment 'Customer rating of the product\'s comfort and wearability on a scale of 1 to 5. Critical metric for apparel and footwear.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fitRating rdf:type rdf:Property ;
    rdfs:label 'Fit Rating' ;
    rdfs:comment 'Customer assessment of how the apparel item fits relative to standard sizing expectations. Critical for apparel purchase decisions.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpfulVotesCount rdf:type rdf:Property ;
    rdfs:label 'Helpful Votes Count' ;
    rdfs:comment 'Number of customers who marked this review as helpful. Used to surface most useful reviews and calculate review quality scores.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive provided to the customer for submitting the review, if applicable. Required for transparency and regulatory compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentivizedReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Incentivized Review Flag' ;
    rdfs:comment 'Indicates whether the customer received an incentive (discount, loyalty points, free product) for submitting the review. Required for FTC compliance.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Media Attachment Count' ;
    rdfs:comment 'Number of photos or videos attached to the review by the customer. Reviews with media typically receive higher engagement.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moderationReason rdf:type rdf:Property ;
    rdfs:label 'Moderation Reason' ;
    rdfs:comment 'Explanation or reason code for rejection or flagging of the review, such as inappropriate content, spam, or policy violation.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationStatus rdf:type rdf:Property ;
    rdfs:label 'Moderation Status' ;
    rdfs:comment 'Current moderation workflow state of the review. Pending indicates awaiting review, approved means published, rejected means not published, flagged indicates requiring additional review.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Moderation Timestamp' ;
    rdfs:comment 'Date and time when the review moderation decision was made by the content moderation team or automated system.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Indicates whether the review is currently visible on the public-facing digital storefront. True if published, False if hidden or unpublished.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the review was first made visible on the digital storefront after moderation approval.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Customer rating of product quality on a scale of 1 to 5, assessing materials, construction, and craftsmanship.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendFlag rdf:type rdf:Property ;
    rdfs:label 'Recommend Flag' ;
    rdfs:comment 'Indicates whether the customer would recommend this product to others. True if yes, False if no. Contributes to Net Promoter Score (NPS) calculation.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewBody rdf:type rdf:Property ;
    rdfs:label 'Review Body' ;
    rdfs:comment 'Full text content of the customer\'s product review, containing detailed feedback, opinions, and experiences.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Review Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the review was written.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Review Source Channel' ;
    rdfs:comment 'The digital channel or touchpoint through which the customer submitted the review.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTitle rdf:type rdf:Property ;
    rdfs:label 'Review Title' ;
    rdfs:comment 'Short headline or title summarizing the customer\'s review, displayed prominently on the product page.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerDisplayName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Display Name' ;
    rdfs:comment 'Public display name or pseudonym of the reviewer shown on the product page. May be customer\'s actual name or chosen alias.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerLocation rdf:type rdf:Property ;
    rdfs:label 'Reviewer Location' ;
    rdfs:comment 'Geographic location of the reviewer, typically city and state or country, displayed to provide context for the review.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizePurchased rdf:type rdf:Property ;
    rdfs:label 'Size Purchased' ;
    rdfs:comment 'The size variant of the product that the customer purchased and is reviewing. Provides context for fit feedback.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleRating rdf:type rdf:Property ;
    rdfs:label 'Style Rating' ;
    rdfs:comment 'Customer rating of the product\'s style and aesthetic appeal on a scale of 1 to 5. Specific to fashion and apparel products.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the customer submitted the product review to the digital storefront.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unhelpfulVotesCount rdf:type rdf:Property ;
    rdfs:label 'Unhelpful Votes Count' ;
    rdfs:comment 'Number of customers who marked this review as not helpful. Used for review quality assessment and ranking algorithms.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueRating rdf:type rdf:Property ;
    rdfs:label 'Value Rating' ;
    rdfs:comment 'Customer assessment of product value for money on a scale of 1 to 5, comparing price paid to perceived quality and utility.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedPurchaseFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Purchase Flag' ;
    rdfs:comment 'Indicates whether the review is from a verified purchase transaction. True if the reviewer purchased the product through the platform, False otherwise.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendationId rdf:type rdf:Property ;
    rdfs:label 'Recommendation Id' ;
    rdfs:comment 'Unique identifier for the product recommendation event. Primary key.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addToCartFlag rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Flag' ;
    rdfs:comment 'Indicates whether any recommended product was added to the shopping cart.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addedToCartSku rdf:type rdf:Property ;
    rdfs:label 'Added To Cart Sku' ;
    rdfs:comment 'The specific SKU from the recommendation set that was added to the cart.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'Type of recommendation algorithm used to generate the product suggestions.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version identifier of the recommendation algorithm used.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickFlag rdf:type rdf:Property ;
    rdfs:label 'Click Flag' ;
    rdfs:comment 'Indicates whether the customer clicked on any of the recommended products.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Click Timestamp' ;
    rdfs:comment 'Date and time when the customer clicked on a recommended product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clickedSku rdf:type rdf:Property ;
    rdfs:label 'Clicked Sku' ;
    rdfs:comment 'The specific SKU that was clicked by the customer from the recommendation set.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the recommended product was purchased.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:convertedSku rdf:type rdf:Property ;
    rdfs:label 'Converted Sku' ;
    rdfs:comment 'The specific SKU from the recommendation set that was purchased.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionFlag rdf:type rdf:Property ;
    rdfs:label 'Impression Flag' ;
    rdfs:comment 'Indicates whether the recommendation was actually displayed to the customer (true) or generated but not rendered (false).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Location or context where the recommendation was displayed to the customer. [ENUM-REF-CANDIDATE: homepage|product_detail_page|cart|checkout|category_page|search_results|email|mobile_app — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySku rdf:type rdf:Property ;
    rdfs:label 'Primary Sku' ;
    rdfs:comment 'The anchor or context SKU that triggered the recommendation (e.g., the product being viewed when recommendations were shown).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationSource rdf:type rdf:Property ;
    rdfs:label 'Recommendation Source' ;
    rdfs:comment 'Source system or service that generated the recommendation (e.g., Adobe Target, internal ML service).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current status of the recommendation event.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recommendation Timestamp' ;
    rdfs:comment 'Date and time when the recommendation was generated and served to the customer.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recommendedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Recommended Sku Count' ;
    rdfs:comment 'Total number of SKUs included in the recommendation set.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedSkuList rdf:type rdf:Property ;
    rdfs:label 'Recommended Sku List' ;
    rdfs:comment 'Comma-separated list of SKU codes that were recommended to the customer in display order.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total revenue generated from the purchase of recommended products in this recommendation event.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategy rdf:type rdf:Property ;
    rdfs:label 'Strategy' ;
    rdfs:comment 'Business strategy or campaign name associated with the recommendation (e.g., cross-sell, upsell, complete-the-look, frequently-bought-together).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToClickSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Click Seconds' ;
    rdfs:comment 'Number of seconds elapsed between recommendation display and customer click.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToConversionSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Seconds' ;
    rdfs:comment 'Number of seconds elapsed between recommendation display and purchase conversion.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchQueryId rdf:type rdf:Property ;
    rdfs:label 'Search Query Id' ;
    rdfs:comment 'Unique identifier for the search query event. Primary key for the search query product.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingRuleId rdf:type rdf:Property ;
    rdfs:label 'Merchandising Rule Id' ;
    rdfs:comment 'The identifier of the merchandising rule applied to this search query if any rule was triggered.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandisingRule .

ind:autocompleteSuggestionCount rdf:type rdf:Property ;
    rdfs:label 'Autocomplete Suggestion Count' ;
    rdfs:comment 'The number of autocomplete suggestions displayed to the shopper as they typed the search term.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Click Through Flag' ;
    rdfs:comment 'Indicates whether the shopper clicked on at least one product from the search results page.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickThroughPosition rdf:type rdf:Property ;
    rdfs:label 'Click Through Position' ;
    rdfs:comment 'The position rank of the first product clicked by the shopper in the search results list. Null if no click occurred.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctedSearchTerm rdf:type rdf:Property ;
    rdfs:label 'Corrected Search Term' ;
    rdfs:comment 'The spell-corrected version of the search term if automatic correction was applied. Null if no correction occurred.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingRuleAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchandising Rule Applied Flag' ;
    rdfs:comment 'Indicates whether any merchandising rules such as boosting, burying, or pinning were applied to influence search result ranking.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalizedSearchTerm rdf:type rdf:Property ;
    rdfs:label 'Normalized Search Term' ;
    rdfs:comment 'The search term after normalization processing including lowercasing, stemming, and synonym expansion for analytics consistency.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nullResultFlag rdf:type rdf:Property ;
    rdfs:label 'Null Result Flag' ;
    rdfs:comment 'Indicates whether the search query returned zero results, signaling a merchandising gap or catalog coverage issue.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageNumber rdf:type rdf:Property ;
    rdfs:label 'Page Number' ;
    rdfs:comment 'The deepest results page number viewed by the shopper during this search session.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Applied Flag' ;
    rdfs:comment 'Indicates whether search results were personalized based on customer profile, browsing history, or segment membership.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refinementAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Refinement Applied Flag' ;
    rdfs:comment 'Indicates whether the shopper applied any filters or refinements such as size, color, price range, or brand after the initial search.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refinementCount rdf:type rdf:Property ;
    rdfs:label 'Refinement Count' ;
    rdfs:comment 'The number of refinement filters applied by the shopper to narrow search results.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultsCount rdf:type rdf:Property ;
    rdfs:label 'Results Count' ;
    rdfs:comment 'The total number of product results returned by the search query.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultsViewedCount rdf:type rdf:Property ;
    rdfs:label 'Results Viewed Count' ;
    rdfs:comment 'The total number of individual product results viewed by the shopper across all pages during this search session.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Search Duration Seconds' ;
    rdfs:comment 'The time in seconds the shopper spent on search results pages before exiting or converting.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchExitType rdf:type rdf:Property ;
    rdfs:label 'Search Exit Type' ;
    rdfs:comment 'The action taken by the shopper to exit the search results: clicked a product, navigated to category, performed new search, exited site, went to cart, or proceeded to checkout.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchMethod rdf:type rdf:Property ;
    rdfs:label 'Search Method' ;
    rdfs:comment 'How the search term was entered: manually typed, selected from autocomplete, clicked from suggested searches, selected from recent searches, or clicked from trending searches.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Search Revenue Amount' ;
    rdfs:comment 'The total revenue attributed to this search query if a conversion occurred within the session.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchSource rdf:type rdf:Property ;
    rdfs:label 'Search Source' ;
    rdfs:comment 'The page or interface location where the search was initiated: header search box, landing page, category page, product page, no-results page, or mobile app search.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchTerm rdf:type rdf:Property ;
    rdfs:label 'Search Term' ;
    rdfs:comment 'The raw search query text entered by the shopper in the search box.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Search Timestamp' ;
    rdfs:comment 'The exact date and time when the search query was executed by the shopper.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:searchType rdf:type rdf:Property ;
    rdfs:label 'Search Type' ;
    rdfs:comment 'The type of search performed: keyword text search, category browse, brand filter, attribute filter, voice search, visual search, or barcode scan. [ENUM-REF-CANDIDATE: keyword|category|brand|attribute|voice|visual|barcode — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOption rdf:type rdf:Property ;
    rdfs:label 'Sort Option' ;
    rdfs:comment 'The sorting method selected by the shopper to order search results: relevance, price ascending, price descending, newest arrivals, bestsellers, highest rating, or highest discount. [ENUM-REF-CANDIDATE: relevance|price_low_high|price_high_low|newest|bestseller|rating|discount — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spellCorrectionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Spell Correction Applied Flag' ;
    rdfs:comment 'Indicates whether the search engine applied automatic spell correction to the original search term.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:synonymExpansionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Synonym Expansion Applied Flag' ;
    rdfs:comment 'Indicates whether the search engine expanded the query using configured synonym rules to broaden results.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchandiserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Merchandiser Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Catalogs are curated by merchandising employees who manage assortment, pricing, and publication workflows. Links enable workload tracking, approval routing, and performance measurement for catalog man' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentCatalogSiteCatalogId rdf:type rdf:Property ;
    rdfs:label 'Parent Catalog Site Catalog Id' ;
    rdfs:comment 'Reference to a parent catalog if this catalog is a subset or variant. Nullable for top-level catalogs. Enables catalog inheritance and hierarchical merchandising.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteCatalog .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'The date when this catalog becomes visible and shoppable on the storefront. Part of the catalog\'s effective date range.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeSkuCount rdf:type rdf:Property ;
    rdfs:label 'Active Sku Count' ;
    rdfs:comment 'The number of SKUs currently active and available for purchase within this catalog. Subset of total SKU count, excluding out-of-stock or discontinued items.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'The date when this catalog is no longer visible on the storefront. Nullable for catalogs with no planned end date (evergreen catalogs).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when this catalog was approved for publication. Nullable if not yet approved.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:catalogCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Code' ;
    rdfs:comment 'Unique business identifier code for the catalog used in system integrations and reporting.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogDescription rdf:type rdf:Property ;
    rdfs:label 'Catalog Description' ;
    rdfs:comment 'Detailed business description of the catalog\'s purpose, target audience, and merchandising strategy. Used for internal planning and external marketing copy.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogName rdf:type rdf:Property ;
    rdfs:label 'Catalog Name' ;
    rdfs:comment 'Business name of the catalog (e.g., Spring 2024 Collection, Outlet Clearance, Holiday Gift Guide).' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogPriority rdf:type rdf:Property ;
    rdfs:label 'Catalog Priority' ;
    rdfs:comment 'Numeric priority ranking used when multiple catalogs are active on the same storefront. Higher values take precedence for product display and search ranking.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catalogType rdf:type rdf:Property ;
    rdfs:label 'Catalog Type' ;
    rdfs:comment 'Classification of the catalog by merchandising strategy: seasonal (time-bound collection), evergreen (year-round core), outlet (clearance), promotional (campaign-driven), exclusive (member-only), or limited edition (special release).' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this catalog is available (e.g., USA,CAN,MEX). Empty for global catalogs.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLocale rdf:type rdf:Property ;
    rdfs:label 'Default Locale' ;
    rdfs:comment 'The primary language and region locale for this catalog (e.g., en_US, fr_FR, de_DE). Determines default product names, descriptions, and pricing display.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCatalogReference rdf:type rdf:Property ;
    rdfs:label 'External Catalog Reference' ;
    rdfs:comment 'The catalog identifier from an external system (e.g., Oracle Retail, legacy PLM). Used for system integration and data lineage tracking.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingTheme rdf:type rdf:Property ;
    rdfs:label 'Merchandising Theme' ;
    rdfs:comment 'The creative or marketing theme for this catalog (e.g., Summer Essentials, Back to School, Holiday Gift Guide, Sustainability Collection). Used for site merchandising and campaign alignment.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible Flag' ;
    rdfs:comment 'Indicates whether products in this catalog are eligible for promotional discounts and offers. False for outlet or already-discounted catalogs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the catalog: draft (being prepared), scheduled (approved for future publication), published (live and shoppable), suspended (temporarily hidden), or archived (no longer active).' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchIndexingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Search Indexing Enabled Flag' ;
    rdfs:comment 'Indicates whether products in this catalog are included in site search results. May be disabled for exclusive or hidden catalogs.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seoEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Seo Enabled Flag' ;
    rdfs:comment 'Indicates whether products in this catalog are indexed by external search engines (Google, Bing). Disabled for member-only or pre-launch catalogs.' ;
    rdfs:domain ind:SiteCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'The total number of unique SKUs included in this catalog. Used for catalog size tracking and assortment breadth analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitePromotionId rdf:type rdf:Property ;
    rdfs:label 'Site Promotion Id' ;
    rdfs:comment 'Unique identifier for the site promotion record. Primary key for the site_promotion data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SitePromotion .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_line. Business justification: Promotional discounts and campaigns must be tracked against marketing budgets for spend control, ROI analysis, and budget variance reporting. Essential for promotional effectiveness and financial plan' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:qualifyingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Qualifying Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Promotions may offer free or discounted shipping with specific carriers (e.g., "Free 2-day FedEx shipping"). Required for promotion eligibility validation, checkout display logic, and carrier cost all' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:applicableCategoryList rdf:type rdf:Property ;
    rdfs:label 'Applicable Category List' ;
    rdfs:comment 'Comma-separated list of product category codes eligible for this promotion. Null if promotion applies to specific SKUs or all products.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSkuList rdf:type rdf:Property ;
    rdfs:label 'Applicable Sku List' ;
    rdfs:comment 'Comma-separated list of SKU codes eligible for this promotion. Null if promotion applies to all products or is category-based.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether the promotion is automatically applied to eligible carts without requiring a promo code entry. True if auto-applied, False if code entry required.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelRestriction rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction' ;
    rdfs:comment 'Digital channel where this promotion is valid. Restricts redemption to specific customer touchpoints.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Code' ;
    rdfs:comment 'Code identifying the customer segment eligible for this promotion (e.g., VIP, loyalty tier, new customer). Null if promotion is available to all customers.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied when promotion type is percentage_off. Null for non-percentage promotions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayMessage rdf:type rdf:Property ;
    rdfs:label 'Display Message' ;
    rdfs:comment 'Customer-facing promotional message displayed on the storefront, cart, or checkout pages to communicate the offer.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionSkuList rdf:type rdf:Property ;
    rdfs:label 'Exclusion Sku List' ;
    rdfs:comment 'Comma-separated list of SKU codes explicitly excluded from this promotion even if they match category or general eligibility rules.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount' ;
    rdfs:comment 'Cap on the total discount value that can be applied in a single transaction, typically used with percentage-based promotions. Null if no cap applies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum cart subtotal required for the promotion to be eligible for redemption. Null if no minimum threshold applies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCount rdf:type rdf:Property ;
    rdfs:label 'Order Count' ;
    rdfs:comment 'Total number of distinct orders that included this promotion.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Business-friendly name of the promotion for internal reference and customer display.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion indicating whether it is available for customer redemption.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Category of discount mechanism applied by this promotion. [ENUM-REF-CANDIDATE: percentage_off|fixed_amount|bogo|free_shipping|bundle|loyalty_point_redemption|tiered_member_pricing|gift_with_purchase|volume_discount — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Total number of times this promotion has been successfully redeemed by customers to date.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'Total monetary value of discounts granted through this promotion to date, representing the revenue reduction attributable to the promotion.' ;
    rdfs:domain ind:SitePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promotion can be combined with other promotions in a single transaction. True if stackable, False if exclusive.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal and business terms governing the use of this promotion, including restrictions, exclusions, and customer obligations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this promotion. Null for unlimited per-customer usage.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Total' ;
    rdfs:comment 'Maximum number of times this promotion can be redeemed across all customers. Null for unlimited usage.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecommerceStorefrontAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Storefront Availability Id' ;
    rdfs:comment 'Unique identifier for the storefront availability record. Primary key for this entity.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Distribution Center Id' ;
    rdfs:comment 'Identifier for the primary warehouse or distribution center that will fulfill orders for this SKU on this storefront.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:qualityHoldId rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_hold. Business justification: Inventory availability must respect quality holds to prevent sale of non-conforming goods. Quality hold status drives WMS inventory blocks, ATP calculation exclusions, and storefront suppression flags' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityHold .

ind:sourceDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Storefront availability records source inventory from specific DCs for ATP calculation and regional stock display. Critical for accurate online inventory visibility and preventing overselling in omnic' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority ranking for inventory allocation to this storefront when inventory is constrained across multiple channels.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'Quantity of the SKU that can be promised to customers for future delivery, accounting for committed inventory and inbound supply.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Availability Change Timestamp' ;
    rdfs:comment 'Timestamp when the availability status last changed. Used for tracking availability transitions and triggering notifications.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availabilityMessage rdf:type rdf:Property ;
    rdfs:label 'Availability Message' ;
    rdfs:comment 'Customer-facing message describing the current availability status of the SKU, such as in stock, low stock, or out of stock messaging.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of the SKU on the digital storefront. Determines shopper visibility, listing suppression, and checkout eligibility.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity of the SKU available for purchase on this storefront. Represents the Available-to-Sell (ATS) quantity visible to shoppers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backInStockNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Back In Stock Notification Enabled' ;
    rdfs:comment 'Indicates whether back-in-stock notifications are enabled for this SKU. When true, customers can subscribe to restock alerts.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backorderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Eligible Flag' ;
    rdfs:comment 'Indicates whether the SKU is eligible for backorder when out of stock. When true, customers can place orders for future fulfillment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backorderEta rdf:type rdf:Property ;
    rdfs:label 'Backorder Eta' ;
    rdfs:comment 'Estimated date when backordered SKUs will be available for fulfillment. Used for backorder messaging and customer expectations.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderMessage rdf:type rdf:Property ;
    rdfs:label 'Backorder Message' ;
    rdfs:comment 'Customer-facing message displayed when the SKU is on backorder, providing estimated availability and fulfillment expectations.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Display Availability Flag' ;
    rdfs:comment 'Indicates whether availability information should be displayed to shoppers on the product detail page. When false, availability is hidden.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventorySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Inventory Source System' ;
    rdfs:comment 'Name of the source system providing inventory data for this availability record, such as WMS, ERP, or OMS.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInventorySyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful inventory synchronization from the warehouse management system to the digital storefront.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Notification Subscriber Count' ;
    rdfs:comment 'Number of customers subscribed to back-in-stock notifications for this SKU on this storefront. Used for demand forecasting.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perpetualFlag rdf:type rdf:Property ;
    rdfs:label 'Perpetual Flag' ;
    rdfs:comment 'Indicates whether this SKU is managed as perpetual inventory (always available) on the storefront, bypassing standard inventory checks.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preOrderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Order Eligible Flag' ;
    rdfs:comment 'Indicates whether the SKU is eligible for pre-order before official release. When true, customers can reserve the SKU for future delivery.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preOrderReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Pre Order Release Date' ;
    rdfs:comment 'Date when pre-ordered SKUs will be released and shipped to customers. Applicable only when availability status is pre-order.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Availability Status' ;
    rdfs:comment 'The availability status immediately before the most recent change. Used for availability change history and analytics.' ;
    rdfs:domain ind:EcommerceStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the SKU currently reserved in active shopping carts or pending orders, not yet available for new purchases.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockDate rdf:type rdf:Property ;
    rdfs:label 'Restock Date' ;
    rdfs:comment 'Expected date when the SKU will be restocked and available for purchase again. Used for back-in-stock notifications and customer communication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Minimum safety stock quantity maintained for this SKU on this storefront to prevent stockouts and maintain service levels.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addToCartCount rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Count' ;
    rdfs:comment 'Number of times the user added items to the shopping cart during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceFlag rdf:type rdf:Property ;
    rdfs:label 'Bounce Flag' ;
    rdfs:comment 'Indicates whether the session was a bounce (single page view with no interaction). True if bounce, False otherwise.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'Web browser used during the session (e.g., Chrome, Safari, Firefox, Edge).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version number of the web browser used during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Checkout Initiated Flag' ;
    rdfs:comment 'Indicates whether the user initiated the checkout process during the session. True if initiated, False otherwise.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cookieConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Status' ;
    rdfs:comment 'Status of the user\'s cookie consent during the session for GDPR and CCPA compliance.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'The last page URL visited by the user before ending the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City name derived from the session IP address geolocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'Three-letter ISO country code derived from the session IP address (e.g., USA, GBR, FRA).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'The first page URL visited by the user when entering the digital storefront in this session.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code representing the user\'s browser language preference (e.g., en, es, fr).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device used during the session (e.g., iOS, Android, Windows, macOS).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Operating System Version' ;
    rdfs:comment 'Version number of the operating system used during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViews rdf:type rdf:Property ;
    rdfs:label 'Page Views' ;
    rdfs:comment 'Total number of pages viewed during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productPageViews rdf:type rdf:Property ;
    rdfs:label 'Product Page Views' ;
    rdfs:comment 'Number of product detail pages viewed during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'The referring URL or source that directed the user to the digital storefront.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchQueryCount rdf:type rdf:Property ;
    rdfs:label 'Search Query Count' ;
    rdfs:comment 'Number of search queries performed by the user during the session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the session in seconds, calculated from start to end timestamp.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Timestamp when the web session ended or timed out. Null for active sessions.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionSourcePlatform rdf:type rdf:Property ;
    rdfs:label 'Session Source Platform' ;
    rdfs:comment 'The commerce platform or application that captured this session data (e.g., Salesforce Commerce Cloud).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Timestamp when the web session was initiated on the digital storefront.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the web session.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'UTM parameter used to differentiate similar content or links within the same campaign.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'UTM parameter identifying paid search keywords or terms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistId rdf:type rdf:Property ;
    rdfs:label 'Wishlist Id' ;
    rdfs:comment 'Unique identifier for the wishlist. Primary key.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backInStockAlertEnabled rdf:type rdf:Property ;
    rdfs:label 'Back In Stock Alert Enabled' ;
    rdfs:comment 'Indicates whether the customer wants to be notified when out-of-stock wishlist items become available.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Number of wishlist items that have been moved to cart or purchased.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultWishlistFlag rdf:type rdf:Property ;
    rdfs:label 'Default Wishlist Flag' ;
    rdfs:comment 'Indicates whether this is the customer\'s default wishlist for quick-add actions from product pages.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Timestamp when the wishlist was soft-deleted by the customer. Null if not deleted.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Target date for event-based wishlists (e.g., wedding date, birthday, holiday). Null for non-event wishlists.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastShareTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Share Timestamp' ;
    rdfs:comment 'Timestamp when the wishlist was most recently shared. Null if never shared.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastViewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Timestamp' ;
    rdfs:comment 'Timestamp when the customer last accessed or viewed this wishlist.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive notifications for price drops, back-in-stock alerts, or promotional offers on wishlist items.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDropAlertEnabled rdf:type rdf:Property ;
    rdfs:label 'Price Drop Alert Enabled' ;
    rdfs:comment 'Indicates whether the customer wants to be notified when any wishlist item price decreases.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Registry Completion Percentage' ;
    rdfs:comment 'For registry-type wishlists, the percentage of items that have been purchased by gift-givers. Null for non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareCount rdf:type rdf:Property ;
    rdfs:label 'Share Count' ;
    rdfs:comment 'Number of times the wishlist has been shared via social media, email, or direct link.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shareToken rdf:type rdf:Property ;
    rdfs:label 'Share Token' ;
    rdfs:comment 'Unique token embedded in the share URL for secure access control.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareUrl rdf:type rdf:Property ;
    rdfs:label 'Share Url' ;
    rdfs:comment 'Unique shareable URL for the wishlist when visibility is public or shared.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Digital channel through which the wishlist was originally created.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Sum of current prices for all items in the wishlist, in the storefront currency.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Total number of times the wishlist has been viewed by the owner or shared recipients.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Privacy setting for the wishlist: private (only owner), public (discoverable), or shared (accessible via link).' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistDescription rdf:type rdf:Property ;
    rdfs:label 'Wishlist Description' ;
    rdfs:comment 'Optional customer-provided description or notes about the wishlist purpose.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistName rdf:type rdf:Property ;
    rdfs:label 'Wishlist Name' ;
    rdfs:comment 'Customer-defined name for the wishlist (e.g., \'Summer Favorites\', \'Gift Ideas\', \'Wedding Registry\').' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistStatus rdf:type rdf:Property ;
    rdfs:label 'Wishlist Status' ;
    rdfs:comment 'Current lifecycle status of the wishlist: active (in use), archived (saved but inactive), or deleted (soft delete).' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistType rdf:type rdf:Property ;
    rdfs:label 'Wishlist Type' ;
    rdfs:comment 'Classification of wishlist purpose: standard (general), registry (wedding/baby), gift (gift ideas), favorites (saved items), seasonal (holiday/season-specific), or event (special occasion).' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record in SAP S/4HANA FI-AP.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:orderPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Order Purchase Order Id' ;
    rdfs:comment 'Identifier of the purchase order against which this invoice is matched in the three-way match process (PO/GR/IR).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderPurchaseOrder .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The user ID or name of the person who approved this invoice for payment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Recognition Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice is recognized as part of COGS for apparel sourcing and manufacturing costs.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the cash discount per payment terms.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert the invoice currency to the company code currency at the time of posting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year to which this invoice is assigned for EOM (End of Month) close and financial reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this invoice is assigned for financial reporting and period closing purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before any deductions, including all line items, freight, and other charges but before tax.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrsAccrualFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Accrual Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice has been accrued for IFRS financial reporting purposes prior to receipt of the vendor invoice.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'The business category of the invoice expense: raw materials, CMT (Cut Make Trim) services, freight, operating expenses, capital expenditure, or other.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. This is the principal business event timestamp for the invoice.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor-provided invoice number as printed on the invoice document. This is the external business identifier for the invoice.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow. [ENUM-REF-CANDIDATE: draft|posted|blocked|approved|paid|cancelled|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'The type of invoice document: standard invoice, credit memo (vendor refund), debit memo (additional charge), prepayment, or recurring invoice.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostFlag rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice contributes to landed cost (LDP) accounting for imported goods, including freight, duties, and customs charges.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The total amount payable to the vendor after applying all taxes, discounts, and adjustments. This is the final payment amount.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether payment for this invoice is currently blocked pending resolution of discrepancies or approval.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'The reason code or description explaining why payment is blocked (e.g., price variance, quantity variance, missing goods receipt, pending approval).' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which payment was made to the vendor. Null if invoice is unpaid.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The method by which payment will be made to the vendor (e.g., wire transfer, check, ACH, EFT, letter of credit).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number assigned when payment is made, linking the invoice to the payment transaction for reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date the invoice was posted to the general ledger in SAP S/4HANA FI. Used for period assignment and financial reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order (PO), goods receipt (GR), and invoice receipt (IR). Critical for invoice approval and payment release.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'An additional reference number provided by the vendor for their internal tracking or cross-reference purposes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment to the vendor per local tax regulations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingBlockReason rdf:type rdf:Property ;
    rdfs:label 'Billing Block Reason' ;
    rdfs:comment 'Free-text or coded reason if the invoice was blocked from posting. Common reasons include credit limit exceeded, pricing errors, incomplete delivery, or customer account on hold. Null for unblocked invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The date the invoice was issued to the customer. Serves as the baseline for payment terms calculation and revenue recognition timing per IFRS 15.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code for segment reporting and profitability analysis. Typically represents product divisions (e.g., athletic, lifestyle, luxury) or geographic regions for EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date the invoice was fully paid and cleared from open items in SAP S/4HANA FI-AR. Null for unpaid or partially paid invoices. Used to calculate actual DSO and payment cycle metrics.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP document number of the payment or clearing transaction that settled this invoice. Links the invoice to the corresponding payment record for reconciliation and audit purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP user ID of the person or system process that created the invoice record. Required for SOX (Sarbanes-Oxley) compliance and segregation of duties audits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date the most recent dunning notice was sent to the customer for this overdue invoice. Used to track collections activity and determine next dunning action timing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections reminder) level for overdue invoices. Typically ranges from 0 (no dunning) to 3+ (final notice before legal action). Increments with each escalation cycle.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Shipping, freight, and logistics charges billed to the customer. May be based on FOB (Free on Board) terms or LDP (Landed Duty Paid) pricing depending on Incoterms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Three-letter Incoterms 2020 code defining the division of costs and risks between buyer and seller (e.g., FOB, CIF, DDP, EXW). Critical for international wholesale transactions and landed cost calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNotes rdf:type rdf:Property ;
    rdfs:label 'Invoice Notes' ;
    rdfs:comment 'Free-text field for additional invoice-level comments, special instructions, or customer-specific billing notes. May include payment instructions, dispute details, or special handling requirements.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'SAP user ID of the person or system process that last modified the invoice record. Supports audit trail requirements and change tracking for financial data integrity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Equals net_amount minus any payments received. Used for AR aging reports, DSO calculation, and cash collection forecasting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The customer\'s purchase order number provided at time of order. Required for wholesale and B2B transactions for customer reconciliation and EDI (Electronic Data Interchange) matching.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Customer rebates and retrospective discounts accrued or applied to this invoice. Common in wholesale channel for volume-based incentives. Tracked separately from standard discounts for rebate accrual accounting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method used to recognize revenue from this invoice per IFRS 15. Point-in-time is standard for product sales at shipment or delivery. Over-time applies to service contracts. Deferred applies to advance payments. Milestone applies to custom manufacturing or ODM (Original Design Manufacturer) contracts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The channel through which the sale was made. Wholesale represents B2B sales to retailers, DTC (Direct-to-Consumer) online represents e-commerce sales, DTC store represents company-owned retail, retail represents third-party retail, and marketplace represents platform sales. Critical for channel profitability analysis and GMROI (Gross Margin Return on Investment) calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Asset Transaction Id' ;
    rdfs:comment 'Unique identifier for the asset transaction record. Primary key for the asset transaction entity.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset master record involved in this transaction. Links to the asset master data in FI-AA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code defining the type of fixed asset (e.g., buildings, machinery, vehicles, IT equipment, leasehold improvements). Determines depreciation rules and GL account assignment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset number for assets with multiple components tracked separately (e.g., building structure vs. HVAC system). Supports component depreciation per IFRS IAS 16.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValueDate rdf:type rdf:Property ;
    rdfs:label 'Asset Value Date' ;
    rdfs:comment 'Date from which the asset transaction becomes effective for asset valuation and depreciation calculation purposes. May differ from posting date for backdated transactions.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area classification for cross-company code segment reporting and internal financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer code for asset retirements involving sale or transfer to external parties. Links to accounts receivable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'Code identifying the depreciation area (book depreciation, tax depreciation, IFRS, group consolidation) for which this transaction is recorded. Supports parallel valuation per IFRS and local GAAP.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLineItem rdf:type rdf:Property ;
    rdfs:label 'Document Line Item' ;
    rdfs:comment 'Line item number within the financial document that corresponds to this asset transaction entry.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'System timestamp when the asset transaction record was created in SAP S/4HANA FI-AA. Provides audit trail for transaction entry time.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the corporate group reporting currency for consolidated financial statements and EBITDA analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the company code local currency for statutory reporting and consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Physical quantity of assets involved in the transaction (e.g., number of units acquired, transferred, or retired). Used for quantity-based asset tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code indicating the business reason for the asset transaction (e.g., normal depreciation, impairment, damage, obsolescence, sale, donation, scrap).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as purchase order (PO), invoice number, or vendor document that originated the asset transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this transaction is a reversal of a previously posted asset transaction. True if reversal, False otherwise.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original transaction that this reversal transaction is canceling. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the asset transaction in the transaction currency. Represents acquisition cost, depreciation expense, write-down amount, or retirement proceeds depending on transaction type.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current processing status of the asset transaction in the financial system workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionText rdf:type rdf:Property ;
    rdfs:label 'Transaction Text' ;
    rdfs:comment 'Free-text description or memo providing additional context about the asset transaction. Used for audit trail and user notes.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Code' ;
    rdfs:comment 'Code representing the type of asset transaction: ACQ (Acquisition), TRF (Transfer), RET (Retirement), DEP (Depreciation), WDN (Write-Down), REV (Revaluation), COR (Correction), ADJ (Adjustment). [ENUM-REF-CANDIDATE: ACQ|TRF|RET|DEP|WDN|REV|COR|ADJ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Vendor or supplier code for asset acquisitions. Links to accounts payable and procurement records.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account record. Primary key for the bank account master data entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Internal account identifier within the house bank structure. Used in combination with house_bank_id to uniquely identify the account in SAP.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountClosingDate rdf:type rdf:Property ;
    rdfs:label 'Account Closing Date' ;
    rdfs:comment 'Date when the bank account was officially closed. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Typically matches the company legal entity name.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Account Opening Date' ;
    rdfs:comment 'Date when the bank account was officially opened and activated with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurposeDescription rdf:type rdf:Property ;
    rdfs:label 'Account Purpose Description' ;
    rdfs:comment 'Free-text description of the business purpose and usage of this bank account. Provides context for treasury management and audit purposes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Available Balance Amount' ;
    rdfs:comment 'Available balance after accounting for holds, pending transactions, and reserved funds. Represents actual spendable cash.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 1' ;
    rdfs:comment 'First line of the bank branch physical address. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 2' ;
    rdfs:comment 'Second line of the bank branch physical address (suite, floor, building). Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is maintained.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier code (e.g., routing number in USA, sort code in UK, bank code in other countries). Used for domestic payment processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full legal name of the financial institution where the account is held.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Phone Number' ;
    rdfs:comment 'Primary contact phone number for the bank branch. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the bank branch location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State or province where the bank branch is located. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolingIndicator rdf:type rdf:Property ;
    rdfs:label 'Cash Pooling Indicator' ;
    rdfs:comment 'Flag indicating whether this account participates in a cash pooling arrangement for treasury optimization across multiple entities or accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current available balance in the bank account as of the last reconciliation or statement date. Used for cash flow management and liquidity analysis.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'Unique identifier for the house bank in SAP S/4HANA FI. Represents the company\'s banking partner where the account is maintained.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number used for cross-border payments and international transactions. Standardized format for global banking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percentage' ;
    rdfs:comment 'Annual interest rate percentage applied to the account balance. May be positive for interest-bearing accounts or negative for certain treasury accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date when the last bank reconciliation was completed for this account. Critical for End of Month (EOM) close and financial reporting accuracy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent bank statement received and processed for this account. Used for reconciliation tracking.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcFacilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Lc Facility Indicator' ;
    rdfs:comment 'Flag indicating whether this account is designated for Letter of Credit (LC) issuance and settlement. Critical for apparel fashion global sourcing and Free on Board (FOB) payment terms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Lc Limit Amount' ;
    rdfs:comment 'Maximum Letter of Credit facility limit available on this account. Used for managing trade finance capacity for international supplier payments.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum balance requirement set by the bank or company policy to avoid fees or maintain account status.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft or credit facility limit extended by the bank for this account. Zero if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this account (e.g., wire transfer, ACH, check, EDI, SWIFT). Used for payment run configuration.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Email' ;
    rdfs:comment 'Email address of the bank relationship manager. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerName rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Name' ;
    rdfs:comment 'Name of the bank relationship manager or account officer responsible for this account. Key contact for banking services and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Phone' ;
    rdfs:comment 'Phone number of the bank relationship manager. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the bank and branch for international wire transfers and Letter of Credit (LC) transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual amount spent or incurred against this budget to date. Updated from financial actuals in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The amount of budget that has been allocated or distributed to specific cost centers, projects, or line items.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget plan (e.g., FY2024 OPEX Budget, Spring Collection COGS Budget).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget plan in the approval and execution workflow. [ENUM-REF-CANDIDATE: DRAFT|SUBMITTED|APPROVED|REJECTED|ACTIVE|CLOSED|REVISED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of budget type: OPEX (Operating Expenses), CAPEX (Capital Expenditures), COGS (Cost of Goods Sold), OTB (Open-to-Buy), REVENUE, or EBITDA (Earnings Before Interest Taxes Depreciation and Amortization).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of budget that has been committed through purchase orders or contractual obligations but not yet spent.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Flag indicating whether this is the baseline (original approved) budget version. True for baseline, False for revised versions.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The granularity of budget period allocation: MONTHLY (12 periods), QUARTERLY (4 periods), or ANNUAL (1 period).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The total planned budget amount for the entire fiscal period, in the specified currency. Sum of all period-level allocations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The variance between budgeted and actual amounts (calculated as total_budget_amount minus actual_amount). Positive indicates under-budget, negative indicates over-budget.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the total budget amount. Calculated as (variance_amount / total_budget_amount) * 100.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'Remaining budget available for spending (revised_amount - committed_amount - actual_amount). Used for Open-to-Buy (OTB) management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level budget category classification (Cost of Goods Sold, operating expense, capital expenditure, marketing, payroll, overhead).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line (draft, approved, active, frozen for no further changes, closed at period end).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Sales channel to which this budget line applies (retail stores, wholesale, e-commerce, direct-to-consumer, outlet).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget line is locked from further edits or reallocations (True/False).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtbControlled rdf:type rdf:Property ;
    rdfs:label 'Is Otb Controlled' ;
    rdfs:comment 'Indicates whether this budget line is subject to Open-to-Buy controls for merchandise purchasing (True/False).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the fiscal period covered by this budget line.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the fiscal period covered by this budget line.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Original planned budget amount allocated to this line for the period.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'Revised budget amount after adjustments, reallocations, or amendments during the fiscal period.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: COGS recognition requires traceability to production lot for FIFO/LIFO costing methods and margin analysis by batch quality/origin. Essential for apparel cost accounting and inventory valuation compli' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:originalEntryCogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Original Entry Cogs Entry Id' ;
    rdfs:comment 'Reference to the original COGS entry ID if this entry is a reversal or adjustment, supporting audit trail and reconciliation.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The actual cost per unit incurred for this SKU, including all manufacturing and procurement costs.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionCode rdf:type rdf:Property ;
    rdfs:label 'Collection Code' ;
    rdfs:comment 'The collection or line code for the product, supporting collection-level margin and IMU/MMU tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'The difference between standard cost and actual cost per unit, used for cost control and variance analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'The inventory costing method applied to calculate the COGS for this entry (standard, average, FIFO, LIFO, or specific identification).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCost rdf:type rdf:Property ;
    rdfs:label 'Duty Cost' ;
    rdfs:comment 'The customs duty and tariff cost component allocated to this unit for international shipments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobCost rdf:type rdf:Property ;
    rdfs:label 'Fob Cost' ;
    rdfs:comment 'The FOB cost component representing the cost of goods at the point of shipment from the supplier or manufacturer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'The freight and transportation cost component allocated to this unit for shipping from origin to destination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID or system process that last modified this COGS entry record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldpCost rdf:type rdf:Property ;
    rdfs:label 'Ldp Cost' ;
    rdfs:comment 'The total landed cost including FOB, freight, duty, and all other costs to deliver the product to the final destination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'The merchandise category code for the product, enabling category-level profitability analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'The quantity of units sold for this SKU in this transaction, triggering the COGS recognition.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which the COGS was recognized, typically aligned with revenue recognition per IFRS 15 or GAAP ASC 606.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'The geographic region code where the sale occurred, enabling regional profitability analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCode rdf:type rdf:Property ;
    rdfs:label 'Size Code' ;
    rdfs:comment 'The size code for the product (e.g., XS, S, M, L, XL, or numeric sizing).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The predetermined standard cost per unit for this SKU as maintained in the cost accounting system, used for variance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCogsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cogs Amount' ;
    rdfs:comment 'The total COGS amount for this entry, calculated as actual cost multiplied by quantity sold.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'The SAP valuation class used for inventory valuation and COGS calculation, supporting material ledger accounting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'Primary accounting standard applied for statutory financial reporting. Options include IFRS (International Financial Reporting Standards), US GAAP (Generally Accepted Accounting Principles), local GAAP, or hybrid approaches for dual reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the company code was activated in the SAP S/4HANA FI system and began posting financial transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the registered legal address for the company code. Includes street number and street name.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the registered legal address for the company code. Includes building name, suite, or floor information.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Primary business segment classification for this company code within the apparel fashion group. Used for segment reporting, profitability analysis, and strategic planning.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this company code. The COA defines the structure of General Ledger (GL) accounts used for recording financial transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character alphanumeric code uniquely identifying the legal entity within the SAP S/4HANA FI system. This is the business identifier used across all financial transactions and statutory reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Full legal name of the company as registered with statutory authorities. Used for financial statements, tax filings, and legal documentation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyNameShort rdf:type rdf:Property ;
    rdfs:label 'Company Name Short' ;
    rdfs:comment 'Abbreviated or trading name of the company used for internal reporting and operational displays.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyStatus rdf:type rdf:Property ;
    rdfs:label 'Company Status' ;
    rdfs:comment 'Current operational status of the company code. Active indicates the entity is operational and posting transactions. Inactive, dormant, liquidation, or merged indicate non-operational states.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entity Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code is included in group-level financial consolidation. True indicates the entity participates in consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting entity to which this company code belongs. Used for multi-level consolidation hierarchies and segment reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Four-character code identifying the Controlling (CO) area to which this company code is assigned. The controlling area is the organizational unit for cost accounting, profitability analysis, and internal management reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfSalesAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Of Sales Accounting Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code uses cost-of-sales accounting (income statement by function) or period accounting (income statement by nature). True indicates cost-of-sales method.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area responsible for managing customer credit limits and credit exposure for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the company code was deactivated or ceased operations. Null if the entity is still active.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the company code, if applicable. Used for formal legal and regulatory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusVariant rdf:type rdf:Property ;
    rdfs:label 'Field Status Variant' ;
    rdfs:comment 'Four-character code defining the field status variant that controls which fields are required, optional, or suppressed during financial document posting for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this company code, including the number of posting periods, special periods for year-end adjustments, and fiscal year start/end dates.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was incorporated or registered with the statutory authority. Used for legal compliance and entity lifecycle tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code participates in automated intercompany clearing and reconciliation processes. True indicates intercompany transactions are tracked and cleared.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Four-character code defining the posting period variant that controls which posting periods are open or closed for transaction posting in this company code.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'Code identifying the standard profit center hierarchy used for profitability analysis and internal management reporting for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or sales tax registration number assigned by the local tax authority. Required for VAT reporting and cross-border transactions within VAT jurisdictions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEntryId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entry Id' ;
    rdfs:comment 'Unique identifier for the consolidation entry record. Primary key for the consolidation entry entity.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consolidation entry creation must link to employee for audit trail and SOX compliance. Apparel companies with multiple entities require created_by FK for consolidation journal entry audit and maker-ch' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Consolidation entries are posted to specific ledgers (group ledger, IFRS ledger, GAAP ledger, etc.) in SAP S/4HANA for parallel accounting and group reporting. Each consolidation entry must be associa' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:reversedEntryConsolidationEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Entry Consolidation Entry Id' ;
    rdfs:comment 'Reference to the original consolidation entry that is being reversed by this entry. Null if not a reversal.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsolidationEntry .

ind:sourceCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Source Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Consolidation entries track source legal entity for intercompany eliminations. Normalizing STRING source_company_code to FK source_company_code_id → company_code.company_code_id (first FK to company_c' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier of the person who approved the consolidation entry for posting. Null if not yet approved.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code identifying the consolidation unit or group entity for which this entry is recorded. Represents the reporting entity in the group structure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the consolidation entry is a debit or credit posting. Determines the direction of the accounting impact.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationMethod rdf:type rdf:Property ;
    rdfs:label 'Elimination Method' ;
    rdfs:comment 'Method used for eliminating intercompany transactions or consolidating subsidiary results. Determines the calculation approach for the consolidation entry.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryAmount rdf:type rdf:Property ;
    rdfs:label 'Entry Amount' ;
    rdfs:comment 'Monetary amount of the consolidation entry in the transaction currency. Represents the value of the adjustment or elimination.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date on which the consolidation entry was created or entered into the system. May differ from posting date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryDescription rdf:type rdf:Property ;
    rdfs:label 'Entry Description' ;
    rdfs:comment 'Detailed textual description of the consolidation entry explaining the business purpose and nature of the adjustment or elimination.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business identifier for the consolidation entry document. Externally-known reference number used for tracking and audit purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the consolidation entry in the approval and posting workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the consolidation entry indicating the nature of the adjustment. Determines the accounting treatment and reporting requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate applied for currency translation. Determines the rate selection methodology per accounting standards.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the group reporting currency. Typically the parent company\'s functional currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityInterestPercentage rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Percentage' ;
    rdfs:comment 'Percentage of non-controlling interest in the subsidiary for which the consolidation entry is recorded. Used for minority interest calculations.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership interest held by the parent in the subsidiary. Determines the consolidation method and elimination scope.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Target Company Code' ;
    rdfs:comment 'Company code of the receiving entity in an intercompany transaction or consolidation adjustment. Represents the receiving or crediting entity.' ;
    rdfs:domain ind:ConsolidationEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation record. Primary key for the cost allocation entity.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCycleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Id' ;
    rdfs:comment 'Identifier for the allocation cycle or run executed in SAP S/4HANA CO. Groups multiple allocation records processed together in a single execution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Reference to the original cost allocation record if this is a reversal or correction. Links reversal documents to their original transactions.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:receiverCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Center Id' ;
    rdfs:comment 'FK to finance.cost_center' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Cost allocations can be allocated to profit centers for profitability analysis. Normalizing STRING receiver_profit_center_code to FK receiver_profit_center_id → profit_center.profit_center_id. Remove ' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:senderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost allocations track sender cost center for internal cost distribution. Normalizing STRING sender_cost_center_code to FK sender_cost_center_id → cost_center.cost_center_id (first FK to cost_center w' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to distribute costs from sender to receiver. Percentage allocates by fixed ratio, quantity by volume or count, equivalence by weighted factors, direct by explicit assignment, activity-based by activity driver consumption, driver-based by cost driver metrics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments explaining the allocation rationale, special circumstances, or business justification. Used for audit and review purposes.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of sender cost allocated to this receiver when using percentage-based allocation method. Value between 0 and 100.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Quantity' ;
    rdfs:comment 'Quantity or volume used as the basis for allocation when using quantity-based or driver-based methods. Unit depends on allocation driver.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRunDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Date' ;
    rdfs:comment 'Date when the allocation cycle was executed. May differ from posting date if allocation is run retrospectively or in batch.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current status of the cost allocation record. Posted indicates successfully posted to CO/FI, reversed indicates reversal document created, pending indicates awaiting approval, error indicates posting failure, cancelled indicates allocation was voided.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Unit' ;
    rdfs:comment 'Unit of measure for the allocation quantity (e.g., hours, square meters, headcount, transactions). Defines the driver metric.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'Controlling area in which the cost allocation is executed. Represents the organizational unit for cost accounting and internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'Cost element (account assignment) under which the allocated cost is posted. Represents the nature of the cost being distributed (e.g., overhead, logistics, marketing).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementName rdf:type rdf:Property ;
    rdfs:label 'Cost Element Name' ;
    rdfs:comment 'Descriptive name of the cost element being allocated. Provides business-readable context for the type of cost.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalenceNumber rdf:type rdf:Property ;
    rdfs:label 'Equivalence Number' ;
    rdfs:comment 'Weighting factor used in equivalence-based allocation. Represents the relative consumption or benefit received by the receiver.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code local currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Product line or category code to which the allocated cost is assigned. Enables product-level profitability and COGS analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'The employee ID or personnel number of the manager responsible for this cost center\'s budget, spending, and performance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or cost driver associated with this cost center (e.g., \'Machine Hours\', \'Labor Hours\', \'Square Footage\', \'Headcount\'). Used for activity-based costing and allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCostYtd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Ytd' ;
    rdfs:comment 'The cumulative actual costs posted to this cost center from the beginning of the fiscal year to the current period. Used for budget variance and EOM close reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCycleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Code' ;
    rdfs:comment 'The identifier of the allocation cycle in which this cost center participates as sender or receiver. Used for overhead distribution and internal cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual budget amount allocated to this cost center for the current fiscal year. Used for budget control and variance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the budget amount (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCostYtd rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Ytd' ;
    rdfs:comment 'The cumulative committed costs (purchase orders, contracts) against this cost center from the beginning of the fiscal year to the current period. Used for funds availability and budget control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects: direct (traced to specific receivers), assessment (fixed allocation), distribution (variable allocation), activity-based (driver-based), percentage (proportional split).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended textual description of the cost center\'s purpose, scope, and responsibilities. Used for documentation and user guidance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The descriptive name of the cost center (e.g., \'Design Studio NYC\', \'Warehouse Operations LA\', \'Marketing Digital\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Center Number' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the cost center in SAP S/4HANA FI/CO. Used for posting, reporting, and budget control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active: operational and accepting postings. Inactive: closed, no new postings. Blocked: temporarily suspended. Planned: future cost center not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional purpose: production (manufacturing/CMT), service (support functions), administration (overhead), sales (retail/wholesale), marketing (brand/campaigns), distribution (logistics/3PL), research and development (PLM/design). [ENUM-REF-CANDIDATE: production|service|administration|sales|marketing|distribution|research_development — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The cost element group or category to which the majority of costs in this cost center belong (e.g., \'Labor\', \'Materials\', \'Overhead\', \'Depreciation\'). Used for COGS buildup and cost-of-sales reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional classification of the cost center (e.g., \'Manufacturing\', \'Logistics\', \'Sales\', \'Marketing\', \'Administration\'). Used for cost-of-sales accounting and COGS buildup.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The hierarchical node or group to which this cost center belongs in the organizational cost center hierarchy. Used for roll-up reporting and consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Boolean flag indicating whether this cost center is locked and cannot accept new cost postings. Used during period close and cost center deactivation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverheadReceiver rdf:type rdf:Property ;
    rdfs:label 'Is Overhead Receiver' ;
    rdfs:comment 'Boolean flag indicating whether this cost center receives allocated overhead costs from other cost centers. True if this cost center is a receiver in allocation cycles.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverheadSender rdf:type rdf:Property ;
    rdfs:label 'Is Overhead Sender' ;
    rdfs:comment 'Boolean flag indicating whether this cost center sends (distributes) overhead costs to other cost centers or cost objects. True if this cost center is a sender in allocation cycles.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'The physical location or site code where this cost center operates (e.g., warehouse code, store code, office code).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center is valid and operational. Used for time-dependent cost center master data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this cost center is valid. Null or far-future date indicates open-ended validity. Used for cost center closure and historical reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterOfCreditId rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Id' ;
    rdfs:comment 'Foreign key linking to finance.letter_of_credit. Business justification: Payments can be linked to letters of credit for trade finance. Normalizing STRING lc_number to FK letter_of_credit_id → letter_of_credit.letter_of_credit_id. Remove redundant lc_number and lc_issuing_' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfCredit .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross payment amount in the transaction currency before any adjustments, fees, or exchange rate conversions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Fees charged by the bank for processing the payment transaction, including wire transfer fees, LC handling fees, or foreign exchange fees.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementDate rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Date' ;
    rdfs:comment 'The date on which this payment appeared on the bank statement, used for bank reconciliation and cash positioning.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryBankName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Name' ;
    rdfs:comment 'The name of the beneficiary\'s bank institution receiving or sending the payment.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code of the beneficiary\'s bank, used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'The name of the payment recipient (vendor, supplier, or customer). For outgoing payments, this is the payee; for incoming receipts, this is the payer.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockIndicator rdf:type rdf:Property ;
    rdfs:label 'Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the payment is blocked for processing due to approval requirements, compliance holds, or dispute resolution. True if blocked, False if released.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text explanation for why the payment is blocked, such as pending approval, invoice dispute, compliance review, or missing documentation.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this payment is an intercompany transaction between legal entities within the same corporate group. True for intercompany, False for external.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'The payment amount converted to the company\'s local reporting currency for consolidation and statutory reporting per IFRS/GAAP requirements.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount transferred after applying discounts and deducting bank charges. Represents the actual cash movement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Run Number' ;
    rdfs:comment 'Identifier for the automated payment run batch in SAP S/4HANA FI that grouped multiple payments for processing. Used for batch reconciliation and audit trails.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date when this payment was successfully reconciled with the bank statement, completing the cash management cycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of bank statement reconciliation: matched to bank statement, unmatched, partially matched, or under review by treasury team.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number or remittance advice identifier provided by the payer or payee for payment tracking and reconciliation purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to the payment transaction in SAP S/4HANA FI, determining tax calculation rules and reporting requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terms rdf:type rdf:Property ;
    rdfs:label 'Terms' ;
    rdfs:comment 'The agreed payment terms between buyer and seller (e.g., Net 30, 2/10 Net 30, FOB, DDP). Influences discount eligibility and cash flow timing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds are available or debited for interest calculation and cash positioning purposes. Critical for treasury management and cash flow analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Employee identifier for the person responsible for the fixed asset. Used for asset custody tracking and accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation posted to date since acquisition. Used to calculate net book value and track asset consumption over time.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original acquisition cost of the fixed asset including purchase price, installation costs, and any directly attributable costs to bring the asset to working condition. Basis for depreciation calculation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetGroupCode rdf:type rdf:Property ;
    rdfs:label 'Asset Group Code' ;
    rdfs:comment 'Grouping code for aggregating similar assets for reporting and analysis. Supports portfolio management and CAPEX planning by asset category.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Business identifier for the fixed asset. The externally-known unique asset number used across SAP S/4HANA FI-AA for asset tracking, depreciation runs, and financial reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP asset subnumber for tracking components or sub-assets within a main asset. Enables detailed tracking of complex assets with multiple depreciable components.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or barcode number affixed to the asset for identification during physical inventory counts and asset verification audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when the asset was capitalized and added to the fixed asset register. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP depreciation area code (e.g., 01 for book depreciation, 15 for tax depreciation). Enables parallel valuation for IFRS, GAAP, and local statutory reporting requirements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Depreciation calculation method applied to the fixed asset. Determines how acquisition cost is systematically allocated over useful life per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized on the fixed asset per IAS 36. Reduces net book value when recoverable amount falls below carrying amount.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering the fixed asset. Supports risk management and insurance claim processing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date of the most recent physical inventory verification for the fixed asset. Supports audit compliance and asset existence verification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Contract number for leased assets. Links fixed asset to lease liability and supports IFRS 16 compliance reporting for right-of-use assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Lease Indicator' ;
    rdfs:comment 'Flag indicating whether the asset is held under a lease agreement. Used for IFRS 16 lease accounting and right-of-use asset tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Code' ;
    rdfs:comment 'Code identifying the preventive maintenance schedule for the fixed asset. Links to maintenance planning and asset reliability programs.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current net book value of the fixed asset calculated as acquisition cost minus accumulated depreciation. Represents the carrying amount on the balance sheet per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Business reason for asset retirement. Supports audit trail and asset lifecycle analysis for CAPEX planning and replacement strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the fixed asset at the end of its useful life. Subtracted from acquisition cost to determine depreciable amount per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique identifier for the physical asset. Used for warranty tracking, maintenance scheduling, and physical inventory verification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'Depreciation method used for tax reporting purposes. May differ from book depreciation method to comply with local tax regulations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the fixed asset in years. Used for depreciation calculation and asset lifecycle planning. May include fractional years for precision.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer warranty expires. Used for maintenance planning and cost forecasting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Account group classification code that controls field status, number range, and account behavior in SAP FI. Groups accounts with similar characteristics and posting rules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongText rdf:type rdf:Property ;
    rdfs:label 'Account Long Text' ;
    rdfs:comment 'Extended description providing detailed explanation of the account purpose, usage guidelines, and posting rules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the general ledger account for display and reporting purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Classification for balance sheet accounts distinguishing current vs non-current assets and liabilities. Not applicable for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to obsolete or suspended accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification of the account for cash flow statement preparation per IFRS/GAAP. Categorizes cash movements into operating, investing, or financing activities.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelClassification rdf:type rdf:Property ;
    rdfs:label 'Channel Classification' ;
    rdfs:comment 'Classification of the account by sales channel (DTC, wholesale, e-commerce, retail store) for channel-specific profitability analysis in apparel fashion business.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Four-character code identifying the chart of accounts to which this account belongs. Supports multi-COA scenarios for global enterprises.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Relevant Flag' ;
    rdfs:comment 'Indicates whether this account is included in COGS calculation. Essential for gross margin analysis and inventory valuation in apparel manufacturing and retail.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'Account number in the group chart of accounts used for financial consolidation and elimination of intercompany transactions at corporate level.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. Enforces cost allocation discipline for expense accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of cost element as primary (posted from FI) or secondary (internal CO allocations). Not applicable for non-cost-element accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this account is relevant for Controlling (CO) module and functions as a cost element for cost center accounting, internal orders, or profitability analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebitdaRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Relevant Flag' ;
    rdfs:comment 'Indicates whether postings to this account are included in EBITDA calculation. Critical for apparel fashion profitability analysis and investor reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Four-character code defining which fields are required, optional, or suppressed when posting to this account. Controls data entry behavior in SAP FI.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Detailed financial statement line item classification for statutory reporting. Maps account to specific line items in balance sheet, income statement, or cash flow statement per IFRS/GAAP requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'US GAAP classification code for accounts used in US statutory reporting. Supports dual-reporting requirements for multinational apparel companies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:comment 'Current lifecycle status of the general ledger account indicating whether it is actively used, retired, or awaiting approval for use.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiCategory rdf:type rdf:Property ;
    rdfs:label 'Gmroi Category' ;
    rdfs:comment 'Classification for GMROI analysis in apparel merchandising. Links account to inventory investment and margin performance metrics by product category or channel.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'Detailed IFRS standard and paragraph reference for account classification. Ensures compliance with international accounting standards for statutory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Indicator' ;
    rdfs:comment 'Code indicating whether and how interest is calculated on balances in this account. Used for customer/vendor interest calculation and treasury management.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostComponent rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Component' ;
    rdfs:comment 'Classification of the account as a component of landed cost calculation (freight, duty, insurance, customs). Critical for apparel import cost accounting and FOB to LDP reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this account. Required for detailed transaction analysis and audit trails.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether the account is managed on an open item basis, requiring explicit clearing of line items. Essential for AP, AR, and clearing accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Defines the organizational level at which budget planning and control is performed for this account (e.g., company code, profit center, cost center).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct manual or automated postings are permitted to this account. Some accounts may be restricted to system-only postings or blocked entirely.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. Used to enforce segment reporting and profitability analysis by business unit.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Classification' ;
    rdfs:comment 'Detailed classification for income statement accounts including COGS, operating expenses, EBITDA components, and non-operating items. Used for margin analysis and profitability reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed postings from subsidiary ledgers such as Accounts Payable (AP), Accounts Receivable (AR), or asset accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-character code controlling the allocation and sorting of line items within the account. Used for automatic payment programs and dunning.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax classification code indicating whether the account is subject to input tax, output tax, non-taxable, or tax-exempt treatment. Used for VAT/GST reporting and compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Four-character code defining posting and clearing tolerances for the account. Controls maximum amounts and variances permitted in transactions.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for the intercompany transaction entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Intercompany transactions track sending legal entity for intercompany reconciliation. Normalizing STRING sending_company_code to FK sending_company_code_id → company_code.company_code_id (first FK to ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:sendingProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Intercompany transactions track sending profit center for segment reporting. Normalizing STRING sending_profit_center_code to FK sending_profit_center_id → profit_center.profit_center_id (first FK to ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date when the intercompany transaction was eliminated during the financial consolidation process. Null if elimination is still pending.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'The current status of the intercompany transaction in the consolidation elimination process. Pending indicates awaiting elimination; eliminated means fully removed from consolidated statements; partially eliminated for complex multi-step transactions; exception for transactions requiring manual review.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingPosition rdf:type rdf:Property ;
    rdfs:label 'Netting Position' ;
    rdfs:comment 'Indicates the settlement position of the intercompany transaction from the group perspective. Payable means the sending entity owes the receiving entity; receivable means the opposite; settled indicates payment completed; offset means netted against other transactions.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The company code of the legal entity that is the receiver or consumer in the intercompany transaction. Represents the entity being charged or receiving goods/services. Typically a 4-character alphanumeric code per SAP standard.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Profit Center Code' ;
    rdfs:comment 'The profit center code within the receiving company that is charged for the intercompany transaction. Used for internal profitability analysis and segment reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when the intercompany transaction was settled through cash payment, netting, or other settlement mechanism between the legal entities. Null if settlement is pending.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'The mechanism used to settle the intercompany transaction. Cash payment for direct fund transfer; netting for multilateral settlement; offset against other balances; loan conversion for capitalization; waiver for forgiveness.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date when the intercompany transaction occurred or was recognized. This is the accounting effective date used for financial period assignment and consolidation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the business activity between legal entities. Goods transfer represents finished goods or materials moved between entities; service charge for shared services; royalty and license fees for intellectual property usage; management fees for corporate overhead; loan and interest for financing arrangements; dividend for profit distribution; allocation for cost sharing. [ENUM-REF-CANDIDATE: goods_transfer|service_charge|royalty|license_fee|management_fee|loan|interest|dividend|allocation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Adjustment Amount' ;
    rdfs:comment 'Any adjustment amount applied to the intercompany transaction to align with transfer pricing policy and arms-length principles. Positive values indicate upward adjustments; negative values indicate downward adjustments.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD-compliant transfer pricing methodology applied to determine the arms-length price for this intercompany transaction. Comparable uncontrolled price uses market benchmarks; resale price based on resale margin; cost plus adds markup to cost; transactional net margin compares net margins; profit split allocates combined profits.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The withholding tax rate percentage applied to the intercompany transaction based on applicable tax treaties and local regulations. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry document in SAP S/4HANA FI. Primary key for the journal entry record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:carbonOffsetId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_offset. Business justification: Links offset purchases to GL postings. Enables financial/ESG reconciliation of carbon credit transactions, net-zero accounting verification, and audit trail for voluntary carbon market purchases—requi' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffset .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item in the document currency (transaction currency). Used for multi-currency reporting and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item in the company code\'s local currency. Used for statutory financial statements and local GAAP reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text field used for additional sorting and grouping of line items. Often contains purchase order numbers, project codes, or other business references for reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level. Provides business context for the entire document (e.g., \'Month-end accrual for freight costs\', \'Intercompany elimination Q1 2024\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the line item level providing business context for the specific posting (e.g., \'Accrued freight for shipment #12345\', \'COGS adjustment for SKU ABC123\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls the type of posting (debit/credit) and the account type (GL, customer, vendor, asset). Determines field status and posting behavior in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this journal entry was reversed, if applicable. Null if not reversed. Used for tracking accrual reversals and corrections.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Organizational unit for segment reporting per IFRS 8. Represents an operating segment for which discrete financial information is available and regularly reviewed by chief operating decision maker.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Identifier for the intercompany trading partner in intercompany transactions. Used for intercompany eliminations and consolidation in multi-entity organizations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-code) used to create this journal entry (e.g., FB01, FB50, F-02). Indicates whether entry was manual or automated from SD/MM/PP modules.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationDate rdf:type rdf:Property ;
    rdfs:label 'Translation Date' ;
    rdfs:comment 'The date used to determine the exchange rate for currency translation. Typically the posting date or document date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project Systems work breakdown structure element for project-related postings. Enables project cost tracking and capital expenditure management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line detail record.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount of the line item converted to the corporate group reporting currency. Used for consolidated financial statements and group-level EBITDA analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Monetary amount of the line item in the original transaction currency. Used for multi-currency operations and foreign exchange tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting. Distinguishes between production, sales, administration, and other functional cost categories per IFRS/GAAP requirements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order number for overhead cost collection and allocation. Used for tracking costs of internal activities, events, or short-term projects.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Material or SKU number for inventory-related postings. Links financial transactions to specific products for COGS analysis and inventory valuation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Manufacturing plant or distribution center code for location-specific cost allocation. Used for multi-site COGS analysis and supply chain cost tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey1 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 1' ;
    rdfs:comment 'First reference key field for linking to source documents or external systems. Commonly used for invoice numbers, PO numbers, or EDI transaction references.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey2 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 2' ;
    rdfs:comment 'Second reference key field for additional cross-reference tracking. Supports multi-level document traceability and reconciliation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey3 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 3' ;
    rdfs:comment 'Third reference key field for extended reference data. Used in complex allocation scenarios or multi-system integration environments.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversal transaction if this line item was reversed. Maintains complete audit trail for corrected entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Storage location within a plant for detailed inventory tracking. Enables warehouse-level cost allocation and inventory valuation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner company code for intercompany transactions. Identifies the counterparty legal entity in cross-company postings for consolidation elimination.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS element for project-related postings. Links financial transactions to specific project phases or deliverables in PLM and capital project accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostId rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Id' ;
    rdfs:comment 'Primary key for landed_cost' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Foreign key linking to inventory.asn. Business justification: Landed cost calculation (duty, freight, insurance) is triggered by ASN receipt and must trace to specific advance shipment notice for accurate cost allocation to received goods. Standard apparel impor' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt document that triggered the landed cost calculation. Links to the inbound inventory receipt event in SAP S/4HANA MM.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:airFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Air Freight Amount' ;
    rdfs:comment 'The cost of air freight transportation if goods were shipped by air. Component of landed cost for expedited shipments.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBrokerageAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Amount' ;
    rdfs:comment 'The fee paid to customs brokers for handling import documentation and customs clearance procedures.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'The customs duty paid to import the goods into the destination country. Calculated based on HS code tariff rate and customs value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsValueAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Value Amount' ;
    rdfs:comment 'The declared value of the goods for customs purposes. Basis for calculating customs duty and import taxes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the destination country where the goods are imported. Determines applicable tariff rates and customs regulations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fobPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fob Price Amount' ;
    rdfs:comment 'The FOB price of the goods as agreed with the supplier. Represents the cost of goods before international freight and insurance.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which the landed cost was posted to the general ledger. Determines the financial period for COGS recognition and inventory valuation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which the goods were physically received into inventory. Determines the accounting period for cost recognition.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gspPreferenceApplied rdf:type rdf:Property ;
    rdfs:label 'Gsp Preference Applied' ;
    rdfs:comment 'Indicates whether a GSP tariff preference was applied to reduce or eliminate customs duty. True if GSP benefits were utilized.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gspPreferenceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Gsp Preference Rate Percent' ;
    rdfs:comment 'The reduced tariff rate percentage applied under GSP preference. Null if no GSP preference was applied.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'The Incoterms 2020 code defining the terms of delivery and cost responsibility between buyer and seller. Common values: FOB, CIF, EXW, FCA, CPT, CIP, DAP, DPU, DDP. [ENUM-REF-CANDIDATE: FOB|CIF|EXW|FCA|CPT|CIP|DAP|DPU|DDP — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inlandFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Inland Freight Amount' ;
    rdfs:comment 'The cost of domestic transportation from the port of discharge to the final warehouse or distribution center.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'The cost of cargo insurance covering the goods during international transit. Component of landed cost.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedCostNumber rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Number' ;
    rdfs:comment 'Business identifier for the landed cost calculation. Human-readable reference number used in financial reporting and audit trails.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostStatus rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Status' ;
    rdfs:comment 'The current status of the landed cost record in the financial workflow. Values: draft (initial calculation), calculated (computation complete), approved (reviewed and approved), posted (recorded to general ledger), reversed (corrected or cancelled).' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterOfCreditNumber rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Number' ;
    rdfs:comment 'The letter of credit number used to secure payment for this shipment. Links to trade finance instruments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oceanFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Ocean Freight Amount' ;
    rdfs:comment 'The cost of ocean freight transportation from the port of loading to the port of discharge. Component of landed cost.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country of manufacture or origin for the goods. Used for customs duty calculation and trade compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charges Amount' ;
    rdfs:comment 'Miscellaneous charges not categorized elsewhere, such as inspection fees, fumigation costs, or special handling charges.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portHandlingAmount rdf:type rdf:Property ;
    rdfs:label 'Port Handling Amount' ;
    rdfs:comment 'The cost of port handling services including unloading, storage, and terminal fees at the port of discharge.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'The seaport or airport where the goods were unloaded upon arrival. Used for customs clearance and port handling cost allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'The seaport or airport from which the goods were shipped. Used for freight cost allocation and logistics tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The quantity of goods received in this shipment. Used to calculate unit landed cost and allocate costs across units.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Percent' ;
    rdfs:comment 'The customs duty rate percentage applied to the goods based on the HS code and origin country. Used to calculate the customs duty amount.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLandedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Landed Cost Amount' ;
    rdfs:comment 'The total landed duty paid cost per unit or shipment. Sum of FOB price, freight, insurance, customs duty, and all other charges. Authoritative cost basis for inventory valuation and COGS.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLandedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Landed Cost Amount' ;
    rdfs:comment 'The landed cost per individual unit of the SKU. Calculated by dividing total landed cost by quantity received. Used for per-unit inventory valuation.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Posting Status' ;
    rdfs:comment 'Status of accrual and deferral postings for the current period. Accruals ensure expenses and revenues are recognized in the correct period per the applicable accounting principle (IFRS, GAAP). Pending indicates accruals not yet posted; complete indicates all accruals posted; partial indicates some accruals posted.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency for this ledger (e.g., USD, EUR, GBP). All financial amounts in this ledger are expressed or translated into this currency.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeBlockingReason rdf:type rdf:Property ;
    rdfs:label 'Close Blocking Reason' ;
    rdfs:comment 'Free-text description of the issue preventing period close completion when close_checklist_status is blocked. Examples: unreconciled intercompany balances, missing accruals, pending depreciation run, outstanding approvals.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCalendarTemplate rdf:type rdf:Property ;
    rdfs:label 'Close Calendar Template' ;
    rdfs:comment 'Identifier or name of the close calendar template defining the structured sequence of close tasks, milestones, and deadlines for this ledger. Templates standardize close processes across periods and company codes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Close Checklist Status' ;
    rdfs:comment 'Overall status of the period-end close checklist for the current period. Not started indicates close has not begun; in progress indicates active close tasks; complete indicates all steps finished and approved; blocked indicates close is halted due to issues.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeResponsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Close Responsible Owner' ;
    rdfs:comment 'Name or identifier of the finance team member or role responsible for managing the period-end close process for this ledger. Accountable for completing close checklist steps and obtaining sign-off approvals.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier of the consolidation group or reporting entity to which this ledger belongs. Used for group-level financial consolidation and statutory reporting across multiple company codes and legal entities.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger is used for group consolidation and statutory reporting. True if the ledger feeds consolidation systems; false for local or management ledgers.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency perspective for this ledger. Company code currency is local operational currency; group currency is the consolidation currency; hard currency is a stable reference currency; index currency supports inflation-adjusted reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Current Fiscal Year' ;
    rdfs:comment 'The fiscal year currently active for posting and reporting in this ledger (e.g., 2024). Updated at fiscal year rollover.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPostingPeriod rdf:type rdf:Property ;
    rdfs:label 'Current Posting Period' ;
    rdfs:comment 'The posting period currently open for transaction entry in this ledger (1-16, where 1-12 are regular periods and 13-16 are special periods for adjustments). Controlled by period-end close process.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationRunStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Status' ;
    rdfs:comment 'Status of the periodic depreciation calculation and posting run for fixed assets in this ledger. Depreciation run is a mandatory step in the End of Month (EOM) close process.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Reconciliation Status' ;
    rdfs:comment 'Status of intercompany balance reconciliation for the current period. Reconciled indicates all intercompany transactions match between trading partners; variance identified indicates discrepancies requiring resolution before close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCloseDate rdf:type rdf:Property ;
    rdfs:label 'Last Close Date' ;
    rdfs:comment 'The date on which the most recent period close was completed and signed off. Represents the last successful End of Month (EOM) close milestone.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Last Closed Period' ;
    rdfs:comment 'The most recent posting period that has completed the End of Month (EOM) close process and is locked for further postings. Used to track close progress and enforce period controls.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadingLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Leading Ledger Flag' ;
    rdfs:comment 'Indicates whether this is the leading ledger (primary book of record) for the organization. True for the leading ledger; false for extension or special purpose ledgers. Only one leading ledger is permitted per client.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Short alphanumeric code identifying the ledger in SAP S/4HANA (e.g., 0L for leading ledger, 2L for IFRS ledger). Used as the business identifier for the ledger across financial transactions and reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the accounting ledger (e.g., Leading Ledger, IFRS Ledger, Management Accounting Ledger). Human-readable label for business users.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger. Active ledgers accept postings; inactive ledgers are configured but not yet in use; closed ledgers are archived and read-only; suspended ledgers are temporarily blocked.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger role in the accounting architecture. Leading ledger is the primary book of record; extension ledgers support parallel accounting views (IFRS, local GAAP); special purpose ledgers support management accounting or simulation scenarios.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiGaapComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Gaap Compliance Flag' ;
    rdfs:comment 'Indicates whether this ledger is part of a multi-GAAP parallel accounting setup, supporting simultaneous compliance with multiple accounting standards (e.g., IFRS and US GAAP). True if multi-GAAP; false if single standard.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCloseDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Close Due Date' ;
    rdfs:comment 'The target date by which the next period close must be completed. Drives the close calendar and task scheduling for depreciation runs, accruals, intercompany reconciliation, and statutory reporting milestones.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parallelAccountingScenario rdf:type rdf:Property ;
    rdfs:label 'Parallel Accounting Scenario' ;
    rdfs:comment 'Describes the specific parallel accounting use case this ledger supports (e.g., IFRS 16 Leases, US GAAP Revenue Recognition, Local Tax Reporting). Free-text field for business context.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Period Lock Status' ;
    rdfs:comment 'Indicates whether the current posting period is open for all users, locked to prevent further postings, or partially locked (open only for specific user groups or account ranges). Managed during End of Month (EOM) close.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffApprover rdf:type rdf:Property ;
    rdfs:label 'Sign Off Approver' ;
    rdfs:comment 'Name or identifier of the senior finance leader (e.g., CFO, Controller, Finance Director) responsible for final approval and sign-off of the period close for this ledger. Approval confirms financial statements are complete and accurate.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The date on which the sign-off approver formally approved the period close and financial statements for this ledger. Marks the official completion of the close process.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statutoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Statutory Reporting Status' ;
    rdfs:comment 'Status of statutory financial reporting deliverables for this ledger and period (e.g., balance sheet, income statement, cash flow statement per IFRS or local GAAP). Not started indicates reports not yet generated; submitted indicates reports filed with authorities; approved indicates reports signed off by auditors or management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The valuation approach applied in this ledger. Legal valuation follows local statutory rules; group valuation applies corporate consolidation policies; profit center and segment valuations support internal management reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Letters of credit are issued through a specific bank account maintained in SAP S/4HANA FI. Currently the issuing bank is captured as denormalized STRING fields (issuing_bank_name, issuing_bank_swift_c' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:advisingBankName rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Name' ;
    rdfs:comment 'The name of the bank that advises the letter of credit to the beneficiary, typically located in the beneficiary\'s country.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisingBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code of the advising bank for international communication and document handling.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment to the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number tracking amendments made to the original letter of credit. Zero indicates the original LC with no amendments.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantAddress rdf:type rdf:Property ;
    rdfs:label 'Applicant Address' ;
    rdfs:comment 'The full business address of the applicant party requesting the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'The name of the party (buyer/importer) who requests the issuing bank to open the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAddress rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Address' ;
    rdfs:comment 'The full business address of the beneficiary party entitled to receive payment under the letter of credit.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesAccount rdf:type rdf:Property ;
    rdfs:label 'Charges Account' ;
    rdfs:comment 'Indicates which party (applicant or beneficiary) is responsible for paying the letter of credit charges and fees.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmingBankName rdf:type rdf:Property ;
    rdfs:label 'Confirming Bank Name' ;
    rdfs:comment 'The name of the bank that adds its confirmation to the letter of credit, providing additional payment guarantee to the beneficiary.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRequirements rdf:type rdf:Property ;
    rdfs:label 'Document Requirements' ;
    rdfs:comment 'Detailed description of all documents required to be presented for negotiation under the letter of credit (e.g., commercial invoice, packing list, bill of lading, certificate of origin, inspection certificate).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Description of the goods or merchandise covered by the letter of credit, including product details, quantities, and specifications.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Shipment Date' ;
    rdfs:comment 'The last permissible date for shipment of goods under the terms of the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcAmount rdf:type rdf:Property ;
    rdfs:label 'Lc Amount' ;
    rdfs:comment 'The maximum monetary value of the letter of credit. This is the principal quantitative fact representing the credit limit available to the beneficiary.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'The externally-known documentary credit number issued by the bank. This is the business identifier used in trade finance communications and documentation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcStatus rdf:type rdf:Property ;
    rdfs:label 'Lc Status' ;
    rdfs:comment 'Current lifecycle status of the letter of credit in the trade finance workflow. [ENUM-REF-CANDIDATE: draft|issued|advised|confirmed|amended|utilized|expired|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcType rdf:type rdf:Property ;
    rdfs:label 'Lc Type' ;
    rdfs:comment 'Classification of the letter of credit based on its terms and conditions. Determines the level of commitment and transferability.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether partial shipments of goods are permitted under the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The payment terms specified in the letter of credit indicating when payment will be made (at sight, deferred, or upon acceptance).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Presentation Period Days' ;
    rdfs:comment 'The maximum number of days after shipment date within which documents must be presented to the bank for negotiation.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revolvingFlag rdf:type rdf:Property ;
    rdfs:label 'Revolving Flag' ;
    rdfs:comment 'Indicates whether the letter of credit automatically renews for additional shipments after each utilization.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any additional special terms, conditions, or instructions specific to this letter of credit that are not covered by standard fields.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenorDays rdf:type rdf:Property ;
    rdfs:label 'Tenor Days' ;
    rdfs:comment 'The number of days after sight or shipment date when payment is due under deferred payment or usance terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'The permissible percentage variance (plus or minus) allowed in the LC amount and quantity as per UCP 600 Article 30.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the letter of credit can be transferred in whole or in part to one or more second beneficiaries.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transshipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Transshipment Allowed' ;
    rdfs:comment 'Indicates whether transshipment (transfer of goods from one vessel to another during transit) is permitted under the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizedAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Amount' ;
    rdfs:comment 'The cumulative amount that has been drawn or utilized against the letter of credit to date.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginRecordId rdf:type rdf:Property ;
    rdfs:label 'Margin Record Id' ;
    rdfs:comment 'Unique identifier for the margin record. Primary key for the authoritative profitability analysis record capturing the complete cost-to-margin chain from landed cost through COGS to realized margin at SKU/transaction level.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalImpactId rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_impact. Business justification: Links product profitability to lifecycle environmental footprint. Enables true-cost accounting (financial + environmental), sustainable product portfolio optimization, and eco-margin analysis—emerging' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalImpact .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit based on real landed cost inputs. Used to calculate cost variance against standard cost.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airFreightCost rdf:type rdf:Property ;
    rdfs:label 'Air Freight Cost' ;
    rdfs:comment 'Air shipping cost component of landed cost. Used when expedited shipping is required, impacting margin significantly.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aspAmount rdf:type rdf:Property ;
    rdfs:label 'Asp Amount' ;
    rdfs:comment 'Average selling price per unit at gross revenue level before markdowns. Used to track pricing strategy effectiveness.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aurAmount rdf:type rdf:Property ;
    rdfs:label 'Aur Amount' ;
    rdfs:comment 'Average selling price per unit after markdowns and discounts. Key metric for pricing effectiveness and markdown impact analysis.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin Amount' ;
    rdfs:comment 'Gross margin minus variable selling expenses. Used for break-even analysis and channel profitability assessment.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Difference between actual cost and standard cost. Positive variance indicates cost overrun impacting margin negatively.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobCostAmount rdf:type rdf:Property ;
    rdfs:label 'Fob Cost Amount' ;
    rdfs:comment 'Factory gate cost before freight, insurance, and duties. First component of the landed duty paid cost breakdown. Sourced from purchase order or standard costing.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiRatio rdf:type rdf:Property ;
    rdfs:label 'Gmroi Ratio' ;
    rdfs:comment 'Gross margin dollars returned for every dollar of inventory investment. Critical metric for inventory productivity and buying decisions.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Net revenue minus COGS. The primary profitability metric for product-level margin analysis.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percentage' ;
    rdfs:comment 'Gross margin as a percentage of net revenue. Key performance indicator for profitability analysis by SKU, channel, and region.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total revenue before discounts and markdowns. The starting point for margin calculation.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspPreferenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Gsp Preference Indicator' ;
    rdfs:comment 'Flag indicating whether GSP tariff preference was applied to reduce or eliminate customs duty. Impacts landed cost and margin calculation.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imuPercentage rdf:type rdf:Property ;
    rdfs:label 'Imu Percentage' ;
    rdfs:comment 'Initial markup percentage from cost to original retail price. Measures the starting margin before markdowns.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inlandFreightCost rdf:type rdf:Property ;
    rdfs:label 'Inland Freight Cost' ;
    rdfs:comment 'Domestic transportation cost from port to distribution center or store. Final component of the full LDP cost breakdown.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCost rdf:type rdf:Property ;
    rdfs:label 'Insurance Cost' ;
    rdfs:comment 'Cargo insurance cost component of landed cost. Part of the full LDP cost breakdown.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Amount' ;
    rdfs:comment 'Price reduction from original retail price. Critical for calculating maintained markup and understanding margin erosion.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmuPercentage rdf:type rdf:Property ;
    rdfs:label 'Mmu Percentage' ;
    rdfs:comment 'Maintained markup percentage after markdowns and discounts. The realized margin percentage that accounts for all price reductions.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Revenue after markdowns and discounts. The revenue figure used to calculate gross margin and contribution margin.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oceanFreightCost rdf:type rdf:Property ;
    rdfs:label 'Ocean Freight Cost' ;
    rdfs:comment 'Ocean shipping cost component of landed cost. Part of the full LDP cost breakdown for margin calculation.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portHandlingCost rdf:type rdf:Property ;
    rdfs:label 'Port Handling Cost' ;
    rdfs:comment 'Port and terminal handling charges component of landed cost. Includes unloading, storage, and customs clearance fees.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the sales order document that triggered the COGS recognition event. Links to the originating transaction in SAP SD.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Unique product identifier at the SKU level for which margin is calculated. Links to the specific product variant (style-color-size combination) in the product master.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Predetermined standard cost per unit used for inventory valuation and initial COGS recognition. Basis for cost variance analysis.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strContribution rdf:type rdf:Property ;
    rdfs:label 'Str Contribution' ;
    rdfs:comment 'Contribution of this transaction to the overall sell-through rate for the SKU/season. Used to assess inventory turn and markdown risk.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Percentage' ;
    rdfs:comment 'Customs duty rate percentage applied to this product based on HS code and country of origin. Used to calculate customs duty amount.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLdpCost rdf:type rdf:Property ;
    rdfs:label 'Total Ldp Cost' ;
    rdfs:comment 'Complete landed cost including FOB, freight, insurance, duties, and inland transportation. The total cost basis for COGS and margin calculation.' ;
    rdfs:domain ind:MarginRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Unique identifier for the period close record. Primary key.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Close Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Period close ownership must link to employee for close process accountability, task assignment, and audit trail. Apparel companies require close_owner FK for SOX compliance and close process managemen' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date on which the period close process was completed and signed off. Null if close is not yet complete.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedSteps rdf:type rdf:Property ;
    rdfs:label 'Blocked Steps' ;
    rdfs:comment 'The number of checklist steps that are currently blocked and cannot proceed due to issues or dependencies.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'A description of the reason why the period close is blocked or delayed, such as missing data, unreconciled accounts, or pending approvals. Null if close is not blocked.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Code' ;
    rdfs:comment 'The code or identifier of the close checklist template used for this period close, defining the standard steps and milestones (e.g., depreciation run, accruals, intercompany reconciliation, statutory reporting).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completion Timestamp' ;
    rdfs:comment 'The date and time when the period close process was marked as complete and all checklist steps were finished.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Start Timestamp' ;
    rdfs:comment 'The date and time when the period close process was initiated and status changed from open to in_progress.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the period close process. Open indicates not started, in_progress indicates close activities underway, complete indicates all steps finished and signed off, blocked indicates close cannot proceed due to issues, reopened indicates a previously closed period has been reopened for adjustments.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeType rdf:type rdf:Property ;
    rdfs:label 'Close Type' ;
    rdfs:comment 'The purpose or scope of the close: operational for internal management reporting, statutory for regulatory and external reporting per IFRS/GAAP, management for internal KPI and EBITDA analysis, consolidation for group-level financial consolidation.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Cogs Recognition Status' ;
    rdfs:comment 'Status of COGS recognition and inventory valuation adjustments for the period, ensuring proper matching of costs to revenues.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedSteps rdf:type rdf:Property ;
    rdfs:label 'Completed Steps' ;
    rdfs:comment 'The number of checklist steps that have been completed and signed off as of the current state.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodLockIndicator rdf:type rdf:Property ;
    rdfs:label 'Period Lock Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the fiscal period has been locked in SAP S/4HANA FI/CO to prevent further postings. True if locked, False if open for postings.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Close Date' ;
    rdfs:comment 'The target date by which the period close process is scheduled to be completed, as defined in the close calendar.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Reopen Approved By' ;
    rdfs:comment 'The name of the senior finance executive who approved the reopening of a previously closed period. Null if period has not been reopened.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'The business justification or reason for reopening a previously closed period, such as error correction, audit adjustment, or late invoice receipt. Null if period has not been reopened.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reopen Timestamp' ;
    rdfs:comment 'The date and time when the period was reopened for additional postings or adjustments. Null if period has not been reopened.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Status of revenue recognition adjustments and deferrals to ensure compliance with IFRS 15 or GAAP ASC 606 revenue recognition standards.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffApproverEmail rdf:type rdf:Property ;
    rdfs:label 'Sign Off Approver Email' ;
    rdfs:comment 'The email address of the sign-off approver who provided final approval for the period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffApproverName rdf:type rdf:Property ;
    rdfs:label 'Sign Off Approver Name' ;
    rdfs:comment 'The full name of the senior finance executive (e.g., CFO, Controller) who provided final sign-off approval for the period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'The date and time when the sign-off approver formally approved and signed off on the period close, marking it as officially complete.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalChecklistSteps rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Steps' ;
    rdfs:comment 'The total number of checklist steps or tasks defined for this period close process.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Explanation or commentary on significant variances identified during the close process, such as budget vs actual variances, prior period comparisons, or unusual transactions.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPeriod rdf:type rdf:Property ;
    rdfs:label 'Analysis Period' ;
    rdfs:comment 'Fiscal period for which profit center performance is analyzed. Format YYYYMM (e.g., 202312 for December 2023). Used for period-over-period EBITDA and margin analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code identifying the group of cost centers that roll up into this profit center for cost allocation and overhead absorption in COGS calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department code for store-level or functional profit centers. Used for department-level profitability in multi-department retail stores.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Code identifying the profit center hierarchy (standard hierarchy) to which this profit center belongs. Used for multi-level profitability reporting and roll-up analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the profit center is locked for transaction posting. True when locked (no new postings allowed); False when unlocked (normal operations). Used during EOM close and financial consolidation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Business identifier for the profit center used in SAP S/4HANA. Externally-known alphanumeric code representing the autonomous business segment (e.g., brand, channel, product line, region).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full descriptive name of the profit center. Human-readable label identifying the business segment (e.g., \'Mens Footwear DTC\', \'Womens Apparel Wholesale\', \'EMEA Retail Operations\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accumulate financial transactions; planned profit centers are configured but not yet operational; inactive profit centers are temporarily suspended; closed profit centers are permanently retired.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension. Indicates whether the profit center represents a brand, sales channel (DTC/wholesale/retail), product line, geographic region, individual store, or business division.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the profit center manager for financial reporting notifications and EBITDA analysis distribution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the business leader or manager accountable for the profit centers financial performance. Typically a brand director, channel head, regional VP, or product line manager.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center used in reports and dashboards for space-constrained displays.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxItemId rdf:type rdf:Property ;
    rdfs:label 'Tax Item Id' ;
    rdfs:comment 'Unique identifier for the tax line item record in the financial system.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTaxItemId rdf:type rdf:Property ;
    rdfs:label 'Original Tax Item Id' ;
    rdfs:comment 'Reference to the original tax item record if this entry is a reversal or adjustment, enabling audit trail and reconciliation.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxItem .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'The customs declaration or entry number associated with import duty tax items, used for customs clearance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the parent financial document, used for ordering and referencing individual tax entries.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Date' ;
    rdfs:comment 'The date used to determine the applicable tax rate and rules, typically the transaction date or delivery date.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is input tax (tax paid on purchases, recoverable) or output tax (tax collected on sales, payable to authorities).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The certificate or authorization number supporting the tax exemption claim, required for audit and compliance verification.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Code' ;
    rdfs:comment 'Code indicating the reason for tax exemption or reduced rate, if applicable (e.g., export exemption, diplomatic exemption, zero-rated goods).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Full name of the tax jurisdiction or authority (e.g., United States - California, European Union, HM Revenue & Customs UK).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The percentage rate applied to calculate the tax amount (e.g., 20.00 for 20% VAT, 5.50 for 5.5% import duty).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The fiscal period or reporting period to which this tax item belongs (e.g., 2024-Q1, 2024-03, 2024-FY).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'Reference number or identifier of the tax return filing in which this tax item is included for statutory reporting to tax authorities.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax applied: VAT (Value Added Tax), sales tax, import duty, excise duty, withholding tax, or GST (Goods and Services Tax).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The base amount on which the tax is calculated, before tax is applied. Represents the net value subject to taxation.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this tax item represents withholding tax deducted at source from vendor payments.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:asnShipToLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Asn Ship To Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the destination location (distribution center, warehouse, retail store, or 3PL) where goods will be received.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:asnWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Asn Warehouse Location Id' ;
    rdfs:comment 'Identifier of the origin location (supplier facility, factory, warehouse, or 3PL) from which goods are shipped.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Foreign key linking to logistics.bill_of_lading. Business justification: Inbound shipments documented on BOLs. Linking enables receiving document validation, freight claim filing, carrier liability determination, and shipment traceability—fundamental apparel receiving oper' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillOfLading .

ind:customsEntryId rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Id' ;
    rdfs:comment 'Foreign key linking to logistics.customs_entry. Business justification: Imported ASNs tied to customs filings. Linking enables pre-clearance planning, ISF compliance validation, customs hold impact analysis, and entry-level traceability—critical for apparel trade complian' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsEntry .

ind:packingListId rdf:type rdf:Property ;
    rdfs:label 'Packing List Id' ;
    rdfs:comment 'Foreign key linking to logistics.packing_list. Business justification: ASN contains packing list details. Linking enables receiving validation (expected vs. actual), carton-level traceability, receiving productivity measurement (scan vs. manual), and vendor compliance sc' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackingList .

ind:preShipmentInspectionId rdf:type rdf:Property ;
    rdfs:label 'Pre Shipment Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: ASNs reference pre-shipment inspections conducted at supplier/factory before goods ship. Enables receiving teams to verify inspection completion, expedite receipt processing, and flag discrepancies be' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:receivingSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ASN receiving operations require supervisor assignment for dock door coordination, labor allocation, and exception handling. Critical for receiving performance metrics, labor productivity tracking, an' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shipToDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Ship To Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: ASN destination is the receiving DC. Role-prefixed to distinguish from origin. Enables dock appointment scheduling, labor planning, inbound volume forecasting, and DC capacity management—critical for ' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:shipToRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Ship To Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Store-bound advance ship notices must identify destination retail store for receiving appointment scheduling, dock door assignment, labor planning, and inbound logistics coordination at store receivin' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:sourcingPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_purchase_order. Business justification: ASNs for inbound materials/fabrics from suppliers reference the originating sourcing PO. Required for receiving planning, dock scheduling, and 3-way match validation in apparel material procurement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPurchaseOrder .

ind:thirdPartyLogisticsId rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Id' ;
    rdfs:comment 'Foreign key linking to logistics.third_party_logistics. Business justification: 3PL-managed inbound shipments. Linking enables 3PL receiving performance measurement, SLA compliance tracking, cost allocation, and service level validation—standard for apparel brands using 3PL recei' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyLogistics .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the ASN was acknowledged by the receiving system or warehouse management system.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment physically arrived at the destination location.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Scheduled date and time for the shipment to be received at the destination facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known unique business identifier for the advance shipment notice, typically provided by supplier or 3PL.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN in the receiving workflow. [ENUM-REF-CANDIDATE: draft|transmitted|acknowledged|in_transit|arrived|receiving|received|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN based on shipment purpose and origin.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the shipping carrier or logistics provider transporting the goods.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service level or shipping method used by the carrier (e.g., ground, express, air freight, ocean freight).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Commercial Invoice Number' ;
    rdfs:comment 'Commercial invoice number associated with this shipment for customs and payment reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'Shipping container identification number for ocean or intermodal freight.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Customs Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the customs value amount.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment' ;
    rdfs:comment 'Assigned dock door or bay number at the receiving facility for unloading this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Anticipated date when the shipment will arrive at the destination location for receiving.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International commercial term defining the responsibilities and costs between buyer and seller for this shipment. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Flag indicating whether the shipment contains hazardous materials requiring special handling and compliance.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Completed Timestamp' ;
    rdfs:comment 'Date and time when physical receiving of the shipment was completed and goods were put away.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Started Timestamp' ;
    rdfs:comment 'Date and time when physical receiving of the shipment began at the destination facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Flag indicating whether the shipment contains RFID-tagged items for automated receiving and tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the container or trailer for tamper detection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date when the goods were shipped from the origin location.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling requirements such as fragile, temperature-controlled, or hazardous materials.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'Supplier\'s internal reference or packing list number for this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Flag indicating whether the shipment requires temperature-controlled handling and storage.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or packages included in this ASN shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets included in this ASN shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total number of individual units (SKUs) across all line items in this ASN.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of the shipment in cubic meters.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking or waybill number for shipment visibility and tracing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Date and time when the ASN was electronically transmitted to the receiving system via EDI or API.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_invoice. Business justification: Receipt events tied to freight invoices. Linking enables landed cost posting to inventory, freight variance analysis, payment approval workflow, and freight accrual reconciliation—fundamental apparel ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightInvoice .

ind:primaryGoodsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who physically received and processed the goods.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:returnShipmentId rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.return_shipment. Business justification: Return receipts. Linking enables return processing time measurement, restocking accuracy validation, refund trigger workflow, and reverse logistics performance—standard apparel returns operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnShipment .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'The quantity of goods that passed quality inspection and were accepted into available inventory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'The total number of cartons or boxes received in this goods receipt transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Standardized code indicating the type of discrepancy found during goods receipt, if any.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Indicates whether the received goods are classified as hazardous materials requiring special handling.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of goods that was originally ordered on the purchase order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'The total number of pallets received in this goods receipt transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'Line item number on the purchase order corresponding to this goods receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Human-readable description of the product being received, including style, color, and size details.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document. Used for tracking and reference across systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt transaction in the warehouse management workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The precise date and time when the physical receipt of goods occurred at the receiving location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the goods receipt transaction based on business purpose and origin.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of goods physically received and accepted at the facility.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'Specific dock door, staging area, or receiving bay code where goods were physically received.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes recorded by the receiving personnel regarding condition, discrepancies, or special observations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'The quantity of goods that failed quality inspection and were rejected or placed on hold.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of the inventory stock status after receipt, determining availability for use or sale.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the goods receipt, calculated as received quantity multiplied by unit cost.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The inventory valuation method applied to the received goods for financial accounting purposes.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the inventory cycle count event. Primary key for the cycle count record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:primaryInventoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Employee Id' ;
    rdfs:comment 'Reference to the warehouse associate or employee assigned to perform the physical count.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Reference to the specific zone, aisle, or storage area within the location being counted. Enables zone-level cycle counting strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification of the SKU determining cycle count frequency: A (high value, frequent counts), B (medium value, moderate counts), C (low value, infrequent counts).' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Financial value of the inventory adjustment calculated as variance quantity multiplied by unit cost. Impacts COGS and inventory valuation.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'Reference number of the inventory adjustment document posted to SAP or ERP system as a result of the approved variance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicator that the variance has been posted to inventory records and financial ledgers. True when adjustment posted, False when pending.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Final quantity approved by supervisor or system after count validation and any required recounts. This quantity is posted to inventory records.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Actual date and time when the physical counting activity was completed and submitted for review.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Technology or process used to perform the physical count: manual (visual count and paper), handheld_scanner (barcode scanning device), rfid_reader (RFID tag reading), automated_system (automated storage and retrieval system count).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text comments or observations recorded by the counter during the cycle count, documenting issues, discrepancies, or special conditions.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count event, typically formatted as CC-YYYYMMDD-NNNNNN for external reference and tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReason rdf:type rdf:Property ;
    rdfs:label 'Count Reason' ;
    rdfs:comment 'Business reason triggering the cycle count: scheduled (routine calendar-based), variance_triggered (system detected discrepancy), stock_adjustment (manual correction needed), audit (compliance or quality check), neveroutofstock (NOS item verification), receiving_discrepancy (inbound variance), returns_verification (RTV or customer return validation). [ENUM-REF-CANDIDATE: scheduled|variance_triggered|stock_adjustment|audit|neveroutofstock|receiving_discrepancy|returns_verification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Actual date and time when the physical counting activity began, captured from WMS or handheld device.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count: planned (scheduled but not started), assigned (counter designated), in_progress (counting underway), completed (count finished pending review), approved (variance accepted and posted), rejected (count invalidated), recount_required (variance exceeds threshold). [ENUM-REF-CANDIDATE: planned|assigned|in_progress|completed|approved|rejected|recount_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count methodology: full (complete location inventory), partial (sample-based), abc_class (frequency based on item value), rfid_assisted (RFID technology enabled), blind (no system quantity shown), targeted (specific SKU focus).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity counted by the assigned counter during the cycle count event.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'System-recorded quantity on hand for the SKU at the location prior to the physical count, sourced from perpetual inventory records.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Quality and availability status of the counted inventory: available (ATS), reserved (allocated to orders), quarantine (quality hold), damaged (not sellable), expired (past shelf life), return_to_vendor (RTV candidate).' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicator that the variance exceeds tolerance and a recount is required before posting adjustment. True when recount needed, False otherwise.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating how many times this item has been recounted. Zero for initial count, increments with each recount attempt.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Calculated difference between expected quantity and counted quantity (counted minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Configured tolerance percentage for acceptable variance. Variances exceeding this threshold trigger recount or management approval requirements.' ;
    rdfs:domain ind:InventoryCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Unique identifier for the inventory reservation record. Primary key for the inventory reservation entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reservation .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Reference to the allocation record if this reservation has been converted to a physical allocation. Null while reservation is still pending or active.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the reservation was cancelled and inventory released. Null if reservation was not cancelled.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time when the reservation will automatically expire and release inventory back to Available to Sell (ATS) pool if not fulfilled or extended.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:extendedCount rdf:type rdf:Property ;
    rdfs:label 'Extended Count' ;
    rdfs:comment 'Number of times the reservation expiry has been extended beyond the original expiry timestamp. Used to track reservation aging and potential inventory lock issues.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfilledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Timestamp' ;
    rdfs:comment 'Date and time when the reservation was converted to a physical allocation and inventory was committed for shipment or pickup. Null if not yet fulfilled.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'Sales and fulfillment channel for which inventory is reserved: ecommerce (online direct-to-consumer), retail_store (brick-and-mortar), wholesale (B2B partner), marketplace (third-party platform), bopis (buy online pick up in store), ship_from_store (store fulfillment for online orders).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardReservationFlag rdf:type rdf:Property ;
    rdfs:label 'Hard Reservation Flag' ;
    rdfs:comment 'Indicates whether this is a hard reservation (true - guaranteed allocation, cannot be overridden) or soft reservation (false - tentative hold, can be reallocated based on priority).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExtendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Extended Timestamp' ;
    rdfs:comment 'Date and time of the most recent reservation expiry extension. Null if reservation has never been extended.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User identifier or system account that last modified the reservation record. Supports change tracking and audit trail.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the reservation was released and inventory returned to the Available to Sell (ATS) pool. Null if reservation is still active.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Business-facing unique reservation number used for tracking and reference across systems and channels.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation: active (currently holding inventory), expired (reservation period elapsed), released (inventory returned to available pool), fulfilled (reservation converted to allocation), cancelled (reservation voided), pending (awaiting confirmation).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'Date and time when the inventory reservation was created in the system. Represents the business event time when stock was earmarked.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the reservation purpose: sales order (committed to customer order), ecommerce cart (held in online shopping cart), wholesale commitment (allocated to wholesale partner), event_hold (reserved for marketing or promotional event), photo_shoot_hold (reserved for photography or content creation), sample_pull (reserved for product sampling or showroom).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source system that initiated this reservation, enabling end-to-end traceability.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch purpose: production (regular manufacturing), sample (pre-production samples), prototype (design validation), rework (quality correction), return (customer returns).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate or license number issued by the certifying body (e.g., OEKO-TEX certificate number, GOTS transaction certificate). Used for audit verification and customer transparency claims.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayConsistencyGrade rdf:type rdf:Property ;
    rdfs:label 'Colorway Consistency Grade' ;
    rdfs:comment 'Quality grade for color consistency within the lot: A (excellent match), B (acceptable variation), C (minor deviation), D (noticeable deviation), F (failed, not usable). Used for quality control and customer claims resolution.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Landed Duty Paid (LDP) cost per unit for this lot, including Free on Board (FOB) cost, freight, duties, and tariffs. Used for Cost of Goods Sold (COGS) calculation and margin analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Percentage' ;
    rdfs:comment 'Percentage of defective units identified during quality inspection. Used for supplier scorecarding and Acceptable Quality Level (AQL) compliance tracking.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dyeLotCode rdf:type rdf:Property ;
    rdfs:label 'Dye Lot Code' ;
    rdfs:comment 'Unique identifier for the dye batch used in fabric coloring. Critical for color consistency matching in apparel production. Ensures garments from same order use same dye lot to avoid shade variation.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryCode rdf:type rdf:Property ;
    rdfs:label 'Factory Code' ;
    rdfs:comment 'Identifier of the manufacturing facility or Original Equipment Manufacturer (OEM) / Original Design Manufacturer (ODM) that produced this lot. Used for supplier performance tracking and recall traceability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Status' ;
    rdfs:comment 'Current lifecycle state of the lot: active (available for use), quarantined (quality hold), consumed (fully allocated), expired (past shelf life), recalled (CPSC recall), disposed (destroyed).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business identifier for the production lot. Externally-known unique code used for traceability across supply chain partners, factories, and regulatory reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:millOriginCode rdf:type rdf:Property ;
    rdfs:label 'Mill Origin Code' ;
    rdfs:comment 'Identifier of the textile mill or raw material supplier that produced the fabric or material in this lot. Critical for material traceability and certification verification.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the lot was manufactured or produced. Critical for shelf-life calculation, warranty tracking, and regulatory compliance.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current available quantity remaining in the lot after consumption and allocation. Used for Available to Sell (ATS) and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'Total quantity manufactured in this lot. Unit of measure varies by product category (units for garments, yards/meters for fabric, kilograms for raw materials).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine Date' ;
    rdfs:comment 'Date when the lot was placed into quarantine status. Null if lot has never been quarantined.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Business reason for placing the lot in quarantine status (e.g., \'Failed color fastness test\', \'Pending certification verification\', \'Customer complaint investigation\'). Null if lot has never been quarantined.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when the recall was initiated for this lot. Null if lot has never been recalled.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this lot is subject to a Consumer Product Safety Commission (CPSC) recall or voluntary recall. True if recalled, False otherwise.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official recall identification number issued by Consumer Product Safety Commission (CPSC) or internal recall tracking number. Null if lot has never been recalled.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the lot was released from quarantine and made available for use. Null if lot has never been quarantined or is currently quarantined.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTagApplied rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Applied' ;
    rdfs:comment 'Indicates whether Radio Frequency Identification (RFID) tags have been applied to units in this lot for automated tracking and inventory accuracy. True if RFID-enabled, False otherwise.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorManagedInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Managed Inventory Flag' ;
    rdfs:comment 'Indicates whether this lot is part of a Vendor Managed Inventory (VMI) program where the supplier manages replenishment. True if VMI, False otherwise.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nosPolicyId rdf:type rdf:Property ;
    rdfs:label 'Nos Policy Id' ;
    rdfs:comment 'Unique identifier for the Never Out of Stock policy record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NosPolicy .

ind:otbBudgetId rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Id' ;
    rdfs:comment 'Foreign key linking to merchandising.otb_budget. Business justification: NOS (Never Out of Stock) inventory is planned within OTB budgets. Essential for NOS budget allocation, ensuring NOS spending aligns with merchandise financial plans and OTB compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtbBudget .

ind:allocationPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Rank' ;
    rdfs:comment 'Numeric ranking used to prioritize inventory allocation when multiple demands compete for limited stock. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automated replenishment orders are generated when inventory falls below threshold without manual intervention.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannelDtc rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel Dtc' ;
    rdfs:comment 'Indicates whether this NOS policy applies to Direct-to-Consumer e-commerce channel.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannelMarketplace rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel Marketplace' ;
    rdfs:comment 'Indicates whether this NOS policy applies to third-party marketplace channel.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannelRetail rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel Retail' ;
    rdfs:comment 'Indicates whether this NOS policy applies to physical retail store channel.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannelWholesale rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel Wholesale' ;
    rdfs:comment 'Indicates whether this NOS policy applies to wholesale distribution channel.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered in a single replenishment transaction under this NOS policy.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFloorStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Floor Stock Quantity' ;
    rdfs:comment 'The absolute minimum inventory quantity that must be maintained at all times to prevent stockouts. Triggers immediate replenishment when breached.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum order quantity required by supplier for replenishment orders under this NOS policy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nosTier rdf:type rdf:Property ;
    rdfs:label 'Nos Tier' ;
    rdfs:comment 'Classification tier indicating priority level of the NOS policy. Platinum represents highest priority items requiring maximum availability.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'Quantity increment in which replenishment orders must be placed (e.g., case packs, pallet quantities).' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier for the NOS policy, used for external reference and reporting.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed description of the NOS policy purpose, scope, and business rationale.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Descriptive name of the NOS policy for business user identification.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-form text field for additional notes, special instructions, or business context related to this NOS policy.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the NOS policy indicating whether it is actively enforced in replenishment and allocation systems.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityReplenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Replenishment Flag' ;
    rdfs:comment 'Indicates whether this NOS policy triggers priority replenishment processing, bypassing standard allocation queues.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled reviews of this NOS policy to assess continued relevance and parameter accuracy.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Required' ;
    rdfs:comment 'Indicates whether items under this NOS policy require RFID tracking for real-time inventory visibility and accuracy.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockMultiplier rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Multiplier' ;
    rdfs:comment 'Multiplier applied to base safety stock calculation to determine buffer inventory levels for NOS items. Higher values provide greater protection against demand variability.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWos rdf:type rdf:Property ;
    rdfs:label 'Target Wos' ;
    rdfs:comment 'Target inventory coverage expressed in weeks of supply. Represents the desired inventory level to maintain continuous availability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmiProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Program Flag' ;
    rdfs:comment 'Indicates whether this NOS policy is part of a Vendor Managed Inventory program where the supplier monitors and replenishes stock.' ;
    rdfs:domain ind:NosPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineHoldId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Id' ;
    rdfs:comment 'Unique identifier for the quarantine hold record. Primary key.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuarantineHold .

ind:qualityInspectionId rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Id' ;
    rdfs:comment 'Reference to the quality inspection record that identified the issue leading to quarantine hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:qualityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Quarantine disposition decisions (release, rework, scrap) require quality manager approval for compliance and financial control. Critical for defect tracking, vendor chargebacks, and regulatory compli' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfidTagId rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Id' ;
    rdfs:comment 'RFID tag identifier associated with the quarantined inventory for tracking purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Reference to the inventory record that is under quarantine or quality hold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The actual date when the quarantine hold was resolved and disposition decision was executed.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the quarantine hold was resolved, including time of day.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the quarantine hold is related to regulatory compliance or safety standards violation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number or identifier of the corrective action plan associated with this quarantine hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Boolean indicator whether the quarantine hold affects customer orders or shipments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'Name or identifier of the person who approved the final disposition decision.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on how to handle the quarantined inventory (return to stock, RTV=Return to Vendor, destroy, rework, donate, transfer to another location).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Additional notes or comments regarding the disposition decision and execution.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Release Date' ;
    rdfs:comment 'Anticipated date when the quarantine hold will be resolved and inventory may be released or disposed.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Hold Approved By' ;
    rdfs:comment 'Name or identifier of the quality manager or authorized person who approved the quarantine hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated By' ;
    rdfs:comment 'Name or identifier of the person, system, or department that initiated the quarantine hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdQuantity rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity' ;
    rdfs:comment 'The quantity of inventory units placed under quarantine hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Hold Quantity Uom' ;
    rdfs:comment 'Unit of measure for the hold quantity (EA=Each, CS=Case, PL=Pallet, CTN=Carton, PR=Pair).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Categorical code indicating the primary reason for placing inventory under quarantine hold.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the inventory was placed under quarantine or quality hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'The date when the quarantine hold was initiated and inventory was blocked from sale or shipment.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the quarantine hold was initiated, including time of day.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the quarantine hold record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingEventReference rdf:type rdf:Property ;
    rdfs:label 'Initiating Event Reference' ;
    rdfs:comment 'Reference number or identifier of the event that triggered the quarantine hold (e.g., quality inspection ID, recall notice number, complaint ticket number).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingEventType rdf:type rdf:Property ;
    rdfs:label 'Initiating Event Type' ;
    rdfs:comment 'Type of event that triggered the quarantine hold (quality inspection failure, supplier defect notification, CPSC recall, customer complaint, internal audit finding, customs flag).' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase order number associated with the quarantined inventory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number or case number from the regulatory authority related to the hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed' ;
    rdfs:comment 'Boolean indicator whether root cause analysis has been completed for the issue that triggered the quarantine hold.' ;
    rdfs:domain ind:QuarantineHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the replenishment order record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:allocationPlanId rdf:type rdf:Property ;
    rdfs:label 'Allocation Plan Id' ;
    rdfs:comment 'Identifier of the merchandise allocation plan that generated this replenishment order, if the order is part of a planned allocation strategy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationPlan .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Identifier of the logistics carrier or 3PL (Third-Party Logistics) provider responsible for transporting the replenishment shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:destinationLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the retail store, distribution center, or warehouse that will receive the replenished inventory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:destinationRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Destination Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Store replenishment orders from DC to retail stores must track destination store for fulfillment planning, store WOS management, replenishment lead time tracking, and store-level inventory flow optimi' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:primaryReplenishmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Employee Id' ;
    rdfs:comment 'Identifier of the inventory planner or merchandise planner responsible for reviewing and approving this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReplenishmentWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution center, or 3PL facility from which inventory will be shipped to fulfill this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:routingGuideId rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Id' ;
    rdfs:comment 'Foreign key linking to logistics.routing_guide. Business justification: Replenishment follows routing rules. Linking enables allocation plan freight assumptions validation, routing compliance, cost-to-serve accuracy, and replenishment cost optimization—critical for appare' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingGuide .

ind:vmiProgramId rdf:type rdf:Property ;
    rdfs:label 'Vmi Program Id' ;
    rdfs:comment 'Foreign key linking to inventory.vmi_program. Business justification: Replenishment orders generated automatically by VMI programs should reference the VMI program that triggered them. This enables tracking of VMI program performance and distinguishes vendor-managed rep' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmiProgram .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date when the replenishment order was received and confirmed at the destination location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atsQuantityAtRequest rdf:type rdf:Property ;
    rdfs:label 'Ats Quantity At Request' ;
    rdfs:comment 'The ATS (Available to Sell) inventory quantity at the destination location when the replenishment order was created, representing on-hand minus allocated/reserved inventory.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledReason rdf:type rdf:Property ;
    rdfs:label 'Cancelled Reason' ;
    rdfs:comment 'Free-text explanation of why the replenishment order was cancelled, if applicable (e.g., inventory no longer needed, source location stockout, budget constraints).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'The target maximum inventory level at the destination location, used in min/max replenishment logic to determine order quantity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityAtRequest rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity At Request' ;
    rdfs:comment 'The physical inventory quantity available at the destination location at the time the replenishment order was created, used to calculate replenishment need.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory level threshold at the destination location that triggered this replenishment order, calculated based on lead time demand and safety stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment order: proposed (system-generated, awaiting review), approved (planner-approved), released (sent to WMS for execution), in_transit (shipment en route), received (goods received at destination), fulfilled (order complete), cancelled (order voided), rejected (approval denied). [ENUM-REF-CANDIDATE: proposed|approved|released|in_transit|received|fulfilled|cancelled|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger' ;
    rdfs:comment 'The business rule or condition that triggered this replenishment order: below reorder point, NOS (Never Out of Stock) breach, OTB (Open-to-Buy) driven, demand forecast, safety stock breach, or allocation plan execution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of how the replenishment order was initiated: automatic (system-triggered by min/max rules or MRP), manual (planner-initiated), VMI (Vendor Managed Inventory), emergency (expedited NOS breach), seasonal (collection-driven), or promotional (event-driven).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The target date by which the destination location requires the replenished inventory to arrive, based on demand forecast or min/max rules.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of units requested by the replenishment algorithm or planner to bring inventory to target levels.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'The minimum inventory buffer maintained at the destination location to protect against demand variability and supply disruptions.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The delivery speed commitment for the replenishment shipment: standard (5-7 days), expedited (2-3 days), next_day, two_day, economy (7-10 days).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'The transportation mode used for the replenishment shipment: ground (truck), air (air freight), ocean (container ship), rail (train), intermodal (multi-mode), courier (express delivery).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'The actual quantity of units shipped from the source location, may differ from approved quantity due to picking variances or stock adjustments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Transaction identifier from the POS system when the item was sold. Links RFID data to sales transaction for reconciliation and customer analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:returnTransactionId rdf:type rdf:Property ;
    rdfs:label 'Return Transaction Id' ;
    rdfs:comment 'Transaction identifier for the return event. Links to return transaction record for return reason and disposition analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnTransaction .

ind:attachmentLocation rdf:type rdf:Property ;
    rdfs:label 'Attachment Location' ;
    rdfs:comment 'Facility where the tag was attached to the product. Typically a CMT (Cut Make Trim) factory, OEM facility, or distribution center.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attachment Timestamp' ;
    rdfs:comment 'Date and time when the RFID tag was physically attached to the garment, footwear, or accessory. Marks the start of item-level tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authentication Timestamp' ;
    rdfs:comment 'Date and time when the RFID tag was authenticated. Used for supply chain security and brand protection.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Reason why the RFID tag was decommissioned. Used for shrinkage analysis, loss prevention, and tag quality management. [ENUM-REF-CANDIDATE: sold|damaged|lost|stolen|expired|tag_failure|product_disposal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommission Timestamp' ;
    rdfs:comment 'Date and time when the RFID tag was decommissioned and removed from active tracking. Occurs after final sale, disposal, or tag failure.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encodingLocation rdf:type rdf:Property ;
    rdfs:label 'Encoding Location' ;
    rdfs:comment 'Facility or location where the RFID tag was encoded. May be a manufacturing plant, distribution center, or third-party logistics provider.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Encoding Timestamp' ;
    rdfs:comment 'Date and time when the RFID tag was encoded with EPC data. Typically occurs at the manufacturing facility or distribution center.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epc rdf:type rdf:Property ;
    rdfs:label 'Epc' ;
    rdfs:comment 'Globally unique Electronic Product Code encoded on the RFID tag, typically in SGTIN-96 or SGTIN-198 format. Enables item-level identification across the supply chain.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReadLocation rdf:type rdf:Property ;
    rdfs:label 'First Read Location' ;
    rdfs:comment 'Location where the tag was first read in the system. Typically a receiving dock at a distribution center or warehouse.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Read Timestamp' ;
    rdfs:comment 'Date and time of the first successful read of this RFID tag in the system. Marks entry into active inventory tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the RFID tag has been authenticated as genuine. Critical for luxury goods and anti-counterfeiting programs.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReusable rdf:type rdf:Property ;
    rdfs:label 'Is Reusable' ;
    rdfs:comment 'Indicates whether the RFID tag is designed for reuse across multiple products or is single-use. Reusable tags are common for returnable assets and rental programs.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReadContext rdf:type rdf:Property ;
    rdfs:label 'Last Read Context' ;
    rdfs:comment 'Business context or event type of the last RFID read. Indicates the operational process during which the tag was scanned. [ENUM-REF-CANDIDATE: receiving|cycle_count|inventory_audit|pos_sale|fitting_room|exit_gate|shipment|return — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Last Read Device Code' ;
    rdfs:comment 'Identifier of the RFID reader device that performed the last successful read. Links to reader device master for troubleshooting and analytics.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadLocation rdf:type rdf:Property ;
    rdfs:label 'Last Read Location' ;
    rdfs:comment 'Physical location where the tag was last read. May be a warehouse zone, store department, fitting room, or point-of-sale terminal.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadSignalStrength rdf:type rdf:Property ;
    rdfs:label 'Last Read Signal Strength' ;
    rdfs:comment 'Signal strength in decibels-milliwatts (dBm) of the last successful read. Used for read quality assessment and reader placement optimization.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Read Timestamp' ;
    rdfs:comment 'Most recent date and time when the RFID tag was successfully read by an RFID reader. Used for real-time inventory visibility and movement tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Write-protection status of the RFID tag memory. Locked tags cannot be rewritten, permalocked tags are permanently locked. Used for security and data integrity.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLocation rdf:type rdf:Property ;
    rdfs:label 'Return Location' ;
    rdfs:comment 'Store or facility where the item was returned. May differ from original sale location for omnichannel returns.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Date and time when the item was returned by the customer. Enables return rate analysis and reverse logistics tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:saleLocation rdf:type rdf:Property ;
    rdfs:label 'Sale Location' ;
    rdfs:comment 'Store or channel where the item was sold. Links to retail store master or e-commerce fulfillment center.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sale Timestamp' ;
    rdfs:comment 'Date and time when the item with this RFID tag was sold at point of sale. Marks transition from inventory to sold status.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tagEncodingStandard rdf:type rdf:Property ;
    rdfs:label 'Tag Encoding Standard' ;
    rdfs:comment 'EPC encoding scheme used on the tag. SGTIN (Serialized Global Trade Item Number) is most common for apparel SKUs, SSCC for logistics units, GRAI for returnable assets, GIAI for fixed assets.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagLifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Lifecycle Status' ;
    rdfs:comment 'Current state of the RFID tag in its operational lifecycle. Tracks progression from encoding through sale or decommissioning. [ENUM-REF-CANDIDATE: encoded|attached|in_transit|received|in_store|sold|returned|decommissioned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagManufacturer rdf:type rdf:Property ;
    rdfs:label 'Tag Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the RFID tag. Used for quality tracking and vendor performance analysis.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagMemorySize rdf:type rdf:Property ;
    rdfs:label 'Tag Memory Size' ;
    rdfs:comment 'Memory capacity of the RFID tag in bits. Determines how much data can be encoded on the tag beyond the basic EPC.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagModel rdf:type rdf:Property ;
    rdfs:label 'Tag Model' ;
    rdfs:comment 'Specific model or part number of the RFID tag. Different models may have varying read ranges, durability, and form factors.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Radio frequency type of the RFID tag. UHF (Ultra High Frequency) for long-range warehouse and store reads, HF (High Frequency) or NFC (Near Field Communication) for close-proximity interactions, LF (Low Frequency) for specialized applications.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReadCount rdf:type rdf:Property ;
    rdfs:label 'Total Read Count' ;
    rdfs:comment 'Cumulative number of times this RFID tag has been successfully read since encoding. Used for tag performance analysis and lifecycle management.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuLocationId rdf:type rdf:Property ;
    rdfs:label 'Sku Location Id' ;
    rdfs:comment 'Unique identifier for the SKU-location association record. Primary key for the sku_location entity.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmiVendorId rdf:type rdf:Property ;
    rdfs:label 'Vmi Vendor Id' ;
    rdfs:comment 'Reference to the vendor responsible for managing inventory replenishment under the VMI program for this SKU-location.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Quantity of inventory at this location that has been allocated to specific customer orders but not yet picked or shipped.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Date when the SKU-location assignment became or will become effective. Used for planning seasonal slotting changes and location transitions.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Expiration Date' ;
    rdfs:comment 'Date when the SKU-location assignment expires or is scheduled to be deactivated. Null for permanent assignments.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current status of the SKU-location assignment indicating whether the assignment is active and operational or in another state.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsQuantity rdf:type rdf:Property ;
    rdfs:label 'Ats Quantity' ;
    rdfs:comment 'Available to Sell quantity at this location. Represents inventory available for customer orders after deducting allocated, reserved, and quality hold quantities.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stock Quantity' ;
    rdfs:comment 'Current on-hand inventory quantity of the SKU at this specific location. Real-time stock level updated by warehouse transactions.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Frequency in days for conducting cycle counts of this SKU at this location. High-value or high-velocity items typically have shorter cycle count intervals.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'Quantity of inventory at this location that has been identified as damaged and is pending disposition (return to vendor, disposal, or salvage).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of inventory in transit to this location from suppliers, other warehouses, or distribution centers. Expected to arrive and increase available stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed for this SKU at this location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Units' ;
    rdfs:comment 'Maximum capacity of the storage location expressed in inventory units (e.g., number of units, cases, or pallets that can be stored).' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCapacityVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Volume Cubic Meters' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location expressed in cubic meters. Used for space utilization and slotting optimization.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location expressed in kilograms. Ensures safe loading and compliance with facility structural limits.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location type indicating its operational purpose within the warehouse or facility.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Stock Quantity' ;
    rdfs:comment 'Maximum inventory quantity that should be stored at this location. Defines the upper limit for replenishment to prevent overstocking.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Stock Quantity' ;
    rdfs:comment 'Minimum inventory quantity that should be maintained at this location to trigger replenishment. Part of min-max inventory control strategy.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Scheduled date for the next cycle count of this SKU at this location based on the cycle count frequency.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nosClassificationTier rdf:type rdf:Property ;
    rdfs:label 'Nos Classification Tier' ;
    rdfs:comment 'Classification tier indicating the priority level for NOS (Never Out of Stock) strategy. Tier 1 represents highest priority items that must always be in stock.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nosPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Nos Policy Code' ;
    rdfs:comment 'Code identifying the specific NOS policy applied to this SKU-location combination, defining replenishment rules, safety stock levels, and escalation procedures.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowLocationCode rdf:type rdf:Property ;
    rdfs:label 'Overflow Location Code' ;
    rdfs:comment 'Code identifying the overflow or secondary storage location for this SKU when primary location capacity is exceeded.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence Number' ;
    rdfs:comment 'Sequence number defining the order in which this location should be picked during wave picking or batch picking operations to optimize picker travel path.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPickLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Location Flag' ;
    rdfs:comment 'Indicates whether this location is designated as the primary pick location for the SKU. True if this is the first location pickers should retrieve inventory from.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity of inventory at this location that is held in quarantine pending quality inspection, compliance verification, or issue resolution.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level at which replenishment should be triggered for this SKU at this location. When ATS (Available to Sell) falls below this threshold, a replenishment order is generated.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Number of days required to replenish inventory at this location from the time a replenishment order is triggered until goods are received and available.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'Method used to trigger and calculate replenishment for this SKU at this location (e.g., min-max, reorder point, periodic review, demand-driven, VMI).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Slotting Priority Rank' ;
    rdfs:comment 'Numerical rank indicating the priority of this SKU for optimal warehouse slotting. Lower numbers indicate higher priority for placement in prime pick locations.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmiIndicator rdf:type rdf:Property ;
    rdfs:label 'Vmi Indicator' ;
    rdfs:comment 'Indicates whether this SKU-location is managed under a VMI (Vendor Managed Inventory) program where the supplier is responsible for monitoring and replenishing inventory levels.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wosCurrent rdf:type rdf:Property ;
    rdfs:label 'Wos Current' ;
    rdfs:comment 'Current WOS (Weeks of Supply) calculated as current stock quantity divided by average weekly demand. Indicates how many weeks the current inventory will last.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wosTarget rdf:type rdf:Property ;
    rdfs:label 'Wos Target' ;
    rdfs:comment 'Target WOS (Weeks of Supply) for this SKU at this location. Represents the desired number of weeks of inventory to maintain based on forecasted demand.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement record.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: High-value transfers, write-offs, and exception movements require managerial approval for financial control and shrink prevention. Standard SOX control for inventory adjustments exceeding thresholds. ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderPurchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Purchase Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.purchase_order_line. Business justification: Inbound stock movements (receipts, putaways) require PO line linkage for 3-way match validation (PO/ASN/GR), landed cost allocation, supplier performance measurement, and accounts payable reconciliati' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderPurchaseOrderLine .

ind:primaryStockWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Location Id' ;
    rdfs:comment 'Identifier of the location from which inventory is being moved. Null for goods receipts from external suppliers. Links to warehouse, store, or distribution center master.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:productionLotId rdf:type rdf:Property ;
    rdfs:label 'Production Lot Id' ;
    rdfs:comment 'Foreign key linking to production.lot. Business justification: Finished goods receipts from production must link to production lot for batch traceability, quality tracking, and recall management. Critical for apparel compliance (country of origin, labor certifica' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.transfer_order. Business justification: Stock movements executed as part of transfer orders should link to the originating transfer_order. This connects the transactional movement record to the operational transfer request, enabling trackin' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business code for the destination location (e.g., warehouse code, store number, DC identifier). Human-readable identifier for reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classification of the destination location to enable location-type-specific analytics and reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level classification of the movement transaction type for reporting and analytics. Groups detailed movement types into business-meaningful categories.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Document Number' ;
    rdfs:comment 'The externally-known business document number for this inventory movement (e.g., goods receipt number, transfer order number, adjustment document number). Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The quantity of inventory moved in this transaction. Positive for receipts and negative for issues. Expressed in the base unit of measure.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction. Indicates whether the movement has been finalized in inventory records or is still in process.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical inventory movement occurred or was recorded in the warehouse management system. Used for real-time inventory tracking and RFID event correlation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'Three-digit code classifying the nature of the inventory movement (e.g., 101=Goods Receipt from PO, 311=Transfer Posting, 551=Scrapping, 601=Goods Issue for Delivery). Aligns with SAP movement type taxonomy.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the movement reason. Used when reason code alone is insufficient to explain the transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Number' ;
    rdfs:comment 'The line item number within the reference document that this movement relates to. Enables line-level traceability.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document that triggered or authorized this inventory movement. Enables traceability back to originating business transaction. [ENUM-REF-CANDIDATE: purchase_order|sales_order|transfer_order|return_authorization|adjustment_request|delivery_note|asn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Business code for the source location (e.g., warehouse code, store number, DC identifier). Human-readable identifier for reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationType rdf:type rdf:Property ;
    rdfs:label 'Source Location Type' ;
    rdfs:comment 'Classification of the source location to enable location-type-specific analytics and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of inventory based on time in stock and seasonal relevance. Current season represents fresh merchandise, prior season is last season carryover, aged is multi-season old inventory, and clearance is marked for liquidation. Drives markdown strategies and inventory valuation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationGroup rdf:type rdf:Property ;
    rdfs:label 'Allocation Group' ;
    rdfs:comment 'Classification code used to group inventory for allocation planning. Allocation groups define how inventory is distributed across channels and locations based on demand forecasts, store grades, and strategic priorities.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountVariance rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance' ;
    rdfs:comment 'Difference between system on-hand quantity and physical count quantity from the last cycle count. Positive values indicate physical surplus, negative values indicate shortage. Used to measure inventory accuracy and identify shrinkage.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heldQuantity rdf:type rdf:Property ;
    rdfs:label 'Held Quantity' ;
    rdfs:comment 'Quantity placed on administrative hold for quality inspection, regulatory compliance review, or investigation. Inventory is physically present but temporarily unavailable for sale or allocation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent inventory adjustment transaction at this location. Adjustments include cycle count corrections, damage write-offs, and system corrections. Used for audit trail and inventory accuracy monitoring.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date of the most recent inventory receipt at this location. Used to track inventory freshness and identify slow-moving stock.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent sale or allocation of this SKU from this location. Used to identify dormant inventory and trigger markdown or transfer decisions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nosFlag rdf:type rdf:Property ;
    rdfs:label 'Nos Flag' ;
    rdfs:comment 'Indicates whether this SKU is designated as a never-out-of-stock item requiring continuous availability. NOS items receive priority replenishment and higher safety stock levels to prevent stockouts.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical inventory quantity currently present at the location. Represents the actual count of units physically available in the facility, verified through cycle counts and RFID tracking.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates the legal ownership of the inventory. Owned is company-owned stock, consignment is supplier-owned until sold, vendor-owned is VMI stock, and customer-owned is inventory held on behalf of wholesale customers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Business date for which this stock position record represents the inventory state. Enables point-in-time inventory analysis and historical trend reporting. Updated daily through batch processing.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current operational status of the inventory at this location. Available indicates sellable stock, reserved is allocated to orders, quarantine is under quality review, damaged is unsellable, in-transit is being received, and blocked is administratively restricted.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Flag' ;
    rdfs:comment 'Indicates whether this inventory is managed under a vendor-managed inventory program where the supplier monitors stock levels and triggers replenishment. VMI programs shift inventory management responsibility to suppliers.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wos rdf:type rdf:Property ;
    rdfs:label 'Wos' ;
    rdfs:comment 'Number of weeks the current on-hand inventory will last based on forecasted demand. Calculated as on-hand quantity divided by average weekly sales rate. Key metric for inventory health and replenishment planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Unique identifier for the stock valuation record.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationAreaId rdf:type rdf:Property ;
    rdfs:label 'Valuation Area Id' ;
    rdfs:comment 'Identifier for the valuation area (plant, warehouse, distribution center, or store) where inventory is valued. Links to location master.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValuationArea .

ind:agedInventoryProvision rdf:type rdf:Property ;
    rdfs:label 'Aged Inventory Provision' ;
    rdfs:comment 'Provision amount for obsolete, slow-moving, or aged inventory that may not be sold at full value. Reflects inventory obsolescence risk.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Amount' ;
    rdfs:comment 'Portion of inventory value allocated to COGS for goods sold during the period. Used for profit and loss calculation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUnitCost rdf:type rdf:Property ;
    rdfs:label 'Current Unit Cost' ;
    rdfs:comment 'The effective unit cost currently applied for valuation, based on the valuation method in use (standard cost or moving average price).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'General Ledger account number to which this inventory valuation is posted for balance sheet reporting.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days inventory remains in stock before being sold. Calculated as (average inventory value / COGS) × 365. Key metric for inventory efficiency.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryWriteDownAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Write Down Amount' ;
    rdfs:comment 'Total amount written down from book value to net realizable value when NRV is lower than cost. Impacts Cost of Goods Sold (COGS) and profitability.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCostUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Update Date' ;
    rdfs:comment 'Date when the unit cost (standard cost or moving average price) was last updated or recalculated.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this SKU at this valuation area. Used to assess valuation accuracy.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Reserve Amount' ;
    rdfs:comment 'Reserve amount set aside to account for anticipated future markdowns on seasonal or slow-moving inventory. Reduces net realizable value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Reserve Percentage' ;
    rdfs:comment 'Percentage of total stock value reserved for anticipated markdowns, typically based on historical markdown rates and seasonal lifecycle stage.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average unit cost recalculated with each goods receipt when moving average valuation method is used.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRealizableValue rdf:type rdf:Property ;
    rdfs:label 'Net Realizable Value' ;
    rdfs:comment 'Estimated selling price in the ordinary course of business less estimated costs of completion and sale. Inventory must be valued at lower of cost or NRV.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Difference between standard cost and actual purchase price for goods received. Tracked separately in standard costing environments.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalWriteDownPercentage rdf:type rdf:Property ;
    rdfs:label 'Seasonal Write Down Percentage' ;
    rdfs:comment 'Percentage write-down applied to inventory value for end-of-season or aged seasonal merchandise to reflect lower net realizable value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Stock Quantity' ;
    rdfs:comment 'Total quantity of inventory on hand at the valuation area for this SKU at the valuation date.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total book value of inventory calculated as total stock quantity multiplied by current unit cost. Represents balance sheet inventory value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Valuation Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for any manual adjustment made to the valuation (e.g., physical count variance, damage, theft, pricing error).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which this valuation snapshot was taken. Typically end-of-month (EOM) or end-of-season for financial reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current status of the valuation record: active (current), frozen (locked for period close), adjusted (manual adjustment applied), written_off (inventory disposed), under_review (pending audit).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Number of weeks the current inventory level will last based on forecasted or historical sales rate. Critical for replenishment planning.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTransferEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that initiated the transfer order.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryTransferWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Warehouse Location Id' ;
    rdfs:comment 'Identifier of the originating location from which inventory is being transferred (warehouse, distribution center, retail store, or third-party logistics facility).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:sourceRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Source Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Inter-store transfers originate from source retail stores for stock balancing, allocation optimization, and ship-from-store fulfillment - requires tracking source store for inventory deduction, transf' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:tertiaryTransferCancelledByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Transfer Cancelled By User Employee Id' ;
    rdfs:comment 'Identifier of the user who cancelled the transfer order, if applicable.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFreightCost rdf:type rdf:Property ;
    rdfs:label 'Actual Freight Cost' ;
    rdfs:comment 'The actual transportation cost incurred for the transfer order in the base currency.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when the transfer order was fully received and closed in the system.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The actual quantity of units confirmed available and allocated for transfer at the source location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'The estimated transportation cost for the transfer order in the base currency.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining who bears the cost and risk of transportation: prepaid, collect, third party, Free on Board (FOB) origin, or FOB destination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Performance indicator showing whether the transfer was delivered on time and in full quantity as requested.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date by which the inventory is requested to be shipped from the source location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTracked rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracked' ;
    rdfs:comment 'Indicates whether the transferred inventory is tracked using RFID technology for real-time visibility.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the upstream business document that triggered this transfer order (e.g., allocation plan ID, replenishment rule ID).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of upstream business document or process that triggered the creation of this transfer order.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the transfer requires temperature-controlled transportation and storage conditions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-facing unique reference number for the transfer order, used for tracking and communication across systems and stakeholders.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the transfer order indicating its progression through the fulfillment workflow. [ENUM-REF-CANDIDATE: draft|approved|in_transit|received|cancelled|partially_received|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer order purpose: replenishment (store restocking), rebalancing (inventory optimization), recall (product withdrawal), return (reverse logistics), consolidation (inventory centralization), or emergency (urgent fulfillment).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: VMI programs require dedicated program managers to coordinate vendor relationships, monitor SLA compliance, resolve discrepancies, and conduct performance reviews. Essential for accountability in vend' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the VMI program agreement automatically renews at the end of its term unless terminated by either party.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the legal contract document governing this VMI program agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharingModel rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Model' ;
    rdfs:comment 'Model defining how inventory carrying costs, obsolescence risk, and markdowns are shared between supplier and retailer.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Frequency' ;
    rdfs:comment 'Frequency at which inventory position, sales, and forecast data are shared with the supplier through EDI or other integration methods.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIntegrationMethod rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Method' ;
    rdfs:comment 'Method used for electronic exchange of inventory data with supplier. EDI 846 (Inventory Inquiry/Advice), EDI 852 (Product Activity Data), EDI 867 (Product Transfer and Resale Report), API (Application Programming Interface), portal (web-based), or manual file exchange.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCoverage rdf:type rdf:Property ;
    rdfs:label 'Facility Coverage' ;
    rdfs:comment 'List of warehouse, distribution center, or retail store locations covered by this VMI program. May reference facility codes or location identifiers.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSettlementTerms rdf:type rdf:Property ;
    rdfs:label 'Financial Settlement Terms' ;
    rdfs:comment 'Description of payment terms, pricing agreements, and financial settlement conditions between retailer and supplier for VMI inventory.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastSharingEnabled rdf:type rdf:Property ;
    rdfs:label 'Forecast Sharing Enabled' ;
    rdfs:comment 'Indicates whether demand forecasts are shared with the supplier to enable proactive replenishment planning.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownResponsibility rdf:type rdf:Property ;
    rdfs:label 'Markdown Responsibility' ;
    rdfs:comment 'Party responsible for absorbing markdown costs when VMI inventory must be sold at reduced prices.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next formal performance review of this VMI program.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipTransferPoint rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Point' ;
    rdfs:comment 'Point in the supply chain where inventory ownership transfers from supplier to retailer. Critical for consignment vs owned inventory models. FOB (Free on Board) terms define shipping responsibility.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days allowed for payment after invoice date or ownership transfer, depending on program terms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Scheduled frequency for formal review of supplier performance against VMI program SLAs and KPIs.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary supplier contact responsible for managing this VMI program.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency' ;
    rdfs:comment 'Scheduled frequency at which the supplier reviews inventory levels and initiates replenishment orders.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToVendorAllowed rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Allowed' ;
    rdfs:comment 'Indicates whether the retailer can return unsold or slow-moving VMI inventory back to the supplier.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Enabled' ;
    rdfs:comment 'Indicates whether RFID technology is used for real-time inventory visibility and tracking within this VMI program.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtvTerms rdf:type rdf:Property ;
    rdfs:label 'Rtv Terms' ;
    rdfs:comment 'Conditions and restrictions governing returns of VMI inventory to the supplier, including timeframes, restocking fees, and eligible reasons.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCategory rdf:type rdf:Property ;
    rdfs:label 'Scope Category' ;
    rdfs:comment 'Product category or merchandise hierarchy level covered by this VMI program (e.g., Basic Tees, Denim Bottoms, Trims and Notions).' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeSkuList rdf:type rdf:Property ;
    rdfs:label 'Scope Sku List' ;
    rdfs:comment 'Comma-separated list of specific SKUs included in the VMI program scope. Used when program covers specific items rather than entire categories.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Rate Target Pct' ;
    rdfs:comment 'Target fill rate percentage that the supplier must achieve, representing the percentage of demand that must be fulfilled from available inventory.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaLeadTimeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Lead Time Target Days' ;
    rdfs:comment 'Maximum lead time in days that the supplier commits to for replenishment orders under this VMI program.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaOtifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Otif Target Pct' ;
    rdfs:comment 'Target OTIF percentage that the supplier must achieve, representing orders delivered on time and complete.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Target Max Stock Level' ;
    rdfs:comment 'Maximum inventory level (in units) that should not be exceeded to avoid overstock and carrying cost issues.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMinStockLevel rdf:type rdf:Property ;
    rdfs:label 'Target Min Stock Level' ;
    rdfs:comment 'Minimum inventory level (in units) that the supplier must maintain to avoid stockouts. Triggers replenishment when inventory falls below this threshold.' ;
    rdfs:domain ind:VmiProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the VMI program agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:energyConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Id' ;
    rdfs:comment 'Foreign key linking to sustainability.energy_consumption. Business justification: Warehouse locations roll up to facilities for scope 1/2 emissions reporting. Location-level energy tracking enables zone-specific efficiency programs, renewable energy allocation, and granular carbon ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyConsumption .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Warehouse facilities require designated facility managers responsible for operations, safety compliance, labor scheduling, and performance. Essential for operational accountability, incident reporting' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteRecordId rdf:type rdf:Property ;
    rdfs:label 'Waste Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_record. Business justification: Waste generation tracked by warehouse location for zero-waste-to-landfill (ZWTL) programs, circular economy initiatives, and facility-level diversion rate reporting. Location-level data enables target' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteRecord .

ind:waterUsageId rdf:type rdf:Property ;
    rdfs:label 'Water Usage Id' ;
    rdfs:comment 'Foreign key linking to sustainability.water_usage. Business justification: Facility water consumption tracking requires location-level granularity for operational efficiency, water stewardship programs, and ESG disclosure. Warehouse locations aggregate to facility-level wate' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterUsage .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'Identifier for the physical aisle where the location resides. Used for travel optimization and picker routing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Identifier for the individual bin or position within the shelf. Represents the most granular storage unit.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether this location is within a customs bonded area where imported goods can be stored without paying duties until they are released for domestic consumption.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Meters' ;
    rdfs:comment 'Maximum cubic volume (in cubic meters) that can be stored in this location. Used for dimensional slotting and space utilization analysis.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Maximum number of inventory units (eaches, cases, pallets) that can be stored in this location. Used for slotting optimization and capacity planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity (in kilograms) for this location. Used to ensure safe storage and compliance with structural load limits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'Indicates whether this location is certified and approved for storing hazardous materials (e.g., certain dyes, chemicals, aerosols) in compliance with safety regulations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the warehouse location for operational reference and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the warehouse location. Determines whether the location is available for putaway, picking, or other warehouse operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether inventory from different lots or batches of the same SKU can be stored together in this location. Important for lot traceability and FIFO compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether multiple different SKUs can be stored in this location simultaneously. Forward pick locations typically allow mixed SKUs while reserve locations may be single-SKU.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence used to optimize picker travel paths during order fulfillment. Lower numbers are visited first in the pick route.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayPriority rdf:type rdf:Property ;
    rdfs:label 'Putaway Priority' ;
    rdfs:comment 'Priority ranking for directed putaway operations. Higher priority locations are filled first during receiving and replenishment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier for the rack or bay within the aisle. Part of the hierarchical location structure.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTriggerLevel rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Level' ;
    rdfs:comment 'Inventory quantity threshold that triggers automatic replenishment from reserve to forward pick locations. Supports Never Out of Stock (NOS) strategies.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Code' ;
    rdfs:comment 'Identifier for the shelf or level within the rack. Part of the hierarchical location structure.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the location. Critical for storing temperature-sensitive apparel materials, adhesives, or specialty items.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal coordinate (X-axis) of the location within the facility floor plan. Used for travel distance calculations and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical coordinate (Y-axis) of the location within the facility floor plan. Used for travel distance calculations and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zCoordinate rdf:type rdf:Property ;
    rdfs:label 'Z Coordinate' ;
    rdfs:comment 'Height coordinate (Z-axis) of the location representing vertical position or level. Used for multi-level warehouse operations and automated storage systems.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsCodeId rdf:type rdf:Property ;
    rdfs:label 'Hs Code Id' ;
    rdfs:comment 'Foreign key linking to logistics.hs_code. Business justification: Bills of lading declare HS codes for the commodity being transported. N:1 relationship. Normalizes hs_code string to FK.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsCode .

ind:originFactorySupplierFactoryId rdf:type rdf:Property ;
    rdfs:label 'Origin Factory Supplier Factory Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_factory. Business justification: BOL requires factory origin for customs documentation accuracy, certificate-of-origin cross-validation, and freight consolidation planning by factory location. Factory address on BOL must match suppli' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierFactory .

ind:shippingCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shipping Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Shipping coordinator prepares and validates BOL documents for export/import compliance. Required for audit trails, customs documentation accountability, and trade compliance reporting in apparel inter' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Externally-known unique document number issued by the carrier for this shipment. Required for customs entry filing and letter of credit negotiation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolStatus rdf:type rdf:Property ;
    rdfs:label 'Bol Status' ;
    rdfs:comment 'Current lifecycle status of the BOL document and associated shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolType rdf:type rdf:Property ;
    rdfs:label 'Bol Type' ;
    rdfs:comment 'Classification of the BOL document type indicating release method and legal status. Original requires physical document for cargo release; telex/express allow electronic release.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed description of the apparel cargo being shipped, including product type, material composition, and any special characteristics. Required for customs classification.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Complete delivery address of the consignee including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal name of the party to whom the goods are being shipped and who will take title upon delivery.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cubicVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cubic Volume M3' ;
    rdfs:comment 'Total volumetric measurement of the cargo in cubic meters, used for dimensional weight pricing and container utilization planning.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Total commercial value of the cargo declared for insurance and customs purposes. Used to calculate duty, insurance premiums, and carrier liability limits.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared cargo value.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightForwarderReference rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Reference' ;
    rdfs:comment 'Internal reference number assigned by the freight forwarder or customs broker managing this shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total weight of the cargo including packaging materials, measured in kilograms. Required for freight cost calculation and customs declaration.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notifyPartyContact rdf:type rdf:Property ;
    rdfs:label 'Notify Party Contact' ;
    rdfs:comment 'Phone number or email address for the notify party to coordinate cargo release and customs clearance.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'Name of the party to be notified upon cargo arrival, often a customs broker or freight forwarder acting on behalf of the consignee.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total count of cartons, boxes, pallets, or other shipping units included in this BOL. Used for cargo verification and tally.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging used for the apparel cargo, with special handling codes for hanging garments and fragile accessories. [ENUM-REF-CANDIDATE: carton|pallet|crate|bundle|roll|hanging_garment|polybag — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'Final destination location where the carrier will deliver the cargo to the consignee, which may differ from port of discharge.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'Location where the carrier first received the cargo from the shipper, which may differ from port of loading for multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port or location where cargo will be unloaded from the vessel or vehicle.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Code' ;
    rdfs:comment 'UN/LOCODE five-character code identifying the port or location where cargo was loaded onto the vessel or vehicle.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Complete address of the shipper including street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Legal name of the party shipping the goods, typically the manufacturer or exporter. Appears on customs documentation.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the ocean vessel, aircraft, truck, or rail car transporting the cargo. Required for ocean and air BOLs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'Voyage number for ocean shipments or flight number for air cargo, identifying the specific transport journey.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Flag' ;
    rdfs:comment 'Indicates whether the carrier provides API integration for real-time tracking, rate quotes, and booking automation (True/False).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational and business relationship status of the carrier. Preferred carriers receive priority routing; approved carriers meet minimum standards; probation indicates performance issues under review; suspended carriers are temporarily blocked; inactive carriers are no longer used.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary classification of the carrier based on transportation mode: ocean shipping line, air freight carrier, ground less-than-truckload (LTL), ground full-truckload (FTL), rail operator, last-mile courier, third-party logistics provider (3PL), or freight forwarder. [ENUM-REF-CANDIDATE: ocean|air|ground_ltl|ground_ftl|rail|courier|3pl|freight_forwarder — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the current carrier contract or service agreement became effective.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current carrier contract or service agreement expires. Null for open-ended or evergreen agreements.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the master service agreement or transportation contract governing the business relationship with this carrier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageClaimRate rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Rate' ;
    rdfs:comment 'Percentage of shipments handled by this carrier that resulted in damage claims. Lower rates indicate better handling quality.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'US Department of Transportation identification number assigned to commercial motor carriers. Required for regulatory compliance and safety tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the carrier supports EDI for automated booking, shipment status updates, and invoicing (True/False).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic regions, countries, or trade lanes served by this carrier (e.g., North America, Trans-Pacific, Europe-Asia, Last-Mile USA).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the carriers headquarters street address.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carriers headquarters is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the carriers headquarters location (e.g., USA, CHN, DEU).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the carriers headquarters address.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or region where the carriers headquarters is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'Two or three-character airline designator code assigned by IATA for air freight carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Certificate number of the carriers cargo insurance or liability insurance policy on file. Required for risk management and compliance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Maximum liability coverage amount provided by the carriers insurance policy, typically in USD. Used to assess risk exposure for high-value shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers current insurance certificate. Monitored to ensure continuous coverage.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Motor Carrier operating authority number issued by FMCSA for interstate commerce in the United States.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'On Time Performance Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) representing the carriers on-time delivery performance based on historical shipment data. Used for carrier selection and routing optimization.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) representing the carriers performance in delivering shipments both on time and in full (complete quantity, undamaged). Key performance indicator for carrier evaluation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique two-to-four-letter code used to identify transportation companies in North America. Required for EDI transactions and customs documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Comma-separated list of service modes offered by the carrier (e.g., express, standard, economy, next-day, two-day, international, domestic, white-glove).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Standard number of days committed by the carrier for delivery under the service level agreement. Used for shipment planning and performance measurement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number (TIN, EIN, VAT number) of the carrier entity. Used for invoicing, tax reporting, and compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for shipment tracking on the carriers website. Placeholder tokens (e.g., {tracking_number}) are replaced with actual shipment identifiers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs broker/specialist who filed entry must be tracked for regulatory compliance, CBP audits, and performance metrics. Required for trade compliance reporting and broker certification tracking in a' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'Date when the vessel or aircraft arrived at the U.S. port. Establishes the timeline for entry filing and duty payment deadlines.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Bond Amount Usd' ;
    rdfs:comment 'Face value of the customs bond in U.S. dollars. For single transaction bonds, typically 2-3 times the estimated duties. For continuous bonds, minimum $50,000 or 10% of duties paid in prior year, whichever is greater.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Type of customs bond securing the entry. Single: covers one transaction; Continuous: covers all transactions for one year (minimum $50,000); None: no bond required (e.g., informal entries under $2,500). Bonds guarantee payment of duties and compliance with regulations.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting the claimed country of origin and trade preference eligibility. Required for many FTA and GSP claims. Format varies by issuing authority.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current processing status of the customs entry. Filed: submitted to CBP; Accepted: entry accepted for processing; Hold: flagged for review; Exam: selected for physical or documentary examination; Released: goods authorized for delivery; Liquidated: final duty determination made; Cancelled: entry voided. [ENUM-REF-CANDIDATE: filed|accepted|hold|exam|released|liquidated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Total declared customs value of the imported goods in U.S. dollars. Represents the transaction value (price paid or payable) adjusted for international freight, insurance, and other costs as required by customs valuation rules. Basis for duty calculation.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Duty Amount Usd' ;
    rdfs:comment 'Total customs duty assessed on the entry in U.S. dollars. Calculated by applying the applicable tariff rate to the dutiable value. May be reduced or eliminated under trade preference programs.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Entry Filing Date' ;
    rdfs:comment 'Date when the customs entry was officially filed with the customs authority. Critical for calculating duty payment deadlines and compliance with entry filing timelines.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entrySummaryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Summary Date' ;
    rdfs:comment 'Date when the entry summary (CBP Form 7501) was filed with CBP. Must be filed within 10 working days of entry release. Contains final classification, valuation, and duty calculation.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'Type of physical or documentary examination conducted by CBP or Partner Government Agency. Intensive: full container exam; Tailored: targeted inspection; Compliance: verification of entry accuracy; PGA: inspection by FDA, USDA, or other agency; None: no exam required.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzAdmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Admission Number' ;
    rdfs:comment 'Admission number assigned when goods are admitted into a Foreign Trade Zone. Allows duty deferral or elimination. Null if goods did not enter an FTZ.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harborMaintenanceFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Harbor Maintenance Fee Usd' ;
    rdfs:comment 'Fee assessed at 0.125% of cargo value for commercial cargo shipped through identified U.S. ports. Used to fund harbor maintenance and dredging. Not applicable to air shipments.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importerOfRecordName rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record Name' ;
    rdfs:comment 'Legal name of the entity responsible for ensuring imported goods comply with all laws and regulations and for paying duties, taxes, and fees. The IOR is legally liable for the accuracy of the customs declaration.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record Number' ;
    rdfs:comment 'IRS-assigned Employer Identification Number (EIN) or CBP-assigned importer number used to identify the importer of record. Format: XX-NNNNNNN.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Number' ;
    rdfs:comment 'Reference number for the ISF (10+2) filing submitted to CBP at least 24 hours before ocean cargo is loaded at foreign port. Required for all ocean shipments to the U.S. Links security data to the entry.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of line items (distinct HS code classifications) on this customs entry. Each line represents a different product classification with its own duty rate and origin.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidationDate rdf:type rdf:Property ;
    rdfs:label 'Liquidation Date' ;
    rdfs:comment 'Date when CBP made the final determination of duties, taxes, and fees owed. Liquidation typically occurs within 314 days of entry but may be extended. After liquidation, the entry is considered final unless protested.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandiseProcessingFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Merchandise Processing Fee Usd' ;
    rdfs:comment 'CBP-assessed fee for processing formal entries. Calculated as 0.3464% of entered value with minimum $27.75 and maximum $538.40 per entry (rates subject to periodic adjustment). Informal entries have fixed MPF rates.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which estimated duties, taxes, and fees must be paid to CBP. Typically 10 working days after entry release for non-periodic monthly statement filers. Late payment incurs interest charges.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Four-digit Schedule D port code identifying the U.S. port where goods are entered for customs clearance. Examples: 2704 (Los Angeles/Long Beach), 4601 (New York/Newark), 5301 (Miami).' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfUnladingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Unlading Code' ;
    rdfs:comment 'Four-digit Schedule D port code identifying where goods were physically unloaded from the arriving vessel or aircraft. May differ from port of entry for in-bond shipments.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protestFiledIndicator rdf:type rdf:Property ;
    rdfs:label 'Protest Filed Indicator' ;
    rdfs:comment 'Indicates whether a formal protest has been filed challenging CBP\'s liquidation decision. Protests must be filed within 180 days of liquidation. True if protest filed; False if no protest.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Indicator' ;
    rdfs:comment 'Indicates whether this entry is filed under CBP\'s reconciliation program, which allows importers to file entries with estimated data and reconcile with final data within 15 months. True if reconciliation entry; False if standard entry.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suretyCode rdf:type rdf:Property ;
    rdfs:label 'Surety Code' ;
    rdfs:comment 'Three-digit code identifying the surety company that issued the customs bond. Surety must be on the Treasury Department\'s list of approved sureties.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of goods covered by this entry, summed across all line items. Unit of measure varies by commodity (pieces, dozens, kilograms, square meters, etc.).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeProgramCode rdf:type rdf:Property ;
    rdfs:label 'Trade Program Code' ;
    rdfs:comment 'Code identifying the trade preference program under which duty reduction or elimination is claimed. GSP (Generalized System of Preferences), USMCA (United States-Mexico-Canada Agreement), FTA (Free Trade Agreement), AGOA (African Growth and Opportunity Act), CBI (Caribbean Basin Initiative), ATPA (Andean Trade Preference Act), NONE (no preference claimed). [ENUM-REF-CANDIDATE: GSP|USMCA|FTA|AGOA|CBI|ATPA|NONE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used to bring goods into the U.S. Ocean: vessel; Air: aircraft; Truck: highway; Rail: railroad; Courier: express consignment. Affects processing requirements and fee calculations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Flight Number' ;
    rdfs:comment 'Vessel voyage number or aircraft flight number on which the goods arrived. Links the entry to the specific conveyance manifest filed by the carrier.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DC site manager is accountable for facility operations, workforce planning, and escalations. Essential for org charts, staffing models, and operational accountability in apparel distribution network m' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of warehouse automation deployed at the distribution center. Manual: labor-intensive operations. Semi-automated: conveyor systems and sortation. Fully automated: automated storage and retrieval systems (AS/RS). Robotic: autonomous mobile robots and advanced automation.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Bulk Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to bulk pallet storage zone for high-volume inventory.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Cold Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to temperature-controlled storage for specialty materials or products requiring climate control.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the distribution center is a customs bonded warehouse authorized to store imported goods before duties are paid. Critical for international trade and Landed Duty Paid (LDP) calculations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems and documentation. Externally-known unique code for facility identification.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the distribution center was decommissioned and ceased operations. Null for active facilities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official name of the distribution center or fulfillment facility.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the distribution center by operational model and purpose. Owned DC: company-owned distribution center. 3PL-operated: Third-Party Logistics (3PL) operated facility. Cross-dock: transshipment facility. Returns center: dedicated returns processing. Forward stocking location: regional inventory buffer. Fulfillment center: e-commerce order fulfillment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hangingStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Hanging Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to hanging garment storage on rails for apparel that requires hanging to maintain quality.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the facility lease expires for leased distribution centers. Null for owned facilities. Used for real estate planning and renewal negotiations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the distribution center (e.g., 24/7, Mon-Fri 6AM-6PM, Mon-Sat 8AM-8PM). Used for scheduling and service level planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickZoneCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Pick Zone Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to active picking zones for order fulfillment operations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsDtcChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Dtc Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports Direct-to-Consumer (DTC) e-commerce order fulfillment.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOutletChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Outlet Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports outlet store fulfillment for clearance and off-season merchandise.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRetailReplenishmentChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Retail Replenishment Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports replenishment shipments to company-owned retail stores.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsWholesaleChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Wholesale Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports wholesale distribution to retail partners and department stores.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily processing capacity measured in units that can be received, stored, picked, packed, and shipped. Used for capacity planning and load balancing.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total facility area in square feet including warehouse, office, and support spaces. Used for capacity planning and cost allocation.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Identifier for the Manhattan Associates WMS instance managing this distribution center. Links facility to specific WMS deployment.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCalculationId rdf:type rdf:Property ;
    rdfs:label 'Duty Calculation Id' ;
    rdfs:comment 'Unique identifier for the duty calculation record. Primary key for the duty calculation transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyCalculation .

ind:primaryDutyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Duty Employee Id' ;
    rdfs:comment 'Reference to the system user or customs specialist who performed or approved the duty calculation.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:antiDumpingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Amount' ;
    rdfs:comment 'Additional duty imposed to offset unfair pricing practices when goods are sold below fair market value. Applied on top of standard duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Duty Amount' ;
    rdfs:comment 'Standard import duty calculated by applying the duty rate percentage to the CIF value, before any trade preferences or additional duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationNumber rdf:type rdf:Property ;
    rdfs:label 'Calculation Number' ;
    rdfs:comment 'Business-readable unique identifier for the duty calculation, used for reference in customs documentation and financial reporting. Format: DC-XXXXXXXXXX.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current lifecycle status of the duty calculation. Tracks progression from initial calculation through customs approval and payment reconciliation. [ENUM-REF-CANDIDATE: draft|calculated|submitted|approved|rejected|paid|reconciled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when the duty calculation was performed. Critical for audit trail and compliance reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cifValue rdf:type rdf:Property ;
    rdfs:label 'Cif Value' ;
    rdfs:comment 'Total customs value including FOB value, freight, and insurance. The dutiable value upon which import duties and taxes are calculated.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countervailingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Amount' ;
    rdfs:comment 'Additional duty imposed to offset foreign government subsidies that unfairly benefit exporters. Applied on top of standard duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'Three-letter ISO country code indicating the country where goods are being imported. Determines applicable customs regulations and duty rates.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exciseTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Amount' ;
    rdfs:comment 'Special excise taxes on specific product categories (e.g., luxury goods, alcohol, tobacco). Applied based on product classification.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobValue rdf:type rdf:Property ;
    rdfs:label 'Fob Value' ;
    rdfs:comment 'The value of goods at the point of shipment, excluding freight and insurance. Base value for duty calculation before transportation costs.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftaClaimedFlag rdf:type rdf:Property ;
    rdfs:label 'Fta Claimed Flag' ;
    rdfs:comment 'Indicates whether preferential duty treatment under a Free Trade Agreement was claimed. FTAs provide reduced or zero duty rates for qualifying goods.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftaName rdf:type rdf:Property ;
    rdfs:label 'Fta Name' ;
    rdfs:comment 'Name of the specific Free Trade Agreement under which preferential treatment is claimed (e.g., USMCA, CAFTA-DR, Korea FTA).' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftaReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Fta Reduction Amount' ;
    rdfs:comment 'Duty reduction amount granted under FTA preferential treatment. Reduces the base duty amount when FTA eligibility is confirmed.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspClaimedFlag rdf:type rdf:Property ;
    rdfs:label 'Gsp Claimed Flag' ;
    rdfs:comment 'Indicates whether GSP preferential duty treatment was claimed for this shipment. GSP provides duty-free treatment for eligible products from developing countries.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gspReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Gsp Reduction Amount' ;
    rdfs:comment 'Duty reduction amount granted under GSP preferential treatment. Reduces the base duty amount when GSP eligibility is confirmed.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hmfAmount rdf:type rdf:Property ;
    rdfs:label 'Hmf Amount' ;
    rdfs:comment 'U.S. fee assessed on cargo shipped through U.S. ports to fund harbor maintenance. Calculated as a percentage of cargo value.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Ldp Total Amount' ;
    rdfs:comment 'Total landed cost including CIF value, all duties, taxes, and fees. Represents the complete cost to bring goods into the destination country.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpUnitCost rdf:type rdf:Property ;
    rdfs:label 'Ldp Unit Cost' ;
    rdfs:comment 'Per-unit landed cost calculated by dividing LDP total amount by quantity. Used for COGS calculation and margin analysis in SAP FI/CO.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpfAmount rdf:type rdf:Property ;
    rdfs:label 'Mpf Amount' ;
    rdfs:comment 'U.S. Customs fee for processing imported merchandise. Calculated as a percentage of shipment value with minimum and maximum caps.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Fees Amount' ;
    rdfs:comment 'Miscellaneous customs fees, inspection charges, or regulatory fees not captured in standard duty and tax categories.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfEntry rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry' ;
    rdfs:comment 'Official customs port or border crossing where goods entered the destination country. Impacts processing times and local regulations.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the duty calculation was submitted to customs authorities. Critical for compliance and SLA tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Amount' ;
    rdfs:comment 'Sum of all duty components including base duty, anti-dumping, countervailing duties, less any GSP or FTA reductions. Excludes taxes and fees.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fees Amount' ;
    rdfs:comment 'Sum of all customs processing fees including MPF, HMF, and other regulatory fees.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all tax components including VAT, excise taxes, and other applicable import taxes.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation for any variance between calculated and actual duty amounts. Used for process improvement and dispute resolution.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'Import VAT or sales tax assessed on the total landed value including duties. Applicable in jurisdictions with VAT systems.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apSpecialistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ap Specialist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AP specialist reviews and approves freight invoices for payment. Required for financial controls, audit trails, and accounts payable workflow management in apparel logistics cost accounting.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryFreightThirdPartyLogisticsId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Third Party Logistics Id' ;
    rdfs:comment 'Reference to the 3PL provider if the invoice is from a third-party logistics partner rather than a direct carrier. Nullable if invoice is from direct carrier.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyLogistics .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Total amount of accessorial charges for additional services such as liftgate, inside delivery, residential delivery, limited access, redelivery, or special handling.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The amount approved for payment after freight audit and rate validation. May differ from total invoiced amount if discrepancies or disputes are identified.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFreightCharge rdf:type rdf:Property ;
    rdfs:label 'Base Freight Charge' ;
    rdfs:comment 'The base transportation charge before surcharges, accessorials, and adjustments. Core component of freight cost.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The end date of the billing period covered by this freight invoice. Used for consolidated invoices covering multiple shipments over a time range.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The start date of the billing period covered by this freight invoice. Used for consolidated invoices covering multiple shipments over a time range.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The contracted rate per unit (per kg, per shipment, per container) agreed with the carrier. Used for rate compliance validation during freight audit.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBrokerageFee rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Fee' ;
    rdfs:comment 'Fee charged by freight forwarder or customs broker for customs clearance services. Covers documentation, filing, and compliance activities.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detentionDemurrageCharges rdf:type rdf:Property ;
    rdfs:label 'Detention Demurrage Charges' ;
    rdfs:comment 'Charges for detention (delay in returning equipment) or demurrage (delay in unloading cargo at port or terminal). Penalty charges for exceeding free time allowances.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator whether this freight invoice is under dispute. True if discrepancies have been identified and are being contested with the service provider.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes documenting the details of the invoice dispute, including specific discrepancies identified and resolution actions taken.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'The reason code for the invoice dispute. Categorizes the nature of the discrepancy or issue requiring resolution with the service provider. [ENUM-REF-CANDIDATE: rate_discrepancy|incorrect_charges|duplicate_invoice|service_failure|damaged_goods|missing_documentation|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Total customs duty amount paid or payable on the imported goods covered by this freight invoice. Based on HS code classification and country of origin.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge' ;
    rdfs:comment 'The fuel surcharge amount applied to the freight invoice. Variable charge based on fuel price indices.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this freight invoice is posted. Used for financial reporting and cost allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCharge rdf:type rdf:Property ;
    rdfs:label 'Insurance Charge' ;
    rdfs:comment 'Freight insurance charge for cargo coverage during transit. Protects against loss or damage to goods.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'The code or identifier for the origin location of the shipment. May be facility code, port code, or airport code depending on transport mode.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderReference rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Reference' ;
    rdfs:comment 'Reference to the purchase order number associated with the shipment(s) covered by this freight invoice. Used for three-way matching and cost allocation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentReferenceList rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference List' ;
    rdfs:comment 'Comma-separated list of shipment numbers or identifiers covered by this freight invoice. Links the invoice to one or more logistics shipments. May reference multiple shipments for consolidated invoices.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInvoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoiced Amount' ;
    rdfs:comment 'The total amount invoiced by the service provider, including all charges, surcharges, fees, duties, and taxes. Sum of all charge components.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chapter rdf:type rdf:Property ;
    rdfs:label 'Chapter' ;
    rdfs:comment 'The two-digit chapter number of the HS code representing the broad product category (e.g., Chapter 61 for knitted apparel, Chapter 62 for woven apparel, Chapter 64 for footwear).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated Flag' ;
    rdfs:comment 'Indicates whether products under this HS code are subject to CPSC safety standards and testing requirements (e.g., flammability standards for children\'s sleepwear, lead content limits).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulation Reference' ;
    rdfs:comment 'Specific CPSC regulation citation applicable to this HS code (e.g., 16 CFR 1610 for flammability, 16 CFR 1501 for small parts). Null if not CPSC regulated.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRateUnit rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Unit' ;
    rdfs:comment 'Indicates whether the duty rate is ad valorem (percentage of value), specific (per unit/weight), or compound (combination of both).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date until which this HS code classification and duty rates remain valid. Null for currently active codes. Used to manage HS code changes during WCO amendment cycles.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification Required' ;
    rdfs:comment 'Environmental or sustainability certifications required or recommended for products under this HS code (e.g., OEKO-TEX Standard 100, GOTS, BCI). Null if no specific requirements.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcLabelingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Required Flag' ;
    rdfs:comment 'Indicates whether products under this HS code require FTC-mandated fiber content labeling, country of origin marking, or care labeling per Textile and Wool Acts.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcLabelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Requirement' ;
    rdfs:comment 'Specific FTC labeling requirements for this HS code including fiber content disclosure, country of origin, manufacturer identification, and care instructions. Null if not required.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalDutyRate rdf:type rdf:Property ;
    rdfs:label 'General Duty Rate' ;
    rdfs:comment 'The standard Most Favored Nation (MFN) duty rate expressed as a percentage or specific rate applicable to imports from countries without preferential trade agreements. Used for Landed Duty Paid (LDP) calculations.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspBeneficiaryCountries rdf:type rdf:Property ;
    rdfs:label 'Gsp Beneficiary Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes eligible for GSP treatment for this HS code. Null if GSP not applicable.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heading rdf:type rdf:Property ;
    rdfs:label 'Heading' ;
    rdfs:comment 'The four-digit heading number providing a more specific product classification within the chapter (e.g., 6109 for T-shirts, singlets, and other vests).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Hs Code Status' ;
    rdfs:comment 'Current lifecycle status of this HS code. Active codes are used for current classifications. Deprecated codes have been replaced by new codes in HS updates. Superseded codes reference the replacement code. Pending codes are scheduled for future activation.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsVersion rdf:type rdf:Property ;
    rdfs:label 'Hs Version' ;
    rdfs:comment 'The version year of the Harmonized System nomenclature (e.g., HS2017, HS2022) under which this code is classified. WCO updates the HS every 5 years.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalExtension rdf:type rdf:Property ;
    rdfs:label 'National Extension' ;
    rdfs:comment 'Additional digits beyond the 6-digit subheading added by individual countries for more granular classification (e.g., US uses 10-digit HTS codes). May be null for base 6-digit codes.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCriteria rdf:type rdf:Property ;
    rdfs:label 'Origin Criteria' ;
    rdfs:comment 'Rules of origin criteria that must be met for products under this HS code to qualify for preferential duty treatment (e.g., tariff shift rules, regional value content thresholds, substantial transformation tests).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to import or export restrictions, quotas, licensing requirements, or prohibitions by customs authorities.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Type of restriction or special requirement applicable to this HS code. Null if restricted_flag is false.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:section301DutyFlag rdf:type rdf:Property ;
    rdfs:label 'Section 301 Duty Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to additional Section 301 tariffs imposed on imports from specific countries (e.g., China tariffs).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:section301DutyRate rdf:type rdf:Property ;
    rdfs:label 'Section 301 Duty Rate' ;
    rdfs:comment 'Additional duty rate percentage imposed under Section 301 trade actions. Null if not subject to Section 301 duties.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the HS code for operational use in warehouse management, shipping documents, and internal systems.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subheading rdf:type rdf:Property ;
    rdfs:label 'Subheading' ;
    rdfs:comment 'The six-digit subheading providing internationally standardized product classification. This is the minimum level required for international trade.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByHsCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Hs Code' ;
    rdfs:comment 'The new HS code that replaces this code when status is superseded. Used to maintain continuity during HS version transitions. Null for active codes.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textileCategory rdf:type rdf:Property ;
    rdfs:label 'Textile Category' ;
    rdfs:comment 'Textile category classification used for quota administration and trade monitoring (historically used for Multi-Fiber Arrangement, still relevant for certain trade agreements).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreement rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement' ;
    rdfs:comment 'Name of the trade agreement or preferential program under which the preferential duty rate applies (e.g., USMCA, GSP, CAFTA-DR, EU-FTA). Null if general duty rate applies.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Of Quantity' ;
    rdfs:comment 'The unit of measure required for statistical reporting and quota tracking for this HS code (e.g., dozens for shirts, pairs for footwear, kilograms for fabric).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightBookingId rdf:type rdf:Property ;
    rdfs:label 'Freight Booking Id' ;
    rdfs:comment 'Unique identifier for the freight booking record. Primary key for the logistics freight booking entity.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFreightEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this freight booking record. Supports audit and accountability.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'Date when the freight booking was formally placed with the carrier or freight forwarder. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingNotes rdf:type rdf:Property ;
    rdfs:label 'Booking Notes' ;
    rdfs:comment 'Additional notes or comments related to the freight booking. Captures operational details, exceptions, or coordination information.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Reference Number' ;
    rdfs:comment 'Externally-known unique booking reference number assigned by the carrier or freight forwarder. Used for tracking and communication with logistics partners.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the freight booking. Tracks progression from draft through confirmation, execution, and completion or cancellation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Collection Season Code' ;
    rdfs:comment 'Code identifying the apparel collection season (e.g., Spring/Summer 2024, Fall/Winter 2024) that this freight booking supports. Critical for seasonal collection launch planning.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedSpaceAllocation rdf:type rdf:Property ;
    rdfs:label 'Confirmed Space Allocation' ;
    rdfs:comment 'Confirmed cargo space allocated by the carrier for this booking, measured in cubic meters (CBM) or container equivalent units (TEU). Supports capacity planning.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Number of containers booked for this freight booking. Applicable for FCL (Full Container Load) shipments.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of shipping container used for the booking. Includes standard dry containers, high-cube, refrigerated (reefer), and specialized containers. Applicable for ocean freight FCL bookings.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOffDate rdf:type rdf:Property ;
    rdfs:label 'Cut Off Date' ;
    rdfs:comment 'Final date and time by which cargo must be delivered to the carrier or terminal to meet the scheduled departure. Critical for operational planning.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Estimated date when the carrier is scheduled to arrive at the port of discharge or destination terminal.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Estimated date when the carrier is scheduled to depart from the port of loading or origin terminal.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight charge amount for this booking as per the rate agreement. Excludes surcharges, duties, and taxes.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the freight charge amount. Indicates the currency in which the freight charge is denominated.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean flag indicating whether the shipment contains hazardous materials requiring special handling and documentation. True if hazardous, False otherwise.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether cargo insurance is required for this booking. True if insurance is required, False otherwise.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the cargo for insurance purposes. Used to calculate insurance premiums and coverage limits.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Reference' ;
    rdfs:comment 'Reference number of the negotiated rate agreement or contract with the carrier that governs pricing for this booking. Links to carrier contract master data.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of freight service booked. FCL (Full Container Load), LCL (Less than Container Load), air charter, express courier, ocean freight, road freight, rail freight, or courier service. [ENUM-REF-CANDIDATE: FCL|LCL|AIR_CHARTER|AIR_EXPRESS|OCEAN_FREIGHT|ROAD_FREIGHT|RAIL_FREIGHT|COURIER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceAllocationUnit rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Unit' ;
    rdfs:comment 'Unit of measure for the confirmed space allocation. CBM (Cubic Meters), TEU (Twenty-foot Equivalent Unit), FEU (Forty-foot Equivalent Unit), KG (Kilograms), or LBS (Pounds).' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Shipment coordinators create and manage shipments for accountability, performance tracking, and audit trails. Essential for logistics operations reporting and workforce productivity analysis in appare' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:destinationFacilityDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Distribution Center Id' ;
    rdfs:comment 'Identifier of the facility, warehouse, store, or customer location to which the shipment is destined.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:shipmentDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Shipment Distribution Center Id' ;
    rdfs:comment 'Identifier of the facility, warehouse, or manufacturing location from which the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the shipment arrived at the destination facility or port.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual timestamp when the shipment departed from the origin facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Legal document number issued by the carrier acknowledging receipt of cargo for shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Carrier or freight forwarder booking reference number for the shipment reservation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMilestone rdf:type rdf:Property ;
    rdfs:label 'Current Milestone' ;
    rdfs:comment 'Most recent shipment milestone or checkpoint reached in the logistics journey (e.g., departed origin, in customs, out for delivery).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Planned or estimated timestamp when the shipment is expected to arrive at the destination facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Timestamp' ;
    rdfs:comment 'Planned or estimated timestamp when the shipment is expected to depart from the origin facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Estimate' ;
    rdfs:comment 'Estimated freight transportation cost for the shipment in the company\'s reporting currency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Declared value of the shipment for insurance purposes in the company\'s reporting currency.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment was delivered on time and in full per the agreed service level agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this shipment has been flagged as high priority requiring expedited handling.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment, used across systems and with external partners.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the logistics workflow.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on commercial terms and destination type. FOB (Free on Board), LDP (Landed Duty Paid), DTC (Direct-to-Consumer), wholesale, inter-facility transfer, or RTV (Return to Vendor).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Date' ;
    rdfs:comment 'Target delivery date per the service level agreement with the customer or internal business unit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionId rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: Packing lists reference final pre-shipment inspections conducted at factory before ex-factory date. Standard apparel process: inline or final inspections are documented and packing list certifies insp' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:primaryPackingDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Packing Distribution Center Id' ;
    rdfs:comment 'Reference to the manufacturing facility or warehouse where goods were packed. Used for sourcing analytics and quality traceability.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:primaryPackingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packing Employee Id' ;
    rdfs:comment 'Reference to the user or employee who prepared and finalized this packing list. Used for accountability and audit trail.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cartonLabelFormat rdf:type rdf:Property ;
    rdfs:label 'Carton Label Format' ;
    rdfs:comment 'Barcode or label standard used on cartons. GS1-128 for standard supply chain labels, SSCC for serial shipping container codes, UCC-128 for legacy format, custom for proprietary labels.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the goods were manufactured or substantially transformed. Used for GSP eligibility and trade agreement compliance.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description of any receiving discrepancies, damages, or quality issues identified. Used for supplier performance tracking and claims processing.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the invoice value. Used for foreign exchange conversion and financial reporting.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingDate rdf:type rdf:Property ;
    rdfs:label 'Packing Date' ;
    rdfs:comment 'Date when the goods were physically packed and the packing list was prepared. Used for lead time calculation and production schedule tracking.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingListNumber rdf:type rdf:Property ;
    rdfs:label 'Packing List Number' ;
    rdfs:comment 'Externally-known unique business identifier for the packing list document. Used for customs clearance, DC receiving, and cross-referencing with commercial invoice and bill of lading.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListStatus rdf:type rdf:Property ;
    rdfs:label 'Packing List Status' ;
    rdfs:comment 'Current lifecycle status of the packing list document. Draft indicates in-progress, finalized means ready for shipment, submitted means sent to customs/receiver, received means acknowledged by DC, discrepancy indicates receiving variance, closed means reconciled.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListType rdf:type rdf:Property ;
    rdfs:label 'Packing List Type' ;
    rdfs:comment 'Classification of packing list document. Master for container-level summary, detailed for SKU-level breakdown, consolidated for multi-PO shipments, sample for pre-production shipments.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingMethod rdf:type rdf:Property ;
    rdfs:label 'Packing Method' ;
    rdfs:comment 'Method used to pack the apparel or footwear goods. Flat pack for folded garments, hanging for garments on hangers, polybag for individual poly-bagged items, boxed for footwear in shoeboxes, mixed for combination methods.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether goods in this packing list require quality inspection upon receipt. True if inspection is mandatory before putaway.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Flag' ;
    rdfs:comment 'Indicates whether goods must be placed in quarantine hold upon receipt pending inspection or compliance verification. True if quarantine is required.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the packing list was acknowledged as received at the destination facility. Used for OTIF compliance and transit time calculation.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingDiscrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Receiving Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a discrepancy was identified during receiving (quantity variance, damage, quality issue). True if discrepancy exists and requires resolution.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCubicVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cubic Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment measured in cubic meters. Used for container utilization analysis and dimensional weight pricing.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment including packaging materials, measured in kilograms. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceValue rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Value' ;
    rdfs:comment 'Total declared value of goods on the commercial invoice for this packing list. Used for customs valuation, duty calculation, and insurance coverage.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of the goods excluding packaging materials, measured in kilograms. Used for customs valuation and duty calculation.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalShipmentId rdf:type rdf:Property ;
    rdfs:label 'Original Shipment Id' ;
    rdfs:comment 'Identifier of the original outbound shipment that delivered the items now being returned.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:returnInspectionId rdf:type rdf:Property ;
    rdfs:label 'Return Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: Return shipments trigger quality inspections to determine disposition (restock, rework, scrap). Standard RMA workflow: all returns are inspected upon receipt to assess condition and determine credit e' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:returnsCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Returns Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Returns coordinator processes RMA authorizations and manages disposition decisions. Essential for customer service accountability, returns processing metrics, and inventory control in apparel reverse ' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Quality grade assigned to returned merchandise: A (like new, resellable at full price), B (minor defects, resellable at discount), C (significant wear, outlet only), D (unsellable, dispose/donate).' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Type' ;
    rdfs:comment 'Type of destination facility: distribution center, dedicated returns center, vendor location, refurbishment center, or outlet warehouse.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final disposition decision for the returned merchandise: restock to primary inventory, refurbish for resale, transfer to outlet channel, donate to charity, destroy, or return to vendor.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight cost incurred for the return shipment transportation, in the company\'s reporting currency.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the return shipment was initiated by the customer, store, or vendor. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Timestamp' ;
    rdfs:comment 'Date and time when quality inspection and condition grading of the returned items was completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Type of origin location: customer address, retail store, distribution center, vendor facility, or warehouse.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the returned items are eligible for restocking into available-to-sell (ATS) inventory. True if items can be resold, False if they require alternative disposition.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally-known unique authorization number issued to approve the return. Format: RMA followed by 10 digits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Return Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional context or details about the reason for the return.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return shipment: consumer RMA (customer return), RTV (Return-to-Vendor), store recall (store-to-DC consolidation), quality reject (failed inspection), warranty claim, or inter-facility transfer of returned goods.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNotes rdf:type rdf:Property ;
    rdfs:label 'Shipment Notes' ;
    rdfs:comment 'Free-text operational notes or special handling instructions for the return shipment.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the return shipment met the defined SLA for processing time and customer refund turnaround. True if compliant, False if SLA was breached.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Reference to the transportation lane this routing guide applies to, linking origin-destination pairs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:primaryCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Id' ;
    rdfs:comment 'Reference to the preferred carrier assigned to this lane as the first choice for transportation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryRoutingDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Routing Distribution Center Id' ;
    rdfs:comment 'Reference to the specific origin facility, warehouse, or manufacturing plant from which shipments originate.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:primaryRoutingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Routing Employee Id' ;
    rdfs:comment 'Identifier of the user or system that created this routing guide record.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRoutingLastMileCarrierId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Routing Last Mile Carrier Id' ;
    rdfs:comment 'Reference to the carrier responsible for final delivery to the destination, used for multi-leg shipments.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:carrierContractNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Number' ;
    rdfs:comment 'Reference number of the carrier contract governing rates and terms for this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this routing guide has mandatory compliance requirements such as customs clearance, HS code validation, or GSP utilization.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guideCode rdf:type rdf:Property ;
    rdfs:label 'Guide Code' ;
    rdfs:comment 'Business identifier for the routing guide rule, used for external reference and operational lookup.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guideName rdf:type rdf:Property ;
    rdfs:label 'Guide Name' ;
    rdfs:comment 'Descriptive name of the routing guide rule for business user identification.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeValidationRequired rdf:type rdf:Property ;
    rdfs:label 'Hs Code Validation Required' ;
    rdfs:comment 'Flag indicating whether shipments using this routing guide must have validated HS codes for customs clearance.' ;
    rdfs:domain ind:RoutingGuide ;
