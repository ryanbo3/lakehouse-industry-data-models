    rdfs:comment 'Primary mode of transportation covered by this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUnit rdf:type rdf:Property ;
