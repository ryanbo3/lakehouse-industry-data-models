    rdfs:range xsd:string .

ind:engagementRatePercent rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate Percent' ;
    rdfs:comment 'Average engagement rate (likes, comments, shares divided by followers) expressed as a percentage. Key metric for campaign ROI forecasting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
