    rdfs:range xsd:string .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing and overseeing this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract indicating its operational state.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the logistics contract by service provider type: carrier (transportation), 3PL (third-party logistics), freight forwarder, customs broker, warehouse, or last-mile delivery.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
