ind:ownerCompany rdf:type rdf:Property ;
    rdfs:label 'Owner Company' ;
    rdfs:comment 'The legal entity or parent company that owns the intellectual property rights to the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarketRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Market Region' ;
    rdfs:comment 'The primary geographic region where the brand has its strongest market presence and focus.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaFacebook rdf:type rdf:Property ;
    rdfs:label 'Social Media Facebook' ;
    rdfs:comment 'The brand\'s official Facebook page name or handle used for social media marketing.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaInstagram rdf:type rdf:Property ;
    rdfs:label 'Social Media Instagram' ;
    rdfs:comment 'The brand\'s official Instagram handle used for social media marketing and customer engagement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaTwitter rdf:type rdf:Property ;
    rdfs:label 'Social Media Twitter' ;
    rdfs:comment 'The brand\'s official Twitter handle used for social media marketing and customer engagement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary demographic audience segment that the brand is designed to serve.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aBTestVariant rdf:type rdf:Property ;
    rdfs:label 'A B Test Variant' ;
    rdfs:comment 'Indicates which A/B test variant this template represents for campaign optimization testing.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionText rdf:type rdf:Property ;
    rdfs:label 'Call To Action Text' ;
    rdfs:comment 'Primary call-to-action button or link text used in the template to drive recipient engagement.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionUrl rdf:type rdf:Property ;
    rdfs:label 'Call To Action Url' ;
    rdfs:comment 'Primary destination URL for the call-to-action button or link, may include tracking parameters.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCategory rdf:type rdf:Property ;
    rdfs:label 'Campaign Category' ;
    rdfs:comment 'Marketing campaign category that this template is designed to support.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewed rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed' ;
    rdfs:comment 'Indicates whether the template has been reviewed and approved for legal and regulatory compliance.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who performed the compliance review of the template.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVersion rdf:type rdf:Property ;
    rdfs:label 'Design Version' ;
    rdfs:comment 'Version number of the template design to track iterations and changes over time.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromEmail rdf:type rdf:Property ;
    rdfs:label 'From Email' ;
    rdfs:comment 'Email address that appears as the sender and receives replies if reply-to is not specified.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htmlBody rdf:type rdf:Property ;
    rdfs:label 'Html Body' ;
    rdfs:comment 'Full HTML markup for the email body including layout, styling, images, and personalization tokens.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPersonalized rdf:type rdf:Property ;
    rdfs:label 'Is Personalized' ;
    rdfs:comment 'Indicates whether the template includes personalization tokens or dynamic content based on recipient data.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResponsive rdf:type rdf:Property ;
    rdfs:label 'Is Responsive' ;
    rdfs:comment 'Indicates whether the email template uses responsive design principles to adapt to different screen sizes.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPlatform rdf:type rdf:Property ;
    rdfs:label 'Marketing Platform' ;
    rdfs:comment 'Name of the marketing automation or email service platform where this template is hosted (e.g., Adobe Experience Platform, Salesforce Marketing Cloud).' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationTokens rdf:type rdf:Property ;
    rdfs:label 'Personalization Tokens' ;
    rdfs:comment 'Comma-separated list of personalization token names used in the template (e.g., first_name, last_purchase_date).' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plainTextBody rdf:type rdf:Property ;
    rdfs:label 'Plain Text Body' ;
    rdfs:comment 'Plain text version of the email body for email clients that do not support HTML rendering.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Platform Template Code' ;
    rdfs:comment 'External identifier of the template in the source marketing platform system.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmail rdf:type rdf:Property ;
    rdfs:label 'Reply To Email' ;
    rdfs:comment 'Email address where recipient replies are directed, if different from the from_email address.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the email template used for external reference and integration purposes.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the email template used for identification and selection in marketing campaigns.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the email template based on its marketing purpose and use case.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailImageUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Image Url' ;
    rdfs:comment 'URL of the thumbnail or preview image representing the template in the marketing platform interface.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeLinkIncluded rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Link Included' ;
    rdfs:comment 'Indicates whether the template includes a mandatory unsubscribe link as required by email marketing regulations.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageStoreSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Average Store Size Sqft' ;
    rdfs:comment 'Average retail floor space in square feet across all stores in the cluster.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Business identifier code for the store cluster used in operational systems and reporting.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDescription rdf:type rdf:Property ;
    rdfs:label 'Cluster Description' ;
    rdfs:comment 'Detailed business description of the cluster purpose, characteristics, and strategic rationale for grouping.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Email' ;
    rdfs:comment 'Business email address of the cluster manager for operational communication.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerName rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Name' ;
    rdfs:comment 'Name of the regional or cluster manager responsible for stores in this cluster.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterName rdf:type rdf:Property ;
    rdfs:label 'Cluster Name' ;
    rdfs:comment 'Descriptive name of the store cluster for business users and reporting purposes.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Status' ;
    rdfs:comment 'Current lifecycle status of the store cluster indicating whether it is actively used for planning and operations.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterTier rdf:type rdf:Property ;
    rdfs:label 'Cluster Tier' ;
    rdfs:comment 'Performance or strategic tier classification of the cluster (tier 1 being highest performing or most strategic).' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterType rdf:type rdf:Property ;
    rdfs:label 'Cluster Type' ;
    rdfs:comment 'Classification of the cluster based on grouping methodology: geographic proximity, demographic profile, performance tier, store format similarity, strategic importance, or seasonal behavior.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Level of competitive pressure from other apparel retailers in the cluster\'s market area.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFlagshipCluster rdf:type rdf:Property ;
    rdfs:label 'Is Flagship Cluster' ;
    rdfs:comment 'Indicates whether this cluster contains flagship or brand showcase stores requiring premium treatment.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchandisingStrategy rdf:type rdf:Property ;
    rdfs:label 'Merchandising Strategy' ;
    rdfs:comment 'Primary merchandising and assortment strategy applied to stores in this cluster (e.g., athletic-focused, lifestyle-casual, luxury-premium).' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelCapability rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Capability' ;
    rdfs:comment 'Level of omnichannel fulfillment capabilities enabled for stores in this cluster (BOPIS: Buy Online Pick-up In Store).' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalProfile rdf:type rdf:Property ;
    rdfs:label 'Seasonal Profile' ;
    rdfs:comment 'Seasonal sales pattern classification for the cluster used in demand forecasting and inventory planning (e.g., winter-peak, summer-peak, balanced).' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Total number of stores currently assigned to this cluster.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficPattern rdf:type rdf:Property ;
    rdfs:label 'Traffic Pattern' ;
    rdfs:comment 'Typical customer foot traffic pattern classification for stores in the cluster.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualMerchandisingStandard rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Standard' ;
    rdfs:comment 'Visual merchandising and store presentation standard applied to the cluster.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentDivisionId rdf:type rdf:Property ;
    rdfs:label 'Parent Division Id' ;
    rdfs:comment 'Reference to the parent division in a hierarchical division structure. Null for top-level divisions.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the primary buyer or merchandising manager responsible for this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionDescription rdf:type rdf:Property ;
    rdfs:label 'Division Description' ;
    rdfs:comment 'Detailed description of the division\'s scope, product categories, and business purpose.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionType rdf:type rdf:Property ;
    rdfs:label 'Division Type' ;
    rdfs:comment 'Classification of the division by product category type.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeWeeks rdf:type rdf:Property ;
    rdfs:label 'Lead Time Weeks' ;
    rdfs:comment 'Average lead time in weeks from order placement to merchandise receipt for this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandiseHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Merchandise Hierarchy Level' ;
    rdfs:comment 'Numeric level of this division within the merchandise hierarchy (e.g., 1=Division, 2=Department, 3=Class).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Otb Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the OTB budget amount.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the primary merchandise planner responsible for assortment and allocation planning for this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPercentage rdf:type rdf:Property ;
    rdfs:label 'Private Label Percentage' ;
    rdfs:comment 'Target percentage of private label merchandise within this division\'s assortment.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLifecycleWeeks rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Weeks' ;
    rdfs:comment 'Average product lifecycle duration in weeks for merchandise in this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonal Indicator' ;
    rdfs:comment 'Indicates whether this division carries seasonal merchandise (True) or year-round merchandise (False).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric value used to control the display order of divisions in reports and user interfaces.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetGrossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Percentage' ;
    rdfs:comment 'Target gross margin percentage for this division, used in merchandise financial planning.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetInitialMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Initial Markup Percentage' ;
    rdfs:comment 'Target initial markup percentage for products in this division, calculated as (retail - cost) / retail * 100.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaintainedMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Maintained Markup Percentage' ;
    rdfs:comment 'Target maintained markup percentage after markdowns for this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Percentage' ;
    rdfs:comment 'Target sell-through rate percentage for this division, calculated as units sold / units received * 100.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorConcentrationPercentage rdf:type rdf:Property ;
    rdfs:label 'Vendor Concentration Percentage' ;
    rdfs:comment 'Percentage of division purchases concentrated with top vendors, used for risk assessment.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentChannelId rdf:type rdf:Property ;
    rdfs:label 'Parent Channel Id' ;
    rdfs:comment 'Reference to a parent channel if this channel is a sub-channel or variant within a hierarchical channel structure. Null for top-level channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:salesOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Id' ;
    rdfs:comment 'Reference to the sales organization responsible for managing this channel.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrganization .

ind:assortmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Strategy' ;
    rdfs:comment 'Merchandising assortment strategy defining the breadth and depth of product selection offered through this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Value' ;
    rdfs:comment 'Historical average transaction value in the channel\'s currency, used for financial planning and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'High-level categorization of the channel by operational medium: physical (brick-and-mortar), digital (online), or omnichannel (integrated).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelManagerName rdf:type rdf:Property ;
    rdfs:label 'Channel Manager Name' ;
    rdfs:comment 'Name of the business leader or manager responsible for this channel\'s performance and strategy.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel in the merchandising system lifecycle.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Visibility Flag' ;
    rdfs:comment 'Indicates whether real-time inventory levels are visible to customers in this channel (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Eligible' ;
    rdfs:comment 'Indicates whether purchases made through this channel are eligible for loyalty program points and rewards (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownPolicy rdf:type rdf:Property ;
    rdfs:label 'Markdown Policy' ;
    rdfs:comment 'Markdown policy governing price reductions in this channel to optimize sell-through rate (STR) and inventory turnover.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled' ;
    rdfs:comment 'Indicates whether this channel is integrated into the omnichannel customer experience (True) or operates independently (False).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Accepted' ;
    rdfs:comment 'Comma-separated list of payment methods accepted in this channel (e.g., credit card, debit card, digital wallet, cash, gift card).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this channel operates seasonally (True) or year-round (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetInitialMarkupPercent rdf:type rdf:Property ;
    rdfs:label 'Target Initial Markup Percent' ;
    rdfs:comment 'Target Initial Markup percentage for merchandise sold through this channel, used in Open-to-Buy (OTB) budget planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaintainedMarkupPercent rdf:type rdf:Property ;
    rdfs:label 'Target Maintained Markup Percent' ;
    rdfs:comment 'Target Maintained Markup percentage after markdowns, used to measure pricing effectiveness and margin preservation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Region Id' ;
    rdfs:comment 'Reference to the parent region in a hierarchical region structure, enabling multi-level geographic or organizational rollups.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:aurTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Aur Target Amount' ;
    rdfs:comment 'Target average unit retail price for merchandise sold in this region, used for assortment planning and pricing strategy.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target gross margin return on investment ratio for this region, measuring profitability of inventory investment.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imuTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Imu Target Percent' ;
    rdfs:comment 'Target initial markup percentage for merchandise in this region, representing the difference between cost and initial retail price.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEcommerceEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Enabled' ;
    rdfs:comment 'Indicates whether e-commerce sales channels are active and operational in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWholesaleEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Wholesale Enabled' ;
    rdfs:comment 'Indicates whether wholesale distribution partnerships are active in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Market Size Category' ;
    rdfs:comment 'Classification of the region based on market size and maturity for strategic planning and resource allocation.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionDescription rdf:type rdf:Property ;
    rdfs:label 'Region Description' ;
    rdfs:comment 'Detailed description of the region including its scope, coverage, and business purpose.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLevel rdf:type rdf:Property ;
    rdfs:label 'Region Level' ;
    rdfs:comment 'Numeric level in the region hierarchy (e.g., 1=Global, 2=Continental, 3=Country, 4=State/Province, 5=District).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionStatus rdf:type rdf:Property ;
    rdfs:label 'Region Status' ;
    rdfs:comment 'Current lifecycle status of the region indicating whether it is actively used in business operations.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the region based on its business purpose (geographic, sales, merchandising, distribution, operational, administrative).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting region-specific regulatory requirements, trade restrictions, or compliance considerations.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Target Amount' ;
    rdfs:comment 'Annual sales target amount set for this region, used for performance measurement and planning.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonCalendarType rdf:type rdf:Property ;
    rdfs:label 'Season Calendar Type' ;
    rdfs:comment 'Seasonal calendar pattern used for merchandising planning in this region (e.g., northern hemisphere follows spring/summer/fall/winter).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceListId rdf:type rdf:Property ;
    rdfs:label 'Base Price List Id' ;
    rdfs:comment 'Reference to a parent or base price list from which this price list inherits default pricing, used for hierarchical price list structures.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:isTaxInclusive rdf:type rdf:Property ;
    rdfs:label 'Is Tax Inclusive' ;
    rdfs:comment 'Flag indicating whether prices in this price list include applicable taxes or are exclusive of tax, affecting gross-to-net price calculations.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'Default markup percentage applied to cost prices in this price list, representing the Initial Markup (IMU) or Maintained Markup (MMU) strategy.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the price list, used for reference in merchandising systems and business communications.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its business purpose and target customer segment, determining pricing strategy and discount applicability.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderHandling rdf:type rdf:Property ;
    rdfs:label 'Backorder Handling' ;
    rdfs:comment 'Defines how this allocation rule handles backorder scenarios (allow backorders, prevent backorders, allow partial backorders).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelFilter rdf:type rdf:Property ;
    rdfs:label 'Channel Filter' ;
    rdfs:comment 'Sales channel(s) to which this allocation rule applies (Direct-to-Consumer, wholesale, retail stores, e-commerce, marketplace, or all channels).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTierFilter rdf:type rdf:Property ;
    rdfs:label 'Customer Tier Filter' ;
    rdfs:comment 'Customer tier or segment classification to which this allocation rule applies. Null indicates rule applies to all tiers.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'Frequency at which this allocation rule is scheduled to execute (real-time, hourly, daily, weekly, on-demand).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Identifier for this allocation rule in the source system of record, used for integration and reconciliation.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionFilter rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Filter' ;
    rdfs:comment 'Geographic region(s) to which this allocation rule applies. Null indicates rule applies globally.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Timestamp when this allocation rule was last executed in an allocation run.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Allocation Quantity' ;
    rdfs:comment 'Maximum quantity cap that can be allocated under this rule. Used to prevent over-concentration of inventory.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Allocation Quantity' ;
    rdfs:comment 'Minimum quantity threshold that must be allocated when this rule is applied. Prevents fractional or uneconomical allocations.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether users are permitted to manually override allocations generated by this rule (true = overrides allowed, false = system-enforced).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryFilter rdf:type rdf:Property ;
    rdfs:label 'Product Category Filter' ;
    rdfs:comment 'Product category or categories to which this allocation rule applies. Null indicates rule applies to all categories.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Method for rounding fractional allocation quantities (round up, round down, round to nearest, or no rounding).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the allocation rule logic, business purpose, and application context.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Business owner or team responsible for maintaining and governing this allocation rule.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the allocation rule (active and in use, inactive, draft/pending approval, temporarily suspended, archived).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version number of this allocation rule, incremented with each modification to support change tracking and audit.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Reserve Percentage' ;
    rdfs:comment 'Percentage of inventory to reserve as safety stock and exclude from allocation calculations (0.00 to 100.00).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemOfRecord rdf:type rdf:Property ;
    rdfs:label 'System Of Record' ;
    rdfs:comment 'Source system where this allocation rule is defined and maintained (e.g., SAP S/4HANA, OMS, WMS).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'Name of the internal account manager responsible for this trading partner relationship.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether the trading partner has provided required compliance certifications (e.g., social compliance, environmental standards).' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI identifier or interchange ID used to route electronic transactions to the trading partner.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI messaging standard used by the trading partner for electronic transactions.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 standard 13-digit identifier for physical locations and legal entities used in EDI and supply chain transactions.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Name of the preferred shipping carrier for deliveries to this trading partner.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToLocationCount rdf:type rdf:Property ;
    rdfs:label 'Ship To Location Count' ;
    rdfs:comment 'Number of active ship-to locations associated with this trading partner.' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number for the trading partner (e.g., EIN, VAT number).' ;
    rdfs:domain ind:TradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the sales order associated with this installment plan.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:amountOutstanding rdf:type rdf:Property ;
    rdfs:label 'Amount Outstanding' ;
    rdfs:comment 'Remaining balance owed on the installment plan, including principal, interest, and fees.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount paid by the customer to date across all completed installments.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for installments. True if auto-pay is active, false if manual payments required.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedInstallments rdf:type rdf:Property ;
    rdfs:label 'Completed Installments' ;
    rdfs:comment 'Number of installment payments that have been successfully completed and received.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial down payment amount paid at plan origination, if applicable. Zero if no down payment required.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Down Payment Date' ;
    rdfs:comment 'Date when the down payment was received, if applicable.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyPayoffAllowed rdf:type rdf:Property ;
    rdfs:label 'Early Payoff Allowed' ;
    rdfs:comment 'Indicates whether the customer is permitted to pay off the remaining balance early without penalty. True if early payoff is allowed, false if restricted.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyPayoffPenalty rdf:type rdf:Property ;
    rdfs:label 'Early Payoff Penalty' ;
    rdfs:comment 'Penalty fee charged if the customer pays off the installment plan before the scheduled final payment date. Zero if no penalty applies.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'Scheduled date for the final installment payment, representing plan maturity.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingPartner rdf:type rdf:Property ;
    rdfs:label 'Financing Partner' ;
    rdfs:comment 'Name of the third-party financing partner or BNPL provider facilitating the installment plan (e.g., Affirm, Klarna, Afterpay). Null if financed internally.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'Scheduled date for the first installment payment.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the due date before a late fee is assessed or the payment is considered delinquent.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentAmount rdf:type rdf:Property ;
    rdfs:label 'Installment Amount' ;
    rdfs:comment 'Standard amount due for each regular installment payment. Final payment may differ.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate applied to the installment plan, expressed as a decimal (e.g., 0.0599 for 5.99% APR). Zero for interest-free plans.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Standard late fee charged when an installment payment is not received within the grace period.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPaymentsCount rdf:type rdf:Property ;
    rdfs:label 'Missed Payments Count' ;
    rdfs:comment 'Total number of installment payments that were missed or not received by the due date.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Date when the next installment payment is due.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerPlanCode rdf:type rdf:Property ;
    rdfs:label 'Partner Plan Code' ;
    rdfs:comment 'External identifier assigned by the financing partner for this installment plan, used for reconciliation and partner API integration.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which installment payments are scheduled: weekly, biweekly (every two weeks), monthly, quarterly, or custom interval.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'Original principal amount financed through the installment plan, excluding interest and fees.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingInstallments rdf:type rdf:Property ;
    rdfs:label 'Remaining Installments' ;
    rdfs:comment 'Number of installment payments still outstanding in the plan.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAcceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Timestamp' ;
    rdfs:comment 'Date and time when the customer accepted the installment plan terms and conditions.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFees rdf:type rdf:Property ;
    rdfs:label 'Total Fees' ;
    rdfs:comment 'Total administrative, processing, or late fees associated with the installment plan.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInterest rdf:type rdf:Property ;
    rdfs:label 'Total Interest' ;
    rdfs:comment 'Total interest charges to be paid over the life of the installment plan.' ;
    rdfs:domain ind:InstallmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Reference to the production order or work order for which this marker was created.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:cadSystemName rdf:type rdf:Property ;
    rdfs:label 'Cad System Name' ;
    rdfs:comment 'Name of the CAD software system used to create the marker, such as Gerber, Lectra, or Optitex.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuttingTableWidthCm rdf:type rdf:Property ;
    rdfs:label 'Cutting Table Width Cm' ;
    rdfs:comment 'Width of the cutting table for which this marker is optimized, ensuring compatibility with factory equipment.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricConsumptionPerGarment rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Per Garment' ;
    rdfs:comment 'Amount of fabric required to produce one garment based on this marker, measured in meters or yards depending on business unit of measure.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricFoldType rdf:type rdf:Property ;
    rdfs:label 'Fabric Fold Type' ;
    rdfs:comment 'Type of fabric fold configuration used when laying the marker for cutting operations.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricGrainDirection rdf:type rdf:Property ;
    rdfs:label 'Fabric Grain Direction' ;
    rdfs:comment 'Primary grain direction of the fabric used in the marker layout, critical for pattern alignment and garment drape.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Fabric Unit Of Measure' ;
    rdfs:comment 'Unit of measurement used for fabric consumption and marker dimensions.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Utilization Percentage' ;
    rdfs:comment 'Efficiency metric representing the percentage of fabric area utilized by pattern pieces within the marker, calculated as (pattern area / marker area) * 100.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricWastagePercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Wastage Percentage' ;
    rdfs:comment 'Percentage of fabric area that is wasted (not utilized) in the marker layout, calculated as 100 minus fabric utilization percentage.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garmentQuantityPerMarker rdf:type rdf:Property ;
    rdfs:label 'Garment Quantity Per Marker' ;
    rdfs:comment 'Number of complete garments that can be cut from one marker repeat.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markerCreationMethod rdf:type rdf:Property ;
    rdfs:label 'Marker Creation Method' ;
    rdfs:comment 'Method or system used to create the marker layout, indicating whether it was manually created, designed using CAD software, or generated automatically.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerLengthCm rdf:type rdf:Property ;
    rdfs:label 'Marker Length Cm' ;
    rdfs:comment 'Total length of the marker layout measured in centimeters, representing the fabric length required for one marker repeat.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markerName rdf:type rdf:Property ;
    rdfs:label 'Marker Name' ;
    rdfs:comment 'Human-readable name or title for the marker layout, typically describing the style and size combination.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerNotes rdf:type rdf:Property ;
    rdfs:label 'Marker Notes' ;
    rdfs:comment 'Additional notes, instructions, or comments related to the marker layout, cutting process, or special handling requirements.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerNumber rdf:type rdf:Property ;
    rdfs:label 'Marker Number' ;
    rdfs:comment 'Business identifier for the marker used in production planning and fabric cutting operations. Externally visible reference number.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerStatus rdf:type rdf:Property ;
    rdfs:label 'Marker Status' ;
    rdfs:comment 'Current lifecycle status of the marker in the production workflow.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerType rdf:type rdf:Property ;
    rdfs:label 'Marker Type' ;
    rdfs:comment 'Classification of the marker based on its intended use and size configuration.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerVersion rdf:type rdf:Property ;
    rdfs:label 'Marker Version' ;
    rdfs:comment 'Version number of the marker layout, used to track revisions and improvements over time.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerWidthCm rdf:type rdf:Property ;
    rdfs:label 'Marker Width Cm' ;
    rdfs:comment 'Width of the marker layout measured in centimeters, corresponding to the usable fabric width.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nestingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Nesting Algorithm' ;
    rdfs:comment 'Name or identifier of the algorithm used to optimize pattern piece placement within the marker to maximize fabric utilization.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pliesCount rdf:type rdf:Property ;
    rdfs:label 'Plies Count' ;
    rdfs:comment 'Number of fabric layers (plies) that can be stacked and cut simultaneously using this marker.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPiecesCount rdf:type rdf:Property ;
    rdfs:label 'Total Pieces Count' ;
    rdfs:comment 'Total number of individual pattern pieces arranged within the marker layout.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricTypeId rdf:type rdf:Property ;
    rdfs:label 'Fabric Type Id' ;
    rdfs:comment 'Reference to the fabric type classification (e.g., cotton, polyester, denim, jersey). Links to fabric_type reference table.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricType .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the purchase order under which this fabric roll was procured. Links to purchase_order table.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPurchaseOrder .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, rack, or shelf location within the warehouse where the fabric roll is stored. Used for inventory picking and cycle counting.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certification rdf:type rdf:Property ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Quality or sustainability certifications held by the fabric (e.g., OEKO-TEX Standard 100, GOTS, BCI, Bluesign). Used for compliance and marketing claims.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:composition rdf:type rdf:Property ;
    rdfs:label 'Composition' ;
    rdfs:comment 'Detailed fiber content composition of the fabric (e.g., 100% Cotton, 60% Cotton 40% Polyester, 95% Polyester 5% Spandex). Required for labeling compliance.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectPoints rdf:type rdf:Property ;
    rdfs:label 'Defect Points' ;
    rdfs:comment 'Total defect points calculated using the Four Point System or similar fabric inspection methodology. Lower points indicate higher quality.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsm rdf:type rdf:Property ;
    rdfs:label 'Gsm' ;
    rdfs:comment 'Fabric weight per unit area measured in grams per square meter. Key specification for fabric quality and performance characteristics.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harmonizedCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Code' ;
    rdfs:comment 'Harmonized System tariff classification code for the fabric. Used for customs declarations, duty calculations, and international trade compliance.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectedBy rdf:type rdf:Property ;
    rdfs:label 'Inspected By' ;
    rdfs:comment 'Name or identifier of the quality inspector who performed the fabric inspection. Used for accountability and quality audit trails.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Total length of fabric on the roll measured in meters. Used for inventory planning and cutting calculations.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rollNumber rdf:type rdf:Property ;
    rdfs:label 'Roll Number' ;
    rdfs:comment 'Externally-known unique identifier assigned to the fabric roll by the supplier or manufacturer. Used for tracking and traceability across the supply chain.' ;
    rdfs:domain ind:FabricRoll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchPercentage rdf:type rdf:Property ;
    rdfs:label 'Stretch Percentage' ;
    rdfs:comment 'Percentage of stretch or elasticity in the fabric. Important for fit and comfort specifications in garment construction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Hour' ;
    rdfs:comment 'Standard production capacity of the line measured in units (garments, pieces, or items) that can be produced per hour under normal operating conditions.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Standard time required in minutes to change over the production line from one product style or order to another, critical for production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the production line was first commissioned and became operational for production activities.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficiencyTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Efficiency Target Percentage' ;
    rdfs:comment 'Target operational efficiency percentage for this production line, representing the expected ratio of actual output to standard capacity.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours required to produce one unit of output on this production line, used for sustainability tracking and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental certifications or sustainability standards applicable to this production line (e.g., ISO 14001, LEED, carbon-neutral certification).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFlexibleLine rdf:type rdf:Property ;
    rdfs:label 'Is Flexible Line' ;
    rdfs:comment 'Indicates whether this production line is configured for flexible manufacturing, capable of quick changeovers between different product styles or categories.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major equipment upgrade, technology refresh, or significant capacity enhancement to the production line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Externally-known unique business identifier for the production line, used across manufacturing systems and factory floor documentation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line measured in meters, relevant for layout planning and material flow optimization.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name or designation of the production line, typically reflecting location or product category (e.g., \'Knitting Line A\', \'Cut-Make-Trim Line 3\').' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedMaintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Schedule' ;
    rdfs:comment 'Frequency of scheduled preventive maintenance activities for this production line to ensure optimal performance and minimize downtime.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Target Percentage' ;
    rdfs:comment 'Target quality pass rate or first-time-right percentage for products manufactured on this line, used for quality performance monitoring.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLaborCostPerHour rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Cost Per Hour' ;
    rdfs:comment 'Standard labor cost rate per hour for operating this production line, used for production costing and variance analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardOverheadRate rdf:type rdf:Property ;
    rdfs:label 'Standard Overhead Rate' ;
    rdfs:comment 'Standard manufacturing overhead allocation rate applied to production on this line, expressed as a decimal multiplier or percentage.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Level' ;
    rdfs:comment 'Classification of the automation and technology sophistication level of the production line equipment and processes.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCategory rdf:type rdf:Property ;
    rdfs:label 'Production Category' ;
    rdfs:comment 'Primary product category that this delivery window is designed to support in the manufacturing schedule.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Required' ;
    rdfs:comment 'Indicates whether PP (Pre-Production) sample approval is mandatory before bulk production can proceed within this delivery window.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetShipDate rdf:type rdf:Property ;
    rdfs:label 'Target Ship Date' ;
    rdfs:comment 'The planned date when finished goods should ship from the manufacturing facility to meet the delivery window commitment.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowCode rdf:type rdf:Property ;
    rdfs:label 'Window Code' ;
    rdfs:comment 'Business identifier code for the delivery window, used for external reference and communication with manufacturing partners and logistics providers.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Human-readable name or label for the delivery window (e.g., \'Spring 2024 Early\', \'Holiday Rush Window\', \'Q3 Bulk Production\').' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Classification of the delivery window based on production urgency and business purpose. Standard for regular production cycles, expedited for rush orders, seasonal for collection launches, bulk for large volume runs, sample for PP (Pre-Production) samples.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilitySchedule rdf:type rdf:Property ;
