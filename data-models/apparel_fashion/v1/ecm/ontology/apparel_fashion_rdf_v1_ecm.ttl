ind:recordedByUser rdf:type rdf:Property ;
    rdfs:label 'Recorded By User' ;
    rdfs:comment 'Username or identifier of the system user or automated process that recorded this milestone event.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyCode rdf:type rdf:Property ;
