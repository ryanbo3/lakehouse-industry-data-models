    rdfs:comment 'Indicates whether the fabric has been treated to resist ignition and slow flame spread.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handFeel rdf:type rdf:Property ;
    rdfs:label 'Hand Feel' ;
    rdfs:comment 'Subjective assessment of the fabric\'s tactile quality and drape characteristics.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantityYards rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Yards' ;
    rdfs:comment 'The minimum quantity of fabric that must be ordered from suppliers, expressed in linear yards.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureWicking rdf:type rdf:Property ;
    rdfs:label 'Moisture Wicking' ;
    rdfs:comment 'Indicates whether the fabric has moisture-wicking properties to draw perspiration away from the body.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pillingResistance rdf:type rdf:Property ;
    rdfs:label 'Pilling Resistance' ;
    rdfs:comment 'The fabric\'s ability to resist the formation of surface pills or fuzz balls during wear and laundering.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
