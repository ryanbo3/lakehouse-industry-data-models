    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or subsidiary to which this pay period applies.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequencyType rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency Type' ;
    rdfs:comment 'The frequency at which employees are paid during this period (weekly, bi-weekly, semi-monthly, monthly).' ;
