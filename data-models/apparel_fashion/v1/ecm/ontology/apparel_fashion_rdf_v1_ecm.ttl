    rdfs:comment 'Indicates whether the organization has tax-exempt status.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityIdentifier rdf:type rdf:Property ;
