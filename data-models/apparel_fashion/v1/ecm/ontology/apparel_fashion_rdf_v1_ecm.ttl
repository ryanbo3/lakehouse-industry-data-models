    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Percentage of fuel surcharge applied to base rate when applicable. Nullable if not applicable.' ;
