    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'The trade name or brand name under which the organization operates, if different from the legal name.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month (1-12) in which the organization\'s fiscal year ends.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standard industry classification code (e.g., NAICS, SIC) that categorizes the organization\'s primary business activity.' ;
