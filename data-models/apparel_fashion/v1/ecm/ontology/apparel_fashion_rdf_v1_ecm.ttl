    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBusinessDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Business Description' ;
    rdfs:comment 'A textual description of the organization\'s primary business activities and operations.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Registration Authority' ;
