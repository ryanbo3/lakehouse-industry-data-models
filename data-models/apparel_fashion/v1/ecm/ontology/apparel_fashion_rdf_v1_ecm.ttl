ind:nextScheduledInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inventory Date' ;
    rdfs:comment 'The date scheduled for the next physical inventory count or cycle count within this valuation area.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
