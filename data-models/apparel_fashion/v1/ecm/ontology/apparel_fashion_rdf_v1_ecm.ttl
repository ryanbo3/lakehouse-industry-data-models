ind:neverOutOfStockFlag rdf:type rdf:Property ;
    rdfs:label 'Never Out Of Stock Flag' ;
    rdfs:comment 'Indicates whether this valuation area follows a never-out-of-stock strategy for critical SKUs to ensure continuous availability.' ;
    rdfs:domain ind:ValuationArea ;
