ind:capNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Number' ;
    rdfs:comment 'Business-facing unique identifier for the corrective action plan, used in communications with suppliers, factories, and internal teams.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capTitle rdf:type rdf:Property ;
    rdfs:label 'Cap Title' ;
    rdfs:comment 'Brief descriptive title summarizing the corrective action plan focus area or issue being addressed.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Primary compliance domain or category of the corrective action: labor standards, health and safety, environmental, product safety, trade compliance, or ethical sourcing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the remediation steps, actions, and measures required to address the non-conformance and prevent recurrence.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action plan: open (newly issued), in progress (being implemented), pending verification (awaiting inspection), verified (confirmed complete), closed (fully resolved), overdue (past target date), escalated (requires management intervention). [ENUM-REF-CANDIDATE: open|in_progress|pending_verification|verified|closed|overdue|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost to implement the corrective action, including materials, labor, training, and any infrastructure improvements required.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the corrective action plan was escalated to higher management levels. Null if no escalation has occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the corrective action plan has been escalated to senior management or executive leadership due to severity, delays, or non-compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the corrective action plan was escalated, such as repeated non-compliance, critical safety risk, or failure to meet deadlines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingId rdf:type rdf:Property ;
    rdfs:label 'Finding Id' ;
    rdfs:comment 'Reference to the specific audit finding or non-conformance that triggered this corrective action plan.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of the business, operational, and reputational impact of the non-conformance and the expected benefits of the corrective action.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed description of the non-conformance, violation, or deficiency identified during the audit that requires corrective action.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMeasures rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures' ;
    rdfs:comment 'Description of preventive measures and systemic changes implemented to prevent recurrence of the non-conformance in the future.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContactEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Email' ;
    rdfs:comment 'Email address of the primary contact person responsible for corrective action implementation and reporting.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContactName rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the responsible party organization who is accountable for corrective action execution.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContactPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person responsible for corrective action execution.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Type of entity responsible for implementing the corrective action: factory, supplier, internal team, third-party vendor, or logistics partner.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause of the non-conformance or violation, identifying systemic issues rather than symptoms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or agreed-upon date by which the corrective action must be completed and verified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when required training was completed as part of the corrective action. Null if training is not required or not yet completed.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether employee or supplier training is required as part of the corrective action plan implementation.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the auditor, compliance officer, or third-party inspector who verified the corrective action completion.' ;
    rdfs:domain ind:CorrectiveActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcLabelId rdf:type rdf:Property ;
    rdfs:label 'Ftc Label Id' ;
    rdfs:comment 'Unique identifier for the FTC-compliant textile and apparel label record. Primary key for the label master data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtcLabel .

ind:ecolabelId rdf:type rdf:Property ;
    rdfs:label 'Ecolabel Id' ;
    rdfs:comment 'Foreign key linking to sustainability.ecolabel. Business justification: FTC labels and ecolabels (GOTS, Cradle to Cradle, EU Ecolabel) both appear on product packaging and hangtags. Linking enables unified label compliance verification, prevents conflicting environmental ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ecolabel .

ind:labelingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.labeling_requirement. Business justification: FTC labels implement country-specific labeling requirements. This FK links the label design to the requirement it satisfies, enabling verification that labels comply with jurisdiction-specific rules. ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelingRequirement .

ind:supersededByLabelFtcLabelId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Label Ftc Label Id' ;
    rdfs:comment 'Reference to the newer label that replaces this label. Used to track label revision history and ensure proper version control. Null for current active labels.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FtcLabel .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the label received final approval for production and use. Marks transition from legal_review to approved status.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:careInstructions rdf:type rdf:Property ;
    rdfs:label 'Care Instructions' ;
    rdfs:comment 'Complete care instructions for the product including washing, bleaching, drying, ironing, and dry cleaning guidance as required by the Care Labeling Rule. Must include at least one safe cleaning method.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careSymbolCode rdf:type rdf:Property ;
    rdfs:label 'Care Symbol Code' ;
    rdfs:comment 'Standardized care symbol codes following ASTM D5489 international care labeling system. Represents washing, bleaching, drying, ironing, and professional care symbols in sequence.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the product was manufactured, processed, or assembled as required by FTC country of origin marking requirements and customs regulations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginStatement rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Statement' ;
    rdfs:comment 'Full country of origin disclosure statement as it appears on the label. Example: \'Made in USA\', \'Imported\', \'Made in China\', \'Assembled in Mexico from imported materials\'.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Down Content Percentage' ;
    rdfs:comment 'Percentage by weight of down fill content. Required disclosure for products containing down fill. Null if product contains no down.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downFeatherIndicator rdf:type rdf:Property ;
    rdfs:label 'Down Feather Indicator' ;
    rdfs:comment 'Indicates whether the product contains down or feather fill and requires down/feather content disclosure per FTC guidelines.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiberContentDescription rdf:type rdf:Property ;
    rdfs:label 'Fiber Content Description' ;
    rdfs:comment 'Complete fiber content disclosure listing all constituent fibers by generic name and percentage by weight in descending order, as required by the Textile Fiber Products Identification Act. Example: \'60% Cotton, 40% Polyester\'.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flammabilityStandardCode rdf:type rdf:Property ;
    rdfs:label 'Flammability Standard Code' ;
    rdfs:comment 'Applicable flammability standard code for the product. 16CFR1610 for general wearing apparel, 16CFR1615/1616 for childrens sleepwear. Required for products subject to CPSC flammability regulations.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flammabilityTestResult rdf:type rdf:Property ;
    rdfs:label 'Flammability Test Result' ;
    rdfs:comment 'Result of flammability testing per applicable CPSC standards. Pass indicates compliance with flammability requirements. Required for childrens sleepwear and certain textile products.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:furAnimalName rdf:type rdf:Property ;
    rdfs:label 'Fur Animal Name' ;
    rdfs:comment 'True English name of the animal producing the fur, as required by the Fur Products Labeling Act. Example: \'Rabbit\', \'Fox\', \'Mink\'. Null if product contains no fur.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:furProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Fur Product Indicator' ;
    rdfs:comment 'Indicates whether the product contains fur and is subject to the Fur Products Labeling Act requirements.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelLanguage rdf:type rdf:Property ;
    rdfs:label 'Label Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the primary language of the label text. Multiple languages may require separate label records.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelNumber rdf:type rdf:Property ;
    rdfs:label 'Label Number' ;
    rdfs:comment 'Business identifier for the label used for tracking and reference across product lifecycle management and compliance systems.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelStatus rdf:type rdf:Property ;
    rdfs:label 'Label Status' ;
    rdfs:comment 'Current lifecycle status of the label in the approval workflow. Tracks progression from draft through legal review to active use and eventual retirement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelType rdf:type rdf:Property ;
    rdfs:label 'Label Type' ;
    rdfs:comment 'Physical format and construction method of the label (woven fabric label, printed label, heat transfer, hang tag, sewn-in label, or adhesive label).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal review of the label was completed and compliance with FTC regulations was verified.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name of the legal or compliance professional who reviewed and approved the label for regulatory compliance.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Identifier Type' ;
    rdfs:comment 'Type of manufacturer or importer identification used on the label: RN (Registered Identification Number), WPL (Wool Products Labeling number), or full company name.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Full legal name of the manufacturer, importer, or other business responsible for the product. Used when RN/WPL number is not provided on the label.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oekoTexCertified rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Certified' ;
    rdfs:comment 'Indicates whether the product is certified under OEKO-TEX Standard 100 for textile safety and absence of harmful substances.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertificationIndicator rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Indicator' ;
    rdfs:comment 'Indicates whether the product carries organic certification (GOTS, USDA Organic, or other recognized organic standard) and requires organic content disclosure.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryFiberPercentage rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Percentage' ;
    rdfs:comment 'Percentage by weight of the primary fiber constituent. Must be accurate within tolerances specified by FTC regulations (typically +/- 3% for fibers over 15%, +/- 2% for fibers under 15%).' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFiberType rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Type' ;
    rdfs:comment 'The predominant fiber type by weight percentage. Used for reporting and categorization purposes.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recycledContentIndicator rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Indicator' ;
    rdfs:comment 'Indicates whether the product contains recycled fiber content and requires recycled content disclosure per FTC Green Guides.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recycledContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percentage' ;
    rdfs:comment 'Percentage by weight of recycled fiber content (pre-consumer or post-consumer). Required for substantiation of recycled content claims.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number for the label. Increments with each approved change to fiber content, care instructions, or other regulated content.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason for creating a new revision of the label. Examples: fiber content change, country of origin change, regulatory requirement update, care instruction correction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rnNumber rdf:type rdf:Property ;
    rdfs:label 'Rn Number' ;
    rdfs:comment 'FTC-issued Registered Identification Number that identifies the manufacturer, importer, or other business responsible for the product. Format: RN followed by 5-6 digits.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woolContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Wool Content Percentage' ;
    rdfs:comment 'Percentage by weight of wool fiber content. Required disclosure for products subject to Wool Products Labeling Act. Null if product contains no wool.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:woolProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Wool Product Indicator' ;
    rdfs:comment 'Indicates whether the product contains wool fiber and is subject to the Wool Products Labeling Act requirements. True if product contains any wool content.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wplNumber rdf:type rdf:Property ;
    rdfs:label 'Wpl Number' ;
    rdfs:comment 'Legacy FTC-issued Wool Products Labeling number (discontinued in 1998 but still valid for existing registrations). Format: WPL followed by 4-5 digits.' ;
    rdfs:domain ind:FtcLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Labeling requirements vary by product category (children\'s sleepwear has different flammability labeling than adult outerwear). Compliance teams map labeling requirements to product categories for lab' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:supersededByRequirementLabelingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Labeling Requirement Id' ;
    rdfs:comment 'Reference to the labeling requirement that supersedes this one, if this requirement has been replaced by a newer version.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelingRequirement .

ind:ageGroup rdf:type rdf:Property ;
    rdfs:label 'Age Group' ;
    rdfs:comment 'Target age group for which this labeling requirement applies, as certain regulations differ for children\'s versus adult apparel.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careInstructionRequired rdf:type rdf:Property ;
    rdfs:label 'Care Instruction Required' ;
    rdfs:comment 'Indicates whether care and maintenance instructions must be provided on the label.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:careSymbolStandard rdf:type rdf:Property ;
    rdfs:label 'Care Symbol Standard' ;
    rdfs:comment 'International or regional standard for care symbols that must be used, such as ISO 3758 or ASTM D5489.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginFormat rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Format' ;
    rdfs:comment 'Prescribed wording or format for the country of origin statement, such as \'Made in [Country]\' or \'Product of [Country]\'.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginRequired rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Required' ;
    rdfs:comment 'Indicates whether the country of origin must be disclosed on the product label.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalClaimStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Claim Standard' ;
    rdfs:comment 'Standard or guideline that must be followed when making environmental claims on labels, such as FTC Green Guides or ISO 14021.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberContentFormat rdf:type rdf:Property ;
    rdfs:label 'Fiber Content Format' ;
    rdfs:comment 'Prescribed format or template for displaying fiber content information on the label, including ordering rules and percentage thresholds.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberContentRequired rdf:type rdf:Property ;
    rdfs:label 'Fiber Content Required' ;
    rdfs:comment 'Indicates whether disclosure of fiber content percentages is mandatory under this requirement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flammabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Flammability Standard' ;
    rdfs:comment 'Flammability testing standard that products must meet, such as 16 CFR Part 1610 for general wearing apparel or 16 CFR Part 1615 for children\'s sleepwear.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fontSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Font Size Minimum' ;
    rdfs:comment 'Minimum font size in points or millimeters required for label text to ensure readability.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes or comments regarding the interpretation, implementation, or special considerations for this labeling requirement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPermanence rdf:type rdf:Property ;
    rdfs:label 'Label Permanence' ;
    rdfs:comment 'Requirement for how the label must be attached, such as permanently sewn, printed, or allowed as a removable hang tag.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPlacement rdf:type rdf:Property ;
    rdfs:label 'Label Placement' ;
    rdfs:comment 'Prescribed location or placement requirements for the label on the garment, such as inside neck, side seam, or permanently attached.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequired rdf:type rdf:Property ;
    rdfs:label 'Language Required' ;
    rdfs:comment 'Language or languages in which label information must be presented, such as English, French, Spanish, or local language requirements.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerIdRequired rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Id Required' ;
    rdfs:comment 'Indicates whether the manufacturer or responsible party must be identified on the label.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerIdType rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Id Type' ;
    rdfs:comment 'Type of manufacturer identification that must be displayed, such as Registered Number (RN), Wool Products Labeling (WPL) number, or full company name and address.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Required' ;
    rdfs:comment 'Indicates whether organic certification information must be displayed if the product claims to be organic.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the maximum penalty amount.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recycledContentDisclosure rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Disclosure' ;
    rdfs:comment 'Indicates whether recycled material content must be disclosed on the label if present.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Url' ;
    rdfs:comment 'Web URL linking to the official regulatory text, guidance document, or authoritative source for this labeling requirement.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Business identifier code for the labeling requirement, used for external reference and cross-system identification.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementName rdf:type rdf:Property ;
    rdfs:label 'Requirement Name' ;
    rdfs:comment 'Human-readable name of the labeling requirement, describing the specific regulation or standard.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle status of the labeling requirement indicating whether it is currently enforceable.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Classification of the labeling requirement by regulatory category.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which this labeling requirement should be reviewed for regulatory changes or updates.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyWarningRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Warning Required' ;
    rdfs:comment 'Indicates whether safety warnings or hazard notices must be included on the label, particularly for children\'s products or items with specific risks.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyWarningText rdf:type rdf:Property ;
    rdfs:label 'Safety Warning Text' ;
    rdfs:comment 'Prescribed text for mandatory safety warnings, such as choking hazard notices or flammability warnings.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeLabelingRequired rdf:type rdf:Property ;
    rdfs:label 'Size Labeling Required' ;
    rdfs:comment 'Indicates whether size information must be displayed on the label.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeStandard rdf:type rdf:Property ;
    rdfs:label 'Size Standard' ;
    rdfs:comment 'International or regional sizing standard that must be followed, such as ISO 3635 for clothing sizes or country-specific sizing conventions.' ;
    rdfs:domain ind:LabelingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSafetyTestId rdf:type rdf:Property ;
    rdfs:label 'Product Safety Test Id' ;
    rdfs:comment 'Unique identifier for the product safety test record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSafetyTest .

ind:cadFileId rdf:type rdf:Property ;
    rdfs:label 'Cad File Id' ;
    rdfs:comment 'Foreign key linking to design.cad_file. Business justification: Safety testing references specific CAD files for construction details affecting test outcomes (drawstring length, small parts, fabric layering for flammability). Essential for traceability when tests ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CadFile .

ind:chemicalComplianceId rdf:type rdf:Property ;
    rdfs:label 'Chemical Compliance Id' ;
    rdfs:comment 'Foreign key linking to sustainability.chemical_compliance. Business justification: Safety testing and chemical compliance testing often use same samples, labs, and test methods (e.g., CPSIA lead testing overlaps with ZDHC MRSL screening). Linking enables unified chemical risk manage' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalCompliance .

ind:colorwayId rdf:type rdf:Property ;
    rdfs:label 'Colorway Id' ;
    rdfs:comment 'Foreign key linking to product.colorway. Business justification: Safety tests (lead content, phthalates, azo dyes, flammability) are conducted on specific colorways because dyes and finishes can introduce restricted substances. QA/compliance teams test each colorwa' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Colorway .

ind:productSampleId rdf:type rdf:Property ;
    rdfs:label 'Product Sample Id' ;
    rdfs:comment 'Unique identifier of the physical sample submitted for testing. Enables traceability to the specific unit tested.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSample .

ind:testingLaboratoryVendorId rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory Vendor Id' ;
    rdfs:comment 'Identifier of the accredited laboratory that performed the safety test.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether this test is required for a formal certification (e.g., OEKO-TEX, CPSC compliance certificate).' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional notes, observations, or context related to the safety test.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the test failed, including specific non-conformance details.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Production Batch Number' ;
    rdfs:comment 'Batch or lot number of the production run from which the test sample was drawn.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction or market for which this test was conducted (e.g., USA, EU, China). Determines applicable regulatory standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective action plan to address test failures or non-conformances.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation actions must be completed.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Indicates whether corrective action is required based on the test result.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Scheduled or actual date for retesting the product.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestRequired rdf:type rdf:Property ;
    rdfs:label 'Retest Required' ;
    rdfs:comment 'Indicates whether the product must be retested after remediation or due to inconclusive results.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of units or specimens tested in this safety test.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Season or collection identifier for which the product was tested (e.g., SS24, FW24).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Test Approved By' ;
    rdfs:comment 'Name or identifier of the quality manager or compliance officer who approved the test results.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Test Approved Date' ;
    rdfs:comment 'Date on which the test results were formally approved by the quality or compliance team.' ;
    rdfs:domain ind:ProductSafetyTest ;
    rdf:type owl:DatatypeProperty ;
