    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:destinationLocationDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Center Id' ;
    rdfs:comment 'Identifier for the destination location (warehouse, distribution center, store, or port) where shipments end.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Standard base freight rate for this lane before surcharges and adjustments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume Cbm' ;
    rdfs:comment 'Maximum volumetric capacity available on this lane per shipment cycle, measured in cubic meters.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance of the lane route measured in kilometers.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved' ;
    rdfs:comment 'Indicates whether this lane is approved for transporting hazardous materials.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landedDutyPaid rdf:type rdf:Property ;
    rdfs:label 'Landed Duty Paid' ;
    rdfs:comment 'Indicates whether the lane rate includes all duties, taxes, and customs fees (LDP calculation).' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Business identifier code for the lane, typically combining origin and destination codes.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable name of the shipping lane, typically origin to destination description.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the lane based on geographic scope and routing characteristics.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRateUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Rate Update Date' ;
    rdfs:comment 'Date when the lane rate was last updated or renegotiated.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit of measure basis for the lane rate calculation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomsClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Customs Clearance' ;
    rdfs:comment 'Indicates whether shipments on this lane require customs clearance procedures.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingGuidePriority rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Priority' ;
    rdfs:comment 'Priority ranking of this lane in the routing guide for shipment allocation decisions.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaOnTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Pct' ;
    rdfs:comment 'Target percentage for on-time delivery performance as defined in the carrier SLA for this lane.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Standard transit time for shipments on this lane, measured in days.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAmbassadorProgram rdf:type rdf:Property ;
    rdfs:label 'Brand Ambassador Program' ;
    rdfs:comment 'Indicates whether the brand operates an active brand ambassador or influencer partnership program.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandAwarenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Brand Awareness Percentage' ;
    rdfs:comment 'Percentage of the target market that has awareness or recognition of the brand, measured through market research.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandColorPrimary rdf:type rdf:Property ;
    rdfs:label 'Brand Color Primary' ;
    rdfs:comment 'The primary brand color represented as a hexadecimal color code used in marketing and visual identity.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandColorSecondary rdf:type rdf:Property ;
    rdfs:label 'Brand Color Secondary' ;
    rdfs:comment 'The secondary brand color represented as a hexadecimal color code used in marketing and visual identity.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandEquityScore rdf:type rdf:Property ;
