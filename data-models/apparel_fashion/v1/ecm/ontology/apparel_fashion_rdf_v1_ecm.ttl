    rdfs:comment 'Strategic zone within the store where this planogram is intended to be placed for optimal customer engagement.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPlanogramId rdf:type rdf:Property ;
    rdfs:label 'Parent Planogram Id' ;
