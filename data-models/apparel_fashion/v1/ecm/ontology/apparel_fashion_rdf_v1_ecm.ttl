    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for minimum shipment volume (cartons, pallets, kilograms, pounds, cubic meters, cubic feet).' ;
