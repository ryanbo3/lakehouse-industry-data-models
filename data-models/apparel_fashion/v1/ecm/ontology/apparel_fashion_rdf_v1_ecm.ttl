    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodName rdf:type rdf:Property ;
    rdfs:label 'Pay Period Name' ;
    rdfs:comment 'Human-readable name or label for the pay period (e.g., \'PP01-2024\', \'January 2024 - Period 1\').' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Pay Period Number' ;
    rdfs:comment 'Sequential number of the pay period within the fiscal or calendar year (e.g., 1, 2, 3...26 for bi-weekly).' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Processing Date' ;
    rdfs:comment 'The date on which payroll calculations and processing are executed for this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timesheetDueDate rdf:type rdf:Property ;
    rdfs:label 'Timesheet Due Date' ;
    rdfs:comment 'The deadline by which employees must submit timesheets for this pay period.' ;
