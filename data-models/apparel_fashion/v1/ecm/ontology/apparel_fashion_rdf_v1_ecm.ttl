ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_target. Business justification: Compliance obligations (EU Green Deal, plastic packaging taxes, Extended Producer Responsibility) drive sustainability targets with regulatory deadlines. Linking enables regulatory-driven target setti' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Target .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
