    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PR placements managed by internal PR team members require employee tracking for relationship management with journalists, workload balancing, and performance metrics on media value secured per team me' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:articleTitle rdf:type rdf:Property ;
    rdfs:label 'Article Title' ;
    rdfs:comment 'Title of the article, segment, or content piece featuring the brand.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:articleUrl rdf:type rdf:Property ;
    rdfs:label 'Article Url' ;
    rdfs:comment 'Web link to the published article or content (if available online).' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedTraffic rdf:type rdf:Property ;
    rdfs:label 'Attributed Traffic' ;
    rdfs:comment 'Number of website visits or traffic attributed to this PR placement through tracking links or referral analysis.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandProminence rdf:type rdf:Property ;
    rdfs:label 'Brand Prominence' ;
    rdfs:comment 'Level of brand visibility and prominence within the placement (primary focus, secondary mention, tertiary reference).' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionFeatured rdf:type rdf:Property ;
    rdfs:label 'Collection Featured' ;
    rdfs:comment 'Brand collection or seasonal line highlighted in the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Impressions' ;
    rdfs:comment 'Estimated total impressions generated by the PR placement across all distribution channels.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imageCount rdf:type rdf:Property ;
    rdfs:label 'Image Count' ;
    rdfs:comment 'Number of brand or product images included in the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalistEmail rdf:type rdf:Property ;
    rdfs:label 'Journalist Email' ;
    rdfs:comment 'Email address of the journalist or editor for follow-up and relationship management.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessages rdf:type rdf:Property ;
    rdfs:label 'Key Messages' ;
    rdfs:comment 'Primary brand messages, themes, or talking points communicated in the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'Type of media channel for the placement (print, online, broadcast, podcast, social media, blog).' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchDate rdf:type rdf:Property ;
    rdfs:label 'Pitch Date' ;
    rdfs:comment 'Date when the story or placement was initially pitched to the journalist or publication.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date when the PR placement was published or aired.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prAgencyContact rdf:type rdf:Property ;
    rdfs:label 'Pr Agency Contact' ;
    rdfs:comment 'Primary contact person at the PR agency responsible for this placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prAgencyName rdf:type rdf:Property ;
    rdfs:label 'Pr Agency Name' ;
    rdfs:comment 'Name of the external PR agency that secured or facilitated the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFeatured rdf:type rdf:Property ;
    rdfs:label 'Product Featured' ;
    rdfs:comment 'Specific product, SKU, or collection featured in the PR placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryMarkets rdf:type rdf:Property ;
    rdfs:label 'Secondary Markets' ;
    rdfs:comment 'Additional markets or geographies where the placement had distribution or reach, comma-separated country codes.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securedDate rdf:type rdf:Property ;
    rdfs:label 'Secured Date' ;
    rdfs:comment 'Date when the PR placement was confirmed or secured with the publication.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sentiment rdf:type rdf:Property ;
    rdfs:label 'Sentiment' ;
    rdfs:comment 'Overall sentiment tone of the PR placement toward the brand (positive, neutral, negative, mixed).' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareOfVoicePercent rdf:type rdf:Property ;
    rdfs:label 'Share Of Voice Percent' ;
    rdfs:comment 'Percentage of total media coverage or mentions captured by the brand relative to competitors in this placement context.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spokespersonName rdf:type rdf:Property ;
    rdfs:label 'Spokesperson Name' ;
    rdfs:comment 'Name of the brand spokesperson, executive, or representative quoted or featured in the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Video Included Flag' ;
    rdfs:comment 'Indicates whether video content was included in the placement.' ;
    rdfs:domain ind:PrPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleCustomerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Eligible Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Promo codes are often segment-restricted (VIP-only codes, new customer codes, loyalty tier codes). Enforces eligibility rules, tracks segment-specific promotion performance, and enables segment-target' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:affiliateCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Affiliate Commission Rate' ;
    rdfs:comment 'The commission percentage paid to affiliates or influencers for sales generated using this promotional code. Used for commission reconciliation.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableSkus rdf:type rdf:Property ;
    rdfs:label 'Applicable Skus' ;
    rdfs:comment 'Comma-separated list of specific SKU codes that this promotional code can be applied to. Null if category-level restrictions apply instead.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Allocation Amount' ;
    rdfs:comment 'The allocated customer acquisition cost budget for this promotional code, used to calculate CAC and marketing efficiency metrics.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Channel Restrictions' ;
    rdfs:comment 'Specifies which sales channels this promotional code is valid for: all channels, Direct-to-Consumer (DTC) only, e-commerce only, retail stores only, or wholesale excluded.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeName rdf:type rdf:Property ;
    rdfs:label 'Code Name' ;
    rdfs:comment 'Internal descriptive name for the promotional code used for campaign tracking and reporting purposes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Specifies which customer segments are eligible to use this promotional code (e.g., new customers, loyalty members, VIP tier). Null if available to all customers.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The type of discount mechanism applied by this promotional code: percentage off, fixed dollar amount, free shipping, buy-one-get-one, or tiered discount based on order value.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'The numeric value of the discount. For percentage discounts, this is the percentage (e.g., 15.00 for 15% off). For fixed amount discounts, this is the dollar amount.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Excluded Product Categories' ;
    rdfs:comment 'Comma-separated list of product category codes or identifiers that are explicitly excluded from this promotional code. Used to prevent discounts on certain product lines.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedSkus rdf:type rdf:Property ;
    rdfs:label 'Excluded Skus' ;
    rdfs:comment 'Comma-separated list of specific SKU codes that are explicitly excluded from this promotional code, even if their category is included.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCodeReference rdf:type rdf:Property ;
    rdfs:label 'External Code Reference' ;
    rdfs:comment 'The unique identifier for this promotional code in the source system, used for integration and reconciliation purposes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Flag' ;
    rdfs:comment 'Indicates whether this promotional code has been flagged for potential abuse or fraudulent redemption patterns. True if flagged for review, False otherwise.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoCodeCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code Code' ;
    rdfs:comment 'The actual alphanumeric promotional code string that customers enter at checkout to receive a discount. Must be unique and human-readable.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Code Status' ;
    rdfs:comment 'Current lifecycle status of the promotional code: draft (not yet published), active (available for use), paused (temporarily disabled), expired (past validity date), or cancelled (permanently disabled).' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Public Visibility Flag' ;
    rdfs:comment 'Indicates whether this promotional code is publicly advertised or is a private/targeted code. True if public, False if private or invitation-only.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDiscountGiven rdf:type rdf:Property ;
    rdfs:label 'Total Discount Given' ;
    rdfs:comment 'The cumulative discount amount granted across all redemptions of this promotional code. Used for financial reconciliation and campaign cost tracking.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionsCount rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Count' ;
    rdfs:comment 'The cumulative number of times this promotional code has been successfully redeemed to date. Used for tracking against usage limits.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Attributed' ;
    rdfs:comment 'The cumulative gross revenue (before discount) from all orders where this promotional code was successfully applied. Used for campaign ROI measurement.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique identifier for the promotional code redemption event.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing source or touchpoint that led to this promo code redemption (e.g., email, social media, influencer, paid search).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstTimeCustomerFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Customer Flag' ;
    rdfs:comment 'Indicates whether this redemption was by a first-time customer (true) or a returning customer (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderSubtotalAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Subtotal After Discount' ;
    rdfs:comment 'The order subtotal amount after the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSubtotalBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Subtotal Before Discount' ;
    rdfs:comment 'The order subtotal amount before the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderTotalAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total After Discount' ;
    rdfs:comment 'The total order amount including tax and shipping after the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderTotalBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total Before Discount' ;
    rdfs:comment 'The total order amount including tax and shipping before the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The sales channel through which the promo code was redeemed (DTC, e-commerce, retail POS, mobile app, wholesale, call center).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the redemption occurred.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDeviceType rdf:type rdf:Property ;
    rdfs:label 'Redemption Device Type' ;
    rdfs:comment 'The type of device used to redeem the promo code (desktop, mobile, tablet, POS terminal, kiosk, unknown).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Redemption Ip Address' ;
    rdfs:comment 'The IP address from which the promo code redemption was initiated, used for fraud detection and geographic analysis.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Exceeded Flag' ;
    rdfs:comment 'Indicates whether the customer attempted to redeem the promo code beyond the allowed usage limit (true) or within limits (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current status of the promo code redemption (applied, pending, failed, reversed, expired).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the promotional code was redeemed by the customer.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stackingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed Flag' ;
    rdfs:comment 'Indicates whether this promo code was allowed to be stacked with other promotions (true) or not (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heroStyleId rdf:type rdf:Property ;
    rdfs:label 'Hero Style Id' ;
    rdfs:comment 'Foreign key linking to product.style. Business justification: Launches feature hero/signature styles (key looks, statement pieces). Required for launch planning, hero product allocation, PR seeding, and influencer gifting. Complements existing collection_id with' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Style .

ind:launchOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Launch Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Seasonal launches require dedicated cross-functional coordination. Tracking the employee owner enables accountability for launch execution, timeline management, and post-launch performance analysis. L' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetStockPositionId rdf:type rdf:Property ;
    rdfs:label 'Target Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Seasonal launches require coordinated inventory positioning across channels. Real process: launch planning teams monitor stock positions for launch SKUs to ensure sufficient inventory is allocated and' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:dtcFlag rdf:type rdf:Property ;
    rdfs:label 'Dtc Flag' ;
    rdfs:comment 'Indicates whether the launch includes direct-to-consumer channels (owned retail stores, brand e-commerce site). True if DTC is part of the channel mix.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecommerceFlag rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Flag' ;
    rdfs:comment 'Indicates whether the launch includes e-commerce digital storefront activation. True if online sales channels are activated.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:embargoDate rdf:type rdf:Property ;
    rdfs:label 'Embargo Date' ;
    rdfs:comment 'Date and time before which press, influencers, and media partners are restricted from publishing content about the collection. Critical for coordinated PR strategy.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:influencerActivationFlag rdf:type rdf:Property ;
    rdfs:label 'Influencer Activation Flag' ;
    rdfs:comment 'Indicates whether influencer partnerships and content creator collaborations are part of the launch strategy. True if influencer marketing is activated.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchCode rdf:type rdf:Property ;
    rdfs:label 'Launch Code' ;
    rdfs:comment 'Unique business identifier code for the seasonal launch event, used across marketing, merchandising, and e-commerce systems for cross-functional reference.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchName rdf:type rdf:Property ;
    rdfs:label 'Launch Name' ;
    rdfs:comment 'Marketing name of the seasonal launch event (e.g., \'Spring Summer 2025 Runway Show\', \'Fall Winter 2024 Digital Drop\').' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchStatus rdf:type rdf:Property ;
    rdfs:label 'Launch Status' ;
    rdfs:comment 'Current lifecycle status of the seasonal launch event in the go-to-market workflow. [ENUM-REF-CANDIDATE: planning|approved|in_production|ready|live|completed|cancelled|postponed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchTheme rdf:type rdf:Property ;
    rdfs:label 'Launch Theme' ;
    rdfs:comment 'Creative theme or narrative concept for the seasonal launch (e.g., \'Urban Explorer\', \'Coastal Minimalism\', \'Heritage Reimagined\'). Guides creative execution across all touchpoints.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchType rdf:type rdf:Property ;
    rdfs:label 'Launch Type' ;
    rdfs:comment 'Classification of the launch event format and go-to-market activation strategy. [ENUM-REF-CANDIDATE: runway_show|lookbook_drop|digital_launch|pop_up_event|wholesale_preview|influencer_preview|press_preview — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchVideoUrl rdf:type rdf:Property ;
    rdfs:label 'Launch Video Url' ;
    rdfs:comment 'URL link to the hero video content for the seasonal launch (runway show recording, campaign film, behind-the-scenes content). Hosted in DAM or video platform.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookbookUrl rdf:type rdf:Property ;
    rdfs:label 'Lookbook Url' ;
    rdfs:comment 'URL link to the digital lookbook or collection catalog published for the seasonal launch. Hosted in the Digital Asset Management (DAM) system or brand website.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStrategy rdf:type rdf:Property ;
    rdfs:label 'Pr Strategy' ;
    rdfs:comment 'Primary public relations and media strategy employed for the launch event to generate brand awareness and editorial coverage.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Pre Launch Date' ;
    rdfs:comment 'Date for exclusive early access events such as VIP previews, influencer unboxings, or wholesale partner previews before the public launch.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'Primary geographic market for the launch event (e.g., \'USA\', \'GBR\', \'FRA\'). The lead market driving launch strategy and timing.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesaleFlag rdf:type rdf:Property ;
    rdfs:label 'Wholesale Flag' ;
    rdfs:comment 'Indicates whether the launch includes wholesale distribution partners (department stores, multi-brand retailers). True if wholesale is part of the channel mix.' ;
    rdfs:domain ind:SeasonalLaunch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:socialEngagementEventId rdf:type rdf:Property ;
    rdfs:label 'Social Engagement Event Id' ;
    rdfs:comment 'Unique identifier for the social media engagement event record.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialPostId rdf:type rdf:Property ;
    rdfs:label 'Social Post Id' ;
    rdfs:comment 'Unique identifier of the brand-owned social media post that received the engagement.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SocialPost .

ind:clickDestinationUrl rdf:type rdf:Property ;
    rdfs:label 'Click Destination Url' ;
    rdfs:comment 'Destination URL clicked by the user, applicable for click and swipe-up engagement events.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentText rdf:type rdf:Property ;
    rdfs:label 'Comment Text' ;
    rdfs:comment 'Text content of user comment, captured for sentiment analysis and brand health monitoring. Stored only if user consent obtained.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTheme rdf:type rdf:Property ;
    rdfs:label 'Content Theme' ;
    rdfs:comment 'Thematic category or topic of the post content, such as product launch, lifestyle, sustainability, or influencer collaboration.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Format type of the social media content that received the engagement.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementLagHours rdf:type rdf:Property ;
    rdfs:label 'Engagement Lag Hours' ;
    rdfs:comment 'Number of hours elapsed between post publication and this engagement event, used to analyze engagement velocity.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementValueScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Value Score' ;
    rdfs:comment 'Weighted score representing the business value of this engagement type, used for calculating overall engagement quality.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when the social engagement event occurred on the platform, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market where the engagement originated.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags associated with the post, used for content performance analysis by topic.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Date and time when this engagement event record was ingested into the Adobe Experience Platform from the social media API.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isOrganic rdf:type rdf:Property ;
    rdfs:label 'Is Organic' ;
    rdfs:comment 'Flag indicating whether the engagement occurred on organic (non-paid) content versus paid promoted content.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Publish Timestamp' ;
    rdfs:comment 'Date and time when the original post was published to the social platform.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referrerSource rdf:type rdf:Property ;
    rdfs:label 'Referrer Source' ;
    rdfs:comment 'Source from which the user arrived at the social post, such as feed, explore, hashtag, or profile.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userPseudonym rdf:type rdf:Property ;
    rdfs:label 'User Pseudonym' ;
    rdfs:comment 'Anonymized user identifier compliant with GDPR and CCPA privacy requirements. Does not contain personally identifiable information.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionPercent rdf:type rdf:Property ;
    rdfs:label 'Video Completion Percent' ;
    rdfs:comment 'Percentage of video content watched by the user, applicable only for video engagement events.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoWatchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Video Watch Duration Seconds' ;
    rdfs:comment 'Duration in seconds that the user watched video content, applicable only for video engagement events.' ;
    rdfs:domain ind:SocialEngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHandle rdf:type rdf:Property ;
    rdfs:label 'Account Handle' ;
    rdfs:comment 'Brand social media account handle or username that published the post (e.g., @brandname). Supports multi-account brand architecture.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'Actual date and time when the post went live on the platform. Primary timestamp for engagement rate calculations and time-series analysis.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Boost Budget Amount' ;
    rdfs:comment 'Total paid media budget allocated to boost this post. Used for paid social ROI calculation and CAC (Customer Acquisition Cost) attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Boost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for boost budget amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boostedFlag rdf:type rdf:Property ;
    rdfs:label 'Boosted Flag' ;
    rdfs:comment 'Indicates whether the post received paid promotion or boosting. True if paid media budget was allocated to amplify organic reach.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandSafetyFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Flag' ;
    rdfs:comment 'Indicates whether the post passed brand safety review. False if content contains inappropriate comments or context that could harm brand reputation.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionText rdf:type rdf:Property ;
    rdfs:label 'Caption Text' ;
    rdfs:comment 'Full text caption or description accompanying the social media post. Includes copy, emojis, and call-to-action messaging.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of clicks on links within the post. Measures DTC (Direct-to-Consumer) traffic generation and conversion funnel entry.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory compliance review for posts containing claims, endorsements, or sponsored content. Ensures FTC (Federal Trade Commission) and advertising standards compliance.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatorName rdf:type rdf:Property ;
    rdfs:label 'Creator Name' ;
    rdfs:comment 'Name of the content creator, photographer, or agency responsible for producing the post content. Supports creator performance tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMetricsRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Metrics Refresh Timestamp' ;
    rdfs:comment 'Date and time when engagement metrics were last refreshed from platform APIs. Indicates data currency for reporting and analytics.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postExternalReference rdf:type rdf:Property ;
    rdfs:label 'Post External Reference' ;
    rdfs:comment 'Platform-native unique identifier for the post (e.g., Instagram post ID, TikTok video ID, YouTube video ID). Used for API reconciliation and platform-specific tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle status of the social media post. Tracks content from creation through publication to archival.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'Content format type of the social media post. Enables content format performance analysis. [ENUM-REF-CANDIDATE: photo|video|carousel|story|reel|short|live|poll|article — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTags rdf:type rdf:Property ;
    rdfs:label 'Product Tags' ;
    rdfs:comment 'Comma-separated list of product SKUs (Stock Keeping Units) or product identifiers tagged in the post. Enables product-level social attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'Planned date and time for post publication. Used for content calendar management and scheduling optimization.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utmParameters rdf:type rdf:Property ;
    rdfs:label 'Utm Parameters' ;
    rdfs:comment 'Urchin Tracking Module (UTM) parameters appended to link URL for campaign tracking (utm_source, utm_medium, utm_campaign). Enables granular traffic source attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate Percent' ;
    rdfs:comment 'Percentage of viewers who watched the video to completion. Key quality metric for video content effectiveness.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViewCount rdf:type rdf:Property ;
    rdfs:label 'Video View Count' ;
    rdfs:comment 'Total number of video views for video posts. Platform-specific view definitions apply (e.g., 3-second view threshold).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationDetailId rdf:type rdf:Property ;
    rdfs:label 'Allocation Detail Id' ;
    rdfs:comment 'Unique surrogate identifier for each allocation detail line record within the allocation plan. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Allocation Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Detailed allocation decisions at SKU-location level are made by specific analysts for manual overrides, exception handling, and store-specific adjustments. Essential for accountability, quality contro' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourcingPurchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Purchase Order Line Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_purchase_order_line. Business justification: Detail-level allocation tied to specific PO lines. Enables precise inventory flow tracking from factory to location, reconciliation of received vs. allocated quantities, and SKU-level supply chain vis' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPurchaseOrderLine .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'The actual date on which the destination location confirmed receipt of the allocated units. Used for OTIF compliance measurement and inventory availability updates.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the allocation was created and authorized in Oracle Retail Merchandising System. Used for OTB (Open-to-Buy) period alignment and merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible business identifier for the allocation detail line, used for cross-system reference between Oracle Retail Merchandising System, Manhattan Associates WMS, and SAP S/4HANA. Follows the format ALLOC-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedQty rdf:type rdf:Property ;
    rdfs:label 'Approved Qty' ;
    rdfs:comment 'The number of units formally approved for allocation after review and authorization. May differ from planned quantity due to inventory availability constraints or OTB budget adjustments.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asrNumber rdf:type rdf:Property ;
    rdfs:label 'Asr Number' ;
    rdfs:comment 'The Advance Shipment Receipt number generated by Manhattan Associates WMS when the allocation is released for fulfillment. Used by destination locations to pre-receive and reconcile inbound inventory against the allocation.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsQty rdf:type rdf:Property ;
    rdfs:label 'Ats Qty' ;
    rdfs:comment 'The Available to Sell (ATS) quantity for this SKU at the time the allocation was created, representing total on-hand and on-order inventory minus existing commitments. Determines the maximum allocatable quantity and is sourced from Oracle Retail Merchandising System inventory positions.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Merchandise class code within the department hierarchy for the allocated SKU (e.g., Tops, Bottoms, Outerwear). Supports class-level allocation analysis and assortment planning in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrePack rdf:type rdf:Property ;
    rdfs:label 'Is Pre Pack' ;
    rdfs:comment 'Indicates whether the allocated units are configured as pre-packs (assorted size/color combinations packed together) rather than individual units. Pre-pack allocations require different WMS handling and store receiving procedures in Manhattan Associates WMS.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReplenishment rdf:type rdf:Property ;
    rdfs:label 'Is Replenishment' ;
    rdfs:comment 'Indicates whether this allocation detail line is a replenishment allocation (true) triggered by store inventory depletion, as opposed to an initial buy allocation (false) for a new season or collection. Supports NOS (Never Out of Stock) and VMI (Vendor Managed Inventory) program tracking.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'The Manufacturer\'s Suggested Retail Price (MSRP) for the SKU at the time of allocation. Used for IMU (Initial Markup) calculation, markdown planning, and sell-through rate (STR) analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packConfigCode rdf:type rdf:Property ;
    rdfs:label 'Pack Config Code' ;
    rdfs:comment 'Code identifying the pre-pack or inner-pack configuration for this allocation line (e.g., size ratio pack, color assortment pack). Applicable when is_pre_pack is true. Drives carton-level fulfillment logic in Manhattan Associates WMS.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQty rdf:type rdf:Property ;
    rdfs:label 'Planned Qty' ;
    rdfs:comment 'The number of units originally planned for allocation to the destination location for this SKU within the allocation plan. Represents the merchandiser\'s intended distribution quantity before any adjustments.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The expected date on which the destination location (store or DC) is scheduled to receive the allocated units. Drives store receiving workflows and floor-set planning.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'The scheduled date on which allocated units are planned to ship from the distribution center or warehouse to the destination location. Used for OTIF (On Time In Full) tracking and T&A (Time and Action) calendar management.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qtyVariance rdf:type rdf:Property ;
    rdfs:label 'Qty Variance' ;
    rdfs:comment 'The difference between approved allocation quantity and actual shipped quantity (approved_qty minus shipped_qty). Negative values indicate under-shipment; positive values indicate over-shipment. Used for allocation accuracy KPI reporting.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedQty rdf:type rdf:Property ;
    rdfs:label 'Received Qty' ;
    rdfs:comment 'The actual number of units confirmed as received at the destination location. May differ from shipped quantity due to transit damage, short shipments, or receiving discrepancies.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippedQty rdf:type rdf:Property ;
    rdfs:label 'Shipped Qty' ;
    rdfs:comment 'The actual number of units physically shipped from the distribution center to the destination location. Captured from Manhattan Associates WMS shipment confirmation and used for OTIF and variance analysis.' ;
    rdfs:domain ind:AllocationDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subclassCode rdf:type rdf:Property ;
    rdfs:label 'Subclass Code' ;
    rdfs:comment 'Merchandise subclass code providing the most granular product classification level within the department-class hierarchy (e.g., T-Shirts, Denim Jeans, Running Shoes). Enables granular allocation and STR (Sell-Through Rate) analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Allocator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Allocation plans are created and owned by allocation analysts who determine store-level distribution strategy, size curve application, and replenishment rules. Required for approval workflows, audit t' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:buyPlanId rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.buy_plan. Business justification: Allocation plans distribute inventory that was committed via buy plans. The buy_plan commits to purchasing X units of a style from a vendor; the allocation_plan determines how to distribute those unit' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyPlan .

ind:classMerchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Class Merchandise Hierarchy Id' ;
    rdfs:comment 'Reference to the merchandise class within the Oracle Retail hierarchy (below department, above subclass), used to scope the allocation plan to a specific product grouping such as \'Outerwear\' or \'Athletic Footwear\'.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:destinationDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Destination Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Store allocations often route through regional DCs before final delivery. Destination DC link enables multi-echelon allocation planning, inter-DC transfer planning, and regional replenishment strategi' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:sizeCurveId rdf:type rdf:Property ;
    rdfs:label 'Size Curve Id' ;
    rdfs:comment 'Reference to the size curve profile that defines the percentage distribution of units across sizes (e.g., XS/S/M/L/XL) for this allocation plan. Derived from historical sell-through rate (STR) data by store cluster and product category.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SizeCurve .

ind:storeClusterId rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Id' ;
    rdfs:comment 'Reference to the store cluster grouping used to drive allocation distribution logic. Store clusters segment retail locations by performance tier, geography, climate, or customer demographics to enable targeted allocation strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreCluster .

ind:subclassMerchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Subclass Merchandise Hierarchy Id' ;
    rdfs:comment 'Reference to the merchandise subclass within the Oracle Retail hierarchy (most granular classification level), scoping the allocation plan to a specific product type such as \'Puffer Jackets\' or \'Running Shoes\'.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation strategy applied in this plan. \'Initial\' distributes new receipts to stores; \'replenishment\' refills depleted stock; \'push\' proactively sends inventory based on forecasts; \'transfer\' moves stock between locations; \'pre_pack\' allocates pre-assembled size sets.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableToSellUnits rdf:type rdf:Property ;
    rdfs:label 'Available To Sell Units' ;
    rdfs:comment 'The number of units confirmed as ATS (Available to Sell) at the time of allocation plan creation. Represents the inventory pool from which allocations are drawn, net of committed and reserved quantities.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inStoreDate rdf:type rdf:Property ;
    rdfs:label 'In Store Date' ;
    rdfs:comment 'The planned date on which allocated inventory is expected to arrive and be available on the retail floor or in the fulfillment center. Critical for floor set planning, marketing campaign alignment, and NOS (Never Out of Stock) compliance.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether any allocation quantities in this plan have been manually overridden by a planner, deviating from the system-calculated distribution. Supports audit trail requirements and exception reporting.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNosEligible rdf:type rdf:Property ;
    rdfs:label 'Is Nos Eligible' ;
    rdfs:comment 'Indicates whether the items in this allocation plan are designated as NOS (Never Out of Stock) items, requiring continuous replenishment allocation to maintain minimum stock levels across all qualifying locations.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSizeCurveOverride rdf:type rdf:Property ;
    rdfs:label 'Is Size Curve Override' ;
    rdfs:comment 'Indicates whether the default size curve profile has been manually overridden by the merchandise planner for this allocation plan. When True, the size_curve_id reflects a custom profile rather than the system-recommended curve.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxStoreUnits rdf:type rdf:Property ;
    rdfs:label 'Max Store Units' ;
    rdfs:comment 'The maximum number of units that can be allocated to any single store location in this plan. Prevents over-stocking and ensures equitable distribution across the store network.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStoreUnits rdf:type rdf:Property ;
    rdfs:label 'Min Store Units' ;
    rdfs:comment 'The minimum number of units that must be allocated to each qualifying store location in this plan. Ensures NOS (Never Out of Stock) compliance and prevents under-stocking of key locations.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The business date on which the allocation plan was created or initiated by the merchandise planner. Represents the principal real-world event time for this allocation planning transaction.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name for the allocation plan, typically referencing the season, collection, or merchandise category (e.g., \'Fall 2025 Outerwear Initial Push\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the allocation plan, used in cross-system references, buyer communications, and Oracle Retail Allocation module tracking. Follows the format ALLOC-YYYY-NNNNNN.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the allocation plan within the Oracle Retail Allocation workflow. Controls whether the plan is editable, executable, or archived. [ENUM-REF-CANDIDATE: draft|approved|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRule rdf:type rdf:Property ;
    rdfs:label 'Priority Rule' ;
    rdfs:comment 'The business rule governing how inventory is prioritized across locations when supply is constrained. Options include sales volume ranking, store grade, cluster rank, manual override, OTB (Open-to-Buy) balance, or WOS (Weeks of Supply) target. [ENUM-REF-CANDIDATE: sales_volume|store_grade|cluster_rank|manual|otb_balance|wos_target — promote to reference product]' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'The planned date on which inventory is scheduled to ship from the distribution center to allocated store or fulfillment locations. Drives warehouse pick/pack scheduling in Manhattan Associates WMS.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strTargetPct rdf:type rdf:Property ;
    rdfs:label 'Str Target Pct' ;
    rdfs:comment 'The target STR (Sell-Through Rate) percentage for this allocation plan, expressed as a decimal percentage (e.g., 85.00 = 85%). Used to evaluate allocation effectiveness and inform markdown (MD) timing decisions.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualUnits rdf:type rdf:Property ;
    rdfs:label 'Total Actual Units' ;
    rdfs:comment 'The total number of units actually allocated and confirmed for distribution across all locations. May differ from planned units due to inventory availability, ATS (Available to Sell) constraints, or manual overrides.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Planned Units' ;
    rdfs:comment 'The total number of units planned for distribution across all locations in this allocation plan. Represents the gross planned allocation quantity before any adjustments or overrides.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unallocatedUnits rdf:type rdf:Property ;
    rdfs:label 'Unallocated Units' ;
    rdfs:comment 'The number of units from the available inventory pool that remain unallocated after the plan is executed. Represents residual inventory requiring further allocation decisions or return to the warehouse.' ;
    rdfs:domain ind:AllocationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Assortment Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the assortment plan record in the Databricks Silver Layer. Primary key generated by the lakehouse ingestion pipeline from Oracle Retail Merchandising System assortment planning module.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentPlan .

ind:collectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Collection Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.collection_plan. Business justification: Assortment plans operationalize collection plans by defining the specific SKU-level assortments, store clusters, and channel strategies for a collection. The collection_plan defines the thematic visio' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionPlan .

ind:primaryAssortmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Employee Id' ;
    rdfs:comment 'Reference to the merchandise planner (employee) responsible for creating and managing this assortment plan. The planner owns OTB budget reconciliation, STR tracking, and markdown decisions. Sourced from Workday HCM employee master. Serves as the PARTY_REFERENCE for this entity.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAssortmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Assortment Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically a Director of Merchandising or VP of Planning) who approved the assortment plan and committed the OTB budget. Required for audit trail and financial governance under IFRS/GAAP internal controls.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Allocation Strategy' ;
    rdfs:comment 'Inventory allocation methodology applied to this assortment plan. top_down = corporate-driven allocation to stores; bottom_up = store-requested replenishment; hybrid = combination approach; vmi = Vendor Managed Inventory (VMI) where the supplier manages replenishment. Drives Oracle Retail allocation module configuration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aurTarget rdf:type rdf:Property ;
    rdfs:label 'Aur Target' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price for the assortment, representing the expected average selling price per unit across all styles and colorways in the plan. A key KPI in Anaplan merchandise financial planning used to project net sales and validate GMROI targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryForwardPct rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Pct' ;
    rdfs:comment 'Percentage of styles in this assortment plan that are carried forward from the prior season versus new introductions. A key collection planning metric used by merchants to balance newness investment against proven performers. Expressed as a percentage of total style count.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorwayCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Colorway Count Planned' ;
    rdfs:comment 'Number of distinct colorways planned across all styles in the assortment. Colorway depth is a key assortment decision in apparel fashion, balancing color story cohesion against inventory fragmentation risk.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imuTargetPct rdf:type rdf:Property ;
    rdfs:label 'Imu Target Pct' ;
    rdfs:comment 'Target Initial Markup (IMU) percentage for the assortment plan, expressed as a percentage of retail price. IMU = (Retail Price − Cost) / Retail Price × 100. Drives cost negotiation targets with suppliers and is a primary input to GMROI optimization in Anaplan merchandise financial planning.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinalVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Version' ;
    rdfs:comment 'Indicates whether this record represents the final approved version of the assortment plan (True) or a superseded draft/revision (False). Used to filter active plan versions in reporting and analytics without requiring version_number logic.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Required' ;
    rdfs:comment 'Indicates whether suppliers fulfilling this assortment plan must hold active FLA (Fair Labor Association) or WRAP (Worldwide Responsible Accredited Production) certification. Enforced during supplier onboarding in Infor PLM sourcing and SAP S/4HANA MM vendor master.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Amount' ;
    rdfs:comment 'Total markdown (MD) budget allocated to this assortment plan for planned price reductions during the selling season. Markdown budget is a key input to MMU calculation and is managed in Anaplan merchandise financial planning and Oracle Retail Price Management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmuTargetPct rdf:type rdf:Property ;
    rdfs:label 'Mmu Target Pct' ;
    rdfs:comment 'Target Maintained Markup (MMU) percentage after accounting for planned markdowns (MD), shrinkage, and employee discounts. MMU reflects the realized margin and is the primary profitability metric tracked in Anaplan merchandise financial planning alongside GMROI.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpMax rdf:type rdf:Property ;
    rdfs:label 'Msrp Max' ;
    rdfs:comment 'Highest Manufacturer\'s Suggested Retail Price (MSRP) point within the assortment plan\'s price architecture. Defines the ceiling price tier and is used alongside msrp_min to establish the price range strategy and IMU targets for the planned assortment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpMin rdf:type rdf:Property ;
    rdfs:label 'Msrp Min' ;
    rdfs:comment 'Lowest Manufacturer\'s Suggested Retail Price (MSRP) point within the assortment plan\'s price architecture. Defines the entry price tier for the planned assortment and is used in IMU (Initial Markup) and AUR (Average Unit Retail) calculations in Oracle Retail Price Management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbUnitsPlanned rdf:type rdf:Property ;
    rdfs:label 'Otb Units Planned' ;
    rdfs:comment 'Total number of units planned for procurement under this assortment plan\'s OTB budget. Used to calculate average unit cost, validate MOQ (Minimum Order Quantity) compliance with suppliers, and drive purchase order (PO) generation in SAP S/4HANA MM.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known business identifier for the assortment plan, assigned by the Oracle Retail Merchandising System. Used by merchants and planners to reference the plan across systems (e.g., ORM-AP-2025-FALL-WMN-001). Serves as the BUSINESS_IDENTIFIER for this entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Date on which the assortment plan expires or the season closes. Marks the end of the active selling window and triggers end-of-season markdown (MD) and clearance processes. Serves as the EFFECTIVE_UNTIL for this entity. Nullable for open-ended NOS assortments.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date on which the assortment plan becomes effective for in-season execution — i.e., the first floor-set or go-live date for the planned assortment. Used to align T&A (Time and Action) calendar milestones and pre-production (PP) sample review schedules. Serves as the EFFECTIVE_FROM for this MASTER_AGREEMENT-role entity.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the assortment plan by merchandise strategy. seasonal = time-bound seasonal collection; core = evergreen carry-forward styles; nos = Never Out of Stock (NOS) replenishment assortment; capsule = limited-edition capsule collection; collab = brand collaboration or licensed assortment. Drives OTB budget methodology and replenishment logic.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentEligible rdf:type rdf:Property ;
    rdfs:label 'Replenishment Eligible' ;
    rdfs:comment 'Indicates whether styles within this assortment plan are eligible for automated replenishment (True) or are one-time buys with no replenishment (False). NOS (Never Out of Stock) assortments are always True. Drives replenishment trigger logic in Oracle Retail allocation and Manhattan Associates WMS.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeRange rdf:type rdf:Property ;
    rdfs:label 'Size Range' ;
    rdfs:comment 'Planned size range for the assortment (e.g., \'XS-3XL\', \'00-24\', \'5-13\'). Defines the inclusive size offering for the plan and is used to validate size curve alignment with store cluster demographics and FTC textile labeling requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sourcing Country Code' ;
    rdfs:comment 'ISO 3166-1 Alpha-3 country code of the primary manufacturing/sourcing country for this assortment plan (e.g., BGD=Bangladesh, VNM=Vietnam, CHN=China). Used for landed duty paid (LDP) cost modeling, HS Code tariff classification, and GSP eligibility assessment in SAP S/4HANA MM and Infor PLM sourcing.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Style Count Planned' ;
    rdfs:comment 'Number of distinct styles (parent product silhouettes) planned in the assortment, independent of colorway or size. Style count is a key assortment breadth metric used by merchants to balance newness versus carry-forward depth in collection planning.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertified rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified' ;
    rdfs:comment 'Indicates whether the assortment plan requires sustainability certification compliance (True) such as GOTS (Global Organic Textile Standard), OEKO-TEX Standard 100, or BCI (Better Cotton Initiative). Drives supplier qualification requirements in Infor PLM sourcing and compliance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSkuCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count Planned' ;
    rdfs:comment 'Total number of distinct SKUs (Stock Keeping Units) planned within this assortment, representing the breadth of the assortment. Includes all style-color-size combinations. Used to assess assortment productivity and compare planned vs. actual SKU rationalization outcomes.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedVendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Quote Id' ;
    rdfs:comment 'Foreign key linking to sourcing.vendor_quote. Business justification: Buy plans are awarded based on accepted vendor quotes. Tracks which specific quote was selected for procurement, enabling cost reconciliation and vendor performance tracking. Essential for procurement' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuote .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Buy plans are owned by merchandise buyers who negotiate vendor terms, manage procurement strategy, and approve purchase commitments. Essential for accountability, approval workflows, and buyer perform' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_audit. Business justification: Factory audit scores gate new buy plan approvals and sourcing decisions. Audit results determine vendor eligibility for new orders. Essential for responsible sourcing, compliance risk management, and ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAudit .

ind:buyPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the buy plan, used in cross-system communication with Oracle Retail Merchandising System, Anaplan, and SAP S/4HANA MM. Follows the format BP-{YEAR}-{ALPHANUMERIC_CODE}.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Date' ;
    rdfs:comment 'Planned date on which finished goods are expected to leave the manufacturing facility (ex-factory). Key milestone in the T&A (Time and Action) calendar. Used to calculate transit lead times and planned receipt dates.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorSetDate rdf:type rdf:Property ;
    rdfs:label 'Floor Set Date' ;
    rdfs:comment 'Planned date for merchandise to be on the retail floor or live on the e-commerce site. Aligns with the seasonal collection launch calendar and marketing campaign timing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:imuPercent rdf:type rdf:Property ;
    rdfs:label 'Imu Percent' ;
    rdfs:comment 'Initial Markup percentage calculated as (MSRP - LDP Cost) / MSRP * 100. Represents the planned gross margin at the time of the buy decision. Key financial KPI in merchandise financial planning reviewed in Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inDcDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Date' ;
    rdfs:comment 'Planned date for merchandise to arrive at the distribution center. Drives inbound scheduling in Manhattan Associates WMS and store allocation timing. Critical for floor-set and launch date compliance.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Flag indicating whether the merchandise in this buy plan is an exclusive product (e.g., retailer-exclusive colorway, channel-exclusive style). Exclusives may have different MOQ, pricing, and allocation rules.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNos rdf:type rdf:Property ;
    rdfs:label 'Is Nos' ;
    rdfs:comment 'Flag indicating whether this buy plan is for a Never Out of Stock (NOS) / core replenishment item that is carried across multiple seasons, as opposed to a seasonal fashion buy. NOS items follow continuous replenishment planning rules.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedReceiptEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt End Date' ;
    rdfs:comment 'Latest planned date for all merchandise receipts under this buy plan to be completed. Defines the receipt window for seasonal floor-set readiness and OTB period closure.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReceiptStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Start Date' ;
    rdfs:comment 'Earliest planned date for merchandise receipts to arrive at the destination DC or store. Drives the receipt flow schedule and warehouse inbound planning in Manhattan Associates WMS.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStrPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Str Percent' ;
    rdfs:comment 'Planned Sell-Through Rate (STR) percentage for this buy plan, representing the expected proportion of units sold at full price by end of season. Used as a key input for OTB budget sizing and markdown risk assessment in Anaplan.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Planned Total Cost' ;
    rdfs:comment 'Total planned cost commitment for this buy plan, calculated as planned_units × ldp_cost. Represents the OTB budget consumption amount in the merchandise financial plan. Expressed in the plan currency.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Total Retail' ;
    rdfs:comment 'Total planned retail value of the buy plan, calculated as planned_units × MSRP. Used for OTB retail budget tracking and GMROI planning in Anaplan merchandise financial planning.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Units' ;
    rdfs:comment 'Total number of units planned for purchase in this buy plan across all sizes and colorways. Represents the gross buy quantity before MOQ adjustments. Used as the primary quantity driver for OTB consumption calculation.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Type' ;
    rdfs:comment 'Manufacturing sourcing model for this buy plan. CMT (Cut Make Trim) = vendor provides labor only; OEM (Original Equipment Manufacturer) = vendor manufactures to spec; ODM (Original Design Manufacturer) = vendor designs and manufactures; direct = owned factory.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each line-level record within a seasonal buy plan. Primary key for the buy_plan_line entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Individual buy plan lines are assigned to assistant buyers or planners for SKU-level execution, sample tracking, and delivery management. Critical for workload distribution, performance metrics, and o' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqLineId rdf:type rdf:Property ;
    rdfs:label 'Rfq Line Id' ;
    rdfs:comment 'Foreign key linking to sourcing.rfq_line. Business justification: Line-level traceability from RFQ response to buy plan execution. Critical for cost variance analysis, comparing target costs in RFQ to planned costs in buy plan. Supports vendor performance evaluation' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfqLine .

ind:vendorCostQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Cost Quote Id' ;
    rdfs:comment 'Foreign key linking to sourcing.vendor_cost_quote. Business justification: Line-level cost traceability from vendor quote to buy plan. Essential for margin analysis, IMU calculation validation, and cost reconciliation. Enables comparison of quoted costs to planned costs for ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorCostQuote .

ind:confirmedUnits rdf:type rdf:Property ;
    rdfs:label 'Confirmed Units' ;
    rdfs:comment 'The number of units formally confirmed with the supplier via Purchase Order (PO). May differ from planned or revised units due to Minimum Order Quantity (MOQ) constraints or supplier capacity limitations.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Indicates the cost basis for the unit cost on this line: CMT (Cut Make Trim), FOB (Free on Board), LDP (Landed Duty Paid), DDP (Delivered Duty Paid), or EXW (Ex Works). Determines what logistics and duty costs are included in the unit cost figure.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricContent rdf:type rdf:Property ;
    rdfs:label 'Fabric Content' ;
    rdfs:comment 'The fiber/material composition of the product on this buy plan line (e.g., 100% Cotton, 60% Polyester 40% Nylon). Required for FTC textile labeling compliance, OEKO-TEX certification tracking, and sustainability reporting under GOTS/BCI standards.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Pct' ;
    rdfs:comment 'The Initial Markup (IMU) percentage for this buy plan line, calculated as (MSRP - Unit Cost) / MSRP. Represents the planned gross margin at full retail price before any markdowns. Key metric in merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNeverOutOfStock rdf:type rdf:Property ;
    rdfs:label 'Is Never Out Of Stock' ;
    rdfs:comment 'Indicates whether this buy plan line is designated as a Never Out of Stock (NOS) item, meaning it is a core replenishment SKU that must be continuously available. NOS items receive priority in allocation and replenishment planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'The current workflow status of this buy plan line, tracking its lifecycle from initial planning through receipt. [ENUM-REF-CANDIDATE: draft|submitted|approved|po_issued|in_production|shipped|received|cancelled — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownAllowancePct rdf:type rdf:Property ;
    rdfs:label 'Markdown Allowance Pct' ;
    rdfs:comment 'The planned markdown (MD) allowance percentage for this buy plan line, representing the anticipated price reduction from MSRP to clear end-of-season inventory. Used in Maintained Markup (MMU) calculations and merchandise financial planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCancelDate rdf:type rdf:Property ;
    rdfs:label 'Original Cancel Date' ;
    rdfs:comment 'The original date by which the purchase order for this buy plan line must be cancelled if the supplier cannot fulfill. Established at the time of initial buy plan creation as part of the Time and Action (T&A) calendar.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSellThroughPct rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Pct' ;
    rdfs:comment 'The planned Sell-Through Rate (STR) percentage for this buy plan line, representing the expected proportion of units sold at full price or within the season. Used as a benchmark for post-season performance analysis and future buy plan calibration.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preProductionSampleStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Production Sample Status' ;
    rdfs:comment 'The approval status of the Pre-Production (PP) sample for this buy plan line. PP sample approval is a prerequisite for production release in the T&A calendar. Tracked in the PLM system.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Purchase Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the unit cost is denominated (e.g., USD, EUR, CNY). Required for multi-currency buy plan consolidation and financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedCancelDate rdf:type rdf:Property ;
    rdfs:label 'Revised Cancel Date' ;
    rdfs:comment 'The most recently revised cancel date for this buy plan line, updated during the T&A (Time and Action) calendar review process. Tracks changes to delivery commitments and supplier negotiation outcomes.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedUnits rdf:type rdf:Property ;
    rdfs:label 'Revised Units' ;
    rdfs:comment 'The most recently revised unit quantity for this buy plan line, reflecting any adjustments made after the initial plan was set. Enables tracking of buy plan changes against original commitments and OTB impact analysis.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeRunType rdf:type rdf:Property ;
    rdfs:label 'Size Run Type' ;
    rdfs:comment 'Indicates whether this buy plan line represents a full size run, partial size run, core size run (best-selling sizes only), or extended size run (including plus/petite). Drives assortment breadth decisions and size curve planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleNumber rdf:type rdf:Property ;
    rdfs:label 'Style Number' ;
    rdfs:comment 'The alphanumeric style identifier assigned during product design and development in the PLM system. Represents the base product design before colorway and size differentiation. Used for cross-SKU reporting and collection planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionId rdf:type rdf:Property ;
    rdfs:label 'Division Id' ;
    rdfs:comment 'Reference to the merchandise division (e.g., Womens, Mens, Kids, Accessories) to which this collection plan belongs. Aligns with Oracle Retail Merchandising System merchandise hierarchy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:primaryCollectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Collection Employee Id' ;
    rdfs:comment 'Reference to the creative director or lead designer responsible for the thematic direction of this collection plan. Links to workforce records in Workday HCM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:channelAllocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Allocation Strategy' ;
    rdfs:comment 'Planned channel distribution strategy for this collection. DTC (Direct-to-Consumer) First = prioritize own retail and e-commerce; Wholesale First = prioritize wholesale partners; Balanced = equal distribution. Drives allocation decisions in Oracle Retail and Salesforce Commerce Cloud.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTheme rdf:type rdf:Property ;
    rdfs:label 'Collection Theme' ;
    rdfs:comment 'Descriptive thematic concept or creative narrative for the collection (e.g., \'Urban Nomad\', \'Coastal Luxe\', \'Performance Elevated\'). Guides design direction, marketing storytelling, and visual merchandising.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection by commercial strategy. Mainline = full seasonal assortment; Capsule = focused limited assortment; Collaboration = co-branded with external partner; Limited_Edition = restricted volume; Carry_Over = NOS (Never Out of Stock) continuity styles; Core = foundational basics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBriefUrl rdf:type rdf:Property ;
    rdfs:label 'Design Brief Url' ;
    rdfs:comment 'URL or document path to the creative design brief for this collection plan stored in Centric PLM or a connected document management system. Provides access to mood boards, color palettes, and thematic direction.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Dtc Allocation Pct' ;
    rdfs:comment 'Planned percentage of total collection inventory allocated to Direct-to-Consumer (DTC) channels (own retail stores and e-commerce). Expressed as a decimal (e.g., 0.6000 = 60%). Used in channel allocation planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'First Delivery Date' ;
    rdfs:comment 'Planned date of the first merchandise delivery to distribution centers or stores for this collection. Anchors the T&A (Time and Action) calendar and drives pre-production planning milestones.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Planned date of the final merchandise delivery for this collection. Defines the end of the inbound supply window and informs markdown timing and end-of-season clearance planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineArchitectureVersion rdf:type rdf:Property ;
    rdfs:label 'Line Architecture Version' ;
    rdfs:comment 'Version identifier for the line architecture document associated with this collection plan (e.g., v1.0, v2.3). Tracks iterative changes to style count, category mix, and price tier targets during the planning process in Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbLockDate rdf:type rdf:Property ;
    rdfs:label 'Otb Lock Date' ;
    rdfs:comment 'Date on which the OTB (Open-to-Buy) budget for this collection plan is locked and committed. After this date, budget changes require formal approval. Managed in Anaplan Merchandise Planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAurAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Aur Amount' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price for the collection in the planning currency. Represents the expected average selling price per unit across all styles and channels, used in revenue and unit planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCogsAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cogs Amount' ;
    rdfs:comment 'Total planned Cost of Goods Sold (COGS) for this collection plan in the planning currency. Used to calculate planned gross margin and GMROI targets in Anaplan financial planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Planned Gross Margin Pct' ;
    rdfs:comment 'Planned gross margin percentage for the collection, expressed as a decimal (e.g., 0.6200 = 62.00%). Derived from planned revenue and COGS targets; stored as a planning input in Anaplan to support IMU (Initial Markup) and MMU (Maintained Markup) targets.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue Amount' ;
    rdfs:comment 'Total planned net sales revenue target for this collection plan in the planning currency. Used as the top-line financial KPI for merchandise financial planning and GMROI optimization in Anaplan.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStrPct rdf:type rdf:Property ;
    rdfs:label 'Planned Str Pct' ;
    rdfs:comment 'Target Sell-Through Rate (STR) for the collection, expressed as a decimal (e.g., 0.8500 = 85%). Represents the planned percentage of received inventory expected to sell at full price or planned markdown cadence before end of season.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceTierDistribution rdf:type rdf:Property ;
    rdfs:label 'Price Tier Distribution' ;
    rdfs:comment 'Planned percentage distribution of styles across price tiers (e.g., \'Entry:20%|Mid:50%|Premium:30%\'). Guides assortment architecture to balance accessibility and margin. Stored as a structured string; detailed tier breakdowns managed in Anaplan.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryMix rdf:type rdf:Property ;
    rdfs:label 'Product Category Mix' ;
    rdfs:comment 'Planned distribution of styles across product categories within the collection (e.g., \'Tops:35%|Bottoms:25%|Outerwear:20%|Footwear:15%|Accessories:5%\'). Stored as a structured string; detailed breakdowns managed in Anaplan and Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Range Review Date' ;
    rdfs:comment 'Scheduled date for the formal range review meeting where the collection plan is presented to commercial and creative stakeholders for approval. A key milestone in the T&A (Time and Action) calendar.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the retail season type for this collection plan. Drives line architecture, delivery cadence, and OTB budget allocation. [ENUM-REF-CANDIDATE: Spring/Summer|Fall/Winter|Resort|Pre-Fall|Holiday|Cruise — promote to reference product if additional seasons are added]' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellEndDate rdf:type rdf:Property ;
    rdfs:label 'Sell End Date' ;
    rdfs:comment 'Planned date when the collection is retired from active selling. Triggers end-of-season markdown strategy and clearance allocation. Effective-until date for the collection\'s commercial lifecycle.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sellStartDate rdf:type rdf:Property ;
    rdfs:label 'Sell Start Date' ;
    rdfs:comment 'Planned date when the collection becomes available for sale to consumers across channels. Aligns with marketing campaign launch and store floor set dates. Effective-from date for the collection\'s commercial lifecycle.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainableMaterialPct rdf:type rdf:Property ;
    rdfs:label 'Sustainable Material Pct' ;
    rdfs:comment 'Planned percentage of styles in the collection using certified sustainable materials (organic cotton, recycled polyester, BCI cotton, etc.). Expressed as a decimal (e.g., 0.4000 = 40%). Supports ESG reporting and FTC textile labeling compliance.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarketRegion rdf:type rdf:Property ;
    rdfs:label 'Target Market Region' ;
    rdfs:comment 'Primary geographic market region(s) for which this collection is planned (e.g., \'NAM\', \'EMEA\', \'APAC\', \'GLOBAL\'). Influences sizing standards, labeling requirements, and channel allocation strategy. [ENUM-REF-CANDIDATE: NAM|EMEA|APAC|LATAM|GLOBAL|DOMESTIC — promote to reference product]' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStyleCount rdf:type rdf:Property ;
    rdfs:label 'Target Style Count' ;
    rdfs:comment 'Planned number of distinct styles (SKU families) to be included in this collection. A key line architecture metric used to manage assortment breadth and design resource allocation in Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Wholesale Allocation Pct' ;
    rdfs:comment 'Planned percentage of total collection inventory allocated to wholesale and distribution partners. Expressed as a decimal (e.g., 0.4000 = 40%). Complements DTC allocation to sum to 100% of planned inventory.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandiseFinancialPlanId rdf:type rdf:Property ;
    rdfs:label 'Merchandise Financial Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the merchandise financial plan record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseFinancialPlan .

ind:financialPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Financial Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Merchandise financial plans are owned by financial planning analysts who forecast sales, margin, and inventory targets. Critical for approval workflows, forecast accuracy tracking, and planner perform' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:channelInventoryAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Channel Inventory Allocation Pct' ;
    rdfs:comment 'Percentage of total planned inventory allocated to this specific distribution channel (DTC retail, DTC e-commerce, wholesale, outlet). Drives channel-level receipt planning and allocation strategies in Oracle Retail.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The distribution channel for which this financial plan is scoped: DTC (Direct-to-Consumer) retail stores, DTC e-commerce, wholesale partnerships, or outlet stores. Drives channel-specific pricing strategy and inventory allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the merchandise financial plan (e.g., v1.0, v2.3). Supports iterative planning cycles where plans are revised across pre-season, in-season, and post-season phases.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAur rdf:type rdf:Property ;
    rdfs:label 'Planned Aur' ;
    rdfs:comment 'Planned AUR (Average Unit Retail) representing the expected average selling price per unit across the department/class/channel combination. Drives unit sales plan derivation from the net sales dollar plan.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBopInventoryAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Bop Inventory Amt' ;
    rdfs:comment 'Planned inventory value at retail at the beginning of the planning period. Used as the opening stock position for OTB calculations and inventory flow modeling.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCogsAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Cogs Amt' ;
    rdfs:comment 'Planned COGS (Cost of Goods Sold) for the season, representing the total cost of merchandise expected to be sold. Used to derive planned gross margin and GMROI targets.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEopInventoryAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Eop Inventory Amt' ;
    rdfs:comment 'Planned inventory value at retail at the end of the planning period (EOM). Represents the target closing stock position and feeds into the next season\'s BOP. Critical for OTB and WOS (Weeks of Supply) planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGmroi rdf:type rdf:Property ;
    rdfs:label 'Planned Gmroi' ;
    rdfs:comment 'Planned GMROI (Gross Margin Return on Investment) representing the gross margin dollars generated per dollar of average inventory investment. Core KPI for evaluating merchandise productivity and capital efficiency.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrossMarginAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Gross Margin Amt' ;
    rdfs:comment 'Planned gross margin in absolute dollar terms (planned net sales minus planned COGS). Represents the financial contribution of the merchandise category before operating expenses.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedImuPct rdf:type rdf:Property ;
    rdfs:label 'Planned Imu Pct' ;
    rdfs:comment 'Planned IMU (Initial Markup) percentage representing the difference between the cost of merchandise and its original retail price, expressed as a percentage of retail. Establishes the pricing floor before markdowns.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedInventoryTurns rdf:type rdf:Property ;
    rdfs:label 'Planned Inventory Turns' ;
    rdfs:comment 'Planned number of times inventory is expected to sell through and be replenished during the season (COGS / average inventory at cost). Drives OTB budget and receipt flow planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Amt' ;
    rdfs:comment 'Total planned markdown (MD) dollars for the season representing the anticipated reduction from original retail price to drive sell-through. Directly impacts MMU and gross margin performance.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownPct rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Pct' ;
    rdfs:comment 'Planned markdown as a percentage of planned net sales. Used to benchmark markdown aggressiveness across departments and channels and to set MMU expectations.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMmuPct rdf:type rdf:Property ;
    rdfs:label 'Planned Mmu Pct' ;
    rdfs:comment 'Planned MMU (Maintained Markup) percentage representing the actual markup achieved after markdowns and promotions, expressed as a percentage of net sales. Reflects the realized pricing performance versus IMU.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMsrpAvg rdf:type rdf:Property ;
    rdfs:label 'Planned Msrp Avg' ;
    rdfs:comment 'Planned average MSRP (Manufacturer\'s Suggested Retail Price) across the SKUs in this department/class/channel plan. Establishes the retail price anchor for IMU calculation and consumer-facing pricing.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedNetSalesAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Net Sales Amt' ;
    rdfs:comment 'Total planned net sales revenue (gross sales minus returns and allowances) for the season, department, class, and channel combination. Core financial target in the merchandise financial plan. Expressed in the plan\'s currency.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOtbAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Otb Amt' ;
    rdfs:comment 'Planned OTB (Open-to-Buy) budget in dollars representing the amount of merchandise the buyer is authorized to purchase for the season. Calculated as planned EOP inventory + planned sales + planned markdowns - planned BOP inventory.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Amt' ;
    rdfs:comment 'Total planned merchandise receipts (inbound inventory) at retail value for the season. Represents the planned flow of new inventory into the channel to support the sales plan.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Planned Units Sold' ;
    rdfs:comment 'Total planned number of units expected to be sold during the season for the department/class/channel combination. Derived from planned net sales divided by planned AUR. Feeds into allocation and replenishment planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWos rdf:type rdf:Property ;
    rdfs:label 'Planned Wos' ;
    rdfs:comment 'Planned WOS (Weeks of Supply) representing the number of weeks the current inventory position is expected to last at the planned rate of sale. Used to identify over/under-stock risk and trigger replenishment actions.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Indicates the planning phase this plan represents: pre-season (initial buy plan before season starts), in-season (revised plan during active selling), or post-season (actuals reconciliation and hindsight).' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Planned pricing strategy for this channel and merchandise category: full_price (MSRP-driven), promotional (planned promotional events), value (everyday low price positioning), or outlet (clearance/off-price). Informs IMU and MMU targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentHierarchyMerchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Merchandise Hierarchy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent node in the merchandise hierarchy. A Division node has a null parent; a Department references its Division; a Class references its Department; a Subclass references its Class. Enables hierarchical roll-up for OTB, GMROI, and financial planning.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Descriptive name of the Class (e.g., \'Jackets\', \'Pants\', \'T-Shirts\', \'Sneakers\'). Null for Division and Department-level records. Displayed in Oracle Retail assortment planning, allocation, and price management modules.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscRegulated rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated' ;
    rdfs:comment 'Indicates whether products in this merchandise hierarchy node are subject to Consumer Product Safety Commission (CPSC) safety standards (e.g., childrens apparel flammability, drawstring regulations). Triggers mandatory safety testing and compliance documentation requirements in Infor PLM and quality management workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Descriptive name of the Department (e.g., \'Activewear\', \'Outerwear\', \'Denim\', \'Footwear\'). Null for Division-level records. Denormalized for flat reporting in assortment planning, OTB dashboards, and Anaplan merchandise financial plans.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Alphanumeric code identifying the top-level Division to which this hierarchy node belongs (e.g., \'MNS\' for Mens, \'WMN\' for Womens, \'KDS\' for Kids). Populated at all levels for denormalized reporting and OTB budget allocation in Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Descriptive name of the top-level Division (e.g., \'Mens\', \'Womens\', \'Kids\', \'Accessories\'). Denormalized at all hierarchy levels to support flat reporting in Oracle Retail, Anaplan, and BI dashboards without requiring joins.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Erp Category Code' ;
    rdfs:comment 'Corresponding material group or product category code in SAP S/4HANA (MM module) that maps to this merchandise hierarchy node. Ensures alignment between Oracle Retail merchandise taxonomy and SAP procurement, inventory valuation, and COGS reporting.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of this node in the hierarchy tree: 1=Division, 2=Department, 3=Class, 4=Subclass. Supports hierarchical traversal, roll-up aggregation, and level-specific filtering in OTB and GMROI reporting.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable name of the merchandise hierarchy node (e.g., \'Mens Activewear\', \'Outerwear\', \'Footwear\'). Displayed in assortment planning, OTB reporting, and financial planning dashboards in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of this merchandise hierarchy node. Active nodes are available for assortment planning, OTB budgeting, and SKU assignment. Inactive or archived nodes are retained for historical reporting but excluded from new planning cycles in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Hs Code Prefix' ;
    rdfs:comment 'The Harmonized System (HS) Code prefix (4-6 digit chapter/heading) associated with this merchandise hierarchy node, used for customs classification, import duty calculation, and trade compliance reporting. Supports LDP cost calculation and GSP eligibility assessment in SAP S/4HANA and supply chain operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this merchandise hierarchy node is designated for private label (own-brand) products as opposed to national or licensed brands. Affects sourcing strategy (CMT, OEM, ODM), IMU targets, and margin planning in Infor PLM and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Standard' ;
    rdfs:comment 'Labor compliance certification standard required for suppliers producing goods in this merchandise hierarchy node (e.g., FLA, WRAP, SA8000, SEDEX). Governs supplier qualification, factory audit requirements, and sourcing decisions in SAP S/4HANA MM and Infor PLM sourcing modules.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifestyleCategory rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Category' ;
    rdfs:comment 'Lifestyle or end-use category classification for this hierarchy node, distinguishing athletic performance, lifestyle, luxury, workwear, casual, and outdoor segments. Supports brand positioning, collection planning, and targeted marketing strategies in Adobe Experience Platform and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Strategy' ;
    rdfs:comment 'Markdown (MD) strategy designation for this merchandise hierarchy node, indicating the planned approach to price reductions during the selling season. Governs Oracle Retail Price Management markdown rules, Anaplan financial planning assumptions, and MMU maintenance targets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseHierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Merchandise Hierarchy Description' ;
    rdfs:comment 'Free-text business description of this merchandise hierarchy node, providing additional context about the product category, its scope, and any special planning or sourcing considerations. Maintained in Oracle Retail Merchandising System and used in buyer-facing assortment planning documentation.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseType rdf:type rdf:Property ;
    rdfs:label 'Merchandise Type' ;
    rdfs:comment 'Broad merchandise type classification indicating the nature of products within this hierarchy node. Drives category-specific planning rules, margin targets, and allocation strategies in Oracle Retail and Anaplan merchandise financial planning.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbBudgetMethod rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Method' ;
    rdfs:comment 'Indicates the Open-to-Buy (OTB) budget planning methodology applied to this merchandise hierarchy node: top-down (executive-driven), bottom-up (buyer-driven), or hybrid. Determines how Anaplan merchandise financial plans are structured and reconciled with Oracle Retail OTB budgets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Plm Category Code' ;
    rdfs:comment 'Corresponding category code in the Infor PLM or Centric PLM system that maps to this merchandise hierarchy node. Enables cross-system alignment between the Oracle Retail merchandise taxonomy and the PLM product design and BOM management classification for collection planning and tech pack organization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonApplicability rdf:type rdf:Property ;
    rdfs:label 'Season Applicability' ;
    rdfs:comment 'Seasonal classification indicating which selling seasons this hierarchy node is active for. Drives seasonal buy plan creation, OTB budget phasing, and collection planning cycles in Oracle Retail Merchandising System and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric ordering sequence for displaying this hierarchy node among its siblings within the same parent. Controls the display order in Oracle Retail Merchandising System screens, assortment planning tools, and reporting dashboards.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subclassName rdf:type rdf:Property ;
    rdfs:label 'Subclass Name' ;
    rdfs:comment 'Descriptive name of the Subclass (e.g., \'Puffer Jackets\', \'Windbreakers\', \'Slim Fit Jeans\'). Null for Division, Department, and Class-level records. Used in Oracle Retail for the most granular assortment planning, allocation, and markdown optimization.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGmroi rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi' ;
    rdfs:comment 'Target Gross Margin Return on Investment (GMROI) for this merchandise hierarchy node, calculated as gross margin dollars divided by average inventory cost. A primary KPI for merchandise financial planning and OTB budget justification in Anaplan and Oracle Retail.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImuPct rdf:type rdf:Property ;
    rdfs:label 'Target Imu Pct' ;
    rdfs:comment 'Target Initial Markup (IMU) percentage for products within this merchandise hierarchy node, representing the planned markup from cost to MSRP at the time of first receipt. A key financial planning metric in Anaplan OTB and Oracle Retail Price Management for setting pricing strategy and GMROI targets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStrPct rdf:type rdf:Property ;
    rdfs:label 'Target Str Pct' ;
    rdfs:comment 'Target Sell-Through Rate (STR) percentage for this merchandise hierarchy node, representing the planned proportion of received inventory sold within a season. Used in Oracle Retail and Anaplan to evaluate assortment performance, trigger markdown decisions, and set OTB buy quantities.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReceiptsCost rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts Cost' ;
    rdfs:comment 'The actual merchandise receipt value at cost consumed by confirmed purchase orders (POs) for the OTB budget month to date. Used for open-to-buy cost-basis tracking and cash flow management. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts Retail' ;
    rdfs:comment 'The actual merchandise receipt value at retail price consumed by confirmed buy plans and purchase orders (POs) for the OTB budget month to date. Compared against planned receipts to compute remaining OTB. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Percent' ;
    rdfs:comment 'The variance threshold percentage (e.g., 0.10 = 10%) at which a merchant alert is triggered for this OTB budget record. When actual receipts or sales deviate from plan by more than this threshold, an alert is raised for merchant review and OTB recalculation.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertTriggered rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered' ;
    rdfs:comment 'Indicates whether a merchant alert has been triggered for this OTB budget record due to variance exceeding the defined alert threshold. True = alert active and pending merchant review; False = within acceptable variance range.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:anaplanModelCode rdf:type rdf:Property ;
    rdfs:label 'Anaplan Model Code' ;
    rdfs:comment 'The unique identifier of the Anaplan model and workspace from which this OTB budget record was sourced. Enables traceability back to the originating Anaplan planning model for reconciliation and audit.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomInventoryCost rdf:type rdf:Property ;
    rdfs:label 'Bom Inventory Cost' ;
    rdfs:comment 'The value of on-hand inventory at cost (landed duty paid) at the beginning of the OTB budget month. Used for COGS tracking and gross margin analysis. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomInventoryRetail rdf:type rdf:Property ;
    rdfs:label 'Bom Inventory Retail' ;
    rdfs:comment 'The value of on-hand inventory at retail (selling) price at the beginning of the OTB budget month. Used as the opening inventory position in the OTB formula: OTB = Planned EOM Inventory + Planned Sales + Planned Markdowns - BOM Inventory. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetMonth rdf:type rdf:Property ;
    rdfs:label 'Budget Month' ;
    rdfs:comment 'The calendar month (1–12) to which this OTB budget record applies. OTB is recalculated monthly; this field identifies the specific planning month within the budget year.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of the OTB budget record, incremented each time the budget is revised or re-submitted. Supports version control and audit trail for merchandise financial planning changes in Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'The fiscal or calendar year (e.g., 2025) to which this OTB budget record applies. Used for annual merchandise financial planning and year-over-year variance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eomInventoryTargetRetail rdf:type rdf:Property ;
    rdfs:label 'Eom Inventory Target Retail' ;
    rdfs:comment 'The planned ending inventory value at retail price at the end of the OTB budget month. This is the target stock position that feeds into the next month\'s BOM inventory and is a key driver of the OTB formula. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Recalculation Timestamp' ;
    rdfs:comment 'The exact date and time when the OTB budget values were last recalculated in Anaplan. Supports audit trail and ensures merchants are working with the most current OTB position.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otbCost rdf:type rdf:Property ;
    rdfs:label 'Otb Cost' ;
    rdfs:comment 'The remaining open-to-buy dollars at cost available for the OTB budget month. Derived from OTB at retail adjusted by the Initial Markup (IMU) percentage. Used for purchase order (PO) commitment and cash flow management. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbRetail rdf:type rdf:Property ;
    rdfs:label 'Otb Retail' ;
    rdfs:comment 'The remaining open-to-buy dollars at retail price available for the OTB budget month. Calculated as: Planned EOM Inventory + Planned Sales + Planned Markdowns - BOM Inventory - Actual Receipts at Retail. A positive value indicates buying capacity; negative indicates over-bought. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Retail' ;
    rdfs:comment 'The planned markdown (MD) dollar amount at retail for the OTB budget month. Markdowns reduce the retail inventory value and are a key input to the OTB formula and Maintained Markup (MMU) calculation. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsCost rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Cost' ;
    rdfs:comment 'The total planned merchandise receipt value at cost (landed duty paid / LDP) for the OTB budget month. Used for cash flow planning, purchase order (PO) commitment tracking, and COGS forecasting. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Retail' ;
    rdfs:comment 'The total planned merchandise receipt value at retail price for the OTB budget month. Represents the maximum retail value of goods the merchant plans to receive. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Retail' ;
    rdfs:comment 'The planned net sales revenue at retail price for the OTB budget month, as defined in the merchandise financial plan. Drives the OTB calculation and sell-through rate (STR) targets. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Units' ;
    rdfs:comment 'The planned number of units to be sold during the OTB budget month. Used alongside planned sales at retail to derive the Average Unit Retail (AUR) and validate unit-level buy quantities.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Rate' ;
    rdfs:comment 'The planned Sell-Through Rate (STR) for the OTB budget month, expressed as a decimal (e.g., 0.75 = 75%). STR = Units Sold / (Beginning Inventory Units + Received Units). Used to validate receipt plans and assess inventory productivity.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Planned Weeks Of Supply' ;
    rdfs:comment 'The planned Weeks of Supply (WOS) at the end of the OTB budget month. WOS = EOM Inventory Units / Average Weekly Sales Units. Used to assess inventory coverage and prevent stockouts or overstock situations.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Recalculation Trigger Date' ;
    rdfs:comment 'The date on which the weekly OTB recalculation was last triggered for this budget record. OTB is recalculated weekly in Anaplan based on updated actual receipts, sales actuals, and revised forecasts.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Variance Receipts Retail' ;
    rdfs:comment 'The variance between planned receipts at retail and actual receipts at retail for the OTB budget month. Positive = under-received vs plan; Negative = over-received vs plan. Triggers merchant alerts when variance exceeds the defined threshold. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceSalesRetail rdf:type rdf:Property ;
    rdfs:label 'Variance Sales Retail' ;
    rdfs:comment 'The variance between planned sales at retail and actual sales at retail for the OTB budget month. Used to assess sales performance against plan and trigger OTB recalculation when variance exceeds the alert threshold. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeEventId rdf:type rdf:Property ;
    rdfs:label 'Price Change Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each price change event record in the merchandising system. Primary key for the price_change_event data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChangeEvent .

ind:markdownBudgetId rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Id' ;
    rdfs:comment 'Reference to the Open-to-Buy (OTB) markdown budget allocation against which this price change event is charged. Links the price change to the merchandise financial plan managed in Anaplan.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Price changes (especially markdowns) are often timed to marketing campaigns. This link tracks which campaign drove the pricing decision, enabling analysis of campaign-driven markdown effectiveness and' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:priceMasterId rdf:type rdf:Property ;
    rdfs:label 'Price Master Id' ;
    rdfs:comment 'Foreign key linking to merchandising.price_master. Business justification: Price change events modify prices; price_master is the authoritative source for pricing data. Adding price_master_id FK links transactional price changes to master pricing records and removes redundan' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceMaster .

ind:vendorAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Allowance Id' ;
    rdfs:comment 'Foreign key linking to merchandising.vendor_allowance. Business justification: Price change events (markdowns) may be funded by vendor allowances (markdown money). Adding vendor_allowance_id FK links markdown execution to vendor funding source. FK will reference merchandising.ve' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAllowance .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized reason code from Oracle Retail Merchandising System explaining the business rationale for the price change (e.g., SEASONAL_MD, COMPETITIVE_RESPONSE, CLEARANCE, PROMO, CORRECTION). Supports markdown (MD) analysis and GMROI reporting. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text narrative description providing additional context for the price change event beyond the standardized reason code. Entered by the merchandising planner or buyer.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClearance rdf:type rdf:Property ;
    rdfs:label 'Is Clearance' ;
    rdfs:comment 'Indicates whether this price change event designates the SKU or style as a clearance item. Once flagged as clearance, the item is typically excluded from future regular-price replenishment and tracked separately for end-of-season liquidation reporting.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompetitiveResponse rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Response' ;
    rdfs:comment 'Indicates whether this price change event was triggered by a competitive pricing response to a market competitor\'s price action. Supports competitive pricing analytics and brand positioning strategy.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPosApplied rdf:type rdf:Property ;
    rdfs:label 'Is Pos Applied' ;
    rdfs:comment 'Indicates whether this price change event has been successfully transmitted and applied at the Point of Sale (POS) system via SAP Customer Activity Repository. Supports reconciliation between merchandising system and store operations.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Sequence Number' ;
    rdfs:comment 'Sequential number indicating the ordinal position of this markdown (MD) event within the seasonal markdown cadence for the affected SKU or style (e.g., 1st markdown, 2nd markdown, 3rd markdown). Supports sell-through rate (STR) analysis and markdown optimization.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mmuPercent rdf:type rdf:Property ;
    rdfs:label 'Mmu Percent' ;
    rdfs:comment 'The Maintained Markup (MMU) percentage for the affected SKU or style after applying this price change event. Reflects the actual margin achieved post-markdown or post-markup. Key metric for GMROI optimization.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newRetailPrice rdf:type rdf:Property ;
    rdfs:label 'New Retail Price' ;
    rdfs:comment 'The updated retail selling price applied to the SKU or style as a result of this price change event. Represents the Average Unit Retail (AUR) post-change and is used in sell-through rate (STR) and GMROI analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Original Retail Price' ;
    rdfs:comment 'The retail selling price of the SKU or style immediately prior to this price change event. Serves as the baseline for calculating markdown (MD) depth, sell-through rate (STR) impact, and maintained markup (MMU).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'The absolute monetary value of the price change (new_retail_price minus original_retail_price). A negative value indicates a markdown (MD); a positive value indicates a markup (MU). Used in merchandise financial planning and OTB impact analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeLevel rdf:type rdf:Property ;
    rdfs:label 'Price Change Level' ;
    rdfs:comment 'Indicates the merchandise hierarchy level at which this price change event was initiated. A style-level change cascades to all associated SKUs; a SKU-level change applies only to the specific variant.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Price Change Number' ;
    rdfs:comment 'Externally-known business identifier for the price change event as assigned by Oracle Retail Merchandising System or SAP S/4HANA SD module. Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePercent rdf:type rdf:Property ;
    rdfs:label 'Price Change Percent' ;
    rdfs:comment 'The percentage change in retail price relative to the original retail price. Calculated as (price_change_amount / original_retail_price) * 100. Used for markdown (MD) depth reporting and sell-through rate (STR) analysis in Anaplan.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Zone Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based pricing zone to which this price change event applies. Pricing zones group locations with identical pricing strategies in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strAtChange rdf:type rdf:Property ;
    rdfs:label 'Str At Change' ;
    rdfs:comment 'The Sell-Through Rate (STR) for the affected SKU or style at the time of this price change event, expressed as a decimal (e.g., 0.65 = 65%). Provides context for the markdown decision and is used in post-event STR lift analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOnHand rdf:type rdf:Property ;
    rdfs:label 'Units On Hand' ;
    rdfs:comment 'The inventory quantity on hand for the affected SKU at the time of this price change event. Used to calculate the total markdown (MD) dollar exposure and weeks of supply (WOS) impact in merchandise financial planning.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wosAtChange rdf:type rdf:Property ;
    rdfs:label 'Wos At Change' ;
    rdfs:comment 'The Weeks of Supply (WOS) for the affected SKU at the time of this price change event, calculated as units on hand divided by average weekly sales rate. Used to assess inventory urgency and justify markdown (MD) depth decisions.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Reference to the sales channel for which this price record is applicable (e.g., DTC retail store, e-commerce, wholesale). Supports channel-specific pricing strategies.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Reference to the price list or price zone under which this record is governed. Price lists segment pricing by channel, region, or customer tier in Oracle Retail Price Management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Reference to the geographic region or market for which this price record applies. Supports regional pricing strategies across domestic and international markets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:aur rdf:type rdf:Property ;
    rdfs:label 'Aur' ;
    rdfs:comment 'Average Unit Retail (AUR) — the average price at which a unit is actually sold after accounting for promotions, markdowns (MD), and clearance events. A key KPI in merchandise financial planning and STR (Sell-Through Rate) analysis. Managed in Anaplan merchandise planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Price' ;
    rdfs:comment 'The observed or benchmarked competitor price for a comparable product at the time of pricing decision. Used to support competitive pricing analysis and market positioning strategy. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The landed cost price of the product including COGS (Cost of Goods Sold) components such as CMT (Cut Make Trim), materials, LDP (Landed Duty Paid) duties, and freight. Used as the denominator for IMU (Initial Markup) and MMU (Maintained Markup) calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedDutyPaidCost rdf:type rdf:Property ;
    rdfs:label 'Landed Duty Paid Cost' ;
    rdfs:comment 'Total LDP (Landed Duty Paid) cost including FOB (Free on Board) price, import duties, freight, insurance, and customs clearance charges. Used as the true cost basis for margin calculations and sourcing decisions.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPercent rdf:type rdf:Property ;
    rdfs:label 'Markdown Percent' ;
    rdfs:comment 'The percentage reduction from MSRP applied during a markdown (MD) event, calculated as (MSRP - Markdown Price) / MSRP × 100. Used to track markdown depth, promotional cadence, and margin erosion in merchandise financial planning.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPrice rdf:type rdf:Property ;
    rdfs:label 'Markdown Price' ;
    rdfs:comment 'The reduced selling price applied during a markdown (MD) event, clearance, or end-of-season promotion. Tracked separately from MSRP to enable markdown depth analysis and STR (Sell-Through Rate) optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Min Advertised Price' ;
    rdfs:comment 'The minimum price at which wholesale partners and retailers are contractually permitted to advertise this product. Enforced to protect brand equity and prevent price erosion in wholesale and marketplace channels.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification or reason code for the price change event (e.g., seasonal markdown, competitive response, cost increase, promotional event, clearance). Supports pricing audit trail and merchandise financial planning analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceElasticityIndex rdf:type rdf:Property ;
    rdfs:label 'Price Elasticity Index' ;
    rdfs:comment 'A numeric index representing the price sensitivity of demand for this SKU/style, derived from historical sales and pricing data in Anaplan. Used to optimize markdown timing, promotional depth, and AUR (Average Unit Retail) planning.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceMasterCode rdf:type rdf:Property ;
    rdfs:label 'Price Master Code' ;
    rdfs:comment 'Externally-known business identifier for the price master record as assigned in Oracle Retail Price Management. Used for cross-system reference and EDI (Electronic Data Interchange) integration with wholesale partners and ERP systems.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the price master record. Active records are currently in use; pending records are approved but not yet effective; expired records have passed their effective end date; superseded records have been replaced by a newer price version.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Categorizes the nature of the price record — regular everyday price, promotional price, clearance/end-of-season price, wholesale price, cost price, or internal transfer price. Governs which price is applied in each transaction context.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVersion rdf:type rdf:Property ;
    rdfs:label 'Price Version' ;
    rdfs:comment 'Sequential version number of the price record, incremented each time the price is updated or superseded. Enables price history tracking and point-in-time pricing reconstruction for audit and analytics purposes.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceZoneCode rdf:type rdf:Property ;
    rdfs:label 'Price Zone Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based price zone to which this price record belongs. Price zones allow differentiated pricing across markets (e.g., US_EAST, EU_WEST, APAC) within Oracle Retail Price Management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelType rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Type' ;
    rdfs:comment 'The type of sales channel for which this price is applicable. DTC (Direct-to-Consumer) retail, DTC e-commerce, wholesale, outlet, marketplace, or franchise. Enables channel-specific pricing strategy and margin analysis.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the MSRP and selling prices include applicable taxes (VAT, GST, sales tax). True = tax-inclusive pricing (common in EU/UK markets); False = tax-exclusive pricing (common in US markets). Governs POS and e-commerce price display.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'The internal price used for inter-company or inter-division product transfers (e.g., from distribution center to retail store, or between legal entities). Used in SAP S/4HANA FI/CO for intercompany accounting and IFRS transfer pricing compliance.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'Universal Product Code (UPC) barcode identifier for the SKU. Used for POS (Point of Sale) scanning, RFID (Radio Frequency Identification) tagging, and retail shelf management. Conforms to GS1 UPC-A or EAN-13 standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'The applicable VAT (Value Added Tax) or GST rate percentage for this product in the specified country/region. Used for tax-inclusive price calculation, consumer receipt display, and regulatory tax reporting.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesalePrice rdf:type rdf:Property ;
    rdfs:label 'Wholesale Price' ;
    rdfs:comment 'The price at which the product is sold to wholesale partners, department stores, and distribution accounts. Used in wholesale margin analysis, partner negotiations, and GMROI (Gross Margin Return on Investment) reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Promotions are created and managed by marketing or merchandising employees who define discount strategy, channel scope, and performance targets. Required for approval workflows, promotion effectivenes' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourcePromotionId rdf:type rdf:Property ;
    rdfs:label 'Source Promotion Id' ;
    rdfs:comment 'Original promotion identifier as recorded in the source operational system (e.g., Oracle Retail promotion number, SAP SD condition record number). Enables traceability and reconciliation between the Databricks Silver Layer and source systems of record.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:actualLiftPct rdf:type rdf:Property ;
    rdfs:label 'Actual Lift Pct' ;
    rdfs:comment 'Realized percentage increase in unit sales or revenue achieved by this promotion compared to baseline, captured post-promotion from SAP CAR POS data and Salesforce Commerce Cloud. Compared against planned_lift_pct for STR (Sell-Through Rate) analysis and future promotion planning.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRevenue rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue' ;
    rdfs:comment 'Realized gross revenue generated during the promotion period, sourced from SAP CAR POS transactions and Salesforce Commerce Cloud order data. Compared against planned_revenue for post-promotion performance analysis and GMROI optimization.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Units' ;
    rdfs:comment 'Realized number of units sold during the promotion period, sourced from SAP CAR POS and Salesforce Commerce Cloud. Used in STR (Sell-Through Rate) analysis and post-promotion inventory reconciliation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Alphanumeric coupon or voucher code that customers enter at POS or e-commerce checkout to activate the promotion when coupon_required is True (e.g., SAVE20, LOYALTY10). Null when coupon_required is False.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRequired rdf:type rdf:Property ;
    rdfs:label 'Coupon Required' ;
    rdfs:comment 'Indicates whether the customer must present or enter a coupon code to redeem the promotion. True = coupon code required at POS or e-commerce checkout; False = automatic/stackable promotion applied without customer action.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Markdown (MD) percentage applied to the original MSRP or AUR (Average Unit Retail) for percentage-off promotion types. Expressed as a percentage (e.g., 25.00 = 25% off). Null for non-percentage promotion types such as fixed_price or bogo. Used in IMU/MMU (Initial Markup/Maintained Markup) impact analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Price Amount' ;
    rdfs:comment 'Absolute promotional selling price applied to eligible items for fixed_price promotion types (e.g., $29.99). Null for percentage-off or BOGO mechanics. Represents the promotional AUR (Average Unit Retail) override in Oracle Retail Price Management.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiImpact rdf:type rdf:Property ;
    rdfs:label 'Gmroi Impact' ;
    rdfs:comment 'Estimated or realized GMROI (Gross Margin Return on Investment) impact of the promotion, calculated as gross margin dollars generated per dollar of inventory investment during the promotional period. A core KPI in apparel merchandising financial planning. Classified confidential as it reveals margin strategy.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLoyaltyExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Exclusive' ;
    rdfs:comment 'Indicates whether this promotion is exclusively available to loyalty program members. True = restricted to loyalty members only (tracked via Adobe Experience Platform or CRM); False = available to all customers. Supports CLTV (Customer Lifetime Value) and loyalty program ROI analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownBudget rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget' ;
    rdfs:comment 'Allocated markdown (MD) budget for this promotion, representing the maximum planned reduction in gross margin approved by the merchandising team. Expressed in currency_code. Managed in Anaplan OTB (Open-to-Buy) financial planning. Classified confidential as it reflects internal pricing strategy.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandiseScope rdf:type rdf:Property ;
    rdfs:label 'Merchandise Scope' ;
    rdfs:comment 'Level of the merchandise hierarchy to which the promotion applies. Determines eligible SKUs (Stock Keeping Units) in Oracle Retail: all_merchandise (storewide), department (e.g., Footwear), class (e.g., Running Shoes), subclass (e.g., Men\'s Running), sku (specific SKU), style (all colorways of a style). Drives assortment planning and allocation strategies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum transaction value (in local currency) a customer must reach to qualify for the promotion. Used for threshold-based promotions (e.g., spend $100 get 20% off). Supports AOV (Average Order Value) uplift strategies in Salesforce Commerce Cloud and SAP CAR.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of units a customer must purchase to qualify for the promotion. Relevant for BOGO, bundle, and quantity-threshold promotions. Aligns with MOQ (Minimum Order Quantity) concepts in wholesale channel promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLiftPct rdf:type rdf:Property ;
    rdfs:label 'Planned Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in unit sales or revenue expected from this promotion compared to baseline, as planned in Anaplan merchandise financial planning. Used to set OTB (Open-to-Buy) budgets and evaluate GMROI (Gross Margin Return on Investment) impact pre-promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRevenue rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue' ;
    rdfs:comment 'Forecasted gross revenue expected to be generated during the promotion period, as modeled in Anaplan merchandise financial planning. Expressed in the currency defined by currency_code. Used for OTB budget setting and GMROI planning.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Free-text business description of the promotion\'s terms, conditions, and marketing narrative as communicated to customers and store associates (e.g., \'Get 25% off all women\'s outerwear this weekend only\'). Used in POS displays, e-commerce banners, and marketing collateral.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of available promotional inventory sold during the promotion period (units sold / units available × 100). A key KPI in apparel merchandising for evaluating promotion effectiveness and informing future markdown (MD) and clearance strategies. Sourced post-promotion from Oracle Retail and SAP CAR.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this promotion can be combined with other active promotions on the same transaction. True = can stack with other promotions; False = exclusive promotion, cannot be combined. Critical for margin protection and MMU (Maintained Markup) management.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Clearance End Date' ;
    rdfs:comment 'The date by which all clearance selling for this season must be completed. After this date, remaining inventory is subject to return-to-vendor (RTV), off-price channel transfer, or write-off. Defines the final boundary of the season\'s sell-through window.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalHalf rdf:type rdf:Property ;
    rdfs:label 'Fiscal Half' ;
    rdfs:comment 'The fiscal half-year period (H1 or H2) to which this season is aligned. Spring/Summer and Resort seasons typically fall in H1; Fall/Winter, Pre-Fall, and Holiday seasons in H2. Used for semi-annual merchandise financial planning (MFP) and OTB budget allocation in Anaplan.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownCadence rdf:type rdf:Property ;
    rdfs:label 'Markdown Cadence' ;
    rdfs:comment 'The planned frequency of markdown (MD) events during the clearance phase of this season. Drives the markdown calendar in Oracle Retail Merchandising System Price Management and informs maintained markup (MMU) forecasting in Anaplan.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStartDate rdf:type rdf:Property ;
    rdfs:label 'Markdown Start Date' ;
    rdfs:comment 'The date on which the first planned markdown (MD) event for this season begins. Initiates the end-of-season clearance cadence. Drives markdown (MD) planning in Oracle Retail Merchandising System Price Management and Anaplan merchandise financial planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Market Week End Date' ;
    rdfs:comment 'The end date of the industry market week associated with this season. Together with market_week_start_date, defines the window during which wholesale buyers finalize orders and assortment commitments.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Market Week Start Date' ;
    rdfs:comment 'The start date of the industry market week (trade show / buying week) associated with this season, during which buyers review collections and place wholesale orders. Key date for collection planning and wholesale distribution calendars.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mfpVersion rdf:type rdf:Property ;
    rdfs:label 'Mfp Version' ;
    rdfs:comment 'The version identifier of the approved merchandise financial plan (MFP) associated with this season in Anaplan (e.g., \'v1.0-Initial\', \'v2.1-Revised\'). Tracks plan revisions through the planning cycle and ensures alignment between OTB budgets and financial targets.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numPlannedSkus rdf:type rdf:Property ;
    rdfs:label 'Num Planned Skus' ;
    rdfs:comment 'The total number of distinct SKUs (Stock Keeping Units) planned for this season across all styles, colors, and sizes. Used to manage assortment breadth, warehouse capacity planning in Manhattan Associates WMS, and OTB unit buy planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numPlannedStyles rdf:type rdf:Property ;
    rdfs:label 'Num Planned Styles' ;
    rdfs:comment 'The total number of distinct styles (SKU parent-level products) planned for this season\'s assortment. Set during collection planning in Centric PLM and used to manage line architecture, OTB depth-versus-breadth trade-offs, and assortment productivity analysis.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Order Deadline Date' ;
    rdfs:comment 'The final date by which all purchase orders (POs) for this season must be submitted to suppliers to ensure on-time delivery within the season\'s delivery window. Critical T&A calendar milestone managed in SAP S/4HANA MM and Centric PLM.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otbBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Amount' ;
    rdfs:comment 'The total approved Open-to-Buy (OTB) budget in the company\'s reporting currency for this season. Represents the maximum planned merchandise spend authorized for buying activities. Set during merchandise financial planning (MFP) in Anaplan and tracked against actual PO commitments in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Amount' ;
    rdfs:comment 'The total planned net sales revenue in the company\'s reporting currency for this season as set during merchandise financial planning (MFP). Serves as the top-line revenue target against which actual sell-through rate (STR) and average unit retail (AUR) performance are measured.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The date on which internal merchandise planning activities formally begin for this season, including OTB budget setting, assortment planning, and buy plan development in Anaplan and Oracle Retail Merchandising System. Precedes the trading start date by several months.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Production Start Date' ;
    rdfs:comment 'The date on which pre-production (PP) activities commence for this season, including fabric and trim approvals, fit samples, and pre-production sample sign-off. Key milestone in the T&A calendar tracked in Centric PLM and Infor PLM.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regionScope rdf:type rdf:Property ;
    rdfs:label 'Region Scope' ;
    rdfs:comment 'The geographic region or market scope for which this season is defined (e.g., \'Global\', \'North America\', \'EMEA\', \'APAC\'). Supports multi-regional merchandise planning where season start/end dates and delivery windows may vary by market. Used in Oracle Retail Merchandising System and Anaplan regional planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonDescription rdf:type rdf:Property ;
    rdfs:label 'Season Description' ;
    rdfs:comment 'Free-text narrative description of the season, capturing key strategic intent, collection positioning, target consumer profile, or planning notes. Used by merchandising and planning teams for context in Oracle Retail Merchandising System and Anaplan.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable full name of the merchandise season (e.g., \'Spring/Summer 2025\', \'Fall/Winter 2024\', \'Holiday 2024\', \'Resort 2025\'). Used in reporting, planning dashboards, and buyer-facing documents.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle state of the merchandise season. \'planning\' indicates the season is in pre-production planning; \'active\' indicates the season is currently trading; \'closed\' indicates the season has ended trading; \'archived\' indicates the season is retained for historical reference only. Controls visibility in planning tools and reporting.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Source System Season Code' ;
    rdfs:comment 'The native season identifier as recorded in the originating operational system of record (e.g., Oracle Retail Merchandising System season number, Anaplan season key). Enables traceability and reconciliation between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Tna Calendar Code' ;
    rdfs:comment 'Reference code linking this season to its associated Time and Action (T&A) calendar template in Centric PLM or Infor PLM. The T&A calendar defines all critical path milestones from design brief through to final delivery for the season.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply Target' ;
    rdfs:comment 'The target number of weeks of supply (WOS) to be maintained during the peak trading period of this season. Used to calibrate inventory depth in buy plans and allocation strategies, ensuring sufficient stock without excess inventory build-up.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Basis Period End Date' ;
    rdfs:comment 'End date of the historical sell-through data period used to derive this size curve\'s distribution percentages. Together with basis_period_start_date, defines the historical window for statistical calibration of size ratios.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Basis Period Start Date' ;
    rdfs:comment 'Start date of the historical sell-through data period used to derive this size curve\'s distribution percentages. Defines the lookback window for statistical calibration. Typically covers 1-3 prior seasons of comparable selling history.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level of the size curve based on the volume and quality of historical sell-through data used in derivation. High confidence curves are used directly in buy plans; low confidence curves require planner override review. Drives curve applicability flags in Anaplan.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveCode rdf:type rdf:Property ;
    rdfs:label 'Curve Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the size curve profile, used in Oracle Retail Merchandising System and Anaplan for cross-system reference. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveDerivationMethod rdf:type rdf:Property ;
    rdfs:label 'Curve Derivation Method' ;
    rdfs:comment 'Method used to derive the size distribution percentages for this curve. Historical STR uses actual sell-through data; planner_override reflects manual planner judgment; vendor_recommended uses supplier-provided size ratios; statistical_model uses algorithmic forecasting; blended combines multiple methods. Affects confidence level assignment.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Human-readable descriptive name for the size curve profile (e.g., \'Women\'s Fitted Tops Standard\', \'Men\'s Denim 28-42 Bell Curve\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity. Used in Oracle Retail and Anaplan planning interfaces.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the size curve profile indicating the fit and silhouette category that drives the distribution shape. Standard curves follow bell-curve distributions; fitted curves skew toward smaller sizes; oversized curves skew toward larger sizes. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: standard|fitted|oversized|petite|plus|tall|slim|relaxed — promote to reference product]' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultForClass rdf:type rdf:Property ;
    rdfs:label 'Is Default For Class' ;
    rdfs:comment 'Indicates whether this size curve is the default curve applied to new styles within the associated merchandise class when no style-specific curve exists. True = default fallback curve for the class. Used in Oracle Retail automated allocation and buy plan generation.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReplenishmentEligible rdf:type rdf:Property ;
    rdfs:label 'Is Replenishment Eligible' ;
    rdfs:comment 'Indicates whether this size curve is approved for use in automated replenishment size pack calculations in Manhattan Associates WMS. True = curve can drive replenishment size breaks. False = curve is restricted to initial buy plan and allocation use only.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this size curve was last reviewed and validated by a merchandise planner. Curves not reviewed within a defined period (e.g., 2 seasons) are flagged for re-validation to ensure continued accuracy. Supports governance of curve quality.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Markdown Risk Index' ;
    rdfs:comment 'Composite risk score (0.00-100.00) indicating the likelihood of size-related markdown exposure if this curve is applied to a buy plan. Derived from historical size fragmentation patterns and STR variance across sizes. Higher scores indicate greater markdown risk from size imbalance. Critical for GMROI optimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numericSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Numeric Size Distribution' ;
    rdfs:comment 'Serialized representation of the size distribution percentages for numeric size runs (waist sizes 28-42 or equivalent), stored as a delimited string of size:percentage pairs (e.g., \'28:5.0|30:12.0|32:22.0|34:25.0|36:18.0|38:12.0|40:4.0|42:2.0\'). Null for alpha or shoe size scale types. Used when the number of numeric sizes exceeds the available discrete percentage columns.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctL rdf:type rdf:Property ;
    rdfs:label 'Pct L' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size L in the alpha size run. Expressed as a percentage (e.g., 25.00 = 25%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and replenishment size pack optimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctM rdf:type rdf:Property ;
    rdfs:label 'Pct M' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size M in the alpha size run. Expressed as a percentage (e.g., 28.00 = 28%). Typically the modal size in standard bell-curve distributions. Null for numeric or shoe size scale types.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctS rdf:type rdf:Property ;
    rdfs:label 'Pct S' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size S in the alpha size run. Expressed as a percentage (e.g., 18.00 = 18%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and allocation size breaks.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXl rdf:type rdf:Property ;
    rdfs:label 'Pct Xl' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XL in the alpha size run. Expressed as a percentage (e.g., 14.00 = 14%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and initial distribution planning.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXs rdf:type rdf:Property ;
    rdfs:label 'Pct Xs' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XS in the alpha size run. Expressed as a percentage (e.g., 8.50 = 8.5%). Null for numeric or shoe size scale types. All size distribution percentages must sum to 100.00 for a valid curve. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXxl rdf:type rdf:Property ;
    rdfs:label 'Pct Xxl' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XXL in the alpha size run. Expressed as a percentage (e.g., 6.50 = 6.5%). Null for numeric or shoe size scale types. Monitoring XXL distribution is critical for plus-size assortment planning and markdown minimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUnitCount rdf:type rdf:Property ;
    rdfs:label 'Sample Unit Count' ;
    rdfs:comment 'Total number of units sold in the historical basis period used to derive this size curve. Higher sample counts yield higher statistical confidence. Used to validate confidence_level assignment — curves based on fewer than a threshold number of units are flagged as low confidence.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to the base size distribution percentages to account for seasonal demand shifts (e.g., 1.0500 = 5% upward adjustment). Captures known seasonal size preference changes such as outerwear seasons skewing larger. Applied in Anaplan seasonal buy plan calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shoeSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Shoe Size Distribution' ;
    rdfs:comment 'Serialized representation of the size distribution percentages for shoe size runs (US sizes 5-14 or equivalent), stored as a delimited string of size:percentage pairs (e.g., \'7:8.0|7.5:10.0|8:15.0|8.5:18.0|9:17.0|9.5:14.0|10:12.0|10.5:6.0\'). Null for alpha or numeric apparel size scale types.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCount rdf:type rdf:Property ;
    rdfs:label 'Size Count' ;
    rdfs:comment 'Total number of discrete sizes in the size run covered by this curve (e.g., 6 for XS-XXL alpha, 8 for 28-42 even numeric). Drives the number of size break columns populated in allocation and replenishment size pack calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeCurveStatus rdf:type rdf:Property ;
    rdfs:label 'Size Curve Status' ;
    rdfs:comment 'Current lifecycle status of the size curve profile. Active curves are used in live buy plans and allocation runs. Draft curves are under development. Archived curves are retained for historical analysis but excluded from new planning cycles. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeMax rdf:type rdf:Property ;
    rdfs:label 'Size Range Max' ;
    rdfs:comment 'The largest size in the size run covered by this curve (e.g., \'XXL\', \'42\', \'14\'). Combined with size_range_min to define the full size run span. Used to validate that buy plan size breaks fall within the defined range.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeMin rdf:type rdf:Property ;
    rdfs:label 'Size Range Min' ;
    rdfs:comment 'The smallest size in the size run covered by this curve (e.g., \'XS\', \'28\', \'5\'). Combined with size_range_max to define the full size run span. Used to validate that buy plan size breaks fall within the defined range.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeClusterCode rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Code' ;
    rdfs:comment 'Identifier for the store cluster or store tier to which this size curve applies (e.g., \'FLAGSHIP\', \'MALL_A\', \'OUTLET_B\'). Store clusters group locations with similar size-selling patterns. Enables cluster-level size allocation optimization to reduce size-related markdowns.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strBasisPct rdf:type rdf:Property ;
    rdfs:label 'Str Basis Pct' ;
    rdfs:comment 'The minimum Sell-Through Rate (STR) achieved in the historical basis period for the data to be considered statistically valid for curve derivation. Expressed as a percentage (e.g., 75.00 means 75% STR). Curves derived from low-STR periods may be flagged as low-confidence.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to quality.corrective_action. Business justification: CAPA completion is a condition for allowance reinstatement after quality failures. Corrective action costs offset vendor allowances. Critical for linking quality improvement to vendor financial terms ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'End date of the financial accrual period during which the allowance is earned.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'Start date of the financial accrual period during which the allowance is earned.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualPerformanceAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Performance Amount' ;
    rdfs:comment 'Actual sales or purchase amount achieved during the accrual period, used to calculate earned allowance.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPerformanceUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Performance Units' ;
    rdfs:comment 'Actual unit quantity sold or purchased during the accrual period, used to calculate earned allowance.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementAmount rdf:type rdf:Property ;
    rdfs:label 'Agreement Amount' ;
    rdfs:comment 'Total contracted or committed allowance amount agreed with the vendor.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'Effective end date of the vendor allowance agreement or accrual period. Nullable for open-ended agreements.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'Effective start date of the vendor allowance agreement or accrual period.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowanceNumber rdf:type rdf:Property ;
    rdfs:label 'Allowance Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the vendor allowance agreement, used in vendor negotiations and financial reporting.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Allowance Rate Percent' ;
    rdfs:comment 'Percentage rate applied to calculate the allowance (e.g., 5% of net sales, 2% markdown allowance). Nullable if allowance is fixed amount.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Allowance Status' ;
    rdfs:comment 'Current lifecycle status of the vendor allowance: draft (under negotiation), active (in effect), claimed (submitted for payment), partially settled, fully settled, expired, disputed, or cancelled. [ENUM-REF-CANDIDATE: draft|active|claimed|partially_settled|fully_settled|expired|disputed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Category of vendor allowance: markdown money (MDA), advertising allowance, volume rebate, defective allowance, Return to Vendor (RTV) credit, promotional funding, or freight allowance. [ENUM-REF-CANDIDATE: markdown_money|advertising_allowance|volume_rebate|defective_allowance|rtv_credit|promotional_funding|freight_allowance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'External reference number or claim ID provided by the vendor for tracking the allowance claim.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Deadline' ;
    rdfs:comment 'Final date by which the allowance claim must be submitted to the vendor for payment.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Amount of allowance formally claimed from the vendor for settlement.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed allowance was resolved. Nullable if no dispute or not yet resolved.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnedAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Amount' ;
    rdfs:comment 'Amount of allowance earned based on performance criteria (sales volume, markdown taken, promotional activity) during the accrual period.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Gmroi Impact Percent' ;
    rdfs:comment 'Estimated or actual impact of this allowance on Gross Margin Return on Investment (GMROI) for the associated merchandise.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Amount' ;
    rdfs:comment 'Minimum sales or purchase volume required to qualify for the allowance. Nullable if no threshold applies.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceThresholdUnits rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Units' ;
    rdfs:comment 'Minimum unit quantity required to qualify for the allowance. Nullable if no unit threshold applies.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'Amount of allowance actually paid or credited by the vendor to date.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemAllowanceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Allowance Code' ;
    rdfs:comment 'Original unique identifier for this vendor allowance in the source system.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity Uom' ;
    rdfs:comment 'Unit of measure for the allocated quantity (e.g., each, pieces, pairs).' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'The precise date and time when the allocation was created in the system.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atpConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Flag' ;
    rdfs:comment 'Indicates whether the allocation was confirmed against Available to Promise inventory rules.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atpConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Timestamp' ;
    rdfs:comment 'The date and time when ATP confirmation was received for this allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atsAtAllocation rdf:type rdf:Property ;
    rdfs:label 'Ats At Allocation' ;
    rdfs:comment 'Snapshot of the Available to Sell inventory quantity at the source location at the time of allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Customer segment classification influencing allocation priority and method.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'The actual quantity fulfilled against this allocation, which may differ from allocated quantity due to shortages or adjustments.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preorderFlag rdf:type rdf:Property ;
    rdfs:label 'Preorder Flag' ;
    rdfs:comment 'Indicates whether this allocation is for a preorder item not yet available in inventory.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date promised to the customer for delivery of the allocated SKU, used for OTIF tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderId rdf:type rdf:Property ;
    rdfs:label 'Backorder Id' ;
    rdfs:comment 'Unique identifier for the backorder record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Backorder .

ind:allocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Id' ;
    rdfs:comment 'Reference to the allocation rule that was applied when the backorder was created, if applicable.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:backorderSkuId rdf:type rdf:Property ;
    rdfs:label 'Backorder Sku Id' ;
    rdfs:comment 'Reference to the SKU (style-color-size combination) that is backordered.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:backorderSubstituteSkuId rdf:type rdf:Property ;
    rdfs:label 'Backorder Substitute Sku Id' ;
    rdfs:comment 'Reference to an alternative SKU offered or accepted as a substitute for the backordered item, if applicable.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Date' ;
    rdfs:comment 'The actual date when the backorder was fulfilled and shipped, null if still pending.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderNumber rdf:type rdf:Property ;
    rdfs:label 'Backorder Number' ;
    rdfs:comment 'Human-readable business identifier for the backorder, used for tracking and customer communication.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderStatus rdf:type rdf:Property ;
    rdfs:label 'Backorder Status' ;
    rdfs:comment 'Current lifecycle status of the backorder indicating its fulfillment stage. [ENUM-REF-CANDIDATE: open|allocated|in_production|ready_to_ship|shipped|cancelled|substituted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Backordered Quantity' ;
    rdfs:comment 'The quantity of units that could not be fulfilled and are on backorder.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when the backorder was cancelled, either by the customer or by the business, null if still active.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'The precise timestamp when the backorder record was created in the system.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOnBackorder rdf:type rdf:Property ;
    rdfs:label 'Days On Backorder' ;
    rdfs:comment 'The number of days the order has been on backorder status, calculated from backorder_creation_date to current date or fulfillment date.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Expected Fulfillment Date' ;
    rdfs:comment 'The estimated date when the backorder will be fulfilled and shipped to the customer.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Expected Replenishment Date' ;
    rdfs:comment 'The anticipated date when inventory will be replenished and available to fulfill this backorder.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'The total monetary value of the backordered quantity (backordered_quantity × unit_price).' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date when the backorder notification was sent to the customer.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Status indicating whether the customer has been notified about the backorder and any follow-up communications.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The sales channel through which the original order was placed (e-commerce, wholesale EDI, retail POS, call center, mobile app).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRequestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Requested Quantity' ;
    rdfs:comment 'The original quantity requested on the sales order line before partial fulfillment or backorder split.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'The action taken or planned to resolve the backorder (hold for next drop, cancel, substitute with alternative SKU, split shipment, upgrade).' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The unit price of the backordered SKU at the time of the original order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediTransactionId rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Id' ;
    rdfs:comment 'Unique identifier for the EDI transaction record. Primary key.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: EDI exceptions and validation failures require manual intervention; tracking resolution ownership is critical for SLA compliance, chargeback dispute resolution, and trading partner relationship manage' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tradingPartnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Agreement Id' ;
    rdfs:comment 'Reference to the trading partner agreement or vendor routing guide that governs this EDI transaction. Ensures compliance with retailer-specific requirements (e.g., Nordstrom, Macys routing guides).' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:tradingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Id' ;
    rdfs:comment 'Identifier of the wholesale trading partner (retailer, distributor, or vendor) involved in this EDI transaction.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradingPartner .

ind:chargebackRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Risk Flag' ;
    rdfs:comment 'Indicates whether this transaction has potential chargeback risk due to late transmission, missing data, or non-compliance with trading partner requirements.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Protocol used to transmit or receive the EDI message. Common values: AS2 (Applicability Statement 2), SFTP (Secure File Transfer Protocol), FTP, VAN (Value-Added Network), API, HTTPS.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the EDI message was received (inbound) or sent (outbound) by the business.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Standard Version' ;
    rdfs:comment 'Version of the ANSI X12 standard used for this transaction (e.g., 004010, 005010). From ISA12 element.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Human-readable description of the error or rejection reason. Provides context for troubleshooting failed EDI transactions.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAckStatus rdf:type rdf:Property ;
    rdfs:label 'Functional Ack Status' ;
    rdfs:comment 'Status of the ANSI X12 997 Functional Acknowledgment for this transaction. Tracks whether acknowledgment was sent (for inbound) or received (for outbound).' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Functional Ack Timestamp' ;
    rdfs:comment 'Date and time when the 997 Functional Acknowledgment was sent or received for this transaction.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalGroupControlNumber rdf:type rdf:Property ;
    rdfs:label 'Functional Group Control Number' ;
    rdfs:comment 'Control number for the functional group (GS segment) containing this transaction set. Groups related transaction sets together.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationBatchCode rdf:type rdf:Property ;
    rdfs:label 'Integration Batch Code' ;
    rdfs:comment 'Identifier of the integration batch or job that processed this EDI transaction into downstream operational systems.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Number' ;
    rdfs:comment 'Unique control number for the entire EDI interchange envelope per ANSI X12 ISA segment. Ensures end-to-end traceability.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Payload Size Bytes' ;
    rdfs:comment 'Size of the EDI message payload in bytes. Used for transmission monitoring and capacity planning.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the EDI transaction was successfully processed and integrated into operational systems.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing state of the EDI transaction. Tracks lifecycle from receipt through validation, acknowledgment, and integration into operational systems. [ENUM-REF-CANDIDATE: received|validated|accepted|rejected|processed|error|pending_ack — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCode rdf:type rdf:Property ;
    rdfs:label 'Receiver Code' ;
    rdfs:comment 'Unique identifier of the EDI message receiver. Format depends on receiver_qualifier. From ANSI X12 ISA08.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverQualifier rdf:type rdf:Property ;
    rdfs:label 'Receiver Qualifier' ;
    rdfs:comment 'Qualifier identifying the type of receiver ID (e.g., 01=DUNS, 12=Phone, 14=UPC, ZZ=Mutually Defined). From ANSI X12 ISA07.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times transmission or processing of this EDI transaction was retried due to errors or failures.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Number of segments in the EDI transaction set. Used for validation and completeness checking per ANSI X12 SE01 element.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderCode rdf:type rdf:Property ;
    rdfs:label 'Sender Code' ;
    rdfs:comment 'Unique identifier of the EDI message sender. Format depends on sender_qualifier (e.g., DUNS number, phone, custom ID). From ANSI X12 ISA06.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderQualifier rdf:type rdf:Property ;
    rdfs:label 'Sender Qualifier' ;
    rdfs:comment 'Qualifier identifying the type of sender ID (e.g., 01=DUNS, 12=Phone, 14=UPC, ZZ=Mutually Defined). From ANSI X12 ISA05.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Indicator' ;
    rdfs:comment 'Indicates whether this is a test transaction (true) or production transaction (false). From ANSI X12 ISA15 element (T=Test, P=Production).' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSetControlNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Control Number' ;
    rdfs:comment 'Unique control number assigned to the transaction set within the functional group per ANSI X12 ST segment. Used for tracking and acknowledgment.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time when the EDI message was transmitted or received. Captured from ISA interchange date/time or system receipt timestamp.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Id' ;
    rdfs:comment 'Primary key for fulfillment' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Picker Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Warehouse pickers execute order picking; essential for labor productivity tracking, pick accuracy metrics, quality control, and performance-based compensation in DC operations. Role-prefixed to distin' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Precise date and time the shipment was delivered to the customer, including time zone. Captured from carrier proof of delivery.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Reference Number' ;
    rdfs:comment 'EDI 856 ASN document reference number sent to wholesale buyers notifying them of inbound shipment details.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier or third-party logistics provider assigned to transport the shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Number' ;
    rdfs:comment 'Business-facing unique identifier for the fulfillment record. Used for tracking and customer communication.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'Classification of the fulfillment service level. Determines handling priority and delivery expectations. [ENUM-REF-CANDIDATE: standard|express|same_day|next_day|international|store_pickup|curbside — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Boolean indicator of whether the fulfillment included 100% of the ordered quantity, regardless of delivery timing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Boolean indicator of whether the fulfillment was delivered on or before the promised delivery date, regardless of quantity completeness.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Boolean indicator of whether the fulfillment met OTIF (On Time In Full) performance criteria: delivered on or before promised date with complete quantity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Complete Timestamp' ;
    rdfs:comment 'Date and time when all items were packed into shipping cartons and ready for carrier pickup.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Date and time when packing activity began for this fulfillment. Marks the transition from picking to packing operations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Complete Timestamp' ;
    rdfs:comment 'Date and time when all items for this fulfillment were successfully picked from warehouse inventory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'Date and time when warehouse picking activity began for this fulfillment. Marks the start of physical fulfillment execution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'Primary street address line for the shipment delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number at the delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City name for the shipment delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipment delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Email Address' ;
    rdfs:comment 'Email address for the delivery recipient. Used for shipment tracking notifications and delivery confirmations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToName rdf:type rdf:Property ;
    rdfs:label 'Ship To Name' ;
    rdfs:comment 'Name of the recipient or delivery contact for this shipment. May differ from the ordering customer for gift orders.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ship To Phone Number' ;
    rdfs:comment 'Contact phone number for the delivery recipient. Used by carrier for delivery coordination and customer notification.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipment delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State, province, or region for the shipment delivery destination.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Amount' ;
    rdfs:comment 'Total freight cost charged by the carrier for this shipment. Used for COGS (Cost of Goods Sold) calculation and profitability analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the shipping cost amount.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:comment 'Total number of shipping cartons or packages in this fulfillment. Used for warehouse capacity planning and carrier billing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of individual SKU (Stock Keeping Unit) units included in this fulfillment across all cartons.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volumetric measurement of the shipment in cubic meters. Used for warehouse space planning and dimensional weight pricing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderHoldId rdf:type rdf:Property ;
    rdfs:label 'Order Hold Id' ;
    rdfs:comment 'Unique identifier for the order hold record. Primary key.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOrderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Employee Id' ;
    rdfs:comment 'User ID of the person who manually placed the hold, if applicable. Empty for system-generated holds.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOrderLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this hold record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether explicit management approval is required to release this hold (true) or if it can be auto-released by system rules (false).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Business role or job function authorized to approve release of this hold type. Examples include CREDIT_MANAGER, FRAUD_ANALYST, COMPLIANCE_OFFICER, WAREHOUSE_SUPERVISOR.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReleaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Release Eligible Flag' ;
    rdfs:comment 'Indicates whether this hold is eligible for automatic release by system rules when conditions are met (true) or requires manual intervention (false).' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Blocked Delivery Date' ;
    rdfs:comment 'Originally scheduled delivery date that is now at risk due to this hold. Used to assess customer impact and On Time In Full (OTIF) risk.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division responsible for managing this hold. Used for organizational reporting and accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified about the order hold and potential delivery delay.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when customer notification was sent regarding the hold. Null if no notification has been sent.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP distribution channel code for the order. Examples include Direct-to-Consumer (DTC), wholesale, e-commerce, retail store.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Calculated duration in hours that the hold was active, from placement to release. Used for Service Level Agreement (SLA) compliance reporting and process improvement analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the hold was most recently escalated to a higher approval level. Null if never escalated.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalHoldReference rdf:type rdf:Property ;
    rdfs:label 'External Hold Reference' ;
    rdfs:comment 'External reference identifier from third-party systems such as fraud detection services, credit bureaus, or compliance platforms.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCategory rdf:type rdf:Property ;
    rdfs:label 'Hold Category' ;
    rdfs:comment 'High-level business category grouping similar hold types for reporting and analytics. Enables trend analysis across hold categories.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'System-assigned code identifying the specific hold type in SAP SD. Examples include ZCRD (credit hold), ZFRAUD (fraud review), ZINV (inventory shortage), ZCOMP (compliance review), ZADDR (address verification).' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Business classification of the hold reason. Determines the workflow and approval authority required for release. [ENUM-REF-CANDIDATE: credit_hold|fraud_review|inventory_shortage|compliance_review|address_verification|payment_verification|export_control|quality_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAmount rdf:type rdf:Property ;
    rdfs:label 'Impact Amount' ;
    rdfs:comment 'Total order value in base currency that is blocked by this hold. Used for financial impact analysis and prioritization.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the hold impact amount.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedBySystemFlag rdf:type rdf:Property ;
    rdfs:label 'Placed By System Flag' ;
    rdfs:comment 'Indicates whether the hold was automatically triggered by system rules (true) or manually applied by a user (false).' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Related Document Number' ;
    rdfs:comment 'Reference number of related business document that triggered or is associated with the hold. Examples include credit memo number, Return Merchandise Authorization (RMA) number, compliance case ID.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes entered by the user who released the hold, documenting the resolution or approval rationale.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReasonCode rdf:type rdf:Property ;
    rdfs:label 'Release Reason Code' ;
    rdfs:comment 'Code indicating the reason the hold was released. Examples include APPROVED, RESOLVED, OVERRIDE, EXPIRED, CANCELLED.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the hold review process. Determines whether the order proceeds, is cancelled, or requires further action.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP sales organization code associated with the order under hold. Determines approval workflow and business rules.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target resolution time in hours defined for this hold type. Used to calculate Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:OrderHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifMetricId rdf:type rdf:Property ;
    rdfs:label 'Otif Metric Id' ;
    rdfs:comment 'Primary key for otif_metric' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'The actual quantity of units delivered to the customer. Used to calculate in-full compliance and fill rate.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Days' ;
    rdfs:comment 'The number of days between promised and actual delivery date. Negative values indicate early delivery, positive values indicate late delivery, zero indicates on-time.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percent' ;
    rdfs:comment 'The percentage of ordered quantity that was delivered, calculated as (delivered_quantity / ordered_quantity) * 100. Measures in-full performance independent of timing.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'In Full Tolerance Percent' ;
    rdfs:comment 'The acceptable variance percentage for in-full compliance. For example, 5% tolerance means 95-105% of ordered quantity is considered in-full. Retailer-specific parameter.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementLevel rdf:type rdf:Property ;
    rdfs:label 'Measurement Level' ;
    rdfs:comment 'The granularity level at which OTIF is being measured: order (entire order), shipment (individual shipment), line_item (SKU-level), or po (purchase order level). Determines aggregation logic.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order channel: DTC (Direct-to-Consumer e-commerce), wholesale (B2B EDI orders), retail_pos (store point-of-sale), replenishment (automated stock replenishment), or transfer (inter-facility transfer).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Threshold Percent' ;
    rdfs:comment 'The retailer-specific or customer-specific OTIF compliance threshold percentage required for this order. Typically ranges from 85% to 98% depending on retailer SLA agreements.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Flag' ;
    rdfs:comment 'Boolean indicator of whether this OTIF failure triggered a financial penalty or chargeback from the retailer. True=penalty applied, False=no penalty.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for ordered and delivered quantities. EA=Each, CS=Case, PK=Pack, DZ=Dozen, PR=Pair. Standard apparel industry UOM codes.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between ordered and delivered quantity (delivered_quantity - ordered_quantity). Negative values indicate short shipment, positive values indicate over-shipment.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The fiscal or calendar period (e.g., 2024-Q1, 2024-W15, 2024-03) to which this OTIF record is assigned for scorecard reporting. Format varies by retailer requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerCode rdf:type rdf:Property ;
    rdfs:label 'Retailer Code' ;
    rdfs:comment 'Standardized code identifying the wholesale retailer or distribution partner. Used for retailer-specific OTIF threshold application.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause for OTIF failure. Used for trend analysis and corrective action planning. Null if OTIF compliant. [ENUM-REF-CANDIDATE: warehouse_capacity|inventory_shortage|transportation_delay|system_error|supplier_delay|weather|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseNotes rdf:type rdf:Property ;
    rdfs:label 'Root Cause Notes' ;
    rdfs:comment 'Free-text field capturing detailed explanation of the root cause for OTIF failure. Used for continuous improvement and dispute resolution. Null if OTIF compliant.' ;
    rdfs:domain ind:OtifMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Order Payment Id' ;
    rdfs:comment 'Unique identifier for the payment record. Primary key for the payment entity.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Installment Plan Id' ;
    rdfs:comment 'Reference identifier for the installment or BNPL plan if applicable. Links to external financing provider or internal installment program. Null for non-installment payments.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstallmentPlan .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Response code from Address Verification Service check. Indicates match status between billing address provided and address on file with card issuer. Used for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (apartment, suite, unit number). Optional field for additional address details.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Date' ;
    rdfs:comment 'Date when a chargeback was initiated by the cardholder or issuing bank. Null if no chargeback has occurred. Used for dispute management and financial reconciliation.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'Standardized reason code provided by card network for the chargeback. Used to categorize disputes and identify root causes for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Response Code' ;
    rdfs:comment 'Response code from CVV/CVC verification check. Indicates whether the card security code provided matches the issuer records. Used for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayName rdf:type rdf:Property ;
    rdfs:label 'Gateway Name' ;
    rdfs:comment 'Name of the payment gateway or payment service provider that processed the transaction. Examples include Stripe, Adyen, PayPal, Authorize.Net, or internal payment systems.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequential number of this installment payment within the plan. For example, 1 for first payment, 2 for second payment. Null for non-installment payments.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Installment Plan Flag' ;
    rdfs:comment 'Indicates whether this payment is part of an installment or Buy Now Pay Later (BNPL) plan. True if installment plan is active, false otherwise.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalInstallments rdf:type rdf:Property ;
    rdfs:label 'Total Installments' ;
    rdfs:comment 'Total number of installments in the payment plan. Used to calculate payment schedule and remaining balance. Null for non-installment payments.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOrderWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Warehouse Location Id' ;
    rdfs:comment 'Reference to the vendor facility or origin location from which goods will ship. Used for logistics planning and landed cost calculation.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Vendor-confirmed delivery date. May differ from requested date based on vendor capacity and lead time. Nullable until vendor acknowledgment received.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediAcknowledgmentReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Acknowledgment Received Flag' ;
    rdfs:comment 'Indicates whether vendor has sent EDI 855 Purchase Order Acknowledgment confirming receipt and acceptance of the PO. True if acknowledgment received, False if pending or not applicable.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Flag' ;
    rdfs:comment 'Indicates whether this purchase order was transmitted to vendor via EDI (True) or through manual/email channel (False). Used for process automation tracking.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fobTerms rdf:type rdf:Property ;
    rdfs:label 'Fob Terms' ;
    rdfs:comment 'Specific FOB terms detailing the point at which ownership and risk transfer from vendor to buyer. May include location details beyond standard Incoterms.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcReference rdf:type rdf:Property ;
    rdfs:label 'Lc Reference' ;
    rdfs:comment 'Reference number for letter of credit securing payment for this purchase order. Used for international trade finance. Nullable for domestic or non-LC transactions.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether this purchase order meets the vendor\'s minimum order quantity requirements. True if compliant, False if exception was granted.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Target Flag' ;
    rdfs:comment 'Indicates whether this purchase order met OTIF performance targets. True if delivered on or before confirmed_delivery_date with full quantity, False otherwise. Nullable until delivery complete.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date the purchase order was issued to the vendor. Principal business event timestamp for the transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks progression from draft through vendor acknowledgment, production, shipment, receipt, and closure. Cancelled indicates order was terminated before completion. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|in_production|shipped|received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order by business purpose: replenishment (NOS restocking, VMI, min-max), wholesale (bulk buying for resale), drop-ship (direct-to-customer fulfillment), demand-driven (responsive to actual demand signal), consignment (vendor-owned inventory), or sample (pre-production or marketing samples).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Urgency classification for this purchase order. Rush and critical orders may incur premium freight or vendor surcharges. Used for vendor capacity allocation and logistics planning.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the buyer or buying team responsible for this PO. Used for workload distribution and performance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Code identifying the organizational unit responsible for procurement. May represent centralized or decentralized buying structure.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLandedCost rdf:type rdf:Property ;
    rdfs:label 'Total Landed Cost' ;
    rdfs:comment 'Total cost to land goods at destination including PO value, taxes, freight, duties, and other charges. Used for inventory valuation and profitability analysis. Expressed in currency_code.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before taxes and freight. Expressed in currency_code.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the primary vendor contact for this purchase order. Business-confidential organizational contact data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the primary vendor contact person for this purchase order. Used for order coordination and issue resolution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center to which this line item expense is allocated. Used for internal cost accounting and departmental budgeting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineCategory rdf:type rdf:Property ;
    rdfs:label 'Line Category' ;
    rdfs:comment 'Classification of the purchase order line type. Determines procurement process and inventory handling. Values: standard (normal purchase), consignment (supplier-owned inventory), subcontracting (CMT with buyer-supplied materials), stock_transfer (inter-company transfer).' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or special instructions for this line item. May include packing requirements, labeling instructions, or quality specifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value for this line. Calculated as ordered quantity multiplied by unit cost.' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Textual description of the material or product being ordered. Includes style, color, size, and fabric details.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received. Calculated as confirmed quantity minus received quantity. Used for backorder tracking.' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether this line item requires quality inspection upon receipt. True triggers QC workflow in WMS before stock availability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerContactId rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Wholesale quote preparation targets specific buyer contacts at accounts. Eliminates denormalized contact fields, enables contact-level quote tracking and sales performance analysis by contact relation' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:previousQuoteId rdf:type rdf:Property ;
    rdfs:label 'Previous Quote Id' ;
    rdfs:comment 'Reference to the prior version of this quote if it has been revised. Enables revision history tracking and audit trail.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:buyerApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Date' ;
    rdfs:comment 'Date when the wholesale buyer approved or rejected the quote. Key milestone in the pre-season booking cycle.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyerApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Notes' ;
    rdfs:comment 'Comments or conditions provided by the buyer regarding their approval decision. Captures negotiation details and special requests.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Buyer Approval Status' ;
    rdfs:comment 'Wholesale buyer decision status on the quote. Tracks whether the buyer has accepted, rejected, or conditionally approved the quoted assortment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedToOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Converted To Order Flag' ;
    rdfs:comment 'Indicates whether this quote has been converted to a confirmed sales order. True when the quote transitions to a firm Electronic Data Interchange (EDI) 850 purchase order.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'Latest date in the delivery window for the quoted seasonal merchandise. Defines the fulfillment timeframe for the wholesale order.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'Earliest date in the delivery window for the quoted seasonal merchandise. Part of the Time and Action (TNA) calendar critical to apparel wholesale.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketEventDate rdf:type rdf:Property ;
    rdfs:label 'Market Event Date' ;
    rdfs:comment 'Date of the market week or trade show event associated with this quote. Used for tracking seasonal booking cycles.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketEventName rdf:type rdf:Property ;
    rdfs:label 'Market Event Name' ;
    rdfs:comment 'Name of the market week or trade show event where this quote was presented to the buyer. Examples include MAGIC Las Vegas, Coterie New York.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing method used for the quote. Free On Board (FOB) is standard in apparel wholesale; Landed Duty Paid (LDP) includes all import costs.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date when the quote was created and presented to the wholesale buyer. Principal business event timestamp for the quote lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Business-facing unique quote number used in communications with wholesale buyers during market week and trade shows. Externally visible identifier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the quote in the pre-season booking workflow. Tracks progression from draft through buyer approval to order conversion. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|expired|converted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quote Timestamp' ;
    rdfs:comment 'Precise timestamp when the quote was generated, including time zone information for global wholesale operations.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on the business context and sales channel. Distinguishes seasonal wholesale bookings from special orders.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date after which the quote expires and pricing is no longer guaranteed. Critical for managing seasonal booking windows.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the quote pricing and terms become valid. Defines the beginning of the quote acceptance window.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rmaCustomerServiceRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rma Customer Service Rep Employee Id' ;
    rdfs:comment 'Reference to the customer service representative who processed the RMA request.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rmaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rma Employee Id' ;
    rdfs:comment 'Reference to the warehouse employee or quality control inspector who assessed the returned merchandise condition.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rmaExchangeOrderSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Exchange Order Sales Order Id' ;
    rdfs:comment 'Reference to the new order created if the disposition type is exchange.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:rmaSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order that this RMA is associated with.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued in the financial system for this return.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'Action taken on the return: full refund, exchange for different item, store credit issued, repair and return, or rejection of return.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes recorded by the inspector during the condition assessment of returned merchandise.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectCode rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Code' ;
    rdfs:comment 'Standardized code identifying the specific quality defect found during inspection, if applicable.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the customer or wholesale partner initiated the return request.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Assessment of the physical condition of returned merchandise upon inspection: new/unused, opened but unused, lightly used, damaged, defective, or missing parts.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelType rdf:type rdf:Property ;
    rdfs:label 'Return Label Type' ;
    rdfs:comment 'Indicates who paid for the return shipping label: prepaid by retailer, paid by customer, or paid by vendor.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA: requested, approved, rejected, in transit, received at warehouse, inspected, completed, or cancelled. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Unique identifier for the RMA line item. Primary key for the RMA line entity.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'The action to be taken with the returned merchandise. RESTOCK=return to sellable inventory, DESTROY=dispose of item, RTV=Return to Vendor, LIQUIDATE=sell through secondary channel, REPAIR=send for refurbishment, DONATE=charitable donation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned item. PASS=item meets restocking criteria, FAIL=item does not meet criteria, PENDING=inspection in progress, NOT_INSPECTED=inspection not yet performed.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Line Refund Amount' ;
    rdfs:comment 'Total refund amount for this line item, calculated as quantity returned multiplied by unit refund amount, minus any restocking fees or adjustments.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'The original unit price paid by the customer at the time of purchase. Used for refund calculation and variance analysis.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'The number of units of this SKU being returned by the customer. Used for inventory reconciliation and refund calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingBinLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Bin Location' ;
    rdfs:comment 'Specific bin or staging location within the warehouse where the returned item is physically stored pending disposition. Enables precise inventory tracking.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Timestamp when the refund for this line item was successfully processed and issued to the customer. Used for SLA tracking and customer communication.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Refund Amount' ;
    rdfs:comment 'The refund amount per unit for this SKU. May differ from original unit price due to promotions, discounts, or partial refund policies.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorRmaNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Rma Number' ;
    rdfs:comment 'RMA number issued by the vendor for items being returned to vendor (RTV). Used for tracking vendor returns and processing vendor credits.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or distribution center where the returned item was received and inspected. Used for inventory tracking and logistics.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer-provided purchase order number for wholesale and B2B orders. Required for EDI (Electronic Data Interchange) orders and accounts payable matching. Null for DTC (Direct-to-Consumer) orders.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Product division or category for the order. Used for business unit reporting and merchandise planning. Represents the primary product line of the order. [ENUM-REF-CANDIDATE: mens|womens|kids|accessories|footwear|athletic|lifestyle — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The date when the sales order was placed by the customer. Represents the business event timestamp for order creation. Used for sales reporting, trend analysis, and OTIF (On Time In Full) tracking.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Order Source System' ;
    rdfs:comment 'Operational system of record where the order was originally created. SAP S/4HANA SD handles wholesale and B2B orders, Salesforce Commerce Cloud manages DTC e-commerce, SAP CAR (Customer Activity Repository) captures retail POS transactions, Oracle Retail handles store operations.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTime rdf:type rdf:Property ;
    rdfs:label 'Order Time' ;
    rdfs:comment 'Precise timestamp when the order was placed, including time zone. Used for order sequencing, fulfillment prioritization, and customer service.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'Sales organization code responsible for this order. Represents the legal entity or business unit that owns the customer relationship and revenue. Used for financial reporting and commission calculation.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Delivery method selected for the order. Standard is regular ground shipping, express is expedited delivery, overnight is next-day, two-day is second-day, ground is economy shipping, freight is for large wholesale orders, pickup is for BOPIS (Buy Online Pickup In Store). [ENUM-REF-CANDIDATE: standard|express|overnight|two_day|ground|freight|pickup — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmed Flag' ;
    rdfs:comment 'Indicates whether this line item has been confirmed against available inventory through ATP check. True if inventory is reserved, false if pending or backordered.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelDate rdf:type rdf:Property ;
    rdfs:label 'Cancel Date' ;
    rdfs:comment 'The date on which this line item was cancelled. Populated only for cancelled lines. Used for order cancellation analysis.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'The date on which the business has confirmed it can ship this line item. May differ from requested date based on ATP availability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'The standard or actual cost of the goods sold on this line item. Used for margin calculation and profitability analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which this order line was captured. Enables channel-specific analytics and fulfillment routing.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Business-readable product identifier or style number for the item ordered. Used for display and reporting purposes.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name or description of the product ordered on this line. Includes style name and key attributes for business user recognition.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBackordered rdf:type rdf:Property ;
    rdfs:label 'Quantity Backordered' ;
    rdfs:comment 'The quantity of units on backorder due to insufficient inventory at time of order processing. Awaiting future stock availability.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'The quantity of units cancelled from this line item, either by customer request or due to inability to fulfill.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Quantity Confirmed' ;
    rdfs:comment 'The quantity of units confirmed for fulfillment after ATP (Available to Promise) check. May differ from quantity ordered due to inventory constraints.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'The actual quantity of units shipped to the customer for this line item. Updated as shipments are processed.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key for the BOM product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically assigned by the PLM system. Used for external communication with suppliers and factories.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM indicating its approval state and readiness for production use.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use case: engineering BOM for design, manufacturing BOM for production, costing BOM for financial analysis, or planning BOM for procurement.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmtCost rdf:type rdf:Property ;
    rdfs:label 'Cmt Cost' ;
    rdfs:comment 'Total labor and manufacturing cost charged by the factory for cutting, making, and trimming the garment. Does not include material costs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Approval Status' ;
    rdfs:comment 'Approval status of the cost buildup by finance or merchandising teams. Approved costs are used for margin analysis and pricing decisions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Cost Approved Date' ;
    rdfs:comment 'Date when the cost buildup was approved. Used for audit trail and version control.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'Version identifier for the cost buildup to track changes in costing assumptions, material prices, or factory quotes over time.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingStage rdf:type rdf:Property ;
    rdfs:label 'Costing Stage' ;
    rdfs:comment 'Stage of the costing process indicating the maturity and accuracy of cost data: initial estimate during design, preliminary costing after sampling, final costing before production, or actual costing post-production.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutCost rdf:type rdf:Property ;
    rdfs:label 'Cut Cost' ;
    rdfs:comment 'Labor cost component for cutting fabric and materials. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRate rdf:type rdf:Property ;
    rdfs:label 'Duty Rate' ;
    rdfs:comment 'Import duty rate percentage applied to the product based on its HS Code and country of origin. Used to calculate duty cost.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Content Percentage' ;
    rdfs:comment 'Detailed breakdown of fabric composition by material type and percentage (e.g., 60% Cotton, 40% Polyester). Required for FTC labeling compliance and OEKO-TEX certification.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makeCost rdf:type rdf:Property ;
    rdfs:label 'Make Cost' ;
    rdfs:comment 'Labor cost component for sewing and assembling the garment. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFabricType rdf:type rdf:Property ;
    rdfs:label 'Primary Fabric Type' ;
    rdfs:comment 'Dominant fabric material used in the product (e.g., Cotton, Polyester, Wool, Silk, Nylon). Used for merchandising classification and sustainability reporting.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCogs rdf:type rdf:Property ;
    rdfs:label 'Target Cogs' ;
    rdfs:comment 'Target cost of goods sold set during product development to achieve desired margin objectives. Used as a benchmark against actual LDP cost.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Sum of all raw material, fabric, trim, and component costs required to manufacture one unit of the product. Expressed in the costing currency.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimCost rdf:type rdf:Property ;
    rdfs:label 'Trim Cost' ;
    rdfs:comment 'Labor cost component for finishing, trimming, and quality inspection. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOM line. Tracks whether the line is active for production, pending approval, or has been obsoleted or superseded by a newer version.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Textual explanation for why this BOM line was added, modified, or inactivated. Supports change management and audit trail for BOM revisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this BOM line calculated as quantity per unit multiplied by unit cost. Represents the material cost contribution to one finished unit.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Flag indicating whether this material is on the critical path for production. True if delays in this material would delay the entire production schedule.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSustainable rdf:type rdf:Property ;
    rdfs:label 'Is Sustainable' ;
    rdfs:comment 'Flag indicating whether the material meets sustainability criteria such as organic, recycled, or certified sustainable sourcing.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDescription rdf:type rdf:Property ;
    rdfs:label 'Placement Description' ;
    rdfs:comment 'Textual description of where the material is used or placed on the garment. Examples: front panel, back yoke, sleeve cuff, center front zipper, care label at side seam.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Unit' ;
    rdfs:comment 'Amount of material required to produce one finished unit of the parent product. Critical for material planning, costing, and procurement calculations.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedSubstanceTested rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Tested' ;
    rdfs:comment 'Flag indicating whether the material has been tested for restricted substances per OEKO-TEX or similar standards. Critical for product safety and regulatory compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Size Specification' ;
    rdfs:comment 'Size or dimension specification for the material component. Examples: button diameter, zipper length, label dimensions.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Reference' ;
    rdfs:comment 'Supplier\'s own material code or reference number. Used for cross-referencing with vendor catalogs and purchase orders.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastePercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Percentage' ;
    rdfs:comment 'Expected material waste or scrap percentage during manufacturing. Used to adjust material requirements for procurement and yield planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageUnitRetail rdf:type rdf:Property ;
    rdfs:label 'Average Unit Retail' ;
    rdfs:comment 'Average retail price per unit across all SKUs in the collection. Confidential pricing information.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of external partner or designer for collaboration collections (e.g., celebrity, artist, brand partnership).' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the collection: Planning (concept phase), Design (creative development), Development (pre-production), Commercialized (ready for market), Active (in-market), Closed (end of lifecycle), or Cancelled. [ENUM-REF-CANDIDATE: PLANNING|DESIGN|DEVELOPMENT|COMMERCIALIZED|ACTIVE|CLOSED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDirectionNotes rdf:type rdf:Property ;
    rdfs:label 'Creative Direction Notes' ;
    rdfs:comment 'Detailed creative direction, design inspiration, and aesthetic guidance for the collection. Confidential business information.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Date when the collection is planned to be discontinued or phased out from active selling.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandisingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Merchandising System Code' ;
    rdfs:comment 'Unique identifier for the collection in the Oracle Retail Merchandising System.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Planned date for the collection to be available for sale or distribution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Planning System Code' ;
    rdfs:comment 'Unique identifier for the collection in the Anaplan merchandise planning system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Plm System Code' ;
    rdfs:comment 'Unique identifier for the collection in the source PLM system (Centric PLM or Infor PLM).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationType rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Type' ;
    rdfs:comment 'Type of sustainability certification achieved by the collection (e.g., GOTS, OEKO-TEX, BCI, Bluesign, Cradle to Cradle, Fair Trade, Organic Content, Recycled Content). [ENUM-REF-CANDIDATE: GOTS|OEKO-TEX|BCI|BLUESIGN|CRADLE_TO_CRADLE|FAIR_TRADE|ORGANIC_CONTENT|RECYCLED_CONTENT — promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Primary sales channel for which the collection is designed: Direct-to-Consumer (DTC), Wholesale, Retail, E-Commerce, Outlet, or Department Store.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStyleCount rdf:type rdf:Property ;
    rdfs:label 'Total Style Count' ;
    rdfs:comment 'Total number of unique styles included in the collection.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorFamily rdf:type rdf:Property ;
    rdfs:label 'Color Family' ;
    rdfs:comment 'The broad color family or category that the colorway belongs to, used for filtering and search in e-commerce and merchandising systems. [ENUM-REF-CANDIDATE: red|blue|green|yellow|orange|purple|pink|brown|black|white|gray|multi — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStandard rdf:type rdf:Property ;
    rdfs:label 'Color Standard' ;
    rdfs:comment 'The color standard system used to define the colorway (e.g., Pantone, Natural Color System (NCS), RAL, CMYK, RGB, HEX).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date when the colorway was discontinued or removed from active production. Null if the colorway is still active.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Description' ;
    rdfs:comment 'Details about the exclusivity arrangement, such as the specific retailer, channel, or region where the colorway is exclusively available.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishType rdf:type rdf:Property ;
    rdfs:label 'Finish Type' ;
    rdfs:comment 'The surface finish or texture applied to the colorway (e.g., matte, glossy, metallic, satin). Relevant for footwear, accessories, and certain apparel categories.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'The URL or file path to the primary product image for this colorway, used in e-commerce, Point of Sale (POS), and marketing materials.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLimitedEdition rdf:type rdf:Property ;
    rdfs:label 'Is Limited Edition' ;
    rdfs:comment 'Indicates whether the colorway is a limited edition release with restricted production quantities. True for limited editions, False for standard releases.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oracleRetailItemCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Retail Item Code' ;
    rdfs:comment 'The unique identifier for this colorway in Oracle Retail Merchandising System. Used for integration with merchandising, allocation, and pricing modules.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pantoneCode rdf:type rdf:Property ;
    rdfs:label 'Pantone Code' ;
    rdfs:comment 'The Pantone Matching System (PMS) code for the primary color, used for precise color matching in manufacturing and printing.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColor rdf:type rdf:Property ;
    rdfs:label 'Primary Color' ;
    rdfs:comment 'The dominant color of the colorway. This is the main color that defines the visual appearance of the product.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printPattern rdf:type rdf:Property ;
    rdfs:label 'Print Pattern' ;
    rdfs:comment 'Description of any print or pattern applied to the colorway (e.g., \'Floral\', \'Geometric\', \'Camouflage\', \'Solid\'). Null for solid colors without patterns.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryColor rdf:type rdf:Property ;
    rdfs:label 'Secondary Color' ;
    rdfs:comment 'The secondary or accent color of the colorway, if applicable. May be null for single-color colorways.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swatchImageUrl rdf:type rdf:Property ;
    rdfs:label 'Swatch Image Url' ;
    rdfs:comment 'The URL or file path to the color swatch image for this colorway, used for color selection in e-commerce and merchandising tools.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryColor rdf:type rdf:Property ;
    rdfs:label 'Tertiary Color' ;
    rdfs:comment 'The third accent color of the colorway, if applicable. Used for multi-color designs.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSheetId rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Id' ;
    rdfs:comment 'Unique identifier for the cost sheet record. Primary key.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCogs rdf:type rdf:Property ;
    rdfs:label 'Actual Cogs' ;
    rdfs:comment 'Actual Cost of Goods Sold realized after production and delivery, used for financial reporting and variance analysis.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSheetNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Number' ;
    rdfs:comment 'Business identifier or document number for the cost sheet, used for external reference and tracking.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSheetStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Status' ;
    rdfs:comment 'Current approval and workflow status of the cost sheet within the PLM and costing approval process.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricCost rdf:type rdf:Property ;
    rdfs:label 'Fabric Cost' ;
    rdfs:comment 'Cost of fabric materials used in the garment or product, subset of total material cost.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Direct labor cost for manufacturing operations, may overlap with or be part of CMT cost depending on costing methodology.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Total cost of all raw materials including fabrics, trims, accessories, and packaging materials used in the product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'Manufacturing overhead and indirect costs allocated to the product including factory utilities, supervision, and facility costs.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Cost of packaging materials including polybags, hangtags, cartons, and shipping materials.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bciCertified rdf:type rdf:Property ;
    rdfs:label 'Bci Certified' ;
    rdfs:comment 'Indicates whether the cotton content is sourced through Better Cotton Initiative. True if certified, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Cost Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the standard cost (meter, yard, kilogram, piece, roll, unit).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cottonPercentage rdf:type rdf:Property ;
    rdfs:label 'Cotton Percentage' ;
    rdfs:comment 'Percentage of cotton fiber in the material composition. Used for sustainability reporting and sourcing decisions.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material record was first created in the system. Used for audit trail and material lifecycle tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishTreatment rdf:type rdf:Property ;
    rdfs:label 'Finish Treatment' ;
    rdfs:comment 'Description of any chemical or mechanical finish applied to the material (e.g., \'Water Repellent\', \'Anti-Microbial\', \'Enzyme Wash\', \'Brushed\', \'Calendered\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gotsCertified rdf:type rdf:Property ;
    rdfs:label 'Gots Certified' ;
    rdfs:comment 'Indicates whether the material is certified under Global Organic Textile Standard. True if certified, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level grouping of the material for procurement and inventory purposes (fabric, trim, accessory, component, packaging).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the material used across PLM, sourcing, and manufacturing systems. Business identifier for material lookup and BOM references.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name of the material (e.g., \'Organic Cotton Jersey\', \'Italian Leather\', \'YKK Zipper\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material (active, inactive, discontinued, pending_approval, restricted, obsolete). Controls availability for new product development and sourcing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material by construction or category (woven fabric, knit fabric, leather, synthetic, trim, hardware, packaging, label, thread, elastic). [ENUM-REF-CANDIDATE: woven|knit|leather|synthetic|trim|hardware|packaging|label|thread|elastic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for this material. Critical for procurement planning and cost optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyesterPercentage rdf:type rdf:Property ;
    rdfs:label 'Polyester Percentage' ;
    rdfs:comment 'Percentage of polyester fiber in the material composition. Tracked for performance characteristics and sustainability metrics.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedSubstanceCompliant rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Compliant' ;
    rdfs:comment 'Indicates whether the material complies with restricted substance lists (e.g., REACH, California Prop 65, CPSIA). True if compliant, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the material to maintain quality (e.g., \'Store in cool, dry place\', \'Avoid direct sunlight\', \'Temperature controlled\').' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Code' ;
    rdfs:comment 'Material code or reference number used by the supplier. Facilitates cross-referencing and order accuracy.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference number or identifier for quality and compliance test reports (e.g., lab test reports, certification documents). Links to external document management systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGsm rdf:type rdf:Property ;
    rdfs:label 'Weight Gsm' ;
    rdfs:comment 'Weight of the material measured in grams per square meter. Key specification for fabric performance, drape, and costing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpPriceId rdf:type rdf:Property ;
    rdfs:label 'Msrp Price Id' ;
    rdfs:comment 'Unique identifier for the MSRP price record. Primary key for the MSRP price entity.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorBenchmarkPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Benchmark Price' ;
    rdfs:comment 'Reference price from competitor analysis used to inform MSRP positioning. Supports competitive pricing strategy and market positioning.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Basis' ;
    rdfs:comment 'The cost of goods sold (COGS) or landed cost used as the basis for calculating the initial markup percentage. Business-confidential financial data.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Three-letter ISO country code representing the market or region where this MSRP applies (e.g., USA, CAN, GBR, DEU, CHN).' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Advertised Price' ;
    rdfs:comment 'The minimum price at which retailers are allowed to advertise this product. Used to protect brand positioning and prevent price erosion in wholesale channels.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Amount' ;
    rdfs:comment 'The suggested retail price amount set by the manufacturer for this SKU or style in the specified market and currency. This is the recommended selling price to consumers.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePointStrategy rdf:type rdf:Property ;
    rdfs:label 'Price Point Strategy' ;
    rdfs:comment 'The pricing strategy classification for this MSRP: penetration (low to gain share), premium (high for exclusivity), competitive (market-aligned), value (cost-plus), or psychological (charm pricing).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceZone rdf:type rdf:Property ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Geographic or market-based pricing zone code used for regional price differentiation within a country or market. Supports localized pricing strategies.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedMarkdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Recommended Markdown Percentage' ;
    rdfs:comment 'Suggested markdown percentage for promotional or clearance pricing. Used for planning maintained markup (MMU) and sell-through rate (STR) targets.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Inclusive Flag' ;
    rdfs:comment 'Indicates whether the MSRP amount includes VAT or other consumption taxes. True if tax-inclusive, false if tax-exclusive.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the immediate parent category in the merchandise hierarchy. Null for top-level divisions.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the category within the merchandising hierarchy. Used as business key across Oracle Retail, PLM, and e-commerce systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the product category including scope, product types included, and merchandising guidelines.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the product category as displayed in merchandising, e-commerce, and reporting systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category. Inactive categories are excluded from new product assignments and assortment planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the product category by major product type. Aligns with design and sourcing organizational structure.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPaletteStrategy rdf:type rdf:Property ;
    rdfs:label 'Color Palette Strategy' ;
    rdfs:comment 'Color assortment strategy for this category. Core colors are year-round; seasonal and trend colors change by collection.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginPrimary rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Primary' ;
    rdfs:comment 'Primary country of origin for products in this category (ISO 3166-1 alpha-3 code). Influences sourcing strategy and compliance labeling.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percent' ;
    rdfs:comment 'Average import duty rate percentage for products in this category. Used for LDP (Landed Duty Paid) cost calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecommerceDisplaySequence rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Display Sequence' ;
    rdfs:comment 'Sort order for displaying this category in e-commerce navigation menus and product listing pages.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftcLabelingRequired rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Required' ;
    rdfs:comment 'Indicates whether products in this category require FTC textile and apparel labeling (fiber content, country of origin, care instructions).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Primary gender segmentation for this category. Used for assortment planning, allocation, and merchandising strategy. [ENUM-REF-CANDIDATE: mens|womens|unisex|boys|girls|infant|toddler — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensed rdf:type rdf:Property ;
    rdfs:label 'Is Licensed' ;
    rdfs:comment 'Indicates whether products in this category require licensing agreements (e.g., sports leagues, entertainment properties).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWebVisible rdf:type rdf:Property ;
    rdfs:label 'Is Web Visible' ;
    rdfs:comment 'Indicates whether this category is visible on e-commerce storefronts. Inactive or wholesale-only categories may be hidden from web.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Target Percent' ;
    rdfs:comment 'Target gross margin percentage for products within this category. Used for pricing strategy and financial planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Markdown Risk Level' ;
    rdfs:comment 'Historical markdown risk classification based on sell-through rate (STR) and inventory turnover patterns. Influences OTB (Open-to-Buy) planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleRetailCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Retail Category Code' ;
    rdfs:comment 'External category identifier from Oracle Retail Merchandising System. Used for system integration and data synchronization.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Strategic product line classification indicating brand positioning and target market segment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Inventory replenishment approach for this category. NOS (Never Out of Stock) applies to core basics; fashion items use allocation-driven strategies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleType rdf:type rdf:Property ;
    rdfs:label 'Size Scale Type' ;
    rdfs:comment 'Standard sizing system used for products in this category: numeric (2-16), alpha (XS-XXL), footwear (US/EU/UK), one-size, or custom.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Samples are assigned to specific employees (designers, tech designers, merchandisers) for fit evaluation, quality approval, and wash testing. Assigned_to field exists but needs FK for workload managem' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:techPackId rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Id' ;
    rdfs:comment 'Foreign key linking to product.tech_pack. Business justification: Product sample has tech_pack_version (STRING) which should be normalized to a FK to tech_pack.tech_pack_id. Samples are produced according to a specific tech pack version for fit and construction vali' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechPack .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost incurred to produce this sample, including materials, labor, and shipping.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitComments rdf:type rdf:Property ;
    rdfs:label 'Fit Comments' ;
    rdfs:comment 'Detailed feedback and observations from the fit evaluation session, including specific adjustments needed.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitEvaluationResult rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Result' ;
    rdfs:comment 'Outcome of the fit evaluation process for fit samples, determining if the sample meets graded measurement specifications.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iterationNumber rdf:type rdf:Property ;
    rdfs:label 'Iteration Number' ;
    rdfs:comment 'Sequential iteration number tracking how many times this sample has been revised or resubmitted (e.g., 1st sample, 2nd sample, 3rd sample).' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementChestCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Chest Cm' ;
    rdfs:comment 'Graded measurement specification for chest circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementHipCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Hip Cm' ;
    rdfs:comment 'Graded measurement specification for hip circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementLengthCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Length Cm' ;
    rdfs:comment 'Graded measurement specification for garment length in centimeters (e.g., center back length, inseam), critical for fit evaluation.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWaistCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Waist Cm' ;
    rdfs:comment 'Graded measurement specification for waist circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'URL or file path to digital photographs of the sample for visual reference and documentation.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefects rdf:type rdf:Property ;
    rdfs:label 'Quality Defects' ;
    rdfs:comment 'Detailed description of any quality defects identified during inspection, including severity and location.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Outcome of the quality inspection process evaluating construction, stitching, finishing, and overall workmanship.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Unique business identifier for the sample used across PLM and production systems.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample based on its purpose in the design-to-production lifecycle. Proto samples are initial design prototypes, fit samples are used for fit evaluation, salesman samples are for sales presentations, production samples validate final manufacturing, pre-production samples (PP) verify production readiness, and SMS (Sample Management System) samples are tracked through the sample management system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the sample was submitted for review and approval.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Expected date for sample delivery based on TNA (Time and Action) calendar milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:washTestCompleted rdf:type rdf:Property ;
    rdfs:label 'Wash Test Completed' ;
    rdfs:comment 'Indicates whether the sample has undergone wash testing to evaluate colorfastness, shrinkage, and durability.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washTestResult rdf:type rdf:Property ;
    rdfs:label 'Wash Test Result' ;
    rdfs:comment 'Outcome of wash testing evaluation for colorfastness, shrinkage, and fabric integrity.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGrams rdf:type rdf:Property ;
    rdfs:label 'Weight Grams' ;
    rdfs:comment 'Physical weight of the sample garment in grams, used for shipping calculations and product specifications.' ;
    rdfs:domain ind:ProductSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandApplicability rdf:type rdf:Property ;
    rdfs:label 'Brand Applicability' ;
    rdfs:comment 'Comma-separated list of brand codes or names this size scale is applicable to. Allows for brand-specific sizing standards (e.g., luxury brands may use different scales than athletic brands).' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTableReference rdf:type rdf:Property ;
    rdfs:label 'Conversion Table Reference' ;
    rdfs:comment 'Reference identifier or URL to the size conversion table that maps this scale to other regional or brand scales. Enables cross-market size normalization.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultForCategory rdf:type rdf:Property ;
    rdfs:label 'Default For Category' ;
    rdfs:comment 'Indicates whether this size scale is the default scale for its product category and gender combination. Used to auto-populate size scales during product creation in PLM systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'External identifier for this size scale in the ERP system (SAP S/4HANA). Used for integration with merchandising, allocation, and inventory management modules.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitModelReference rdf:type rdf:Property ;
    rdfs:label 'Fit Model Reference' ;
    rdfs:comment 'Reference identifier to the fit model or body form specifications used to validate this size scale. Links to sample development and fit approval processes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderApplicability rdf:type rdf:Property ;
    rdfs:label 'Gender Applicability' ;
    rdfs:comment 'The gender or demographic segment this size scale is designed for (mens, womens, unisex, boys, girls, infant, toddler). Aligns with product categorization and merchandising hierarchy. [ENUM-REF-CANDIDATE: mens|womens|unisex|boys|girls|infant|toddler — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingRuleReference rdf:type rdf:Property ;
    rdfs:label 'Grading Rule Reference' ;
    rdfs:comment 'Reference identifier to the grading rule set used for pattern grading across sizes in this scale. Links to technical design specifications in PLM systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the size scale: draft (under development), active (in use), deprecated (phasing out), retired (no longer used). Governs availability for new product assignments.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement System' ;
    rdfs:comment 'The regional measurement system or standard used for this size scale (US, EU, UK, JP, CN, AU, KR, INT for International). Determines the sizing convention and labeling standards. [ENUM-REF-CANDIDATE: US|EU|UK|JP|CN|AU|KR|INT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measurement used for size specifications in this scale (inches, centimeters, waist_inseam for bottoms, chest_length for tops, not_applicable for alpha or one-size scales).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalMarket rdf:type rdf:Property ;
    rdfs:label 'Regional Market' ;
    rdfs:comment 'Comma-separated list of 3-letter ISO country codes where this size scale is used (e.g., USA,CAN,MEX for North America). Enables regional size mapping and localization.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeChartUrl rdf:type rdf:Property ;
    rdfs:label 'Size Chart Url' ;
    rdfs:comment 'URL or file path to the customer-facing size chart document or image for this scale. Used for e-commerce display and customer service reference.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeIncrement rdf:type rdf:Property ;
    rdfs:label 'Size Increment' ;
    rdfs:comment 'The increment or step between consecutive sizes in numeric scales (e.g., 2 for waist sizes 28,30,32,34). Not applicable for alpha scales.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeLabels rdf:type rdf:Property ;
    rdfs:label 'Size Labels' ;
    rdfs:comment 'Ordered comma-separated list of size labels in this scale run (e.g., XS,S,M,L,XL,XXL or 28,30,32,34,36,38,40 or 6,8,10,12,14). Order represents the size progression from smallest to largest.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleCode rdf:type rdf:Property ;
    rdfs:label 'Size Scale Code' ;
    rdfs:comment 'Business identifier code for the size scale (e.g., MENS_TOPS_US, WOMENS_BOTTOMS_EU, FOOTWEAR_UK). Used as the externally-known unique code for this size scale across systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleDescription rdf:type rdf:Property ;
    rdfs:label 'Size Scale Description' ;
    rdfs:comment 'Detailed description of the size scale, including its intended use, product categories, and any special characteristics or measurement guidelines.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleName rdf:type rdf:Property ;
    rdfs:label 'Size Scale Name' ;
    rdfs:comment 'Human-readable name of the size scale (e.g., Men\'s Tops US Standard, Women\'s Bottoms EU, Footwear UK Sizing). Provides clear business context for the size run.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeType rdf:type rdf:Property ;
    rdfs:label 'Size Type' ;
    rdfs:comment 'Classification of the size labeling system: alpha (XS-XXL), numeric (28-40, 6-14), hybrid (combination of alpha and numeric), or one_size. Determines display and conversion logic.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsFlag rdf:type rdf:Property ;
    rdfs:label 'Ats Flag' ;
    rdfs:comment 'Indicates whether the SKU is currently available for sale across channels. Drives e-commerce availability and order promising.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit EAN barcode identifier used for international retail distribution and point-of-sale operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gspEligible rdf:type rdf:Property ;
    rdfs:label 'Gsp Eligible' ;
    rdfs:comment 'Indicates whether the SKU qualifies for GSP duty-free treatment based on country of origin and product classification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment '14-digit global trade item number for supply chain and logistics tracking across international markets.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'The length dimension of the packaged SKU in centimeters. Used for carton planning and warehouse space optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the product into apparel, footwear, or accessories. Drives business rules and fulfillment logic.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagReference rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Reference' ;
    rdfs:comment 'RFID tag identifier for automated inventory tracking, anti-theft, and supply chain visibility. Enables real-time location tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRunPosition rdf:type rdf:Property ;
    rdfs:label 'Size Run Position' ;
    rdfs:comment 'Numeric position of this size within the size curve or size run. Used for allocation and assortment planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU. Controls visibility, ordering, and inventory management across all channels.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'The weight of the SKU in kilograms. Used for shipping cost calculation, freight planning, and logistics optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designOwner rdf:type rdf:Property ;
    rdfs:label 'Design Owner' ;
    rdfs:comment 'Name or identifier of the designer or design team responsible for creating the style. Used for attribution, collaboration tracking, and design portfolio management.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoreStyle rdf:type rdf:Property ;
    rdfs:label 'Is Core Style' ;
    rdfs:comment 'Boolean flag indicating whether this is a core, never-out-of-stock (NOS) style that is continuously replenished. Core styles receive priority in inventory allocation and replenishment planning.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Product safety certifications and compliance standards met by the style. Required for consumer product safety and regulatory compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouette rdf:type rdf:Property ;
    rdfs:label 'Silhouette' ;
    rdfs:comment 'Design silhouette or fit profile of the style (e.g., slim fit, relaxed fit, oversized, tailored). Key attribute for product differentiation and customer preference matching.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleDescription rdf:type rdf:Property ;
    rdfs:label 'Style Description' ;
    rdfs:comment 'Detailed narrative description of the style including design features, aesthetic attributes, and intended use. Used for marketing copy and product catalogs.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleName rdf:type rdf:Property ;
    rdfs:label 'Style Name' ;
    rdfs:comment 'Human-readable marketing name or title of the style. Used in catalogs, e-commerce, and merchandising communications.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackReference rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Reference' ;
    rdfs:comment 'Reference identifier or document link to the technical specification package (tech pack) containing detailed construction, measurements, and manufacturing instructions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitModelProfileId rdf:type rdf:Property ;
    rdfs:label 'Fit Model Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.profile. Business justification: Tech packs specify the fit model (customer profile) used for grading and measurement specifications. Technical designers reference fit model body measurements when creating grade rules. Critical for e' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primaryTechnicalDesignerId rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Designer Id' ;
    rdfs:comment 'FK to design.designer' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Designer .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Foreign key linking to production.routing. Business justification: Tech packs specify manufacturing routing for operation sequences, SAM calculations, and line balancing. Critical for factory issuance and production planning. No existing routing reference on tech_pac' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:baseSize rdf:type rdf:Property ;
    rdfs:label 'Base Size' ;
    rdfs:comment 'The base size from which all grading is calculated. All measurements in this tech pack are specified for the base size, and grade rules define increments for other sizes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDescription rdf:type rdf:Property ;
    rdfs:label 'Construction Description' ;
    rdfs:comment 'Detailed narrative description of garment construction methods, assembly sequence, and structural details. Communicates how the garment is built.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitEvaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Criteria' ;
    rdfs:comment 'Detailed criteria for evaluating fit during sample approval process. Defines acceptable fit characteristics, critical fit points, and pass/fail criteria for fit sessions.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeRules rdf:type rdf:Property ;
    rdfs:label 'Grade Rules' ;
    rdfs:comment 'Grading increment specifications defining how measurements change per size step. Specifies the dimensional increment (positive or negative) for each measurement point as sizes increase or decrease from the base size.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedToFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Issued To Factory Date' ;
    rdfs:comment 'Date on which this tech pack was officially issued to the manufacturing factory. Marks the start of factory production preparation.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirements' ;
    rdfs:comment 'Comprehensive labeling requirements including content labels, care labels, brand labels, size labels, country of origin, and regulatory compliance labels per FTC Textile and Wool Acts.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPoints rdf:type rdf:Property ;
    rdfs:label 'Measurement Points' ;
    rdfs:comment 'Comprehensive list of all measurement points with descriptions and base size values. Includes body measurements (chest, waist, hip, inseam, sleeve length, etc.) and garment measurements (length, width, circumference at key points).' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Detailed notes describing changes made in this version compared to the previous version. Tracks evolution of specifications through the development cycle.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seamAllowanceCm rdf:type rdf:Property ;
    rdfs:label 'Seam Allowance Cm' ;
    rdfs:comment 'Standard seam allowance measurement in centimeters. Defines the fabric margin beyond the seam line for construction.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional special instructions or notes for factory regarding unique construction techniques, quality requirements, or handling procedures.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stitchType rdf:type rdf:Property ;
    rdfs:label 'Stitch Type' ;
    rdfs:comment 'Primary stitch type(s) used in garment construction, using ISO 4915 stitch classification (e.g., 301 lockstitch, 504 overedge, 401 chainstitch).' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackName rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Name' ;
    rdfs:comment 'Human-readable name or title of the tech pack, typically including style name and season reference.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackNumber rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Number' ;
    rdfs:comment 'The externally-known unique business identifier for this tech pack document. Used for communication with factories and internal teams. Managed in Centric PLM.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackStatus rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Status' ;
    rdfs:comment 'Current lifecycle status of the tech pack document. Tracks progression from draft through approval to factory issuance.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaCalendarReference rdf:type rdf:Property ;
    rdfs:label 'Tna Calendar Reference' ;
    rdfs:comment 'Reference identifier linking this tech pack to its Time and Action calendar. TNA calendar tracks all critical milestones from design through production delivery.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceRange rdf:type rdf:Property ;
    rdfs:label 'Tolerance Range' ;
    rdfs:comment 'Acceptable tolerance range for measurements, typically expressed as +/- value. Defines quality acceptance criteria for dimensional accuracy.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTnaCalendarId rdf:type rdf:Property ;
    rdfs:label 'Product Tna Calendar Id' ;
    rdfs:comment 'Unique identifier for the Time and Action calendar entry. Primary key for the T&A calendar product.' ;
    rdfs:domain ind:ProductTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dependencyMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Dependency Milestone Id' ;
    rdfs:comment 'Reference to a predecessor milestone that must be completed before this milestone can begin. Enables critical path analysis and dependency tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:productionTnaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Production Tna Milestone Id' ;
    rdfs:comment 'Reference to the specific milestone definition in the T&A critical path (design review, fabric approval, lab dip approval, PP sample, bulk production start, ex-factory date, in-DC date).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionTnaMilestone .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual date on which this milestone was achieved or completed. Null if milestone is not yet completed. Used to calculate days variance and OTIF performance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bufferDays rdf:type rdf:Property ;
    rdfs:label 'Buffer Days' ;
    rdfs:comment 'Number of buffer or safety days built into the schedule for this milestone to absorb delays without impacting downstream milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysVariance rdf:type rdf:Property ;
    rdfs:label 'Days Variance' ;
    rdfs:comment 'The number of days difference between planned and actual (or forecast) milestone date. Positive values indicate delay, negative values indicate early completion. Critical for OTIF tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to supporting documentation for this milestone such as tech pack version, lab dip approval document, PP sample report, or inspection certificate.' ;
    rdfs:domain ind:ProductTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current status of the milestone in its lifecycle. Enables real-time tracking of production progress and identification of bottlenecks.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Description of the corrective actions or mitigation strategies being implemented to address risks and bring the milestone back on track.' ;
    rdfs:domain ind:ProductTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Impact Flag' ;
    rdfs:comment 'Boolean indicator that delays to this milestone will impact the OTIF delivery commitment to the customer or retail channel. Used for prioritization.' ;
    rdfs:domain ind:ProductTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference or identifier for this T&A calendar entry in the source PLM system (Centric PLM or Infor PLM). Used for system integration and traceability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed description of the risk factors, issues, or blockers affecting this milestone. Provides context for risk mitigation planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Flag' ;
    rdfs:comment 'Boolean indicator that this milestone is at risk of missing its planned date. True when forecast date exceeds planned date by threshold or when status is at_risk or blocked.' ;
    rdfs:domain ind:ProductTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bulkFabricReceiptId rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Receipt Id' ;
    rdfs:comment 'Unique identifier for the bulk fabric receipt record at the CMT factory. Primary key for this entity.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForProductionDate rdf:type rdf:Property ;
    rdfs:label 'Approved For Production Date' ;
    rdfs:comment 'The date on which the fabric was officially approved and released for use in production cutting. Gates the start of cutting operations.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aqlInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Aql Inspection Result' ;
    rdfs:comment 'The outcome of the AQL-based statistical sampling inspection. Indicates whether the fabric lot meets the agreed quality standards.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'The AQL level applied during inspection (e.g., 1.0, 2.5, 4.0). Defines the maximum acceptable defect rate for the fabric lot.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The production batch number assigned by the fabric mill. Enables traceability back to the manufacturing process and raw material sources.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFastnessResult rdf:type rdf:Property ;
    rdfs:label 'Color Fastness Result' ;
    rdfs:comment 'The outcome of the color fastness test, indicating whether the fabric color is resistant to fading or bleeding during washing, rubbing, or light exposure.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'The total number of defects identified during the fabric inspection. Used to calculate defect rate and determine acceptance or rejection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Description of the primary types of defects found during inspection (e.g., holes, stains, weaving flaws, color inconsistency). Supports root cause analysis and supplier feedback.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The originally scheduled delivery date from the purchase order or supplier commitment. Used to calculate delivery performance and OTIF metrics.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'The current status of the quality inspection process for the received fabric. Determines whether the fabric can be released for cutting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'The name of the quality inspector who performed the fabric inspection. Supports accountability and quality audit trails.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which the fabric was physically received at the CMT factory. Gates the earliest possible cut-start date for production scheduling.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for capturing additional notes, observations, or special handling instructions related to the fabric receipt. Supports communication between receiving, quality, and production teams.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollCount rdf:type rdf:Property ;
    rdfs:label 'Roll Count' ;
    rdfs:comment 'The number of fabric rolls received in this shipment. Used for physical inventory verification and warehouse space planning.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shadeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Shade Lot Number' ;
    rdfs:comment 'The dye lot or shade lot number assigned by the mill. Ensures color consistency within a production run, as different lots may have slight color variations.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkagePercentageLength rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Percentage Length' ;
    rdfs:comment 'The measured shrinkage percentage in the length (warp) direction after washing. Used to verify compliance with technical specifications.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkagePercentageWidth rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Percentage Width' ;
    rdfs:comment 'The measured shrinkage percentage in the width (weft) direction after washing. Used to verify compliance with technical specifications.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageTestResult rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Test Result' ;
    rdfs:comment 'The outcome of the fabric shrinkage test, indicating whether the fabric meets the specified shrinkage tolerance after washing. Critical for garment fit and quality.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The warehouse location or bin where the received fabric is stored. Supports efficient material retrieval for cutting operations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOrderId rdf:type rdf:Property ;
    rdfs:label 'Cut Order Id' ;
    rdfs:comment 'Unique identifier for the cut order record. Primary key.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CutOrder .

ind:cuttingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Cutting Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cutting operations track cost centers for fabric utilization efficiency, cutting department cost allocation, and marker efficiency variance analysis—standard in apparel production costing.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:fabricRollId rdf:type rdf:Property ;
    rdfs:label 'Fabric Roll Id' ;
    rdfs:comment 'Reference to the primary fabric roll allocated for this cut order. Links to inventory fabric roll tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricRoll .

ind:markerId rdf:type rdf:Property ;
    rdfs:label 'Marker Id' ;
    rdfs:comment 'Reference to the CAD marker layout used for this cut. The marker defines the pattern piece arrangement on fabric for optimal material utilization.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Marker .

ind:primaryCutEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cut Employee Id' ;
    rdfs:comment 'Reference to the supervisor responsible for overseeing this cut order execution. Links to workforce management system.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCutUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cut Updated By User Employee Id' ;
    rdfs:comment 'Reference to the user who last updated this cut order record. Audit trail for change tracking.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualPanelsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Panels Count' ;
    rdfs:comment 'Actual number of fabric panels cut during execution. Used for yield tracking and quality control.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleTicketGenerated rdf:type rdf:Property ;
    rdfs:label 'Bundle Ticket Generated' ;
    rdfs:comment 'Indicates whether bundle tickets have been generated for the cut panels to track them through sewing operations. True when cut panels are bundled and tagged for downstream workflow.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutDate rdf:type rdf:Property ;
    rdfs:label 'Cut Date' ;
    rdfs:comment 'The date on which the cutting operation was executed. Primary business event timestamp for this cut order.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Cut Efficiency Percentage' ;
    rdfs:comment 'Actual cutting efficiency achieved versus the marker plan, expressed as a percentage. Calculated as (actual fabric consumed / planned fabric consumption) * 100. Key KPI for material utilization and waste reduction.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cut End Timestamp' ;
    rdfs:comment 'Precise timestamp when the cutting operation was completed. Used for cycle time calculation and throughput analysis.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Cut Order Number' ;
    rdfs:comment 'Business identifier for the cut order, externally visible and used for tracking and communication with cut room supervisors and production planners.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cut Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the cutting operation began. Used for cycle time analysis and labor productivity tracking.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutStatus rdf:type rdf:Property ;
    rdfs:label 'Cut Status' ;
    rdfs:comment 'Current lifecycle status of the cut order. Tracks progression through the cutting workflow and gates downstream sewing operations.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuttingMachineCode rdf:type rdf:Property ;
    rdfs:label 'Cutting Machine Code' ;
    rdfs:comment 'Reference to the cutting equipment used (manual table, straight knife, die cutter, laser cutter, automated spreader). Links to equipment asset master.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectNotes rdf:type rdf:Property ;
    rdfs:label 'Defect Notes' ;
    rdfs:comment 'Free-text description of defects encountered during cutting (e.g., fabric flaws, miscuts, pattern misalignment). Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricConsumptionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Per Unit' ;
    rdfs:comment 'Planned fabric consumption per garment unit based on marker efficiency, measured in meters or yards. Used for material costing and yield analysis.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricConsumptionUom rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Uom' ;
    rdfs:comment 'Unit of measure for fabric consumption (meters, yards, or feet).' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Marker Efficiency Percentage' ;
    rdfs:comment 'Theoretical marker efficiency from the CAD marker layout, representing the percentage of fabric utilized in the marker versus waste. Baseline for cut efficiency comparison.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markerReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Marker Reference Code' ;
    rdfs:comment 'External marker code from CAD system used for cross-reference and traceability to the digital marker file.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPanelsCount rdf:type rdf:Property ;
    rdfs:label 'Planned Panels Count' ;
    rdfs:comment 'Number of fabric panels planned to be cut based on the marker layout and order quantity.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plyCount rdf:type rdf:Property ;
    rdfs:label 'Ply Count' ;
    rdfs:comment 'Number of fabric layers (plies) stacked and cut simultaneously in this cut order. Higher ply counts improve efficiency but require precision equipment.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Quality control status for the cut panels. Indicates whether the cut pieces meet quality standards for pattern accuracy, edge finish, and fabric integrity before release to sewing.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCutDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Cut Date' ;
    rdfs:comment 'Originally planned date for the cutting operation based on production scheduling and TNA (Time and Action) calendar.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sizeRatioBreakdown rdf:type rdf:Property ;
    rdfs:label 'Size Ratio Breakdown' ;
    rdfs:comment 'Size distribution for this cut order, typically expressed as ratio notation (e.g., XS:2, S:4, M:6, L:4, XL:2). Defines the quantity of each size to be cut.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFabricAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Fabric Allocated' ;
    rdfs:comment 'Total fabric quantity allocated to this cut order in the specified unit of measure. Represents the material reservation for this cutting operation.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFabricConsumed rdf:type rdf:Property ;
    rdfs:label 'Total Fabric Consumed' ;
    rdfs:comment 'Actual fabric quantity consumed during cutting execution. Captured post-cut for variance analysis and material accounting.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsCut rdf:type rdf:Property ;
    rdfs:label 'Total Units Cut' ;
    rdfs:comment 'Actual number of garment units cut and passed to downstream sewing operations. May differ from planned due to fabric defects or cutting errors.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Units Planned' ;
    rdfs:comment 'Total number of garment units planned to be produced from this cut order across all sizes.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score from the most recent audit, typically on a 0-100 scale. Used for factory performance benchmarking and risk assessment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedCapacityUnitsPerWeek rdf:type rdf:Property ;
    rdfs:label 'Certified Capacity Units Per Week' ;
    rdfs:comment 'Maximum production capacity in units per week as certified by the factory and validated through capacity audits. Used for production planning and allocation decisions.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees working at the factory. Used for capacity assessment, social compliance monitoring, and risk evaluation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilitySizeSqm rdf:type rdf:Property ;
    rdfs:label 'Facility Size Sqm' ;
    rdfs:comment 'Total floor area of the factory in square meters. Used for capacity planning and facility assessment.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryName rdf:type rdf:Property ;
    rdfs:label 'Factory Name' ;
    rdfs:comment 'Common business name of the manufacturing facility as used in operational communications and planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryType rdf:type rdf:Property ;
    rdfs:label 'Factory Type' ;
    rdfs:comment 'Classification of the manufacturing relationship model. CMT (Cut Make Trim) = factory provides labor only; OEM (Original Equipment Manufacturer) = factory manufactures to buyer specs; ODM (Original Design Manufacturer) = factory provides design and manufacturing; INTERNAL = company-owned facility; HYBRID = mixed model; SUBCONTRACTOR = secondary tier supplier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifPerformancePct rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Pct' ;
    rdfs:comment 'Percentage of orders delivered On Time In Full over the trailing 12 months. Key performance indicator for factory reliability and used in allocation decisions.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this factory has preferred vendor status based on performance, quality, compliance, and strategic relationship. Preferred vendors receive priority allocation and longer-term commitments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCapabilities rdf:type rdf:Property ;
    rdfs:label 'Production Capabilities' ;
    rdfs:comment 'Comma-separated list of product categories and manufacturing techniques the factory is equipped to produce (e.g., woven, knit, denim, footwear, accessories, leather goods, outerwear, activewear, swimwear, intimate apparel).' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk classification for the factory based on compliance history, audit findings, geographic risk, and operational stability. Used for sourcing decisions and monitoring frequency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryCapacityId rdf:type rdf:Property ;
    rdfs:label 'Factory Capacity Id' ;
    rdfs:comment 'Unique identifier for the factory capacity planning record.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FactoryCapacity .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Foreign key linking to production.work_center. Business justification: Factory capacity is often planned and tracked at the work center or production line level. The table currently has production_line_id (STRING) but no formal FK to work_center. Adding work_center_id en' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:allocatedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Units' ;
    rdfs:comment 'Production capacity units already allocated to confirmed purchase orders (PO) or work orders during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Units' ;
    rdfs:comment 'Remaining production capacity units available for new bookings, calculated as total capacity minus allocated and reserved capacity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableLaborHours rdf:type rdf:Property ;
    rdfs:label 'Available Labor Hours' ;
    rdfs:comment 'Total labor hours available for production during the planning period, based on workforce headcount and shift schedules.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableMachineHours rdf:type rdf:Property ;
    rdfs:label 'Available Machine Hours' ;
    rdfs:comment 'Total machine hours available for production during the planning period, accounting for scheduled maintenance and downtime.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Booking Cutoff Date' ;
    rdfs:comment 'Last date by which new production orders can be booked for this capacity period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityAllocationPriority rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Priority' ;
    rdfs:comment 'Priority level for capacity allocation, used to manage competing demands from multiple customers or product lines.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBufferPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Buffer Percent' ;
    rdfs:comment 'Safety buffer percentage applied to capacity planning to account for variability, quality issues, or unexpected delays.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Operational status of the factory or production line during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to express production capacity (e.g., pieces, garments, dozens, pairs).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate Percent' ;
    rdfs:comment 'Factory or production line efficiency rate as a percentage, representing actual output versus theoretical maximum capacity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineCount rdf:type rdf:Property ;
    rdfs:label 'Machine Count' ;
    rdfs:comment 'Total number of production machines or equipment units available during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeHoursAvailable rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Available' ;
    rdfs:comment 'Additional overtime hours available for production if needed to meet demand during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Total hours of planned downtime for maintenance, changeovers, or scheduled breaks during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the capacity planning period (weekly or monthly bucket).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the capacity planning period (weekly or monthly bucket).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the capacity planning period (daily, weekly, or monthly).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Reserved Capacity Units' ;
    rdfs:comment 'Production capacity units reserved for specific seasons, collections, or customers but not yet confirmed by purchase order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCount rdf:type rdf:Property ;
    rdfs:label 'Shift Count' ;
    rdfs:comment 'Number of production shifts per day during the planning period (e.g., 1, 2, or 3 shifts).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardMinuteValue rdf:type rdf:Property ;
    rdfs:label 'Standard Minute Value' ;
    rdfs:comment 'Average standard minute value (SMV) per unit for the product mix planned during this capacity period, used for capacity calculation.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Units' ;
    rdfs:comment 'Total production capacity expressed in units (pieces, garments, or SKUs) that can be manufactured during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Capacity utilization rate as a percentage, calculated as allocated capacity divided by total available capacity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of production workers assigned to the factory or production line during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'Number of working days available during the planning period, excluding holidays and factory closures.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Unique identifier for the production lot or batch. Primary key. [ROLE: MASTER_RESOURCE - canonical entity representing a discrete manufacturing run]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Identifier of the manufacturing line or assembly line where this lot was produced.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:cartonRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Carton Range End' ;
    rdfs:comment 'Last carton number in the range of shipping cartons packed from this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonRangeStart rdf:type rdf:Property ;
    rdfs:label 'Carton Range Start' ;
    rdfs:comment 'First carton number in the range of shipping cartons packed from this lot, enabling downstream shipment traceability.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmtType rdf:type rdf:Property ;
    rdfs:label 'Cmt Type' ;
    rdfs:comment 'Manufacturing arrangement type. CMT is cut-make-trim (factory provides labor only); FOB is free-on-board (factory sources materials); CM is cut-and-make (buyer provides fabric); full_package is turnkey production; consignment is buyer-owned materials.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Number' ;
    rdfs:comment 'Certificate number for regulatory compliance documentation (e.g., CPSIA certificate, OEKO-TEX certificate) associated with this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Required' ;
    rdfs:comment 'Indicates whether this lot requires regulatory compliance certification (CPSIA, REACH, CA Prop 65, etc.) before shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical defects (safety hazards, non-compliance issues) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricShadeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Fabric Shade Lot Number' ;
    rdfs:comment 'Shade lot identifier for the bulk fabric used in this production lot, critical for color consistency and traceability.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishingDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Date' ;
    rdfs:comment 'Date when finishing operations (pressing, trimming, packaging) were completed for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the production lot. Open indicates lot is active and receiving production; in_progress indicates manufacturing underway; closed indicates lot is complete; on_hold indicates temporary suspension; cancelled indicates lot was terminated; quarantined indicates quality hold.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the production lot by purpose. Bulk production is main manufacturing run; pre-production sample is PP sample lot; top sample is first production unit; shipment sample is quality check sample; development sample is design validation; reorder is repeat production; rework is defect correction. [ENUM-REF-CANDIDATE: bulk_production|pre_production_sample|top_sample|shipment_sample|development_sample|reorder|rework — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Major Defect Count' ;
    rdfs:comment 'Number of major defects (functional failures, significant appearance issues) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defect Count' ;
    rdfs:comment 'Number of minor defects (cosmetic issues, small workmanship flaws) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target number of units to be produced in this lot as per the work order.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producedQuantity rdf:type rdf:Property ;
    rdfs:label 'Produced Quantity' ;
    rdfs:comment 'Actual number of finished units produced in this lot, including all quality grades.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionEndDate rdf:type rdf:Property ;
    rdfs:label 'Production End Date' ;
    rdfs:comment 'Date when manufacturing of this lot was completed.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Date when manufacturing of this lot commenced at the factory.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Number of units sent for rework or repair to correct defects.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Number of units that were scrapped or discarded due to irreparable defects.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sewEndDate rdf:type rdf:Property ;
    rdfs:label 'Sew End Date' ;
    rdfs:comment 'Date when sewing operations were completed for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewStartDate rdf:type rdf:Property ;
    rdfs:label 'Sew Start Date' ;
    rdfs:comment 'Date when sewing operations began for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Work shift during which this lot was primarily produced (e.g., day, night, A, B, C).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production order confirmation record. Primary key for the goods confirmation transaction.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedConfirmationOrderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Confirmation Order Confirmation Id' ;
    rdfs:comment 'Reference to the original confirmation record that this reversal transaction is cancelling. Creates audit trail for corrections.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderConfirmation .

ind:workOrderOperationId rdf:type rdf:Property ;
    rdfs:label 'Work Order Operation Id' ;
    rdfs:comment 'Reference to the specific operation within the work order routing that this confirmation applies to. Represents a discrete manufacturing step.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderOperation .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Classification of the production activity performed during this operation. Used for activity-based costing and capacity planning.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'The total number of labor hours consumed to complete this operation. Used for labor cost calculation and capacity planning.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineHours rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Hours' ;
    rdfs:comment 'The total number of machine or equipment hours utilized during this operation. Used for equipment utilization analysis and maintenance scheduling.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether component materials were automatically consumed via backflushing when this confirmation was posted. Used for automated material consumption.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The calendar date on which the production activity was completed and confirmed. Represents the actual manufacturing event date.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Business-facing confirmation document number generated by the production system. Used for tracking and audit purposes.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the confirmation record indicating whether it is in draft, submitted for approval, posted to inventory, cancelled, or reversed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Precise date and time when the confirmation transaction was recorded in the system. Used for audit trail and real-time production tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation transaction indicating whether this is a partial completion, final completion, milestone achievement, rework confirmation, or scrap reporting.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConfirmationIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Indicator' ;
    rdfs:comment 'Indicates whether this is the final confirmation for the operation, signaling that no further output is expected and the operation can be closed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsMovementPosted rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Posted' ;
    rdfs:comment 'Indicates whether the confirmed quantities have been posted to inventory through a goods receipt transaction. Links confirmation to inventory update.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The material document number generated when confirmed output was posted to inventory. Used for inventory reconciliation and traceability.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeHours rdf:type rdf:Property ;
    rdfs:label 'Setup Time Hours' ;
    rdfs:comment 'The time spent preparing equipment, tooling, and materials before production could begin. Separate from actual production time.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeHours rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Hours' ;
    rdfs:comment 'The time spent cleaning, resetting, or breaking down equipment after the production operation was completed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text explanation providing additional context about production variances, quality issues, or operational challenges encountered during this confirmation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating the reason for any variance between planned and actual quantities or times. Used for root cause analysis of production inefficiencies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The actual quantity of good output produced and confirmed for this operation. Represents conforming units that passed quality inspection.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppSampleId rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Id' ;
    rdfs:comment 'Unique identifier for the pre-production sample record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpSample .

ind:reviewerContactId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Wholesale buyer contacts are the named individuals who review and approve samples. Linking to contact enables approval workflow routing, notification delivery, and audit trail of who approved what. re' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:constructionApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Construction Approval Status' ;
    rdfs:comment 'Specific approval decision for the construction dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionComments rdf:type rdf:Property ;
    rdfs:label 'Construction Comments' ;
    rdfs:comment 'Consolidated feedback on the construction quality, stitching, and assembly of the sample.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Issue Flag' ;
    rdfs:comment 'Indicates whether the sample has critical defects that must be resolved before production (True = critical issues present, False = no critical issues).' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fabricApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Status' ;
    rdfs:comment 'Specific approval decision for the fabric dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricComments rdf:type rdf:Property ;
    rdfs:label 'Fabric Comments' ;
    rdfs:comment 'Feedback on fabric quality, hand feel, color accuracy, and material performance.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fit Approval Status' ;
    rdfs:comment 'Specific approval decision for the fit dimension of the sample.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueSeverity rdf:type rdf:Property ;
    rdfs:label 'Issue Severity' ;
    rdfs:comment 'Overall severity classification of issues found during sample review.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Labeling Approval Status' ;
    rdfs:comment 'Specific approval decision for the labeling dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingComments rdf:type rdf:Property ;
    rdfs:label 'Labeling Comments' ;
    rdfs:comment 'Feedback on care labels, brand labels, size tags, and regulatory labeling compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallComments rdf:type rdf:Property ;
    rdfs:label 'Overall Comments' ;
    rdfs:comment 'General feedback and summary notes from the review team covering all aspects of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Approval Status' ;
    rdfs:comment 'Specific approval decision for the packaging dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingComments rdf:type rdf:Property ;
    rdfs:label 'Packaging Comments' ;
    rdfs:comment 'Feedback on packaging materials, folding, hangtags, and presentation.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of issue resolution and corrective action implementation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Target date by which the sample review and approval decision must be completed.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionRound rdf:type rdf:Property ;
    rdfs:label 'Revision Round' ;
    rdfs:comment 'Sequential number indicating which iteration of the sample this represents (1 = first submission, 2 = first revision, etc.).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleCost rdf:type rdf:Property ;
    rdfs:label 'Sample Cost' ;
    rdfs:comment 'Cost incurred to produce this individual sample unit, typically charged by the factory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the sample cost (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Business identifier for the sample, typically assigned by the PLM or production system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Production Date' ;
    rdfs:comment 'Planned date for bulk production to commence following sample approval.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trimApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Status' ;
    rdfs:comment 'Specific approval decision for the trim dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimComments rdf:type rdf:Property ;
    rdfs:label 'Trim Comments' ;
    rdfs:comment 'Feedback on trims, accessories, buttons, zippers, and embellishments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key for the master production schedule (MPS) entity.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryWindowId rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Id' ;
    rdfs:comment 'Reference to the target delivery window or time bucket for finished goods. Aligns production schedule with retail distribution calendar and store delivery requirements.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryWindow .

ind:actualCutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cut Date' ;
    rdfs:comment 'Actual date when fabric cutting operations began. Used for On-Time In-Full (OTIF) performance tracking and schedule variance analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ex Factory Date' ;
    rdfs:comment 'Actual date when finished goods left the factory. Critical for OTIF performance measurement and supply chain delivery tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFinishingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finishing Date' ;
    rdfs:comment 'Actual date when finishing operations completed. Used for quality gate tracking and final production milestone confirmation.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSewEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual Sew End Date' ;
    rdfs:comment 'Actual date when sewing operations completed. Used for cycle time analysis and production efficiency measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSewStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Sew Start Date' ;
    rdfs:comment 'Actual date when sewing operations commenced. Used for production milestone tracking and factory performance measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factoryCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Factory Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of factory production line capacity consumed by this schedule. Used for capacity planning and factory loading optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockedBy rdf:type rdf:Property ;
    rdfs:label 'Locked By' ;
    rdfs:comment 'User identifier of the planner or manager who locked this schedule. Locked schedules are committed to factory and cannot be changed without approval.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Locked Timestamp' ;
    rdfs:comment 'Date and time when this schedule was locked. Marks the point when the schedule became committed and change-controlled.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCutDate rdf:type rdf:Property ;
    rdfs:label 'Planned Cut Date' ;
    rdfs:comment 'Scheduled date for fabric cutting operations to begin. First milestone in the Cut-Make-Trim (CMT) production process, marking when raw materials are cut into garment pieces.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ex Factory Date' ;
    rdfs:comment 'Scheduled date for finished goods to leave the factory. Critical milestone for Free On Board (FOB) shipment and supply chain handoff to logistics partners.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFinishingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finishing Date' ;
    rdfs:comment 'Scheduled date for finishing operations including washing, pressing, quality inspection, and packaging. Final production milestone before ex-factory shipment.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSewEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Sew End Date' ;
    rdfs:comment 'Scheduled date for sewing operations to complete. Marks the end of garment assembly before finishing operations begin.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSewStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Sew Start Date' ;
    rdfs:comment 'Scheduled date for sewing operations to commence. Marks the beginning of garment assembly on the production line.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group or team responsible for this schedule. Used for workload distribution and organizational reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionMethod rdf:type rdf:Property ;
    rdfs:label 'Production Method' ;
    rdfs:comment 'Manufacturing model for this production schedule. Cut-Make-Trim (CMT) is contract manufacturing, Free On Board (FOB) is full-package manufacturing, Original Design Manufacturer (ODM) provides design and manufacturing, Original Equipment Manufacturer (OEM) manufactures to buyer specifications, and in-house is internal production.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of production run type. Pre-production (PP) samples are for approval, bulk production is main volume manufacturing, pilot runs are small test batches, and reorders are repeat production of proven styles.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the production schedule record. Human-readable schedule number used in communications with factory partners and internal planning teams.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule. Draft schedules are under planning, confirmed schedules are committed to factory, locked schedules cannot be changed, in-progress schedules are actively executing, completed schedules are finished, cancelled schedules are voided, and on-hold schedules are temporarily suspended. [ENUM-REF-CANDIDATE: draft|confirmed|locked|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'Total quantity of units scheduled for production in this schedule record. Represents the planned output volume for the production run.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeDate rdf:type rdf:Property ;
    rdfs:label 'Change Date' ;
    rdfs:comment 'Date when the most recent schedule change was made. Used for change frequency analysis and schedule stability measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Routings are designed and approved by industrial engineers who own process standards, SAM calculations, and line balancing. Critical for engineering accountability, continuous improvement tracking, an' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cmtCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cmt Cost Per Unit' ;
    rdfs:comment 'Calculated CMT (Cut Make Trim) cost per unit based on total SAM, labor rates, and overhead allocation. Used for product costing and pricing decisions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complexityRating rdf:type rdf:Property ;
    rdfs:label 'Complexity Rating' ;
    rdfs:comment 'Overall complexity rating of this routing based on number of operations, skill requirements, and technical difficulty. Used for capacity planning and factory assignment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathOperations rdf:type rdf:Property ;
    rdfs:label 'Critical Path Operations' ;
    rdfs:comment 'Comma-separated list of operation sequence numbers that form the critical path for this routing. These operations determine the minimum production time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when this routing record was last modified. Used to track routing changes and improvements over time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineBalancingTarget rdf:type rdf:Property ;
    rdfs:label 'Line Balancing Target' ;
    rdfs:comment 'Target line balancing efficiency percentage for this routing. Represents the ideal distribution of work across operations to minimize bottlenecks.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTypeRequirements rdf:type rdf:Property ;
    rdfs:label 'Machine Type Requirements' ;
    rdfs:comment 'Comma-separated list of machine types required to execute this routing (e.g., single needle, overlock, flatlock, buttonhole, bartack, pressing).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum production batch size that this routing can handle without requiring line reconfiguration or additional resources.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum production batch size for which this routing is economically viable. Below this quantity, setup costs make production inefficient.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'Total number of discrete manufacturing operations defined in this routing sequence.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineType rdf:type rdf:Property ;
    rdfs:label 'Production Line Type' ;
    rdfs:comment 'Type of production line configuration required for this routing. Modular lines use flexible workstations, progressive bundle systems move work in batches, unit production systems use overhead conveyors, and lean cells use cellular manufacturing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckPoints rdf:type rdf:Property ;
    rdfs:label 'Quality Check Points' ;
    rdfs:comment 'Number of quality inspection checkpoints defined within this routing sequence to ensure product quality standards.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'Business identifier for the routing, typically a combination of style code and factory code.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed description of the manufacturing routing including special instructions, quality requirements, and production notes.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingName rdf:type rdf:Property ;
    rdfs:label 'Routing Name' ;
    rdfs:comment 'Descriptive name of the routing, typically including style name and factory name for easy identification.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Draft routings are under development, approved routings are ready for use, active routings are in production, inactive routings are temporarily suspended, and obsolete routings are retired.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing based on its purpose. Standard routings are the default process, alternative routings are backup options, prototype routings are for PP (Pre-Production) samples, sample routings are for SMS (Sample Management System), and bulk production routings are for high-volume manufacturing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Total time in minutes required to set up the production line before starting this routing. Includes machine setup, material preparation, and line configuration.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillLevelRequirements rdf:type rdf:Property ;
    rdfs:label 'Skill Level Requirements' ;
    rdfs:comment 'Minimum operator skill level required to execute this routing. Used for workforce planning and training needs assessment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Required' ;
    rdfs:comment 'Comma-separated list of special equipment or tools required for this routing beyond standard sewing machines (e.g., heat press, ultrasonic welder, laser cutter, embroidery machine).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Efficiency Percentage' ;
    rdfs:comment 'Target production efficiency percentage for this routing. Used to calculate expected output and labor costs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOutputPerHour rdf:type rdf:Property ;
    rdfs:label 'Target Output Per Hour' ;
    rdfs:comment 'Expected number of units that can be produced per hour when this routing is executed at standard efficiency.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Total time in minutes required to tear down the production line after completing this routing. Includes cleanup, machine reset, and material removal.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSam rdf:type rdf:Property ;
    rdfs:label 'Total Sam' ;
    rdfs:comment 'Total Standard Allowed Minutes for completing all operations in the routing. Used for capacity planning, CMT (Cut Make Trim) cost calculation, and labor costing. Sum of SAM values across all operations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractingOrderId rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Order Id' ;
    rdfs:comment 'Unique identifier for the subcontracting purchase order. Primary key.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcontractCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: CMT subcontracting costs must allocate to cost centers for accurate production cost tracking, outsourced vs in-house cost comparison, and subcontractor performance analysis.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the subcontractor began the manufacturing operation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmtPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Cmt Price Per Unit' ;
    rdfs:comment 'Agreed unit price for the subcontracting operation, typically representing the CMT cost.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentsSentDate rdf:type rdf:Property ;
    rdfs:label 'Components Sent Date' ;
    rdfs:comment 'Date when component materials were sent to the subcontractor for processing.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentsSentQuantity rdf:type rdf:Property ;
    rdfs:label 'Components Sent Quantity' ;
    rdfs:comment 'Total quantity of component materials sent to the subcontractor.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International commercial terms defining delivery responsibilities. Common values: FOB, CIF, EXW, DDP.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type of manufacturing or finishing operation being subcontracted (e.g., CMT, embroidery, printing, washing, dyeing). [ENUM-REF-CANDIDATE: cut_make_trim|embroidery|printing|washing|dyeing|finishing|stitching|assembly|packaging — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Total quantity of units ordered for the subcontracting operation.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when the subcontractor is expected to begin the manufacturing operation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poItemNumber rdf:type rdf:Property ;
    rdfs:label 'Po Item Number' ;
    rdfs:comment 'Line item number within the subcontracting purchase order. SAP item category L for subcontracting.' ;
    rdfs:domain ind:SubcontractingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the subcontracting order (order quantity × CMT price per unit).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverContactId rdf:type rdf:Property ;
    rdfs:label 'Approver Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Critical TNA milestones (fabric approval, sample approval, shipment authorization) require buyer contact approval in B2B workflows. Linking enables approval routing, notification, and compliance track' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'Detailed description or notes explaining the reason for the delay. Provides context beyond the standardized delay reason code. Null if milestone was on time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerVisible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Visible' ;
    rdfs:comment 'Flag indicating whether this milestone is visible to the customer or buyer in external milestone tracking reports. True for customer-facing milestones like PP sample approval and ex-factory.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAtMilestone rdf:type rdf:Property ;
    rdfs:label 'Quantity At Milestone' ;
    rdfs:comment 'The quantity of units (pieces, garments, SKUs) that reached this milestone. Enables tracking of partial completions and yield analysis across production stages.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedBy rdf:type rdf:Property ;
    rdfs:label 'Recorded By' ;
    rdfs:comment 'Name or identifier of the user or system that recorded this milestone completion. Provides audit trail for data entry accountability.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Timestamp when this milestone record was created or updated in the system. Distinct from actual_timestamp which represents the real-world event time.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisedDate rdf:type rdf:Property ;
    rdfs:label 'Revised Date' ;
    rdfs:comment 'Updated target date for the milestone if the original plan was revised. Captures schedule adjustments due to delays, expedites, or other changes. Null if no revision occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingMode rdf:type rdf:Property ;
    rdfs:label 'Shipping Mode' ;
    rdfs:comment 'The mode of transportation for shipment-related milestones (ex-factory, cargo receipt). Impacts lead time expectations and milestone planning.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Work centers have supervisors managing daily operations, quality control, staffing, and equipment utilization. Essential for labor cost allocation, performance reviews, and operational accountability.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Capacity category code used for grouping work centers with similar capacity characteristics in capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Day' ;
    rdfs:comment 'Available production capacity of the work center measured in hours per day. Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'SAP PP control key that determines which operations are relevant for scheduling, capacity planning, and costing at this work center.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Type of production department this work center belongs to within the apparel manufacturing process. [ENUM-REF-CANDIDATE: cutting|sewing|finishing|pressing|packing|embroidery|printing|quality_inspection — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulaKey rdf:type rdf:Property ;
    rdfs:label 'Formula Key' ;
    rdfs:comment 'Key identifying the formula used to calculate standard values (setup time, machine time, labor time) for operations at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Labor Time Per Unit Minutes' ;
    rdfs:comment 'Standard labor time per production unit, measured in minutes. Used for workforce planning and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Physical location description within the factory (e.g., Building A Floor 2, Production Hall 3 Zone B).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Machine Time Per Unit Minutes' ;
    rdfs:comment 'Standard machine processing time per production unit, measured in minutes. Used for capacity planning and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Move Time Minutes' ;
    rdfs:comment 'Standard time required to move materials to the next work center after operation completion, measured in minutes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfMachines rdf:type rdf:Property ;
    rdfs:label 'Number Of Machines' ;
    rdfs:comment 'Total count of machines or equipment units available in this work center.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfOperators rdf:type rdf:Property ;
    rdfs:label 'Number Of Operators' ;
    rdfs:comment 'Total count of operators or workers assigned to this work center for production operations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Code' ;
    rdfs:comment 'Quality certification or compliance code applicable to this work center (e.g., ISO 9001, WRAP, OEKO-TEX).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Queue Time Minutes' ;
    rdfs:comment 'Standard queue time (waiting time before operation starts) at this work center, measured in minutes. Used in production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Scheduling method used for operations at this work center: forward scheduling from start date, backward scheduling from due date, or midpoint scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern for this work center (single shift, two shifts, three shifts, or continuous 24/7 operation).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardValueUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Value Unit' ;
    rdfs:comment 'Unit of measure for standard time values (minutes, hours, seconds, days) used in capacity and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Classification of the work center based on resource type: machine-intensive, labor-intensive, or mixed operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Business identifier for the work center used in production planning and routing. Externally-known unique code used in SAP PP module.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center (e.g., Sewing Line 3, Cutting Room A, Finishing Department B).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center in its lifecycle. Determines availability for production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryId rdf:type rdf:Property ;
    rdfs:label 'Factory Id' ;
    rdfs:comment 'FK to supplier.factory.factory_id — MUST-HAVE: Links production work orders to the factory master for capacity planning, compliance verification, and production allocation decisions.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionFactory .

ind:productionCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Production Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Production orders must allocate manufacturing costs to cost centers for standard costing, variance analysis, and factory overhead allocation—core requirement in apparel manufacturing accounting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sapPpOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Pp Order Number' ;
    rdfs:comment 'SAP S/4HANA PP module production order number. System of record identifier linking this work order to the ERP production planning system.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Target Ex Factory Date' ;
    rdfs:comment 'Target date for goods to leave the factory. Critical milestone for logistics planning and On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known business identifier for the work order. Human-readable unique reference used across manufacturing systems and communications with factory partners.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order. Tracks progression from initial creation through production execution to final closure. [ENUM-REF-CANDIDATE: draft|released|confirmed|in_progress|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Operation Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Individual operations require cost center assignment for activity-based costing, labor cost allocation by department, and detailed production cost variance analysis—standard in apparel manufacturing c' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryWorkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Employee Id' ;
    rdfs:comment 'Reference to the production operator or worker who performed or is assigned to this operation. Used for performance tracking and labor management.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWorkConfirmedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Work Confirmed By User Employee Id' ;
    rdfs:comment 'System user ID of the person who confirmed the operation completion in the ERP system.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual time taken to complete this operation, measured in minutes. Used to calculate efficiency variance against SAM.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the operation execution was completed on the factory floor, captured from production confirmation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the operation execution began on the factory floor, captured from production confirmation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:efficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Efficiency Percentage' ;
    rdfs:comment 'Operation efficiency calculated as (standard_allowed_minutes / actual_duration_minutes) * 100. Measures operator and work center performance against standard.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Factory Location Code' ;
    rdfs:comment 'Three-letter code identifying the manufacturing facility or factory where this operation is performed (e.g., BDH for Bangladesh Dhaka, CNS for China Shenzhen).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Quality inspection lot number assigned to this operation for tracking quality control results and defects.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether quality inspection is required after completing this operation. True if inspection is mandatory, False otherwise.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours consumed for this operation, including direct production time, setup, and teardown. Used for labor costing and capacity analysis.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineHours rdf:type rdf:Property ;
    rdfs:label 'Machine Hours' ;
    rdfs:comment 'Total machine or equipment hours utilized for this operation. Used for machine costing and utilization tracking.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCode rdf:type rdf:Property ;
    rdfs:label 'Operation Code' ;
    rdfs:comment 'Standardized code identifying the type of manufacturing operation (e.g., CUT, SEW, FINISH, PRESS, PACK, INSPECT, EMBROIDER, PRINT).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Operation Cost Amount' ;
    rdfs:comment 'Total cost incurred for this operation, including labor, machine, overhead, and material costs. Used for production costing and variance analysis.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Detailed textual description of the manufacturing operation, including specific instructions, techniques, or requirements for execution.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'The unique operation number within the routing sequence, typically a 4-digit code (e.g., 0010, 0020, 0030) that defines the order of manufacturing steps.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'Sequential order of this operation within the work order routing. Determines the execution order of manufacturing steps.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow. [ENUM-REF-CANDIDATE: planned|released|in_progress|completed|confirmed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when this operation is planned to be completed based on standard times and production scheduling.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier for the production line or assembly line where this operation is executed. Used for line balancing and capacity planning.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality inspection result status for this operation indicating whether output meets quality standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardAllowedMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Allowed Minutes' ;
    rdfs:comment 'Standard time allocated for completing this operation per unit, measured in minutes. Used for capacity planning, costing, and efficiency measurement in apparel manufacturing.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Percentage of good output relative to input for this operation, calculated as (confirmed_quantity / planned_quantity) * 100. Key metric for production efficiency.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aqlPlanId rdf:type rdf:Property ;
    rdfs:label 'Aql Plan Id' ;
    rdfs:comment 'Unique identifier for the AQL sampling plan configuration.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AqlPlan .

ind:supersededByPlanAqlPlanId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Plan Aql Plan Id' ;
    rdfs:comment 'Reference to the AQL plan that replaces this plan when it is superseded. Null if the plan is still current or has been archived without replacement.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AqlPlan .

ind:acceptNumberCritical rdf:type rdf:Property ;
    rdfs:label 'Accept Number Critical' ;
    rdfs:comment 'Maximum number of critical defects allowed in the sample for the lot to be accepted. Typically 0 for critical defects.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptNumberMajor rdf:type rdf:Property ;
    rdfs:label 'Accept Number Major' ;
    rdfs:comment 'Maximum number of major defects allowed in the sample for the lot to be accepted.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptNumberMinor rdf:type rdf:Property ;
    rdfs:label 'Accept Number Minor' ;
    rdfs:comment 'Maximum number of minor defects allowed in the sample for the lot to be accepted.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableSupplierTier rdf:type rdf:Property ;
    rdfs:label 'Applicable Supplier Tier' ;
    rdfs:comment 'Supplier tier classification to which this AQL plan applies. Tier 1 suppliers may have more stringent or relaxed plans based on performance history.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aqlCritical rdf:type rdf:Property ;
    rdfs:label 'Aql Critical' ;
    rdfs:comment 'AQL percentage for critical defects (defects that render the product unsafe or non-compliant with mandatory regulations). Typical values range from 0.0 to 0.65 percent. Critical defects are those that could cause injury or violate safety standards such as CPSC, OEKO-TEX, or GOTS.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aqlMajor rdf:type rdf:Property ;
    rdfs:label 'Aql Major' ;
    rdfs:comment 'AQL percentage for major defects (defects that significantly affect product usability, performance, or appearance and are likely to result in customer rejection). Typical values range from 1.0 to 2.5 percent.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aqlMinor rdf:type rdf:Property ;
    rdfs:label 'Aql Minor' ;
    rdfs:comment 'AQL percentage for minor defects (defects that do not significantly affect product usability but represent deviations from specifications). Typical values range from 2.5 to 6.5 percent.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aqlPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Aql Plan Status' ;
    rdfs:comment 'Current lifecycle status of the AQL plan configuration.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Regulatory or certification standards that this AQL plan is designed to satisfy (e.g., OEKO-TEX Standard 100, CPSC, GOTS, FTC labeling, ISO 9001). Multiple standards may be comma-separated.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLevel rdf:type rdf:Property ;
    rdfs:label 'Inspection Level' ;
    rdfs:comment 'General inspection level (I, II, III) or special inspection level (S-1 through S-4) that determines the relationship between lot size and sample size. Level II is typical for general use; Level I requires smaller samples; Level III requires larger samples. Special levels S-1 through S-4 are used when small sample sizes are necessary and large sampling risks can be tolerated. [ENUM-REF-CANDIDATE: I|II|III|S-1|S-2|S-3|S-4 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStandard rdf:type rdf:Property ;
    rdfs:label 'Inspection Standard' ;
    rdfs:comment 'The quality inspection standard framework upon which this AQL plan is based.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeMax rdf:type rdf:Property ;
    rdfs:label 'Lot Size Max' ;
    rdfs:comment 'Maximum lot size (in units) to which this AQL plan applies. Defines the upper bound of the lot size range for sample size determination. Null indicates no upper limit.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeMin rdf:type rdf:Property ;
    rdfs:label 'Lot Size Min' ;
    rdfs:comment 'Minimum lot size (in units) to which this AQL plan applies. Defines the lower bound of the lot size range for sample size determination.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGateStage rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Stage' ;
    rdfs:comment 'Stage in the Time and Action (T&A) calendar or production lifecycle where this AQL plan is applied (e.g., PP sample, pre-production, inline inspection, final random inspection, shipment inspection). Multiple stages may be comma-separated. [ENUM-REF-CANDIDATE: pp_sample|pre_production|inline_inspection|final_random_inspection|shipment_inspection|receiving_inspection|in_process_inspection — promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectNumberCritical rdf:type rdf:Property ;
    rdfs:label 'Reject Number Critical' ;
    rdfs:comment 'Minimum number of critical defects in the sample that triggers lot rejection. Typically 1 for critical defects.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectNumberMajor rdf:type rdf:Property ;
    rdfs:label 'Reject Number Major' ;
    rdfs:comment 'Minimum number of major defects in the sample that triggers lot rejection.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectNumberMinor rdf:type rdf:Property ;
    rdfs:label 'Reject Number Minor' ;
    rdfs:comment 'Minimum number of minor defects in the sample that triggers lot rejection.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeCodeLetter rdf:type rdf:Property ;
    rdfs:label 'Sample Size Code Letter' ;
    rdfs:comment 'Code letter (A through R) assigned based on lot size and inspection level, used to determine the actual sample size from the master sampling tables. [ENUM-REF-CANDIDATE: A|B|C|D|E|F|G|H|J|K|L|M|N|P|Q|R — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlanType rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Type' ;
    rdfs:comment 'Type of sampling plan: single (one sample, one decision), double (up to two samples with intermediate decision), or multiple (up to seven samples with cumulative decision).' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:switchingRule rdf:type rdf:Property ;
    rdfs:label 'Switching Rule' ;
    rdfs:comment 'Current inspection severity level. Normal is the default. Tightened inspection is applied when quality history deteriorates (2 out of 5 consecutive lots rejected). Reduced inspection is applied when quality history is consistently good (10 consecutive lots accepted under normal inspection). Switching rules are defined in ANSI/ASQ Z1.4 Section 9.' ;
    rdfs:domain ind:AqlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateId rdf:type rdf:Property ;
    rdfs:label 'Gate Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_gate. Business justification: Corrective action is associated with a quality gate stage where the issue was detected. N corrective_actions : 1 quality_gate. No columns removed because quality_gate_stage is an execution value.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action plan to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-readable unique identifier for the corrective action, typically following a CAPA numbering convention.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action as corrective (addressing existing non-conformance), preventive (preventing potential non-conformance), or both.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment action taken to prevent further non-conforming product from reaching customers or production.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action plan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfQualityImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Of Quality Impact' ;
    rdfs:comment 'Estimated financial impact of the non-conformance and corrective action, including rework, scrap, returns, and prevention costs.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Recurrence Count' ;
    rdfs:comment 'Number of times the same or similar non-conformance has recurred, indicating effectiveness of corrective actions.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'Methodology used to identify the root cause of the non-conformance (5-Why, Fishbone/Ishikawa, Fault Tree Analysis, Pareto, etc.).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed description of the identified root cause of the non-conformance or quality issue.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPerformanceImpact rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Impact' ;
    rdfs:comment 'Impact of this corrective action on supplier performance rating and relationship status.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the effectiveness review indicating whether the corrective action successfully addressed the root cause and prevented recurrence.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fit sessions require employee evaluators for approval authority and accountability. Real business process: fit approval workflow, evaluator assignment, and decision tracking. Removes denormalized fit_' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fitModelId rdf:type rdf:Property ;
    rdfs:label 'Fit Model Id' ;
    rdfs:comment 'Reference to the fit model who wore the garment during the evaluation session. Fit models have standardized body measurements representing target customer segments.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FitModel .

ind:armholeFitComment rdf:type rdf:Property ;
    rdfs:label 'Armhole Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the armhole area including depth and circumference. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chestBustFitComment rdf:type rdf:Property ;
    rdfs:label 'Chest Bust Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the chest or bust area. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Construction Issue Flag' ;
    rdfs:comment 'Indicates whether construction or workmanship issues were identified during the fit session that require corrective action beyond pattern changes.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionIssueNotes rdf:type rdf:Property ;
    rdfs:label 'Construction Issue Notes' ;
    rdfs:comment 'Details of any construction, stitching, or assembly issues identified during fit evaluation (e.g., seam puckering, uneven hem, incorrect stitch type).' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricPerformanceComment rdf:type rdf:Property ;
    rdfs:label 'Fabric Performance Comment' ;
    rdfs:comment 'Observations on fabric behavior during fit session including drape, stretch recovery, wrinkling, and comfort. Informs fabric approval decisions.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitEvaluatorTeam rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluator Team' ;
    rdfs:comment 'Comma-separated list of additional team members present during the fit session (designers, merchandisers, product managers). Captures cross-functional collaboration.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitModelMeasurements rdf:type rdf:Property ;
    rdfs:label 'Fit Model Measurements' ;
    rdfs:comment 'Key body measurements of the fit model at the time of the session (e.g., bust-waist-hip in inches or centimeters). Provides context for fit evaluation.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitStage rdf:type rdf:Property ;
    rdfs:label 'Fit Stage' ;
    rdfs:comment 'The stage in the product development lifecycle at which this fit session occurs. Aligns with quality gates in the Time and Action (T&A) calendar from prototype through Pre-Production (PP) sample approval. [ENUM-REF-CANDIDATE: proto|first_fit|second_fit|final_fit|pp_sample|top_sample|size_set — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingNotes rdf:type rdf:Property ;
    rdfs:label 'Grading Notes' ;
    rdfs:comment 'Notes on how fit adjustments should be applied across the size range during grading. Ensures proportional fit across all sizes based on base size approval.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipFitComment rdf:type rdf:Property ;
    rdfs:label 'Hip Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the hip area. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inseamFitComment rdf:type rdf:Property ;
    rdfs:label 'Inseam Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the inseam and crotch area (applicable to bottoms). Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthFitComment rdf:type rdf:Property ;
    rdfs:label 'Length Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for overall garment length (hem, rise, torso length). Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementVarianceFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Variance Flag' ;
    rdfs:comment 'Indicates whether actual garment measurements deviate from tech pack specifications beyond acceptable tolerance. Triggers measurement reconciliation.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:necklineFitComment rdf:type rdf:Property ;
    rdfs:label 'Neckline Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the neckline and collar area. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFitSessionRequired rdf:type rdf:Property ;
    rdfs:label 'Next Fit Session Required' ;
    rdfs:comment 'Indicates whether an additional fit session is required after pattern amendments are made. Drives scheduling in the Time and Action (T&A) calendar.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallFitComment rdf:type rdf:Property ;
    rdfs:label 'Overall Fit Comment' ;
    rdfs:comment 'General fit evaluation comments covering overall silhouette, balance, proportion, and any cross-zone observations not captured in body-zone-specific comments.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallFitStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Fit Status' ;
    rdfs:comment 'The overall approval status resulting from this fit session. Determines whether the style can proceed to the next quality gate or requires additional fit sessions.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternAmendmentNotes rdf:type rdf:Property ;
    rdfs:label 'Pattern Amendment Notes' ;
    rdfs:comment 'Detailed instructions for pattern maker on specific adjustments required (e.g., add 0.5 inch to shoulder seam, reduce waist by 1 cm). Supports technical specification updates.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternAmendmentRequired rdf:type rdf:Property ;
    rdfs:label 'Pattern Amendment Required' ;
    rdfs:comment 'Indicates whether pattern adjustments are required based on fit session findings. Triggers pattern maker work in the product development workflow.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'File path or URL reference to photos taken during the fit session. Visual documentation supports remote collaboration and historical reference.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'The date on which the fit evaluation session was conducted. Critical for tracking progress against the Time and Action (T&A) calendar.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Sequential number of this fit session for the given style (e.g., 1 for first fit, 2 for second fit). Tracks iteration count through the fit approval process.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shoulderFitComment rdf:type rdf:Property ;
    rdfs:label 'Shoulder Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the shoulder area. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeEvaluated rdf:type rdf:Property ;
    rdfs:label 'Size Evaluated' ;
    rdfs:comment 'The garment size being evaluated in this fit session (e.g., M, L, 8, 10). Typically the base size for initial fit approval before grading.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sleeveFitComment rdf:type rdf:Property ;
    rdfs:label 'Sleeve Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the sleeve area including armhole, sleeve length, and cuff. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetNextFitDate rdf:type rdf:Property ;
    rdfs:label 'Target Next Fit Date' ;
    rdfs:comment 'Planned date for the next fit session if additional evaluation is required. Supports Time and Action (T&A) calendar management and critical path tracking.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waistFitComment rdf:type rdf:Property ;
    rdfs:label 'Waist Fit Comment' ;
    rdfs:comment 'Detailed fit evaluation comments for the waist area. Documents fit issues, adjustments needed, or approval notes for this body zone.' ;
    rdfs:domain ind:FitSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agency rdf:type rdf:Property ;
    rdfs:label 'Agency' ;
    rdfs:comment 'The name of the third-party inspection agency or internal quality team that performed the inspection (e.g., SGS, Bureau Veritas, Intertek).' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'The reference number of the CAPA record created as a result of this inspection, if applicable.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaTriggered rdf:type rdf:Property ;
    rdfs:label 'Capa Triggered' ;
    rdfs:comment 'Flag indicating whether this inspection triggered a formal CAPA (Corrective and Preventive Action) process due to significant quality issues or non-conformance.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalDefectsFound rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Found' ;
    rdfs:comment 'The count of critical defects identified during the inspection. Critical defects are those that pose safety hazards or render the product completely unusable.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Flag indicating whether the inspected lot has been placed on quality hold, preventing shipment or further processing until issues are resolved.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Human-readable business identifier for the inspection event, typically formatted as INS-YYYYMMDD or similar pattern used in quality management systems.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection event based on the stage in the production lifecycle. Pre-production (PP) inspections validate samples before bulk production; inline inspections occur during manufacturing; mid-production inspections assess progress; final random inspection (FRI) validates finished goods using AQL sampling; receiving inspections validate incoming materials; lab test inspections validate compliance with technical specifications.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorNotes rdf:type rdf:Property ;
    rdfs:label 'Inspector Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the inspector during the inspection, providing additional context and details beyond structured defect data.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labTestRequired rdf:type rdf:Property ;
    rdfs:label 'Lab Test Required' ;
    rdfs:comment 'Flag indicating whether laboratory testing is required as part of this inspection to validate material composition, chemical safety, or performance specifications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labTestStatus rdf:type rdf:Property ;
    rdfs:label 'Lab Test Status' ;
    rdfs:comment 'The current status of laboratory testing associated with this inspection, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'The total quantity of units in the production lot or shipment being inspected.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorDefectsFound rdf:type rdf:Property ;
    rdfs:label 'Major Defects Found' ;
    rdfs:comment 'The count of major defects identified during the inspection. Major defects significantly impair product functionality or appearance and are likely to result in customer rejection.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectsFound rdf:type rdf:Property ;
    rdfs:label 'Minor Defects Found' ;
    rdfs:comment 'The count of minor defects identified during the inspection. Minor defects are small imperfections that do not significantly affect product functionality or appearance.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailOutcome rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Outcome' ;
    rdfs:comment 'The final inspection result indicating whether the lot met the AQL acceptance criteria. Pass indicates acceptance; Fail indicates rejection; Conditional Pass indicates acceptance with minor corrective actions required; Pending indicates awaiting final determination.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Url' ;
    rdfs:comment 'The URL or file path to photographic evidence of defects or inspection findings, typically stored in a document management system or cloud storage.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'The statistical sampling plan reference used for the inspection, defining sample size and acceptance criteria based on lot size and AQL level.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'The specific production stage or milestone in the Time and Action (T&A) calendar where the inspection was performed. Aligns with quality gates in the manufacturing workflow.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDefectsFound rdf:type rdf:Property ;
    rdfs:label 'Total Defects Found' ;
    rdfs:comment 'The total count of all defects (critical + major + minor) identified during the inspection.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsInspected rdf:type rdf:Property ;
    rdfs:label 'Units Inspected' ;
    rdfs:comment 'The actual number of units physically inspected during the inspection event. May differ from sample size if inspection was incomplete.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labTestId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Id' ;
    rdfs:comment 'Unique identifier for the laboratory test record. Primary key for the lab test entity.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricDevelopmentId rdf:type rdf:Property ;
    rdfs:label 'Fabric Development Id' ;
    rdfs:comment 'Foreign key linking to sourcing.fabric_development. Business justification: Fabric testing is mandatory quality gate in development cycle. Links test results (colorfastness, shrinkage, pilling) to fabric development records for bulk approval decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricDevelopment .

ind:primaryLabEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Employee Id' ;
    rdfs:comment 'Reference to the quality engineer, product developer, or sourcing manager who requested the test. Used for workflow tracking and accountability.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retestOfTestId rdf:type rdf:Property ;
    rdfs:label 'Retest Of Test Id' ;
    rdfs:comment 'Reference to the original lab test ID if this is a retest following a failure or corrective action. Enables tracking of retest cycles and remediation effectiveness.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTest .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the compliance certificate expires. Critical for ongoing compliance monitoring and re-testing schedules. OEKO-TEX certificates typically valid for 12 months.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date when the compliance certificate was issued by the certifying body. Marks the start of certificate validity period.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Number' ;
    rdfs:comment 'ISO/IEC 17025 accreditation certificate number for the testing laboratory. Validates lab competency and compliance.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labLocation rdf:type rdf:Property ;
    rdfs:label 'Lab Location' ;
    rdfs:comment 'Geographic location (city and country) of the testing laboratory facility.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the accredited laboratory that performed the test. Must be ISO/IEC 17025 accredited for applicable test types.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDestination rdf:type rdf:Property ;
    rdfs:label 'Market Destination' ;
    rdfs:comment 'Target market or country where the product will be sold. Determines applicable regulatory standards (e.g., USA requires CPSC flammability; EU requires REACH compliance). Pipe-separated list for multi-market products. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|CHN|JPN|AUS — promote to reference product]' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Aggregate pass/fail/conditional outcome for the entire test. Conditional indicates minor deviations requiring review. Determines whether the sample meets quality gate requirements.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this test is required for regulatory compliance (FTC labeling, CPSC safety, OEKO-TEX certification). True for mandatory compliance tests; false for voluntary quality tests.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether corrective action or remediation is required based on test results. True for failed or conditional results requiring supplier corrective action or material rework.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date when the physical sample was received by the laboratory. Marks the start of the testing timeline.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when all test procedures were completed and results finalized. Critical for T&A calendar compliance and pre-production (PP) sample approval gates.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testCostAmount rdf:type rdf:Property ;
    rdfs:label 'Test Cost Amount' ;
    rdfs:comment 'Total cost charged by the laboratory for performing this test. Used for cost of quality (COQ) analysis and budget tracking.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-text notes and observations from the laboratory or quality team regarding test conditions, anomalies, or special considerations. Provides context for test interpretation.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPriority rdf:type rdf:Property ;
    rdfs:label 'Test Priority' ;
    rdfs:comment 'Urgency level for test completion. Critical priority used for pre-production samples on tight T&A timelines or regulatory compliance issues.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPurpose rdf:type rdf:Property ;
    rdfs:label 'Test Purpose' ;
    rdfs:comment 'Business reason for conducting the test. Determines approval workflow and quality gate requirements. Pre-production tests gate production approval; random inspections validate ongoing compliance.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Unique report number issued by the laboratory for this test. Used for audit trail and certificate reference.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testRequestDate rdf:type rdf:Property ;
    rdfs:label 'Test Request Date' ;
    rdfs:comment 'Date when the test request was submitted to the laboratory. Used for tracking against Time and Action (T&A) calendar milestones.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Test Request Number' ;
    rdfs:comment 'Externally-known unique identifier for the test request submitted to the laboratory. Business identifier used for tracking and reference.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when laboratory testing commenced. Used for tracking test duration and turnaround time.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementSpecId rdf:type rdf:Property ;
    rdfs:label 'Measurement Spec Id' ;
    rdfs:comment 'Unique identifier for the measurement specification record. Primary key.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualMeasurement rdf:type rdf:Property ;
    rdfs:label 'Actual Measurement' ;
    rdfs:comment 'Actual measurement value captured during fit session, pre-production sample inspection, or final random inspection.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSizeMeasurement rdf:type rdf:Property ;
    rdfs:label 'Base Size Measurement' ;
    rdfs:comment 'Target measurement value for the base size at this measurement point.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garmentType rdf:type rdf:Property ;
    rdfs:label 'Garment Type' ;
    rdfs:comment 'Specific garment type within the category (e.g., t-shirt, jeans, jacket, sneaker).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeRule rdf:type rdf:Property ;
    rdfs:label 'Grade Rule' ;
    rdfs:comment 'Grading rule defining how the measurement changes across size breaks (e.g., +1 inch per size, -0.5 cm per size).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Location where the measurement was taken (e.g., factory name, lab name, headquarters fit room).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPointCode rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Code' ;
    rdfs:comment 'Standardized code for the measurement point used across tech packs and inspection protocols.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPointName rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Name' ;
    rdfs:comment 'Name of the specific measurement point on the garment (e.g., chest width, inseam length, sleeve length, waist circumference).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStage rdf:type rdf:Property ;
    rdfs:label 'Measurement Stage' ;
    rdfs:comment 'Stage in the Time and Action (T&A) calendar when the measurement was captured (fit session, PP sample, pre-production, inline, final).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementVariance rdf:type rdf:Property ;
    rdfs:label 'Measurement Variance' ;
    rdfs:comment 'Calculated variance between actual measurement and specified target measurement (actual minus target).' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Pass or fail determination for this measurement point based on whether actual measurement falls within tolerance.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternCorrectionNotes rdf:type rdf:Property ;
    rdfs:label 'Pattern Correction Notes' ;
    rdfs:comment 'Specific instructions for pattern corrections needed to bring measurements within specification.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specNumber rdf:type rdf:Property ;
    rdfs:label 'Spec Number' ;
    rdfs:comment 'Business identifier for the measurement specification, typically a human-readable code used in tech packs and PLM systems.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of the measurement specification in the approval workflow.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specVersion rdf:type rdf:Property ;
    rdfs:label 'Spec Version' ;
    rdfs:comment 'Version number of the measurement specification, incremented when spec is revised during product development or after fit sessions.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceMinus rdf:type rdf:Property ;
    rdfs:label 'Tolerance Minus' ;
    rdfs:comment 'Negative tolerance allowed below the target measurement before the garment is considered out of specification.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tolerancePlus rdf:type rdf:Property ;
    rdfs:label 'Tolerance Plus' ;
    rdfs:comment 'Positive tolerance allowed above the target measurement before the garment is considered out of specification.' ;
    rdfs:domain ind:MeasurementSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryNonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Non Employee Id' ;
    rdfs:comment 'Reference to the quality inspector, auditor, or user who created this non-conformance report.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedNcrNonConformanceId rdf:type rdf:Property ;
    rdfs:label 'Related Ncr Non Conformance Id' ;
    rdfs:comment 'Reference to a previous or related non-conformance report, used to track recurring issues and corrective action effectiveness.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonConformance .

ind:tertiaryNonClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Non Closed By User Employee Id' ;
    rdfs:comment 'Reference to the quality manager or authorized user who approved closure of this non-conformance report.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Id' ;
    rdfs:comment 'Foreign key linking to sourcing.vendor_quote. Business justification: NCRs may reference quoted specifications for compliance verification when actual product deviates from vendor quote commitments. Supports vendor accountability and quote accuracy audits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuote .

ind:complianceStandardViolated rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard Violated' ;
    rdfs:comment 'Specific regulatory or certification standard that was violated by this non-conformance (e.g., OEKO-TEX Standard 100, CPSC safety requirements, GOTS organic standards). Critical for compliance reporting and audit trails. [ENUM-REF-CANDIDATE: OEKO-TEX Standard 100|CPSC Product Safety|GOTS Organic|BCI Cotton|FLA Labor Standards|WRAP Certification|ISO 9001 — promote to reference product]' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedAtStage rdf:type rdf:Property ;
    rdfs:label 'Detected At Stage' ;
    rdfs:comment 'Quality gate or stage in the T&A (Time and Action) calendar where the non-conformance was identified. Earlier detection reduces cost and customer impact.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date when the non-conformance was first identified during inspection, audit, or customer feedback.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost of the non-conformance, including material cost, rework cost, logistics cost, and potential customer claims. Expressed in company reporting currency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Business-facing unique identifier for the non-conformance report, typically formatted as NCR-YYYYMMDD or similar pattern used in quality management workflows.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'Current lifecycle status of the non-conformance report. Tracks progression from identification through resolution and closure.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCategory rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Category' ;
    rdfs:comment 'High-level classification of the type of non-conformance. Used for trend analysis and root cause categorization in quality reporting.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Total number of units (pieces, cartons, or other unit of measure) impacted by this non-conformance. Used for containment scope and financial impact calculation.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the quantity affected field. Aligns with inventory and logistics unit standards.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Rework Completion Date' ;
    rdfs:comment 'Date when rework or corrective production activities were completed. Null if disposition was not rework.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'Categorization of the underlying root cause of the non-conformance. Used for corrective action planning and continuous improvement initiatives.' ;
    rdfs:domain ind:NonConformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Quality audits require assigned auditor employees for execution and accountability. Real business process: audit assignment, execution tracking, and auditor performance management. Removes denormalize' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Name of the organization or entity that conducted the audit (e.g., third-party certification body, internal audit team, customer audit team, accredited inspection agency).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorCertification rdf:type rdf:Property ;
    rdfs:label 'Auditor Certification' ;
    rdfs:comment 'Professional certification or accreditation held by the lead auditor (e.g., ISO 9001 Lead Auditor, WRAP Certified Auditor, FLA Accredited Assessor).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certification or approval was issued as a result of this audit (True if certification was granted, False otherwise).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the on-site audit fieldwork, measured in days (e.g., 1.0, 2.5, 3.0 days).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'The scheduled date for the follow-up audit to verify corrective action implementation and finding closure.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Months' ;
    rdfs:comment 'The required frequency (in months) for conducting audits of this facility, based on risk assessment, audit grade, and compliance requirements (e.g., 6, 12, 24 months).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Letter grade, pass/fail designation, or color-coded rating assigned to the audit result based on the total score and findings severity (e.g., A/B/C/D/F, pass/fail, platinum/gold/silver/bronze, red/amber/green). [ENUM-REF-CANDIDATE: A|B|C|D|F|pass|fail|conditional_pass|platinum|gold|silver|bronze|red|amber|green — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'The planned date for the next scheduled audit of this facility, based on audit frequency requirements and the results of this audit.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Total number of observations or opportunities for improvement noted during the audit. Observations are not formal non-conformances but represent areas for enhancement.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'The date on which the formal audit report was issued to the audited facility and stakeholders.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Approval Status' ;
    rdfs:comment 'The approval status of the supplier or facility resulting from this audit: approved (meets all requirements), conditional_approval (approved with conditions), suspended (approval temporarily withdrawn), rejected (does not meet requirements), under_review (decision pending).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalScore rdf:type rdf:Property ;
    rdfs:label 'Total Score' ;
    rdfs:comment 'Overall numerical score or rating achieved by the audited facility, expressed as a percentage or point value based on the audit standard\'s scoring methodology.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the accreditation body that accredits the issuing body (e.g., ANAB, UKAS, DAkkS). Provides additional assurance of certification validity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'The required frequency of audits or surveillance visits in months (e.g., 12 for annual, 6 for semi-annual). Used for scheduling compliance activities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The level or grade of certification achieved, if the certification standard has multiple tiers (e.g., OEKO-TEX Class I, II, III, IV; GOTS organic vs. made with organic).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Reference' ;
    rdfs:comment 'The internal identifier of the entity that holds the certification. This could reference a factory ID, supplier ID, material ID, or product SKU depending on certified_entity_type.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceGate rdf:type rdf:Property ;
    rdfs:label 'Compliance Gate' ;
    rdfs:comment 'The stage in the Time and Action (T&A) calendar or product lifecycle where this certification is required as a quality gate (e.g., pre-production, bulk production, customs clearance).' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer' ;
    rdfs:comment 'The name or employee ID of the internal compliance officer responsible for managing this certification and ensuring ongoing compliance.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Boolean flag indicating whether this certification is mandatory for the certified entity to be used in production or sold in target markets. True if mandatory, False if voluntary.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBodyContact rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Contact' ;
    rdfs:comment 'Contact information (email or phone) for the certifying body representative responsible for this certification.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'The specific regulatory requirement, law, or customer mandate that necessitates this certification (e.g., CPSC 16 CFR 1610, EU REACH, customer sustainability policy).' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the certification must be renewed to maintain continuous compliance. Used for proactive renewal planning.' ;
    rdfs:domain ind:QualityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'The quantitative or qualitative threshold that distinguishes acceptable variation from a defect. Defines pass/fail boundaries for inspections and lab tests, ensuring consistent application across factories and seasons.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedArea rdf:type rdf:Property ;
    rdfs:label 'Affected Area' ;
    rdfs:comment 'The specific component or area of the garment or product where the defect occurs. Enables root-cause analysis by production stage and supplier capability assessment. [ENUM-REF-CANDIDATE: seam|fabric|trim|print|embroidery|fit|label|packaging|hardware|zipper|button — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aqlClassification rdf:type rdf:Property ;
    rdfs:label 'Aql Classification' ;
    rdfs:comment 'AQL (Acceptable Quality Limit) classification tier per ISO 2859-1 and ANSI/ASQC Z1.4 standards. Determines sampling plan, acceptance number, and rejection criteria during pre-production (PP), inline, and final random inspections.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionGuidance rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Guidance' ;
    rdfs:comment 'Recommended corrective and preventive actions (CAPA) to address this defect type. Provides factory partners and internal quality teams with standardized remediation steps aligned with ISO 9001 and continuous improvement frameworks.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Category' ;
    rdfs:comment 'Estimated financial impact category of this defect type, considering rework costs, RTV (Return to Vendor) expenses, customer returns, and brand reputation risk. Informs quality investment prioritization.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerVisibility rdf:type rdf:Property ;
    rdfs:label 'Customer Visibility' ;
    rdfs:comment 'Indicates whether the defect is visible to the end customer during normal use. Visible defects have higher severity weighting and stricter acceptance criteria. Hidden defects may still affect durability or compliance.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'AQL (Acceptable Quality Limit) classification of the defect severity. Critical defects render product unsafe or unusable; major defects significantly impair function or appearance; minor defects are noticeable but do not affect primary use. Drives sampling plans and acceptance criteria per ISO 2859-1.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the defect type across all quality workflows. Used as the operational reference in inspection systems, SMS (Sample Management System), and audit reports.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed textual description of the defect, including visual characteristics, measurement criteria, and conditions under which it is considered a defect. Serves as the authoritative definition for training inspectors and resolving disputes.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectName rdf:type rdf:Property ;
    rdfs:label 'Defect Name' ;
    rdfs:comment 'Human-readable name of the defect type. Provides clear identification for quality inspectors, factory auditors, and merchandising teams.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyRank rdf:type rdf:Property ;
    rdfs:label 'Frequency Rank' ;
    rdfs:comment 'Historical ranking of this defect type by occurrence frequency across all inspections and audits. Lower numbers indicate more common defects. Used for Pareto analysis and prioritization of quality improvement initiatives.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'The quality gate or inspection checkpoint where this defect type is typically identified. Aligns with T&A (Time and Action) calendar milestones and quality protocols across the production lifecycle.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labTestMethod rdf:type rdf:Property ;
    rdfs:label 'Lab Test Method' ;
    rdfs:comment 'The specific laboratory test method or standard used to detect or measure this defect. References AATCC (American Association of Textile Chemists and Colorists), ASTM, or ISO test procedures.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Reference Url' ;
    rdfs:comment 'URL link to photographic or visual reference material illustrating the defect. Used in training materials, SMS (Sample Management System) workflows, and factory communication to ensure consistent identification.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFeasibility rdf:type rdf:Property ;
    rdfs:label 'Rework Feasibility' ;
    rdfs:comment 'Indicates whether products with this defect can be repaired or reworked to meet quality standards, or must be rejected and returned to vendor (RTV). Conditional rework depends on defect severity and cost-benefit analysis.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityWeight rdf:type rdf:Property ;
    rdfs:label 'Severity Weight' ;
    rdfs:comment 'Numeric weighting factor representing the relative impact of this defect on product quality and customer satisfaction. Used in quality scoring algorithms, Pareto analysis, and supplier scorecards. Higher values indicate greater severity.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether occurrence of this defect triggers mandatory notification to the supplier or factory partner. Critical and major defects typically require immediate supplier engagement and corrective action.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorGateId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Gate Id' ;
    rdfs:comment 'Reference to the quality gate that must be completed before this gate can be executed. Null if this is the first gate or has no predecessor dependency.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:applicableOrderType rdf:type rdf:Property ;
    rdfs:label 'Applicable Order Type' ;
    rdfs:comment 'Type of production order to which this quality gate applies (production, sample, bulk, all).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Job role or title authorized to provide formal approval for this quality gate (e.g., QA Director, Technical Design Manager, Compliance Lead).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Boolean flag indicating whether formal approval signature is required to pass this gate.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoEscalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Escalation Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic escalation is enabled when the gate is not completed within SLA.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bypassAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Bypass Authority Role' ;
    rdfs:comment 'Job role or title authorized to bypass or override this quality gate in exceptional circumstances (e.g., VP Quality, Chief Product Officer, General Manager).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bypassRequiresJustification rdf:type rdf:Property ;
    rdfs:label 'Bypass Requires Justification' ;
    rdfs:comment 'Boolean flag indicating whether a written justification is required when the gate is bypassed.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Enforcement mode of the quality gate: blocking (production/shipment cannot proceed without pass), advisory (warning issued but can proceed), warning (notification only).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRecipientEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Recipient Email' ;
    rdfs:comment 'Email address or distribution list to receive escalation notifications when the gate is overdue.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours past the SLA deadline before automatic escalation is triggered. Null if auto-escalation is disabled.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateCategory rdf:type rdf:Property ;
    rdfs:label 'Gate Category' ;
    rdfs:comment 'High-level category of the quality gate (material, sample, production, inspection, compliance, shipment).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCode rdf:type rdf:Property ;
    rdfs:label 'Gate Code' ;
    rdfs:comment 'Unique business identifier code for the quality gate (e.g., FAB_APPR, LAB_TEST, PP_SIGN, INLINE_INSP, FINAL_RND, TOP_APPR, PRESHIP).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDescription rdf:type rdf:Property ;
    rdfs:label 'Gate Description' ;
    rdfs:comment 'Detailed description of the quality gate purpose, scope, and requirements.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateName rdf:type rdf:Property ;
    rdfs:label 'Gate Name' ;
    rdfs:comment 'Descriptive name of the quality gate checkpoint (e.g., Fabric Approval, Lab Test Pass, Pre-Production Sample Sign-Off, In-Line Inspection, Final Random Inspection, Time of Production Approval, Pre-Shipment Inspection).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Status' ;
    rdfs:comment 'Current status of the quality gate configuration (active, inactive, draft, deprecated).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientList rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or distribution lists to receive notifications for this quality gate.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passCriteria rdf:type rdf:Property ;
    rdfs:label 'Pass Criteria' ;
    rdfs:comment 'Detailed specification of the criteria that must be satisfied for the gate to pass (e.g., AQL levels, test results, approval signatures, defect thresholds).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List of documents or records that must be submitted for gate approval (e.g., lab test report, PP sample photos, inspection report, certificate of compliance). Multiple documents separated by semicolon.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'Specific job role or title responsible for gate approval (e.g., QA Manager, Technical Designer, Compliance Officer, Production Manager).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential order of this gate within the overall quality gate framework (1, 2, 3, etc.). Lower numbers indicate earlier gates in the T&A calendar.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaDaysBeforeExfactory rdf:type rdf:Property ;
    rdfs:label 'Sla Days Before Exfactory' ;
    rdfs:comment 'Number of days before the ex-factory date that this quality gate must be completed, as defined in the Time & Action (T&A) calendar. Negative values indicate days after ex-factory.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the specific test method, protocol, or standard operating procedure (SOP) used for this gate (e.g., AATCC 61, ISO 105-C06, ASTM D1230). Applicable for lab test and inspection gates.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Order Fulfillment Id' ;
    rdfs:comment 'Foreign key linking to order.fulfillment. Business justification: Quality holds block warehouse fulfillment execution when defects detected during pick/pack. WMS integration enforces hold at fulfillment level to prevent shipment of non-conforming inventory to custom' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fulfillment .

ind:rtvOrderId rdf:type rdf:Property ;
    rdfs:label 'Rtv Order Id' ;
    rdfs:comment 'Foreign key linking to sourcing.rtv_order. Business justification: Holds trigger RTVs when disposition is return-to-vendor. Direct workflow link between quality hold decision and sourcing RTV execution for vendor returns.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtvOrder .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the final disposition decision was made and executed, marking the resolution of the quality hold.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the quality hold was placed on the goods, marking the start of the hold period and blocking inventory movement.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labTestReportNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Test Report Number' ;
    rdfs:comment 'Reference number for the laboratory test report if the hold was triggered by physical, chemical, or performance test failure (e.g., colorfastness, flammability, chemical content).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHold rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hold' ;
    rdfs:comment 'Quantity of goods placed on hold, measured in the unit of measure appropriate to the material type (units for finished goods, yards/meters for fabric, pieces for trims).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Date when re-inspection of the held goods was performed after rework or corrective action.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Flag indicating whether the goods must undergo re-inspection after rework or corrective action before the hold can be released.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinspectionResult rdf:type rdf:Property ;
    rdfs:label 'Reinspection Result' ;
    rdfs:comment 'Result of the re-inspection: passed (goods approved), failed (hold continues or disposition changes), or conditional pass (approved with specific usage restrictions).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Specific conditions or corrective actions required before the hold can be released, such as rework completion, re-inspection passing, lab test approval, or supplier corrective action plan acceptance.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Unique identifier for the supplier or factory that produced the goods on hold, enabling supplier performance tracking and corrective action follow-up.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Wms Block Flag' ;
    rdfs:comment 'System flag indicating whether the held goods are blocked in the WMS, preventing picking, shipping, or transfer transactions until the hold is released.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version number of the BOM (Bill of Materials) used to produce this sample. Identifies the specific material and component specifications.' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorComments rdf:type rdf:Property ;
    rdfs:label 'Color Comments' ;
    rdfs:comment 'Feedback on color accuracy, consistency, and match to approved color standards. Includes assessment of dye quality, color fastness, and shade variation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition decision for the sample after evaluation is complete. Retain (keep for reference), Archive (long-term storage), Destroy (dispose), RTV (Return to Vendor).' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the formal sample evaluation was conducted. Represents the principal business event timestamp for the evaluation process.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationDecision rdf:type rdf:Property ;
    rdfs:label 'Evaluation Decision' ;
    rdfs:comment 'Final outcome of the sample evaluation. Pass (approved for next stage), Fail (rejected, requires rework), Conditional (approved with amendments required).' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Classification of the evaluation activity performed on the sample. Fit session (fit and construction), aesthetic review (design and appearance), PP approval (pre-production sign-off), TOP approval (top of production sign-off), lab test (physical testing), compliance check (regulatory verification).' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'Target date by which the sample is expected to arrive at the evaluation facility. Used for T&A (Time and Action) calendar planning and milestone tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricHandComments rdf:type rdf:Property ;
    rdfs:label 'Fabric Hand Comments' ;
    rdfs:comment 'Feedback on the tactile quality and drape of the fabric, including texture, weight, softness, and overall hand feel. Assesses material quality and suitability.' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalComments rdf:type rdf:Property ;
    rdfs:label 'General Comments' ;
    rdfs:comment 'Additional observations, notes, or feedback about the sample that do not fit into specific evaluation categories. Provides context and supplementary information.' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the individual who initiated the sample request. Typically a product developer, designer, or merchandiser.' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredAmendments rdf:type rdf:Property ;
    rdfs:label 'Required Amendments' ;
    rdfs:comment 'Detailed list of corrections, modifications, or improvements required before the sample can be approved. Used when evaluation decision is conditional or fail.' ;
    rdfs:domain ind:QualitySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Standard Id' ;
    rdfs:comment 'Reference to the quality_standard_id of the newer standard version that supersedes this one. Null if this is the current active version. Enables version lineage tracking.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Standard .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Sales channels or distribution methods to which this quality standard applies (e.g., DTC (Direct-to-Consumer), wholesale, e-commerce, retail stores). Enables channel-specific quality requirements.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Geographic markets or regions where this quality standard is required or applicable (e.g., USA, EU, APAC, Global). Uses 3-letter ISO country codes or region identifiers.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Categories' ;
    rdfs:comment 'Comma-separated list or description of product categories to which this quality standard applies (e.g., apparel, footwear, accessories, children\'s wear, sleepwear). Drives automatic quality workflow setup for new styles.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionThreshold rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Threshold' ;
    rdfs:comment 'Threshold or trigger condition that mandates corrective action when non-conformance to this standard is detected (e.g., defect rate exceeds AQL, critical safety failure, repeated minor defects). Drives CAPA (Corrective and Preventive Action) workflows.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Estimated cost impact of complying with this quality standard on product COGS (Cost of Goods Sold) or operational expenses (e.g., high for extensive lab testing, low for documentation-only requirements).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'Description of documentation that must be maintained or submitted to demonstrate compliance with this quality standard (e.g., test reports, certificates of conformity, audit reports, material safety data sheets, traceability records).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Required frequency of quality inspections mandated by this standard (e.g., per batch, per shipment, random sampling). Drives inspection scheduling in the T&A (Time and Action) calendar. [ENUM-REF-CANDIDATE: per_batch|per_shipment|per_style|per_season|random|continuous|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or identifier of the internal business role, department, or individual responsible for maintaining and enforcing this quality standard (e.g., Quality Assurance Manager, Compliance Director, Product Safety Team).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether compliance with this quality standard is mandatory (true) or voluntary (false) for the applicable product categories and markets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryLabTests rdf:type rdf:Property ;
    rdfs:label 'Mandatory Lab Tests' ;
    rdfs:comment 'Comma-separated list of laboratory test protocols required by this quality standard (e.g., colorfastness, tensile strength, flammability, chemical residue analysis, pH testing). Configures lab test workflows in SMS (Sample Management System).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppSampleApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Required' ;
    rdfs:comment 'Indicates whether this quality standard requires formal approval of PP (Pre-Production) samples before bulk production can commence. Drives quality gates in the T&A calendar.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Document Url' ;
    rdfs:comment 'URL or file path to the authoritative reference document, standard specification, or regulatory text for this quality standard. Enables direct access to source documentation.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Legal or regulatory framework that mandates or influences this quality standard (e.g., CPSC 16 CFR 1610, FTC Textile Fiber Products Identification Act, EU REACH Regulation 1907/2006). Null for voluntary standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of certifications that must be obtained to comply with this quality standard (e.g., OEKO-TEX Standard 100, GOTS Organic, WRAP Facility Certification). Drives audit and certification tracking.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvDispositionRule rdf:type rdf:Property ;
    rdfs:label 'Rtv Disposition Rule' ;
    rdfs:comment 'Rule governing RTV (Return to Vendor) disposition when products fail to meet this quality standard (e.g., automatic RTV for critical defects, conditional RTV for minor defects, no RTV allowed). Drives supply chain and vendor management workflows.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Integration Flag' ;
    rdfs:comment 'Indicates whether this quality standard is integrated with the SMS (Sample Management System) for automated sample tracking, test result capture, and approval workflows.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Functional category grouping the standard by its primary compliance or quality domain (e.g., textile safety, chemical compliance, labor standards). [ENUM-REF-CANDIDATE: textile_safety|chemical_compliance|labor_standards|environmental|product_safety|flammability|labeling|organic|sustainability|general_quality — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Unique business identifier for the quality standard (e.g., OEKO-TEX-100, GOTS-5.0, CPSC-FLAM, ISO-9001). Used for external reference and system integration.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Full descriptive name of the quality standard (e.g., OEKO-TEX Standard 100 Textile Safety Certification, Global Organic Textile Standard Version 5.0).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardStatus rdf:type rdf:Property ;
    rdfs:label 'Standard Status' ;
    rdfs:comment 'Current lifecycle status of the quality standard within the organization\'s quality management system.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardType rdf:type rdf:Property ;
    rdfs:label 'Standard Type' ;
    rdfs:comment 'Classification of the quality standard by its nature and purpose within the quality management framework.' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Required' ;
    rdfs:comment 'Indicates whether suppliers must be pre-qualified or certified to meet this quality standard before they can be approved for production (e.g., WRAP certification, OEKO-TEX facility approval).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Description of training or competency requirements for personnel involved in activities governed by this quality standard (e.g., quality inspector certification, lab technician training, auditor qualification).' ;
    rdfs:domain ind:Standard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvDispositionId rdf:type rdf:Property ;
    rdfs:label 'Rtv Disposition Id' ;
    rdfs:comment 'Unique identifier for the RTV disposition record. Primary key.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Financial credit amount expected or issued by the supplier for the returned goods. Represents the monetary value of the RTV.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Date' ;
    rdfs:comment 'Date when the supplier issued the financial credit for the returned goods. Triggers accounts payable adjustment and financial reconciliation.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionInstructions rdf:type rdf:Property ;
    rdfs:label 'Disposition Instructions' ;
    rdfs:comment 'Detailed instructions for handling the RTV, including packaging requirements, shipping instructions, documentation needed, and any special handling notes.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current lifecycle status of the RTV disposition process. Tracks progression from initiation through closure. [ENUM-REF-CANDIDATE: initiated|approved|in_transit|received_by_vendor|credit_issued|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsCarrier rdf:type rdf:Property ;
    rdfs:label 'Logistics Carrier' ;
    rdfs:comment 'Name of the shipping carrier or third-party logistics (3PL) provider handling the return shipment to the vendor.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPoNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Po Number' ;
    rdfs:comment 'Purchase order number for replacement goods, if the RTV type is replacement. Links to the new procurement transaction for substitute inventory.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Date' ;
    rdfs:comment 'Date when the goods were physically shipped back to the vendor.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Tracking Number' ;
    rdfs:comment 'Tracking number for the return shipment. Used to monitor the physical movement of goods back to the supplier.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Rtv Authorization Number' ;
    rdfs:comment 'Externally-known unique authorization number issued for this return-to-vendor transaction. Used for tracking and supplier communication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvType rdf:type rdf:Property ;
    rdfs:label 'Rtv Type' ;
    rdfs:comment 'Classification of the RTV disposition action. Defines whether goods are physically returned, credited without return, replaced, repaired, or scrapped.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledgment Date' ;
    rdfs:comment 'Date when the supplier formally acknowledged the RTV authorization. Marks the start of the return logistics process.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the supplier has acknowledged receipt of the RTV authorization and agreed to the disposition terms. True if acknowledged, False otherwise.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorDebitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Debit Memo Number' ;
    rdfs:comment 'Debit memo number issued to the supplier for the financial charge-back associated with this RTV. Links to finance domain for accounts payable adjustment.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Warehouse or distribution center location code where the non-conforming goods were held prior to RTV disposition.' ;
    rdfs:domain ind:RtvDisposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Developer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fabric development is led by textile developers who manage lab dips, strike-offs, and bulk approvals. Tracks ownership for fabric innovation, quality issues, and development timelines. Normalizes deno' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bulkApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Approval Date' ;
    rdfs:comment 'Date when the fabric received final bulk approval. Enables procurement to issue Purchase Orders (PO) for production yardage.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bulkApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Bulk Approval Status' ;
    rdfs:comment 'Final approval status for bulk production of the fabric. Indicates whether the fabric is cleared for large-scale manufacturing and Purchase Order (PO) placement.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkYardageCommitment rdf:type rdf:Property ;
    rdfs:label 'Bulk Yardage Commitment' ;
    rdfs:comment 'Total yardage or meterage of fabric committed for bulk production. Used for capacity planning and Minimum Order Quantity (MOQ) negotiations with the mill.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentSeason rdf:type rdf:Property ;
    rdfs:label 'Development Season' ;
    rdfs:comment 'The target season for which this fabric is being developed. Format: SS (Spring/Summer), FW (Fall/Winter), SP (Spring), FA (Fall) followed by two-digit year (e.g., SS24, FW25).' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricCode rdf:type rdf:Property ;
    rdfs:label 'Fabric Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the fabric for system identification and cross-referencing across Product Lifecycle Management (PLM) and Enterprise Resource Planning (ERP) systems.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricConstruction rdf:type rdf:Property ;
    rdfs:label 'Fabric Construction' ;
    rdfs:comment 'Technical description of the fabric structure including weave type, knit pattern, or construction method (e.g., plain weave, twill, jersey knit, rib knit, interlock).' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricName rdf:type rdf:Property ;
    rdfs:label 'Fabric Name' ;
    rdfs:comment 'Business name or marketing name assigned to the fabric being developed. Used for identification in collection planning and merchandising.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricWeight rdf:type rdf:Property ;
    rdfs:label 'Fabric Weight' ;
    rdfs:comment 'Weight of the fabric measured in grams per square meter (GSM) or ounces per square yard. Critical specification for product costing and performance characteristics.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricWidth rdf:type rdf:Property ;
    rdfs:label 'Fabric Width' ;
    rdfs:comment 'Width of the fabric measured in inches or centimeters. Standard widths impact cutting efficiency and Bill of Materials (BOM) calculations.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberBlend rdf:type rdf:Property ;
    rdfs:label 'Fiber Blend' ;
    rdfs:comment 'Composition of fibers used in the fabric with percentages (e.g., 60% Cotton 40% Polyester, 100% Organic Cotton). Must comply with Federal Trade Commission (FTC) fiber content labeling requirements.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labDipApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Approval Date' ;
    rdfs:comment 'Date when the lab dip color sample was approved by the design or product development team. Critical milestone in the TNA calendar.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labDipStatus rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Status' ;
    rdfs:comment 'Approval status of the lab dip color sample. Lab dip is the initial small-scale color sample submitted by the mill for color approval before bulk production.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labDipSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Submission Date' ;
    rdfs:comment 'Date when the lab dip color sample was submitted by the mill for review. Used to track Time and Action (TNA) calendar milestones.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:millReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mill Reference Number' ;
    rdfs:comment 'The mills internal reference or article number for this fabric. Used for communication and ordering with the supplier.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure for the Minimum Order Quantity (MOQ) - may be linear measure (yards/meters) or weight (kg) depending on mill requirements.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionRound rdf:type rdf:Property ;
    rdfs:label 'Submission Round' ;
    rdfs:comment 'Sequential number indicating which iteration of fabric submission this represents. Tracks the number of times the mill has resubmitted samples for approval.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetHandFeel rdf:type rdf:Property ;
    rdfs:label 'Target Hand Feel' ;
    rdfs:comment 'Desired tactile characteristics and drape of the fabric as specified by the design team (e.g., soft, crisp, fluid, structured, brushed).' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Summary of physical and chemical test results performed on the fabric (e.g., colorfastness, shrinkage, pilling resistance, tensile strength). Links to detailed lab test reports.' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthUnit rdf:type rdf:Property ;
    rdfs:label 'Width Unit' ;
    rdfs:comment 'Unit of measure for fabric width (inches or centimeters).' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardageUnit rdf:type rdf:Property ;
    rdfs:label 'Yardage Unit' ;
    rdfs:comment 'Unit of measure for bulk yardage commitment (yards or meters).' ;
    rdfs:domain ind:FabricDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labDipId rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Id' ;
    rdfs:comment 'Unique identifier for the lab dip approval record. Primary key for tracking color development and approval process for fabric or material.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLabA rdf:type rdf:Property ;
    rdfs:label 'Actual Lab A' ;
    rdfs:comment 'Measured green-red axis value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLabB rdf:type rdf:Property ;
    rdfs:label 'Actual Lab B' ;
    rdfs:comment 'Measured blue-yellow axis value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLabL rdf:type rdf:Property ;
    rdfs:label 'Actual Lab L' ;
    rdfs:comment 'Measured lightness value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorStandardType rdf:type rdf:Property ;
    rdfs:label 'Color Standard Type' ;
    rdfs:comment 'Type of color standard used for matching specification (Pantone, LAB values, RGB, CMYK, or physical swatch).' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deltaEValue rdf:type rdf:Property ;
    rdfs:label 'Delta E Value' ;
    rdfs:comment 'Calculated color difference (Delta E) between target and actual color. Lower values indicate closer match. Typically acceptable range is Delta E < 1.0 for critical color matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalImageUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Image Url' ;
    rdfs:comment 'URL link to digital photograph or scan of the lab dip sample. Enables remote review and digital archiving.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dyeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Dye Lot Number' ;
    rdfs:comment 'Batch identifier for the dye lot used in this lab dip submission. Critical for traceability and consistency in bulk production.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dyeRecipeCode rdf:type rdf:Property ;
    rdfs:label 'Dye Recipe Code' ;
    rdfs:comment 'Code identifying the specific dye formulation and recipe used for this color. Links to dye house technical specifications.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStrikeOffRequired rdf:type rdf:Property ;
    rdfs:label 'Is Strike Off Required' ;
    rdfs:comment 'Boolean flag indicating whether a larger strike-off sample (printed or dyed fabric yardage) is required after lab dip approval before bulk production commitment.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labDipNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Number' ;
    rdfs:comment 'Business identifier for the lab dip submission. Externally-known reference number used across PLM systems and vendor communications.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightFastnessGrade rdf:type rdf:Property ;
    rdfs:label 'Light Fastness Grade' ;
    rdfs:comment 'Grade (1-8 scale) measuring resistance to color change from light exposure. Grade 8 is excellent, grade 1 is poor.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pantoneReference rdf:type rdf:Property ;
    rdfs:label 'Pantone Reference' ;
    rdfs:comment 'Pantone color standard reference code used as the target color specification for matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePhysicalLocation rdf:type rdf:Property ;
    rdfs:label 'Sample Physical Location' ;
    rdfs:comment 'Physical storage location of the lab dip sample swatch (e.g., design studio, quality lab, archive). Used for sample retrieval and reference.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrophotometerReadingFile rdf:type rdf:Property ;
    rdfs:label 'Spectrophotometer Reading File' ;
    rdfs:comment 'File path or reference to the spectrophotometer measurement data file. Contains detailed color measurement data for technical analysis.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBulkProductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Bulk Production Date' ;
    rdfs:comment 'Planned date for bulk fabric production to begin. Drives urgency of lab dip approval process within TNA calendar.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetLabA rdf:type rdf:Property ;
    rdfs:label 'Target Lab A' ;
    rdfs:comment 'Target green-red axis value in CIELAB color space. Negative values indicate green, positive indicate red.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLabB rdf:type rdf:Property ;
    rdfs:label 'Target Lab B' ;
    rdfs:comment 'Target blue-yellow axis value in CIELAB color space. Negative values indicate blue, positive indicate yellow.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLabL rdf:type rdf:Property ;
    rdfs:label 'Target Lab L' ;
    rdfs:comment 'Target lightness value in CIELAB color space (0-100 scale). Used for precise color measurement and matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washFastnessGrade rdf:type rdf:Property ;
    rdfs:label 'Wash Fastness Grade' ;
    rdfs:comment 'Grade (1-5 scale) measuring resistance to color change from washing. Grade 5 is excellent, grade 1 is poor.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeProfileId rdf:type rdf:Property ;
    rdfs:label 'Lead Time Profile Id' ;
    rdfs:comment 'Unique identifier for the lead time profile record.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether the supplier has capacity constraints for this product category that may affect lead time variability.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Lead Time Days' ;
    rdfs:comment 'Number of days required for customs clearance, duty payment, and import documentation processing.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fobPortCode rdf:type rdf:Property ;
    rdfs:label 'Fob Port Code' ;
    rdfs:comment 'Code identifying the port of loading where goods are handed over to the carrier under FOB terms.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSourcingLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Material Sourcing Lead Time Days' ;
    rdfs:comment 'Number of days required to source and procure raw materials, fabrics, and trims from mills and vendors.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppApprovalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Lead Time Days' ;
    rdfs:comment 'Number of days required for pre-production sample approval workflow including fit, construction, and material compliance evaluation.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Production Lead Time Days' ;
    rdfs:comment 'Number of days required for bulk production including cutting, making, and trimming (CMT) operations.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Descriptive name for the lead time profile to facilitate identification and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lead Time Days' ;
    rdfs:comment 'Number of days allocated for quality inspection and compliance testing before shipment.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Quality standard or certification requirement applicable to this lead time profile (e.g., ISO 9001, AQL 2.5).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDevelopmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sample Development Lead Time Days' ;
    rdfs:comment 'Number of days required for sample development, submission, and evaluation through the Sample Management System (SMS).' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingTransitLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Shipping Transit Lead Time Days' ;
    rdfs:comment 'Number of days required for freight transportation from Free on Board (FOB) port to destination warehouse or distribution center.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Required' ;
    rdfs:comment 'Indicates whether sustainability certifications (OEKO-TEX, GOTS, BCI) are required for this supplier-category combination, which may impact lead time.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Total Lead Time Days' ;
    rdfs:comment 'Total end-to-end lead time in days from order placement to delivery at destination, including all component lead times and buffers.' ;
    rdfs:domain ind:LeadTimeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Materials are sourced by fabric/trim buyers who negotiate with mills. Tracks accountability for material selection, sustainability compliance, and cost negotiations. Essential for performance metrics ' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierMaterialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Supplier Id' ;
    rdfs:comment 'Reference to the approved mill or supplier from whom this material is sourced. Links to supplier master data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierMaterialSupplier .

ind:bciCotton rdf:type rdf:Property ;
    rdfs:label 'Bci Cotton' ;
    rdfs:comment 'Indicates whether the material contains cotton sourced through the Better Cotton Initiative for sustainable cotton farming.' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Unit' ;
    rdfs:comment 'Unit of measure for the unit cost (e.g., per yard, per meter, per kilogram, per piece).' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberContent rdf:type rdf:Property ;
    rdfs:label 'Fiber Content' ;
    rdfs:comment 'Composition of the material by fiber type and percentage (e.g., \'100% Organic Cotton\', \'65% Polyester 35% Cotton\', \'Metal: Brass\'). Required for FTC textile labeling compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gotsCompliant rdf:type rdf:Property ;
    rdfs:label 'Gots Compliant' ;
    rdfs:comment 'Indicates whether the material meets Global Organic Textile Standard (GOTS) requirements for organic fiber content and sustainable processing.' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Date' ;
    rdfs:comment 'Date when the material received Pre-Production approval. Key milestone in the Time and Action (TNA) calendar.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Status' ;
    rdfs:comment 'Pre-Production approval status for the material. Indicates whether the material has passed quality and specification review for production use.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAvailable rdf:type rdf:Property ;
    rdfs:label 'Sample Available' ;
    rdfs:comment 'Indicates whether a physical sample of this material is available in the Sample Management System (SMS) for design review and approval.' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Reference Number' ;
    rdfs:comment 'Reference number for the physical sample in the Sample Management System (SMS) if available.' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportAvailable rdf:type rdf:Property ;
    rdfs:label 'Test Report Available' ;
    rdfs:comment 'Indicates whether lab test reports (e.g., colorfastness, shrinkage, tensile strength) are available for this material.' ;
    rdfs:domain ind:SourcingMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:widthInches rdf:type rdf:Property ;
    rdfs:label 'Width Inches' ;
    rdfs:comment 'Usable width of the fabric material measured in inches. Critical for yield calculation and cutting efficiency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor or mill that was selected and awarded the business as a result of this RFQ evaluation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date when the RFQ was awarded to the selected vendor.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedQuoteAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Quote Amount' ;
    rdfs:comment 'The final quoted unit price from the awarded vendor.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Any regulatory, labor, or ethical compliance requirements that vendors must meet (e.g., WRAP certification, FLA compliance, CPSC safety standards).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume' ;
    rdfs:comment 'The anticipated total order volume or quantity that may be placed if the RFQ results in an award.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricComposition rdf:type rdf:Property ;
    rdfs:label 'Fabric Composition' ;
    rdfs:comment 'The fiber content and blend percentages for fabric RFQs (e.g., 80% Cotton 20% Polyester).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Quote Received Count' ;
    rdfs:comment 'The number of vendor quotations received in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business-facing unique identifier for the RFQ, used in vendor communications and sourcing documentation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ: draft (being prepared), issued (sent to vendors), under evaluation (quotes received and being reviewed), awarded (vendor selected), closed (process complete), cancelled (RFQ withdrawn).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on sourcing scope: CMT (Cut Make Trim), FOB (Free on Board), material procurement, trim sourcing, fabric sourcing, or full package manufacturing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Required Flag' ;
    rdfs:comment 'Indicates whether vendors are required to submit physical samples as part of their quotation response.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Sample Submission Deadline' ;
    rdfs:comment 'The deadline by which vendors must submit physical samples if required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcingRegion rdf:type rdf:Property ;
    rdfs:label 'Sourcing Region' ;
    rdfs:comment 'The geographic region being targeted for sourcing through this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleReference rdf:type rdf:Property ;
    rdfs:label 'Style Reference' ;
    rdfs:comment 'The style number or design reference code that this RFQ is requesting quotes for.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The final date by which vendors must submit their quotations in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityRequirement rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirement' ;
    rdfs:comment 'Any sustainability or certification requirements specified in the RFQ (e.g., GOTS certified, BCI cotton, OEKO-TEX Standard 100, recycled materials, organic).' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCost rdf:type rdf:Property ;
    rdfs:label 'Target Cost' ;
    rdfs:comment 'The desired or budgeted unit cost that the business is aiming to achieve through this RFQ process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalPackReference rdf:type rdf:Property ;
    rdfs:label 'Technical Pack Reference' ;
    rdfs:comment 'Reference to the technical specification document or tech pack that provides detailed construction, measurement, and material specifications for the RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCount rdf:type rdf:Property ;
    rdfs:label 'Vendor Count' ;
    rdfs:comment 'The number of vendors or mills to whom this RFQ has been issued.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomReference rdf:type rdf:Property ;
    rdfs:label 'Bom Reference' ;
    rdfs:comment 'Reference to the Bill of Materials document listing all components, fabrics, and trims required for this style.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Notes' ;
    rdfs:comment 'Internal notes from the buyer or sourcing team regarding special requirements, constraints, or context for this line item.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderClassification rdf:type rdf:Property ;
    rdfs:label 'Gender Classification' ;
    rdfs:comment 'Target gender demographic for the product. Used for merchandising planning and assortment allocation.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingRequirement rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirement' ;
    rdfs:comment 'Packaging specifications for this line item. Includes polybag requirements, hangtags, labels, carton specifications, and shipping marks.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBreakTier1 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 1' ;
    rdfs:comment 'First quantity threshold for tiered pricing. Vendors provide different unit costs based on volume commitments.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBreakTier2 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 2' ;
    rdfs:comment 'Second quantity threshold for tiered pricing. Enables cost comparison across different volume scenarios.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBreakTier3 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 3' ;
    rdfs:comment 'Third quantity threshold for tiered pricing. Supports complex volume-based sourcing strategies.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which vendors must submit their quotations for this line item. Critical for Time and Action (TNA) calendar management.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCmtCost rdf:type rdf:Property ;
    rdfs:label 'Target Cmt Cost' ;
    rdfs:comment 'Target CMT cost per unit for manufacturing services only. Excludes material costs, represents labor and production overhead.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFobCost rdf:type rdf:Property ;
    rdfs:label 'Target Fob Cost' ;
    rdfs:comment 'Target FOB cost per unit that the buyer is seeking from vendors. Represents the price at the port of origin before shipping.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingRequirement rdf:type rdf:Property ;
    rdfs:label 'Testing Requirement' ;
    rdfs:comment 'Laboratory testing requirements for materials or finished goods. May include colorfastness, shrinkage, pilling, flammability, or chemical content testing.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Notes' ;
    rdfs:comment 'Notes or comments provided by vendors in their quotation response. May include production constraints, alternative suggestions, or clarification requests.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Status' ;
    rdfs:comment 'Current status of vendor responses for this RFQ line. Tracks the quotation lifecycle from request through vendor selection.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Credit Amount' ;
    rdfs:comment 'Actual credit amount issued by the vendor after inspection and approval of returned goods.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditDisposition rdf:type rdf:Property ;
    rdfs:label 'Credit Disposition' ;
    rdfs:comment 'Vendor decision on how the return will be credited or resolved.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditIssueDate rdf:type rdf:Property ;
    rdfs:label 'Credit Issue Date' ;
    rdfs:comment 'Date when the vendor issued the credit memo for the returned goods.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Credit Amount' ;
    rdfs:comment 'Expected credit amount to be issued by the vendor for the returned goods.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightResponsibility rdf:type rdf:Property ;
    rdfs:label 'Freight Responsibility' ;
    rdfs:comment 'Party responsible for bearing the freight cost of the return shipment.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Reference' ;
    rdfs:comment 'Reference number of the quality inspection report documenting the defects or non-conformance.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectCategory rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Category' ;
    rdfs:comment 'Classification of the quality defect type when return is due to quality issues.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'Date when the vendor is requested to pick up or receive the returned goods.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtvDate rdf:type rdf:Property ;
    rdfs:label 'Rtv Date' ;
    rdfs:comment 'Date when the RTV order was created and initiated in the system.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtvNumber rdf:type rdf:Property ;
    rdfs:label 'Rtv Number' ;
    rdfs:comment 'Externally-known unique business identifier for the RTV order used in vendor communication and tracking.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvStatus rdf:type rdf:Property ;
    rdfs:label 'Rtv Status' ;
    rdfs:comment 'Current lifecycle status of the RTV order in the return workflow process. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|received_by_vendor|credit_issued|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReturnQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Return Quantity' ;
    rdfs:comment 'Total quantity of units being returned to the vendor across all line items.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturnValue rdf:type rdf:Property ;
    rdfs:label 'Total Return Value' ;
    rdfs:comment 'Total monetary value of all goods being returned to the vendor.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Receipt Date' ;
    rdfs:comment 'Date when the vendor confirmed receipt of the returned goods.' ;
    rdfs:domain ind:RtvOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Sample Evaluation Id' ;
    rdfs:comment 'Primary key for sample_evaluation' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Color Accuracy Score' ;
    rdfs:comment 'Assessment of color match against approved lab dip or color standard. Evaluates color consistency across all materials and components.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Construction Quality Score' ;
    rdfs:comment 'Assessment of garment construction quality including seam quality, stitching consistency, finishing, and workmanship. Evaluates adherence to construction specifications in tech pack.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed list of specific corrective actions the supplier must take to address evaluation findings. Provides clear direction for sample revision.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Duration Minutes' ;
    rdfs:comment 'Time spent conducting the evaluation in minutes. Used for resource planning and process efficiency analysis.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'General notes and observations from the evaluation that do not fit into specific category comments. Captures additional context and evaluator insights.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the evaluation record. Externally visible evaluation tracking number used in communications with suppliers and internal teams.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the evaluation. Pending = awaiting evaluator assignment, In Progress = evaluation underway, Approved = sample meets all requirements, Approved with Comments = sample acceptable with minor notes, Rejected = sample fails requirements and must be revised, On Hold = evaluation paused pending additional information.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Full name of the person who conducted the evaluation. Captured for audit trail and communication purposes.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorRole rdf:type rdf:Property ;
    rdfs:label 'Evaluator Role' ;
    rdfs:comment 'Functional role of the evaluator. Determines evaluation focus area and approval authority level.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Score' ;
    rdfs:comment 'Overall assessment of garment fit against technical specifications. Pass = meets all fit requirements, Fail = significant fit issues, Acceptable = minor fit deviations within tolerance, Needs Improvement = fit issues requiring correction.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComments rdf:type rdf:Property ;
    rdfs:label 'Material Comments' ;
    rdfs:comment 'Detailed notes on material compliance including fabric hand feel, weight deviations, trim substitutions, and any material quality concerns. Documents material approval or rejection reasons.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Material Compliance Score' ;
    rdfs:comment 'Assessment of whether materials used match approved specifications. Evaluates fabric type, weight, composition, and trim components against Bill of Materials (BOM).' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementComments rdf:type rdf:Property ;
    rdfs:label 'Measurement Comments' ;
    rdfs:comment 'Detailed documentation of specific measurement points that deviate from specifications, including actual vs. target measurements and tolerance analysis.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Deviation Flag' ;
    rdfs:comment 'Indicates whether any measurements fall outside acceptable tolerance ranges defined in the tech pack. True = deviations exist, False = all measurements within tolerance.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallApprovalDecision rdf:type rdf:Property ;
    rdfs:label 'Overall Approval Decision' ;
    rdfs:comment 'Final approval decision for the sample. Approved = sample passes all criteria and can proceed to production, Approved with Comments = sample acceptable with documented notes, Rejected = sample fails and requires revision.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Flag' ;
    rdfs:comment 'Indicates whether photographic documentation was captured during evaluation. True = photos attached, False = no photos. Photos are critical for communicating issues to suppliers.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Flag' ;
    rdfs:comment 'Indicates whether this evaluation resulted in Pre-Production (PP) approval, which authorizes the supplier to proceed with bulk production. True = PP approved, False = PP not approved.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Category' ;
    rdfs:comment 'Primary category of rejection when sample is not approved. Helps categorize supplier performance issues and track common failure modes. [ENUM-REF-CANDIDATE: fit|construction|material|color|measurement|workmanship|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required Flag' ;
    rdfs:comment 'Indicates whether supplier must resubmit a revised sample. True = resubmission required, False = no resubmission needed (approved or approved with minor comments).' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Notified Date' ;
    rdfs:comment 'Date when evaluation results were communicated to the supplier. Tracks communication timeliness and supplier response time.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetResubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resubmission Date' ;
    rdfs:comment 'Expected date for supplier to resubmit revised sample. Drives Time and Action (TNA) calendar updates and production timeline management.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sample requests are initiated by product development or design employees. Tracks who requested proto/PP/SMS samples for accountability in sample management, cost allocation, and development timeline t' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final approval decision for the sample: approved (sample meets all requirements and production can proceed), approved_with_comments (sample acceptable with minor notes for production), rejected (sample does not meet requirements and must be revised).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorAccuracyEvaluation rdf:type rdf:Property ;
    rdfs:label 'Color Accuracy Evaluation' ;
    rdfs:comment 'Assessment of how accurately the sample color matches the approved lab dip or Pantone standard, including any color correction instructions.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionEvaluationComments rdf:type rdf:Property ;
    rdfs:label 'Construction Evaluation Comments' ;
    rdfs:comment 'Evaluation comments on the construction quality of the sample, including seam quality, stitching, finishing, and adherence to construction specifications in the tech pack.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Factory Submission Date' ;
    rdfs:comment 'Actual date when the factory submitted the sample for evaluation.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitEvaluationComments rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Comments' ;
    rdfs:comment 'Detailed comments from the fit evaluation session describing how the sample fits on the fit model, including any adjustments needed to silhouette, ease, or proportions.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialFabricReference rdf:type rdf:Property ;
    rdfs:label 'Material Fabric Reference' ;
    rdfs:comment 'Reference code for the fabric used in the sample, linking to the material library in PLM system for fabric specifications and sourcing details.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementConformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Conformance Status' ;
    rdfs:comment 'Indicates whether the sample measurements conform to the tech pack specifications: pass (all measurements within tolerance), fail (critical measurements out of spec), within_tolerance (acceptable variance), out_of_spec (unacceptable variance).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDeviationDetails rdf:type rdf:Property ;
    rdfs:label 'Measurement Deviation Details' ;
    rdfs:comment 'Specific details of any measurement deviations from tech pack specifications, including which measurements are out of tolerance and by how much.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLocation rdf:type rdf:Property ;
    rdfs:label 'Recipient Location' ;
    rdfs:comment 'Office or facility location where the sample should be delivered (e.g., headquarters, regional office, showroom).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the sample request, externally visible and used for tracking and communication with factories and internal teams.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the sample request: draft (being prepared), submitted (sent to factory), in_production (factory is making sample), shipped (sample in transit), received (sample arrived), under_evaluation (being evaluated), approved (evaluation complete and approved), rejected (evaluation complete and rejected), cancelled (request cancelled). [ENUM-REF-CANDIDATE: draft|submitted|in_production|shipped|received|under_evaluation|approved|rejected|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCostFob rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Fob' ;
    rdfs:comment 'Cost charged by the factory for producing the sample on a FOB (Free on Board) basis, used for budgeting and cost tracking.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimReference rdf:type rdf:Property ;
    rdfs:label 'Trim Reference' ;
    rdfs:comment 'Reference codes for trims and accessories used in the sample (buttons, zippers, labels, etc.), linking to the material library.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Employee Id' ;
    rdfs:comment 'Reference to the internal buyer or sourcing manager responsible for negotiating and managing this agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementSourcingAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Sourcing Agent Employee Id' ;
    rdfs:comment 'Reference to the third-party sourcing agent or buying office involved in this agreement, if applicable.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the sourcing agreement for easy identification and reference by business users.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the sourcing agreement, used in vendor communications and contract references.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the sourcing agreement indicating its operational state and enforceability. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the sourcing agreement based on its strategic purpose and scope. Master agreements cover multiple seasons, seasonal agreements are collection-specific, spot agreements are one-time purchases, blanket agreements provide volume commitments, framework agreements establish terms for future orders, and exclusive agreements grant sole sourcing rights.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCmtRate rdf:type rdf:Property ;
    rdfs:label 'Base Cmt Rate' ;
    rdfs:comment 'The baseline Cut Make Trim labor rate per unit negotiated in this agreement for manufacturing services.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFobPrice rdf:type rdf:Property ;
    rdfs:label 'Base Fob Price' ;
    rdfs:comment 'The baseline Free On Board unit price negotiated in this agreement before volume discounts or surcharges are applied.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Percent' ;
    rdfs:comment 'The percentage of the vendors production capacity allocated or reserved for the buyer under this agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Quantity' ;
    rdfs:comment 'The total volume or quantity of goods that the buyer commits to source from the vendor under this agreement, used for volume guarantee negotiations.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'The destination port or distribution center where goods will be delivered under this agreement.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the scope of exclusivity if applicable, detailing which products, categories, or geographic regions are covered by the exclusive arrangement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of penalties or liquidated damages applicable for breach of agreement terms, such as failure to meet volume commitments or quality standards.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierStructure rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Structure' ;
    rdfs:comment 'Description of the volume-based pricing tiers negotiated in this agreement, detailing quantity breaks and corresponding unit prices or discount percentages.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The number of days advance notice required to terminate or opt out of auto-renewal of this agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of the conditions and procedures under which either party may terminate this agreement before its natural expiration.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'The unit of measure for the committed volume quantity (e.g., units, pieces, dozens, cases, pallets).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourcingAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Agent Employee Id' ;
    rdfs:comment 'Reference to the third-party sourcing agent or buying office facilitating this purchase order, if applicable.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySourcingApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sourcing Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this purchase order for submission to the vendor.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:landedCost rdf:type rdf:Property ;
    rdfs:label 'Landed Cost' ;
    rdfs:comment 'Total landed cost including product value, freight, duties, taxes, and all other costs to deliver goods to final destination. Used for true Cost of Goods Sold (COGS) calculation.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Status' ;
    rdfs:comment 'Status of pre-production (PP) sample approval for this purchase order: not_required (bulk order without sample), pending (awaiting review), approved (sample accepted), rejected (sample failed), conditional (approved with modifications).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window End Date' ;
    rdfs:comment 'Latest acceptable date for the vendor to ship goods. Defines the end of the delivery window.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window Start Date' ;
    rdfs:comment 'Earliest acceptable date for the vendor to ship goods. Defines the beginning of the delivery window.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Tna Milestone Status' ;
    rdfs:comment 'Overall status of Time and Action calendar milestones for this purchase order: on_track (meeting deadlines), at_risk (potential delay), delayed (missed milestone), completed (all milestones met).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourcingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Employee Id' ;
    rdfs:comment 'Reference to the user who created this purchase order line. Supports audit trail and accountability.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lineTotalCost rdf:type rdf:Property ;
    rdfs:label 'Line Total Cost' ;
    rdfs:comment 'The total cost for this line item, calculated as ordered quantity multiplied by unit cost. Represents the extended line value.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'The remaining quantity yet to be received for this line item. Calculated as ordered quantity minus received quantity.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkProductionStartActualDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Production Start Actual Date' ;
    rdfs:comment 'Actual date when bulk production started. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bulkProductionStartPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Production Start Planned Date' ;
    rdfs:comment 'Planned date for bulk production to commence at the factory. Follows PP approval.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Free-text explanation of the primary cause of delay if T&A is at risk or delayed. Used for root cause analysis.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exFactoryActualDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Actual Date' ;
    rdfs:comment 'Actual date when goods left the factory. Null if milestone not yet achieved.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exFactoryPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Planned Date' ;
    rdfs:comment 'Planned date for goods to leave the factory. Critical milestone for shipment and logistics planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Actual Date' ;
    rdfs:comment 'Actual date when fabric approval was completed. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Planned Date' ;
    rdfs:comment 'Planned date for fabric approval milestone. Critical pre-production milestone for material sign-off.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inDcActualDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Actual Date' ;
    rdfs:comment 'Actual date when goods arrived at the distribution center. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inDcPlannedDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Planned Date' ;
    rdfs:comment 'Planned date for goods to arrive at the distribution center. End of pre-production T&A scope.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Order Quantity' ;
    rdfs:comment 'Total quantity planned for this production run. May exceed MOQ based on demand forecast.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Actual Date' ;
    rdfs:comment 'Actual date when pre-production sample was approved. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Planned Date' ;
    rdfs:comment 'Planned date for pre-production sample approval. Gate for bulk production authorization.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Actual Date' ;
    rdfs:comment 'Actual date when pre-production sample was submitted. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSamplePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Planned Date' ;
    rdfs:comment 'Planned date for pre-production sample submission. Critical milestone for final fit and construction approval before bulk production.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaCode rdf:type rdf:Property ;
    rdfs:label 'Tna Code' ;
    rdfs:comment 'Business identifier for the Time and Action calendar. Externally-known unique code used across PLM and sourcing systems.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaStatus rdf:type rdf:Property ;
    rdfs:label 'Tna Status' ;
    rdfs:comment 'Current lifecycle status of the T&A calendar. Indicates overall health and progress of the sourcing timeline. [ENUM-REF-CANDIDATE: draft|active|on_track|at_risk|delayed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaType rdf:type rdf:Property ;
    rdfs:label 'Tna Type' ;
    rdfs:comment 'Classification of the T&A calendar type. Indicates the phase of product lifecycle this calendar governs.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Actual Date' ;
    rdfs:comment 'Actual date when trim approval was completed. Null if milestone not yet achieved.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trimApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Planned Date' ;
    rdfs:comment 'Planned date for trim and accessories approval milestone. Includes buttons, zippers, labels, and other components.' ;
    rdfs:domain ind:SourcingTnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcingTnaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Tna Milestone Id' ;
    rdfs:comment 'Unique identifier for the sourcing TNA milestone record. Primary key.' ;
    rdfs:domain ind:SourcingTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the individual who provided the approval decision. Null if approval is not required or not yet provided.' ;
    rdfs:domain ind:SourcingTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentCommission rdf:type rdf:Property ;
    rdfs:label 'Agent Commission' ;
    rdfs:comment 'Commission paid to sourcing agent or buying office per unit. Typically a percentage of FOB cost, expressed as absolute amount per unit.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsEstimate rdf:type rdf:Property ;
    rdfs:label 'Cogs Estimate' ;
    rdfs:comment 'Estimated COGS per unit including all landed costs and internal allocation of overhead. Used for financial planning and margin calculation.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:embellishmentCost rdf:type rdf:Property ;
    rdfs:label 'Embellishment Cost' ;
    rdfs:comment 'Additional cost for embellishments such as embroidery, printing, appliqué, or special finishes. Optional cost component for decorated styles.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherCharges rdf:type rdf:Property ;
    rdfs:label 'Other Charges' ;
    rdfs:comment 'Miscellaneous charges not captured in other cost components (e.g., bank fees, inspection fees, special handling). Catch-all for additional costs.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteVersion rdf:type rdf:Property ;
    rdfs:label 'Quote Version' ;
    rdfs:comment 'Version number of the cost quote. Increments with each revision as negotiations progress or specifications change. Supports cost history tracking.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetImuPercent rdf:type rdf:Property ;
    rdfs:label 'Target Imu Percent' ;
    rdfs:comment 'Target initial markup percentage for this style based on merchandising strategy. Used to validate if the quoted cost supports desired retail price and margin.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Target Retail Price' ;
    rdfs:comment 'Target retail price for this style. Used with cost quote to calculate achievable margin and validate pricing strategy.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingCertificationCost rdf:type rdf:Property ;
    rdfs:label 'Testing Certification Cost' ;
    rdfs:comment 'Cost per unit for product testing and certifications (OEKO-TEX, GOTS, CPSC compliance testing, etc.). Amortized across production quantity.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Buyer decision status on this quote. Indicates whether the quote has been accepted, rejected, or is under negotiation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkScore rdf:type rdf:Property ;
    rdfs:label 'Benchmark Score' ;
    rdfs:comment 'Comparative score assigned to this quote during vendor selection analysis. Enables objective comparison across multiple vendor quotes.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAvailableUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Available Units' ;
    rdfs:comment 'Production capacity available from the vendor for this quote period. Indicates maximum units the vendor can produce within the lead time window.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmtRate rdf:type rdf:Property ;
    rdfs:label 'Cmt Rate' ;
    rdfs:comment 'Quoted CMT rate per unit. Represents the manufacturing labor cost for cutting fabric, making the garment, and trimming/finishing, excluding material costs.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterTerms rdf:type rdf:Property ;
    rdfs:label 'Counter Terms' ;
    rdfs:comment 'Any counter-proposals, exceptions, or deviations from the original RFQ terms proposed by the vendor. Captures negotiation points.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fobPrice rdf:type rdf:Property ;
    rdfs:label 'Fob Price' ;
    rdfs:comment 'Quoted FOB price per unit. Represents the cost of goods loaded onto the shipping vessel at the port of origin, excluding freight and insurance.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpEstimate rdf:type rdf:Property ;
    rdfs:label 'Ldp Estimate' ;
    rdfs:comment 'Estimated total landed cost per unit including FOB price, freight, insurance, duties, and taxes. Provides a complete cost view for comparison.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sample Lead Time Days' ;
    rdfs:comment 'Number of days required to produce and deliver pre-production samples for approval. Critical for Sample Management System (SMS) workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolingCost rdf:type rdf:Property ;
    rdfs:label 'Tooling Cost' ;
    rdfs:comment 'One-time cost for tooling, molds, dies, or setup required for production. May be amortized across order quantity or charged separately.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date of the quote. After this date, the vendor is not obligated to honor the quoted terms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associateNumber rdf:type rdf:Property ;
    rdfs:label 'Associate Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the associate, used on POS terminals, scheduling systems, and commission reports. Sourced from SAP Customer Activity Repository operator configuration.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisFulfillmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Bopis Fulfillment Enabled' ;
    rdfs:comment 'Indicates whether the associate is authorized and trained to fulfill Buy Online Pick Up In Store (BOPIS) orders. Supports omnichannel fulfillment assignment in Salesforce Commerce Cloud and SAP Customer Activity Repository.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether the associate is eligible to earn sales commission. Eligibility is determined by store role, employment type, and department assignment per the compensation policy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Code identifying the commission plan structure assigned to the associate (e.g., tiered, flat-rate, department-specific). References the commission plan configuration in SAP Customer Activity Repository.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Individual commission rate applied to the associate\'s attributed net sales, expressed as a decimal (e.g., 0.0250 = 2.50%). Used for commission accrual calculations in SAP FI/CO. Confidential compensation data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyholderFlag rdf:type rdf:Property ;
    rdfs:label 'Keyholder Flag' ;
    rdfs:comment 'Indicates whether the associate holds store key access and is authorized to open or close the store. Keyholders have elevated POS and alarm system permissions.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Loss Prevention Flag' ;
    rdfs:comment 'Indicates whether the associate has an active loss prevention alert or investigation flag. Confidential — access restricted to store management and loss prevention teams. Used for shrinkage management.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScoreAvg rdf:type rdf:Property ;
    rdfs:label 'Nps Score Avg' ;
    rdfs:comment 'Average Net Promoter Score (NPS) received by the associate from customer satisfaction surveys attributed to their POS transactions. Ranges from -100 to 100. Used for associate-level service quality monitoring.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posLoginEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Login Enabled' ;
    rdfs:comment 'Indicates whether the associate is currently authorized to log in to POS terminals. Set to false during suspension, leave, or post-termination to prevent unauthorized transactions.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Pos Operator Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the associate on POS terminals for transaction attribution, cash drawer assignment, and sales performance tracking. Configured in SAP Customer Activity Repository.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Primary Department Code' ;
    rdfs:comment 'Alphanumeric code identifying the associate\'s primary assigned department within the store (e.g., FTWR for Footwear, APRL for Apparel). Used for floor coverage planning and department-level sales attribution.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productKnowledgeTier rdf:type rdf:Property ;
    rdfs:label 'Product Knowledge Tier' ;
    rdfs:comment 'Certified level of product knowledge attained by the associate across the brand\'s apparel, footwear, and accessories categories. Drives assignment to high-value customer interactions and specialist floor zones.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidBadgeCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Badge Code' ;
    rdfs:comment 'Unique RFID chip identifier embedded in the associate\'s access badge. Used for store entry/exit access control, time and attendance tracking, and loss prevention audit trails.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesFloorZone rdf:type rdf:Property ;
    rdfs:label 'Sales Floor Zone' ;
    rdfs:comment 'Designated zone or area of the sales floor to which the associate is assigned (e.g., Front-of-House, Back Wall, Fitting Room, Cash Wrap). Supports visual merchandising coverage and traffic analytics.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours Per Week' ;
    rdfs:comment 'Standard contracted or scheduled weekly hours for the associate. Used for labor cost planning, overtime threshold monitoring, and workforce scheduling in the store operations context.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Department Code' ;
    rdfs:comment 'Code for a secondary department the associate is cross-trained to cover. Enables flexible floor scheduling and cross-department sales attribution during peak periods.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether the associate is authorized to process ship-from-store fulfillment orders, including picking, packing, and carrier handoff. Supports omnichannel DTC fulfillment operations.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeAssignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Store Assignment End Date' ;
    rdfs:comment 'Date the associate\'s assignment to the current store ended due to transfer, termination, or leave. Null if the assignment is currently active. Enables historical store assignment tracking.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeAssignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Store Assignment Start Date' ;
    rdfs:comment 'Date the associate was assigned to the current store. Distinct from hire_date — an associate may transfer between stores. Used for store-level tenure and performance benchmarking.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeRole rdf:type rdf:Property ;
    rdfs:label 'Store Role' ;
    rdfs:comment 'Operational role of the associate within the retail store context. Drives POS operator permissions, commission tier eligibility, scheduling authority, and floor coverage responsibilities. Distinct from HR job title in Workday HCM.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformSizeBottom rdf:type rdf:Property ;
    rdfs:label 'Uniform Size Bottom' ;
    rdfs:comment 'Apparel size for the associate\'s uniform bottom garment. Used by store operations for uniform inventory management and replenishment ordering.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformSizeTop rdf:type rdf:Property ;
    rdfs:label 'Uniform Size Top' ;
    rdfs:comment 'Apparel size for the associate\'s uniform top garment. Used by store operations for uniform inventory management and replenishment ordering.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address assigned to the associate for internal communications, scheduling notifications, and system access. Sourced from Workday HCM.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Work or store-assigned phone number for the associate, used for scheduling contact and store operations communication.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisOrderId rdf:type rdf:Property ;
    rdfs:label 'Bopis Order Id' ;
    rdfs:comment 'Unique identifier for the BOPIS order fulfillment record. Primary key.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBopisPickAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Bopis Pick Associate Id' ;
    rdfs:comment 'Reference to the store associate who picked the items for this BOPIS order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order was assigned to the fulfilling store.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notes' ;
    rdfs:comment 'Free-text notes providing additional context about the BOPIS order cancellation.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason why the BOPIS order was cancelled.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curbsideFlag rdf:type rdf:Property ;
    rdfs:label 'Curbside Flag' ;
    rdfs:comment 'Indicates whether the customer requested curbside pickup service for this BOPIS order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Timestamp' ;
    rdfs:comment 'The date and time when the customer was notified that their BOPIS order is ready for pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The communication channel used to notify the customer that their order is ready for pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'The date and time when the customer placed the original online order. Principal business event timestamp.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The total monetary value of the BOPIS order including all items, taxes, and fees.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupLocationType rdf:type rdf:Property ;
    rdfs:label 'Pickup Location Type' ;
    rdfs:comment 'The type of pickup location within or near the store where the customer will collect their order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Timestamp' ;
    rdfs:comment 'The date and time when the customer picked up the BOPIS order from the store.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Pickup Verification Method' ;
    rdfs:comment 'The method used to verify customer identity and authorize order handoff at pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyForPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready For Pickup Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order was marked ready for customer pickup and customer notification was triggered.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'The actual number of minutes elapsed from order assignment to ready-for-pickup status. Used for SLA compliance tracking.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the BOPIS order fulfillment met the defined SLA target time. True if actual time is less than or equal to target time.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The target number of minutes from order assignment to ready-for-pickup status, as defined by store operations policy.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Description' ;
    rdfs:comment 'Description of the customer\'s vehicle (make, model, color) for curbside pickup identification.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailySalesSummaryId rdf:type rdf:Property ;
    rdfs:label 'Daily Sales Summary Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily sales summary record. Primary key for the daily_sales_summary data product in the store domain.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeekId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week Id' ;
    rdfs:comment 'Foreign key linking to store.fiscal_week. Business justification: Daily sales summaries are aggregated and reported by fiscal week. Currently daily_sales_summary has fiscal_week (INT), fiscal_period (INT), and fiscal_year (INT) as denormalized attributes. Adding fis' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalWeek .

ind:reconciliationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Store managers/supervisors reconcile daily sales to resolve variances between POS totals and physical cash/card settlements. Critical audit trail for financial controls, loss prevention investigations' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code for any post-close adjustment applied to this daily sales summary. Only populated when is_adjusted = True. Used for audit trail and financial control reporting. [ENUM-REF-CANDIDATE: system_correction|manual_override|return_reclass|shrinkage_update|tax_correction|other — promote to reference product]' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asp rdf:type rdf:Property ;
    rdfs:label 'Asp' ;
    rdfs:comment 'Average selling price (ASP) per transaction on the business date, calculated as net sales amount divided by transaction count. Distinct from AUR which is per unit; ASP reflects basket-level pricing performance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisOrderCount rdf:type rdf:Property ;
    rdfs:label 'Bopis Order Count' ;
    rdfs:comment 'Number of buy-online-pick-up-in-store (BOPIS) orders fulfilled at this store on the business date. Key omnichannel fulfillment metric used to assess store capacity utilization and DTC channel performance.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'The retail business date (trading day) for which this end-of-day sales summary applies. Represents the fiscal trading day, which may differ from the calendar date for overnight operations.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Card Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via credit or debit card on the business date. Reconciled against card processor settlement reports as part of daily sales reconciliation. Includes all card network types (Visa, Mastercard, Amex, etc.).' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Tender Amount' ;
    rdfs:comment 'Total sales amount tendered in cash on the business date. Used for daily cash reconciliation, safe count verification, and bank deposit preparation as part of end-of-day store close procedures.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Closing Inventory Units' ;
    rdfs:comment 'Total on-hand inventory unit count at the end of the business date after all sales, returns, receipts, and adjustments. Used for weeks-of-supply (WOS) calculation and next-day opening inventory.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Percentage of customer visits that resulted in a completed purchase transaction on the business date (transaction count / customer traffic count), expressed as a decimal. Key store performance KPI for associate effectiveness and visual merchandising impact.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerTrafficCount rdf:type rdf:Property ;
    rdfs:label 'Customer Traffic Count' ;
    rdfs:comment 'Total number of customer visits (door count) recorded at the store on the business date via traffic counting systems. Used to calculate conversion rate (transaction count / traffic count) as a store performance KPI.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via digital payment methods (mobile wallets, gift cards, buy-now-pay-later, loyalty points redemption) on the business date. Tracked separately for digital payment adoption analytics.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Gift Card Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via gift cards on the business date. Tracked separately from other digital tenders for gift card liability reconciliation and breakage accounting per IFRS/GAAP deferred revenue standards.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue for the business date before deducting returns, markdowns, or discounts. Represents the sum of all POS transaction line amounts at full selling price prior to any adjustments.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdjusted rdf:type rdf:Property ;
    rdfs:label 'Is Adjusted' ;
    rdfs:comment 'Boolean flag indicating whether this daily sales summary record has been subject to a post-close adjustment (True). Adjusted records require additional audit scrutiny and are tracked for financial control compliance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Boolean flag indicating whether the daily sales summary has been formally reconciled (True) or is still pending reconciliation (False). Used to filter confirmed records for financial reporting and OTB updates.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Total net sales revenue for the business date after deducting returns and markdowns from gross sales. The primary revenue figure used for store performance reporting, OTB tracking, and STR calculation.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Opening Inventory Units' ;
    rdfs:comment 'Total on-hand inventory unit count at the start of the business date (beginning of day). Used as the denominator for daily sell-through rate (STR) calculation and OTB tracking.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pos Close Timestamp' ;
    rdfs:comment 'The exact date and time when the POS end-of-day close process was completed for this store on the business date. Represents the principal business event timestamp for this summary record. Sourced from SAP Customer Activity Repository daily close process.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The date and time when the daily sales summary was formally reconciled and approved by the store manager or back-office team. Distinct from POS close timestamp; represents the human-verified sign-off event.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Return Transaction Count' ;
    rdfs:comment 'Total number of return transactions processed at the store on the business date. Used to calculate return rate and assess customer satisfaction and product quality issues.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total monetary value of customer merchandise returns processed at the store on the business date. Subtracted from gross sales to derive net sales. Sourced from SAP CAR return transaction aggregation.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromStoreOrderCount rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Order Count' ;
    rdfs:comment 'Number of e-commerce orders fulfilled via ship-from-store on the business date. Reflects the store\'s contribution to omnichannel fulfillment and impacts available-to-sell (ATS) inventory levels.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shrinkageAmount rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Amount' ;
    rdfs:comment 'Estimated or recorded shrinkage (inventory loss due to theft, damage, or administrative error) value for the business date. Used for loss prevention reporting and COGS adjustment. Sourced from cycle count variances and known loss events.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The externally-known alphanumeric store identifier as assigned in the retail merchandising and POS systems (e.g., \'STR-0042\'). Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:str rdf:type rdf:Property ;
    rdfs:label 'Str' ;
    rdfs:comment 'Sell-through rate (STR) for the business date, expressed as a decimal (e.g., 0.0325 = 3.25%). Calculated as units sold divided by beginning-of-day on-hand inventory units. Used for inventory productivity and OTB management.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:summaryStatus rdf:type rdf:Property ;
    rdfs:label 'Summary Status' ;
    rdfs:comment 'Current lifecycle status of the daily sales summary record. \'open\' indicates the trading day is in progress; \'pending_reconciliation\' indicates end-of-day close initiated; \'reconciled\' indicates cash and card tenders have been balanced; \'closed\' indicates the record is finalized; \'adjusted\' indicates a post-close correction was applied; \'voided\' indicates the record was invalidated. [ENUM-REF-CANDIDATE: open|pending_reconciliation|reconciled|closed|adjusted|voided — promote to reference product]' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of completed POS sales transactions (excluding voids and returns) processed at the store on the business date. Used as the denominator for average order value (AOV) and average unit retail (AUR) calculations.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Units Per Transaction' ;
    rdfs:comment 'Average number of units sold per sales transaction on the business date (units sold divided by transaction count). A key store productivity KPI used to measure associate selling effectiveness and cross-sell performance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsReturned rdf:type rdf:Property ;
    rdfs:label 'Units Returned' ;
    rdfs:comment 'Total number of individual units returned by customers on the business date. Used to calculate gross units sold and return rate metrics for store performance analysis.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of individual units (SKUs) sold on the business date, net of returns. Used for sell-through rate (STR) calculation, average unit retail (AUR) computation, and inventory depletion tracking.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Void Transaction Count' ;
    rdfs:comment 'Total number of voided POS transactions on the business date. Elevated void counts may indicate training issues, fraud risk, or system errors and are monitored as part of loss prevention.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markdownEventId rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Id' ;
    rdfs:comment 'Primary key for markdown_event' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMarkdownEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Markdown Employee Id' ;
    rdfs:comment 'User identifier of the merchandising manager or authorized personnel who approved the markdown event in Oracle Retail Price Management. Supports authorization audit and segregation of duties compliance.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference number or code from the authorization workflow that approved this markdown event. Typically sourced from Oracle Retail Price Management approval chain. Required for audit compliance and financial controls.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintainedMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Maintained Markup Pct' ;
    rdfs:comment 'Maintained Markup (MMU) percentage after applying the markdown, reflecting the actual margin retained post-markdown. Calculated as (markdown_price minus cost_price) / markdown_price. Critical for GMROI analysis and financial planning in Anaplan.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownEventNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Number' ;
    rdfs:comment 'Externally-known business identifier for the markdown event as assigned by Oracle Retail Price Management. Used for cross-system reference, audit trails, and reconciliation with source system records.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownLevel rdf:type rdf:Property ;
    rdfs:label 'Markdown Level' ;
    rdfs:comment 'Granularity at which the markdown event is defined and applied within the merchandise hierarchy. SKU-level markdowns are the most granular; department-level markdowns apply broadly across a category.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Pct' ;
    rdfs:comment 'Percentage reduction from the original retail price to the markdown price, expressed as a decimal (e.g., 0.3000 = 30%). Key metric for MD depth analysis, OTB reconciliation, and maintained markup (MMU) tracking.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReasonCode rdf:type rdf:Property ;
    rdfs:label 'Markdown Reason Code' ;
    rdfs:comment 'Business reason driving the markdown event. [ENUM-REF-CANDIDATE: clearance|seasonal|competitive|slow_seller|overstock|damage|end_of_line — promote to reference product]' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Classification of the markdown event by pricing permanence. Permanent markdowns reduce the ongoing retail price; temporary markdowns revert after the event period; promotional markdowns are tied to a campaign; clearance markdowns are end-of-lifecycle reductions.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'The original Manufacturer\'s Suggested Retail Price (MSRP) for the SKU prior to any markdown. Serves as the baseline for markdown percentage calculation and IMU/MMU analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Store-level on-hand inventory quantity for the SKU at the time the markdown event is created. Captured to support sell-through rate (STR) analysis, weeks of supply (WOS) calculation, and OTB reconciliation.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Applied Flag' ;
    rdfs:comment 'Indicates whether the markdown price has been successfully pushed to and activated at the store Point of Sale (POS) system (SAP Customer Activity Repository). True when the markdown is live at POS; False when pending or failed.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceLabelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Price Label Required Flag' ;
    rdfs:comment 'Indicates whether physical price label reprinting is required for store fixtures and merchandise as part of this markdown event. Drives visual merchandising and store operations task management.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidRepricedFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Repriced Flag' ;
    rdfs:comment 'Indicates whether RFID-tagged units for this SKU have been repriced and relabeled in the store as part of the markdown event execution. Supports RFID-enabled inventory accuracy and shrinkage control.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitsSoldDuringEvent rdf:type rdf:Property ;
    rdfs:label 'Units Sold During Event' ;
    rdfs:comment 'Total number of units of the SKU sold at the markdown price during the event period. Populated at event close or via daily reconciliation from SAP Customer Activity Repository. Supports STR and markdown effectiveness analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashierAssociateId rdf:type rdf:Property ;
    rdfs:label 'Cashier Associate Id' ;
    rdfs:comment 'Reference to the sales associate or cashier who processed the transaction. Used for associate-level performance tracking, commission calculation, and loss prevention audits.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:registerId rdf:type rdf:Property ;
    rdfs:label 'Register Id' ;
    rdfs:comment 'Reference to the specific POS register (terminal) at which the transaction was processed within the store. Supports register-level reconciliation and shrinkage analysis.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Register .

ind:returnOriginalTransactionPosTransactionId rdf:type rdf:Property ;
    rdfs:label 'Return Original Transaction Pos Transaction Id' ;
    rdfs:comment 'For RETURN or EXCHANGE transaction types, references the original sale transaction being returned against. Enables return merchandise authorization (RMA) traceability and shrinkage analysis. Null for non-return transactions.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'Total number of distinct line items (SKU entries) in the transaction. Differs from item_count when multiple units of the same SKU are purchased. Used for transaction complexity analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether a manager authorization override was required to complete this transaction (e.g., for price overrides, high-value returns, or discount exceptions). Critical for loss prevention and exception-based reporting.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Price Override Flag' ;
    rdfs:comment 'Indicates whether a manual price override was applied to one or more items in this transaction, bypassing the system-calculated selling price. Used in loss prevention audits and markdown (MD) exception reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Delivery Method' ;
    rdfs:comment 'Method by which the transaction receipt was delivered to the customer: PRINT (paper receipt), EMAIL (digital email receipt), SMS (text message receipt), NONE (no receipt requested). Supports sustainability reporting and digital engagement analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Verified Flag' ;
    rdfs:comment 'Indicates whether the items in this transaction were verified via Radio Frequency Identification (RFID) scanning at the point of sale. Supports inventory accuracy, shrinkage reduction, and omnichannel Available to Sell (ATS) reconciliation.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenderCashAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Cash Amount' ;
    rdfs:comment 'Amount of the transaction settled by cash tender. Used in daily cash drawer reconciliation and loss prevention audits. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Credit Amount' ;
    rdfs:comment 'Amount of the transaction settled by credit card tender. Supports PCI DSS compliance reporting and payment reconciliation. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Debit Amount' ;
    rdfs:comment 'Amount of the transaction settled by debit card tender. Supports payment reconciliation and PCI DSS compliance. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderGiftCardAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Gift Card Amount' ;
    rdfs:comment 'Amount of the transaction settled by gift card redemption. Used for gift card liability tracking, breakage analysis, and revenue recognition per IFRS/GAAP deferred revenue rules.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderMobileWalletAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Mobile Wallet Amount' ;
    rdfs:comment 'Amount of the transaction settled via mobile wallet payment (e.g., Apple Pay, Google Pay, Samsung Pay). Tracks digital payment adoption trends and supports omnichannel payment analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderStoreCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Store Credit Amount' ;
    rdfs:comment 'Amount of the transaction settled using store credit (issued from prior returns or promotions). Supports Return to Vendor (RTV) and return merchandise authorization liability tracking.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModeFlag rdf:type rdf:Property ;
    rdfs:label 'Training Mode Flag' ;
    rdfs:comment 'Indicates whether this transaction was processed in POS training/demo mode and should be excluded from financial reporting and sales analytics. Critical for data quality and accurate daily sales reconciliation.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time when the transaction was initiated at the register, as recorded by the POS system. Principal business event timestamp. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for intraday traffic analytics and hourly sales reporting.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Coded reason for voiding a transaction (e.g., OPERATOR_ERROR, CUSTOMER_CHANGED_MIND, SYSTEM_ERROR, MANAGER_OVERRIDE). Populated only for VOID transaction types. Used in loss prevention and exception reporting. [ENUM-REF-CANDIDATE: OPERATOR_ERROR|CUSTOMER_CHANGED_MIND|SYSTEM_ERROR|MANAGER_OVERRIDE|PRICE_OVERRIDE|DUPLICATE_TRANSACTION — promote to reference product]' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationNumber rdf:type rdf:Property ;
    rdfs:label 'Workstation Number' ;
    rdfs:comment 'Human-readable identifier of the POS workstation/terminal as configured in SAP Customer Activity Repository (e.g., REG-01, KIOSK-03). Used for register-level reconciliation and store layout analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionLineId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Line Id' ;
    rdfs:comment 'Primary key for pos_transaction_line' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesAssociateId rdf:type rdf:Property ;
    rdfs:label 'Sales Associate Id' ;
    rdfs:comment 'Reference to the sales associate who processed or assisted with this transaction line. Used for associate-level sales performance tracking, commission calculation, and clienteling analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:cogs rdf:type rdf:Property ;
    rdfs:label 'Cogs' ;
    rdfs:comment 'Cost of Goods Sold (COGS) for this line item representing the total cost of the units sold. Used to calculate gross margin, GMROI, and MMU at the SKU-store-day grain. Sourced from SAP S/4HANA material valuation.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discount Reason Code' ;
    rdfs:comment 'Code identifying the business reason for any discount or markdown applied to this line item (e.g., EMPLOYEE, LOYALTY, COUPON, CLEARANCE, PROMO, DAMAGE). Used for discount analytics, shrinkage investigation, and promotional effectiveness reporting. [ENUM-REF-CANDIDATE: EMPLOYEE|LOYALTY|COUPON|CLEARANCE|PROMO|DAMAGE|PRICE_MATCH|MANAGER_OVERRIDE — promote to reference product]' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imuPct rdf:type rdf:Property ;
    rdfs:label 'Imu Pct' ;
    rdfs:comment 'Initial Markup (IMU) percentage for this SKU at the time of the transaction, representing the difference between the original retail price and COGS as a percentage of retail. Key metric for margin planning and merchandise financial performance.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isClearanceItem rdf:type rdf:Property ;
    rdfs:label 'Is Clearance Item' ;
    rdfs:comment 'Indicates whether the SKU on this line was designated as a clearance item at the time of sale. Clearance items are end-of-lifecycle SKUs being liquidated. Distinct from is_markdown_item which covers all markdowns including promotional.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMarkdownItem rdf:type rdf:Property ;
    rdfs:label 'Is Markdown Item' ;
    rdfs:comment 'Indicates whether the SKU on this line was sold at a marked-down price at the time of the transaction. True if the item was on permanent or promotional markdown. Used to segment full-price vs. markdown sales for AUR and margin analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidScanned rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Scanned' ;
    rdfs:comment 'Indicates whether this line item was identified via RFID (Radio Frequency Identification) tag scan rather than traditional barcode/UPC scan at the POS. Supports RFID adoption tracking, inventory accuracy measurement, and shrinkage reduction analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineExtendedAmount rdf:type rdf:Property ;
    rdfs:label 'Line Extended Amount' ;
    rdfs:comment 'Total net sales amount for this line item (unit_retail_price × quantity_sold minus line_discount_amount). Represents the actual revenue recognized for this line. Used in daily sales reconciliation and financial reporting.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the transaction line indicating whether it represents a sale, return, exchange, void, or layaway. Drives revenue recognition logic, inventory adjustment direction, and return analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmuPct rdf:type rdf:Property ;
    rdfs:label 'Mmu Pct' ;
    rdfs:comment 'Maintained Markup (MMU) percentage for this line item, reflecting the actual margin achieved after all markdowns and discounts. Calculated as (unit_retail_price - unit_cost) / unit_retail_price. Core KPI for merchandise financial planning.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registerCode rdf:type rdf:Property ;
    rdfs:label 'Register Code' ;
    rdfs:comment 'Identifier of the POS register or terminal where this transaction line was processed. Used for register-level reconciliation, shrinkage investigation, and store operations auditing.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineReference rdf:type rdf:Property ;
    rdfs:label 'Source System Line Reference' ;
    rdfs:comment 'The native transaction line identifier from the source system (SAP Customer Activity Repository). Preserves the original system reference for data lineage, reconciliation, and audit trail purposes in the Silver layer.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The actual retail price charged per unit on this line after all markdowns and promotions have been applied. Represents the AUR (Average Unit Retail) at the transaction level. Core input for ASP and AUR analytics. Aligns with TRANSACTION_LINE role LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Foreign key linking to store.district. Business justification: Retail stores belong to districts for regional management hierarchy. retail_store currently has district_name (STRING) which is redundant once district_id FK is added. The district table contains dist' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:districtManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'District Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: District managers oversee 8-15 store clusters, responsible for performance management, operational compliance, and escalation resolution. Essential for retail organizational hierarchy reporting, labor' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Each store is assigned a primary DC for replenishment routing, inventory allocation planning, and freight cost modeling. Fundamental supply chain network design relationship used in allocation and tra' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:renewableEnergyCertificateId rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Certificate Id' ;
    rdfs:comment 'Foreign key linking to sustainability.renewable_energy_certificate. Business justification: Stores are allocated renewable energy certificates to offset Scope 2 emissions from electricity consumption. Sustainability teams track REC allocation by facility for carbon accounting, RE100 complian' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RenewableEnergyCertificate .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the retail store (suite, floor, unit, mall name, or building identifier). Supplements address_line1 for precise location identification in complex retail environments such as shopping malls or department stores.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBaseRent rdf:type rdf:Property ;
    rdfs:label 'Annual Base Rent' ;
    rdfs:comment 'Annual base rent amount payable under the store lease agreement in the store\'s local currency. Used for occupancy cost analysis, GMROI (Gross Margin Return on Investment) calculation, and store profitability modelling. Excludes turnover/percentage rent and service charges.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Köppen-based climate zone classification for the store\'s geographic location. Drives seasonal assortment planning, markdown timing, and inventory allocation decisions for weather-sensitive apparel categories (outerwear, swimwear, knitwear).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fittingRoomCount rdf:type rdf:Property ;
    rdfs:label 'Fitting Room Count' ;
    rdfs:comment 'Total number of fitting rooms (changing rooms/dressing rooms) available in the store. Used for store capacity planning, customer experience benchmarking, and visual merchandising layout design. Relevant for apparel conversion rate analytics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossSellingSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Selling Sqft' ;
    rdfs:comment 'Total gross interior square footage of the retail store including all selling, back-of-house, stockroom, and ancillary areas. Used for lease cost-per-square-foot analysis, capital expenditure planning, and store portfolio benchmarking.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Headcount Capacity' ;
    rdfs:comment 'Maximum approved headcount (number of employees) for the store as defined in the workforce plan. Used for labour scheduling, Workday HCM position management, and compliance with local employment regulations. Drives OTB labour cost budgeting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Enabled' ;
    rdfs:comment 'Indicates whether the store is configured and operationally enabled to fulfil Buy Online Pick Up In Store (BOPIS) orders. Drives omnichannel order routing logic in Salesforce Commerce Cloud and SAP Customer Activity Repository. True = BOPIS active; False = BOPIS not available at this location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether the store is equipped with Radio Frequency Identification (RFID) infrastructure for inventory tracking, cycle counting, and loss prevention. RFID-enabled stores support real-time inventory accuracy and ATS (Available to Sell) visibility. True = RFID infrastructure active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether the store is configured to fulfil e-commerce orders by shipping directly to customers from store inventory. Enables distributed fulfilment network capabilities. Drives order routing in Salesforce Commerce Cloud and Manhattan Associates WMS. True = ship-from-store active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Expiration date of the current lease agreement for the store premises. Used for lease renewal pipeline management, store closure planning, and IFRS 16 lease liability amortization schedule. Nullable for month-to-month or perpetual arrangements.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Commencement date of the current lease agreement for the store premises as recorded in SAP S/4HANA Real Estate module. Used for lease term tracking, IFRS 16 right-of-use asset calculation, and lease renewal planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netSellingSqft rdf:type rdf:Property ;
    rdfs:label 'Net Selling Sqft' ;
    rdfs:comment 'Net productive selling floor area in square feet, excluding stockroom, fitting rooms, cash wrap, and back-of-house. Primary denominator for sales-per-square-foot (SPF) KPI, visual merchandising density planning, and fixture capacity modelling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date on which the store first opened for trading to customers. Used for store age calculations, comparable store (comp-store) sales analysis, and new store ramp-up performance benchmarking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Classification of the POS terminal configuration deployed in the store. Fixed terminals are traditional counter-based registers; mobile POS (mPOS) enables floor-based selling; self-checkout enables customer-operated transactions; mixed indicates a combination. Drives IT infrastructure planning and customer experience design.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the geographic region within Apparel Fashion\'s retail organizational hierarchy (e.g., North America, EMEA, APAC). Top tier of the region/district/territory hierarchy used for regional performance reporting and resource allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerCount rdf:type rdf:Property ;
    rdfs:label 'Register Count' ;
    rdfs:comment 'Total number of active Point of Sale (POS) terminals (registers) installed in the store. Used for transaction throughput capacity planning, queue management, and SAP Customer Activity Repository (CAR) terminal configuration management.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remodelDate rdf:type rdf:Property ;
    rdfs:label 'Remodel Date' ;
    rdfs:comment 'Date of the most recent store remodel or significant capital refurbishment. Used to assess store condition age, plan future capital expenditure cycles, and correlate store investment with post-remodel sales uplift.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentStructureType rdf:type rdf:Property ;
    rdfs:label 'Rent Structure Type' ;
    rdfs:comment 'Classification of the rent payment structure under the store lease. Fixed rent is a flat periodic payment; turnover rent is a percentage of net sales; fixed_plus_turnover combines a base rent with a sales-linked top-up; concession_percentage applies to shop-in-shop and concession formats. Drives financial planning and OTB (Open-to-Buy) modelling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTradingHours rdf:type rdf:Property ;
    rdfs:label 'Standard Trading Hours' ;
    rdfs:comment 'Standard weekly operating hours for the store expressed as a structured string (e.g., \'Mon-Sat 09:00-21:00; Sun 11:00-18:00\'). Used for customer-facing store finder, workforce scheduling in Workday HCM, and daily sales reconciliation cut-off timing in SAP Customer Activity Repository.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockroomSqft rdf:type rdf:Property ;
    rdfs:label 'Stockroom Sqft' ;
    rdfs:comment 'Total square footage of the store\'s back-of-house stockroom area. Used for inventory capacity planning, WMS (Warehouse Management System) configuration, and the calculation of net-to-gross selling area ratio. Informs replenishment frequency and NOS (Never Out of Stock) capability.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCode rdf:type rdf:Property ;
    rdfs:label 'Store Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the store, used across SAP S/4HANA, SAP Customer Activity Repository (CAR), Oracle Retail, and EDI integrations. Conforms to NRF ARTS store numbering convention. Unique across all store formats and geographies.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'Operational format classification of the store that determines merchandising strategy, assortment depth, pricing authority, and capital investment profile. Flagship stores carry full-price full-assortment; outlet stores carry clearance/off-price; pop-up stores are temporary; shop-in-shop and concession operate within a host retailer\'s space.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'Official trading name of the retail store location as displayed on signage, customer receipts, and marketing materials. Used for customer-facing communications and brand management reporting.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Name of the territory or cluster within the district hierarchy. Lowest tier of the organizational hierarchy above individual store level, used for territory manager assignments and localized assortment planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Trading Area Classification' ;
    rdfs:comment 'Classification of the retail trading environment in which the store operates. Determines foot traffic patterns, trading hours, lease structure, and competitive benchmarking peer group. Used in store performance analytics and site selection models. [ENUM-REF-CANDIDATE: high_street|shopping_mall|outlet_center|airport|resort|standalone|department_store — promote to reference product]' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approving Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Store managers approve high-value returns, no-receipt returns, and policy exceptions (manager_override_flag). Critical fraud prevention control, return abuse detection, and policy compliance tracking ' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReturnSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Sku Id' ;
    rdfs:comment 'Identifier of the specific Stock Keeping Unit (SKU) being returned. Enables return rate analysis by product, style, color, and size.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:processingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Processing Associate Id' ;
    rdfs:comment 'Identifier of the sales associate or cashier who processed the return transaction at the Point of Sale (POS). Used for associate performance tracking and loss prevention audit trails.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:daysSincePurchase rdf:type rdf:Property ;
    rdfs:label 'Days Since Purchase' ;
    rdfs:comment 'Number of calendar days elapsed between the original purchase date and the return transaction date. Used for return policy compliance validation and return window analytics. Stored as a business attribute to avoid repeated calculation in reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemConditionCode rdf:type rdf:Property ;
    rdfs:label 'Item Condition Code' ;
    rdfs:comment 'Condition assessment of the returned merchandise as evaluated by the processing associate at Point of Sale (POS). Drives disposition routing decisions: new_with_tags and new_without_tags are eligible for floor restock; worn and damaged route to outlet transfer or damage write-off; defective routes to Return to Vendor (RTV).' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsReversed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Reversed' ;
    rdfs:comment 'Number of loyalty program points deducted from the customer\'s account as a result of the return transaction. Reverses the points originally earned on the purchase.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalOrderChannel rdf:type rdf:Property ;
    rdfs:label 'Original Order Channel' ;
    rdfs:comment 'Sales channel through which the original purchase was made. Enables cross-channel return analysis (e.g., online purchase returned in-store) and Direct-to-Consumer (DTC) return rate reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Date' ;
    rdfs:comment 'Date on which the merchandise was originally purchased. Used to calculate days since purchase for return policy eligibility validation and warranty period determination.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTenderType rdf:type rdf:Property ;
    rdfs:label 'Original Tender Type' ;
    rdfs:comment 'Payment method used in the original purchase transaction. Required to determine refund eligibility and routing when refund_method is \'original_tender\'. Sourced from the original POS transaction record.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Presented Flag' ;
    rdfs:comment 'Indicates whether the customer presented the original purchase receipt at the time of return. Affects return policy eligibility, refund method options, and loss prevention risk scoring.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Return Discount Amount' ;
    rdfs:comment 'Total discount amount that was applied to the original purchase and is being reversed or credited back as part of the return. Ensures accurate net refund calculation.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Return Gross Amount' ;
    rdfs:comment 'Total gross merchandise value of the returned items before any adjustments, calculated as unit_retail_price multiplied by quantity_returned. Used for return rate and Sell-Through Rate (STR) impact analysis.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnNetAmount rdf:type rdf:Property ;
    rdfs:label 'Return Net Amount' ;
    rdfs:comment 'Net amount refunded to the customer after applying discounts and taxes. Equals return_gross_amount minus return_discount_amount plus return_tax_amount. Used for financial reconciliation and daily sales reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'Externally visible, human-readable return authorization number printed on the return receipt and used for customer-facing communication, warranty claims, and Return to Vendor (RTV) processing. Generated by SAP Customer Activity Repository (CAR).' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Return Policy Code' ;
    rdfs:comment 'Code identifying the specific return policy applied to this transaction (e.g., standard 30-day, extended holiday, loyalty member extended window, final sale). Determines return eligibility and refund method options.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Return Tax Amount' ;
    rdfs:comment 'Tax amount being refunded to the customer as part of the return transaction. Calculated based on the applicable tax jurisdiction and original tax paid.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialReturnerFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Returner Flag' ;
    rdfs:comment 'Indicates whether the customer associated with this return has been identified as a serial returner based on return frequency thresholds. Distinct from loss_prevention_flag which covers broader fraud patterns. Used for targeted loss prevention intervention.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeCreditVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Store Credit Voucher Number' ;
    rdfs:comment 'Voucher or store credit account number issued to the customer when refund_method is \'store_credit\'. Used for store credit redemption tracking and liability reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Warranty claim reference number assigned when the return is associated with a product defect or warranty issue. Links the return to the warranty claim tracking workflow in SAP S/4HANA.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Primary key for shift' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Identifier for the payroll period to which this shift\'s hours are attributed (e.g., PP-2024-26 for the 26th pay period of 2024). Used to batch shift records for payroll export to Workday HCM.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:shiftAssociateId rdf:type rdf:Property ;
    rdfs:label 'Shift Associate Id' ;
    rdfs:comment 'Reference to the store associate (employee) assigned to this shift. Sourced from Workday HCM employee master.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:shiftCoveringAssociateId rdf:type rdf:Property ;
    rdfs:label 'Shift Covering Associate Id' ;
    rdfs:comment 'Reference to the associate who covered this shift in the event of a no-show, swap, or emergency absence. Null if no coverage was arranged. Supports shift swap tracking and labor scheduling analytics.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:shiftOriginalAssociateId rdf:type rdf:Property ;
    rdfs:label 'Shift Original Associate Id' ;
    rdfs:comment 'Reference to the associate originally scheduled for this shift before a swap or reassignment occurred. Populated only when shift_swap_flag is True. Enables full audit trail of schedule changes.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:workdayPositionId rdf:type rdf:Property ;
    rdfs:label 'Workday Position Id' ;
    rdfs:comment 'External position identifier from Workday HCM corresponding to the associate\'s role at the time of the shift. Used for payroll integration and labor cost allocation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for a no-show or partial absence (e.g., sick leave, personal leave, emergency, unauthorized). Populated when no_show_flag is True or shift is cancelled. [ENUM-REF-CANDIDATE: sick_leave|personal_leave|emergency|unauthorized|bereavement|jury_duty|weather — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Break Minutes' ;
    rdfs:comment 'Total actual break time taken by the associate in minutes as recorded by the time and attendance system. Compared against scheduled break duration for compliance and payroll accuracy.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'Total number of hours the associate actually worked during the shift, computed from clock-in/clock-out minus break durations. Used for payroll processing, overtime calculation, and labor productivity KPIs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes for the shift (sum of all meal and rest breaks). Used to compute net hours worked and ensure compliance with labor rest-period regulations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockInMethod rdf:type rdf:Property ;
    rdfs:label 'Clock In Method' ;
    rdfs:comment 'Method used by the associate to record their clock-in time (e.g., POS terminal, mobile app, biometric scanner, RFID badge, manager manual entry). Supports time and attendance audit and fraud detection.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockInTime rdf:type rdf:Property ;
    rdfs:label 'Clock In Time' ;
    rdfs:comment 'Actual date and time the associate clocked in for the shift as recorded by the time and attendance system. Null if the associate has not yet clocked in or was a no-show.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutMethod rdf:type rdf:Property ;
    rdfs:label 'Clock Out Method' ;
    rdfs:comment 'Method used by the associate to record their clock-out time. Mirrors clock_in_method for symmetry and audit completeness.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockOutTime rdf:type rdf:Property ;
    rdfs:label 'Clock Out Time' ;
    rdfs:comment 'Actual date and time the associate clocked out at the end of the shift. Null if the shift is still in progress or the associate did not clock out (requires manager resolution).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:earlyDepartureFlag rdf:type rdf:Property ;
    rdfs:label 'Early Departure Flag' ;
    rdfs:comment 'Indicates whether the associate clocked out before the scheduled end time. True = early departure occurred. Used for attendance tracking and SLA compliance in store staffing.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Estimated or actual labor cost for this shift in the store\'s operating currency, computed from actual hours worked multiplied by the applicable pay rate. Used for store-level labor cost reporting and GMROI analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Indicates whether the associate failed to appear for a scheduled shift without prior notification. True = no-show recorded. Feeds into attendance management and disciplinary workflows in Workday HCM.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omnichannelFulfillmentFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Fulfillment Flag' ;
    rdfs:comment 'Indicates whether the associate\'s role during this shift includes omnichannel fulfillment duties such as BOPIS (Buy Online Pick Up In Store) or ship-from-store. True = omnichannel duties assigned. Used for labor allocation and fulfillment capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the manager when a shift time override is applied (e.g., system outage, forgotten clock-out, emergency). Required when manager_override_flag is True.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of hours worked beyond the standard shift threshold that qualify for overtime pay, as determined by applicable labor regulations and the associate\'s employment contract. Feeds directly into Workday HCM payroll processing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateCode rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Code' ;
    rdfs:comment 'Code identifying the pay rate tier applicable to this shift (e.g., standard, overtime, holiday, training). References the compensation rate table in Workday HCM. Classified confidential as it reveals compensation structure.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollExportFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Export Flag' ;
    rdfs:comment 'Indicates whether this shift record has been successfully exported to Workday HCM for payroll processing. True = exported; False = pending export. Used to prevent duplicate payroll submissions.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollExportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payroll Export Timestamp' ;
    rdfs:comment 'Date and time when this shift record was exported to Workday HCM for payroll processing. Null if payroll_export_flag is False. Supports payroll reconciliation and audit.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roleDuringShift rdf:type rdf:Property ;
    rdfs:label 'Role During Shift' ;
    rdfs:comment 'The operational role the associate performs during this specific shift (e.g., Sales Associate, Cashier, Floor Supervisor, Stock Associate, Visual Merchandiser, BOPIS Fulfillment). May differ from the associate\'s primary job title. [ENUM-REF-CANDIDATE: sales_associate|cashier|floor_supervisor|stock_associate|visual_merchandiser|bopis_fulfillment|keyholder|manager_on_duty — promote to reference product]' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleAdherenceMinutes rdf:type rdf:Property ;
    rdfs:label 'Schedule Adherence Minutes' ;
    rdfs:comment 'Variance in minutes between the scheduled start time and actual clock-in time. Positive value = late arrival; negative value = early arrival. Used for store operations KPI reporting and associate performance management.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Indicates the origin of the shift schedule record — whether generated automatically by Workday HCM scheduling, entered manually by a manager, or adjusted post-generation. Supports audit and schedule quality analysis.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The planned end date and time of the shift as defined in the labor scheduling system. Used to compute scheduled shift duration and planned labor cost.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total number of hours the associate is scheduled to work for this shift, derived from scheduled start and end times minus planned break duration. Stored explicitly for scheduling and OTB labor budget comparisons.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The planned start date and time of the shift as defined in the labor scheduling system. Used to measure schedule adherence and compute planned labor hours.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'The calendar date on which the shift is scheduled or occurred. Used as the primary business date for labor scheduling, daily sales reconciliation, and store performance reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Human-readable business identifier for the shift record, used in scheduling systems, payroll exports, and store operations reporting. Format: SHF-YYYYMMDD-NNNNNN.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle state of the shift record. \'scheduled\' = future shift confirmed; \'in_progress\' = associate currently clocked in; \'completed\' = shift ended and reconciled; \'cancelled\' = shift removed before start; \'no_show\' = associate did not clock in for a scheduled shift.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift for labor scheduling and payroll purposes. Drives overtime eligibility, holiday pay rates, and training hour tracking. [ENUM-REF-CANDIDATE: regular|overtime|on_call|split|holiday|training — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapFlag rdf:type rdf:Property ;
    rdfs:label 'Swap Flag' ;
    rdfs:comment 'Indicates whether this shift was the result of a shift swap between two associates. True = shift was swapped. Used to track schedule changes and ensure proper payroll attribution.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingShiftFlag rdf:type rdf:Property ;
    rdfs:label 'Training Shift Flag' ;
    rdfs:comment 'Indicates whether this shift is designated as a training shift where the associate is undergoing onboarding, product knowledge training, or compliance training rather than performing standard operational duties.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipFromStoreId rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Id' ;
    rdfs:comment 'Unique surrogate identifier for each ship-from-store fulfillment record in the Silver layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the shipment destination (customer delivery address or alternate store). Classified as restricted PII per GDPR Article 4 and CCPA as it identifies the customer\'s physical location.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City of the shipment destination address. Used for carrier zone determination, delivery time estimation, and geographic fulfillment analytics. Classified as restricted PII as part of the customer delivery address.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipment destination. Used for carrier zone calculation, delivery time estimation, and geographic demand analytics. Classified as restricted PII as part of the customer delivery address.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateCode rdf:type rdf:Property ;
    rdfs:label 'Destination State Code' ;
    rdfs:comment 'Two-letter ISO 3166-2 state or province code of the shipment destination. Used for carrier zone mapping, tax jurisdiction determination, and regional fulfillment performance analytics.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Request Number' ;
    rdfs:comment 'Externally-known business identifier for the ship-from-store fulfillment request, used for cross-system traceability across Salesforce Commerce Cloud, Manhattan Associates WMS, and SAP S/4HANA SD. Corresponds to the outbound delivery document number in WMS. [BUSINESS_IDENTIFIER category]' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the packing of the ship-from-store order was completed and the parcel was sealed and labeled. Used to measure pack cycle time and overall fulfillment throughput.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Package Weight Kg' ;
    rdfs:comment 'Actual weight of the packed parcel in kilograms as measured at the store packing station. Used for carrier rate calculation, dimensional weight billing reconciliation, and shipping cost allocation.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialFulfillmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Fulfillment Flag' ;
    rdfs:comment 'Indicates that the shipped_quantity is less than the ordered_quantity, resulting in a partial shipment. Triggers downstream processes such as backorder creation, customer notification, or alternate store sourcing.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the store associate completed the pick operation for this fulfillment request. Used to measure pick cycle time and store fulfillment throughput performance.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'The actual number of units physically picked from store inventory during the pick operation. May differ from ordered_quantity due to inventory discrepancies, shrinkage, or partial fulfillment scenarios.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'The committed date by which the store must ship the order to meet the customer-facing delivery promise. Used as the SLA (Service Level Agreement) target for OTIF measurement and store performance KPI reporting.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The date and time when the ship-from-store fulfillment request was created and assigned to the store, representing the principal business event time. Used for OTIF (On Time In Full) SLA measurement and store capacity planning. [BUSINESS_EVENT_TIMESTAMP category]' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retailValueAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Value Amount' ;
    rdfs:comment 'The total retail selling value (AUR × shipped_quantity) of the merchandise shipped in this fulfillment request, at the current selling price. Used for store-level revenue attribution, omnichannel sales reporting, and shrinkage risk assessment.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the parcel was tendered to the carrier and the shipment was confirmed. Used as the primary timestamp for OTIF (On Time In Full) compliance measurement against the SLA target.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingLabelReference rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Reference' ;
    rdfs:comment 'Internal identifier for the shipping label generated by the WMS for this parcel. Used to reconcile label costs, void labels on cancellations, and audit label generation events in Manhattan Associates WMS.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeInventoryDeductedFlag rdf:type rdf:Property ;
    rdfs:label 'Store Inventory Deducted Flag' ;
    rdfs:comment 'Indicates whether the shipped_quantity has been successfully deducted from the store\'s on-hand inventory in the WMS and ERP systems. Used to detect inventory reconciliation failures and ensure ATS (Available to Sell) accuracy.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageIncidentId rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Incident Id' ;
    rdfs:comment 'Unique system-generated identifier for each shrinkage incident record in the store loss prevention system. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete loss event with its own lifecycle, investigation workflow, and financial impact.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:involvedProfileId rdf:type rdf:Property ;
    rdfs:label 'Involved Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.profile. Business justification: Loss prevention incidents involving identified customers (apprehensions, banned individuals, organized retail crime suspects) require customer profile linkage for case management, banned customer list' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:receivingShipmentId rdf:type rdf:Property ;
    rdfs:label 'Receiving Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_shipment. Business justification: Shrinkage discovered during store receiving (shortage, damage) must be traced to inbound shipment for vendor claim filing, carrier liability determination, and supply chain quality metrics. Required f' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:storeCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Store Cycle Count Id' ;
    rdfs:comment 'Reference to the cycle count or physical inventory event that identified the shrinkage variance, where discovery_method is cycle_count_variance or physical_inventory. Null for incidents discovered by other methods.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreCycleCount .

ind:apprehensionMade rdf:type rdf:Property ;
    rdfs:label 'Apprehension Made' ;
    rdfs:comment 'Indicates whether a suspect was apprehended in connection with this shrinkage incident. Used to measure LP team effectiveness and track apprehension rates by store, shrinkage type, and time period.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costValueLost rdf:type rdf:Property ;
    rdfs:label 'Cost Value Lost' ;
    rdfs:comment 'Total cost value (Cost of Goods Sold / COGS) of the units lost in this incident at the time of discovery. Used for financial write-off entries in the general ledger and EBITDA impact reporting. Distinct from retail_value_lost which reflects selling price.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Calendar date on which the shrinkage event was first identified or detected by store operations or loss prevention. Distinct from incident_date when the event occurred prior to detection.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'The operational process or technology that first identified the shrinkage event. Supports analysis of detection effectiveness by method and investment decisions for loss prevention technology. [ENUM-REF-CANDIDATE: cycle_count_variance|rfid_exception|video_analytics|eas_alarm|receiving_audit|pos_exception|physical_inventory — promote to reference product]' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Precise date and time when the shrinkage event was first identified, including time-zone offset. Used for intraday loss pattern analysis and correlation with POS transaction timelines.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:easAlarmTriggered rdf:type rdf:Property ;
    rdfs:label 'Eas Alarm Triggered' ;
    rdfs:comment 'Indicates whether an Electronic Article Surveillance (EAS) alarm was triggered in connection with this shrinkage incident. Used to evaluate EAS system effectiveness and correlate alarm events with confirmed shrinkage.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Flag' ;
    rdfs:comment 'Indicates whether the financial write-off for this shrinkage incident has been posted to the General Ledger (GL) in SAP S/4HANA FI/CO. Supports financial close reconciliation and shrinkage expense reporting.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the shrinkage event is estimated or confirmed to have occurred. May differ from the discovery date when shrinkage is identified retrospectively through cycle count variance or RFID exception reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Flag' ;
    rdfs:comment 'Indicates whether a formal inventory adjustment has been posted in the inventory management system (SAP S/4HANA MM) to reflect the confirmed shrinkage loss. Ensures financial and operational inventory records are reconciled.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lpCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Lp Case Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the Loss Prevention (LP) department or case management system to track the investigation associated with this shrinkage incident. Used for cross-referencing with LP investigation workflows and law enforcement reports.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseCategory rdf:type rdf:Property ;
    rdfs:label 'Merchandise Category' ;
    rdfs:comment 'The merchandise hierarchy category of the affected product (e.g., Outerwear, Footwear, Accessories, Activewear). Supports high-shrink category identification for fixture security decisions and assortment risk reporting.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiSkuFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Sku Flag' ;
    rdfs:comment 'Indicates whether this shrinkage incident involves more than one Stock Keeping Unit (SKU). When true, additional affected SKUs are captured in the shrinkage_incident_line detail product. Supports accurate total incident valuation.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organizedRetailCrimeFlag rdf:type rdf:Property ;
    rdfs:label 'Organized Retail Crime Flag' ;
    rdfs:comment 'Indicates whether this incident has been classified as Organized Retail Crime (ORC) based on LP investigation findings. ORC incidents are escalated to regional LP teams and may be reported to law enforcement task forces. Supports ORC trend analysis and network-level investigation.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official law enforcement report number filed in connection with this shrinkage incident, where applicable (primarily external theft cases). Used for insurance claims, legal proceedings, and regulatory reporting.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLost rdf:type rdf:Property ;
    rdfs:label 'Quantity Lost' ;
    rdfs:comment 'Number of units confirmed lost or unaccounted for as a result of this shrinkage incident. Used as the primary quantitative measure for shrinkage rate KPI calculation and inventory adjustment.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Recovery Quantity' ;
    rdfs:comment 'Number of units recovered following the shrinkage incident (e.g., merchandise recovered from a shoplifter, items found misplaced). Used to calculate net shrinkage after recovery and to assess LP recovery effectiveness.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryValue rdf:type rdf:Property ;
    rdfs:label 'Recovery Value' ;
    rdfs:comment 'Retail value of merchandise recovered following the shrinkage incident. Used to calculate net financial impact after recovery and to report on LP recovery performance.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which the shrinkage incident was formally resolved and the case closed. Used to calculate case resolution cycle time and LP team performance metrics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The outcome or resolution method applied to close this shrinkage incident. Drives financial treatment (write-off vs. recovery vs. insurance claim) and vendor chargeback (Return to Vendor / RTV) processing.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailValueLost rdf:type rdf:Property ;
    rdfs:label 'Retail Value Lost' ;
    rdfs:comment 'Total retail selling value of the units lost in this incident, calculated as quantity_lost multiplied by the current retail price at time of discovery. Expressed in the store\'s operating currency. Used as the primary monetary measure for shrinkage rate KPI (target <1.5% of net sales) and financial write-off processing.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Exception Flag' ;
    rdfs:comment 'Indicates whether this shrinkage incident was triggered or corroborated by a Radio Frequency Identification (RFID) inventory exception, such as an item present in RFID scan but absent from physical count, or vice versa. Supports RFID ROI analysis for loss prevention.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageType rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Type' ;
    rdfs:comment 'Primary classification of the shrinkage event by root cause. External theft covers shoplifting and organized retail crime; internal theft covers employee theft; administrative error covers mis-scans, pricing errors, and paperwork discrepancies; vendor fraud covers short-shipment or substitution fraud; damage/spoilage covers unsaleable goods. Drives LP investigation routing and shrinkage rate decomposition reporting.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeZone rdf:type rdf:Property ;
    rdfs:label 'Store Zone' ;
    rdfs:comment 'Specific area or zone within the store where the incident occurred (e.g., fitting room, entrance, stockroom, sales floor, cash wrap). Supports hotspot mapping for LP resource deployment and fixture security planning.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoEvidenceFlag rdf:type rdf:Property ;
    rdfs:label 'Video Evidence Flag' ;
    rdfs:comment 'Indicates whether video surveillance footage has been captured and retained as evidence for this shrinkage incident. Supports LP investigation documentation and legal proceedings.' ;
    rdfs:domain ind:ShrinkageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countScheduleId rdf:type rdf:Property ;
    rdfs:label 'Count Schedule Id' ;
    rdfs:comment 'Reference to the cycle count schedule or plan that generated this count event. Links scheduled counts to their originating plan for compliance tracking against the store\'s annual cycle count calendar.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:primaryStoreCounterAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Store Counter Associate Id' ;
    rdfs:comment 'Reference to the sales associate or stock associate who performed the physical count. Supports accountability tracking and count accuracy analysis by associate. Sourced from Workday HCM employee records.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:artsConformanceVersion rdf:type rdf:Property ;
    rdfs:label 'Arts Conformance Version' ;
    rdfs:comment 'The version of the NRF Association for Retail Technology Standards (ARTS) InventoryCount schema to which this record conforms. Supports regulatory and standards audit documentation.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisReservedQty rdf:type rdf:Property ;
    rdfs:label 'Bopis Reserved Qty' ;
    rdfs:comment 'The quantity of this SKU reserved for Buy Online Pick Up In Store (BOPIS) orders at the time of the cycle count. Excluded from Available to Sell (ATS) calculation and must be reconciled separately during omnichannel fulfillment accuracy review.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical inventory cycle count was conducted. Used for scheduling, trend analysis, and reconciliation against system on-hand as of that date. Principal business event date for this transaction.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalCountQty rdf:type rdf:Property ;
    rdfs:label 'Physical Count Qty' ;
    rdfs:comment 'The actual quantity of units physically counted and verified on the store floor or stockroom for this SKU during the cycle count. This is the raw count result entered by the counter associate.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountQty rdf:type rdf:Property ;
    rdfs:label 'Recount Qty' ;
    rdfs:comment 'The quantity recorded during a mandatory recount triggered when the initial physical count variance exceeds the tolerance threshold. Null if no recount was performed. Used to validate or override the original physical count.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount was triggered for this SKU because the initial variance exceeded the store\'s tolerance threshold. True = recount was required and performed; False = variance within acceptable tolerance.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retailUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Unit Price' ;
    rdfs:comment 'The current retail selling price (Average Unit Retail — AUR) of the SKU at the time of the cycle count. Used to calculate variance retail value and supports Manufacturers Suggested Retail Price (MSRP) compliance checks.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromStoreReservedQty rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Reserved Qty' ;
    rdfs:comment 'The quantity of this SKU reserved for ship-from-store fulfillment orders at the time of the cycle count. Supports omnichannel inventory accuracy and Available to Promise (ATP) reconciliation.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemOnHandQty rdf:type rdf:Property ;
    rdfs:label 'System On Hand Qty' ;
    rdfs:comment 'The inventory quantity recorded in the system of record (SAP S/4HANA MM or SAP CAR) at the time the cycle count was initiated. Serves as the baseline for variance calculation. Represents the book inventory position before physical count.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceCostValue rdf:type rdf:Property ;
    rdfs:label 'Variance Cost Value' ;
    rdfs:comment 'The monetary value of the inventory variance expressed at cost (Cost of Goods Sold — COGS basis). Used for financial inventory write-down reporting and EBITDA impact analysis. Expressed in the store\'s operating currency.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The inventory variance expressed as a percentage of system on-hand quantity (variance_qty / system_on_hand_qty × 100). Used to measure inventory accuracy against the target KPI of greater than 98% accuracy per NRF best practices.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQty rdf:type rdf:Property ;
    rdfs:label 'Variance Qty' ;
    rdfs:comment 'The unit difference between physical count quantity and system on-hand quantity (physical_count_qty minus system_on_hand_qty). Negative values indicate shrinkage or unrecorded outbound movement; positive values indicate unrecorded inbound or phantom inventory.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceRetailValue rdf:type rdf:Property ;
    rdfs:label 'Variance Retail Value' ;
    rdfs:comment 'The monetary value of the inventory variance expressed at retail price (variance_qty multiplied by the current retail price of the SKU). Used for shrinkage dollar reporting, loss prevention analysis, and financial reconciliation. Expressed in the store\'s operating currency.' ;
    rdfs:domain ind:StoreCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Alphanumeric code identifying the physical zone or area within the store that was counted (e.g., sales floor, stockroom, fitting room, receiving dock). Enables zone-level inventory accuracy analysis and targeted shrinkage investigation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficCountId rdf:type rdf:Property ;
    rdfs:label 'Traffic Count Id' ;
    rdfs:comment 'Primary key for traffic_count' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgDwellTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Avg Dwell Time Seconds' ;
    rdfs:comment 'Average time in seconds that customers spent inside the store or zone during the counting period, as measured by stereoscopic video analytics or thermal sensors. Indicates customer engagement depth and supports visual merchandising effectiveness analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceRate rdf:type rdf:Property ;
    rdfs:label 'Bounce Rate' ;
    rdfs:comment 'Proportion of visitors who entered the store or zone but exited within a very short dwell threshold (typically under 30 seconds) without engaging, expressed as a decimal (e.g., 0.1500 = 15%). Indicates storefront or window display effectiveness.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captureRate rdf:type rdf:Property ;
    rdfs:label 'Capture Rate' ;
    rdfs:comment 'Ratio of store entries to total passing pedestrian traffic (entry_count ÷ passing_traffic_count), expressed as a decimal. Key metric for lease negotiation support and storefront effectiveness benchmarking.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDirection rdf:type rdf:Property ;
    rdfs:label 'Count Direction' ;
    rdfs:comment 'Indicates whether the sensor captures bidirectional traffic (both entries and exits), inbound only, or outbound only. Affects how entry_count and exit_count values should be interpreted.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countHour rdf:type rdf:Property ;
    rdfs:label 'Count Hour' ;
    rdfs:comment 'Hour of the day (0–23) for which this traffic count record applies. Enables hourly granularity for peak-hour staffing optimization and intraday traffic pattern analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countPeriodType rdf:type rdf:Property ;
    rdfs:label 'Count Period Type' ;
    rdfs:comment 'Granularity of the traffic count record indicating whether the record represents an hourly, daily, weekly, or monthly aggregation. Supports multi-granularity reporting in the silver layer.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Day of the week corresponding to the count_date. Used for weekly traffic pattern analysis, staffing models, and comparative performance reporting. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryCount rdf:type rdf:Property ;
    rdfs:label 'Entry Count' ;
    rdfs:comment 'Total number of customer entries (inbound foot-traffic) recorded by the sensor during the counting period. Core traffic KPI used for store performance analysis, lease negotiation, and staffing optimization.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitCount rdf:type rdf:Property ;
    rdfs:label 'Exit Count' ;
    rdfs:comment 'Total number of customer exits (outbound foot-traffic) recorded by the sensor during the counting period. Used alongside entry_count to calculate net occupancy and validate sensor accuracy.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapFilledFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Filled Flag' ;
    rdfs:comment 'Indicates whether any portion of the traffic count for this period was estimated or interpolated due to sensor downtime or data loss (True = gap-filled). Supports data lineage transparency and analytics confidence scoring.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Indicates whether the count_date falls on a public or retail holiday (True = holiday). Enables holiday-adjusted traffic benchmarking and year-over-year comparable analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Period' ;
    rdfs:comment 'Indicates whether the counting period coincides with an active promotional or markdown event (True = promotional period). Enables traffic lift analysis attributable to marketing and promotional activities.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreOpen rdf:type rdf:Property ;
    rdfs:label 'Is Store Open' ;
    rdfs:comment 'Indicates whether the store was open for trading during the counting period (True = open). Used to exclude closed-period records from traffic KPI calculations and to identify after-hours sensor anomalies.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOccupancyCount rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy Count' ;
    rdfs:comment 'Peak simultaneous occupancy count recorded within the counting period, derived from cumulative entry minus exit counts. Used for compliance with fire safety occupancy limits and store capacity management.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingTrafficCount rdf:type rdf:Property ;
    rdfs:label 'Passing Traffic Count' ;
    rdfs:comment 'Number of pedestrians passing in front of the store entrance without entering, as measured by external-facing sensors. Used to calculate store capture rate (entry_count ÷ passing_traffic_count) for lease negotiation and location performance benchmarking.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakHourFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Flag' ;
    rdfs:comment 'Indicates whether the counting period falls within a designated peak trading hour for the store (True = peak hour). Used for staffing optimization and scheduling decisions.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Timestamp' ;
    rdfs:comment 'Exact timestamp marking the end of the traffic counting period (yyyy-MM-ddTHH:mm:ss.SSSXXX). Together with period_start_timestamp defines the precise observation window.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Start Timestamp' ;
    rdfs:comment 'Exact timestamp marking the beginning of the traffic counting period (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for precise temporal alignment of hourly and sub-hourly records.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of the traffic count record indicating data quality state. \'active\' = validated sensor data; \'estimated\' = gap-filled via interpolation; \'adjusted\' = manually corrected; \'excluded\' = removed from KPI calculations; \'pending_review\' = flagged for data quality review.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Reference to the specific traffic counting sensor device that recorded this observation. Enables sensor-level data quality monitoring and calibration tracking.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Technology type of the traffic counting sensor that generated this record. [ENUM-REF-CANDIDATE: ir_beam_break|stereoscopic_video|thermal|time_of_flight|wifi_bluetooth — promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorUptimePct rdf:type rdf:Property ;
    rdfs:label 'Sensor Uptime Pct' ;
    rdfs:comment 'Percentage of the counting period during which the sensor was operational and recording valid data (0.00–100.00). Used to assess data completeness and determine whether gap-filling or estimation is required.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromStoreCount rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Count' ;
    rdfs:comment 'Number of ship-from-store fulfillment orders processed at the store during the counting period. Supports omnichannel fulfillment traffic analysis and store-as-warehouse capacity planning.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffCountScheduled rdf:type rdf:Property ;
    rdfs:label 'Staff Count Scheduled' ;
    rdfs:comment 'Number of sales associates scheduled to be on the store floor during the counting period. Used to calculate traffic-to-staff ratio for staffing optimization and labor productivity analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient outdoor temperature in degrees Celsius at the store location during the counting period. Used as a quantitative weather covariate in traffic regression models and seasonal demand planning.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Prevailing weather condition at the store location during the counting period. Used as an external factor in traffic variance analysis and demand forecasting models. [ENUM-REF-CANDIDATE: clear|cloudy|rain|snow|storm|extreme_heat — promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'ISO calendar week number (1–53) of the count_date. Supports weekly traffic trend analysis and year-over-year comparisons aligned to the retail fiscal calendar.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visualMerchandisingPlanId rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the visual merchandising plan record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisualMerchandisingPlan .

ind:vmAssociateId rdf:type rdf:Property ;
    rdfs:label 'Vm Associate Id' ;
    rdfs:comment 'Identifier of the visual merchandising associate or field representative responsible for executing and auditing this plan at the store level. References the workforce/associate master.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:collectionDisplayGuidelines rdf:type rdf:Property ;
    rdfs:label 'Collection Display Guidelines' ;
    rdfs:comment 'Narrative description of the seasonal collection display guidelines, including brand story, lifestyle theme, hero product callouts, and cross-category adjacency rules. Sourced from Centric PLM collection management.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorBlockingDirection rdf:type rdf:Property ;
    rdfs:label 'Color Blocking Direction' ;
    rdfs:comment 'Prescribed color sequencing strategy for merchandise presentation on fixtures and walls. Drives visual consistency across stores within the same cluster.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The date by which the store team must resolve all non-compliant zones and resubmit evidence for re-audit. Drives escalation workflows in SAP Customer Activity Repository.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionNotes rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Notes' ;
    rdfs:comment 'Free-text description of the corrective actions prescribed by the VM field team or regional manager to remediate non-compliant zones identified during the audit.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureLayoutCode rdf:type rdf:Property ;
    rdfs:label 'Fixture Layout Code' ;
    rdfs:comment 'Code identifying the prescribed fixture configuration for the store floor (e.g., gondola arrangement, wall system, freestanding unit layout). References the fixture library in Oracle Retail or Centric PLM.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mannequinCount rdf:type rdf:Property ;
    rdfs:label 'Mannequin Count' ;
    rdfs:comment 'Total number of mannequins specified in the visual merchandising plan, including window and interior mannequins. Drives mannequin styling instruction tracking.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mannequinStylingNotes rdf:type rdf:Property ;
    rdfs:label 'Mannequin Styling Notes' ;
    rdfs:comment 'Free-text instructions for mannequin outfit composition, accessory pairings, pose direction, and wig/hair styling as specified by the VM creative team. Sourced from Centric PLM tech pack directives.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompliantZoneCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Zone Count' ;
    rdfs:comment 'Number of merchandising zones found to be non-compliant during the most recent audit. Used to prioritize corrective action and track improvement over audit cycles.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonCompliantZoneNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Zone Notes' ;
    rdfs:comment 'Free-text description of the specific zones, fixtures, or product placements found to be non-compliant during the audit, including the nature of each deviation from the plan directive.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Flag' ;
    rdfs:comment 'Indicates whether this visual merchandising plan includes omnichannel fulfillment zone directives such as BOPIS (Buy Online Pick Up In Store) or ship-from-store staging area setup.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Planogram Document Url' ;
    rdfs:comment 'URL or file path to the planogram PDF or digital asset stored in the content management system. Provides store teams direct access to the fixture layout and product placement diagrams.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramVersion rdf:type rdf:Property ;
    rdfs:label 'Planogram Version' ;
    rdfs:comment 'Version identifier of the planogram document associated with this plan (e.g., v1.0, v2.3). Tracks revisions issued to stores after initial publication. Sourced from Oracle Retail Merchandising System planogram management.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPlacementZoneNotes rdf:type rdf:Property ;
    rdfs:label 'Product Placement Zone Notes' ;
    rdfs:comment 'Narrative instructions describing product placement by zone, wall, table, and window. Captures hero product positioning, color blocking direction, and adjacency rules for the floor set.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signageNotes rdf:type rdf:Property ;
    rdfs:label 'Signage Notes' ;
    rdfs:comment 'Free-text notes detailing specific signage placement instructions, size requirements, and messaging guidelines for this visual merchandising plan.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signageSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Signage Specification Code' ;
    rdfs:comment 'Code referencing the signage package specification (e.g., price tickets, lifestyle imagery, campaign headers, promotional banners) prescribed for this plan. Links to the signage asset library.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRunDisplayStandard rdf:type rdf:Property ;
    rdfs:label 'Size Run Display Standard' ;
    rdfs:comment 'Standard governing how size runs are displayed on the sales floor (e.g., full size run on fixture, key sizes only on mannequin). Aligns with Oracle Retail size curve and assortment planning.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Flag' ;
    rdfs:comment 'Indicates whether the visual merchandising plan materials (fixtures, signage, packaging) comply with the company\'s sustainability standards, including GOTS, BCI, and OEKO-TEX requirements for display materials.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowDisplayCount rdf:type rdf:Property ;
    rdfs:label 'Window Display Count' ;
    rdfs:comment 'Number of storefront window displays included in this visual merchandising plan. Used to track window execution compliance separately from interior floor sets.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCount rdf:type rdf:Property ;
    rdfs:label 'Zone Count' ;
    rdfs:comment 'Total number of distinct merchandising zones (e.g., front-of-store, mid-floor, back wall, window) covered by this visual merchandising plan.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Vm Compliance Check Id' ;
    rdfs:comment 'Unique surrogate identifier for each visual merchandising compliance audit record. Primary key for the vm_compliance_check data product.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Auditor Associate Id' ;
    rdfs:comment 'Identifier of the individual who conducted the audit — either the store manager or a field visual merchandising team member. Links to the workforce/associate master.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:priorAuditComplianceCheckVmComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Prior Audit Compliance Check Vm Compliance Check Id' ;
    rdfs:comment 'Reference to the immediately preceding compliance check record for this store and VM plan, enabling trend analysis and comparison of compliance scores across audit cycles.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmComplianceCheck .

ind:reAuditComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Re Audit Compliance Check Id' ;
    rdfs:comment 'Reference to the subsequent re-audit compliance check record created after corrective actions are completed. Enables chaining of audit and re-audit records for full remediation lifecycle tracking.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmComplianceCheck .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time at which the store manager formally acknowledged the audit findings. Populated only when store_manager_acknowledgement_flag is True.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'General free-text observations and comments recorded by the auditor during the compliance check. Captures context not covered by structured fields, such as store-specific circumstances, staffing constraints, or positive observations.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Precise date and time at which the compliance audit was initiated in the store, including timezone offset. Supports intraday scheduling and field team coordination.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditorRole rdf:type rdf:Property ;
    rdfs:label 'Auditor Role' ;
    rdfs:comment 'Job role of the individual who conducted the audit. Distinguishes between internal store management audits and field visual merchandising team audits, which may carry different authority levels.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Overall percentage compliance score achieved by the store for this audit, expressed as a value between 0.00 and 100.00. Calculated by the auditor based on the number of compliant zones versus total zones assessed. Enables fleet-wide brand consistency benchmarking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold' ;
    rdfs:comment 'Minimum compliance score percentage required for the store to be considered passing for this audit period. Captured at time of audit to preserve the standard in effect, as thresholds may change over time.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compliantZonesCount rdf:type rdf:Property ;
    rdfs:label 'Compliant Zones Count' ;
    rdfs:comment 'Number of assessed zones that were found to be fully compliant with the VM plan directives. Used alongside total_zones_assessed to validate the compliance_score.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalViolationDescription rdf:type rdf:Property ;
    rdfs:label 'Critical Violation Description' ;
    rdfs:comment 'Free-text description of any critical brand standard violations identified. Populated only when critical_violation_flag is True. Documents the nature and location of the violation for escalation and remediation tracking.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Violation Flag' ;
    rdfs:comment 'Indicates whether any critical brand standard violations were identified during the audit (True = at least one critical violation present). Critical violations typically require immediate corrective action and may trigger escalation to district or regional management.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixtureLayoutCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fixture Layout Compliant Flag' ;
    rdfs:comment 'Indicates whether the physical fixture layout and product adjacency on the sales floor matched the VM plan floor map directive during this audit.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foldingHangingCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Folding Hanging Compliant Flag' ;
    rdfs:comment 'Indicates whether product folding, hanging, and presentation standards (e.g., size sequencing, color blocking, facing direction) were compliant with the VM directive during this audit.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lightingCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Lighting Compliant Flag' ;
    rdfs:comment 'Indicates whether store lighting (accent, ambient, and feature lighting) was set in accordance with the VM plan specifications during this audit.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mannequinStylingCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Mannequin Styling Compliant Flag' ;
    rdfs:comment 'Indicates whether mannequin styling and outfit coordination across the store floor was compliant with the VM plan directive. Mannequin presentation is a key brand consistency indicator in apparel retail.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompliantZones rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Zones' ;
    rdfs:comment 'Comma-separated list or free-text description of the specific store zones or sections found to be non-compliant during the audit (e.g., \'Front Window Display, Denim Wall, Checkout Counter\'). Enables targeted corrective action assignment.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Flag' ;
    rdfs:comment 'Indicates whether the store passed (True) or failed (False) the compliance audit based on whether the compliance_score met or exceeded the compliance_threshold. Drives escalation and corrective action workflows.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photographic evidence images captured and attached to this compliance audit record. Photos document both compliant and non-compliant zones and are stored in the associated document management system.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'External reference identifier or URL path to the photo evidence package stored in the document management or digital asset management system for this audit record.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reAuditDate rdf:type rdf:Property ;
    rdfs:label 'Re Audit Date' ;
    rdfs:comment 'Scheduled or actual date for the follow-up re-audit to verify that corrective actions have been completed and the store is now compliant. Populated only when re_audit_required_flag is True.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Audit Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up re-audit is required for this store (True = re-audit scheduled or required). Typically set to True when the store fails the initial audit or when critical violations are identified.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signageCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Signage Compliant Flag' ;
    rdfs:comment 'Indicates whether in-store signage (promotional, price, directional, and brand signage) was compliant with the VM plan and current marketing campaign directives during this audit.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeManagerAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Store Manager Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the store manager has formally acknowledged receipt of the audit findings and corrective action requirements (True = acknowledged). Required for audit closure in many brand compliance frameworks.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalZonesAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Zones Assessed' ;
    rdfs:comment 'Total number of visual merchandising zones or sections evaluated during the audit (e.g., front window, entrance table, wall fixtures, fitting room corridor). Provides the denominator for compliance scoring.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmDirectiveVersion rdf:type rdf:Property ;
    rdfs:label 'Vm Directive Version' ;
    rdfs:comment 'Version identifier of the VM plan or directive document against which this audit was conducted (e.g., \'v2.1\'). Ensures auditability when VM directives are updated mid-season.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDisplayCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Window Display Compliant Flag' ;
    rdfs:comment 'Indicates whether the store\'s front window display was found to be compliant with the VM plan directive during this audit. Window displays are a high-visibility brand touchpoint and are tracked separately.' ;
    rdfs:domain ind:VmComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityProfileId rdf:type rdf:Property ;
    rdfs:label 'Capacity Profile Id' ;
    rdfs:comment 'Unique identifier for the capacity profile record. Primary key.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Confirmation Date' ;
    rdfs:comment 'Date when the factory formally confirmed or committed to this capacity allocation.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Capacity Risk Level' ;
    rdfs:comment 'Risk assessment level for capacity availability based on factory performance, compliance, and external factors (low, medium, high, critical).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityType rdf:type rdf:Property ;
    rdfs:label 'Capacity Type' ;
    rdfs:comment 'Classification of capacity status: allocated (assigned to orders), reserved (held for future orders), available (open for booking), committed (contractually bound), or planned (forecasted).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Month' ;
    rdfs:comment 'Total production capacity expressed in units per month for the specified product category and season.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Valid From Date' ;
    rdfs:comment 'Start date of the period for which this capacity profile is valid and applicable.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityValidToDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Valid To Date' ;
    rdfs:comment 'End date of the period for which this capacity profile is valid and applicable.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Current status of factory compliance certifications (WRAP, FLA, GOTS, OEKO-TEX) relevant to this capacity profile.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum number of units that can be produced in a single production run or order cycle for this product category.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target percentage for on-time and in-full delivery performance expected from this factory for this capacity profile.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Season Flag' ;
    rdfs:comment 'Indicator whether this capacity profile represents a peak production season with higher demand and tighter lead times.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningSystemSource rdf:type rdf:Property ;
    rdfs:label 'Planning System Source' ;
    rdfs:comment 'Name of the source planning system or module from which this capacity profile was created or synchronized (e.g., Anaplan, SAP PP, Oracle RMS).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCount rdf:type rdf:Property ;
    rdfs:label 'Production Line Count' ;
    rdfs:comment 'Number of production lines or assembly lines dedicated to this product category during the capacity period.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Historical quality acceptance rate (percentage of units passing quality inspection) for this factory and product category.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of total capacity currently utilized, calculated as (allocated + reserved) / total capacity * 100.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmtAgreementId rdf:type rdf:Property ;
    rdfs:label 'Cmt Agreement Id' ;
    rdfs:comment 'Unique identifier for the CMT agreement record. Primary key.' ;
    rdfs:domain ind:CmtAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CMT agreements are negotiated and managed by sourcing employees responsible for contract terms, renewals, amendments, and performance monitoring. Essential for contract lifecycle management, approval ' ;
    rdfs:domain ind:CmtAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_agreement. Business justification: CMT agreements are specific contract types that should reference their parent master vendor agreement. vendor_agreement is the framework contract governing the overall commercial relationship; cmt_agr' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAgreement .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments or addendums made to the original agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCommitmentUnitsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Commitment Units Per Month' ;
    rdfs:comment 'Contracted monthly production capacity in units that the factory commits to reserve for the brand.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmtRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Cmt Rate Per Unit' ;
    rdfs:comment 'Contracted CMT manufacturing cost per unit (garment or pair). Excludes materials cost.' ;
    rdfs:domain ind:CmtAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'Comma-separated list of mandatory compliance certifications the factory must maintain (e.g., WRAP, FLA, GOTS, OEKO-TEX, BSCI).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether a non-disclosure agreement (NDA) or confidentiality clause is included in this CMT agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Total estimated or committed contract value over the agreement term, in agreement currency. May be null for open-ended agreements.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed method for resolving contractual disputes: negotiation, mediation, arbitration, or litigation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fobPort rdf:type rdf:Property ;
    rdfs:label 'Fob Port' ;
    rdfs:comment 'Named port of shipment for FOB delivery terms (e.g., Shanghai, Ningbo, Ho Chi Minh City).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a force majeure clause covering unforeseeable circumstances (natural disasters, pandemics, war) that prevent contract fulfillment.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderSpecialization rdf:type rdf:Property ;
    rdfs:label 'Gender Specialization' ;
    rdfs:comment 'Gender segment specialization for products manufactured under this agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law that applies to this agreement (e.g., New York USA, Hong Kong, England and Wales).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Description of insurance coverage the factory must maintain (e.g., product liability, workers compensation, property insurance).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipClause rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Clause' ;
    rdfs:comment 'Contractual clause defining ownership of designs, patterns, tech packs, and other intellectual property created under this agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to the agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lc Required Flag' ;
    rdfs:comment 'Indicates whether a letter of credit is required for payment under this agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcTerms rdf:type rdf:Property ;
    rdfs:label 'Lc Terms' ;
    rdfs:comment 'Specific terms and conditions for letter of credit issuance, including sight or usance period.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount that either party can claim for breach of contract or damages, in agreement currency.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqValue rdf:type rdf:Property ;
    rdfs:label 'Moq Value' ;
    rdfs:comment 'Minimum order value threshold required per order or season, in agreement currency.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Value of the performance bond or bank guarantee required, in agreement currency.' ;
    rdfs:domain ind:CmtAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the factory is required to provide a performance bond or bank guarantee to secure contract obligations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required to prevent automatic renewal or to initiate renewal negotiations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryNameBuyer rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Buyer' ;
    rdfs:comment 'Full name and title of the authorized signatory representing the brand/buyer.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNameVendor rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Vendor' ;
    rdfs:comment 'Full name and title of the authorized signatory representing the vendor/factory.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the CMT agreement was signed by both parties.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal employee coordinates audit scheduling, accompanies auditors, manages corrective action plan follow-up, and tracks remediation. Required for compliance reporting, audit calendar management, an' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:announcedFlag rdf:type rdf:Property ;
    rdfs:label 'Announced Flag' ;
    rdfs:comment 'Boolean indicator of whether the audit was announced to the supplier in advance. True indicates the supplier was notified ahead of time; False indicates an unannounced surprise audit.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees, travel expenses, and certification body charges. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of days spent conducting the on-site audit fieldwork. Includes partial days represented as decimals (e.g., 2.5 days).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date when the audit fieldwork concluded. For multi-day audits, this represents the last day of on-site inspection.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFramework rdf:type rdf:Property ;
    rdfs:label 'Audit Framework' ;
    rdfs:comment 'The compliance standard or framework against which the audit was conducted. Examples include FLA Workplace Code of Conduct, WRAP 12 Principles, BSCI Code of Conduct, Sedex SMETA, GOTS, OEKO-TEX Standard 100, ISO 14001, SA8000.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Letter grade or categorical rating assigned to the factory based on audit performance. Grading systems vary by certification body and audit framework. [ENUM-REF-CANDIDATE: A|B|C|D|F|Pass|Conditional Pass|Fail|Gold|Silver|Bronze — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'URL or file path to the full audit report document stored in the document management system. Provides access to detailed findings, evidence, and recommendations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'The date when the audit fieldwork began. For multi-day audits, this represents the first day of on-site inspection.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditingFirm rdf:type rdf:Property ;
    rdfs:label 'Auditing Firm' ;
    rdfs:comment 'Name of the third-party auditing organization or certification body that conducted the audit. Examples include Bureau Veritas, SGS, Intertek, UL, TUV. Null if the audit was conducted by internal compliance team.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Approved Flag' ;
    rdfs:comment 'Boolean indicator of whether the submitted Corrective Action Plan has been reviewed and approved by the compliance team or auditing body. True indicates approval; False indicates rejection or pending review.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capDueDate rdf:type rdf:Property ;
    rdfs:label 'Cap Due Date' ;
    rdfs:comment 'The deadline by which the supplier must submit a formal Corrective Action Plan addressing all identified non-conformances. Null if no CAP is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal Corrective Action Plan is required from the supplier to address identified non-conformances. True indicates CAP is mandatory; False indicates no CAP required (typically for audits with no significant findings).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Cap Submitted Date' ;
    rdfs:comment 'The date when the supplier submitted their Corrective Action Plan in response to audit findings. Null if CAP has not yet been submitted or is not required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification body issuing the compliance certificate or audit credential. Relevant for WRAP, FLA, GOTS, OEKO-TEX, BSCI, and Sedex audits.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Certification Valid From Date' ;
    rdfs:comment 'The effective start date of the compliance certification issued as a result of this audit. Applicable for certification audits (WRAP, FLA, GOTS, OEKO-TEX). Null for non-certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Certification Valid Until Date' ;
    rdfs:comment 'The expiration date of the compliance certification issued as a result of this audit. Applicable for certification audits (WRAP, FLA, GOTS, OEKO-TEX). Null for non-certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalNcrCount rdf:type rdf:Property ;
    rdfs:label 'Critical Ncr Count' ;
    rdfs:comment 'Number of critical non-conformances identified during the audit. Critical NCRs represent severe violations that pose immediate risk to worker safety, health, or fundamental rights (e.g., child labor, forced labor, unsafe structural conditions).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryScore rdf:type rdf:Property ;
    rdfs:label 'Factory Score' ;
    rdfs:comment 'Overall numerical score assigned to the factory based on audit findings. Scoring scale varies by audit framework (e.g., 0-100 for some frameworks, A-F letter grades converted to numeric for others). Higher scores indicate better compliance.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Final Audit Status' ;
    rdfs:comment 'The final outcome determination of the audit after all reviews and corrective actions. Pass indicates full compliance; Conditional Pass indicates compliance with minor issues requiring monitoring; Fail indicates non-compliance requiring immediate action; Pending Corrective Action indicates awaiting CAP implementation; Certification Granted/Denied applies to certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level narrative summary of the key audit findings, including strengths, weaknesses, and areas of concern identified during the inspection. Provides context for the numerical scores and NCR counts.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Major Ncr Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major NCRs represent significant violations of compliance standards that require corrective action but do not pose immediate critical risk.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementInterviewsCount rdf:type rdf:Property ;
    rdfs:label 'Management Interviews Count' ;
    rdfs:comment 'Number of factory management personnel interviewed during the audit to assess management systems, policies, and commitment to compliance.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Minor Ncr Count' ;
    rdfs:comment 'Number of minor non-conformances identified during the audit. Minor NCRs represent less severe violations or areas for improvement that do not significantly impact compliance status.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reauditDueDate rdf:type rdf:Property ;
    rdfs:label 'Reaudit Due Date' ;
    rdfs:comment 'The scheduled date for the follow-up re-audit to verify corrective action implementation. Null if no re-audit is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reauditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reaudit Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a follow-up re-audit is required to verify that corrective actions have been implemented and non-conformances have been resolved. True indicates re-audit is mandatory; False indicates no re-audit needed.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerInterviewsCount rdf:type rdf:Property ;
    rdfs:label 'Worker Interviews Count' ;
    rdfs:comment 'Number of factory workers interviewed during the audit as part of the social compliance assessment. Worker interviews are a key component of FLA, WRAP, and BSCI audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierFactoryCertificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Factory Certification Id' ;
    rdfs:comment 'Unique identifier for the factory certification record. Primary key.' ;
    rdfs:domain ind:SupplierFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationCost rdf:type rdf:Property ;
    rdfs:label 'Certification Cost' ;
    rdfs:comment 'Total cost incurred for obtaining or renewing the certification, including audit fees, consulting fees, and administrative costs. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Certification Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:SupplierFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certification is included in Environmental, Social, and Governance (ESG) reporting and sustainability disclosures. True if included in ESG reporting. False otherwise.' ;
    rdfs:domain ind:SupplierFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'Specific product categories or types covered by the certification (e.g., \'Woven apparel\', \'Knit garments\', \'Footwear\', \'Accessories\'). Indicates which product lines are certified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certification is publicly disclosed on the company\'s website or in sustainability reports. True if publicly disclosed. False if confidential.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Initiated Date' ;
    rdfs:comment 'Date on which the certification renewal process was formally initiated. Format: yyyy-MM-dd. Null if renewal has not been initiated.' ;
    rdfs:domain ind:SupplierFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'Detailed description of the scope and coverage of the certification, including specific product categories, processes, or facilities covered (e.g., \'Cut-Make-Trim operations for woven garments\', \'Dyeing and finishing of cotton fabrics\', \'Full manufacturing facility including warehousing\').' ;
    rdfs:domain ind:SupplierFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Approver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Material approvals require technical employee sign-off (product developers, technical designers, lab managers) for quality, sustainability, and performance standards. Essential for material qualificat' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedColorways rdf:type rdf:Property ;
    rdfs:label 'Approved Colorways' ;
    rdfs:comment 'List of approved color options or colorways that this supplier is qualified to provide for this material. Supports collection planning and merchandising.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Per Month' ;
    rdfs:comment 'Supplier\'s monthly production capacity for this material in the specified unit of measure. Used for capacity planning and allocation decisions.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositionPercentage rdf:type rdf:Property ;
    rdfs:label 'Composition Percentage' ;
    rdfs:comment 'Detailed percentage breakdown of material composition by component. Supports multi-component materials and blends.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Rating' ;
    rdfs:comment 'Supplier delivery performance rating based on OTIF (On Time In Full) metrics. Critical for supply chain reliability and TNA (Time and Action) planning.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBciCotton rdf:type rdf:Property ;
    rdfs:label 'Is Bci Cotton' ;
    rdfs:comment 'Indicates whether cotton content is BCI (Better Cotton Initiative) certified. Supports sustainable sourcing commitments and supply chain transparency.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOekoTexCertified rdf:type rdf:Property ;
    rdfs:label 'Is Oeko Tex Certified' ;
    rdfs:comment 'Indicates whether this material holds OEKO-TEX Standard 100 certification for textile safety. Required for certain retail partners and consumer safety compliance.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecycled rdf:type rdf:Property ;
    rdfs:label 'Is Recycled' ;
    rdfs:comment 'Indicates whether this material contains recycled content. Supports sustainability initiatives and circular economy reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oekoTexCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Certificate Number' ;
    rdfs:comment 'The OEKO-TEX Standard 100 certificate number for this material, if certified. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is a preferred or strategic supplier for this material. Influences sourcing decisions and allocation strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when this supplier-material combination was qualified and approved for the AVL (Approved Vendor List). Establishes the start of the supplier relationship for this material.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierItemCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Code' ;
    rdfs:comment 'The supplier\'s internal item code or SKU (Stock Keeping Unit) for this material. Used for purchase orders and supplier communication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityAttributes rdf:type rdf:Property ;
    rdfs:label 'Sustainability Attributes' ;
    rdfs:comment 'Additional sustainability certifications or attributes for this material (e.g., Fair Trade, Cradle to Cradle, bluesign). Supports ESG (Environmental Social Governance) reporting.' ;
    rdfs:domain ind:SupplierMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemOdmAgreementId rdf:type rdf:Property ;
    rdfs:label 'Oem Odm Agreement Id' ;
    rdfs:comment 'Unique identifier for the OEM/ODM partnership agreement record.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Required frequency of compliance and quality audits for the supplier under this OEM/ODM agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designOwnership rdf:type rdf:Property ;
    rdfs:label 'Design Ownership' ;
    rdfs:comment 'Specifies ownership rights for product designs, tech packs, and pattern specifications developed under this agreement.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingScope rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Scope' ;
    rdfs:comment 'Detailed description of the product categories, styles, or collections covered under this OEM/ODM agreement (e.g., mens activewear, womens footwear, accessories).' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSourcingResponsibility rdf:type rdf:Property ;
    rdfs:label 'Material Sourcing Responsibility' ;
    rdfs:comment 'Defines who is responsible for sourcing raw materials and components: buyer-nominated suppliers, supplier-sourced, or a combination.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompeteClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compete Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes non-compete provisions restricting the supplier from manufacturing similar products for competitors.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing structure agreed for manufacturing services under this OEM/ODM agreement (e.g., fixed unit price, cost-plus margin, volume-based discounts).' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDevelopmentTerms rdf:type rdf:Property ;
    rdfs:label 'Sample Development Terms' ;
    rdfs:comment 'Terms governing sample development including lead times, costs, approval processes, and ownership of pre-production (PP) samples.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNameSupplier rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Supplier' ;
    rdfs:comment 'Full name and title of the authorized representative who signed the agreement on behalf of the supplier.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRestriction rdf:type rdf:Property ;
    rdfs:label 'Territory Restriction' ;
    rdfs:comment 'Geographic regions or markets where the supplier is authorized or restricted from manufacturing, selling, or distributing products under this agreement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingOwnership rdf:type rdf:Property ;
    rdfs:label 'Tooling Ownership' ;
    rdfs:comment 'Specifies ownership of molds, dies, patterns, and other tooling developed for production under this agreement.' ;
    rdfs:domain ind:OemOdmAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the supplier risk assessment record. Primary key.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Risk assessments are owned by compliance managers or sourcing directors responsible for mitigation strategy execution and escalation. Critical for risk governance, remediation tracking, and regulatory' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which this risk assessment was conducted or recorded.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The methodology or approach used to conduct the risk assessment. Self-Assessment relies on supplier-provided information. Third-Party Audit uses independent auditors. Site Visit involves on-site inspection. Document Review analyzes certifications and records. Questionnaire uses structured surveys. Scorecard applies a standardized rating framework. Hybrid combines multiple methods. [ENUM-REF-CANDIDATE: Self-Assessment|Third-Party Audit|Site Visit|Document Review|Questionnaire|Scorecard|Hybrid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'The current workflow status of the risk assessment record. Draft indicates the assessment is being prepared. Under Review indicates it is awaiting approval. Approved indicates it has been validated and accepted. Closed indicates the risk has been resolved or is no longer relevant. Escalated indicates the risk requires senior management attention.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'The type or trigger of the risk assessment. Initial assessments occur during supplier onboarding, periodic assessments follow a schedule, triggered assessments respond to specific events or incidents.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactArea rdf:type rdf:Property ;
    rdfs:label 'Business Impact Area' ;
    rdfs:comment 'The primary business function or area that would be affected if the risk materializes. Supports prioritization and cross-functional risk management.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationReference rdf:type rdf:Property ;
    rdfs:label 'Certification Reference' ;
    rdfs:comment 'Reference number or identifier of any relevant certification or compliance audit that informed this risk assessment, such as WRAP, FLA, GOTS, OEKO-TEX, or ISO certifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Flag' ;
    rdfs:comment 'Indicates whether this risk assessment is related to Environmental, Social, or Governance (ESG) criteria. True if the risk has ESG implications, False otherwise. Supports ESG reporting and sustainability initiatives.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRiskRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Region' ;
    rdfs:comment 'The geographic region or country associated with this risk, if the risk is location-specific. Supports geopolitical and regional risk analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'A numeric score representing the severity of consequences if the risk materializes. Typically scored on a scale of 1 to 5, where 1 is Negligible and 5 is Catastrophic. Considers financial, operational, reputational, and compliance impacts.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'The overall risk level before any mitigation measures are applied. Typically derived from the combination of likelihood and impact scores. Low indicates minimal concern, Medium requires monitoring, High requires active management, and Critical demands immediate action and escalation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'A numeric score representing the probability that the risk will materialize. Typically scored on a scale of 1 to 5, where 1 is Very Unlikely and 5 is Very Likely. Used in conjunction with impact score to calculate inherent risk rating.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationCost rdf:type rdf:Property ;
    rdfs:label 'Mitigation Cost' ;
    rdfs:comment 'The estimated or actual cost of implementing the mitigation strategy, in the company\'s reporting currency. Supports cost-benefit analysis and risk management budgeting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'The current implementation status of the mitigation strategy. Tracks progress from planning through execution.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'A detailed description of the actions, controls, or measures implemented or planned to reduce the likelihood or impact of the risk. May include supplier development programs, contract clauses, diversification strategies, audits, or contingency plans.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'The risk level remaining after mitigation measures have been applied. Represents the accepted or tolerated risk level. Used to determine if additional mitigation is required or if the risk is within acceptable tolerance.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'A more granular classification of the risk within the primary category. For example, under Compliance, subcategories might include Child Labor, Forced Labor, Wage Violations, or Chemical Safety. Allows for detailed risk taxonomy.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Supplier Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the supplier audit finding record. Primary key for the supplier audit finding entity.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the corrective action was completed, verified, and the finding was formally closed. Null if the finding remains open.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Additional notes, observations, or context provided by the auditor regarding the finding, including mitigating factors, supplier cooperation, or special circumstances.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current status of the finding in the corrective action lifecycle. Open: newly identified, action not started. In Progress: corrective action underway. Pending Verification: action completed, awaiting verification. Closed: verified and accepted. Overdue: past target closure date without completion.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToRemediate rdf:type rdf:Property ;
    rdfs:label 'Cost To Remediate' ;
    rdfs:comment 'Estimated or actual cost incurred by the supplier to implement the corrective action and remediate the finding, including infrastructure upgrades, training, process changes, or equipment purchases.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Url' ;
    rdfs:comment 'URL or file path to supporting evidence documentation for the finding, including photographs, audit reports, corrective action plans, or verification records stored in the document management system.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance finding, including specific observations, conditions found, and evidence collected during the audit.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Date' ;
    rdfs:comment 'Date when the non-conformance finding was first identified during the audit inspection or assessment.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Business-readable unique reference number assigned to this non-conformance finding for tracking and communication purposes.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSubcategory rdf:type rdf:Property ;
    rdfs:label 'Finding Subcategory' ;
    rdfs:comment 'Detailed subcategory or specific compliance area within the primary finding category, providing granular classification for analysis and reporting.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFindingReference rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Reference' ;
    rdfs:comment 'Reference number of the previous finding if this is identified as a repeat finding, enabling linkage and trend analysis of recurring non-conformances.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Boolean indicator (True/False) identifying whether this finding is a repeat occurrence of a previously identified and closed non-conformance at the same supplier, indicating systemic compliance issues or ineffective corrective actions.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePartyTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Title' ;
    rdfs:comment 'Job title or position of the responsible party at the supplier factory, such as Factory Manager, Compliance Officer, or Health & Safety Coordinator.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed and the finding closed, based on severity level and agreed-upon remediation timeline.' ;
    rdfs:domain ind:SupplierAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the supplier delivery schedule record. Primary key for the Time and Action (T&A) calendar tracking production milestones from design handoff to ex-factory shipment.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkFabricInhouseActualDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Inhouse Actual Date' ;
    rdfs:comment 'Actual date when bulk fabric arrived at the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bulkFabricInhousePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Inhouse Planned Date' ;
    rdfs:comment 'Planned date for bulk fabric to arrive at the factory and be available for cutting.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutActualDate rdf:type rdf:Property ;
    rdfs:label 'Cut Actual Date' ;
    rdfs:comment 'Actual date when fabric cutting began.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Cut Planned Date' ;
    rdfs:comment 'Planned date for fabric cutting to begin in the Cut Make Trim (CMT) process.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Design Approval Actual Date' ;
    rdfs:comment 'Actual date when design was approved. Variance from planned date impacts downstream milestones.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Design Approval Planned Date' ;
    rdfs:comment 'Planned date for final design approval milestone before tech pack issue.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricBookingActualDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Booking Actual Date' ;
    rdfs:comment 'Actual date when bulk fabric was booked.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricBookingPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Booking Planned Date' ;
    rdfs:comment 'Planned date for booking bulk fabric with mills or suppliers.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionActualDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Actual Date' ;
    rdfs:comment 'Actual date when final quality inspection was completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Planned Date' ;
    rdfs:comment 'Planned date for final quality inspection before shipment authorization.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finishingActualDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Actual Date' ;
    rdfs:comment 'Actual date when finishing operations were completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finishingPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Planned Date' ;
    rdfs:comment 'Planned date for completing finishing operations including pressing, tagging, and packaging.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallDaysVariance rdf:type rdf:Property ;
    rdfs:label 'Overall Days Variance' ;
    rdfs:comment 'Total number of days the schedule is ahead (negative) or behind (positive) the planned ex-factory date. Key metric for supplier performance.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppSampleApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Actual Date' ;
    rdfs:comment 'Actual date when pre-production samples were approved.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Planned Date' ;
    rdfs:comment 'Planned date for approving pre-production samples and authorizing bulk production.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleSubmissionActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Submission Actual Date' ;
    rdfs:comment 'Actual date when pre-production samples were submitted.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleSubmissionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Submission Planned Date' ;
    rdfs:comment 'Planned date for factory to submit pre-production samples for approval.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleComments rdf:type rdf:Property ;
    rdfs:label 'Schedule Comments' ;
    rdfs:comment 'Free-text comments and notes regarding schedule status, delays, risks, or special instructions for this T&A calendar.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStartDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Start Date' ;
    rdfs:comment 'Planned start date of the T&A calendar, typically the design handoff or tech pack issue date.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewCompletionActualDate rdf:type rdf:Property ;
    rdfs:label 'Sew Completion Actual Date' ;
    rdfs:comment 'Actual date when sewing was completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewCompletionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Sew Completion Planned Date' ;
    rdfs:comment 'Planned date for completing the sewing phase of production.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentTerms rdf:type rdf:Property ;
    rdfs:label 'Shipment Terms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities and costs for shipping, such as Free on Board (FOB) or Delivered Duty Paid (DDP).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackIssueActualDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Issue Actual Date' ;
    rdfs:comment 'Actual date when tech pack was issued to the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:techPackIssuePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Issue Planned Date' ;
    rdfs:comment 'Planned date for issuing the technical specification package to the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaTemplateVersion rdf:type rdf:Property ;
    rdfs:label 'Tna Template Version' ;
    rdfs:comment 'Version identifier of the T&A template used to define the milestone structure and critical path for this schedule.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the factory was originally established or began operations. Indicates factory maturity and operational experience.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total manufacturing floor space in square meters. Used to assess factory scale, capacity utilization, and compliance with workplace safety standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent purchase order placed with this factory. Used to identify inactive suppliers and manage supplier lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:machineryTypes rdf:type rdf:Property ;
    rdfs:label 'Machinery Types' ;
    rdfs:comment 'Comma-separated list of key machinery and equipment types available at the factory (e.g., single-needle machines, overlock machines, flatlock machines, buttonhole machines, pressing equipment, cutting tables). Determines production capabilities and product suitability.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines or assembly lines operating within the factory. Indicates scale and parallel production capability.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoriesManufactured rdf:type rdf:Property ;
    rdfs:label 'Product Categories Manufactured' ;
    rdfs:comment 'Comma-separated list of product categories the factory is equipped to manufacture (e.g., T-shirts, Dresses, Outerwear, Denim, Activewear, Footwear, Accessories). Used for supplier selection and product allocation.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCapacityUnitsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Units Per Month' ;
    rdfs:comment 'Maximum monthly production capacity of the factory measured in units (garments, pieces, or pairs). Used for capacity planning, order allocation, and Open-to-Buy (OTB) calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStructure rdf:type rdf:Property ;
    rdfs:label 'Shift Structure' ;
    rdfs:comment 'Daily shift operation model of the factory. Indicates production hours and capacity flexibility. Triple shift operations provide maximum throughput but require strong labor compliance oversight.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Profile Id' ;
    rdfs:comment 'Unique identifier for the sustainability and ESG profile record.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bciCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Bci Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier is certified under the Better Cotton Initiative for sustainable cotton sourcing.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bluesignCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Bluesign Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds Bluesign certification for sustainable textile production and chemical management.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonFootprintTco2eYear rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Tco2e Year' ;
    rdfs:comment 'Total annual carbon emissions measured in metric tons of CO2 equivalent (tCO2e) for the supplier facility.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chemicalInventoryDisclosedFlag rdf:type rdf:Property ;
    rdfs:label 'Chemical Inventory Disclosed Flag' ;
    rdfs:comment 'Indicates whether the supplier has disclosed a full chemical inventory and formulation list for transparency and compliance.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityInvestmentPrograms rdf:type rdf:Property ;
    rdfs:label 'Community Investment Programs' ;
    rdfs:comment 'Description of community investment and social responsibility programs operated by the supplier, including education, healthcare, and local development initiatives.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFramework rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Framework' ;
    rdfs:comment 'Primary ESG reporting framework or standard used by the supplier for sustainability disclosure (GRI, SASB, TCFD, CDP, UN Global Compact, or Integrated Reporting).' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flaAccreditedFlag rdf:type rdf:Property ;
    rdfs:label 'Fla Accredited Flag' ;
    rdfs:comment 'Indicates whether the supplier is accredited by the Fair Labor Association for labor rights compliance.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderEqualityScore rdf:type rdf:Property ;
    rdfs:label 'Gender Equality Score' ;
    rdfs:comment 'Numerical score (0-100) representing the supplier\'s performance on gender equality metrics including pay equity, representation, and workplace policies.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gotsCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gots Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds valid GOTS certification for organic textile processing.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:higgFemScore rdf:type rdf:Property ;
    rdfs:label 'Higg Fem Score' ;
    rdfs:comment 'Higg FEM score (0-100) measuring the environmental performance of the manufacturing facility across energy, water, waste, and emissions.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:higgFslmScore rdf:type rdf:Property ;
    rdfs:label 'Higg Fslm Score' ;
    rdfs:comment 'Higg FSLM score (0-100) measuring the social and labor performance of the facility including worker rights, health and safety, and management systems.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 14001 certification for environmental management systems.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds valid ISO 45001 certification for occupational health and safety management systems.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livingWageCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Living Wage Compliant Flag' ;
    rdfs:comment 'Indicates whether the supplier pays workers a living wage that meets or exceeds local living wage benchmarks.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'Scheduled date for the next sustainability or ESG assessment or audit.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oekoTexCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds valid OEKO-TEX Standard 100 certification for textile safety.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableEnergyPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Percentage' ;
    rdfs:comment 'Percentage of total energy consumption sourced from renewable energy sources (solar, wind, hydro, etc.).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traceabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Traceability Level' ;
    rdfs:comment 'Level of supply chain traceability achieved by the supplier, indicating visibility into upstream tiers (Tier 1, Tier 2, Tier 3, Tier 4, raw material, or full chain).' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDiversionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Diversion Rate Percentage' ;
    rdfs:comment 'Percentage of total waste diverted from landfill through recycling, composting, or reuse programs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterUsageIntensityLitersKg rdf:type rdf:Property ;
    rdfs:label 'Water Usage Intensity Liters Kg' ;
    rdfs:comment 'Water consumption intensity measured in liters per kilogram of product produced, indicating water efficiency.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wrapCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Wrap Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds valid WRAP certification for ethical manufacturing and labor standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zdhcMrslCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Zdhc Mrsl Compliant Flag' ;
    rdfs:comment 'Indicates whether the supplier complies with ZDHC MRSL for chemical management and hazardous substance elimination.' ;
    rdfs:domain ind:SustainabilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendor\'s bank account number used for electronic payment transfers and settlements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official government-issued business registration or tax identification number for the vendor entity.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStatus rdf:type rdf:Property ;
    rdfs:label 'Business Status' ;
    rdfs:comment 'Current operational status of the vendor relationship indicating whether the vendor is actively engaged, suspended, or terminated.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of compliance certifications held by the vendor, such as WRAP, FLA, GOTS, OEKO-TEX, ISO 9001, ISO 14001, ISO 45001, BCI, or other industry-recognized standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the vendor received final executive or procurement approval to be added to the approved vendor list.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full physical address of the vendor\'s primary headquarters or registered office location.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcTermsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lc Terms Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor requires payment to be secured through a letter of credit for international transactions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Actual date when all onboarding activities and checklist items were completed and the vendor was approved for activation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Percentage' ;
    rdfs:comment 'Percentage of onboarding checklist items completed, calculated as completed tasks divided by total required tasks, expressed as a decimal (0.00 to 100.00).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingManager rdf:type rdf:Property ;
    rdfs:label 'Onboarding Manager' ;
    rdfs:comment 'Name of the internal employee or team responsible for managing the vendor onboarding process and ensuring completion of all required steps.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the vendor onboarding workflow process, tracking progress from initial documentation through final approval and system setup. [ENUM-REF-CANDIDATE: Not Started|Documentation|Compliance Review|Factory Audit|Contract Negotiation|System Setup|Approved|Completed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRatingScore rdf:type rdf:Property ;
    rdfs:label 'Quality Rating Score' ;
    rdfs:comment 'Vendor quality performance score based on defect rates, compliance with specifications, and quality audit results, typically on a scale of 0.00 to 5.00.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'Planned date when the vendor is expected to be fully operational and ready to begin fulfilling orders or providing services.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Supply chain tier level indicating the vendor\'s position in the supply chain hierarchy. Tier 1 represents direct suppliers, Tier 2 represents suppliers to Tier 1, and so on.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the type of goods or services provided. CMT (Cut Make Trim) for contract manufacturers, OEM (Original Equipment Manufacturer), ODM (Original Design Manufacturer), Fabric Mill for textile suppliers, Trim Supplier for accessories, 3PL (Third-Party Logistics) for logistics providers. [ENUM-REF-CANDIDATE: CMT|OEM|ODM|Fabric Mill|Trim Supplier|3PL|Raw Material|Packaging|Logistics|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is eligible and approved to participate in vendor-managed inventory programs where they manage stock levels at buyer locations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding payable amount allowed under this agreement before additional approvals or holds are required.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultIncoterm rdf:type rdf:Property ;
    rdfs:label 'Default Incoterm' ;
    rdfs:comment 'The default Incoterm rule applied to shipments under this agreement unless otherwise specified on the purchase order (PO). Common values include FOB (Free on Board), CIF (Cost Insurance Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsVersion rdf:type rdf:Property ;
    rdfs:label 'Incoterms Version' ;
    rdfs:comment 'The version of International Commercial Terms (Incoterms) governing the delivery, risk transfer, and cost allocation for goods under this agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Id' ;
    rdfs:comment 'Unique identifier for the vendor bank account record. Primary key.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Account Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the bank account. Determines the settlement currency for payments and impacts foreign exchange requirements.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Address' ;
    rdfs:comment 'Full address of the bank branch or headquarters. Required for international payment routing and compliance documentation.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'Branch identifier or sort code used for domestic payment routing. Format varies by country (e.g., UK sort code, Indian IFSC code).' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the bank\'s domicile. Critical for cross-border payment routing, foreign exchange, and compliance with international sanctions and trade regulations.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External identifier for this bank account in the source system or vendor portal. Used for cross-system reconciliation and data integration.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Name of the intermediary or correspondent bank used for routing international payments when direct settlement is not available. Common in cross-border transactions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the intermediary bank. Required for routing payments through correspondent banking networks in international transactions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment processed to this bank account in the account currency. Used for payment pattern analysis and fraud detection.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment processed to this bank account. Used for account activity monitoring and dormant account identification.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lc Expiry Date' ;
    rdfs:comment 'Expiration date of the current Letter of Credit arrangement for this vendor account. After this date, a new LC must be issued for continued payment processing.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcIssuingBank rdf:type rdf:Property ;
    rdfs:label 'Lc Issuing Bank' ;
    rdfs:comment 'Name of the bank that issues Letters of Credit on behalf of the buyer (Apparel Fashion) for payments to this vendor. Required when LC payment method is used.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority ranking for this bank account when multiple accounts exist for a vendor. Lower numbers indicate higher priority. Used by AP automation to select payment account.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Account Flag' ;
    rdfs:comment 'Indicates whether this is the primary/default bank account for the vendor. True if this account should be used by default for payment processing when multiple accounts exist.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'ABA routing number for US domestic payments (ACH and wire transfers). Nine-digit code identifying the financial institution.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Unique identifier for the vendor contact person. Primary key.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalRelationshipOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Relationship Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each vendor contact has an internal relationship owner (buyer, sourcing manager, QA lead) responsible for coordination, communication, and issue resolution. Essential for vendor management workflows, ' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of decision-making authority the contact has within the vendor organization (e.g., Operational, Managerial, Executive). Used to determine appropriate escalation paths and approval workflows.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCredentials rdf:type rdf:Property ;
    rdfs:label 'Certification Credentials' ;
    rdfs:comment 'Professional certifications or credentials held by the contact relevant to their role (e.g., WRAP Auditor, GOTS Certified, Six Sigma Black Belt, ISO 9001 Lead Auditor). Supports compliance verification and quality assurance.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name or given name of the vendor contact person.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFullName rdf:type rdf:Property ;
    rdfs:label 'Contact Full Name' ;
    rdfs:comment 'Full legal name of the vendor contact person, including first name, middle name, and last name.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name or family name of the vendor contact person.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the vendor contact record. Indicates whether the contact is actively engaged, temporarily unavailable, or no longer with the vendor organization.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Number' ;
    rdfs:comment 'Emergency contact phone number for urgent situations requiring immediate vendor response, such as production issues, quality failures, or compliance incidents.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this vendor contact. Used for relationship management and engagement tracking.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number of the vendor contact person for urgent communications and field coordination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or site where the contact is based within the vendor organization (e.g., factory name, office branch, city). Used for site visit planning and logistics coordination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingManagerName rdf:type rdf:Property ;
    rdfs:label 'Reporting Manager Name' ;
    rdfs:comment 'Name of the contact\'s direct manager or supervisor within the vendor organization. Used for escalation paths and organizational context.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Standardized role classification indicating the primary function of the contact in the vendor relationship. Used for routing communications and workflow assignments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'Specific area of expertise or specialization of the contact within their role (e.g., Fabric Sourcing, Garment Construction, Chemical Compliance, Export Documentation, Quality Testing). Used for routing specialized inquiries.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wechatHandle rdf:type rdf:Property ;
    rdfs:label 'Wechat Handle' ;
    rdfs:comment 'WeChat contact identifier or username used for instant messaging communication with the vendor contact, commonly used for China-based suppliers.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whatsappHandle rdf:type rdf:Property ;
    rdfs:label 'Whatsapp Handle' ;
    rdfs:comment 'WhatsApp contact identifier (typically phone number) used for instant messaging communication with the vendor contact, commonly used in international sourcing operations.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Vendor Document Id' ;
    rdfs:comment 'Unique identifier for the vendor document record. Primary key.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Monetary coverage amount specified in the insurance certificate or liability document.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentFileUrl rdf:type rdf:Property ;
    rdfs:label 'Document File Url' ;
    rdfs:comment 'Uniform Resource Locator pointing to the stored digital file of the document in the document management system or cloud storage.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full descriptive title or name of the document as it appears on the official record.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadedBy rdf:type rdf:Property ;
    rdfs:label 'Uploaded By' ;
    rdfs:comment 'Name or identifier of the user who uploaded the document to the system.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Uploaded Timestamp' ;
    rdfs:comment 'Date and time when the document was uploaded to the system.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorScorecardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Id' ;
    rdfs:comment 'Unique identifier for the vendor scorecard evaluation record.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aqlDefectRatePercent rdf:type rdf:Property ;
    rdfs:label 'Aql Defect Rate Percent' ;
    rdfs:comment 'Percentage of defective units found during quality inspections based on AQL sampling standards. Lower values indicate better quality performance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of vendor production capacity allocated to this business during the evaluation period. Indicates strategic partnership depth and allocation priority.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimRatePercent rdf:type rdf:Property ;
    rdfs:label 'Claim Rate Percent' ;
    rdfs:comment 'Percentage of orders resulting in quality claims, chargebacks, or Return to Vendor (RTV) actions during the evaluation period. Lower is better.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceAuditScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Score' ;
    rdfs:comment 'Composite score from social compliance and labor standards audits (WRAP, FLA, BSCI, Sedex). Typically scored 0-100 or letter grade converted to numeric.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCompetitivenessIndex rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Index' ;
    rdfs:comment 'Index comparing vendor pricing against market benchmarks and peer vendors. Values above 100 indicate above-market pricing; below 100 indicates competitive pricing.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Score' ;
    rdfs:comment 'Subjective score evaluating vendor contributions to product innovation, material development, process improvements, and value engineering initiatives.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimePerformanceDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Performance Days' ;
    rdfs:comment 'Average lead time in days from purchase order issuance to delivery during the evaluation period. Shorter lead times improve supply chain agility.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeSampleSubmissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Sample Submission Rate Percent' ;
    rdfs:comment 'Percentage of product samples (SMS, PP samples) submitted on or before the scheduled deadline per the Time and Action (TNA) calendar.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Order Fill Rate Percent' ;
    rdfs:comment 'Percentage of ordered quantity successfully fulfilled without shortages or cancellations. Measures vendor reliability and inventory management.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRatePercent rdf:type rdf:Property ;
    rdfs:label 'Otif Rate Percent' ;
    rdfs:comment 'Percentage of purchase orders delivered on time and in full during the evaluation period. Key operational KPI for supply chain reliability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallWeightedScore rdf:type rdf:Property ;
    rdfs:label 'Overall Weighted Score' ;
    rdfs:comment 'Composite weighted score aggregating all KPI dimensions (OTIF, quality, compliance, cost, responsiveness, sustainability) per the scorecard weighting methodology. Primary ranking metric.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Vendor classification tier based on overall weighted score. Preferred vendors receive priority allocation; Probation/Delisted vendors face restrictions or exit.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppSampleApprovalRatePercent rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Rate Percent' ;
    rdfs:comment 'Percentage of pre-production samples approved on first submission without requiring rework or resubmission. Indicates design and technical capability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'Vendor performance tier from the prior evaluation period. Enables trend analysis and tier movement tracking.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Strategic sourcing recommendation based on scorecard results. Drives allocation decisions, remediation plans, or vendor exit strategies.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal corrective action or remediation plan is required due to performance deficiencies (True) or not (False).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsivenessRating rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Rating' ;
    rdfs:comment 'Subjective rating (typically 1-5 or 1-10 scale) assessing vendor communication quality, issue resolution speed, and collaboration effectiveness.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Change Flag' ;
    rdfs:comment 'Indicates whether the vendor tier changed from the previous evaluation period (True) or remained the same (False).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPoCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Count' ;
    rdfs:comment 'Total number of purchase orders issued to this vendor during the evaluation period. Indicates transaction volume and relationship scale.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Po Value Usd' ;
    rdfs:comment 'Total value in USD of all purchase orders issued to this vendor during the evaluation period. Provides spend context for performance assessment.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biodiversityImpactId rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Impact Id' ;
    rdfs:comment 'Unique identifier for the biodiversity impact assessment record.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to sustainability.facility. Business justification: Biodiversity assessments are location-based and should link to sustainability.facility for in-domain consistency. Enables leveraging facility master data (certifications, operational status, etc.) and' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:annualSourcingVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Sourcing Volume' ;
    rdfs:comment 'Annual volume of material sourced from this location, measured in metric tons or applicable unit.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Methodology or framework used to conduct the biodiversity impact assessment.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the biodiversity impact assessment, formatted as BIA-YYYYMMDD.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the individual or organization that conducted the biodiversity impact assessment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityOffsetAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Offset Area Hectares' ;
    rdfs:comment 'Total area of biodiversity offset committed or implemented, measured in hectares.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biodiversitySensitivityClassification rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Sensitivity Classification' ;
    rdfs:comment 'Classification of biodiversity sensitivity level based on international conservation designations and risk assessments. [ENUM-REF-CANDIDATE: key_biodiversity_area|ramsar_wetland|unesco_world_heritage|deforestation_risk_zone|high_conservation_value|protected_area|critical_habitat|low_risk — promote to reference product]' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deforestationRiskZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Deforestation Risk Zone Flag' ;
    rdfs:comment 'Indicates whether the location is classified as a high-risk deforestation zone.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecosystemType rdf:type rdf:Property ;
    rdfs:label 'Ecosystem Type' ;
    rdfs:comment 'Classification of the ecosystem type present at the assessed location. [ENUM-REF-CANDIDATE: tropical_rainforest|temperate_forest|grassland|wetland|marine|freshwater|agricultural|urban — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iucnKbaFlag rdf:type rdf:Property ;
    rdfs:label 'Iucn Kba Flag' ;
    rdfs:comment 'Indicates whether the location is within or adjacent to an IUCN-designated Key Biodiversity Area.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iucnRedListCategory rdf:type rdf:Property ;
    rdfs:label 'Iucn Red List Category' ;
    rdfs:comment 'Highest IUCN Red List threat category among species identified at the assessed location.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landUseChangeAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Land Use Change Area Hectares' ;
    rdfs:comment 'Total area of land use change measured in hectares associated with this assessment.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landUseChangeImpact rdf:type rdf:Property ;
    rdfs:label 'Land Use Change Impact' ;
    rdfs:comment 'Assessment of the impact level of land use change on local biodiversity.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Mitigation Effectiveness Rating' ;
    rdfs:comment 'Assessment of the effectiveness of implemented biodiversity mitigation measures.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasuresImplemented rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures Implemented' ;
    rdfs:comment 'Description of biodiversity mitigation measures implemented at the assessed location.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ramsarWetlandFlag rdf:type rdf:Property ;
    rdfs:label 'Ramsar Wetland Flag' ;
    rdfs:comment 'Indicates whether the location is within or adjacent to a Ramsar Convention-designated wetland of international importance.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period covered by this biodiversity impact assessment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period covered by this biodiversity impact assessment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restorationProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Restoration Program Enrolled' ;
    rdfs:comment 'Indicates whether the location is enrolled in a biodiversity restoration or conservation program.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restorationProgramName rdf:type rdf:Property ;
    rdfs:label 'Restoration Program Name' ;
    rdfs:comment 'Name of the biodiversity restoration or conservation program in which the location is enrolled.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPracticeRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Practice Risk Level' ;
    rdfs:comment 'Risk level assessment of sourcing practices at this location with respect to biodiversity impact.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Sourcing Volume Unit' ;
    rdfs:comment 'Unit of measure for the annual sourcing volume.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesAtRiskCount rdf:type rdf:Property ;
    rdfs:label 'Species At Risk Count' ;
    rdfs:comment 'Number of threatened or endangered species identified in the assessed location.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speciesAtRiskList rdf:type rdf:Property ;
    rdfs:label 'Species At Risk List' ;
    rdfs:comment 'Comma-separated list of threatened or endangered species identified in the assessed location.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Flag' ;
    rdfs:comment 'Indicates whether the biodiversity impact assessment has been verified by an independent third party.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tnfdDisclosureAlignment rdf:type rdf:Property ;
    rdfs:label 'Tnfd Disclosure Alignment' ;
    rdfs:comment 'Indicates whether this biodiversity impact assessment aligns with TNFD (Taskforce on Nature-related Financial Disclosures) reporting requirements.' ;
    rdfs:domain ind:BiodiversityImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationBodyName rdf:type rdf:Property ;
    rdfs:label 'Verification Body Name' ;
    rdfs:comment 'Name of the third-party organization that verified the biodiversity impact assessment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope3CategoryId rdf:type rdf:Property ;
    rdfs:label 'Scope3 Category Id' ;
    rdfs:comment 'Foreign key linking to sustainability.scope3_category. Business justification: Scope 3 carbon emissions must be classified into one of the 15 GHG Protocol Scope 3 categories (purchased goods, business travel, employee commuting, etc.). The carbon_emission table has emission_scop' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scope3Category .

ind:activityDataUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Data Unit' ;
    rdfs:comment 'Unit of measure for the activity data value, standardized for carbon accounting calculations. [ENUM-REF-CANDIDATE: kWh|MWh|liters|gallons|kg|tonnes|tonne-km|passenger-km|m3|GJ — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDataValue rdf:type rdf:Property ;
    rdfs:label 'Activity Data Value' ;
    rdfs:comment 'Quantitative measure of the activity that generated the emission (e.g., 1500 kWh electricity, 250 liters diesel, 1200 tonne-km freight).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biogenicEmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Biogenic Emission Flag' ;
    rdfs:comment 'Indicates whether the emission is biogenic (from biomass/biological sources) and should be reported separately per GHG Protocol guidance.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdpDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Cdp Disclosure Flag' ;
    rdfs:comment 'Indicates whether this emission record is included in CDP climate change disclosure reporting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ch4QuantityKg rdf:type rdf:Property ;
    rdfs:label 'Ch4 Quantity Kg' ;
    rdfs:comment 'Quantity of methane emitted in kilograms, reported separately for detailed gas composition analysis.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2QuantityKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Quantity Kg' ;
    rdfs:comment 'Quantity of carbon dioxide emitted in kilograms, reported separately for detailed gas composition analysis.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Quantity Kg' ;
    rdfs:comment 'Total greenhouse gas emission calculated in kilograms of CO2 equivalent, representing the global warming potential of all GHGs emitted.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionDate rdf:type rdf:Property ;
    rdfs:label 'Emission Date' ;
    rdfs:comment 'Date when the emission event occurred or was recorded, used for temporal analysis and reporting period allocation.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Emission Event Number' ;
    rdfs:comment 'Business identifier for the emission event, used for external reporting and audit trails. Format: CE-XXXXXXXXXX.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorSource rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Source' ;
    rdfs:comment 'Source database or standard from which the emission factor was obtained (e.g., IPCC 2021, DEFRA 2023, EPA eGRID).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorValue rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Value' ;
    rdfs:comment 'Emission factor applied to convert activity data to CO2 equivalent emissions, expressed as kg CO2e per unit of activity.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorVersion rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Version' ;
    rdfs:comment 'Version or publication year of the emission factor database used, ensuring traceability and consistency in carbon accounting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionScope rdf:type rdf:Property ;
    rdfs:label 'Emission Scope' ;
    rdfs:comment 'GHG Protocol scope classification: Scope 1 (direct emissions from owned/controlled sources), Scope 2 (indirect emissions from purchased energy), Scope 3 (all other indirect emissions in value chain).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Emission Source Identifier' ;
    rdfs:comment 'Unique identifier of the specific source entity (facility code, vehicle ID, material batch, logistics route) that generated the emission.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceName rdf:type rdf:Property ;
    rdfs:label 'Emission Source Name' ;
    rdfs:comment 'Human-readable name or description of the emission source (e.g., Vietnam Factory A, NYC Distribution Center, Cotton Supplier X).' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceType rdf:type rdf:Property ;
    rdfs:label 'Emission Source Type' ;
    rdfs:comment 'Type of physical or operational source generating the emission within the apparel supply chain. [ENUM-REF-CANDIDATE: Factory|Distribution Center|Retail Store|Warehouse|Office|Logistics Leg|Raw Material|Packaging Material|Finished Goods|Waste Stream|Energy Grid — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:n2oQuantityKg rdf:type rdf:Property ;
    rdfs:label 'N2o Quantity Kg' ;
    rdfs:comment 'Quantity of nitrous oxide emitted in kilograms, reported separately for detailed gas composition analysis.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Offset Applied Flag' ;
    rdfs:comment 'Indicates whether a carbon offset or credit has been applied to neutralize this emission.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetProjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Offset Project Identifier' ;
    rdfs:comment 'Unique identifier of the carbon offset project or credit registry (e.g., Verra VCS project ID, Gold Standard ID) used to offset this emission.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Offset Quantity Kg' ;
    rdfs:comment 'Quantity of carbon offsets applied to this emission in kilograms CO2e, if offset_applied_flag is true.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherGhgQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Other Ghg Quantity Kg' ;
    rdfs:comment 'Quantity of other greenhouse gases (HFCs, PFCs, SF6, NF3) emitted in kilograms CO2e, aggregated for reporting.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Flag' ;
    rdfs:comment 'Indicates whether the energy source for this emission was from renewable sources (solar, wind, hydro), relevant for Scope 2 market-based accounting.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Calendar or fiscal year for which the emission is reported, facilitating year-over-year trend analysis and regulatory compliance.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scienceBasedTargetAlignment rdf:type rdf:Property ;
    rdfs:label 'Science Based Target Alignment' ;
    rdfs:comment 'Indicates whether this emission is tracked against the company\'s Science-Based Targets initiative commitments.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifierOrganization rdf:type rdf:Property ;
    rdfs:label 'Verifier Organization' ;
    rdfs:comment 'Name of the third-party organization that verified the emission data, if applicable.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalityVerified rdf:type rdf:Property ;
    rdfs:label 'Additionality Verified' ;
    rdfs:comment 'Indicates whether the offset project has been verified to meet additionality criteria (i.e., emission reductions would not have occurred without the carbon finance). True if verified, False otherwise.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Business Unit' ;
    rdfs:comment 'Business unit, division, or product line to which the carbon offset credits are allocated for internal carbon accounting and cost allocation purposes.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Allocation Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the offset credits are allocated to compensate emissions. May differ from vintage year or purchase year.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedEmissionScope rdf:type rdf:Property ;
    rdfs:label 'Associated Emission Scope' ;
    rdfs:comment 'GHG Protocol emission scope category that these offset credits are intended to compensate. Supports allocation of offsets to specific emission categories in ESG reporting.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'International carbon offset standard under which the credits were verified and issued. Determines credibility and acceptance in voluntary and compliance markets.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Co Benefits Description' ;
    rdfs:comment 'Narrative description of additional environmental or social benefits delivered by the project beyond carbon reduction (e.g., biodiversity protection, community employment, water quality improvement).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleCountingPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Double Counting Prevention Flag' ;
    rdfs:comment 'Indicates whether the offset credits are subject to corresponding adjustments or other mechanisms to prevent double counting between jurisdictions or entities. True if safeguards are in place, False otherwise.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netZeroClaimEligible rdf:type rdf:Property ;
    rdfs:label 'Net Zero Claim Eligible' ;
    rdfs:comment 'Indicates whether these offset credits meet the quality criteria for use in Apparel Fashion\'s net-zero or carbon neutrality claims, per internal policy and external guidance (e.g., SBTi Net-Zero Standard). True if eligible, False otherwise.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetProjectName rdf:type rdf:Property ;
    rdfs:label 'Offset Project Name' ;
    rdfs:comment 'Full name of the carbon offset project from which credits were purchased. Examples include reforestation initiatives, renewable energy installations, or cookstove distribution programs.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Permanence Risk Rating' ;
    rdfs:comment 'Assessment of the risk that carbon sequestered by the project could be reversed (e.g., forest fire, land use change). Particularly relevant for nature-based solutions.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Project Location Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carbon offset project is physically located. Supports geographic analysis and co-benefit assessment.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationRegion rdf:type rdf:Property ;
    rdfs:label 'Project Location Region' ;
    rdfs:comment 'Geographic region or state/province where the offset project is located. Provides additional geographic granularity beyond country.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Category of carbon offset project methodology. Defines the mechanism by which greenhouse gas reductions or removals are achieved.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date on which Apparel Fashion acquired the carbon offset credits from the project developer or broker.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasePricePerTco2e rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Per Tco2e' ;
    rdfs:comment 'Unit price paid per metric ton of CO2 equivalent for the carbon offset credits. Used for financial accounting and cost analysis.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e' ;
    rdfs:comment 'Total quantity of carbon offset credits purchased or retired, measured in metric tons of carbon dioxide equivalent. Represents the greenhouse gas reduction or removal impact.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the carbon registry to this specific batch of offset credits. Ensures traceability and prevents double-counting.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementCertificateUrl rdf:type rdf:Property ;
    rdfs:label 'Retirement Certificate Url' ;
    rdfs:comment 'Web link to the official retirement certificate issued by the carbon registry. Provides proof of retirement for audit and verification purposes.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementStatus rdf:type rdf:Property ;
    rdfs:label 'Retirement Status' ;
    rdfs:comment 'Current lifecycle status of the carbon offset credits. Active credits are held in inventory; retired credits have been claimed against emissions.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope3Category rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category' ;
    rdfs:comment 'Specific Scope 3 value chain category (e.g., Category 1 Purchased Goods, Category 4 Upstream Transportation) if the offset is allocated to Scope 3 emissions. Null if not Scope 3.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBrokerName rdf:type rdf:Property ;
    rdfs:label 'Supplier Broker Name' ;
    rdfs:comment 'Name of the carbon credit broker, marketplace, or project developer from whom the credits were purchased.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Amount' ;
    rdfs:comment 'Total monetary amount paid for the carbon offset credit purchase. Calculated as quantity multiplied by unit price.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unSdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Un Sdg Alignment' ;
    rdfs:comment 'Comma-separated list of UN SDG numbers (1-17) that the offset project contributes to. Supports integrated ESG reporting and impact measurement.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationReportUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Report Url' ;
    rdfs:comment 'Web link to the publicly available verification report or project documentation. Supports transparency and stakeholder due diligence.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which the greenhouse gas emission reductions or removals occurred. Vintage year affects credit pricing and eligibility for certain programs.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'Level of assurance provided by the third-party verifier: limited (moderate assurance), reasonable (high assurance), or none (no external verification).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Assurance Provider' ;
    rdfs:comment 'Name of the third-party organization providing independent verification and assurance of emissions data and target progress (e.g., \'Deloitte\', \'EY\', \'Bureau Veritas\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineEmissionsMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Baseline Emissions Mt Co2e' ;
    rdfs:comment 'Total greenhouse gas emissions in the baseline year expressed in metric tons of carbon dioxide equivalent (MT CO2e). Represents the starting point for measuring reduction progress.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineIntensityValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Intensity Value' ;
    rdfs:comment 'Emissions intensity in the baseline year (e.g., MT CO2e per million USD revenue). Null for absolute targets.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'The reference year against which carbon reduction progress is measured (e.g., 2019, 2020). Typically aligned with the most recent complete emissions inventory prior to target setting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date on which the Board of Directors or equivalent governance body formally approved this carbon reduction target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Boundary Description' ;
    rdfs:comment 'Textual description of the organizational and operational boundaries covered by this target (e.g., \'Global operations including all owned facilities, leased warehouses, and corporate offices; excludes franchised stores\').' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmissionsMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Current Emissions Mt Co2e' ;
    rdfs:comment 'Most recent annual emissions measurement in metric tons CO2e for the scopes covered by this target. Used to track progress toward the target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentYear rdf:type rdf:Property ;
    rdfs:label 'Current Year' ;
    rdfs:comment 'The reporting year for the current emissions measurement. Tracks the most recent progress data point.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which this target was first publicly disclosed or announced.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAssuranceFlag rdf:type rdf:Property ;
    rdfs:label 'External Assurance Flag' ;
    rdfs:comment 'Indicates whether emissions data and progress toward this target have been verified by an independent third-party assurance provider.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intensityMetric rdf:type rdf:Property ;
    rdfs:label 'Intensity Metric' ;
    rdfs:comment 'The denominator used for intensity-based targets (e.g., emissions per million USD revenue, per garment produced, per square meter of retail space, per employee). Set to \'none\' for absolute targets.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssuranceDate rdf:type rdf:Property ;
    rdfs:label 'Last Assurance Date' ;
    rdfs:comment 'Date of the most recent third-party assurance or verification of emissions data related to this target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:methodologyNotes rdf:type rdf:Property ;
    rdfs:label 'Methodology Notes' ;
    rdfs:comment 'Additional notes on calculation methodology, assumptions, exclusions, or special considerations applied in setting or tracking this target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTrackFlag rdf:type rdf:Property ;
    rdfs:label 'On Track Flag' ;
    rdfs:comment 'Boolean indicator of whether the target is on track to be achieved by the target year based on current progress trajectory and linear reduction pathway.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:progressPercentage rdf:type rdf:Property ;
    rdfs:label 'Progress Percentage' ;
    rdfs:comment 'Percentage of the target reduction achieved to date, calculated as (baseline emissions - current emissions) / (baseline emissions - target emissions) * 100. Values over 100 indicate over-achievement.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleExecutive rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive' ;
    rdfs:comment 'Name or title of the executive accountable for achieving this target (e.g., \'Chief Sustainability Officer\', \'VP Supply Chain\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Sbti Approval Date' ;
    rdfs:comment 'Date on which the Science Based Targets initiative formally approved this target as science-based and aligned with the 1.5°C pathway.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sbtiCommitmentLetterDate rdf:type rdf:Property ;
    rdfs:label 'Sbti Commitment Letter Date' ;
    rdfs:comment 'Date on which Apparel Fashion submitted its commitment letter to the Science Based Targets initiative, pledging to set science-based targets within 24 months.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sbtiValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Sbti Validation Status' ;
    rdfs:comment 'Current status of third-party validation by the Science Based Targets initiative. Approved targets are aligned with climate science to limit global warming to 1.5°C.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope3CategoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category Coverage' ;
    rdfs:comment 'Comma-separated list of GHG Protocol Scope 3 categories included in this target (e.g., \'Category 1: Purchased Goods and Services, Category 4: Upstream Transportation, Category 11: Use of Sold Products\'). Null if target does not cover Scope 3.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCoverage rdf:type rdf:Property ;
    rdfs:label 'Scope Coverage' ;
    rdfs:comment 'GHG Protocol emission scopes covered by this target: Scope 1 (direct emissions), Scope 2 (purchased energy), Scope 3 (value chain), or combinations thereof.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEmissionsMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Target Emissions Mt Co2e' ;
    rdfs:comment 'Absolute emissions level in metric tons CO2e that must be achieved by the target year to meet the reduction commitment. Calculated as baseline emissions minus the reduction percentage.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetIntensityValue rdf:type rdf:Property ;
    rdfs:label 'Target Intensity Value' ;
    rdfs:comment 'Target emissions intensity to be achieved by the target year (e.g., MT CO2e per million USD revenue). Null for absolute targets.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Business-friendly name or label for the carbon reduction target (e.g., \'2030 Scope 1+2 Absolute Reduction\', \'Supply Chain Intensity Target\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Reduction Percentage' ;
    rdfs:comment 'The percentage reduction in emissions committed to achieve by the target year, relative to the baseline year (e.g., 50.00 represents a 50% reduction commitment).' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the carbon target: draft (under development), active (in force), achieved (met ahead of schedule), expired (target year passed), retired (no longer pursued), superseded (replaced by new target).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the carbon target methodology: absolute (total emissions reduction in metric tons CO2e) or intensity (emissions per unit of activity such as revenue, production volume, or square footage).' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetYear rdf:type rdf:Property ;
    rdfs:label 'Target Year' ;
    rdfs:comment 'The year by which the carbon reduction target must be achieved (e.g., 2030, 2050). Defines the time horizon for the commitment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureAlignment rdf:type rdf:Property ;
    rdfs:label 'Temperature Alignment' ;
    rdfs:comment 'The global warming scenario that this target is aligned with, based on climate science (e.g., 1.5°C pathway per Paris Agreement ambition).' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework or standard governing this chemical restriction. May include REACH, CPSC, OEKO-TEX STANDARD 100, ZDHC MRSL, California Proposition 65, or other jurisdiction-specific regulations.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'Common or trade name of the chemical substance being tracked for compliance. Used for identification and communication across supply chain partners.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionStatus rdf:type rdf:Property ;
    rdfs:label 'Detection Status' ;
    rdfs:comment 'Indicates whether the chemical substance was detected in the test sample. Distinct from compliance status; a substance may be detected but still compliant if below threshold.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountry rdf:type rdf:Property ;
    rdfs:label 'Facility Country' ;
    rdfs:comment 'ISO 3-letter country code of the production facility location. Used for jurisdiction-specific compliance requirements and supply chain transparency.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation' ;
    rdfs:comment 'Accreditation body and certificate number validating the testing laboratory\'s competence. Examples include ISO 17025, CNAS, UKAS, A2LA.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oekoTexClass rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Class' ;
    rdfs:comment 'OEKO-TEX Standard 100 product class determining applicable limit values. Class I (baby products) has strictest limits; Class IV (decoration materials) has most lenient.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionFacility rdf:type rdf:Property ;
    rdfs:label 'Production Facility' ;
    rdfs:comment 'Name or identifier of the manufacturing facility where the material or product was produced. Important for MRSL compliance tracking at facility level.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulation Jurisdiction' ;
    rdfs:comment 'Geographic region or country where the regulation applies. Uses ISO 3-letter country codes or regional identifiers (e.g., USA, EUR, CHN, Global).' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Actual date when remediation action was completed and verified. Used to track remediation cycle time and supplier performance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation action plan. Tracks progress from identification through verification of corrective measures.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Description' ;
    rdfs:comment 'Detailed description of the sample tested, including color, material composition, processing stage, or other identifying characteristics relevant to the test.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Standardized laboratory test method or protocol used to detect and quantify the chemical substance. Examples include ISO, ASTM, AATCC, or proprietary test methods.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultValue rdf:type rdf:Property ;
    rdfs:label 'Test Result Value' ;
    rdfs:comment 'Actual measured concentration or quantity of the chemical substance detected in laboratory testing. Expressed in the same unit as threshold_unit for direct comparison.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited third-party laboratory that performed the chemical compliance testing. Should be ISO 17025 accredited for credibility.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit' ;
    rdfs:comment 'Maximum allowable concentration or quantity of the chemical substance permitted by the applicable regulation. Expressed in the unit specified in threshold_unit.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zdhcMrslVersion rdf:type rdf:Property ;
    rdfs:label 'Zdhc Mrsl Version' ;
    rdfs:comment 'Version number of the ZDHC MRSL standard used for compliance assessment. ZDHC MRSL is updated periodically with new restrictions and revised limits.' ;
    rdfs:domain ind:ChemicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Kg' ;
    rdfs:comment 'Estimated carbon dioxide equivalent (CO2e) offset in kilograms achieved through this circular enrollment, calculated based on diversion outcome and material type. Used for ESG carbon footprint reporting.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method by which items were collected from the participant: drop-off (customer brought to store), mail-in (shipped by customer), pickup (courier collected), event (collected at activation), partner-site (collected at third-party location).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Flag' ;
    rdfs:comment 'Indicates whether the customer provided explicit consent for their enrollment data to be used in sustainability reporting and marketing communications. True if consent given, False otherwise.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionOutcome rdf:type rdf:Property ;
    rdfs:label 'Diversion Outcome' ;
    rdfs:comment 'Final disposition outcome of the submitted items: recycled (material recovery), resold (second-hand sale), repaired (restored for reuse), upcycled (creatively transformed), donated (charitable distribution), disposed (landfill or incineration as last resort).' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Date and time when the customer or partner enrolled in the circular economy program. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:esgReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Period' ;
    rdfs:comment 'Reporting period (quarter or month) to which this enrollment is attributed for ESG and sustainability reporting. Format: YYYY-QN for quarterly or YYYY-MM for monthly.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incentive value (e.g., USD, EUR, GBP). Null if incentive is non-monetary (e.g., loyalty points) or none.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Incentive Expiry Date' ;
    rdfs:comment 'Date when the issued incentive expires and can no longer be redeemed. Null if incentive has no expiration or was not issued.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentiveIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Incentive Issued Date' ;
    rdfs:comment 'Date when the incentive (voucher, credit, points) was issued to the customer or partner. Null if no incentive was issued.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemsSubmittedCount rdf:type rdf:Property ;
    rdfs:label 'Items Submitted Count' ;
    rdfs:comment 'Total number of garments or products submitted by the customer or partner as part of this enrollment event.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Partner Organization Name' ;
    rdfs:comment 'Name of the third-party partner organization facilitating the circular program (e.g., recycling vendor, resale platform, charity partner). Null if managed internally.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Processing Completed Date' ;
    rdfs:comment 'Date when the processing of submitted items was completed and the diversion outcome was finalized. Null if processing is still pending.' ;
    rdfs:domain ind:CircularEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Annual budget allocated for operating and marketing the circular program. Currency determined by business operating currency.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonReductionTargetKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Target Kg' ;
    rdfs:comment 'Target carbon dioxide equivalent reduction in kilograms expected from this circular program over its lifecycle.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circularProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Circular Program Description' ;
    rdfs:comment 'Detailed description of the circular program objectives, mechanics, and value proposition for customers and the business.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Customer Eligibility Criteria' ;
    rdfs:comment 'Description of customer eligibility requirements for program participation (e.g., loyalty member, original purchaser, any customer).' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerParticipationTarget rdf:type rdf:Property ;
    rdfs:label 'Customer Participation Target' ;
    rdfs:comment 'Target number of unique customers expected to participate in the circular program within the reporting period.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diversionTargetQuantity rdf:type rdf:Property ;
    rdfs:label 'Diversion Target Quantity' ;
    rdfs:comment 'Target quantity of items or materials to be diverted from landfill through this circular program, measured in units or weight.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionTargetUnit rdf:type rdf:Property ;
    rdfs:label 'Diversion Target Unit' ;
    rdfs:comment 'Unit of measure for the diversion target quantity (units, kilograms, tonnes, pounds).' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProductCategories rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories eligible for participation in the circular program (e.g., footwear, outerwear, denim, accessories).' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgAlignmentGoals rdf:type rdf:Property ;
    rdfs:label 'Esg Alignment Goals' ;
    rdfs:comment 'Description of how the circular program aligns with and contributes to the organization\'s broader ESG commitments and sustainability goals.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRecoveryRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Material Recovery Rate Target Pct' ;
    rdfs:comment 'Target percentage of collected materials that will be successfully recovered and reused or recycled rather than sent to landfill.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumItemCondition rdf:type rdf:Property ;
    rdfs:label 'Minimum Item Condition' ;
    rdfs:comment 'Minimum acceptable condition of items for participation in the circular program.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingChannels rdf:type rdf:Property ;
    rdfs:label 'Participating Channels' ;
    rdfs:comment 'Comma-separated list of sales and distribution channels where the circular program is available (e.g., retail stores, e-commerce, wholesale, mobile app).' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPartner rdf:type rdf:Property ;
    rdfs:label 'Processing Partner' ;
    rdfs:comment 'Name of the third-party partner or internal facility responsible for processing collected items (recycling, refurbishment, resale preparation).' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for managing the circular program.' ;
    rdfs:domain ind:CircularProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which program performance and environmental impact metrics are reported to stakeholders.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web URL where customers can access the full terms and conditions governing participation in the circular program.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual License Fee Amount' ;
    rdfs:comment 'Annual licensing fee amount charged by the issuing body for the right to use this eco-label. Null if no fee is required.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableMaterialTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Material Types' ;
    rdfs:comment 'Comma-separated list of material or fiber types eligible for this eco-label (e.g., organic cotton, recycled polyester, Tencel, wool).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonReductionClaim rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Claim' ;
    rdfs:comment 'Description of carbon footprint reduction or climate impact claim associated with this eco-label (e.g., 30% lower CO2 emissions vs conventional production).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyRequired rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Required' ;
    rdfs:comment 'Indicates whether a documented chain of custody from raw material to finished product is required for this eco-label.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:circularEconomyEligible rdf:type rdf:Property ;
    rdfs:label 'Circular Economy Eligible' ;
    rdfs:comment 'Indicates whether products bearing this eco-label are eligible for circular economy programs such as take-back, recycling, or resale initiatives.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerFacingClaimText rdf:type rdf:Property ;
    rdfs:label 'Consumer Facing Claim Text' ;
    rdfs:comment 'Approved marketing claim or label text that can be displayed to consumers on product tags, packaging, or digital channels (e.g., Made with Organic Cotton, Certified Recycled Content).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCriteria rdf:type rdf:Property ;
    rdfs:label 'Environmental Criteria' ;
    rdfs:comment 'Summary of the environmental performance criteria required to earn this eco-label (e.g., reduced water usage, chemical restrictions, renewable energy use, biodegradability).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the headquarters location of the issuing body.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Name' ;
    rdfs:comment 'Name of the organization or certification body that issues and governs the eco-label (e.g., Textile Exchange, OEKO-TEX Association, Fair Labor Association).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCode rdf:type rdf:Property ;
    rdfs:label 'Label Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the eco-label or certification standard (e.g., GOTS, OEKO-TEX, BCI, FSC).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelName rdf:type rdf:Property ;
    rdfs:label 'Label Name' ;
    rdfs:comment 'Full official name of the eco-label or sustainability certification (e.g., Global Organic Textile Standard, OEKO-TEX Standard 100).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the annual license fee (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeRequired rdf:type rdf:Property ;
    rdfs:label 'License Fee Required' ;
    rdfs:comment 'Indicates whether a licensing fee must be paid to the issuing body to use this eco-label on products.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoFilePath rdf:type rdf:Property ;
    rdfs:label 'Logo File Path' ;
    rdfs:comment 'File path or storage location of the official eco-label logo image for use in product labeling and marketing materials.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Content Percentage' ;
    rdfs:comment 'Minimum percentage of certified or sustainable material required in a product to qualify for this eco-label (e.g., 95% organic cotton for GOTS).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognizedCountries rdf:type rdf:Property ;
    rdfs:label 'Recognized Countries' ;
    rdfs:comment 'Comma-separated list of three-letter ISO country codes where this eco-label is officially recognized and accepted by regulators and consumers.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialCriteria rdf:type rdf:Property ;
    rdfs:label 'Social Criteria' ;
    rdfs:comment 'Summary of social and labor standards required for this eco-label (e.g., fair wages, safe working conditions, no child labor, freedom of association).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageGuidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Usage Guidelines Url' ;
    rdfs:comment 'Web address linking to the official usage guidelines, logo specifications, and compliance requirements for this eco-label.' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStewardshipClaim rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Claim' ;
    rdfs:comment 'Description of water conservation or stewardship claim associated with this eco-label (e.g., reduced water consumption, wastewater treatment standards).' ;
    rdfs:domain ind:Ecolabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionDate rdf:type rdf:Property ;
    rdfs:label 'Consumption Date' ;
    rdfs:comment 'The date on which the energy consumption occurred or was recorded. Primary business event timestamp for the energy consumption transaction.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumption Quantity' ;
    rdfs:comment 'The quantity of energy consumed during the reporting period. Measured in the unit specified in the unit_of_measure field.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'The emission factor used to convert energy consumption to CO2 equivalent emissions (kg CO2e per unit of energy). Varies by energy source and geographic location.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyCost rdf:type rdf:Property ;
    rdfs:label 'Energy Cost' ;
    rdfs:comment 'The total cost of the energy consumed during the reporting period in the currency specified. Used for energy cost analysis and budgeting.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyIntensityMetric rdf:type rdf:Property ;
    rdfs:label 'Energy Intensity Metric' ;
    rdfs:comment 'Energy intensity calculated as energy consumption per unit of activity (e.g., kWh per square foot for retail stores, kWh per unit produced for manufacturing facilities). Enables benchmarking and efficiency tracking.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySource rdf:type rdf:Property ;
    rdfs:label 'Energy Source' ;
    rdfs:comment 'The type of energy source consumed. Distinguishes between fossil fuels, grid electricity, and renewable sources for Scope 1 and Scope 2 GHG emissions calculations.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intensityDenominator rdf:type rdf:Property ;
    rdfs:label 'Intensity Denominator' ;
    rdfs:comment 'The denominator used to calculate the energy intensity metric (e.g., square feet for retail stores, units produced for manufacturing, revenue for corporate offices).' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterCode rdf:type rdf:Property ;
    rdfs:label 'Meter Code' ;
    rdfs:comment 'The identifier of the physical or virtual meter that recorded the energy consumption. Links consumption data to specific metering infrastructure.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadingType rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Type' ;
    rdfs:comment 'Indicates whether the consumption quantity is based on an actual meter reading, an estimated value, or a billed amount from the utility provider.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1EmissionsKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Emissions Kg Co2e' ;
    rdfs:comment 'Calculated Scope 1 greenhouse gas emissions in kilograms of carbon dioxide equivalent resulting from direct energy consumption (natural gas, diesel, fuel oil). Derived using emission factors from the energy source.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Emissions Kg Co2e' ;
    rdfs:comment 'Calculated Scope 2 greenhouse gas emissions in kilograms of carbon dioxide equivalent resulting from purchased electricity consumption. Derived using grid emission factors for the facility location.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilityAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Utility Account Number' ;
    rdfs:comment 'The account number assigned by the utility provider for billing purposes. Confidential business information used for invoice reconciliation.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityProvider rdf:type rdf:Property ;
    rdfs:label 'Utility Provider' ;
    rdfs:comment 'The name of the utility company or energy provider that supplied the energy. Used for invoice reconciliation and supplier engagement tracking.' ;
    rdfs:domain ind:EnergyConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acidificationPotentialKgSo2e rdf:type rdf:Property ;
    rdfs:label 'Acidification Potential Kg So2e' ;
    rdfs:comment 'Measure of acid rain and soil acidification potential, expressed as kilograms of sulfur dioxide equivalent per functional unit. Results from sulfur oxides, nitrogen oxides, and ammonia emissions from energy generation and chemical processing.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'Name of the consulting firm, certification body, or internal department that performed the assessment. Used for credibility evaluation and third-party verification tracking.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecotoxicityPotentialKg14Dbe rdf:type rdf:Property ;
    rdfs:label 'Ecotoxicity Potential Kg 1 4 Dbe' ;
    rdfs:comment 'Measure of potential ecosystem harm from toxic chemical discharge, expressed as kilograms of 1,4-dichlorobenzene equivalent per functional unit. Covers aquatic toxicity, terrestrial toxicity, and sediment toxicity from chemical effluents.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionMj rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Mj' ;
    rdfs:comment 'Total primary energy consumed per functional unit, measured in megajoules. Includes fossil fuels, electricity, and renewable energy sources. Used for energy efficiency benchmarking and renewable energy transition planning.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eutrophicationPotentialKgPo4e rdf:type rdf:Property ;
    rdfs:label 'Eutrophication Potential Kg Po4e' ;
    rdfs:comment 'Measure of nutrient enrichment potential in aquatic and terrestrial ecosystems, expressed as kilograms of phosphate equivalent per functional unit. Caused by nitrogen and phosphorus discharge from dyeing, finishing, and agricultural runoff.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalUnit rdf:type rdf:Property ;
    rdfs:label 'Functional Unit' ;
    rdfs:comment 'The reference unit to which all environmental impact results are normalized. Examples: one garment, one kilogram of fabric, one production batch. Enables comparability across assessments per ISO 14040 requirements.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Functional Unit Quantity' ;
    rdfs:comment 'Numeric quantity of the functional unit for this assessment. Used to scale impact results to different production volumes or product quantities.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:globalWarmingPotentialKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Global Warming Potential Kg Co2e' ;
    rdfs:comment 'Total greenhouse gas emissions expressed as kilograms of carbon dioxide equivalent per functional unit. Aggregates CO2, methane, nitrous oxide, and other GHGs using IPCC conversion factors. Primary metric for carbon footprint reporting.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousWasteKg rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Kg' ;
    rdfs:comment 'Total hazardous waste generated per functional unit, measured in kilograms. Includes chemical sludge, contaminated materials, and regulated waste streams requiring special handling per EPA or local regulations.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humanToxicityPotentialKg14Dbe rdf:type rdf:Property ;
    rdfs:label 'Human Toxicity Potential Kg 1 4 Dbe' ;
    rdfs:comment 'Measure of potential human health impact from toxic chemical exposure, expressed as kilograms of 1,4-dichlorobenzene equivalent per functional unit. Aggregates carcinogens, respiratory irritants, and endocrine disruptors from dyes, finishes, and processing chemicals.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landUseSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Land Use Square Meters' ;
    rdfs:comment 'Total land area occupied or transformed per functional unit, measured in square meters. Includes agricultural land for natural fibers, facility footprint, and mining/extraction areas. Relevant for biodiversity impact assessment.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The standardized methodology or software tool used to conduct the environmental impact assessment. ISO 14040/14044 is the international standard; Higg MSI is apparel-industry specific; PEF is EU Product Environmental Footprint; GaBi, SimaPro, and Ecoinvent are LCA databases and tools. [ENUM-REF-CANDIDATE: iso_14040_14044|higg_msi|pef|gabi|simapro|ecoinvent|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ozoneDepletionPotentialKgCfc11e rdf:type rdf:Property ;
    rdfs:label 'Ozone Depletion Potential Kg Cfc11e' ;
    rdfs:comment 'Measure of stratospheric ozone layer depletion potential, expressed as kilograms of CFC-11 equivalent per functional unit. Relevant for refrigerants, solvents, and legacy chemical processes.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peerReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Peer Review Completed' ;
    rdfs:comment 'Boolean flag indicating whether this environmental impact assessment has undergone independent peer review by qualified LCA practitioners per ISO 14044 critical review requirements. True indicates peer-reviewed; false indicates not reviewed.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peerReviewDate rdf:type rdf:Property ;
    rdfs:label 'Peer Review Date' ;
    rdfs:comment 'Date when the independent peer review of this environmental impact assessment was completed. Null if peer review has not been conducted. Used for quality assurance tracking and regulatory compliance.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photochemicalOzoneCreationPotentialKgC2h4e rdf:type rdf:Property ;
    rdfs:label 'Photochemical Ozone Creation Potential Kg C2h4e' ;
    rdfs:comment 'Measure of ground-level smog formation potential, expressed as kilograms of ethylene equivalent per functional unit. Results from volatile organic compounds and nitrogen oxides reacting in sunlight. Relevant for solvent-based processes.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Content Percentage' ;
    rdfs:comment 'Percentage of the product or material derived from renewable biological resources (organic cotton, Tencel, bio-based polyester). Used for bio-based content claims and sustainable sourcing metrics.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'System Boundary Description' ;
    rdfs:comment 'Detailed textual description of the processes, stages, and geographic boundaries included in this environmental impact assessment. Defines what is in-scope and out-of-scope per ISO 14044 requirements.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyPercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percentage' ;
    rdfs:comment 'Estimated percentage uncertainty or confidence interval around the primary impact results. Reflects data gaps, modeling assumptions, and variability in supply chain processes. Used for sensitivity analysis and risk-adjusted decision making.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteGeneratedKg rdf:type rdf:Property ;
    rdfs:label 'Waste Generated Kg' ;
    rdfs:comment 'Total solid waste generated per functional unit, measured in kilograms. Includes fabric cutting waste, packaging waste, and end-of-life disposal. Used for circular economy metrics and waste diversion rate calculation.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionLiters rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Liters' ;
    rdfs:comment 'Total freshwater consumed (withdrawn and not returned to source) per functional unit, measured in liters. Includes process water, cooling water, and embedded water in materials. Critical metric for water-scarce regions.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterPollutionIndex rdf:type rdf:Property ;
    rdfs:label 'Water Pollution Index' ;
    rdfs:comment 'Composite index measuring water quality degradation from chemical discharge, thermal pollution, and suspended solids. Normalized score per functional unit. Higher values indicate greater aquatic ecosystem impact.' ;
    rdfs:domain ind:EnvironmentalImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The baseline or reference value against which progress is measured. Used for target-based metrics to track improvement over time.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The specific business unit, division, or brand to which this metric applies. Enables segment-level ESG performance tracking and accountability.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Description of the method, formula, or standard used to calculate or derive the metric value. Ensures transparency and reproducibility of ESG metrics.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorType rdf:type rdf:Property ;
    rdfs:label 'Indicator Type' ;
    rdfs:comment 'The nature of the metric value: quantitative (numeric measurement), qualitative (descriptive assessment), binary (yes/no), or narrative (text explanation).' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialityAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment Flag' ;
    rdfs:comment 'Indicates whether this metric was identified as material through the organization\'s materiality assessment process. True if the metric is considered material to stakeholders and business impact.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'High-level ESG pillar classification of the metric. Categorizes the metric into one of the four primary ESG dimensions.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCode rdf:type rdf:Property ;
    rdfs:label 'Metric Code' ;
    rdfs:comment 'Unique business identifier for the ESG metric. Typically follows the reporting framework standard code (e.g., GRI 305-1, SASB CG-AA-130a.1, TCFD Metrics a).' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricSubcategory rdf:type rdf:Property ;
    rdfs:label 'Metric Subcategory' ;
    rdfs:comment 'Detailed subcategory within the ESG pillar (e.g., Emissions, Water, Waste, Labor Practices, Diversity, Ethics, Supply Chain). Provides granular classification for analytics and benchmarking.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Metric Value Numeric' ;
    rdfs:comment 'The quantitative value of the ESG metric for the reporting period. Used for numeric metrics such as emissions tonnage, water volume, energy consumption, employee count, incident rates.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricValueText rdf:type rdf:Property ;
    rdfs:label 'Metric Value Text' ;
    rdfs:comment 'The qualitative or narrative value of the ESG metric. Used for descriptive metrics, policy statements, or explanatory disclosures that cannot be captured numerically.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousReportedValue rdf:type rdf:Property ;
    rdfs:label 'Previous Reported Value' ;
    rdfs:comment 'The originally reported value before restatement. Maintained for audit trail and transparency when metrics are restated.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingAgencySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Rating Agency Submission Flag' ;
    rdfs:comment 'Indicates whether this metric is submitted to external ESG rating agencies (e.g., MSCI, Sustainalytics, CDP). True if the metric is part of rating agency disclosures.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether reporting of this metric is mandated by regulatory or legal requirements. True if the metric is required by law or regulation (e.g., EU CSRD, SEC climate disclosure).' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'The ESG reporting framework or standard under which this metric is disclosed. Indicates the governing body or standard that defines the metric. [ENUM-REF-CANDIDATE: GRI|SASB|TCFD|CDP|UNGC|IIRC|CDSB|ISO14001|GOTS|OEKO-TEX — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementFlag rdf:type rdf:Property ;
    rdfs:label 'Restatement Flag' ;
    rdfs:comment 'Indicates whether this metric value is a restatement of a previously reported value. True if the metric has been restated due to methodology changes, data corrections, or boundary adjustments.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Explanation of why the metric was restated. Provides transparency on changes to previously disclosed values and ensures stakeholder understanding of data revisions.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeBoundary rdf:type rdf:Property ;
    rdfs:label 'Scope Boundary' ;
    rdfs:comment 'Defines the organizational and operational boundary of the metric (e.g., Company-Owned Operations, Tier 1 Suppliers, Full Supply Chain, Global, Regional). Critical for understanding what entities and activities are included in the measurement.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Priority Level' ;
    rdfs:comment 'The priority level assigned to this metric based on stakeholder engagement and materiality assessment. Reflects the importance of the metric to key stakeholder groups.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromTargetPct rdf:type rdf:Property ;
    rdfs:label 'Variance From Target Pct' ;
    rdfs:comment 'The percentage variance between the actual metric value and the target value. Positive values indicate over-performance, negative values indicate under-performance. Calculated field for performance tracking.' ;
    rdfs:domain ind:EsgDisclosureMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReportEsgReportId rdf:type rdf:Property ;
    rdfs:label 'Previous Report Esg Report Id' ;
    rdfs:comment 'Reference to the prior period ESG report for year-over-year comparison and trend analysis.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgReport .

ind:assuranceStandard rdf:type rdf:Property ;
    rdfs:label 'Assurance Standard' ;
    rdfs:comment 'Specific assurance standard or methodology applied by the assurance provider (e.g., ISAE 3000, AA1000AS).' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Assurance Status' ;
    rdfs:comment 'Level of external third-party assurance obtained for this ESG report.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationApproach rdf:type rdf:Property ;
    rdfs:label 'Consolidation Approach' ;
    rdfs:comment 'Method used to determine which entities and operations are included in the ESG report scope.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Name of the individual responsible for inquiries related to this ESG report.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureLevel rdf:type rdf:Property ;
    rdfs:label 'Disclosure Level' ;
    rdfs:comment 'Extent and depth of ESG disclosures included in this report relative to framework requirements.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'Primary file format in which the ESG report is published and distributed.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griContentIndexIncluded rdf:type rdf:Property ;
    rdfs:label 'Gri Content Index Included' ;
    rdfs:comment 'Indicates whether the report includes a GRI content index mapping disclosures to GRI standards.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityAssessmentConducted rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment Conducted' ;
    rdfs:comment 'Indicates whether a formal materiality assessment was performed to identify significant ESG topics for this report.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportLanguage rdf:type rdf:Property ;
    rdfs:label 'Report Language' ;
    rdfs:comment 'Primary language in which the ESG report is published, using ISO 639-2 three-letter language code.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique identifier for the ESG report, typically following format ESG-YYYY-####.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the report based on publication frequency and purpose.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restatementExplanation rdf:type rdf:Property ;
    rdfs:label 'Restatement Explanation' ;
    rdfs:comment 'Detailed explanation of any restatements made to previously reported ESG data, including reasons and impact.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasbIndexIncluded rdf:type rdf:Property ;
    rdfs:label 'Sasb Index Included' ;
    rdfs:comment 'Indicates whether the report includes a SASB index mapping disclosures to SASB standards for the apparel industry.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Boundary Description' ;
    rdfs:comment 'Detailed description of organizational and operational boundaries included in this ESG report (e.g., which subsidiaries, geographies, business units are covered).' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderEngagementConducted rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Engagement Conducted' ;
    rdfs:comment 'Indicates whether formal stakeholder engagement activities were conducted as part of the report preparation process.' ;
    rdfs:domain ind:EsgReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcfdAlignment rdf:type rdf:Property ;
    rdfs:label 'Tcfd Alignment' ;
    rdfs:comment 'Indicates whether the report is aligned with TCFD recommendations for climate-related financial disclosures.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAssessmentHiggIndexAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Previous Assessment Higg Index Assessment Id' ;
    rdfs:comment 'Reference to the prior year or prior cycle assessment for the same facility or scope, enabling year-over-year performance tracking.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HiggIndexAssessment .

ind:actionPlanCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Completion Date' ;
    rdfs:comment 'Actual date when all improvement actions from the action plan were completed and verified.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target completion date for the improvement action plan associated with this assessment.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airEmissionsScore rdf:type rdf:Property ;
    rdfs:label 'Air Emissions Score' ;
    rdfs:comment 'Section-level score for air quality management and emissions control practices, expressed as a percentage (0-100). Applicable for FEM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentLanguage rdf:type rdf:Property ;
    rdfs:label 'Assessment Language' ;
    rdfs:comment 'Primary language in which the assessment was completed and documented, using ISO 639-1 two-letter language codes.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope Description' ;
    rdfs:comment 'Detailed description of the operational, geographic, or organizational boundaries covered by this assessment.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentYear rdf:type rdf:Property ;
    rdfs:label 'Assessment Year' ;
    rdfs:comment 'The calendar year for which this assessment was conducted, representing the reporting period.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandScope rdf:type rdf:Property ;
    rdfs:label 'Brand Scope' ;
    rdfs:comment 'The brand or business unit within Apparel Fashion for which this assessment applies. Relevant for BRM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalsScore rdf:type rdf:Property ;
    rdfs:label 'Chemicals Score' ;
    rdfs:comment 'Section-level score for chemical management, ZDHC compliance, and hazardous substance control, expressed as a percentage (0-100). Applicable for FEM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the completeness, accuracy, and reliability of the data submitted in this assessment, as evaluated by verifiers or internal reviewers.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyScore rdf:type rdf:Property ;
    rdfs:label 'Energy Score' ;
    rdfs:comment 'Section-level score for energy management and consumption practices, expressed as a percentage (0-100). Applicable for FEM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Health Safety Score' ;
    rdfs:comment 'Section-level score for occupational health and safety management systems and practices, expressed as a percentage (0-100). Applicable for FSLM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:higgPlatformCode rdf:type rdf:Property ;
    rdfs:label 'Higg Platform Code' ;
    rdfs:comment 'Unique identifier assigned by the Higg Index platform for this assessment, used for cross-system reconciliation and data sharing.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Improvement Action Plan Status' ;
    rdfs:comment 'Current status of the corrective action plan (CAP) or continuous improvement plan developed in response to assessment findings.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborPracticesScore rdf:type rdf:Property ;
    rdfs:label 'Labor Practices Score' ;
    rdfs:comment 'Section-level score for labor rights, working conditions, and employee welfare practices, expressed as a percentage (0-100). Applicable for FSLM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moduleType rdf:type rdf:Property ;
    rdfs:label 'Module Type' ;
    rdfs:comment 'The specific Higg Index module being assessed: Facility Environmental Module (FEM), Facility Social & Labor Module (FSLM), Brand & Retail Module (BRM), Materials Module, or Product Module.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Score' ;
    rdfs:comment 'The overall score achieved during the self-assessment phase, expressed as a percentage (0-100).' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifiedScore rdf:type rdf:Property ;
    rdfs:label 'Verified Score' ;
    rdfs:comment 'The final score after third-party verification, expressed as a percentage (0-100). Null if verification has not been completed.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifierAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Verifier Accreditation Number' ;
    rdfs:comment 'Official accreditation or registration number of the verification body, as recognized by SAC or relevant governing bodies.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteScore rdf:type rdf:Property ;
    rdfs:label 'Waste Score' ;
    rdfs:comment 'Section-level score for waste management, recycling, and circular economy practices, expressed as a percentage (0-100). Applicable for FEM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterScore rdf:type rdf:Property ;
    rdfs:label 'Water Score' ;
    rdfs:comment 'Section-level score for water use, wastewater management, and water conservation practices, expressed as a percentage (0-100). Applicable for FEM assessments.' ;
    rdfs:domain ind:HiggIndexAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference number or identifier for the audit report document that contains detailed findings and verification results.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Certification Cost Amount' ;
    rdfs:comment 'The total cost incurred to obtain and maintain this material certification, including audit fees, testing fees, and annual license fees.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Certification Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the official certification document or certificate.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStandardCode rdf:type rdf:Property ;
    rdfs:label 'Certification Standard Code' ;
    rdfs:comment 'The sustainability or safety certification standard under which the material is certified. Examples include GOTS (Global Organic Textile Standard), OEKO-TEX STANDARD 100, bluesign, GRS (Global Recycled Standard), BCI (Better Cotton Initiative), FSC (Forest Stewardship Council), C2C (Cradle to Cradle), REACH, RCS (Recycled Claim Standard), OCS (Organic Content Standard), RWS (Responsible Wool Standard), RDS (Responsible Down Standard), LWG (Leather Working Group), ZDHC (Zero Discharge of Hazardous Chemicals). [ENUM-REF-CANDIDATE: GOTS|OEKO-TEX-100|BLUESIGN|GRS|BCI|FSC|C2C|OEKO-TEX-LEATHER|REACH|RCS|OCS|RWS|RDS|LWG|ZDHC|STANDARD-100 — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVersion rdf:type rdf:Property ;
    rdfs:label 'Certification Version' ;
    rdfs:comment 'The version number of the certification standard under which this material was certified (e.g., GOTS Version 6.0, OEKO-TEX STANDARD 100 2023 edition).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Certified Content Percentage' ;
    rdfs:comment 'The percentage of certified material content in the product or material composition (e.g., 95% organic cotton, 50% recycled polyester).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Certified Product Category' ;
    rdfs:comment 'The product category or categories for which this material certification is valid (e.g., apparel, home textiles, accessories, footwear).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Accreditation Number' ;
    rdfs:comment 'The accreditation number or license identifier of the certifying body, validating their authority to issue the certification.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyName rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Name' ;
    rdfs:comment 'The name of the independent third-party organization or accredited body that issued the certification (e.g., Control Union, ECOCERT, TÜV, SGS, Intertek).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyTcNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Tc Number' ;
    rdfs:comment 'The transaction certificate number that tracks the certified material through the supply chain, ensuring traceability from source to finished product.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Method' ;
    rdfs:comment 'The method used by the certifying body to verify compliance with the certification standard (e.g., on-site audit, document review, laboratory testing, remote assessment, hybrid approach).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiSiteCertification rdf:type rdf:Property ;
    rdfs:label 'Is Multi Site Certification' ;
    rdfs:comment 'Boolean flag indicating whether this certification covers multiple production sites or facilities under a single certificate.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialOriginCountryCode rdf:type rdf:Property ;
    rdfs:label 'Material Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country of origin where the certified material was sourced or produced.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notes' ;
    rdfs:comment 'Notes documenting any non-compliance issues, corrective actions required, or conditions attached to the certification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The scheduled date by which the certification must be renewed to maintain continuous valid status.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementPackagingPackagingSustainabilityId rdf:type rdf:Property ;
    rdfs:label 'Replacement Packaging Packaging Sustainability Id' ;
    rdfs:comment 'Reference to the more sustainable packaging type that will replace this one during phase-out. Null if no replacement identified.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackagingSustainability .

ind:annualVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Units' ;
    rdfs:comment 'Estimated annual usage volume of this packaging type across all channels. Used to calculate total environmental impact and cost.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biodegradabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Biodegradability Certification' ;
    rdfs:comment 'Third-party certification for biodegradable or compostable packaging: ok_compost_home (home composting), ok_compost_industrial (industrial composting), astm_d6400 (US standard), en_13432 (EU standard), not_certified.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintKgCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kg Co2e' ;
    rdfs:comment 'Estimated carbon footprint of the packaging unit expressed in kilograms of carbon dioxide equivalent (CO2e), covering raw material extraction, manufacturing, and end-of-life. Supports Scope 3 emissions reporting.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerUnitUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit Usd' ;
    rdfs:comment 'Standard cost per packaging unit in US dollars. Used for cost-benefit analysis of sustainable packaging alternatives.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eprComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Epr Compliance Status' ;
    rdfs:comment 'Compliance status with Extended Producer Responsibility regulations requiring producers to manage end-of-life packaging: compliant (meets all EPR requirements), non_compliant (violations identified), exempt (not subject to EPR), pending_review (under assessment).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eprRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epr Registration Number' ;
    rdfs:comment 'Official registration number with EPR compliance schemes (e.g., PRN in UK, Green Dot in EU). Null if not registered or exempt.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fscCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Fsc Certificate Number' ;
    rdfs:comment 'Official FSC chain-of-custody certificate number for paper-based packaging (e.g., FSC-C123456). Null if not FSC-certified.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fscCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fsc Certification Status' ;
    rdfs:comment 'FSC certification level for paper/cardboard packaging: fsc_100 (100% FSC-certified forests), fsc_mix (mix of FSC and controlled sources), fsc_recycled (100% recycled fiber), not_certified, pending (certification in progress).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Indicator' ;
    rdfs:comment 'Indicates whether the packaging contains hazardous substances restricted under REACH, RoHS, or similar regulations (e.g., heavy metals, phthalates, PFAS). True if hazardous substances present, False if compliant.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:microplasticSheddingRisk rdf:type rdf:Property ;
    rdfs:label 'Microplastic Shedding Risk' ;
    rdfs:comment 'Assessment of the risk that the packaging will shed microplastics during use or degradation: high (significant shedding expected), medium (moderate risk), low (minimal risk), none (no plastic content or non-shedding material).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCategory rdf:type rdf:Property ;
    rdfs:label 'Packaging Category' ;
    rdfs:comment 'Classification of packaging by usage context: primary (direct product contact), secondary (retail display), tertiary (shipping/distribution), point_of_sale (in-store), e_commerce (online fulfillment), wholesale (B2B distribution).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingReductionTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Packaging Reduction Target Percentage' ;
    rdfs:comment 'Target percentage reduction in packaging weight or volume compared to baseline year, aligned with corporate sustainability commitments (e.g., 25.00 for 25% reduction target).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Type Code' ;
    rdfs:comment 'Unique code identifying the packaging type (e.g., PBAG001 for polybag, HTAG002 for hang tag, SBAG003 for shopping bag, MAIL004 for mailer, CRTN005 for carton).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingTypeName rdf:type rdf:Property ;
    rdfs:label 'Packaging Type Name' ;
    rdfs:comment 'Human-readable name of the packaging type (e.g., Polybag, Hang Tag, Shopping Bag, Mailer, Carton, Box, Tissue Paper, Ribbon).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseOutTargetDate rdf:type rdf:Property ;
    rdfs:label 'Phase Out Target Date' ;
    rdfs:comment 'Target date for discontinuing this packaging type as part of sustainability roadmap. Null if no phase-out planned.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plasticWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Plastic Weight Grams' ;
    rdfs:comment 'Total weight of plastic content per packaging unit in grams. Critical for tracking plastic reduction targets and Extended Producer Responsibility (EPR) reporting.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postConsumerRecycledPercentage rdf:type rdf:Property ;
    rdfs:label 'Post Consumer Recycled Percentage' ;
    rdfs:comment 'Percentage of post-consumer recycled content specifically (material recovered from consumer waste streams), as distinct from post-industrial recycled content. Critical for ESG reporting and sustainability claims.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryMaterialType rdf:type rdf:Property ;
    rdfs:label 'Primary Material Type' ;
    rdfs:comment 'The dominant material category of the packaging: plastic, paper, cardboard, textile, metal, glass, bioplastic (plant-based), or composite (mixed materials). [ENUM-REF-CANDIDATE: plastic|paper|cardboard|textile|metal|glass|bioplastic|composite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Reach Compliance Status' ;
    rdfs:comment 'Compliance status with EU REACH regulation restricting hazardous substances in packaging materials: compliant (meets all REACH requirements), non_compliant (violations identified), under_review (assessment in progress), not_applicable (outside EU scope).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclabilityRating rdf:type rdf:Property ;
    rdfs:label 'Recyclability Rating' ;
    rdfs:comment 'Assessment of how easily the packaging can be recycled in standard municipal recycling systems: fully_recyclable (accepted everywhere), widely_recyclable (accepted in most programs), limited_recyclability (specialty facilities only), not_recyclable, compostable (industrial composting), biodegradable (natural decomposition).' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Reusability Indicator' ;
    rdfs:comment 'Indicates whether the packaging is designed for multiple uses (e.g., reusable shopping bags, returnable shipping containers). True if reusable, False if single-use.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reuseCycleCount rdf:type rdf:Property ;
    rdfs:label 'Reuse Cycle Count' ;
    rdfs:comment 'Expected number of reuse cycles for reusable packaging before end-of-life. Null for single-use packaging.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierSustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Supplier Sustainability Score' ;
    rdfs:comment 'Sustainability performance score of the packaging supplier, typically on a 0-100 scale. Based on environmental audits, certifications, and ESG assessments.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainableCertificationList rdf:type rdf:Property ;
    rdfs:label 'Sustainable Certification List' ;
    rdfs:comment 'Semicolon-separated list of sustainability certifications held by the packaging (e.g., Cradle to Cradle; OEKO-TEX; Global Recycled Standard; Blue Angel; Nordic Swan). Supports ESG reporting and marketing claims.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Total Weight Grams' ;
    rdfs:comment 'Total weight of the packaging unit in grams, including all materials. Used for carbon footprint calculations and logistics optimization.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:virginPlasticIndicator rdf:type rdf:Property ;
    rdfs:label 'Virgin Plastic Indicator' ;
    rdfs:comment 'Indicates whether the packaging contains virgin (non-recycled) plastic. True if virgin plastic is present, False if plastic-free or 100% recycled plastic. Critical for plastic reduction commitments.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterUsageLiters rdf:type rdf:Property ;
    rdfs:label 'Water Usage Liters' ;
    rdfs:comment 'Estimated water consumption in liters required to produce one unit of packaging, from raw material extraction through manufacturing. Supports water stewardship reporting.' ;
    rdfs:domain ind:PackagingSustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associatedMarket rdf:type rdf:Property ;
    rdfs:label 'Associated Market' ;
    rdfs:comment 'Geographic market or grid region where the certificate is being applied for Scope 2 accounting, ensuring alignment between generation location and consumption location per GHG Protocol guidance.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryOrganization rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Organization' ;
    rdfs:comment 'Name of the organization on whose behalf the certificate was retired, typically Apparel Fashion or a subsidiary entity.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate. Active = available for use, Retired = claimed for Scope 2 accounting, Expired = past validity period, Cancelled = invalidated, Transferred = moved to another account.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of renewable energy certificate instrument. REC = Renewable Energy Certificate (North America), GO = Guarantee of Origin (Europe), I-REC = International Renewable Energy Certificate, TIGR = The International Greenhouse Gas Registry, J-Credit = Japan Carbon Credit.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationEndDate rdf:type rdf:Property ;
    rdfs:label 'Generation End Date' ;
    rdfs:comment 'End date of the generation period for the electricity represented by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationFacilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Generation Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the generation facility is located.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Generation Facility Location' ;
    rdfs:comment 'Geographic location of the generation facility, typically city and state or province.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Generation Facility Name' ;
    rdfs:comment 'Name of the renewable energy generation facility or power plant that produced the electricity.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationStartDate rdf:type rdf:Property ;
    rdfs:label 'Generation Start Date' ;
    rdfs:comment 'Start date of the generation period for the electricity represented by this certificate.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'Method by which the renewable energy certificate was procured. Unbundled REC = certificate purchased separately from electricity, Bundled PPA = Power Purchase Agreement with bundled RECs, VPPA = Virtual Power Purchase Agreement, Green Tariff = utility green pricing program, Direct Investment = owned generation facility.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePricePerMwh rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Per Mwh' ;
    rdfs:comment 'Price paid per megawatt-hour for this certificate, used for cost tracking and financial reporting.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityMwh rdf:type rdf:Property ;
    rdfs:label 'Quantity Mwh' ;
    rdfs:comment 'Quantity of renewable electricity represented by this certificate, measured in megawatt-hours. One certificate typically represents one MWh of renewable electricity generation.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:re100EligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Re100 Eligible Flag' ;
    rdfs:comment 'Indicates whether this certificate meets RE100 technical criteria for renewable electricity sourcing, including additionality, vintage matching, and geographic correlation requirements.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Account Number' ;
    rdfs:comment 'Account number or identifier in the registry system under which this certificate is held or was retired.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the tracking system or registry that issued and tracks this certificate (e.g., M-RETS, PJM-GATS, APX TIGR, I-REC Standard).' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope2ReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Reporting Period' ;
    rdfs:comment 'Fiscal year or reporting period for which this certificate is being applied to Scope 2 market-based emissions accounting (e.g., FY2024, 2024-Q1).' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the broker, utility, or renewable energy provider from whom the certificate was purchased.' ;
    rdfs:domain ind:RenewableEnergyCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Applicability Flag' ;
    rdfs:comment 'Boolean indicator of whether this Scope 3 category is applicable and material to Apparel Fashion\'s business operations and value chain. True indicates the category is relevant and should be tracked; False indicates the category does not apply to the company\'s activities.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationMethodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology Description' ;
    rdfs:comment 'Detailed explanation of the specific calculation approach, data sources, emission factors, and assumptions used to quantify emissions for this Scope 3 category at Apparel Fashion. Includes references to databases such as DEFRA, EPA, or industry-specific factors.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryNumber rdf:type rdf:Property ;
    rdfs:label 'Category Number' ;
    rdfs:comment 'The official numeric identifier (1-15) assigned to this Scope 3 category by the GHG Protocol Corporate Value Chain Standard. Categories are numbered sequentially from 1 (Purchased Goods and Services) through 15 (Investments).' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectionApproach rdf:type rdf:Property ;
    rdfs:label 'Data Collection Approach' ;
    rdfs:comment 'Description of how activity data is collected for this category, including source systems (ERP, PLM, WMS, procurement systems), data collection frequency, responsible parties, and data quality controls. Specific to Apparel Fashion\'s operational systems and supply chain structure.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Data Coverage Percentage' ;
    rdfs:comment 'The percentage of total activity within this category for which actual data is collected and used in emission calculations, as opposed to estimated or extrapolated data. Higher coverage indicates more accurate and reliable emission quantification.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Data Owner Email' ;
    rdfs:comment 'The email address of the data owner responsible for this Scope 3 category. Used for coordination, data quality escalation, and audit inquiries.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataOwnerName rdf:type rdf:Property ;
    rdfs:label 'Data Owner Name' ;
    rdfs:comment 'The name of the individual or role accountable for the accuracy, completeness, and timeliness of emission data for this category. Serves as the primary contact for data quality issues and methodology questions.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'Classification of the typical data quality level achieved for this category based on the GHG Protocol data quality hierarchy. Tier 1 represents supplier-specific primary data; Tier 2 represents secondary data; Tier 3 represents industry averages; Tier 4 represents proxy or estimated data.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequirement rdf:type rdf:Property ;
    rdfs:label 'Disclosure Requirement' ;
    rdfs:comment 'Classification of the disclosure expectation for this category based on regulatory requirements, investor expectations, and sustainability reporting frameworks. Mandatory categories must be reported; recommended categories are expected by stakeholders; optional categories may be disclosed for transparency.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorDatabase rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Database' ;
    rdfs:comment 'The authoritative database or source used to obtain emission factors for calculating this category\'s carbon footprint. Common sources include DEFRA, EPA, Ecoinvent, GaBi, Higg MSI, or industry-specific databases.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griStandardReference rdf:type rdf:Property ;
    rdfs:label 'Gri Standard Reference' ;
    rdfs:comment 'The specific GRI standard and disclosure number to which this Scope 3 category maps for sustainability reporting purposes. Typically references GRI 305: Emissions standard.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySpecificGuidance rdf:type rdf:Property ;
    rdfs:label 'Industry Specific Guidance' ;
    rdfs:comment 'Reference to apparel and fashion industry-specific calculation guidance, tools, or standards applicable to this category. May include references to Higg Index, Sustainable Apparel Coalition methodologies, or textile-specific emission factor databases.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'The date when emissions data for this category was most recently verified or assured by a third-party auditor. Used to track assurance currency and plan future verification cycles.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Materiality Assessment Date' ;
    rdfs:comment 'The date when the most recent materiality assessment was conducted to determine whether this Scope 3 category is significant to Apparel Fashion\'s carbon footprint and should be included in reporting.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialityRationale rdf:type rdf:Property ;
    rdfs:label 'Materiality Rationale' ;
    rdfs:comment 'Business justification explaining why this category was determined to be material or immaterial to Apparel Fashion\'s Scope 3 emissions inventory. Includes considerations such as estimated emission magnitude, stakeholder expectations, and strategic relevance.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Primary Data Source System' ;
    rdfs:comment 'The name of the primary operational system of record from which activity data for this category is extracted. Examples include SAP S/4HANA for procurement data, Manhattan WMS for logistics data, or Centric PLM for product material data.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Reduction Target Percentage' ;
    rdfs:comment 'The percentage reduction in emissions targeted for this category by the target year, relative to the baseline year. Aligned with Apparel Fashion\'s overall Scope 3 reduction commitments and SBTi validation requirements.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingBoundary rdf:type rdf:Property ;
    rdfs:label 'Reporting Boundary' ;
    rdfs:comment 'Definition of the organizational and operational boundaries for this category, specifying which entities, facilities, geographies, and activities are included in or excluded from the emission calculations for this category.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasbMetricReference rdf:type rdf:Property ;
    rdfs:label 'Sasb Metric Reference' ;
    rdfs:comment 'The specific SASB metric code from the Apparel, Accessories & Footwear industry standard to which this Scope 3 category maps. Used for investor-focused sustainability disclosure.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Sbti Alignment Flag' ;
    rdfs:comment 'Boolean indicator of whether the reduction target for this category is aligned with and validated by the Science Based Targets initiative. True indicates SBTi validation; False indicates internal target only.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyChainTierCoverage rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Tier Coverage' ;
    rdfs:comment 'Description of which tiers of the apparel supply chain are included in this category\'s emission calculations. For example, Tier 1 (cut-make-trim facilities), Tier 2 (fabric mills), Tier 3 (fiber producers), Tier 4 (raw material extraction). Critical for understanding supply chain transparency and data collection scope.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyRangePercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Range Percentage' ;
    rdfs:comment 'The estimated uncertainty or margin of error in emission calculations for this category, expressed as a percentage. Reflects data quality, estimation methods, and variability in emission factors. Used for sensitivity analysis and disclosure.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Verification Requirement' ;
    rdfs:comment 'Classification indicating the level of external assurance or verification required for emissions data in this category. Third-party verification may be required for regulatory compliance, investor expectations, or SBTi validation.' ;
    rdfs:domain ind:Scope3Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditProvider rdf:type rdf:Property ;
    rdfs:label 'Audit Provider' ;
    rdfs:comment 'Name of the third-party organization that conducted the external audit or verification of program impact.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Total number of individuals directly benefiting from the program during the reporting period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Direct Beneficiary Count' ;
    rdfs:comment 'Number of individuals receiving direct program services or interventions.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Flag' ;
    rdfs:comment 'Indicates whether the program has undergone or is subject to external third-party audit or verification.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReportingFlag rdf:type rdf:Property ;
    rdfs:label 'External Reporting Flag' ;
    rdfs:comment 'Indicates whether this program is included in external ESG reports, sustainability disclosures, or public communications.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:femaleBeneficiaryPercentage rdf:type rdf:Property ;
    rdfs:label 'Female Beneficiary Percentage' ;
    rdfs:comment 'Percentage of program beneficiaries who are female, supporting gender equity tracking.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flaAlignedFlag rdf:type rdf:Property ;
    rdfs:label 'Fla Aligned Flag' ;
    rdfs:comment 'Indicates whether the program is aligned with Fair Labor Association workplace standards and principles.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:herprojectFlag rdf:type rdf:Property ;
    rdfs:label 'Herproject Flag' ;
    rdfs:comment 'Indicates whether this program is part of the HERproject womens empowerment initiative in the supply chain.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactMetricType rdf:type rdf:Property ;
    rdfs:label 'Impact Metric Type' ;
    rdfs:comment 'Primary quantitative metric used to measure program impact and effectiveness.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Impact Metric Unit' ;
    rdfs:comment 'Unit of measurement for the impact metric value (e.g., USD, hours, individuals, percentage).' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactMetricValue rdf:type rdf:Property ;
    rdfs:label 'Impact Metric Value' ;
    rdfs:comment 'Quantitative value of the primary impact metric achieved during the reporting period.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectBeneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Indirect Beneficiary Count' ;
    rdfs:comment 'Estimated number of individuals indirectly benefiting from the program (e.g., family members, community members).' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentAmount rdf:type rdf:Property ;
    rdfs:label 'Investment Amount' ;
    rdfs:comment 'Total financial investment committed or allocated to the program in the reporting currency.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Investment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the investment amount.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:livingWageBenchmarkMetFlag rdf:type rdf:Property ;
    rdfs:label 'Living Wage Benchmark Met Flag' ;
    rdfs:comment 'Indicates whether the program has achieved living wage benchmarks for participating workers as defined by Fair Wage Network or Global Living Wage Coalition standards.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerNgoName rdf:type rdf:Property ;
    rdfs:label 'Partner Ngo Name' ;
    rdfs:comment 'Name of the primary non-governmental organization or non-profit partner collaborating on program delivery.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerNgoType rdf:type rdf:Property ;
    rdfs:label 'Partner Ngo Type' ;
    rdfs:comment 'Classification of the partner organization type.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programManagerName rdf:type rdf:Property ;
    rdfs:label 'Program Manager Name' ;
    rdfs:comment 'Name of the individual responsible for day-to-day program management and execution.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successStorySummary rdf:type rdf:Property ;
    rdfs:label 'Success Story Summary' ;
    rdfs:comment 'Brief summary of key success stories, testimonials, or qualitative impact evidence from the program.' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiaryGroup rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiary Group' ;
    rdfs:comment 'Description of the primary beneficiary population or demographic group targeted by this program (e.g., garment workers, women in supply chain, local artisans, factory communities).' ;
    rdfs:domain ind:SocialImpactProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areasForImprovement rdf:type rdf:Property ;
    rdfs:label 'Areas For Improvement' ;
    rdfs:comment 'Description of areas where the supplier needs to improve ESG performance to meet standards or best practices.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCost rdf:type rdf:Property ;
    rdfs:label 'Assessment Cost' ;
    rdfs:comment 'Total cost incurred for conducting the ESG assessment, including auditor fees, travel, and administrative expenses.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the assessment cost.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'URL or file path to the detailed assessment report document stored in the document management system.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorAccreditation rdf:type rdf:Property ;
    rdfs:label 'Assessor Accreditation' ;
    rdfs:comment 'Professional accreditation or certification held by the assessor (e.g., APSCA, SAAS, ISO lead auditor).' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAchieved rdf:type rdf:Property ;
    rdfs:label 'Certification Achieved' ;
    rdfs:comment 'Indicates whether the supplier achieved formal certification as a result of this assessment (e.g., WRAP certified, SA8000 certified).' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Name of the ESG certification or standard achieved by the supplier through this assessment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanApproved rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Approved' ;
    rdfs:comment 'Indicates whether the submitted corrective action plan has been reviewed and approved by Apparel Fashion.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlanSubmitted rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Submitted' ;
    rdfs:comment 'Indicates whether the supplier has submitted a formal corrective action plan in response to assessment findings.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Score' ;
    rdfs:comment 'Numerical score representing the supplier\'s environmental performance across metrics such as energy use, water consumption, waste management, emissions, and chemical management. Scale and methodology depend on assessment type.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the facility location.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assessment Date' ;
    rdfs:comment 'Scheduled date for the follow-up assessment to verify corrective action completion.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Assessment Required' ;
    rdfs:comment 'Indicates whether a follow-up assessment is required to verify implementation of corrective actions.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governanceScore rdf:type rdf:Property ;
    rdfs:label 'Governance Score' ;
    rdfs:comment 'Numerical score representing the supplier\'s governance and ethical business practices including anti-corruption, transparency, management systems, and compliance with laws and regulations. Scale and methodology depend on assessment type.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'Textual summary of the most significant findings, violations, and observations from the ESG assessment.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Target date by which the supplier must complete all required corrective actions and remediation measures.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:socialScore rdf:type rdf:Property ;
    rdfs:label 'Social Score' ;
    rdfs:comment 'Numerical score representing the supplier\'s social and labor performance across metrics such as working conditions, wages, working hours, health and safety, freedom of association, and non-discrimination. Scale and methodology depend on assessment type.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthsIdentified rdf:type rdf:Property ;
    rdfs:label 'Strengths Identified' ;
    rdfs:comment 'Description of positive practices, strengths, and areas of excellence identified during the assessment.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Supply chain tier classification of the assessed supplier. Tier 1 are direct suppliers (cut-make-trim factories), Tier 2 are fabric mills and material processors, Tier 3 are raw material suppliers (fiber, yarn), Tier 4 are commodity suppliers.' ;
    rdfs:domain ind:SupplierEsgAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCarbonReductionMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Actual Carbon Reduction Mt Co2e' ;
    rdfs:comment 'Measured annual greenhouse gas emissions reduction in metric tons of CO2 equivalent achieved by the initiative, null until verified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEnergySavingsMwh rdf:type rdf:Property ;
    rdfs:label 'Actual Energy Savings Mwh' ;
    rdfs:comment 'Measured annual energy consumption reduction in megawatt hours achieved by the initiative, null until verified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWasteDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Actual Waste Diversion Kg' ;
    rdfs:comment 'Measured annual waste diverted from landfill in kilograms achieved by the initiative, null until verified.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWaterSavingsM3 rdf:type rdf:Property ;
    rdfs:label 'Actual Water Savings M3' ;
    rdfs:comment 'Measured annual water consumption reduction in cubic meters achieved by the initiative, null until verified.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alignmentToSbti rdf:type rdf:Property ;
    rdfs:label 'Alignment To Sbti' ;
    rdfs:comment 'Indicates whether the initiative contributes to the company\'s Science Based Targets for climate action.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alignmentToUnSdg rdf:type rdf:Property ;
    rdfs:label 'Alignment To Un Sdg' ;
    rdfs:comment 'Comma-separated list of UN SDG goal numbers that the initiative supports, such as \'6,12,13\' for Clean Water, Responsible Consumption, and Climate Action.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTarget rdf:type rdf:Property ;
    rdfs:label 'Certification Target' ;
    rdfs:comment 'Name of the sustainability certification or standard the initiative aims to achieve, such as GOTS, OEKO-TEX, or Cradle to Cradle.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor' ;
    rdfs:comment 'Senior executive providing strategic oversight and budget approval for the initiative.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sustainability initiative, used for tracking and reporting across systems.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeDescription rdf:type rdf:Property ;
    rdfs:label 'Initiative Description' ;
    rdfs:comment 'Detailed description of the sustainability initiative, including objectives, scope, and expected outcomes.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Human-readable name of the sustainability initiative, such as \'Renewable Energy Transition DC-East\' or \'Waterless Dyeing Pilot Program\'.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the sustainability initiative in the portfolio management workflow.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeType rdf:type rdf:Property ;
    rdfs:label 'Initiative Type' ;
    rdfs:comment 'Classification of the initiative by implementation approach and business function impacted.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the executive or department responsible for delivering the initiative.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCarbonReductionMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Projected Carbon Reduction Mt Co2e' ;
    rdfs:comment 'Estimated annual greenhouse gas emissions reduction in metric tons of CO2 equivalent that the initiative is expected to achieve.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedEnergySavingsMwh rdf:type rdf:Property ;
    rdfs:label 'Projected Energy Savings Mwh' ;
    rdfs:comment 'Estimated annual energy consumption reduction in megawatt hours that the initiative is expected to achieve.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedWasteDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Projected Waste Diversion Kg' ;
    rdfs:comment 'Estimated annual waste diverted from landfill in kilograms through circular economy or waste reduction programs.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedWaterSavingsM3 rdf:type rdf:Property ;
    rdfs:label 'Projected Water Savings M3' ;
    rdfs:comment 'Estimated annual water consumption reduction in cubic meters that the initiative is expected to achieve.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityPillar rdf:type rdf:Property ;
    rdfs:label 'Sustainability Pillar' ;
    rdfs:comment 'Primary sustainability focus area of the initiative, aligned with ESG (Environmental, Social, and Governance) framework pillars.' ;
    rdfs:domain ind:Initiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the third-party organization that conducted verification or assurance of the initiative\'s impact.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentFramework rdf:type rdf:Property ;
    rdfs:label 'Commitment Framework' ;
    rdfs:comment 'The external sustainability framework, initiative, or standard to which this target is aligned (e.g., \'Science Based Targets\', \'UN SDG 6\', \'ZDHC Roadmap to Zero\', \'Fair Labor Association\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentValue rdf:type rdf:Property ;
    rdfs:label 'Current Value' ;
    rdfs:comment 'The most recent measured or reported value representing progress toward the target. Updated periodically as performance data becomes available.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentValueAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Current Value As Of Date' ;
    rdfs:comment 'The date on which the current value was last measured or reported, indicating the freshness of progress data.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPublicCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Public Commitment' ;
    rdfs:comment 'Indicates whether this target has been publicly disclosed or committed to external stakeholders, investors, or regulatory bodies.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of the calculation method, data sources, and standards used to measure progress toward the target.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Public Commitment Date' ;
    rdfs:comment 'The date on which the target was publicly announced or committed to external parties. Null if not publicly committed.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedSdgGoals rdf:type rdf:Property ;
    rdfs:label 'Related Sdg Goals' ;
    rdfs:comment 'Comma-separated list of United Nations Sustainable Development Goals (SDGs) to which this target contributes (e.g., \'SDG 6\', \'SDG 12\', \'SDG 5\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Unique business identifier or code for the sustainability target used for external reporting and tracking (e.g., \'WATER-2030\', \'CIRC-DIV-2025\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year by which the target value is committed to be achieved.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biodegradableFlag rdf:type rdf:Property ;
    rdfs:label 'Biodegradable Flag' ;
    rdfs:comment 'Indicates whether the material is biodegradable under standard environmental conditions. True if biodegradable, False otherwise.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chemicalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Chemical Compliance Status' ;
    rdfs:comment 'Status of material compliance with restricted substance lists (RSL) and manufacturing restricted substance lists (MRSL). Indicates whether material meets chemical safety standards.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularEconomyEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Circular Economy Eligible Flag' ;
    rdfs:comment 'Indicates whether the material is eligible for circular economy programs (take-back, recycling, upcycling). True if eligible, False otherwise.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgScore rdf:type rdf:Property ;
    rdfs:label 'Esg Score' ;
    rdfs:comment 'Composite ESG score for the material based on environmental impact, social responsibility, and governance criteria (0.00 to 100.00). Used for sustainability reporting and material selection.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberType rdf:type rdf:Property ;
    rdfs:label 'Fiber Type' ;
    rdfs:comment 'Primary fiber type of the material. Indicates the base fiber composition category. [ENUM-REF-CANDIDATE: cotton|polyester|nylon|wool|linen|hemp|bamboo|tencel|modal|elastane|silk|rayon|acrylic|blended — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialWeightGsm rdf:type rdf:Property ;
    rdfs:label 'Material Weight Gsm' ;
    rdfs:comment 'Weight of the material in grams per square meter (GSM). Standard textile weight measurement used in product specifications and tech packs.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialWidthCm rdf:type rdf:Property ;
    rdfs:label 'Material Width Cm' ;
    rdfs:comment 'Standard width of the material in centimeters. Used for yield calculations and pattern making.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Organic Content Percentage' ;
    rdfs:comment 'Percentage of organic fiber content in the material (0.00 to 100.00). Null if material is not organic. Required for GOTS certification compliance.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Source Flag' ;
    rdfs:comment 'Indicates whether the material is derived from renewable sources (plant-based, bio-based). True if renewable, False otherwise.' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkagePercentage rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Percentage' ;
    rdfs:comment 'Expected shrinkage percentage after washing. Used for pattern grading and quality specifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityAttribute rdf:type rdf:Property ;
    rdfs:label 'Sustainability Attribute' ;
    rdfs:comment 'Primary sustainability characteristic of the material (organic, recycled, bio-based, regenerative agriculture, low-impact dye, bluesign certified, Better Cotton Initiative cotton, fair trade). [ENUM-REF-CANDIDATE: organic|recycled|bio_based|regenerative|low_impact|bluesign|bci_cotton|fair_trade — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SustainableMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityTier rdf:type rdf:Property ;
    rdfs:label 'Traceability Tier' ;
    rdfs:comment 'Level of supply chain traceability for the material. Tier 1 (finished goods supplier), Tier 2 (fabric mill), Tier 3 (yarn spinner), Tier 4 (raw material producer), Full Chain (end-to-end traceability).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the audit report or inspection record associated with this traceability event, linking to compliance and quality assurance documentation.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockchainHash rdf:type rdf:Property ;
    rdfs:label 'Blockchain Hash' ;
    rdfs:comment 'The cryptographic hash or transaction identifier if this traceability record is anchored on a blockchain platform for immutable supply chain transparency.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyMethod rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Method' ;
    rdfs:comment 'The method used to track and verify the material through the supply chain. Identity Preserved maintains physical separation of certified material throughout. Segregated keeps certified material separate but may mix sources. Mass Balance allows mixing with tracking of certified content percentage. Book and Claim uses administrative credits without physical traceability.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalUsageKg rdf:type rdf:Property ;
    rdfs:label 'Chemical Usage Kg' ;
    rdfs:comment 'The total weight of chemicals used in this processing stage (e.g., dyes, finishes, treatments), measured in kilograms, supporting chemical management and ZDHC compliance.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'The energy consumed during this manufacturing or processing stage, measured in kilowatt hours (kWh), supporting energy efficiency and renewable energy reporting.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairTradeCertified rdf:type rdf:Property ;
    rdfs:label 'Fair Trade Certified' ;
    rdfs:comment 'Boolean flag indicating whether this supply chain stage is Fair Trade certified, ensuring fair labor practices and community development.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoordinates rdf:type rdf:Property ;
    rdfs:label 'Geographic Coordinates' ;
    rdfs:comment 'The latitude and longitude coordinates of the facility or farm where this traceability event occurred, enabling precise geographic traceability.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'The specific manufacturing or processing stage captured in this traceability record (e.g., Spinning, Weaving, Knitting, Dyeing, Printing, Cutting, Sewing, Finishing, Packaging).' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeData rdf:type rdf:Property ;
    rdfs:label 'Qr Code Data' ;
    rdfs:comment 'The encoded data string from the QR code associated with this traceability record, enabling consumer-facing transparency and product authentication.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Document Number' ;
    rdfs:comment 'The shipping document, bill of lading, or delivery note number associated with the physical movement of material in this traceability event.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Certificate Reference' ;
    rdfs:comment 'The unique reference number of the transaction certificate (TC) issued by the certification body for this supply chain transaction, enabling verification of certified material transfer.' ;
    rdfs:domain ind:TraceabilityRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteReductionInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Waste Reduction Initiative Id' ;
    rdfs:comment 'Reference to a specific waste reduction or circular economy initiative that this waste record is associated with for program effectiveness tracking.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:disposalFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Location' ;
    rdfs:comment 'Geographic location (city, state, country) of the disposal or recovery facility for supply chain transparency and carbon footprint analysis.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Name' ;
    rdfs:comment 'Name of the final disposal, recycling, or recovery facility where the waste was processed.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used to dispose of or divert the waste material. Critical for calculating diversion rates and Zero Waste to Landfill compliance. [ENUM-REF-CANDIDATE: landfill|incineration|recycling|composting|reuse|donation|energy_recovery — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Date and time when the waste was finally disposed of or diverted through the specified disposal method.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:diversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percent' ;
    rdfs:comment 'Percentage of waste diverted from landfill through recycling, composting, reuse, or energy recovery. Key metric for Zero Waste to Landfill (ZWTL) programs.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousWasteManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Manifest Number' ;
    rdfs:comment 'Regulatory manifest or tracking number for hazardous waste shipments, required for compliance with environmental regulations.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueFromRecycling rdf:type rdf:Property ;
    rdfs:label 'Revenue From Recycling' ;
    rdfs:comment 'Revenue generated from selling recyclable waste materials (e.g., fabric scraps, metal, cardboard) to recycling partners. Supports circular economy business case.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the waste record was verified for accuracy and compliance, supporting audit trail requirements.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Volume of waste material in cubic meters, used for bulky or low-density waste where volume is a key operational metric.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waste Collection Timestamp' ;
    rdfs:comment 'Precise date and time when the waste was collected for disposal or diversion. Critical for operational tracking and compliance documentation.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wasteGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Date' ;
    rdfs:comment 'Date when the waste was generated at the facility or supply chain node. Used for temporal analysis and reporting period aggregation.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteHandlerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Handler License Number' ;
    rdfs:comment 'Regulatory license or permit number of the waste handler, required for hazardous waste tracking and compliance.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteHandlerName rdf:type rdf:Property ;
    rdfs:label 'Waste Handler Name' ;
    rdfs:comment 'Name of the third-party waste management company or handler responsible for collection and disposal.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteSourceProcess rdf:type rdf:Property ;
    rdfs:label 'Waste Source Process' ;
    rdfs:comment 'Business process or operational activity that generated the waste (e.g., cutting room operations, packaging line, quality control rejection, store operations).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Classification' ;
    rdfs:comment 'Regulatory classification of the waste stream indicating handling requirements and environmental risk level.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Transaction Number' ;
    rdfs:comment 'Business-readable unique identifier for the waste transaction event, used for tracking and audit purposes.' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Classification of the waste material generated. Includes fabric offcuts, packaging, chemical waste, e-waste, and general waste categories. [ENUM-REF-CANDIDATE: fabric_offcuts|packaging_material|chemical_waste|electronic_waste|general_waste|textile_waste|plastic_waste|cardboard|metal_scrap|organic_waste — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zwtlCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Zwtl Compliant Flag' ;
    rdfs:comment 'Indicates whether this waste transaction meets Zero Waste to Landfill compliance criteria (typically 90%+ diversion rate).' ;
    rdfs:domain ind:WasteRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method used to collect water usage data: automated meter reading, manual meter reading, estimation, or supplier-reported data.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Data Verification Status' ;
    rdfs:comment 'Verification status of the water usage data: verified internally, unverified, third-party audited, or pending verification.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDestinationType rdf:type rdf:Property ;
    rdfs:label 'Discharge Destination Type' ;
    rdfs:comment 'Destination to which wastewater is discharged: municipal sewer system, surface water body, groundwater, third-party treatment facility, or on-site treatment.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Precise date and time when the water usage measurement was recorded or meter reading was taken.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiration Date' ;
    rdfs:comment 'Expiration date of the regulatory permit for water usage and discharge.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Production Volume Units' ;
    rdfs:comment 'Total production volume at the facility during the reporting period, measured in units relevant to the facility type (e.g., garments produced, square meters of fabric processed).' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Number' ;
    rdfs:comment 'Government-issued permit or license number authorizing water withdrawal and wastewater discharge at the facility.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyAuditorName rdf:type rdf:Property ;
    rdfs:label 'Third Party Auditor Name' ;
    rdfs:comment 'Name of the third-party auditor or verification body that validated the water usage data, if applicable.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWaterIntakeVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Water Intake Volume M3' ;
    rdfs:comment 'Total volume of water withdrawn or consumed during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterDischargedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Wastewater Discharged Volume M3' ;
    rdfs:comment 'Volume of wastewater discharged from the facility during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastewaterTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Wastewater Treatment Method' ;
    rdfs:comment 'Method used to treat wastewater before discharge: primary, secondary, tertiary, biological, chemical, Zero Liquid Discharge (ZLD), or none. [ENUM-REF-CANDIDATE: primary|secondary|tertiary|biological|chemical|zld|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionPerUnitProduced rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Per Unit Produced' ;
    rdfs:comment 'Water intensity metric representing cubic meters of water consumed per unit of product manufactured during the reporting period.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityBodMgPerL rdf:type rdf:Property ;
    rdfs:label 'Water Quality Bod Mg Per L' ;
    rdfs:comment 'Biochemical Oxygen Demand (BOD) level of discharged wastewater, measured in milligrams per liter, indicating organic pollution level.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityCodMgPerL rdf:type rdf:Property ;
    rdfs:label 'Water Quality Cod Mg Per L' ;
    rdfs:comment 'Chemical Oxygen Demand (COD) level of discharged wastewater, measured in milligrams per liter, indicating chemical pollution level.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityPhLevel rdf:type rdf:Property ;
    rdfs:label 'Water Quality Ph Level' ;
    rdfs:comment 'pH level of discharged wastewater, indicating acidity or alkalinity on a scale of 0 to 14.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityTssMgPerL rdf:type rdf:Property ;
    rdfs:label 'Water Quality Tss Mg Per L' ;
    rdfs:comment 'Total Suspended Solids (TSS) concentration in discharged wastewater, measured in milligrams per liter.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterRecycledVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Water Recycled Volume M3' ;
    rdfs:comment 'Volume of water recycled or reused within the facility during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterReductionAchievedM3 rdf:type rdf:Property ;
    rdfs:label 'Water Reduction Achieved M3' ;
    rdfs:comment 'Actual volume of water reduction achieved by the facility during the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterReductionTargetM3 rdf:type rdf:Property ;
    rdfs:label 'Water Reduction Target M3' ;
    rdfs:comment 'Target volume of water reduction committed by the facility for the reporting period, measured in cubic meters.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Type of water source from which water was withdrawn: municipal supply, groundwater well, rainwater harvesting, surface water, recycled water, or desalinated water.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStewardshipCertification rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Certification' ;
    rdfs:comment 'Name of the water stewardship certification or standard achieved by the facility, if applicable (e.g., AWS Platinum, AWS Gold).' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStewardshipProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Water Stewardship Program Enrolled' ;
    rdfs:comment 'Indicates whether the facility is enrolled in a recognized water stewardship or conservation program (e.g., Alliance for Water Stewardship, CEO Water Mandate).' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterStressBasinClassification rdf:type rdf:Property ;
    rdfs:label 'Water Stress Basin Classification' ;
    rdfs:comment 'Water stress level of the basin where the facility is located, based on WRI Aqueduct classification: low, low-to-medium, medium-to-high, high, or extremely high.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zldCommitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Zld Commitment Status' ;
    rdfs:comment 'Status of the facility\'s commitment to Zero Liquid Discharge: committed, in progress, achieved, or not applicable.' ;
    rdfs:domain ind:WaterUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan selected by the employee. Links to the benefit plan catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:acaAffordabilitySafeHarbor rdf:type rdf:Property ;
    rdfs:label 'Aca Affordability Safe Harbor' ;
    rdfs:comment 'Safe harbor method used to determine ACA affordability for this enrollment. Employers can use federal poverty line, rate of pay, or W-2 wages to demonstrate that coverage offered meets affordability requirements and avoid employer shared responsibility penalties.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acaMinimumValueMetFlag rdf:type rdf:Property ;
    rdfs:label 'Aca Minimum Value Met Flag' ;
    rdfs:comment 'Indicates whether the benefit plan meets the ACA minimum value standard of covering at least 60% of the total allowed cost of benefits. Required for ACA compliance and Form 1095-C reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Premium Amount' ;
    rdfs:comment 'Total annual cost of the benefit plan for the selected coverage tier. Represents the combined employer and employee contribution before any cost-sharing splits.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierConfirmationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Confirmation Received Flag' ;
    rdfs:comment 'Indicates whether the benefit carrier has confirmed receipt and processing of the enrollment. Confirmation typically includes member ID assignment and coverage effective date validation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Member Number' ;
    rdfs:comment 'Unique member identifier assigned by the benefit carrier for this enrollment. Used for claims processing, provider verification, and member services. Differs from employee ID and is carrier-specific.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Notification Sent Date' ;
    rdfs:comment 'Date on which enrollment data was transmitted to the benefit carrier. Used to track carrier processing timelines and resolve coverage activation issues.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the enrollment information was transmitted to the benefit carrier for coverage activation. Typically sent via EDI 834 transaction for medical, dental, and vision plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraElectionDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Date' ;
    rdfs:comment 'Date on which the former employee or qualified beneficiary elected to continue coverage under COBRA. Must occur within 60 days of the later of the qualifying event date or the date the COBRA notice was provided.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Expiration Date' ;
    rdfs:comment 'Date on which COBRA continuation coverage ends. Typically 18 months after the qualifying event for termination or reduction in hours, 36 months for divorce or dependent loss of eligibility.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraQualifyingEvent rdf:type rdf:Property ;
    rdfs:label 'Cobra Qualifying Event' ;
    rdfs:comment 'Type of qualifying event that triggered COBRA continuation coverage eligibility. Termination of employment and reduction in hours are most common for employees; divorce and dependent aging out apply to dependents.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected by the employee, determining who is covered under the benefit plan. Employee only covers the individual, employee plus spouse covers two adults, employee plus children covers employee and dependents under 26, and employee plus family covers all eligible dependents.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of eligible dependents covered under this enrollment. Includes spouse, domestic partner, and children under age 26 as defined by ACA dependent coverage provisions.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Annual amount deducted from employee pay for benefit premium. Typically deducted pre-tax for qualified plans under Section 125. Used for payroll processing and W-2 reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeDiscountEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Discount Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for the Apparel Fashion employee discount program as part of their benefits package. Typically available to retail associates and corporate staff for purchasing company merchandise at reduced prices.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Employee Discount Percentage' ;
    rdfs:comment 'Percentage discount on company merchandise available to the employee. Varies by employee type and tenure. Retail associates typically receive 20-30% discount, corporate staff may receive higher tiers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Annual amount contributed by Apparel Fashion toward the employee benefit premium. Used for ACA affordability calculations and ERISA reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentConfirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Date' ;
    rdfs:comment 'Date on which the enrollment confirmation was sent to the employee via email or postal mail. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentConfirmationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Flag' ;
    rdfs:comment 'Indicates whether an enrollment confirmation notification was sent to the employee. Confirmation includes enrollment number, coverage details, premium amounts, and effective dates.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Channel or system through which the benefit enrollment was submitted. Employee self-service indicates online enrollment through Workday portal, HR representative indicates manual entry by HR staff, automated renewal applies to passive enrollments carried forward from prior year.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Classification of the enrollment event that triggered this benefit election. New hire enrollments occur within 30 days of hire date, open enrollment is the annual election period, qualifying life events include marriage/birth/divorce, and COBRA applies to continuation coverage after employment termination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1095cFurnishedDate rdf:type rdf:Property ;
    rdfs:label 'Form 1095c Furnished Date' ;
    rdfs:comment 'Date on which Form 1095-C was provided to the employee. Must be furnished by January 31st following the calendar year of coverage per IRS requirements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:form1095cGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Form 1095c Generated Flag' ;
    rdfs:comment 'Indicates whether IRS Form 1095-C has been generated for this enrollment record. Form 1095-C is required for ACA reporting to document that coverage was offered to the employee and dependents.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollDeductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Payroll Deduction Frequency' ;
    rdfs:comment 'Frequency at which employee benefit contributions are deducted from payroll. Aligns with the company payroll schedule for retail associates, corporate staff, and distribution center teams.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perPayPeriodDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Per Pay Period Deduction Amount' ;
    rdfs:comment 'Employee contribution amount deducted each pay period. Calculated by dividing annual employee contribution by number of pay periods per year based on payroll deduction frequency.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year for which this benefit enrollment is effective. Typically aligns with open enrollment periods and ACA reporting requirements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingLifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Date' ;
    rdfs:comment 'Date on which the qualifying life event occurred. Used to determine the 30-day election window and coverage effective date for mid-year changes.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingLifeEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Type' ;
    rdfs:comment 'Type of qualifying life event that triggered a mid-year enrollment change outside of open enrollment. QLE allows employees to modify benefit elections within 30 days of the event as permitted by HIPAA special enrollment rights. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death|loss_of_coverage|employment_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingDate rdf:type rdf:Property ;
    rdfs:label 'Vesting Date' ;
    rdfs:comment 'Date on which the employee becomes fully vested in employer contributions. Typically after 3-5 years of service depending on the plan vesting schedule (cliff or graded).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vestingPercentage rdf:type rdf:Property ;
    rdfs:label 'Vesting Percentage' ;
    rdfs:comment 'Percentage of employer contributions that the employee is entitled to retain upon termination. Applicable to retirement plans such as 401k with employer match. Increases based on years of service per the plan vesting schedule.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Reason provided by employee for declining benefit coverage. Required for ACA reporting to demonstrate that coverage was offered but declined. Spouse coverage and other employer coverage are most common reasons. [ENUM-REF-CANDIDATE: spouse_coverage|other_employer_coverage|medicare|medicaid|tricare|cost|not_needed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverSignedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Signed Date' ;
    rdfs:comment 'Date on which the employee signed the benefit waiver form. Required documentation for ACA compliance to prove that coverage was offered and voluntarily declined.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Unique identifier for the compensation plan record. Primary key.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Compensation plans are structured around job profiles. The compensation_plan has job_code which should be normalized to job_profile_id FK. Job profile defines pay grade, competency requirements, and c' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:annualReviewMonth rdf:type rdf:Property ;
    rdfs:label 'Annual Review Month' ;
    rdfs:comment 'Month (1-12) in which the employees annual compensation review is scheduled under this plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basePayAmount rdf:type rdf:Property ;
    rdfs:label 'Base Pay Amount' ;
    rdfs:comment 'The base compensation amount for the employee under this plan. For salaried employees, this is annual salary; for hourly employees, this is hourly rate.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for performance or discretionary bonuses under this compensation plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Bonus Target Percentage' ;
    rdfs:comment 'Target bonus as a percentage of base pay. For example, 15.00 represents a 15% target bonus.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compaRatio rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio' ;
    rdfs:comment 'Comparative ratio expressing the employees base pay as a percentage of the midpoint for their pay grade. Used for pay equity analysis. For example, 95.00 means the employee earns 95% of the grade midpoint.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Status' ;
    rdfs:comment 'Current lifecycle status of the compensation plan (active, inactive, pending approval, suspended, expired).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityGrantAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Amount' ;
    rdfs:comment 'Monetary value or number of equity units granted to the employee under this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityGrantEligible rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for equity compensation (stock options, restricted stock units, or other equity instruments) under this plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification of the employee under the Fair Labor Standards Act: exempt (not eligible for overtime) or non-exempt (eligible for overtime).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligible rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for merit-based salary increases under this compensation plan.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for overtime pay under labor regulations (typically applies to non-exempt hourly employees).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which the employee is paid under this plan (weekly, biweekly, semimonthly, monthly, quarterly, annual).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Pay grade or band assigned to this compensation plan, used for internal equity and compensation benchmarking (e.g., Grade 5, Band C, Level 3).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Maximum' ;
    rdfs:comment 'Maximum compensation amount for the pay grade or band associated with this plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMidpoint rdf:type rdf:Property ;
    rdfs:label 'Pay Range Midpoint' ;
    rdfs:comment 'Midpoint compensation amount for the pay grade or band associated with this plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Pay Range Minimum' ;
    rdfs:comment 'Minimum compensation amount for the pay grade or band associated with this plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the employee. Used for age verification, benefits eligibility, and compliance reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eeoClassification rdf:type rdf:Property ;
    rdfs:label 'Eeo Classification' ;
    rdfs:comment 'EEO-1 job category classification for regulatory reporting (e.g., Executive/Senior Officials, Professionals, Sales Workers, Service Workers). Used for diversity and compliance reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee record. Active employees are on payroll and eligible for work assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the employee. Nullable.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in USA, National Insurance Number in UK). Used for tax reporting and payroll.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payCurrency rdf:type rdf:Property ;
    rdfs:label 'Pay Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for employee compensation (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'Current base pay rate for the employee. Represents hourly rate for hourly employees or annual salary for salaried employees. Currency determined by work location.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Compensation structure for the employee. Determines payroll calculation method and time tracking requirements.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review. Used for tracking review cycles and next review scheduling.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehireEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire based on termination circumstances and performance history.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Identifier for the labor union to which the employee belongs. Nullable for non-union employees.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Union Member Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. Determines applicable collective bargaining agreements and labor rules.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Expiry Date' ;
    rdfs:comment 'Expiration date of work authorization (e.g., visa expiry). Nullable for citizens and permanent residents. Used for compliance monitoring and renewal alerts.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Legal authorization status for the employee to work in the jurisdiction. Used for I-9 compliance and visa tracking.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Unique identifier for the employees primary work location (store number, office code, or distribution center ID).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Category of primary work location. Determines applicable labor policies, scheduling systems, and operational workflows.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayEmployeeCode rdf:type rdf:Property ;
    rdfs:label 'Workday Employee Code' ;
    rdfs:comment 'External employee identifier from Workday HCM system. Business key for integration with source HR system.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether positions in this job profile are eligible for performance-based bonus compensation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:careerPathProgression rdf:type rdf:Property ;
    rdfs:label 'Career Path Progression' ;
    rdfs:comment 'Typical next-level job profiles in the career progression path. Used for succession planning and employee development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Certifications Required' ;
    rdfs:comment 'Professional certifications or licenses required or preferred for this job profile. Examples include CPA, PHR, PMP, or industry-specific certifications.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether positions in this job profile are eligible for commission-based compensation, common in retail and wholesale sales roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Competency Requirements' ;
    rdfs:comment 'Detailed list of competencies required for this job profile including behavioral, technical, and leadership competencies. Used for talent assessment and development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Role Flag' ;
    rdfs:comment 'Indicates whether this job profile is designated as business-critical requiring succession planning and talent pipeline development.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum education level required for this job profile. Used for candidate screening and talent acquisition. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional_certification|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under the Fair Labor Standards Act determining overtime eligibility. Exempt employees are not eligible for overtime pay; non-exempt employees are eligible.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational category grouping similar roles together for career pathing and compensation planning in apparel fashion business. [ENUM-REF-CANDIDATE: retail_operations|merchandising|design|supply_chain|corporate|distribution|e_commerce|marketing|finance|human_resources|information_technology|legal|customer_service — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the job profile within the organization indicating seniority and scope of responsibility. [ENUM-REF-CANDIDATE: entry|intermediate|senior|lead|manager|senior_manager|director|senior_director|vice_president|senior_vice_president|executive — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile indicating whether it is available for position creation and hiring.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLevel rdf:type rdf:Property ;
    rdfs:label 'Management Level' ;
    rdfs:comment 'Indicates whether this job profile includes people management responsibilities and at what level.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Physical demands and requirements of the job including lifting, standing, mobility, and environmental conditions. Required for ADA compliance and workplace safety.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Business identifier code for the job profile used across HR systems and organizational documentation. Externally-known unique code.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Comprehensive description of the job profile including purpose, scope, and key responsibilities.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Role Flag' ;
    rdfs:comment 'Indicates whether this job profile is used for seasonal workforce planning, common in retail store operations during peak periods.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillRequirements rdf:type rdf:Property ;
    rdfs:label 'Skill Requirements' ;
    rdfs:comment 'Specific skills required for successful performance in this job profile including technical skills, software proficiency, and domain expertise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spanOfControlMax rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Max' ;
    rdfs:comment 'Maximum number of direct reports typically managed by positions in this job profile. Used for organizational planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spanOfControlMin rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Min' ;
    rdfs:comment 'Minimum number of direct reports typically managed by positions in this job profile. Null for individual contributor roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Stock Eligible Flag' ;
    rdfs:comment 'Indicates whether positions in this job profile are eligible for equity compensation such as stock options or restricted stock units.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryOrganization rdf:type rdf:Property ;
    rdfs:label 'Supervisory Organization' ;
    rdfs:comment 'Default supervisory organization or department where positions from this job profile typically reside in the organizational hierarchy.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of time spent traveling for business purposes. Used for candidate expectations and expense planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Union Eligible Flag' ;
    rdfs:comment 'Indicates whether positions created from this job profile are eligible for union membership or collective bargaining representation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Years Experience Required' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this job profile. Used for candidate qualification.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborComplianceEventId rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Event Id' ;
    rdfs:comment 'Unique identifier for the labor compliance event record.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Location Org Unit Id' ;
    rdfs:comment 'Identifier of the facility, store, distribution center, or corporate office where the compliance event occurred.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryLaborEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Employee Id' ;
    rdfs:comment 'Identifier of the employee affected by or involved in the compliance event.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLaborRemediationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Labor Remediation Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee or compliance officer assigned to own and execute the remediation action.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLaborManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Labor Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor responsible for the affected employee or location at the time of the event.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'External reference number or identifier from FLA, WRAP, or other third-party audit reports linking this event to a formal audit finding.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Source or method by which the compliance event was detected (e.g., automated system alert, manager report, employee complaint, audit finding). [ENUM-REF-CANDIDATE: system_automated|manager_report|employee_report|internal_audit|external_audit|whistleblower|regulatory_inspection — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the compliance event was formally reported or filed with the applicable regulatory authority. Null if no filing is required or filing is pending.' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this compliance event requires formal reporting or filing with a regulatory body (e.g., FTC, OSHA, state labor department).' ;
    rdfs:domain ind:LaborComplianceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:learningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Learning Enrollment Id' ;
    rdfs:comment 'Unique identifier for the learning enrollment record. Primary key for the learning enrollment entity.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseId rdf:type rdf:Property ;
    rdfs:label 'Course Id' ;
    rdfs:comment 'Unique identifier of the training course or learning program. Links to the course catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Course .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved by the employee on the course assessment or exam, typically expressed as a percentage (0.00 to 100.00). Null if the course does not include an assessment or if not yet taken.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'Number of times the employee has attempted the course assessment. Used to track retakes and learning effectiveness.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the employee successfully completed the training course. Null if the course is in progress or not completed.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the training is delivered: instructor_led (in-person classroom), e_learning (online self-paced), blended (combination of methods), on_the_job (hands-on training), virtual_classroom (live online session), or self_paced (asynchronous learning).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the employee regarding their training experience. Used for qualitative assessment of training effectiveness and continuous improvement.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Employee\'s satisfaction rating for the training course, typically on a scale of 1.00 to 5.00. Used to measure training effectiveness and quality. Null if feedback has not been provided.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Full name of the instructor or facilitator who delivered the training course. Null for self-paced or e-learning courses without a designated instructor.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the course assessment, expressed as a percentage (e.g., 80.00 for 80%). Used to determine completion status.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Interval Months' ;
    rdfs:comment 'Number of months between required recertification cycles (e.g., 12 for annual recertification, 24 for biennial). Null if recertification is not required.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the employee must retake the course periodically to maintain certification or compliance. True if recertification is required, False otherwise.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date by which the employee is expected to complete the training course. Used for tracking compliance deadlines and learning plan milestones.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when the employee is expected to begin the training course. May differ from enrollment date for future-scheduled courses.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., Corporate HQ - Conference Room A, Distribution Center - Training Room, Online Platform, Store #1234). Null for fully self-paced online courses.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Flag' ;
    rdfs:comment 'Indicates whether the employee is currently on a waitlist for the course due to capacity constraints. True if waitlisted, False if actively enrolled.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request record. Primary key.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified the leave request record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveCoverageAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Coverage Assigned To Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to cover the absent employees responsibilities during the leave period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workLocationOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Work Location Org Unit Id' ;
    rdfs:comment 'Identifier of the employees primary work location (store, distribution center, or corporate office) at the time of the leave request.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when the employee returned to work, which may differ from the scheduled return date due to extensions or early returns.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Manager notes or comments provided during the approval or denial decision.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsContinuationFlag rdf:type rdf:Property ;
    rdfs:label 'Benefits Continuation Flag' ;
    rdfs:comment 'Indicates whether employee benefits (health insurance, retirement contributions) continue during the leave period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Due Date' ;
    rdfs:comment 'Deadline by which the employee must submit required medical certification documentation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveragePlanRequired rdf:type rdf:Property ;
    rdfs:label 'Coverage Plan Required' ;
    rdfs:comment 'Indicates whether a staffing coverage plan is required for this leave, typically for extended absences or critical roles.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by the manager when a leave request is denied, including business justification.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Fmla Case Number' ;
    rdfs:comment 'Unique case identifier for FMLA-qualifying leave requests, used for compliance tracking and reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Fmla Hours Used' ;
    rdfs:comment 'Total FMLA hours consumed by this leave request, counted against the employees annual 480-hour FMLA entitlement.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intermittentFrequency rdf:type rdf:Property ;
    rdfs:label 'Intermittent Frequency' ;
    rdfs:comment 'Expected frequency pattern for intermittent leave, such as weekly, bi-weekly, or as-needed.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFmlaQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Fmla Qualifying' ;
    rdfs:comment 'Indicates whether the leave request qualifies for FMLA protection under federal law.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntermittent rdf:type rdf:Property ;
    rdfs:label 'Is Intermittent' ;
    rdfs:comment 'Indicates whether the leave is intermittent (taken in separate blocks of time) rather than continuous.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaidLeave rdf:type rdf:Property ;
    rdfs:label 'Is Paid Leave' ;
    rdfs:comment 'Indicates whether the leave request is for paid time off (True) or unpaid leave (False).' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalEmployee rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Employee' ;
    rdfs:comment 'Indicates whether the employee is classified as seasonal at the time of the leave request, impacting leave eligibility and staffing planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'Remaining leave balance (in hours) for the applicable leave type after this request was approved and processed.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'Available leave balance (in hours) for the applicable leave type before this request was processed.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Detailed classification within the leave type, such as Continuous FMLA, Intermittent FMLA, Personal PTO, Vacation PTO, or Medical Sick Leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave requested: PTO (Paid Time Off), FMLA (Family and Medical Leave Act), Maternity, Paternity, Bereavement, Unpaid, or Sick leave. [ENUM-REF-CANDIDATE: PTO|FMLA|Maternity|Paternity|Bereavement|Unpaid|Sick — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificationReceived rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received' ;
    rdfs:comment 'Indicates whether required medical certification has been received and validated by HR.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required' ;
    rdfs:comment 'Indicates whether medical certification documentation is required to support the leave request.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Impact Flag' ;
    rdfs:comment 'Indicates whether this leave request impacts payroll processing, requiring adjustments to regular pay, benefits, or deductions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Scheduled date when the employee is expected to return to work following the leave period.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDaysRequested rdf:type rdf:Property ;
    rdfs:label 'Total Days Requested' ;
    rdfs:comment 'Total number of leave days requested, including partial days for intermittent leave. Calculated as business days between start and end dates.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursRequested rdf:type rdf:Property ;
    rdfs:label 'Total Hours Requested' ;
    rdfs:comment 'Total number of leave hours requested, used for hourly employees and intermittent leave tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables hierarchical roll-up for workforce reporting and labor cost allocation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:glSegment rdf:type rdf:Property ;
    rdfs:label 'Gl Segment' ;
    rdfs:comment 'General ledger segment code for financial reporting and consolidation. Used for EBITDA and P&L roll-up.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full hierarchical path from root to this unit (e.g., \'/CORP/RETAIL/NORAM/STORE001\'). Supports recursive queries and reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this organizational unit operates on a seasonal basis (e.g., pop-up stores, seasonal distribution centers). Supports seasonal workforce planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborUnionCode rdf:type rdf:Property ;
    rdfs:label 'Labor Union Code' ;
    rdfs:comment 'Labor union or collective bargaining agreement code applicable to this organizational unit. Supports labor compliance and FLA reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed business description of the organizational unit\'s purpose, scope, and operational responsibilities.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Indicates operational state and availability for workforce assignment.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Required' ;
    rdfs:comment 'Indicates whether this organizational unit is subject to SLA compliance requirements for operational performance tracking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit. Used for external reporting and system integration.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., \'North America Retail Operations\', \'Distribution Center East\', \'Corporate Marketing\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit type. Determines reporting structure and operational characteristics. [ENUM-REF-CANDIDATE: store|distribution_center|corporate|regional|division|department|cost_center|business_unit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'User ID of the payroll manager or authorized approver who approved this payroll run for processing.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costCenterAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Center Allocation Method' ;
    rdfs:comment 'Method used to allocate labor costs to cost centers: single (all to one cost center), proportional (split by percentage), time-based (by hours worked per cost center), or project-based (by project assignment).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Status' ;
    rdfs:comment 'Status of general ledger posting for this payroll run: pending (not yet posted), posted (successfully recorded in GL), reversed (posting reversed due to correction), or error (posting failed).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isYearEndAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Year End Adjustment' ;
    rdfs:comment 'Boolean flag indicating whether this payroll run includes year-end adjustments for W-2 reconciliation, tax corrections, or annual bonus payouts.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payGroupCode rdf:type rdf:Property ;
    rdfs:label 'Pay Group Code' ;
    rdfs:comment 'Code identifying the pay group or payroll calendar group (e.g., RETAIL_HOURLY, CORP_SALARY, DC_HOURLY). Used to segment employees by payment schedule and processing rules.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'Last day of the pay period covered by this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'First day of the pay period covered by this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentBatchCode rdf:type rdf:Property ;
    rdfs:label 'Payment Batch Code' ;
    rdfs:comment 'Identifier for the payment batch or ACH (Automated Clearing House) file generated for this payroll run. Used to track payment processing through banking systems.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Number' ;
    rdfs:comment 'Business-facing unique identifier for the payroll run, typically formatted as PR-YYYYMMDD-XXX or similar pattern used in Workday HCM.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollType rdf:type rdf:Property ;
    rdfs:label 'Payroll Type' ;
    rdfs:comment 'Type of payroll run: regular (scheduled bi-weekly or monthly), off-cycle (unscheduled), bonus (annual or quarterly bonuses), commission (sales commissions), adjustment (corrections), or final (termination payouts).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Date and time when this payroll run was processed and finalized in Workday HCM.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the payroll run: draft (being prepared), calculated (amounts computed), approved (manager approved), submitted (sent to payment processor), processed (payments initiated), paid (funds disbursed), cancelled (voided before payment), or reversed (corrected after payment). [ENUM-REF-CANDIDATE: draft|calculated|approved|submitted|processed|paid|cancelled|reversed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Count' ;
    rdfs:comment 'Number of distinct tax jurisdictions (federal, state, local) represented in this payroll run. Critical for multi-state tax compliance for retail associates.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Total Employee Count' ;
    rdfs:comment 'Total number of employees included in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEmployeeTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Employee Tax Amount' ;
    rdfs:comment 'Total employee-paid payroll taxes withheld in this run, including federal income tax, state income tax, local tax, employee portion of FICA, and other mandatory withholdings.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Employer Tax Amount' ;
    rdfs:comment 'Total employer-paid payroll taxes for this run, including employer portion of FICA (Federal Insurance Contributions Act), FUTA (Federal Unemployment Tax Act), SUTA (State Unemployment Tax Act), and other employer tax obligations.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay Amount' ;
    rdfs:comment 'Total gross pay amount for all employees in this payroll run before any deductions. Includes base salary, overtime, bonuses, commissions, and other earnings.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPayAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay Amount' ;
    rdfs:comment 'Total net pay amount for all employees in this payroll run after all deductions. This is the total amount disbursed to employees.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Overtime Hours' ;
    rdfs:comment 'Total overtime hours across all hourly employees in this payroll run. Overtime is typically hours worked beyond 40 hours per week.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPostTaxDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Post Tax Deduction Amount' ;
    rdfs:comment 'Total post-tax deductions for all employees in this run, including garnishments, union dues, charitable contributions, and Roth 401(k) contributions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPreTaxDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Pre Tax Deduction Amount' ;
    rdfs:comment 'Total pre-tax deductions for all employees in this run, including 401(k) contributions, health insurance premiums, FSA (Flexible Spending Account) contributions, and HSA (Health Savings Account) contributions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPtoHours rdf:type rdf:Property ;
    rdfs:label 'Total Pto Hours' ;
    rdfs:comment 'Total paid time off hours paid out in this payroll run, including vacation, sick leave, and personal days.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegularHours rdf:type rdf:Property ;
    rdfs:label 'Total Regular Hours' ;
    rdfs:comment 'Total regular work hours across all hourly employees in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2TaxYear rdf:type rdf:Property ;
    rdfs:label 'W2 Tax Year' ;
    rdfs:comment 'Calendar year for which this payroll run contributes to W-2 (Wage and Tax Statement) reporting. Typically the year of the pay period end date.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review or disciplinary action record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed or subject to disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPerformanceHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Performance Hr Business Partner Employee Id' ;
    rdfs:comment 'Identifier of the HR Business Partner who reviewed and validated the performance review or disciplinary action for compliance and fairness.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPerformanceReviewingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Performance Reviewing Manager Employee Id' ;
    rdfs:comment 'Identifier of the second-level manager or reviewer who approved the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the employee filed an appeal or grievance regarding the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Outcome of the employee appeal or grievance process, if applicable.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationSessionDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Date' ;
    rdfs:comment 'Date of the talent calibration session where this performance review was discussed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationSessionFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Flag' ;
    rdfs:comment 'Indicates whether this performance review was discussed and calibrated in a talent calibration session to ensure rating consistency across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyCommunicationRating rdf:type rdf:Property ;
    rdfs:label 'Competency Communication Rating' ;
    rdfs:comment 'Rating for communication skills competency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLeadershipRating rdf:type rdf:Property ;
    rdfs:label 'Competency Leadership Rating' ;
    rdfs:comment 'Rating for leadership competency. Applicable to managers and supervisors.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyTeamworkRating rdf:type rdf:Property ;
    rdfs:label 'Competency Teamwork Rating' ;
    rdfs:comment 'Rating for teamwork and collaboration competency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyTechnicalRating rdf:type rdf:Property ;
    rdfs:label 'Competency Technical Rating' ;
    rdfs:comment 'Rating for technical or job-specific skills competency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanActions rdf:type rdf:Property ;
    rdfs:label 'Development Plan Actions' ;
    rdfs:comment 'Summary of development plan actions, training recommendations, or improvement areas identified during the review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the full performance review or disciplinary action document stored in the document management system.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date the employee acknowledged the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Status' ;
    rdfs:comment 'Status indicating whether the employee has acknowledged receipt and review of the performance review or disciplinary document.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Comments or feedback provided by the employee in response to the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Timestamp when the performance review or disciplinary action was finalized and locked from further edits.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goalAchievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Percentage' ;
    rdfs:comment 'Percentage of performance goals or OKRs (Objectives and Key Results) / KPIs (Key Performance Indicators) achieved during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether this performance review or disciplinary action requires legal review for compliance and risk mitigation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meritIncreaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for a merit increase based on this performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating, typically on a scale (e.g., 1.0 to 5.0). Supports merit increase calculations and calibration.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipEndDate rdf:type rdf:Property ;
    rdfs:label 'Pip End Date' ;
    rdfs:comment 'End date of the Performance Improvement Plan, if applicable for this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipOutcome rdf:type rdf:Property ;
    rdfs:label 'Pip Outcome' ;
    rdfs:comment 'Outcome of the Performance Improvement Plan: successful completion, unsuccessful (leading to further action), or in progress.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Start date of the Performance Improvement Plan, if applicable for this review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyViolated rdf:type rdf:Property ;
    rdfs:label 'Policy Violated' ;
    rdfs:comment 'Name or code of the company policy violated, applicable for disciplinary actions. Null for performance reviews.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period being assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Recommended Flag' ;
    rdfs:comment 'Indicates whether termination is recommended as a result of this performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique identifier for the authorized headcount position within the organization. Primary key.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Reference to the department or cost center to which this position is assigned for budgeting and organizational reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:incumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incumbent Employee Id' ;
    rdfs:comment 'Reference to the employee currently occupying this position. Null if the position is vacant.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supervisorPositionId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Position Id' ;
    rdfs:comment 'Reference to the position that this position reports to in the organizational hierarchy. Null for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:talentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Talent Requisition Id' ;
    rdfs:comment 'Reference to the active job requisition for this position if it is currently vacant and approved for hiring. Null if position is filled or not approved for recruitment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentRequisition .

ind:annualSalaryMax rdf:type rdf:Property ;
    rdfs:label 'Annual Salary Max' ;
    rdfs:comment 'Maximum annual salary for the position based on the assigned pay grade. Used for compensation planning and budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSalaryMin rdf:type rdf:Property ;
    rdfs:label 'Annual Salary Min' ;
    rdfs:comment 'Minimum annual salary for the position based on the assigned pay grade. Used for compensation planning and budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleForBonus rdf:type rdf:Property ;
    rdfs:label 'Eligible For Bonus' ;
    rdfs:comment 'Indicates whether the position is eligible for annual performance bonuses or incentive compensation. True if eligible; False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForCommission rdf:type rdf:Property ;
    rdfs:label 'Eligible For Commission' ;
    rdfs:comment 'Indicates whether the position is eligible for sales commission or variable pay based on performance metrics. True if eligible; False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for the position. 1.0000 represents a full-time position; values less than 1.0 represent part-time positions (e.g., 0.5000 for half-time).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalPosition rdf:type rdf:Property ;
    rdfs:label 'Is Critical Position' ;
    rdfs:comment 'Indicates whether this position is designated as business-critical, requiring priority succession planning and talent development. True for critical positions; False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFilled rdf:type rdf:Property ;
    rdfs:label 'Is Filled' ;
    rdfs:comment 'Indicates whether the position is currently occupied by an employee. True if filled; False if vacant.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for the position as defined in the job profile.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for the position.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business-assigned unique code for the position, used for external reporting and integration with payroll and HR systems.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position responsibilities, key accountabilities, and scope of work. Used for job postings and performance management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active positions are available for hiring; Frozen positions are temporarily on hold; Eliminated positions have been removed from the headcount plan; Pending Approval positions are awaiting budget authorization.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Employment type classification for the position. Regular positions are permanent; Temporary positions have a defined end date; Contract positions are filled by external contractors; Intern positions are for student or graduate programs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for remote or hybrid work arrangements. True if remote work is permitted; False if the position requires on-site presence.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'End date for seasonal positions, indicating when the position is typically eliminated each year. Null for non-seasonal positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'Start date for seasonal positions, indicating when the position becomes active each year. Null for non-seasonal positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Expected number of working hours per week for the position. Typically 40.00 for full-time positions; varies for part-time positions based on FTE allocation.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Pct' ;
    rdfs:comment 'Expected percentage of time the position requires business travel. 0.00 for no travel; values up to 100.00 for positions requiring extensive travel.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workShift rdf:type rdf:Property ;
    rdfs:label 'Work Shift' ;
    rdfs:comment 'Primary work shift assigned to the position, relevant for retail store associates and distribution center teams.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment Id' ;
    rdfs:comment 'Unique identifier for the shift assignment record. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftAssignment .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to this shift. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Identifier of the job role or position the employee is performing during this shift (e.g., sales associate, cashier, warehouse picker).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:shiftSwapRequestId rdf:type rdf:Property ;
    rdfs:label 'Shift Swap Request Id' ;
    rdfs:comment 'Identifier of the shift swap or trade request if this shift was reassigned through an employee-initiated swap process. Used for tracking shift flexibility programs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSwapRequest .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the employee clocked out or completed the shift. Captured from Point of Sale (POS) or time and attendance systems.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the employee clocked in or began the shift. Captured from Point of Sale (POS) or time and attendance systems.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Attendance outcome for this shift indicating whether the employee was present, absent, late, left early, or was a no-call no-show. Used for attendance tracking and performance management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this shift assignment resulted in a labor compliance violation (e.g., insufficient rest period, excessive hours, minor labor law breach). Used for compliance monitoring.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceViolationType rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Type' ;
    rdfs:comment 'Type of labor compliance violation associated with this shift, if any (insufficient rest period, maximum hours exceeded, minor labor law violation, predictive scheduling violation, other).' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyDepartureMinutes rdf:type rdf:Property ;
    rdfs:label 'Early Departure Minutes' ;
    rdfs:comment 'Number of minutes the employee left before the scheduled shift end time. Used for attendance policy enforcement.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHolidayShift rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Shift' ;
    rdfs:comment 'Boolean flag indicating whether this shift falls on a recognized company holiday, which may trigger premium pay rates.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertimeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the employee is eligible for overtime pay during this shift based on employment classification (non-exempt vs exempt).' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalWorker rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Worker' ;
    rdfs:comment 'Boolean flag indicating whether the employee assigned to this shift is classified as a seasonal or temporary worker. Used for workforce planning and compliance reporting.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborStandardHours rdf:type rdf:Property ;
    rdfs:label 'Labor Standard Hours' ;
    rdfs:comment 'Standard or expected hours for this type of shift based on labor planning models. Used for productivity analysis and variance reporting.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Date and time when this shift assignment record was last updated. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payCode rdf:type rdf:Property ;
    rdfs:label 'Pay Code' ;
    rdfs:comment 'Pay classification code for this shift indicating the type of compensation (regular, overtime, holiday pay, sick pay, vacation pay, double-time, premium pay). Used for payroll processing. [ENUM-REF-CANDIDATE: regular|overtime|holiday|sick_pay|vacation_pay|double_time|premium — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCreatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Schedule Created Datetime' ;
    rdfs:comment 'Date and time when this shift assignment was originally created in the scheduling system. Used for audit and compliance tracking.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulePublishedDatetime rdf:type rdf:Property ;
    rdfs:label 'Schedule Published Datetime' ;
    rdfs:comment 'Date and time when this shift assignment was published and communicated to the employee. Used for compliance with predictive scheduling laws.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time when the employee is scheduled to complete the shift. Used for labor planning and scheduling compliance.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned date and time when the employee is scheduled to begin the shift. Used for labor planning and scheduling compliance.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftNotes rdf:type rdf:Property ;
    rdfs:label 'Shift Notes' ;
    rdfs:comment 'Free-text notes or comments about the shift, such as special instructions, incidents, or performance observations. Used for operational communication.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tardinessMinutes rdf:type rdf:Property ;
    rdfs:label 'Tardiness Minutes' ;
    rdfs:comment 'Number of minutes the employee was late for the scheduled shift start time. Used for attendance policy enforcement.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeClockDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Time Clock Device Code' ;
    rdfs:comment 'Identifier of the physical or digital time clock device used by the employee to clock in and out for this shift. Used for audit and fraud prevention.' ;
    rdfs:domain ind:ShiftAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingModelId rdf:type rdf:Property ;
    rdfs:label 'Staffing Model Id' ;
    rdfs:comment 'Unique identifier for the staffing model record. Primary key for workforce planning and headcount budgeting scenarios.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetPeriodId rdf:type rdf:Property ;
    rdfs:label 'Budget Period Id' ;
    rdfs:comment 'Reference to the financial planning period (fiscal year, quarter, month) for which this staffing model is defined.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPeriod .

ind:jobFamilyId rdf:type rdf:Property ;
    rdfs:label 'Job Family Id' ;
    rdfs:comment 'Reference to the job family classification (retail associate, warehouse operator, merchandiser, designer, etc.) covered by this staffing model.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobFamily .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Current or realized number of employees or FTE in this role and organizational unit, used for variance analysis against target.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the executive, manager, or committee who approved this staffing model (e.g., \'VP Retail Operations\', \'CFO\', \'Workforce Planning Committee\').' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRatio rdf:type rdf:Property ;
    rdfs:label 'Coverage Ratio' ;
    rdfs:comment 'Ratio of planned staff to workload drivers (e.g., employees per 1000 square feet of retail space, warehouse staff per 10,000 units shipped), supporting capacity-based staffing models.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountVariance rdf:type rdf:Property ;
    rdfs:label 'Headcount Variance' ;
    rdfs:comment 'Difference between actual and target headcount (actual minus target), indicating over-staffing (positive) or under-staffing (negative).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Amount' ;
    rdfs:comment 'Total financial budget allocated for labor costs (wages, benefits, payroll taxes) for this staffing model scenario, supporting financial workforce plan integration.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the labor budget amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Business-friendly name for the staffing model scenario (e.g., \'FY2024 Holiday Retail Ramp\', \'Q2 DC Expansion Plan\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the staffing model scenario: baseline (steady-state), seasonal (recurring pattern), expansion (growth initiative), reduction (cost optimization), peak_period (holiday/back-to-school surge), special_event (store opening, promotional event).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbHeadcountBudget rdf:type rdf:Property ;
    rdfs:label 'Otb Headcount Budget' ;
    rdfs:comment 'Remaining authorized headcount capacity available for hiring within this model, analogous to Open-to-Buy inventory budget. Calculated as target_headcount minus committed hires.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakEndDate rdf:type rdf:Property ;
    rdfs:label 'Peak End Date' ;
    rdfs:comment 'Date when peak period concludes and staffing wind-down begins (e.g., end of holiday returns period).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakPeriodMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Period Multiplier' ;
    rdfs:comment 'Additional multiplier for short-duration peak periods (Black Friday, Cyber Monday, back-to-school week) requiring temporary surge staffing beyond seasonal baseline.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakStartDate rdf:type rdf:Property ;
    rdfs:label 'Peak Start Date' ;
    rdfs:comment 'Date when peak staffing levels must be achieved (e.g., first day of holiday shopping season).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'Name of the broader workforce planning scenario or initiative this model supports (e.g., \'FY2024 Store Expansion\', \'Omnichannel Transformation\', \'Cost Optimization Initiative\').' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampEndDate rdf:type rdf:Property ;
    rdfs:label 'Ramp End Date' ;
    rdfs:comment 'Date when staffing returns to baseline levels after seasonal wind-down is complete.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rampStartDate rdf:type rdf:Property ;
    rdfs:label 'Ramp Start Date' ;
    rdfs:comment 'Date when seasonal or peak-period staffing ramp-up begins (e.g., pre-holiday hiring start date).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetHeadcount rdf:type rdf:Property ;
    rdfs:label 'Target Headcount' ;
    rdfs:comment 'Planned number of employees or Full-Time Equivalents (FTE) for this role and organizational unit during the budget period.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Target Hours Per Week' ;
    rdfs:comment 'Planned average weekly hours per employee for this role, supporting part-time, full-time, and variable-hour workforce planning.' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceSegment rdf:type rdf:Property ;
    rdfs:label 'Workforce Segment' ;
    rdfs:comment 'Employment classification for the workforce covered by this model: full_time (permanent FT), part_time (permanent PT), seasonal (recurring temporary), temporary (non-recurring), contractor (external), intern (student/trainee).' ;
    rdfs:domain ind:StaffingModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTalentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Talent Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for approving the requisition and making the final hiring decision.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryTalentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Talent Approved By Employee Id' ;
    rdfs:comment 'Reference to the final approver who authorized the requisition to be opened for recruiting.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTalentReplacementForEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Talent Replacement For Employee Id' ;
    rdfs:comment 'Reference to the employee being replaced, if this is a replacement requisition. Used to track turnover and succession planning.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'The current step or status in the multi-level approval workflow (e.g., Pending Hiring Manager, Pending HR, Pending Finance, Approved). Tracks requisition through approval chain.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'The number of positions approved for hire under this requisition. Typically 1 for individual roles, may be greater for high-volume retail associate hiring.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'The compensation or pay grade assigned to this position, which determines the salary range and benefits eligibility.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityInitiativeFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Initiative Flag' ;
    rdfs:comment 'Indicates whether this requisition is part of a diversity and inclusion hiring initiative. Used for diversity pipeline tracking and reporting.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for remote or work-from-home arrangements. True: remote work allowed; False: on-site work required.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed description of the role, including responsibilities, qualifications, required skills, and working conditions. Used in job postings and candidate communications.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPostingTitle rdf:type rdf:Property ;
    rdfs:label 'Job Posting Title' ;
    rdfs:comment 'The external-facing job title used in job postings and advertisements. May differ from the internal job title for marketing or branding purposes.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionsFilled rdf:type rdf:Property ;
    rdfs:label 'Positions Filled' ;
    rdfs:comment 'The number of positions that have been successfully filled (candidates hired) under this requisition. Used to track progress toward approved headcount.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'The date the requisition was closed, either because all positions were filled, the requisition was cancelled, or it expired. End point for time-to-fill KPI calculation.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the requisition, externally visible and used for tracking and communication. Format: REQ-YYYYNNNN.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'The date the requisition was approved and opened for active recruiting. Start point for time-to-fill KPI calculation.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition. Draft: being prepared; Pending Approval: submitted for approval; Approved: approved but not yet posted; Open: actively recruiting; On Hold: temporarily paused; Filled: candidate hired; Cancelled: requisition withdrawn; Closed: requisition completed or expired. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|on_hold|filled|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on the nature of the hire. New Position: net new headcount; Replacement: backfill for departure; Seasonal: holiday or back-to-school temporary hire; Temporary: fixed-term assignment; Contract: contingent worker; Intern: student or graduate program.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'The maximum annual salary or hourly wage for the position, in the local currency. Used for budgeting and offer preparation.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'The minimum annual salary or hourly wage for the position, in the local currency. Used for budgeting and offer preparation.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalCampaign rdf:type rdf:Property ;
    rdfs:label 'Seasonal Campaign' ;
    rdfs:comment 'The name or identifier of the seasonal hiring campaign this requisition belongs to (e.g., Holiday 2024, Back-to-School 2024). Used for high-volume retail associate hiring planning.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannelStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel Strategy' ;
    rdfs:comment 'The planned or preferred sourcing channels for candidate acquisition, such as job boards, employee referrals, campus recruiting, social media, recruitment agencies, or internal transfers. May be a comma-separated list.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'The target date by which the requisition should be filled. Used for SLA (Service Level Agreement) tracking and recruiter performance measurement.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'The desired or planned start date for the hired candidate(s). Used for workforce planning and onboarding preparation.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'The number of calendar days from requisition open date to the date the first candidate accepted an offer. Key performance indicator (KPI) for recruiting efficiency.' ;
    rdfs:domain ind:TalentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payPeriodId rdf:type rdf:Property ;
    rdfs:label 'Pay Period Id' ;
    rdfs:comment 'Identifier of the pay period to which this time entry belongs. Used for payroll processing and reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayPeriod .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee who recorded this time entry. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked in or started their shift.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked out or ended their shift.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device or terminal used to record the time entry, such as biometric scanner ID, mobile device ID, or POS terminal number.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Number of hours worked that qualify for double-time pay, typically for work on holidays or beyond daily overtime thresholds.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes explaining any exceptions, corrections, or special circumstances related to this time entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHolidayWorked rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Worked' ;
    rdfs:comment 'Indicates whether the time entry represents work performed on a company-recognized holiday, which may qualify for premium pay.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualEntry rdf:type rdf:Property ;
    rdfs:label 'Is Manual Entry' ;
    rdfs:comment 'Indicates whether this time entry was manually entered by a manager or HR administrator rather than captured through automated time clock systems.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'The job classification or position code under which the employee worked during this time entry. Used for labor cost allocation and compliance reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualEntryReason rdf:type rdf:Property ;
    rdfs:label 'Manual Entry Reason' ;
    rdfs:comment 'Explanation for why the time entry was manually entered, such as missed punch, system outage, or retroactive correction.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealBreakViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Break Violation Flag' ;
    rdfs:comment 'Indicates whether this time entry violated meal break requirements under applicable labor laws, requiring penalty pay or corrective action.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this time entry has been processed in a payroll run and included in employee compensation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of hours worked at regular pay rate, typically up to 40 hours per week or 8 hours per day depending on jurisdiction.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restBreakViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Rest Break Violation Flag' ;
    rdfs:comment 'Indicates whether this time entry violated rest break requirements under applicable labor laws.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftDifferentialCode rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Code' ;
    rdfs:comment 'Code indicating any shift differential pay applicable to this time entry, such as night shift, weekend, or holiday premium.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryDate rdf:type rdf:Property ;
    rdfs:label 'Time Entry Date' ;
    rdfs:comment 'The calendar date on which the work was performed.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeEntrySource rdf:type rdf:Property ;
    rdfs:label 'Time Entry Source' ;
    rdfs:comment 'The system or method used to capture the time entry. Indicates whether the entry was recorded via biometric device, mobile application, web portal, manual entry by manager, point-of-sale terminal, or self-service kiosk.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeType rdf:type rdf:Property ;
    rdfs:label 'Time Type' ;
    rdfs:comment 'Classification of the time entry indicating the nature of hours worked or time off taken. Determines pay calculation and accrual impact. [ENUM-REF-CANDIDATE: regular|overtime|holiday|sick|vacation|bereavement|jury_duty|training — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Total Hours Worked' ;
    rdfs:comment 'Total number of hours worked during this time entry, calculated as clock-out minus clock-in minus break duration.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCatalogProductListingId rdf:type rdf:Property ;
    rdfs:label 'Product Catalog Product Listing Id' ;
    rdfs:comment 'Primary key for product_catalog_product_listing' ;
    rdfs:domain ind:ProductCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catalogProductListingId rdf:type rdf:Property ;
    rdfs:label 'Catalog Product Listing Id' ;
    rdfs:comment 'Unique identifier for this catalog product listing record. Primary key.' ;
    rdfs:domain ind:ProductCatalogProductListing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcommerceCatalogProductListing .

ind:addedToCatalogTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added To Catalog Timestamp' ;
    rdfs:comment 'The date and time when this SKU was first added to this catalog. Immutable audit field.' ;
    rdfs:domain ind:ProductCatalogProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productMaterialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Product Material Supplier Id' ;
    rdfs:comment 'Primary key for product_material_supplier' ;
    rdfs:domain ind:ProductMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Material Supplier Id' ;
    rdfs:comment 'Unique identifier for this material-vendor sourcing relationship. Primary key.' ;
    rdfs:domain ind:ProductMaterialSupplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierMaterialSupplier .

ind:approvedSupplierList rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List' ;
    rdfs:comment 'Comma-separated list of approved supplier codes or names authorized to supply this material. Used for sourcing compliance and vendor management. [Moved from material: This comma-separated list in the material table is a denormalized representation of the M:N relationship. The proper model is individual records in material_supplier, not a concatenated string. Each approved supplier should be a separate association record with its own pricing and terms.]' ;
    rdfs:domain ind:ProductMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Code' ;
    rdfs:comment 'Code of the preferred or primary supplier for this material. Used for automated sourcing and purchase order generation. [Moved from material: The preferred supplier designation is specific to each material-vendor relationship and should be captured as preferred_supplier_flag in the association. This allows multiple vendors to be approved while one is marked preferred, with full relationship context.]' ;
    rdfs:domain ind:ProductMaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceId rdf:type rdf:Property ;
    rdfs:label 'Attendance Id' ;
    rdfs:comment 'Unique surrogate identifier for this event attendance record. Primary key.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Precise timestamp when the consumer checked in at the event venue or virtual platform. Null if consumer did not attend. Used for attendance verification and engagement timing analysis.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestCount rdf:type rdf:Property ;
    rdfs:label 'Guest Count' ;
    rdfs:comment 'Number of additional guests (plus-ones) brought by this consumer to the event. Defaults to 0 if consumer attended alone. Used for capacity planning and actual attendance reconciliation.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invitationChannel rdf:type rdf:Property ;
    rdfs:label 'Invitation Channel' ;
    rdfs:comment 'Communication channel through which the invitation was delivered to this consumer (email, SMS, direct mail, in-app notification, sales associate outreach, VIP concierge). Used for channel effectiveness analysis.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationSentDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Sent Date' ;
    rdfs:comment 'Date when the event invitation was sent to this consumer profile. Tracks the start of the engagement funnel for this profile-event combination.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postEventSurveyScore rdf:type rdf:Property ;
    rdfs:label 'Post Event Survey Score' ;
    rdfs:comment 'Consumer satisfaction or Net Promoter Score captured via post-event survey for this specific event experience. Scale typically 0.0 to 10.0. Null if survey not completed. Used for event effectiveness measurement.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rsvpDate rdf:type rdf:Property ;
    rdfs:label 'Rsvp Date' ;
    rdfs:comment 'Date when the consumer submitted their RSVP response for this event. Null if no response received. Used to calculate response time and urgency of follow-up.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rsvpStatus rdf:type rdf:Property ;
    rdfs:label 'Rsvp Status' ;
    rdfs:comment 'Current RSVP response status from the consumer for this specific event. Tracks whether the consumer confirmed attendance, declined, or has not responded.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Access Flag' ;
    rdfs:comment 'Indicates whether this consumer was granted VIP or exclusive access privileges for this specific event (backstage access, meet-and-greet, priority seating, exclusive preview). VIP status is event-specific, not profile-level.' ;
    rdfs:domain ind:Attendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productStorefrontAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Product Storefront Availability Id' ;
    rdfs:comment 'Primary key for product_storefront_availability' ;
    rdfs:domain ind:ProductStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Storefront Availability Id' ;
    rdfs:comment 'Primary key for the storefront availability association record' ;
    rdfs:domain ind:ProductStorefrontAvailability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcommerceStorefrontAvailability .

ind:firstAvailableDate rdf:type rdf:Property ;
    rdfs:label 'First Available Date' ;
    rdfs:comment 'Date when this SKU was first made available on this storefront. Used for new arrival tracking and merchandising analytics.' ;
    rdfs:domain ind:ProductStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAvailableDate rdf:type rdf:Property ;
    rdfs:label 'Last Available Date' ;
    rdfs:comment 'Date when this SKU was last available (in stock) on this storefront. Used for out-of-stock duration tracking and replenishment analytics.' ;
    rdfs:domain ind:ProductStorefrontAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:styleSourcingId rdf:type rdf:Property ;
    rdfs:label 'Style Sourcing Id' ;
    rdfs:comment 'Unique identifier for the style-vendor sourcing relationship. Primary key for the association.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Percentage' ;
    rdfs:comment 'Percentage of total style production volume allocated to this vendor. Supports strategic sourcing decisions and vendor diversification strategies (e.g., 60% primary vendor, 40% secondary vendor).' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAllocationUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Units' ;
    rdfs:comment 'Number of units allocated to this vendor for this style in the current production cycle. Used for multi-sourcing strategies where production is split across multiple vendors for risk mitigation or capacity balancing.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifPerformanceRate rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Rate' ;
    rdfs:comment 'Vendor\'s On-Time In-Full (OTIF) delivery performance rate for this specific style, calculated as percentage of orders delivered on schedule and in full quantity. Style-specific metric used for vendor performance evaluation and future allocation decisions.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the vendor for this style. Tracks progression through sample approval, quality validation, and commercial negotiation stages. Values: pending, qualified, approved, suspended, disqualified.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectRate rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Rate' ;
    rdfs:comment 'Defect rate percentage for this style-vendor combination based on QC inspection results. Tracks quality performance at the style level to identify vendor-style fit and inform future sourcing decisions.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Date' ;
    rdfs:comment 'Date when production samples from this vendor for this style were approved by design and quality teams. Milestone in the vendor qualification process before bulk production authorization.' ;
    rdfs:domain ind:StyleSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountContactRoleId rdf:type rdf:Property ;
    rdfs:label 'Account Contact Role Id' ;
    rdfs:comment 'Unique surrogate identifier for this account-contact role assignment record' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountRoleStartDate rdf:type rdf:Property ;
    rdfs:label 'Account Role Start Date' ;
    rdfs:comment 'Date when the contact assumed their current role or position within the associated wholesale account or enterprise partner organization. Supports relationship tenure tracking and account history analysis. [Moved from contact: This date represents when the contact assumed their role for a specific account. When a contact manages multiple accounts, there must be a separate start date for each account relationship. This attribute belongs in the association as relationship_start_date.]' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this account contact role record was created in the system' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when this contact ended their role with this wholesale account. NULL indicates an active relationship. Used for historical analysis and contact turnover tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when this contact began their role with this wholesale account. Used for relationship tenure analysis and historical tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Functional role this contact performs for this specific wholesale account (e.g., Buyer, Logistics Coordinator, Finance Contact). A contact may have different roles for different accounts.' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp when this account contact role record was last modified' ;
    rdfs:domain ind:AccountContactRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seasonalVendorCapacityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Vendor Capacity Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for this seasonal vendor capacity agreement record. Primary key.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualOtifPct rdf:type rdf:Property ;
    rdfs:label 'Actual Otif Pct' ;
    rdfs:comment 'The actual On-Time In-Full delivery performance achieved by this vendor for this season. Calculated as (on-time in-full deliveries / total deliveries) * 100. Compared against otif_target_pct for vendor scorecard.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualQualityAql rdf:type rdf:Property ;
    rdfs:label 'Actual Quality Aql' ;
    rdfs:comment 'The actual defect rate (AQL) observed for shipments from this vendor for this season. Calculated from quality inspection results. Compared against quality_target_aql for vendor scorecard.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnitsOrdered rdf:type rdf:Property ;
    rdfs:label 'Actual Units Ordered' ;
    rdfs:comment 'The actual number of units ordered from this vendor for this season to date. Tracked to monitor capacity utilization against capacity_commitment_units.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedOtbAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Otb Amount' ;
    rdfs:comment 'The portion of the season\'s total OTB (Open-to-Buy) budget allocated to this vendor for this season. Represents the planned spend with this vendor in the season\'s currency_code. Sum of all vendor allocations should not exceed season.otb_budget_amount.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Commitment Units' ;
    rdfs:comment 'The number of units (pieces/garments) that the vendor has committed to produce for this specific season. This is a negotiated capacity block allocation that varies by season based on the vendor\'s total capacity and the brand\'s seasonal volume forecast.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Negotiated Lead Time Days' ;
    rdfs:comment 'The agreed-upon lead time in days from PO placement to FOB delivery for orders placed under this seasonal agreement. Lead times vary by season due to factory loading, material availability, and seasonal complexity (e.g., outerwear in FW has longer lead times than tees in SS).' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'On-Time In-Full delivery performance target percentage agreed for this season. Represents the percentage of orders that must be delivered on the committed date with the full quantity. Performance targets may vary by season based on strategic importance and vendor tier.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityTargetAql rdf:type rdf:Property ;
    rdfs:label 'Quality Target Aql' ;
    rdfs:comment 'Acceptable Quality Limit (AQL) target for this seasonal agreement, representing the maximum acceptable defect rate. Quality standards may be tightened or relaxed by season based on product category (e.g., luxury vs. value) and vendor maturity.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalCmtRate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Cmt Rate' ;
    rdfs:comment 'The negotiated Cut-Make-Trim (CMT) rate or cost per unit for this vendor-season combination. CMT rates are renegotiated seasonally based on order volume, product complexity, material costs, and market conditions. Expressed in the currency specified in currency_code.' ;
    rdfs:domain ind:SeasonalVendorCapacityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingId rdf:type rdf:Property ;
    rdfs:label 'Targeting Id' ;
    rdfs:comment 'Primary key for targeting' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualConversions rdf:type rdf:Property ;
    rdfs:label 'Actual Conversions' ;
    rdfs:comment 'Actual number of conversions (purchases, sign-ups, or other defined campaign actions) achieved from this segment within this campaign. Measured and updated as the campaign executes. Used to calculate segment-specific conversion rates and compare against target_conversion_count.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Percent' ;
    rdfs:comment 'Percentage of the total campaign budget allocated to this segment. Calculated as (target_spend_amount / campaign.budget_allocated_amount) * 100. Sum of budget_allocation_percent across all segments for a campaign should equal 100%.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignSegmentTargetingReference rdf:type rdf:Property ;
    rdfs:label 'Campaign Segment Targeting Reference' ;
    rdfs:comment 'Unique surrogate identifier for this campaign-segment targeting record. Primary key.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Promotional offer or discount code specifically assigned to this segment within this campaign. Enables segment-specific offers (e.g., higher-value offers for high-value segments). Used for attribution and redemption tracking.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationVariantCode rdf:type rdf:Property ;
    rdfs:label 'Personalization Variant Code' ;
    rdfs:comment 'Identifier of the creative or messaging variant used for this segment within this campaign. Enables segment-specific personalization where different segments receive tailored creative, offers, or messaging within the same campaign. References creative asset management system.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Segment Priority Rank' ;
    rdfs:comment 'Ordinal ranking of this segment\'s priority within this campaign (1 = highest priority). Used when campaigns target multiple segments with different strategic importance. Influences budget allocation decisions and creative personalization priority.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetConversionCount rdf:type rdf:Property ;
    rdfs:label 'Target Conversion Count' ;
    rdfs:comment 'Planned number of conversions (purchases, sign-ups, or other defined campaign actions) expected from this segment within this campaign. Used to calculate segment-specific CAC targets and measure campaign effectiveness by segment.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Target Spend Amount' ;
    rdfs:comment 'Planned marketing investment allocated to this specific segment within this campaign. Represents the portion of the campaign budget designated for reaching and converting this segment. Sum of target_spend_amount across all segments for a campaign should align with the campaign\'s budget_allocated_amount.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current lifecycle status of this segment targeting within the campaign. Planned = scheduled but not yet active; Active = currently executing; Paused = temporarily suspended; Completed = finished execution; Cancelled = terminated before completion. Allows independent management of segment targeting within a campaign.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAllocationId rdf:type rdf:Property ;
    rdfs:label 'Collection Allocation Id' ;
    rdfs:comment 'Unique identifier for the collection allocation record. Primary key.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTierPriority rdf:type rdf:Property ;
    rdfs:label 'Account Tier Priority' ;
    rdfs:comment 'Priority level for this allocation based on account tier and strategic importance. Determines allocation sequence and inventory reservation priority.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'Latest date by which the collection must be delivered to this wholesale account. Contractual commitment date.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Earliest date when the collection can be delivered to this wholesale account. Drives logistics and production scheduling.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownAllowancePercent rdf:type rdf:Property ;
    rdfs:label 'Markdown Allowance Percent' ;
    rdfs:comment 'Agreed markdown or promotional allowance percentage for this collection-account combination. Negotiated commercial term affecting margin planning.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preOrderCommitment rdf:type rdf:Property ;
    rdfs:label 'Pre Order Commitment' ;
    rdfs:comment 'Dollar value of pre-order commitment made by the wholesale account for this collection. Used for demand forecasting and production planning.' ;
    rdfs:domain ind:CollectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Storefront Carrier Service Id' ;
    rdfs:comment 'Primary key for the storefront-carrier service configuration record' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Customer-facing display name for this carrier service option shown at checkout (e.g., \'FedEx 2-Day Shipping\', \'UPS Ground\'). May vary by storefront locale.' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enabledFlag rdf:type rdf:Property ;
    rdfs:label 'Enabled Flag' ;
    rdfs:comment 'Indicates whether this carrier service is currently enabled and available for customer selection at checkout on this storefront. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostMax rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Max' ;
    rdfs:comment 'Maximum estimated shipping cost for this carrier service on this storefront, used for customer cost estimation ranges.' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCostMin rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Min' ;
    rdfs:comment 'Minimum estimated shipping cost for this carrier service on this storefront, used for customer cost estimation ranges.' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeShippingThreshold rdf:type rdf:Property ;
    rdfs:label 'Free Shipping Threshold' ;
    rdfs:comment 'Order value threshold above which this carrier service is offered for free on this storefront. Null if no free shipping promotion applies.' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier to the negotiated rate card or pricing agreement applicable to this storefront-carrier combination. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:StorefrontCarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontFulfillmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Storefront Fulfillment Assignment Id' ;
    rdfs:comment 'Unique identifier for this storefront-DC fulfillment assignment record. Primary key.' ;
    rdfs:domain ind:StorefrontFulfillmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentPriority rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Priority' ;
    rdfs:comment 'Numeric priority ranking for this DC when fulfilling orders from this storefront. Lower numbers indicate higher priority. Used by order routing logic to sequence DC selection when multiple DCs can fulfill the same order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Shipping Cutoff Time' ;
    rdfs:comment 'Time of day (in DC local time) by which orders from this storefront must be received to qualify for same-day shipment from this DC. Used for delivery promise calculation and order routing deadlines.' ;
    rdfs:domain ind:StorefrontFulfillmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignParticipationId rdf:type rdf:Property ;
    rdfs:label 'Campaign Participation Id' ;
    rdfs:comment 'Unique identifier for each store-campaign participation record. Primary key.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeActualSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Store Actual Sales Amount' ;
    rdfs:comment 'Actual sales revenue generated by this store attributable to this campaign. Used for campaign ROI analysis at store level.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeBudgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Store Budget Allocated Amount' ;
    rdfs:comment 'Budget amount allocated specifically to this store for this campaign. Part of the campaign\'s total budget is distributed across participating stores.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Store Compliance Flag' ;
    rdfs:comment 'Indicates whether this store is compliant with campaign execution requirements (signage, merchandising, staff training, promotional pricing). Used for campaign audit and quality control.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeEndDate rdf:type rdf:Property ;
    rdfs:label 'Store End Date' ;
    rdfs:comment 'Date when this specific store\'s participation in the campaign ended. May differ from the campaign\'s overall end_date due to early termination or extended participation.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeParticipationStatus rdf:type rdf:Property ;
    rdfs:label 'Store Participation Status' ;
    rdfs:comment 'Current status of this store\'s participation in the campaign. Values: planned, active, paused, completed, cancelled. Allows stores to opt in/out or pause participation independently.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeStartDate rdf:type rdf:Property ;
    rdfs:label 'Store Start Date' ;
    rdfs:comment 'Date when this specific store began participating in the campaign. May differ from the campaign\'s overall start_date due to phased rollouts or regional timing.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeTargetImpressions rdf:type rdf:Property ;
    rdfs:label 'Store Target Impressions' ;
    rdfs:comment 'Target number of impressions or customer touchpoints this specific store is expected to generate for this campaign.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleStyleAgreementId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Style Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for this wholesale style agreement record. Primary key.' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSpecificColorways rdf:type rdf:Property ;
    rdfs:label 'Account Specific Colorways' ;
    rdfs:comment 'Comma-separated list or JSON array of colorway codes that are exclusive to or custom-developed for this wholesale account. Supports exclusive colorway agreements (e.g., Nordstrom-exclusive navy colorway).' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period End' ;
    rdfs:comment 'End date of the exclusivity period. After this date, the style may be offered to other accounts. Null if non-exclusive or perpetual exclusive agreement.' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Start' ;
    rdfs:comment 'Start date of the exclusivity period during which this wholesale account has exclusive rights to distribute this style in their territory or channel. Null if non-exclusive agreement.' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiatedWholesalePrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Wholesale Price' ;
    rdfs:comment 'Custom wholesale price negotiated for this specific style-account relationship. May differ from the styles standard wholesale price based on volume commitments, strategic partnership tier, or exclusivity terms.' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this style is manufactured as a private label product for this wholesale account (e.g., Target-branded apparel manufactured by the company). Drives labeling, branding, and IP ownership rules.' ;
    rdfs:domain ind:WholesaleStyleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:factorySourcingAllocationId rdf:type rdf:Property ;
    rdfs:label 'Factory Sourcing Allocation Id' ;
    rdfs:comment 'Unique identifier for this factory-agreement allocation record. Primary key.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factorySupplierFactoryId rdf:type rdf:Property ;
    rdfs:label 'Factory Supplier Factory Id' ;
    rdfs:comment 'Foreign key linking to the specific manufacturing facility allocated to fulfill this sourcing agreement' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierFactory .

ind:sourcingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Agreement Id' ;
    rdfs:comment 'Foreign key to sourcing.sourcing_agreement identifying the master agreement' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:allocatedVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Volume Quantity' ;
    rdfs:comment 'The portion of the total agreement committed volume allocated to this specific factory. Subset of sourcing_agreement.committed_volume_quantity distributed across multiple factories.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective From Date' ;
    rdfs:comment 'The date when this factory allocation becomes operational. May differ from the master agreement effective date if factories are added mid-term.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective To Date' ;
    rdfs:comment 'The date when this factory allocation expires or is terminated. Nullable for ongoing allocations. May differ from master agreement end date if factories are rotated.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factoryCmtRate rdf:type rdf:Property ;
    rdfs:label 'Factory Cmt Rate' ;
    rdfs:comment 'The factory-specific Cut Make Trim labor rate for this agreement, reflecting factory labor costs and efficiency levels.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Factory Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this specific factory has exclusive production rights for products under this agreement. Factory-level exclusivity within a multi-factory vendor relationship.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:factoryFobPrice rdf:type rdf:Property ;
    rdfs:label 'Factory Fob Price' ;
    rdfs:comment 'The factory-specific Free On Board unit price for this agreement, which may differ from the base agreement price due to factory capabilities, location, or negotiated terms.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFactoryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Factory Flag' ;
    rdfs:comment 'Indicates whether this factory is the primary/lead facility for this agreement when multiple factories are allocated. Used for routing and prioritization decisions.' ;
    rdfs:domain ind:FactorySourcingAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this carrier-factory service agreement. Primary key.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Destination location, port, or distribution center covered by this service agreement.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lanePriority rdf:type rdf:Property ;
    rdfs:label 'Lane Priority' ;
    rdfs:comment 'Priority ranking for this carrier on this factory lane (1=first choice, 2=backup, etc.). Used in routing guide logic for freight booking decisions. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'Minimum shipment volume commitment required under this agreement (if applicable). Null if no minimum commitment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Specific origin location or port for this service agreement (may be more specific than factory address, e.g., nearest port or pickup point).' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the contracted rate (e.g., USD, EUR, CNY). Required to interpret contracted_rate correctly.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the contracted rate (per_kg, per_cbm, per_container, per_shipment, per_pallet). Required to interpret contracted_rate correctly.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Committed transit time in days from factory pickup to destination delivery for this carrier-factory service agreement. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:CarrierServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionSeedingId rdf:type rdf:Property ;
    rdfs:label 'Collection Seeding Id' ;
    rdfs:comment 'Unique system-generated identifier for this collection seeding record. Primary key.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:comment 'Total sales revenue attributed to this specific collection-influencer seeding, tracked via promo codes, affiliate links, or UTM parameters. Performance metric for ROI calculation.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentDeliverableCount rdf:type rdf:Property ;
    rdfs:label 'Content Deliverable Count' ;
    rdfs:comment 'Number of content pieces (posts, stories, videos) the influencer committed to create for this collection seeding. Contractual obligation tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'Average engagement rate (likes, comments, shares divided by reach) across all content pieces created for this collection seeding. Performance metric specific to this collection-influencer combination.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityWindowDays rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Days' ;
    rdfs:comment 'Number of days during which the influencer agrees not to post content featuring competing brands or collections. Collection-specific exclusivity term.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPostEndDate rdf:type rdf:Property ;
    rdfs:label 'Expected Post End Date' ;
    rdfs:comment 'Planned date by which all content deliverables for this collection seeding should be completed and posted.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedPostStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Post Start Date' ;
    rdfs:comment 'Planned date when the influencer should begin posting content featuring this collection. Coordinated with collection launch timing.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seedingDate rdf:type rdf:Property ;
    rdfs:label 'Seeding Date' ;
    rdfs:comment 'Date when the collection merchandise was shipped or delivered to the influencer. Critical for coordinating content timing with launch windows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seedingQuantity rdf:type rdf:Property ;
    rdfs:label 'Seeding Quantity' ;
    rdfs:comment 'Number of units or pieces from the collection seeded to this influencer. Tracks inventory allocation for gifting programs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seedingStatus rdf:type rdf:Property ;
    rdfs:label 'Seeding Status' ;
    rdfs:comment 'Current lifecycle status of this collection seeding record. Values: planned (seeding scheduled), shipped (merchandise in transit), delivered (influencer received), content_in_progress (creating deliverables), completed (all deliverables posted and tracked), cancelled (seeding cancelled).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingValueAmount rdf:type rdf:Property ;
    rdfs:label 'Seeding Value Amount' ;
    rdfs:comment 'Total retail value of merchandise seeded to the influencer for this collection. Used for accounting and ROI calculation.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Aggregate impressions (total views) across all content pieces created for this collection seeding. Platform-reported metric.' ;
    rdfs:domain ind:CollectionSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReach rdf:type rdf:Property ;
    rdfs:label 'Total Reach' ;
    rdfs:comment 'Aggregate reach (unique viewers) across all content pieces created for this collection seeding. Platform-reported metric.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substanceRegulationId rdf:type rdf:Property ;
    rdfs:label 'Substance Regulation Id' ;
    rdfs:comment 'Unique identifier for this substance regulation record. Primary key.' ;
    rdfs:domain ind:SubstanceRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key to compliance_obligation' ;
    rdfs:domain ind:SubstanceRegulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:regulationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulation Status' ;
    rdfs:comment 'Current status of this substance regulation: active (currently enforced), pending (future effective date), superseded (replaced by updated regulation), expired (past sunset date).' ;
    rdfs:domain ind:SubstanceRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Id' ;
    rdfs:comment 'Unique identifier for this campaign flight execution. Primary key.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocatedToStorefront rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated To Storefront' ;
    rdfs:comment 'Marketing budget allocated specifically to this campaign flight for this storefront/market. Subset of the parent campaign\'s total budget.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacActual rdf:type rdf:Property ;
    rdfs:label 'Cac Actual' ;
    rdfs:comment 'Actual Customer Acquisition Cost for this campaign flight on this storefront, calculated as budget spent divided by new customers acquired.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'Actual number of clicks delivered for this campaign flight on this storefront. Performance metric.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Conversions Delivered' ;
    rdfs:comment 'Actual number of conversions (purchases, sign-ups) attributed to this campaign flight on this storefront. Performance metric.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current operational status of this campaign flight on this storefront.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Actual number of impressions delivered for this campaign flight on this storefront. Performance metric.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landingPageUrlOverride rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url Override' ;
    rdfs:comment 'Storefront-specific landing page URL override. If null, uses the parent campaign\'s landing_page_url.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:comment 'Total revenue attributed to this campaign flight on this storefront using the campaign attribution model.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontSpecificCreative rdf:type rdf:Property ;
    rdfs:label 'Storefront Specific Creative' ;
    rdfs:comment 'Reference to the creative asset variant or localized creative used for this storefront (e.g., language-specific imagery, regional messaging, cultural adaptation).' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productMaterialSourcingId rdf:type rdf:Property ;
    rdfs:label 'Product Material Sourcing Id' ;
    rdfs:comment 'Primary key for product_material_sourcing' ;
    rdfs:domain ind:ProductMaterialSourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialSourcingId rdf:type rdf:Property ;
    rdfs:label 'Material Sourcing Id' ;
    rdfs:comment 'Unique identifier for this material-factory sourcing relationship. Primary key.' ;
    rdfs:domain ind:ProductMaterialSourcing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingMaterialSourcing .

ind:materialProgramEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Material Program Eligibility Id' ;
    rdfs:comment 'Unique identifier for this material-program eligibility record. Primary key.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Actual Diversion Kg' ;
    rdfs:comment 'Actual quantity in kilograms of this material diverted through this circular program to date. Performance tracking metric.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonReductionKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Kg' ;
    rdfs:comment 'Carbon dioxide equivalent reduction in kilograms achieved by diverting this specific material through this circular program. Material-specific environmental impact.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionInstructions rdf:type rdf:Property ;
    rdfs:label 'Collection Instructions' ;
    rdfs:comment 'Special handling or collection instructions specific to this material type for this circular program (e.g., remove hardware, separate linings).' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionTargetKg rdf:type rdf:Property ;
    rdfs:label 'Diversion Target Kg' ;
    rdfs:comment 'Target quantity in kilograms for this specific material to be diverted through this circular program. Material-level target contributing to overall program goals.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current eligibility status of this material for this specific circular program. Determines whether the material can be accepted.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRecoveryRate rdf:type rdf:Property ;
    rdfs:label 'Material Recovery Rate' ;
    rdfs:comment 'Actual recovery rate percentage achieved for this specific material within this circular program. Used for program ROI analysis and material-specific performance tracking.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumConditionRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Condition Required' ;
    rdfs:comment 'Minimum acceptable condition for this specific material type to be accepted into this circular program. Material-specific condition requirements.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingMethod rdf:type rdf:Property ;
    rdfs:label 'Processing Method' ;
    rdfs:comment 'Specific processing method used for this material type within this circular program. Different materials require different circular processing approaches.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Quality grade classification for this material when collected through this program. Determines processing pathway and resale value potential.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resaleValue rdf:type rdf:Property ;
    rdfs:label 'Resale Value' ;
    rdfs:comment 'Average resale or recovered material value for this material type within this circular program. Used for program economics and ROI calculation.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resaleValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Resale Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the resale value amount.' ;
    rdfs:domain ind:MaterialProgramEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSubstanceMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Test Substance Measurement Id' ;
    rdfs:comment 'Unique identifier for this test substance measurement record. Primary key.' ;
    rdfs:domain ind:TestSubstanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:result rdf:type rdf:Property ;
    rdfs:label 'Result' ;
    rdfs:comment 'Pass/fail outcome for this specific substance measurement within the test' ;
    rdfs:domain ind:TestSubstanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMeasurementUnit rdf:type rdf:Property ;
    rdfs:label 'Test Measurement Unit' ;
    rdfs:comment 'Unit of measure for the test result (e.g., seconds, ppm, newtons, grade). [Moved from product_safety_test: The unit of measure is specific to each substance measurement within a test. Different substances may be measured in different units within the same test.]' ;
    rdfs:domain ind:TestSubstanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMeasurementValue rdf:type rdf:Property ;
    rdfs:label 'Test Measurement Value' ;
    rdfs:comment 'Quantitative result of the test (e.g., flame spread rate, chemical concentration, tensile strength). [Moved from product_safety_test: This value is specific to a particular substance within a test, not to the test as a whole. A single test measures multiple substances, each with its own measurement value.]' ;
    rdfs:domain ind:TestSubstanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorDefectOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Defect Occurrence Id' ;
    rdfs:comment 'Unique identifier for this vendor-defect occurrence tracking record. Primary key for the association.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Date' ;
    rdfs:comment 'Actual date when the vendor completed corrective actions for this defect type. Used to measure vendor CAPA cycle time and on-time completion rates.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Target date by which the vendor must complete corrective actions for this defect type. Used to track vendor responsiveness and compliance with quality improvement timelines.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costImpactTotal rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Total' ;
    rdfs:comment 'Cumulative financial impact of this defect type at this vendor, including rework costs, scrap, chargebacks, and claims. Used for vendor scorecarding and cost-of-quality analysis.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectFrequencyCount rdf:type rdf:Property ;
    rdfs:label 'Defect Frequency Count' ;
    rdfs:comment 'Total number of times this specific defect type has been observed at this vendor across all inspections and production runs. Supports Pareto analysis and vendor quality trending.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'First Occurrence Date' ;
    rdfs:comment 'The date when this defect type was first identified at this vendor. Tracks the emergence of quality issues and supports root cause timeline analysis.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Last Occurrence Date' ;
    rdfs:comment 'The most recent date when this defect type was observed at this vendor. Used to assess whether corrective actions have been effective and whether the defect is recurring or resolved.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceRate rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rate' ;
    rdfs:comment 'Percentage of inspections or production runs at this vendor where this defect type recurs after corrective action. Indicates effectiveness of vendor quality improvements and process control.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Vendor Responsible Party' ;
    rdfs:comment 'Name or role of the vendor contact responsible for addressing this defect type. Supports accountability and communication in CAPA workflows.' ;
    rdfs:domain ind:VendorDefectOccurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQualityComplianceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quality Compliance Id' ;
    rdfs:comment 'Unique identifier for this vendor-quality standard compliance record. Primary key.' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStandardId rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Id' ;
    rdfs:comment 'Foreign key to quality_standard identifying which standard applies' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Standard .

ind:auditFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Override' ;
    rdfs:comment 'Vendor-specific override of the default audit frequency defined in the quality standard, allowing more frequent audits for high-risk vendors or less frequent for consistently compliant vendors (e.g., Quarterly, Semi-Annual, Annual, Biennial)' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether this specific vendor must obtain formal third-party certification for this quality standard, which may differ from the standards general certification requirements based on vendor tier, product categories supplied, or target markets served' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the third-party organization that issued the certification to this vendor for this standard (may differ from the standards issuing body)' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCorrectiveActions rdf:type rdf:Property ;
    rdfs:label 'Open Corrective Actions' ;
    rdfs:comment 'Number of open corrective action requests (CARs) for this vendor related to this specific quality standard' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date when the granted waiver expires and full compliance is required' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a temporary waiver or exception has been granted for this vendor for this quality standard, allowing production despite non-compliance under specific conditions' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Business justification and approval documentation for the granted waiver' ;
    rdfs:domain ind:VendorQualityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Storefront Fulfillment Id' ;
    rdfs:comment 'Unique surrogate identifier for each store-to-storefront fulfillment configuration record. Primary key.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bopisEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether Buy Online Pick-up In Store (BOPIS) fulfillment is enabled for this store-storefront combination. A store may offer BOPIS for some digital storefronts but not others based on operational capacity, brand alignment, or regional strategy. This is relationship-specific configuration.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Percent' ;
    rdfs:comment 'Percentage of the store\'s available inventory that is allocated for fulfillment of orders from this digital storefront. Allows stores to reserve inventory capacity across multiple digital channels. Sum of allocation percentages across all storefronts for a given store may exceed 100% in overbooking scenarios. This is relationship-specific data because allocation rules vary by storefront based on channel strategy and demand patterns.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelAgreementHours rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Hours' ;
    rdfs:comment 'Target number of hours within which this store commits to fulfill orders from this digital storefront (e.g., 2 hours for BOPIS, 24 hours for ship-from-store). Service level agreements may vary by store-storefront combination based on customer expectations, competitive positioning, and operational capacity. This is relationship-specific operational data.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipFromStoreEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether ship-from-store fulfillment is enabled for this store-storefront combination. Determines if the store can pack and ship orders placed on this digital storefront directly to customers. A store may ship for some storefronts but not others based on shipping infrastructure, labor capacity, or channel strategy. This is relationship-specific configuration.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Identifier of the user or system process that last updated this fulfillment configuration record. Used for audit trail and accountability.' ;
    rdfs:domain ind:StorefrontFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBookingId rdf:type rdf:Property ;
    rdfs:label 'Capacity Booking Id' ;
    rdfs:comment 'Unique surrogate identifier for this seasonal factory capacity booking record. Primary key.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Booked Capacity Units' ;
    rdfs:comment 'The number of production units (garments, pairs, pieces) reserved/committed by merchandising for this season at this factory. Represents the capacity allocation from the factory\'s total certified capacity.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingEndDate rdf:type rdf:Property ;
    rdfs:label 'Booking End Date' ;
    rdfs:comment 'The last date of the production window for this season at this factory. Defines the cutoff for production completion to meet the season\'s delivery deadlines.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingStartDate rdf:type rdf:Property ;
    rdfs:label 'Booking Start Date' ;
    rdfs:comment 'The first date of the production window during which this factory will manufacture goods for this season. Aligns with the season\'s pre-production and delivery calendar.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentLevel rdf:type rdf:Property ;
    rdfs:label 'Commitment Level' ;
    rdfs:comment 'The contractual commitment status of this capacity booking. Firm = binding commitment, Tentative = soft hold pending approval, Option = reserved but not committed, Cancelled = booking withdrawn.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The negotiated pricing tier or rate category for this season-factory booking (e.g., Standard, Volume Discount, Premium Rush). Pricing may vary by season based on volume commitments, timing, and factory utilization.' ;
    rdfs:domain ind:CapacityBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleFactoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Style Factory Allocation Id' ;
    rdfs:comment 'Primary key for style_factory_allocation' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAllocation rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation' ;
    rdfs:comment 'Number of units per week allocated to this factory for this style. Used for production planning and capacity balancing across multiple factories. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmtPrice rdf:type rdf:Property ;
    rdfs:label 'Cmt Price' ;
    rdfs:comment 'Cut-Make-Trim price negotiated with this specific factory for this specific style. Varies by factory based on capabilities, location, and volume commitments. Critical for cost planning and factory selection. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectRate rdf:type rdf:Property ;
    rdfs:label 'Defect Rate' ;
    rdfs:comment 'Defect rate as a decimal (e.g., 0.0250 = 2.5%) for this style at this factory. Calculated from quality inspection data. Used for factory quality comparison and selection.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstProductionDate rdf:type rdf:Property ;
    rdfs:label 'First Production Date' ;
    rdfs:comment 'Date when this factory first produced this style. Used for tracking factory experience with specific styles and production history analysis.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastProductionDate rdf:type rdf:Property ;
    rdfs:label 'Last Production Date' ;
    rdfs:comment 'Date of the most recent production run of this style at this factory. Used for identifying active vs dormant allocations.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredFactoryFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Factory Flag' ;
    rdfs:comment 'Indicates whether this factory is the preferred/primary factory for this style. Used for default factory selection in purchase order creation.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current production status for this style-factory combination. Values: approved, active, on_hold, discontinued. Governs whether new purchase orders can be placed. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Total Units Produced' ;
    rdfs:comment 'Cumulative total units of this style produced at this factory since approval. Used for volume analysis and factory performance tracking.' ;
    rdfs:domain ind:StyleFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:styleCertificationId rdf:type rdf:Property ;
    rdfs:label 'Style Certification Id' ;
    rdfs:comment 'Unique identifier for this style-ecolabel certification record. Primary key.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the style was certified or granted permission to use this eco-label. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifyingAuditorName rdf:type rdf:Property ;
    rdfs:label 'Certifying Auditor Name' ;
    rdfs:comment 'Name of the third-party auditor or certification body representative who conducted the certification audit for this style-ecolabel combination.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Claim Approval Date' ;
    rdfs:comment 'Date when the public claim was approved for use on this style. Used for compliance tracking and marketing launch coordination.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hangtagPrintApproved rdf:type rdf:Property ;
    rdfs:label 'Hangtag Print Approved' ;
    rdfs:comment 'Boolean flag indicating whether this eco-label logo has been approved for printing on physical hangtags for this style. Separate from general claim approval due to production lead times.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Unique license or certificate number issued by the certification body for this style-ecolabel combination. Required for compliance documentation and hangtag printing. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicClaimApproved rdf:type rdf:Property ;
    rdfs:label 'Public Claim Approved' ;
    rdfs:comment 'Boolean flag indicating whether the marketing and legal teams have approved the use of this eco-label in public-facing materials, hangtags, and product descriptions for this specific style. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which recertification audit must be initiated to maintain continuous certification status. Used for compliance calendar and audit scheduling.' ;
    rdfs:domain ind:StyleCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiativeCarbonContributionId rdf:type rdf:Property ;
    rdfs:label 'Initiative Carbon Contribution Id' ;
    rdfs:comment 'Unique identifier for this initiative-to-carbon-target contribution record. Primary key.' ;
    rdfs:domain ind:InitiativeCarbonContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Alignment End Date' ;
    rdfs:comment 'Date when this initiative\'s contribution to this carbon target ended or is planned to end. Null if the alignment is ongoing. Supports historical tracking of initiative-target relationships.' ;
    rdfs:domain ind:InitiativeCarbonContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Alignment Start Date' ;
    rdfs:comment 'Date when this initiative was formally aligned to contribute toward this carbon target. Enables tracking of when initiatives were added to target portfolios.' ;
    rdfs:domain ind:InitiativeCarbonContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethodology rdf:type rdf:Property ;
    rdfs:label 'Allocation Methodology' ;
    rdfs:comment 'Description of the methodology used to allocate this initiative\'s carbon reduction to this specific target (e.g., \'direct attribution - initiative exclusively serves this target\', \'proportional allocation based on scope coverage\', \'financial allocation based on investment split\').' ;
    rdfs:domain ind:InitiativeCarbonContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'The percentage of this initiative\'s total carbon reduction impact that is allocated to this specific carbon target. Enables initiatives to contribute proportionally to multiple targets (e.g., 60% to Scope 1+2 target, 40% to Scope 3 target).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Vendor Relationship Id' ;
    rdfs:comment 'Unique identifier for this vendor-employee relationship assignment record. Primary key.' ;
    rdfs:domain ind:VendorRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Boolean indicator of whether this employee is the primary point of contact for this vendor in this role type. Used to identify the main responsible party when multiple employees have relationships with the same vendor. Only one employee per role_type should be marked as primary for a given vendor at any time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Unique identifier for this vendor certification holding record. Primary key.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifiedFacilityLocation rdf:type rdf:Property ;
    rdfs:label 'Certified Facility Location' ;
    rdfs:comment 'The specific facility or site location covered by this vendor certification, if the scope is facility-level. May differ from vendor headquarters.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSubstanceComplianceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Substance Compliance Id' ;
    rdfs:comment 'Unique identifier for this vendor-substance compliance record. Primary key.' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for compliance team notes specific to this vendor-substance relationship, including corrective actions, special conditions, or monitoring requirements' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the measured_concentration value' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Indicates whether this vendor has been granted an exemption or derogation for this specific substance based on material type, product category, or regulatory conditions' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date when this vendor was last tested for this specific restricted substance' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measuredConcentration rdf:type rdf:Property ;
    rdfs:label 'Measured Concentration' ;
    rdfs:comment 'Actual measured concentration of the restricted substance found in the vendor\'s materials during the most recent test' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Calculated date when the next compliance test is due for this vendor-substance combination based on test_frequency' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'Required frequency of testing for this vendor-substance combination based on risk assessment and contractual agreements' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLabName rdf:type rdf:Property ;
    rdfs:label 'Testing Lab Name' ;
    rdfs:comment 'Name of the third-party testing laboratory used by this vendor for this substance testing' ;
    rdfs:domain ind:VendorSubstanceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontFulfillmentNetworkId rdf:type rdf:Property ;
    rdfs:label 'Storefront Fulfillment Network Id' ;
    rdfs:comment 'Unique identifier for this storefront-warehouse fulfillment network configuration record. Primary key.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentSlaHours rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Sla Hours' ;
    rdfs:comment 'Service level agreement in hours for order fulfillment from this warehouse to customers of this storefront. Represents the committed time from order placement to shipment departure. Used for delivery promise calculations and warehouse performance measurement.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimaryFulfillmentLocation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Fulfillment Location' ;
    rdfs:comment 'Indicates whether this warehouse is the primary/default fulfillment location for this storefront. Typically one primary location per storefront with others serving as backup or overflow capacity.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingCostTier rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Tier' ;
    rdfs:comment 'Classification of shipping cost economics for this warehouse-storefront pair. Reflects distance, carrier rates, and zone-based pricing. Used to optimize fulfillment routing based on shipping cost considerations.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignInitiativePromotionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Initiative Promotion Id' ;
    rdfs:comment 'Unique identifier for this campaign-initiative promotion relationship. Primary key.' ;
    rdfs:domain ind:CampaignInitiativePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Initiative Id' ;
    rdfs:comment 'Foreign key to the sustainability initiative being promoted in this campaign.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Initiative .

ind:attributedImpactMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Attributed Impact Metric Unit' ;
    rdfs:comment 'Unit of measurement for the attributed impact metric (e.g., \'percentage points\', \'new customers\', \'impressions\', \'engagement rate\').' ;
    rdfs:domain ind:CampaignInitiativePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedImpactMetricValue rdf:type rdf:Property ;
    rdfs:label 'Attributed Impact Metric Value' ;
    rdfs:comment 'Quantified impact metric attributed to this campaign-initiative pairing, such as incremental brand awareness lift, customer acquisition attributed to sustainability messaging, or engagement metrics specific to this initiative within the campaign.' ;
    rdfs:domain ind:CampaignInitiativePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeAssetCount rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Count' ;
    rdfs:comment 'Number of creative assets (images, videos, copy variants) produced specifically featuring this sustainability initiative within the campaign.' ;
    rdfs:domain ind:CampaignInitiativePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messagingTheme rdf:type rdf:Property ;
    rdfs:label 'Messaging Theme' ;
    rdfs:comment 'Campaign-specific messaging theme or narrative used to communicate this sustainability initiative to the target audience (e.g., \'Renewable Energy Leadership\', \'Circular Fashion Pioneer\', \'Water Stewardship\').' ;
    rdfs:domain ind:CampaignInitiativePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCertificationUsageId rdf:type rdf:Property ;
    rdfs:label 'Campaign Certification Usage Id' ;
    rdfs:comment 'Unique identifier for this campaign certification usage record. Primary key.' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationComplianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Compliance Certification Id' ;
    rdfs:comment 'Foreign key linking to the compliance certification being featured in the campaign' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCertification .

ind:certificationMarkUsed rdf:type rdf:Property ;
    rdfs:label 'Certification Mark Used' ;
    rdfs:comment 'Boolean flag indicating whether the official certification logo or mark is displayed in campaign materials (true) or only textual claims are made (false).' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'The type of sustainability or compliance claim being made in the campaign using this certification (e.g., organic, fair trade, recycled content, sustainable manufacturing, ethical labor).' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredProductsList rdf:type rdf:Property ;
    rdfs:label 'Featured Products List' ;
    rdfs:comment 'Comma-separated list of product SKUs or product line identifiers that are specifically highlighted as certified in this campaign usage.' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Free-text description of how and where the certification is featured in the campaign (e.g., \'GOTS certified organic cotton featured in email hero image and product detail pages\', \'Fair Trade logo on social media posts for spring collection\').' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageEndDate rdf:type rdf:Property ;
    rdfs:label 'Usage End Date' ;
    rdfs:comment 'The date when this certification stopped being featured in this campaign. May differ from campaign end date if certification expires or is removed early.' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageStartDate rdf:type rdf:Property ;
    rdfs:label 'Usage Start Date' ;
    rdfs:comment 'The date when this certification began being featured or promoted in this campaign. May differ from campaign start date if certification is added mid-campaign.' ;
    rdfs:domain ind:CampaignCertificationUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionSustainabilityContributionId rdf:type rdf:Property ;
    rdfs:label 'Collection Sustainability Contribution Id' ;
    rdfs:comment 'Unique identifier for the collection-initiative contribution record. Primary key.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonReductionAttributedMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Attributed Mt Co2e' ;
    rdfs:comment 'Metric tons of CO2 equivalent emissions reduction attributed to this collection\'s participation in the sustainability initiative. Used for ESG reporting and impact measurement.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionEndDate rdf:type rdf:Property ;
    rdfs:label 'Contribution End Date' ;
    rdfs:comment 'Date when the collection\'s contribution to this initiative ended or is planned to end, typically aligned with collection end-of-life or initiative completion.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionNotes rdf:type rdf:Property ;
    rdfs:label 'Contribution Notes' ;
    rdfs:comment 'Free-text notes describing specific details of how this collection contributes to the initiative, including design choices, material selections, or process changes implemented.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionStartDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Start Date' ;
    rdfs:comment 'Date when the collection began contributing to this sustainability initiative, typically aligned with collection launch or initiative implementation phase.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiativeContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Initiative Contribution Percentage' ;
    rdfs:comment 'Percentage of the collection\'s sustainability impact or investment that is attributed to this specific initiative. Used for ESG reporting allocation and initiative ROI calculation.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentAllocated rdf:type rdf:Property ;
    rdfs:label 'Investment Allocated' ;
    rdfs:comment 'Portion of the initiative\'s total investment budget that is allocated to this specific collection. Used for financial tracking and ROI analysis.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAchievementStatus rdf:type rdf:Property ;
    rdfs:label 'Target Achievement Status' ;
    rdfs:comment 'Current status of the collection\'s progress toward achieving its contribution targets for this initiative. Tracked for portfolio management and reporting.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDiversionAttributedKg rdf:type rdf:Property ;
    rdfs:label 'Waste Diversion Attributed Kg' ;
    rdfs:comment 'Kilograms of waste diverted from landfill attributed to this collection\'s participation in circular economy initiatives. Used for ESG reporting.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSavingsAttributedM3 rdf:type rdf:Property ;
    rdfs:label 'Water Savings Attributed M3' ;
    rdfs:comment 'Cubic meters of water consumption reduction attributed to this collection\'s participation in water stewardship initiatives. Used for ESG reporting.' ;
    rdfs:domain ind:CollectionSustainabilityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterInitiativeParticipationId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Initiative Participation Id' ;
    rdfs:comment 'Unique identifier for the cost center initiative participation record. Primary key.' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Investment Amount' ;
    rdfs:comment 'The portion of the initiative\'s total investment amount allocated to this cost center, calculated as initiative investment_amount × cost_allocation_percentage. Used for cost center budget impact analysis and ESG investment tracking by organizational unit.' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of the initiative\'s total investment amount allocated to or borne by this cost center, expressed as a decimal percentage (0.00 to 100.00). Used for distributing initiative costs across participating organizational units and for cost center budget tracking. This attribute was explicitly identified in the detection reasoning as relationship data (cost share).' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativePhase rdf:type rdf:Property ;
    rdfs:label 'Initiative Phase' ;
    rdfs:comment 'The current phase of initiative implementation at this specific cost center. PLANNING: initiative approved but not yet started at this location. IMPLEMENTATION: active rollout in progress. MEASUREMENT: implementation complete, measuring impact. COMPLETED: initiative fully implemented and measured at this location. SUSPENDED: participation paused or cancelled. This attribute was explicitly identified in the detection reasoning as relationship data (phase).' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'The role of the cost center in the sustainability initiative. LEAD: primary responsible party driving implementation at this location. PARTICIPANT: active participant implementing the program. PILOT: test site for initiative before broader rollout. OBSERVER: monitoring or learning from the initiative without active implementation. This attribute was explicitly identified in the detection reasoning as relationship data.' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of this cost center\'s participation in the initiative. ACTIVE: currently participating. COMPLETED: participation finished successfully. SUSPENDED: temporarily paused. CANCELLED: participation terminated before completion.' ;
    rdfs:domain ind:CostCenterInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontFactoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Storefront Factory Allocation Id' ;
    rdfs:comment 'Unique identifier for this storefront-factory allocation record. Primary key.' ;
    rdfs:domain ind:StorefrontFactoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryDesignerCollaborationId rdf:type rdf:Property ;
    rdfs:label 'Factory Designer Collaboration Id' ;
    rdfs:comment 'Primary key for factory_designer_collaboration' ;
    rdfs:domain ind:FactoryDesignerCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the designer-factory collaboration ended or is scheduled to end. Null for ongoing collaborations. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:FactoryDesignerCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the designer began collaborating with this factory for sample development or production trials. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:FactoryDesignerCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factoryDesignerCollaborationStatus rdf:type rdf:Property ;
    rdfs:label 'Factory Designer Collaboration Status' ;
    rdfs:comment 'Current lifecycle status of the collaboration relationship, indicating whether it is actively in progress, temporarily paused, completed, or cancelled.' ;
    rdfs:domain ind:FactoryDesignerCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryEmbellishmentCapabilityId rdf:type rdf:Property ;
    rdfs:label 'Factory Embellishment Capability Id' ;
    rdfs:comment 'Primary key for the factory_embellishment_capability association' ;
    rdfs:domain ind:FactoryEmbellishmentCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capabilityCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Capability Certification Date' ;
    rdfs:comment 'Date when the factory was certified or approved to execute this specific embellishment technique, following quality audits or sample approval processes' ;
    rdfs:domain ind:FactoryEmbellishmentCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionFactoryCertificationId rdf:type rdf:Property ;
    rdfs:label 'Production Factory Certification Id' ;
    rdfs:comment 'Primary key for production_factory_certification' ;
    rdfs:domain ind:ProductionFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAuditorName rdf:type rdf:Property ;
    rdfs:label 'Issuing Auditor Name' ;
    rdfs:comment 'Name of the specific auditor or audit firm that conducted the certification audit for this factory.' ;
    rdfs:domain ind:ProductionFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'The specific scope of this certification as it applies to this factory. May include product categories covered (e.g., \'woven apparel only\'), production lines certified, or facility areas included. Corresponds to certification_scope from detection phase.' ;
    rdfs:domain ind:ProductionFactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryInitiativeImplementationId rdf:type rdf:Property ;
    rdfs:label 'Factory Initiative Implementation Id' ;
    rdfs:comment 'Unique identifier for this factory-initiative implementation record. Primary key.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Audit Verification Date' ;
    rdfs:comment 'Date when the implementation and impact claims were verified through audit or third-party assessment, used for SBTi and ESG reporting credibility.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Verification Status' ;
    rdfs:comment 'Status of third-party verification for this factory implementation, required for certain certifications and SBTi progress tracking.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryCarbonReductionMtCo2e rdf:type rdf:Property ;
    rdfs:label 'Factory Carbon Reduction Mt Co2e' ;
    rdfs:comment 'Measured annual greenhouse gas emissions reduction in metric tons of CO2 equivalent achieved at this specific factory. Factory-level impact contributing to initiative total. Identified in detection phase relationship data as impact_achieved.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryEnergySavingsMwh rdf:type rdf:Property ;
    rdfs:label 'Factory Energy Savings Mwh' ;
    rdfs:comment 'Measured annual energy consumption reduction in megawatt hours achieved at this factory. Factory-level impact contributing to initiative total.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Factory Investment Amount' ;
    rdfs:comment 'Capital and operational expenditure allocated specifically to this factory for implementing this initiative. Subset of the total initiative investment. Identified in detection phase relationship data.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryInvestmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Factory Investment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the factory-level investment amount, may differ from initiative-level currency.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryWasteDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Factory Waste Diversion Kg' ;
    rdfs:comment 'Measured annual waste diverted from landfill in kilograms at this factory. Factory-level impact contributing to initiative total.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryWaterSavingsM3 rdf:type rdf:Property ;
    rdfs:label 'Factory Water Savings M3' ;
    rdfs:comment 'Measured annual water consumption reduction in cubic meters achieved at this factory. Factory-level impact contributing to initiative total.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationActualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Actual Completion Date' ;
    rdfs:comment 'Actual date when implementation was completed at this factory. Null if still in progress.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationLead rdf:type rdf:Property ;
    rdfs:label 'Implementation Lead' ;
    rdfs:comment 'Name or identifier of the person responsible for executing the initiative at this factory (factory manager, sustainability coordinator, or project lead).' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationNotes rdf:type rdf:Property ;
    rdfs:label 'Implementation Notes' ;
    rdfs:comment 'Free-text notes capturing factory-specific implementation details, challenges, lessons learned, or contextual information for supplier engagement reporting.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'Date when implementation activities commenced at this specific factory. May differ from the initiative-level start date. Identified in detection phase relationship data.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the initiative implementation at this specific factory. Tracks lifecycle from planning through completion. Identified in detection phase relationship data.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Target Completion Date' ;
    rdfs:comment 'Planned completion date for implementation at this factory. Factory-specific milestone within the broader initiative timeline.' ;
    rdfs:domain ind:FactoryInitiativeImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:influencerSeedingId rdf:type rdf:Property ;
    rdfs:label 'Influencer Seeding Id' ;
    rdfs:comment 'Unique identifier for this influencer seeding record. Primary key.' ;
    rdfs:domain ind:InfluencerSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentDeadline rdf:type rdf:Property ;
    rdfs:label 'Content Deadline' ;
    rdfs:comment 'Target date by which the influencer is expected to create and publish content featuring the seeded products. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfluencerSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentPostUrl rdf:type rdf:Property ;
    rdfs:label 'Content Post Url' ;
    rdfs:comment 'URL of the content post created by the influencer featuring the seeded products, captured once published.' ;
    rdfs:domain ind:InfluencerSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productReturnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Product Return Required Flag' ;
    rdfs:comment 'Indicates whether the influencer is required to return the seeded products after content creation (true for high-value items, false for gifted items). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfluencerSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Granted' ;
    rdfs:comment 'Scope of content usage rights granted to the brand for content created with seeded products (e.g., organic post only, paid amplification allowed, full perpetual rights). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:InfluencerSeeding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influencerInitiativePartnershipId rdf:type rdf:Property ;
    rdfs:label 'Influencer Initiative Partnership Id' ;
    rdfs:comment 'Unique identifier for the influencer-initiative partnership record. Primary key.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualContentDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Actual Content Delivered Count' ;
    rdfs:comment 'Actual number of content pieces delivered by the influencer for this sustainability initiative partnership, tracked against contracted deliverable count.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ambassadorRole rdf:type rdf:Property ;
    rdfs:label 'Ambassador Role' ;
    rdfs:comment 'The specific role the influencer plays in promoting this sustainability initiative (e.g., primary_ambassador, supporting_ambassador, guest_contributor, event_participant). Identified in detection phase relationship data.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeFocusArea rdf:type rdf:Property ;
    rdfs:label 'Initiative Focus Area' ;
    rdfs:comment 'The specific aspect or messaging angle of the sustainability initiative that this influencer partnership emphasizes (e.g., circular_fashion, renewable_energy, water_conservation, ethical_sourcing). Identified in detection phase relationship data.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of this specific influencer-initiative partnership: proposed (under negotiation), contracted (signed but not started), active (currently executing), completed (deliverables fulfilled), cancelled (terminated early).' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Total Engagement Count' ;
    rdfs:comment 'Aggregate engagement (likes, comments, shares, saves) achieved across all content delivered for this specific influencer-initiative partnership.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fee Amount' ;
    rdfs:comment 'Total compensation amount paid to the influencer for this specific sustainability initiative partnership, covering all contracted deliverables.' ;
    rdfs:domain ind:InfluencerInitiativePartnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Unique identifier for this specific defect finding record. Primary key for the inspection_finding association.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedUnitReference rdf:type rdf:Property ;
    rdfs:label 'Affected Unit Reference' ;
    rdfs:comment 'Identifier or reference number of the specific unit(s) in the sample where this defect was found (e.g., sample unit 3 of 32).' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this finding triggered a formal Corrective and Preventive Action (CAPA) process due to severity or recurrence.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectLocationOnProduct rdf:type rdf:Property ;
    rdfs:label 'Defect Location On Product' ;
    rdfs:comment 'The specific location on the garment or product where this defect was observed (e.g., left sleeve seam, collar label, front panel). Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finding Timestamp' ;
    rdfs:comment 'The precise timestamp when this defect was identified and recorded during the inspection event.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'The AQL severity classification assigned to this specific finding (Critical/Major/Minor). May differ from the defect catalog default based on inspector judgment. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRfqLineId rdf:type rdf:Property ;
    rdfs:label 'Material Rfq Line Id' ;
    rdfs:comment 'Unique identifier for this material-RFQ line item record. Primary key.' ;
    rdfs:domain ind:MaterialRfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Awarded Unit Cost' ;
    rdfs:comment 'The final quoted unit cost from the awarded vendor for this material line.' ;
    rdfs:domain ind:MaterialRfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the requested quantity (meter, yard, kilogram, piece, roll, unit).' ;
    rdfs:domain ind:MaterialRfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnitCost rdf:type rdf:Property ;
    rdfs:label 'Target Unit Cost' ;
    rdfs:comment 'The desired or budgeted unit cost for this specific material within this RFQ. Varies by material-RFQ combination based on season, volume, and sourcing strategy.' ;
    rdfs:domain ind:MaterialRfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialComplianceId rdf:type rdf:Property ;
    rdfs:label 'Material Compliance Id' ;
    rdfs:comment 'Unique identifier for this material-standard compliance record. Primary key.' ;
    rdfs:domain ind:MaterialCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingLab rdf:type rdf:Property ;
    rdfs:label 'Testing Lab' ;
    rdfs:comment 'Name or code of the accredited laboratory that performed the compliance testing for this material-standard combination.' ;
    rdfs:domain ind:MaterialCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date on which any granted compliance waiver expires. Null if no waiver granted or waiver is permanent.' ;
    rdfs:domain ind:MaterialCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether a compliance waiver or exception has been granted for this material-standard combination, allowing use despite non-compliance.' ;
    rdfs:domain ind:MaterialCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual membership fee charged to maintain this tier status, if applicable. Zero for free tiers, positive amount for premium paid tiers. Expressed in the program\'s base currency.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:birthdayRewardEnabled rdf:type rdf:Property ;
    rdfs:label 'Birthday Reward Enabled' ;
    rdfs:comment 'Indicates whether members of this tier receive special birthday rewards, discounts, or bonus points. True if birthday benefits are included, false otherwise.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Sequence number controlling the display order of tiers in user interfaces and marketing materials. Lower numbers appear first. Used for consistent tier presentation across channels.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downgradeProtectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Downgrade Protection Enabled' ;
    rdfs:comment 'Indicates whether members are protected from immediate tier downgrade if they fail to meet qualification thresholds. True if grace period or soft landing is provided, false for immediate downgrade.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Early Access Enabled' ;
    rdfs:comment 'Indicates whether members of this tier receive early access to new product launches, seasonal collections, and exclusive sales events. True if early access is granted, false otherwise.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveEventsAccess rdf:type rdf:Property ;
    rdfs:label 'Exclusive Events Access' ;
    rdfs:comment 'Indicates whether members of this tier receive invitations to exclusive brand events, fashion shows, VIP shopping experiences, or member-only gatherings. True if event access is granted, false otherwise.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeShippingEnabled rdf:type rdf:Property ;
    rdfs:label 'Free Shipping Enabled' ;
    rdfs:comment 'Indicates whether members of this tier receive complimentary standard shipping on all orders. True if free shipping is a tier benefit, false otherwise.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invitationOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Invitation Only Flag' ;
    rdfs:comment 'Indicates whether this tier is available only by invitation rather than automatic qualification. True for exclusive VIP tiers requiring brand approval, false for standard qualification-based tiers.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxMembersLimit rdf:type rdf:Property ;
    rdfs:label 'Max Members Limit' ;
    rdfs:comment 'Maximum number of customers allowed in this tier at any given time. Used for exclusive invitation-only tiers. Null for unlimited tiers.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Partner Benefits Description' ;
    rdfs:comment 'Description of benefits provided through partner brands, co-branded programs, or affiliate networks (e.g., hotel upgrades, airline lounge access, dining rewards). Enhances tier value proposition through ecosystem partnerships.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsEarningMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Earning Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning rate for members in this tier (e.g., 1.0 for base tier, 1.5 for silver, 2.0 for gold). Rewards higher-tier members with accelerated points accumulation.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prioritySupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Priority Support Enabled' ;
    rdfs:comment 'Indicates whether members of this tier receive priority customer service through dedicated support channels, faster response times, or concierge services. True if priority support is available, false otherwise.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which the qualification threshold must be met (e.g., 12 months for annual qualification, 3 months for quarterly). Defines the rolling window for tier evaluation.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Amount' ;
    rdfs:comment 'Minimum spend amount required to qualify for or maintain this loyalty tier within the qualification period. Expressed in the program\'s base currency.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationThresholdPoints rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Points' ;
    rdfs:comment 'Minimum loyalty points required to qualify for or maintain this tier within the qualification period. Alternative or complementary to spend-based qualification.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Retention Period Months' ;
    rdfs:comment 'Number of months a member retains this tier status after qualification, regardless of subsequent activity. Provides stability and prevents frequent tier fluctuations.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code representing the loyalty tier (e.g., BRONZE, SILVER, GOLD, PLATINUM, VIP). Used as a business identifier in external systems and customer communications.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierColorHex rdf:type rdf:Property ;
    rdfs:label 'Tier Color Hex' ;
    rdfs:comment 'Brand color associated with this tier in hexadecimal format (e.g., #CD7F32 for bronze, #C0C0C0 for silver, #FFD700 for gold). Used for visual representation in mobile apps, websites, and member cards.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the loyalty tier benefits, privileges, and value proposition. Used for customer education and marketing communications.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierIconUrl rdf:type rdf:Property ;
    rdfs:label 'Tier Icon Url' ;
    rdfs:comment 'URL path to the tier badge or icon image used in digital channels. Provides visual identification of tier status in customer profiles and communications.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Numeric ranking of the tier within the loyalty program hierarchy (e.g., 1=Bronze, 2=Silver, 3=Gold, 4=Platinum). Used for tier comparison and upgrade/downgrade logic.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable display name of the loyalty tier (e.g., Bronze Member, Silver Elite, Gold Premier, Platinum VIP). Used in customer-facing applications and marketing materials.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty tier. Active tiers are available for customer assignment; inactive tiers are no longer offered but may have existing members; deprecated tiers are being phased out; planned tiers are under development.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Reference to the parent brand if this is a sub-brand or brand extension. Null for standalone brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:brandManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Brand Manager Email' ;
    rdfs:comment 'Email address of the brand manager for internal communication and coordination.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandManagerName rdf:type rdf:Property ;
    rdfs:label 'Brand Manager Name' ;
    rdfs:comment 'Name of the individual responsible for managing the brand strategy, marketing, and performance.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary market classification of the brand indicating its positioning and target segment within the apparel and fashion industry.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code used internally to identify the brand in systems, SKUs, and reporting. Typically 2-10 uppercase characters.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed narrative description of the brand\'s identity, heritage, values, and market positioning used for internal reference and external marketing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'The year the brand was established or founded, used for heritage marketing and brand storytelling.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'The date when the brand license agreement expires or is set to be renewed. Null for perpetual or owned brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'The date when the brand license agreement became effective. Applicable only for licensed brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Indicates the ownership and licensing model for the brand (owned outright, licensed from another entity, licensed to partners, or joint venture).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Name of the entity that owns the brand intellectual property if the brand is licensed in. Null for owned brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL or file path to the official brand logo image file used in digital and print materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'The official registered name of the brand as it appears on products, marketing materials, and legal documents.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandles rdf:type rdf:Property ;
    rdfs:label 'Social Media Handles' ;
    rdfs:comment 'JSON or comma-separated string containing the brand\'s official social media account handles across platforms (Instagram, Facebook, Twitter, TikTok, etc.).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the brand indicating whether it is actively marketed, discontinued, or in transition.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifications rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certifications' ;
    rdfs:comment 'Comma-separated list of sustainability and ethical certifications the brand has achieved (e.g., B Corp, Fair Trade Certified, GOTS, OEKO-TEX, bluesign).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'Official marketing tagline or slogan associated with the brand, used in advertising and promotional materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'Primary age demographic range the brand targets, expressed as a range or category (e.g., 18-35, youth, mature).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'Primary gender demographic the brand targets with its product offerings.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Price and quality positioning tier of the brand within the portfolio, used for merchandising and pricing strategy.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationCountry rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Country' ;
    rdfs:comment 'Three-letter ISO country code representing the primary jurisdiction where the brand trademark is registered.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official trademark registration number issued by the relevant intellectual property office for the brand name and logo.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceBookId rdf:type rdf:Property ;
    rdfs:label 'Base Price Book Id' ;
    rdfs:comment 'Reference to parent or base price book when this price book is derived or inherits pricing rules from another.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:parentVersionId rdf:type rdf:Property ;
    rdfs:label 'Parent Version Id' ;
    rdfs:comment 'Reference to the previous version of this price book, enabling version history tracking and audit trails.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:initialMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Percentage' ;
    rdfs:comment 'Initial markup percentage representing the difference between cost and original retail price for items in this price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintainedMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Maintained Markup Percentage' ;
    rdfs:comment 'Maintained markup percentage after markdowns, representing actual margin achieved for items in this price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage' ;
    rdfs:comment 'Default markdown percentage applied across items in this price book for promotional or clearance pricing.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Externally-known unique business identifier for the price book used in merchandising systems and reporting.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book indicating its primary merchandising purpose and pricing strategy application.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Boolean flag indicating whether pricing changes in this price book require management approval before activation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rule applied for rounding calculated prices in this price book to achieve psychological pricing or operational simplicity.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusive rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive' ;
    rdfs:comment 'Boolean flag indicating whether prices in this price book include tax or are exclusive of tax.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the physical location or facility where this inventory pool is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApparelFashion .

ind:organizationId rdf:type rdf:Property ;
    rdfs:label 'Organization Id' ;
    rdfs:comment 'Reference to the business organization or entity that owns or manages this inventory pool.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:atpCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Atp Calculation Method' ;
    rdfs:comment 'The method used to calculate Available to Promise inventory for this pool considering future supply and demand.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Ats Calculation Method' ;
    rdfs:comment 'The method used to calculate Available to Sell inventory for this pool (real-time, batch processing, scheduled updates).' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'The frequency at which cycle counts are performed for inventory accuracy verification in this pool.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPoolCode rdf:type rdf:Property ;
    rdfs:label 'External Pool Code' ;
    rdfs:comment 'External system identifier for this inventory pool in source WMS or ERP systems.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled Flag' ;
    rdfs:comment 'Indicates whether this inventory pool is available for omnichannel fulfillment (ship-from-store, buy-online-pickup-in-store, etc.).' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poolCategory rdf:type rdf:Property ;
    rdfs:label 'Pool Category' ;
    rdfs:comment 'Business category indicating ownership and management model of the inventory pool.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Unique business identifier code for the inventory pool used across systems and business communications.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name of the inventory pool for business identification and reporting purposes.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the inventory pool based on facility type and operational model.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Number of days of safety stock maintained in this pool to buffer against demand variability and supply disruptions.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Threshold Pct' ;
    rdfs:comment 'Target utilization percentage threshold that triggers replenishment or rebalancing actions.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'The warehouse management system that manages this inventory pool (Manhattan Associates, SAP EWM, Blue Yonder, etc.).' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wosTargetWeeks rdf:type rdf:Property ;
    rdfs:label 'Wos Target Weeks' ;
    rdfs:comment 'Target weeks of supply to maintain in this inventory pool based on demand forecasts.' ;
    rdfs:domain ind:InventoryPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostFactor rdf:type rdf:Property ;
    rdfs:label 'Boost Factor' ;
    rdfs:comment 'Numeric multiplier applied to product ranking scores when the rule boosts product visibility. Higher values increase prominence.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionLogic rdf:type rdf:Property ;
    rdfs:label 'Condition Logic' ;
    rdfs:comment 'Business logic or criteria that must be met for the merchandising rule to be triggered and applied.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'Indicates whether the merchandising rule applies globally across all markets and channels or is limited to specific targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxProductsDisplayed rdf:type rdf:Property ;
    rdfs:label 'Max Products Displayed' ;
    rdfs:comment 'Maximum number of products that can be displayed when this merchandising rule is applied to a placement zone.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceMetricTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Target' ;
    rdfs:comment 'Primary key performance indicator (KPI) that the merchandising rule is designed to optimize.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementZone rdf:type rdf:Property ;
    rdfs:label 'Placement Zone' ;
    rdfs:comment 'Specific zone or slot on the digital storefront where the rule controls product placement (e.g., homepage hero, category top, PDP recommendations).' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Secondary classification indicating how the rule is triggered or managed within the merchandising system.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the merchandising rule used in external systems and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the merchandising rule for display and identification purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the merchandising rule indicating its primary purpose in the digital storefront.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Three-letter ISO country code indicating the geographic market where the rule applies. Multiple geographies stored as comma-separated codes.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'Customer segment or persona that the merchandising rule is designed to target for personalization purposes.' ;
    rdfs:domain ind:MerchandisingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCycleId rdf:type rdf:Property ;
    rdfs:label 'Parent Cycle Id' ;
    rdfs:comment 'Identifier of the parent allocation cycle if this cycle is a revision or sub-cycle of another. Nullable for top-level cycles.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:sourceCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Center Id' ;
    rdfs:comment 'Identifier of the primary cost center from which costs are being allocated.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date when the allocation cycle execution was completed. Nullable if not yet completed.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The basis or driver used for allocation calculations (e.g., headcount, square footage, revenue, units sold).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationFrequency rdf:type rdf:Property ;
    rdfs:label 'Allocation Frequency' ;
    rdfs:comment 'The frequency at which this allocation cycle is executed (e.g., monthly, quarterly, annual).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationScope rdf:type rdf:Property ;
    rdfs:label 'Allocation Scope' ;
    rdfs:comment 'The organizational scope to which this allocation cycle applies (e.g., global, regional, divisional).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the allocation cycle, used for external reference and reporting.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Descriptive name of the allocation cycle, typically indicating the period or purpose (e.g., Q1 2024 Cost Allocation, Annual Budget Allocation).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the allocation cycle indicating its purpose within the financial planning process.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this allocation cycle is executed through automated processes (True) or requires manual intervention (False).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Allocation Amount' ;
    rdfs:comment 'The total monetary amount being allocated in this cycle across all cost centers, products, or channels.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Zone Manager Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for managing operations within this zone.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aisleRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Aisle Range End' ;
    rdfs:comment 'Ending aisle identifier for the zone\'s physical location range within the warehouse.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeStart rdf:type rdf:Property ;
    rdfs:label 'Aisle Range Start' ;
    rdfs:comment 'Starting aisle identifier for the zone\'s physical location range within the warehouse.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Physical floor or level number within the facility where the zone is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the zone is certified and equipped to handle hazardous materials according to regulatory requirements.' ;
    rdfs:domain ind:Zone ;
    rdf:type owl:DatatypeProperty ;
