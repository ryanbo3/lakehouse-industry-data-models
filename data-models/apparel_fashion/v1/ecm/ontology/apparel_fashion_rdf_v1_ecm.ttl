    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiMicrobial rdf:type rdf:Property ;
    rdfs:label 'Anti Microbial' ;
    rdfs:comment 'Indicates whether the fabric has been treated with anti-microbial agents to inhibit bacterial growth.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breathabilityRating rdf:type rdf:Property ;
    rdfs:label 'Breathability Rating' ;
    rdfs:comment 'Qualitative assessment of the fabric\'s air permeability and moisture vapor transmission.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorfastnessRating rdf:type rdf:Property ;
    rdfs:label 'Colorfastness Rating' ;
    rdfs:comment 'Assessment of the fabric\'s resistance to color fading or bleeding during washing, light exposure, and wear.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerYardUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Yard Usd' ;
    rdfs:comment 'The standard procurement cost of the fabric per linear yard, used for costing and margin analysis.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dyeingMethod rdf:type rdf:Property ;
    rdfs:label 'Dyeing Method' ;
    rdfs:comment 'The method used to apply color to the fabric.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flameRetardant rdf:type rdf:Property ;
