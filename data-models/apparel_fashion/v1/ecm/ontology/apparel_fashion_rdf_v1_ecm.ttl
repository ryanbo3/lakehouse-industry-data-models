    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'The classification of the organization based on its structural role within the enterprise.' ;
