    rdfs:range xsd:string .

ind:affectedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Affected Sku Count' ;
    rdfs:comment 'Number of distinct SKUs impacted by the finding. Used to quantify the scope of product-related compliance issues.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Primary type of business impact if the finding is not remediated. Categories include reputational damage, financial penalties, operational disruption, legal liability, or supply chain interruption.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the user or auditor who verified remediation and closed the finding. Provides accountability for closure decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the finding was verified as remediated and officially closed. Null if the finding is still open or in remediation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Recommended corrective action to remediate the finding and prevent recurrence. Describes specific steps the audited entity must take to achieve compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated remediation cost. Ensures consistent financial reporting across global operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed and verified. Driven by severity level and regulatory timelines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level to which the finding has been escalated within the organization. Reflects the governance and oversight required based on severity and business impact.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action, including capital expenditure, training, process changes, and verification activities. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceFilePath rdf:type rdf:Property ;
    rdfs:label 'Evidence File Path' ;
    rdfs:comment 'File path or URI to supporting evidence documentation such as photographs, documents, or audit reports that substantiate the finding.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'High-level classification of the non-conformance area. Categories include labor practices, workplace safety, environmental impact, product quality, ethical sourcing, and trade compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date on which the non-conformance was observed and documented during the audit. Represents the business event timestamp for the finding.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business-readable unique identifier for the finding within the audit context. Typically follows a pattern such as audit code followed by sequential number.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle state of the finding. Tracks progression from identification through remediation to closure.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the finding record. Tracks changes throughout the finding lifecycle from identification to closure.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean indicator of whether this finding is a repeat of a previously identified and supposedly remediated non-conformance. True indicates a recurring issue requiring escalation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority or governing body to which the finding must be reported, if applicable. Examples include FTC, CPSC, OSHA, EPA, or international equivalents.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulation, standard, code of conduct clause, or policy requirement that was violated. May reference FTC labeling rules, CPSC safety standards, FLA workplace standards, OEKO-TEX criteria, or internal codes of conduct.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this finding must be reported to a regulatory authority or governing body. True for findings that trigger mandatory disclosure obligations.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk assessment score for the finding, typically on a scale of 0-100. Combines severity, likelihood of harm, and potential business impact.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Analysis of the underlying reason or systemic issue that led to the non-conformance. Identifies whether the cause was procedural, training-related, resource-based, or systemic.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Classification of the finding\'s impact and urgency. Critical findings require immediate action, major findings require corrective action plans, minor findings are improvement opportunities, and observations are advisory notes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardClause rdf:type rdf:Property ;
    rdfs:label 'Standard Clause' ;
    rdfs:comment 'Specific clause, section, or article number within the referenced standard or regulation that was not met. Enables precise traceability to compliance requirements.' ;
    rdfs:domain ind:ComplianceAuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was effectively implemented. Options include document review, on-site re-inspection, photographic evidence submission, worker interviews, or full re-audit.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process, including evidence reviewed, observations made, and rationale for verification decision.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current status of the verification process for the corrective action. Tracks whether remediation has been confirmed as effective.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the specific non-conformance observed during the audit. Includes factual observations, evidence collected, and context of the violation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Id' ;
    rdfs:comment 'Unique identifier for the compliance certification record. Primary key for the compliance certification entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCertification .

ind:materialCertificationId rdf:type rdf:Property ;
    rdfs:label 'Material Certification Id' ;
    rdfs:comment 'Foreign key linking to sustainability.material_certification. Business justification: Compliance certifications (OEKO-TEX, GOTS, BCI) are often material-specific sustainability certifications. Linking enables unified certification tracking across compliance and sustainability reporting' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialCertification .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to product.material. Business justification: Material certifications (GOTS for organic cotton, bluesign for sustainable fabrics, recycled content certifications) are tracked at material level. Sourcing teams obtain material certifications from s' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:styleId rdf:type rdf:Property ;
    rdfs:label 'Style Id' ;
    rdfs:comment 'Foreign key linking to product.style. Business justification: Certifications (GOTS organic, bluesign, OEKO-TEX, Fair Trade) are often style-specific. Sustainability/compliance teams obtain certifications for specific styles to support marketing claims and meet r' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Style .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'The URL or file path to the digital copy of the certification certificate document. Provides direct access to the official certificate for verification, audit, and reporting purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate number or identifier issued by the certifying body. This is the externally-known business identifier for the certification (e.g., OEKO-TEX certificate number, GOTS license number).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCategory rdf:type rdf:Property ;
    rdfs:label 'Certification Category' ;
    rdfs:comment 'The high-level category or domain of the certification. Groups certifications by their primary focus area: product safety (e.g., OEKO-TEX Standard 100), sustainability (e.g., bluesign, Cradle to Cradle), ethical manufacturing (e.g., WRAP, FLA, SA8000), quality management (e.g., ISO 9001), environmental management (e.g., ISO 14001), occupational health and safety (e.g., ISO 45001), social accountability (e.g., SA8000), organic standards (e.g., GOTS, OCS), recycled content (e.g., GRS, RCS), or chemical safety (e.g., OEKO-TEX, bluesign). [ENUM-REF-CANDIDATE: product_safety|sustainability|ethical_manufacturing|quality_management|environmental_management|occupational_health_safety|social_accountability|organic|recycled_content|chemical_safety — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'The scope or level at which the certification applies. Indicates whether the certification covers a specific product or product line (product), a manufacturing facility or site (facility), the entire organization (organization), a supplier entity (supplier), a specific material or raw material (material), or a production process (process).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or standard of certification. Classifies the certification by its governing standard or program (e.g., OEKO-TEX Standard 100 for textile safety, GOTS for organic textiles, BCI for sustainable cotton, ISO 9001 for quality management, ISO 14001 for environmental management, ISO 45001 for occupational health and safety, WRAP for ethical manufacturing, FLA for labor standards, SA8000 for social accountability, bluesign for sustainable textile production, Cradle to Cradle for circular economy design, GRS for recycled content verification). [ENUM-REF-CANDIDATE: OEKO-TEX Standard 100|OEKO-TEX STEP|GOTS|BCI|GRS|ISO 9001|ISO 14001|ISO 45001|WRAP|FLA|SA8000|bluesign|Cradle to Cradle|Fair Trade|Organic Content Standard|Recycled Claim Standard — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code for the country where the certified entity is located (e.g., USA, CHN, IND, BGD, VNM, TUR). Used for geographic analysis and compliance reporting by jurisdiction.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityLocation rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Location' ;
    rdfs:comment 'The geographic location (city, state/province, country) of the certified entity. For facility or supplier certifications, this identifies the physical site covered by the certification. For organization-level certifications, this may be the headquarters or registered address.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityName rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Name' ;
    rdfs:comment 'The name of the entity (organization, facility, supplier, or product line) that holds the certification. This is the legal or business name as it appears on the certificate.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityType rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Type' ;
    rdfs:comment 'The type of entity that holds the certification. Classifies whether the certified entity is an internal facility owned by Apparel Fashion (internal_facility), an external supplier or vendor (external_supplier), a contract manufacturer or CMT partner (contract_manufacturer), a raw material or component supplier (raw_material_supplier), a specific product line or SKU group (product_line), or the corporate entity itself (corporate_entity).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedMaterialsList rdf:type rdf:Property ;
    rdfs:label 'Certified Materials List' ;
    rdfs:comment 'A comma-separated or structured list of raw materials, fabrics, or components covered by this certification. For material-scope certifications (e.g., organic cotton, recycled polyester), this identifies which specific materials are certified. May include material codes, fiber types, or material categories.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProductsList rdf:type rdf:Property ;
    rdfs:label 'Certified Products List' ;
    rdfs:comment 'A comma-separated or structured list of product categories, SKUs, or product lines covered by this certification. For product-scope certifications, this identifies which specific products or product families are certified under this certificate. May reference product codes, material types, or product categories as defined in the certification scope document.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Compliance Jurisdiction' ;
    rdfs:comment 'The regulatory jurisdiction or geographic region for which this certification provides compliance coverage (e.g., European Union, United States, Global). Some certifications are jurisdiction-specific (e.g., CPSC compliance for US market), while others are globally recognized.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the certification expires and is no longer valid unless renewed. Nullable for certifications without a fixed expiration (e.g., one-time product certifications that do not require renewal).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this certification record is currently active and in use (true) or has been archived or soft-deleted (false). Used for record lifecycle management and filtering active certifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the certification was officially issued or granted by the certifying body. Represents the effective start date of the certification validity period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The name of the organization, certification body, or accredited auditor that issued the certification (e.g., OEKO-TEX Association, Control Union, Bureau Veritas, SGS, TÜV, Intertek). This is the authoritative source of the certification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Accreditation Number' ;
    rdfs:comment 'The accreditation number or identifier of the issuing body, demonstrating that the certifying organization is itself accredited by a recognized accreditation authority (e.g., ANAB, UKAS, DAkkS). Ensures the legitimacy and authority of the issuing body.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next surveillance or renewal audit. Used for compliance calendar management and proactive audit planning to ensure continuous certification validity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or context about the certification. May include details about audit findings, corrective actions taken, special conditions, or other relevant information not captured in structured fields.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicVerificationUrl rdf:type rdf:Property ;
    rdfs:label 'Public Verification Url' ;
    rdfs:comment 'The URL to a public online verification portal where the certification can be independently verified by customers, regulators, or other stakeholders (e.g., OEKO-TEX certificate verification portal, GOTS public database). Many certification bodies provide online verification tools.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the renewal application was submitted to the certifying body. Tracks the initiation of the renewal process for certifications that require periodic renewal.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'The current status of the certification renewal process. Indicates whether renewal is not required for this certification type (not_required), renewal is upcoming but not yet initiated (pending), renewal application or audit is in progress (in_progress), renewal has been successfully completed (completed), or renewal is overdue and the certification may lapse (overdue).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'The email address of the responsible party for this certification. Used for notifications, renewal reminders, and audit coordination communications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'The name of the individual or team within Apparel Fashion responsible for managing this certification, including renewal tracking, audit coordination, and compliance maintenance. This is the internal owner or steward of the certification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'The version or edition of the certification standard under which the certification was issued (e.g., OEKO-TEX Standard 100 version 2023, GOTS version 6.0, ISO 9001:2015). Standards are periodically updated, and this field tracks which version applies to this certification.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the compliance document record. Primary key for the compliance document entity.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collaborationId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Id' ;
    rdfs:comment 'Foreign key linking to design.design_collaboration. Business justification: Collaboration contracts, IP rights agreements, exclusivity terms, and compliance documentation stored as compliance_documents linked to collaboration. Supports legal compliance and contract management' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collaboration .

ind:conceptId rdf:type rdf:Property ;
    rdfs:label 'Concept Id' ;
    rdfs:comment 'Foreign key linking to design.concept. Business justification: Sustainability certifications, IP agreements, and compliance documentation attached to design concepts for approval workflows. Supports concept-stage compliance review before investment in detailed de' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Concept .

ind:printDesignId rdf:type rdf:Property ;
    rdfs:label 'Print Design Id' ;
    rdfs:comment 'Foreign key linking to design.print_design. Business justification: Licensed print designs require copyright agreements, usage rights documentation, and royalty terms stored as compliance documents. Essential for IP compliance and legal audit trails for licensed artwo' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrintDesign .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Reference to the regulatory filing record this document supports or confirms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:supersedesDocumentId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Document Id' ;
    rdfs:comment 'Reference to the previous version of the compliance document that this version replaces or supersedes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Additional notes or instructions regarding access restrictions, handling requirements, or special considerations for the compliance document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions for the compliance document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Eligible Date' ;
    rdfs:comment 'Calculated date when the document becomes eligible for destruction based on retention period and applicable regulations.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Official date of the document as indicated on the document itself, representing when it was created or issued.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and key findings or conclusions.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Business identifier or reference number assigned to the compliance document for tracking and retrieval purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSource rdf:type rdf:Property ;
    rdfs:label 'Document Source' ;
    rdfs:comment 'Origin or provider of the compliance document indicating who created or issued it.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the compliance document in the review and approval workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the compliance document indicating its purpose and content category.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the compliance document becomes valid or enforceable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the compliance document expires or is no longer valid, applicable for time-limited certifications and approvals.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the compliance document indicating the file type and extension. [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|JPG|PNG|TIFF|XML|CSV — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URI path where the physical compliance document file is stored in the document management system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the compliance document file measured in kilobytes for storage management and tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Regulatory agency, certification body, or standards organization that governs or issued the compliance document.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash value of the document file to ensure integrity and detect tampering or unauthorized modifications.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrganization rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization' ;
    rdfs:comment 'Name of the organization, agency, or entity that issued or authored the compliance document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction to which the compliance document applies, using ISO 3166-1 alpha-3 country codes or regional identifiers.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Case Number' ;
    rdfs:comment 'Case or matter number associated with the legal hold placed on the compliance document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicator of whether the compliance document is subject to a legal hold and must be preserved for litigation or investigation purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the compliance document, applicable for multi-page documents.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Category of products or materials that the compliance document applies to or certifies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework, standard, or compliance program that the document supports or evidences.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for managing and maintaining the compliance document.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the compliance document must be retained per regulatory or legal requirements before eligible for destruction.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of keywords or tags for categorization, search, and retrieval of the compliance document.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title or name of the compliance document for identification and cataloging.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Date when the compliance document was uploaded or ingested into the compliance repository system.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the compliance document was verified for authenticity and accuracy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person who verified the authenticity and accuracy of the compliance document.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for the compliance document to track revisions and updates over time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Unique identifier for the compliance incident record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:colorwayDevelopmentId rdf:type rdf:Property ;
    rdfs:label 'Colorway Development Id' ;
    rdfs:comment 'Foreign key linking to design.colorway_development. Business justification: Colorway-specific compliance failures (azo dye violations, heavy metal content) require linking incident to exact colorway for targeted remediation. Supports colorway-level recalls and prevents reuse ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColorwayDevelopment .

ind:esgDisclosureMetricId rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Metric Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_disclosure_metric. Business justification: Material compliance incidents (fines, sanctions, labor violations) require ESG disclosure under GRI 419, SASB, and SEC climate rules. Linking enables automated incident-to-disclosure workflows, ensure' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgDisclosureMetric .

ind:relatedIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Id' ;
    rdfs:comment 'Identifier of a related or parent compliance incident, used to link recurring or cascading incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:sketchId rdf:type rdf:Property ;
    rdfs:label 'Sketch Id' ;
    rdfs:comment 'Foreign key linking to design.design_sketch. Business justification: Compliance incidents (restricted substance violations, safety failures) often trace to original design decisions. Links incident to design sketch for root cause analysis and prevents recurrence in fut' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sketch .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Compliance incidents (product recalls, safety violations, customer complaints) are tracked at SKU level for traceability. Quality/compliance teams track incidents at SKU level for corrective action, b' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Penalty Amount' ;
    rdfs:comment 'Actual monetary penalty or fine imposed by regulatory authorities as a result of the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Affected Business Unit' ;
    rdfs:comment 'Name or code of the business unit, division, or department where the compliance incident occurred.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedIndividualsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Individuals Count' ;
    rdfs:comment 'Number of individuals (customers, employees, or other data subjects) affected by the incident, applicable for data privacy breaches.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Affected Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction or regulatory region where the incident occurred. Uses 3-letter ISO country codes or multi-country region codes.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedInvestigator rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator' ;
    rdfs:comment 'Name or identifier of the compliance officer, auditor, or investigator assigned to lead the incident investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationImpacted rdf:type rdf:Property ;
    rdfs:label 'Certification Impacted' ;
    rdfs:comment 'Name of industry certification or accreditation that may be impacted or at risk due to the incident (e.g., OEKO-TEX, GOTS, WRAP, FLA).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final summary notes documenting the resolution, lessons learned, and any outstanding follow-up actions at the time of incident closure.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToExecutive rdf:type rdf:Property ;
    rdfs:label 'Escalated To Executive' ;
    rdfs:comment 'Indicates whether the incident was escalated to executive leadership or board level due to severity or regulatory significance.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the incident including potential fines, penalties, remediation costs, and business disruption costs.' ;
    rdfs:domain ind:ApparelFashion ;
