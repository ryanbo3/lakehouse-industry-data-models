ind:affectedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Affected Product Category' ;
    rdfs:comment 'Product category or line impacted by the finding, if applicable. Relevant for quality, safety, or labeling non-conformances that affect specific merchandise.' ;
