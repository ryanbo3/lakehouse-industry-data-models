ind:priceControlMethod rdf:type rdf:Property ;
    rdfs:label 'Price Control Method' ;
    rdfs:comment 'The method used to control and update inventory prices within this valuation area (standard price, moving average price, or manual).' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyLogisticsProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Provider' ;
    rdfs:comment 'Name of the third-party logistics provider managing inventory within this valuation area, if applicable.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Area Code' ;
    rdfs:comment 'Business identifier code for the valuation area used in operational systems and reporting.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCategory rdf:type rdf:Property ;
    rdfs:label 'Valuation Category' ;
    rdfs:comment 'Additional classification for grouping valuation areas by business segment, product category, or operational model.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Valuation Control Indicator' ;
    rdfs:comment 'Indicates whether inventory valuation is controlled centrally at company code level, decentralized at plant level, or hybrid.' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Warehouse Management System' ;
    rdfs:comment 'The warehouse management system used to manage inventory operations within this valuation area (e.g., Manhattan Associates, SAP EWM).' ;
    rdfs:domain ind:ValuationArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
