# --- Attribute Properties ---
ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Unique identifier for the compliance or ethical manufacturing audit record. Primary key for the audit entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_obligation. Business justification: Audits are conducted to verify compliance with specific obligations (e.g., GOTS audit verifies organic cotton obligation). This FK links the audit to the obligation being verified. audit_program is ke' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:productionFactoryId rdf:type rdf:Property ;
    rdfs:label 'Production Factory Id' ;
    rdfs:comment 'Identifier of the facility (factory, warehouse, distribution center, or supplier site) where the audit was conducted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionFactory .

ind:supplierEsgAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supplier Esg Assessment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.supplier_esg_assessment. Business justification: Social compliance audits (WRAP, BSCI, SA8000) and ESG assessments often cover same facilities on overlapping schedules. Linking enables consolidated supplier risk profiles, avoids duplicate audit sche' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierEsgAssessment .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Identifier of the supplier or vendor organization that owns or operates the audited facility. Links the audit to the supplier master record for supply chain compliance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:approvedForProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Production Flag' ;
    rdfs:comment 'Boolean flag indicating whether the facility is approved for production based on audit results. False if critical findings or zero-tolerance violations were identified. Used in factory approval workflows and sourcing decisions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date on which the audit was conducted or completed. Primary business event timestamp for the audit record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique audit reference number assigned by the auditing organization or internal compliance team. Used for tracking and reporting purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific areas, processes, departments, or compliance domains covered during the audit. May include production lines, warehousing operations, chemical management, worker dormitories, or specific regulatory requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Tracks the audit from scheduling through completion and review stages.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its primary focus area: social compliance (labor practices), environmental compliance (sustainability), quality assurance, safety standards, or combined multi-disciplinary audit.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor or audit firm responsible for conducting the audit. Confidential business information for audit integrity and accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the auditing organization, firm, or certification body that performed the audit. Confidential business information.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor conducting the audit: internal (company compliance team), third-party (independent audit firm), or certification body (accredited certification organization).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the certification granted by this audit expires. Applicable for certification-based audit programs. Used for compliance calendar management and recertification planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Certification status resulting from the audit for programs that grant certification (e.g., WRAP, SA8000, OEKO-TEX). Indicates whether the facility achieved, maintained, or lost certification based on audit results.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Percentage of audit criteria or checkpoints that the facility met or passed. Calculated as (compliant items / total items audited) * 100.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which the facility must submit a formal corrective action plan addressing audit findings. Part of the remediation workflow and compliance tracking process.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether corrective action is required based on audit findings. True if any critical, major, or actionable findings were identified that require formal corrective action plans.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees, travel expenses, and administrative costs. Confidential financial information used for compliance program budgeting and cost allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the facility where the audit was conducted. Used for geographic compliance reporting and regional risk analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the audit record was first created in the system. Part of audit trail for data governance and compliance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or zero-tolerance violations identified during the audit. Critical findings typically require immediate corrective action and may result in facility suspension.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the on-site audit activities concluded. Used to calculate audit duration and resource allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
