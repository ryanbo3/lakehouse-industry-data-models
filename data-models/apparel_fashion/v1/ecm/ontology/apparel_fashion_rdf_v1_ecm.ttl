    rdfs:comment 'Primary type of retail fixture or display unit this planogram is designed for.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorSpaceSqm rdf:type rdf:Property ;
