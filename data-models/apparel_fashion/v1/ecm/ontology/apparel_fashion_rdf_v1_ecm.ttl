ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Unique business identifier code assigned to the fit model for external reference and tracking across quality processes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:neckMeasurementCm rdf:type rdf:Property ;
