    rdfs:comment 'The time difference in hours between planned and actual milestone timestamp, used for Service Level Agreement (SLA) compliance tracking. Positive values indicate delay, negative values indicate early arrival.' ;
    rdfs:domain ind:ShipmentMilestone ;
