    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Boolean flag indicating whether this pay period is designated for payroll adjustments or corrections (True/False).' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEnd rdf:type rdf:Property ;
    rdfs:label 'Is Year End' ;
    rdfs:comment 'Boolean flag indicating whether this is the final pay period of the fiscal or calendar year (True/False).' ;
