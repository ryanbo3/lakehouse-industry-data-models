ind:waterResistance rdf:type rdf:Property ;
    rdfs:label 'Water Resistance' ;
    rdfs:comment 'Indicates whether the fabric has been treated or constructed to resist water penetration.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightOzPerSqYd rdf:type rdf:Property ;
    rdfs:label 'Weight Oz Per Sq Yd' ;
    rdfs:comment 'The weight of the fabric measured in ounces per square yard, commonly used in North American markets.' ;
    rdfs:domain ind:FabricType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedById rdf:type rdf:Property ;
    rdfs:label 'Approved By Id' ;
    rdfs:comment 'Reference to the merchandising manager or executive who approved this planogram for deployment.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageUnitRetailUsd rdf:type rdf:Property ;
    rdfs:label 'Average Unit Retail Usd' ;
    rdfs:comment 'Average unit retail price in USD of products included in this planogram, used for sales forecasting.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Integration Enabled' ;
    rdfs:comment 'Indicates whether this planogram includes digital display elements, QR codes, or interactive technology.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixtureType rdf:type rdf:Property ;
