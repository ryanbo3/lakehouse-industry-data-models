ind:parentChannelId rdf:type rdf:Property ;
    rdfs:label 'Parent Channel Id' ;
    rdfs:comment 'Reference to a parent channel if this channel is a sub-channel or variant within a hierarchical channel structure. Null for top-level channels.' ;
    rdfs:domain ind:Channel ;
