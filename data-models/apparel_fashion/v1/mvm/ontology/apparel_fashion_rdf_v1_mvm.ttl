    rdfs:range xsd:decimal .

ind:targetSellThroughRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Percentage' ;
    rdfs:comment 'Target sell-through rate percentage for this division, calculated as units sold / units received * 100.' ;
