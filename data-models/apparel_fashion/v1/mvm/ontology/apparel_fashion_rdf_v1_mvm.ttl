ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'High-level categorization of the channel by operational medium: physical (brick-and-mortar), digital (online), or omnichannel (integrated).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed business description of the channel, including its purpose, target customer segment, and operational characteristics.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel in the merchandising system lifecycle.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'Primary method used to fulfill customer orders in this channel: ship from store, ship from distribution center, in-store pickup, drop-ship, or mixed.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Visibility Flag' ;
    rdfs:comment 'Indicates whether real-time inventory levels are visible to customers in this channel (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Eligible' ;
    rdfs:comment 'Indicates whether purchases made through this channel are eligible for loyalty program points and rewards (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownPolicy rdf:type rdf:Property ;
    rdfs:label 'Markdown Policy' ;
    rdfs:comment 'Markdown policy governing price reductions in this channel to optimize sell-through rate (STR) and inventory turnover.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled' ;
    rdfs:comment 'Indicates whether this channel is integrated into the omnichannel customer experience (True) or operates independently (False).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Accepted' ;
    rdfs:comment 'Comma-separated list of payment methods accepted in this channel (e.g., credit card, debit card, digital wallet, cash, gift card).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this channel operates seasonally (True) or year-round (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetInitialMarkupPercent rdf:type rdf:Property ;
    rdfs:label 'Target Initial Markup Percent' ;
    rdfs:comment 'Target Initial Markup percentage for merchandise sold through this channel, used in Open-to-Buy (OTB) budget planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMaintainedMarkupPercent rdf:type rdf:Property ;
    rdfs:label 'Target Maintained Markup Percent' ;
    rdfs:comment 'Target Maintained Markup percentage after markdowns, used to measure pricing effectiveness and margin preservation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Region Id' ;
    rdfs:comment 'Reference to the parent region in a hierarchical region structure, enabling multi-level geographic or organizational rollups.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:aurTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Aur Target Amount' ;
    rdfs:comment 'Target average unit retail price for merchandise sold in this region, used for assortment planning and pricing strategy.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target gross margin return on investment ratio for this region, measuring profitability of inventory investment.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imuTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Imu Target Percent' ;
    rdfs:comment 'Target initial markup percentage for merchandise in this region, representing the difference between cost and initial retail price.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEcommerceEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Enabled' ;
    rdfs:comment 'Indicates whether e-commerce sales channels are active and operational in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWholesaleEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Wholesale Enabled' ;
    rdfs:comment 'Indicates whether wholesale distribution partnerships are active in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Market Size Category' ;
    rdfs:comment 'Classification of the region based on market size and maturity for strategic planning and resource allocation.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionDescription rdf:type rdf:Property ;
    rdfs:label 'Region Description' ;
    rdfs:comment 'Detailed description of the region including its scope, coverage, and business purpose.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLevel rdf:type rdf:Property ;
    rdfs:label 'Region Level' ;
    rdfs:comment 'Numeric level in the region hierarchy (e.g., 1=Global, 2=Continental, 3=Country, 4=State/Province, 5=District).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionStatus rdf:type rdf:Property ;
    rdfs:label 'Region Status' ;
    rdfs:comment 'Current lifecycle status of the region indicating whether it is actively used in business operations.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the region based on its business purpose (geographic, sales, merchandising, distribution, operational, administrative).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting region-specific regulatory requirements, trade restrictions, or compliance considerations.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Target Amount' ;
    rdfs:comment 'Annual sales target amount set for this region, used for performance measurement and planning.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonCalendarType rdf:type rdf:Property ;
    rdfs:label 'Season Calendar Type' ;
    rdfs:comment 'Seasonal calendar pattern used for merchandising planning in this region (e.g., northern hemisphere follows spring/summer/fall/winter).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackAllocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Fallback Allocation Rule Id' ;
    rdfs:comment 'Self-referencing FK on allocation_rule (fallback_allocation_rule_id)' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The foundational metric or data source used to drive allocation decisions (inventory levels, demand signals, capacity constraints, historical sales, forecast, manual override).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of available inventory or capacity to allocate when using proportional allocation logic (0.00 to 100.00).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationScope rdf:type rdf:Property ;
    rdfs:label 'Allocation Scope' ;
    rdfs:comment 'The organizational or geographic scope to which this allocation rule applies (global, regional, country-level, channel-specific, store-level, warehouse, customer segment).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderHandling rdf:type rdf:Property ;
    rdfs:label 'Backorder Handling' ;
    rdfs:comment 'Defines how this allocation rule handles backorder scenarios (allow backorders, prevent backorders, allow partial backorders).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelFilter rdf:type rdf:Property ;
    rdfs:label 'Channel Filter' ;
    rdfs:comment 'Sales channel(s) to which this allocation rule applies (Direct-to-Consumer, wholesale, retail stores, e-commerce, marketplace, or all channels).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'Frequency at which this allocation rule is scheduled to execute (real-time, hourly, daily, weekly, on-demand).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Identifier for this allocation rule in the source system of record, used for integration and reconciliation.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionFilter rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Filter' ;
    rdfs:comment 'Geographic region(s) to which this allocation rule applies. Null indicates rule applies globally.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Timestamp when this allocation rule was last executed in an allocation run.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Allocation Quantity' ;
    rdfs:comment 'Maximum quantity cap that can be allocated under this rule. Used to prevent over-concentration of inventory.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Allocation Quantity' ;
    rdfs:comment 'Minimum quantity threshold that must be allocated when this rule is applied. Prevents fractional or uneconomical allocations.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether users are permitted to manually override allocations generated by this rule (true = overrides allowed, false = system-enforced).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Method for rounding fractional allocation quantities (round up, round down, round to nearest, or no rounding).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the allocation rule, used for external reference and integration.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the allocation rule logic, business purpose, and application context.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the allocation rule describing its purpose.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Business owner or team responsible for maintaining and governing this allocation rule.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the allocation rule (active and in use, inactive, draft/pending approval, temporarily suspended, archived).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the allocation rule methodology (proportional distribution, priority-based, round-robin, geographic, channel-based, customer tier, product category).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version number of this allocation rule, incremented with each modification to support change tracking and audit.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Reserve Percentage' ;
    rdfs:comment 'Percentage of inventory to reserve as safety stock and exclude from allocation calculations (0.00 to 100.00).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemOfRecord rdf:type rdf:Property ;
    rdfs:label 'System Of Record' ;
    rdfs:comment 'Source system where this allocation rule is defined and maintained (e.g., SAP S/4HANA, OMS, WMS).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedMarkerId rdf:type rdf:Property ;
    rdfs:label 'Revised Marker Id' ;
    rdfs:comment 'Self-referencing FK on marker (revised_marker_id)' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Marker .

ind:cadSystemName rdf:type rdf:Property ;
    rdfs:label 'Cad System Name' ;
    rdfs:comment 'Name of the CAD software system used to create the marker, such as Gerber, Lectra, or Optitex.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationMethod rdf:type rdf:Property ;
    rdfs:label 'Creation Method' ;
    rdfs:comment 'Method or system used to create the marker layout, indicating whether it was manually created, designed using CAD software, or generated automatically.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuttingTableWidthCm rdf:type rdf:Property ;
    rdfs:label 'Cutting Table Width Cm' ;
    rdfs:comment 'Width of the cutting table for which this marker is optimized, ensuring compatibility with factory equipment.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricConsumptionPerGarment rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Per Garment' ;
    rdfs:comment 'Amount of fabric required to produce one garment based on this marker, measured in meters or yards depending on business unit of measure.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricFoldType rdf:type rdf:Property ;
    rdfs:label 'Fabric Fold Type' ;
    rdfs:comment 'Type of fabric fold configuration used when laying the marker for cutting operations.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricGrainDirection rdf:type rdf:Property ;
    rdfs:label 'Fabric Grain Direction' ;
    rdfs:comment 'Primary grain direction of the fabric used in the marker layout, critical for pattern alignment and garment drape.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Fabric Unit Of Measure' ;
    rdfs:comment 'Unit of measurement used for fabric consumption and marker dimensions.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Utilization Percentage' ;
    rdfs:comment 'Efficiency metric representing the percentage of fabric area utilized by pattern pieces within the marker, calculated as (pattern area / marker area) * 100.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricWastagePercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Wastage Percentage' ;
    rdfs:comment 'Percentage of fabric area that is wasted (not utilized) in the marker layout, calculated as 100 minus fabric utilization percentage.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garmentQuantityPerMarker rdf:type rdf:Property ;
    rdfs:label 'Garment Quantity Per Marker' ;
    rdfs:comment 'Number of complete garments that can be cut from one marker repeat.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markerName rdf:type rdf:Property ;
    rdfs:label 'Marker Name' ;
    rdfs:comment 'Human-readable name or title for the marker layout, typically describing the style and size combination.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerNumber rdf:type rdf:Property ;
    rdfs:label 'Marker Number' ;
    rdfs:comment 'Business identifier for the marker used in production planning and fabric cutting operations. Externally visible reference number.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerStatus rdf:type rdf:Property ;
    rdfs:label 'Marker Status' ;
    rdfs:comment 'Current lifecycle status of the marker in the production workflow.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerType rdf:type rdf:Property ;
    rdfs:label 'Marker Type' ;
    rdfs:comment 'Classification of the marker based on its intended use and size configuration.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nestingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Nesting Algorithm' ;
    rdfs:comment 'Name or identifier of the algorithm used to optimize pattern piece placement within the marker to maximize fabric utilization.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pliesCount rdf:type rdf:Property ;
    rdfs:label 'Plies Count' ;
    rdfs:comment 'Number of fabric layers (plies) that can be stacked and cut simultaneously using this marker.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPiecesCount rdf:type rdf:Property ;
    rdfs:label 'Total Pieces Count' ;
    rdfs:comment 'Total number of individual pattern pieces arranged within the marker layout.' ;
    rdfs:domain ind:Marker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedsProductionLineId rdf:type rdf:Property ;
    rdfs:label 'Feeds Production Line Id' ;
    rdfs:comment 'Self-referencing FK on production_line (feeds_production_line_id)' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:capacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Hour' ;
    rdfs:comment 'Standard production capacity of the line measured in units (garments, pieces, or items) that can be produced per hour under normal operating conditions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Standard time required in minutes to change over the production line from one product style or order to another, critical for production scheduling.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the production line was first commissioned and became operational for production activities.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficiencyTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Efficiency Target Percentage' ;
    rdfs:comment 'Target operational efficiency percentage for this production line, representing the expected ratio of actual output to standard capacity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours required to produce one unit of output on this production line, used for sustainability tracking and cost analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental certifications or sustainability standards applicable to this production line (e.g., ISO 14001, LEED, carbon-neutral certification).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFlexibleLine rdf:type rdf:Property ;
    rdfs:label 'Is Flexible Line' ;
    rdfs:comment 'Indicates whether this production line is configured for flexible manufacturing, capable of quick changeovers between different product styles or categories.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major equipment upgrade, technology refresh, or significant capacity enhancement to the production line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Physical length of the production line measured in meters, relevant for layout planning and material flow optimization.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Externally-known unique business identifier for the production line, used across manufacturing systems and factory floor documentation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name or designation of the production line, typically reflecting location or product category (e.g., \'Knitting Line A\', \'Cut-Make-Trim Line 3\').' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedMaintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Schedule' ;
    rdfs:comment 'Frequency of scheduled preventive maintenance activities for this production line to ensure optimal performance and minimize downtime.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Quality tier or grade of products that this production line is certified and configured to produce.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Target Percentage' ;
    rdfs:comment 'Target quality pass rate or first-time-right percentage for products manufactured on this line, used for quality performance monitoring.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLaborCostPerHour rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Cost Per Hour' ;
    rdfs:comment 'Standard labor cost rate per hour for operating this production line, used for production costing and variance analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardOverheadRate rdf:type rdf:Property ;
    rdfs:label 'Standard Overhead Rate' ;
    rdfs:comment 'Standard manufacturing overhead allocation rate applied to production on this line, expressed as a decimal multiplier or percentage.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Level' ;
    rdfs:comment 'Classification of the automation and technology sophistication level of the production line equipment and processes.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorDeliveryWindowId rdf:type rdf:Property ;
    rdfs:label 'Prior Delivery Window Id' ;
    rdfs:comment 'Self-referencing FK on delivery_window (prior_delivery_window_id)' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryWindow .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'User identifier or name of the person who closed this delivery window.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Status' ;
    rdfs:comment 'Current lifecycle status of the delivery window. Draft indicates planning phase, active means available for work order assignment, locked prevents new assignments, closed indicates completion, cancelled means the window was terminated.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCategory rdf:type rdf:Property ;
    rdfs:label 'Production Category' ;
    rdfs:comment 'Primary product category that this delivery window is designed to support in the manufacturing schedule.' ;
    rdfs:domain ind:DeliveryWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Required' ;
    rdfs:comment 'Indicates whether PP (Pre-Production) sample approval is mandatory before bulk production can proceed within this delivery window.' ;
