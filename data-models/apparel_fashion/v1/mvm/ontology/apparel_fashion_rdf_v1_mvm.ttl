    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionType rdf:type rdf:Property ;
    rdfs:label 'Division Type' ;
    rdfs:comment 'Classification of the division by product category type.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeWeeks rdf:type rdf:Property ;
    rdfs:label 'Lead Time Weeks' ;
    rdfs:comment 'Average lead time in weeks from order placement to merchandise receipt for this division.' ;
