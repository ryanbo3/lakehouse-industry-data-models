# RDFS Schema for Business: Apparel Fashion

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/apparel_fashion#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Apparel Fashion ---
ind:ApparelFashion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Apparel Fashion' ;
    rdfs:comment 'Apparel and Fashion is a creative and commercial industry designing, manufacturing, and marketing athletic, lifestyle, and luxury clothing, footwear, and accessories through retail stores, e-commerce, and wholesale partnerships.' .

# --- Domain Classes ---
ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Product' ;
    rdfs:comment 'Single source of truth for all apparel and fashion product definitions including SKUs, UPCs, styles, colorways, sizes, BOMs, tech packs, material compositions, and MSRP. Owns the master product catalog from concept through commercialization across athletic, lifestyle, and luxury clothing, footwear, and accessories. Integrates with PLM systems (Infor PLM, Centric PLM) for design-to-production lifecycle.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Customer' ;
    rdfs:comment 'SSOT for all customer identities, profiles, preferences, segments, loyalty programs, and CLTV across DTC, wholesale, and retail channels. Manages B2C consumers, B2B wholesale accounts, household relationships, and enterprise partnerships. Supports NPS tracking, personalization strategies, and CRM data sourced from Adobe Experience Platform and Salesforce.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Order' ;
    rdfs:comment 'Manages end-to-end order lifecycle from quote to fulfillment including sales orders, POs, backorders, allocations, and OTIF tracking. Handles DTC e-commerce orders, wholesale EDI orders, retail POS orders, and replenishment. Owns ATP, ATS, RMA processing, and order orchestration across SAP S/4HANA SD and Salesforce Commerce Cloud.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Tracks real-time stock levels, ATS, ATP, WOS, and inventory movements across warehouses, DCs, retail stores, and 3PL facilities. Manages cycle counts, stock adjustments, RFID tracking, VMI programs, and NOS strategies. Ensures optimal inventory positioning for omnichannel fulfillment via Manhattan Associates WMS and SAP S/4HANA MM.' .

ind:Merchandising rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Merchandising' ;
    rdfs:comment 'Drives assortment planning, collection planning, OTB budgets, allocation strategies, pricing (MSRP, AUR, IMU, MMU, MU, MD), and GMROI optimization. Manages seasonal buy plans, pre-production planning, sell-through rate (STR) analysis, and merchandise financial planning via Oracle Retail Merchandising System and Anaplan.' .

ind:Store rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Store' ;
    rdfs:comment 'Manages retail store operations including POS transactions, store inventory, sales associates, visual merchandising, store performance KPIs, daily sales reconciliation, shrinkage, and omnichannel fulfillment (BOPIS, ship-from-store). Tracks store-level STR, ASP, AUR, and traffic analytics via SAP Customer Activity Repository.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Coordinates inbound and outbound transportation, freight forwarding, customs clearance, HS code compliance, GSP utilization, LDP calculations, carrier management, routing guides, and last-mile delivery tracking. Manages 3PL partnerships, shipment milestones, SLAs, and distribution network optimization via Manhattan Associates WMS.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Manages brand campaigns, seasonal launches, influencer partnerships, digital advertising, email marketing, social media, and customer acquisition strategies. Tracks campaign performance, brand health metrics, marketing attribution, CAC, and NPS across channels via Adobe Experience Platform.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'SSOT for all vendor and supplier master data including manufacturer profiles, CMT factories, OEM/ODM partners, fabric mills, trim suppliers, and 3PL providers. Manages factory certifications, compliance audits (WRAP, FLA, GOTS, OEKO-TEX), capacity profiles, payment terms, LC terms, and supplier risk scorecards.' .

ind:Sourcing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Sourcing' ;
    rdfs:comment 'Owns the strategic and tactical sourcing process including RFQ/RFP management, costing (CMT, FOB), material development, SMS (Sample Management System), and PP approval workflows. Manages the Time and Action (TNA) calendar, MOQ negotiations, and fabric/trim procurement from mills and vendors via Centric PLM and Infor PLM.' .

ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Production' ;
    rdfs:comment 'Captures manufacturing processes, cut-make-trim (CMT) execution, work orders, production scheduling, factory capacity planning, and production milestone tracking. Manages PP samples, bulk production runs, and manufacturing partner coordination across SAP S/4HANA PP.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ApparelFashion ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Core financial ledger handling financial planning, budgeting, cost accounting (COGS), revenue recognition, AP/AR, general ledger, statutory reporting per IFRS/GAAP, and EBITDA analysis. Manages EOM close, financial consolidation, GMROI, margin analysis, landed cost (LDP) accounting, and profitability analysis by channel, product, and region via SAP S/4HANA FI/CO.' .

# --- Data Product Classes (Tables) ---
ind:AssortmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Assortment Plan' ;
    rdfs:comment 'Master assortment planning entity capturing the seasonal merchandise assortment strategy by department, class, and subclass. Defines which styles, colorways, and sizes will be carried per channel and store cluster, aligned with OTB budgets and collection planning cycles. Sourced from Oracle Retail Merchandising System assortment planning module.' .

ind:CollectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Collection Plan' ;
    rdfs:comment 'Seasonal collection planning master record defining the thematic merchandise collection (e.g., Spring/Summer, Fall/Winter, Resort, Pre-Fall) including line architecture, style count targets, price tier distribution, and channel allocation strategy. Managed in Centric PLM and Anaplan, bridging creative direction with commercial planning.' .

ind:OtbBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Otb Budget' ;
    rdfs:comment 'Open-to-Buy (OTB) budget master record tracking the planned versus actual merchandise purchasing budget by department, class, season, and month. Captures beginning-of-month (BOM) inventory at retail and cost, planned sales, planned markdowns, planned receipts, actual receipts consumed by buy plans, ending inventory targets, and remaining open-to-buy dollars. Includes weekly OTB recalculation triggers and variance thresholds for merchant alerts. Core financial control mechanism preventing over-buying and ensuring inventory investment aligns with sales plans. Managed in Anaplan with Oracle Retail integration.' .

ind:BuyPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Buy Plan' ;
    rdfs:comment 'Seasonal merchandise buy plan capturing planned purchase quantities, costs, receipt timing, and supplier commitments by style, colorway, size, and vendor. Includes MOQ commitments, FOB and LDP cost calculations, planned receipt flow by week, and OTB budget consumption tracking. Links financial OTB authorization to actual purchase order execution. Drives procurement workflows in SAP S/4HANA MM.' .

ind:BuyPlanLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Buy Plan Line' ;
    rdfs:comment 'Line-level detail of the seasonal buy plan representing individual SKU-level purchase commitments within a buy plan. Captures style number, colorway, size run, planned units, unit cost (CMT/FOB), planned receipt date, and supplier allocation. Enables granular tracking of buy plan execution against OTB.' .

ind:MerchandiseHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Merchandise Hierarchy' ;
    rdfs:comment 'Master reference for the merchandise classification hierarchy defining the organizational structure of product categories: Division > Department > Class > Subclass. Governs how assortments, OTB budgets, and financial plans are structured and reported. Managed in Oracle Retail Merchandising System as the foundational taxonomy.' .

ind:PriceMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Price Master' ;
    rdfs:comment 'Master pricing record for each style/SKU capturing MSRP, AUR (Average Unit Retail), IMU (Initial Markup), wholesale price, and cost price across channels and regions. Tracks price tier classification (luxury, premium, value), currency, and effective date ranges. Managed in Oracle Retail Price Management module.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Master record for merchandise promotions including seasonal sales events, clearance promotions, bundle offers, and loyalty-linked price reductions. Captures promotion type, discount mechanics (percentage off, BOGO, fixed price), eligible merchandise scope, channel applicability, and planned versus actual promotional lift. Managed in Oracle Retail and SAP SD.' .

ind:MerchandiseFinancialPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Merchandise Financial Plan' ;
    rdfs:comment 'Merchandise financial plan (MFP) capturing top-down and channel-level financial targets for a season by department, class, and distribution channel (DTC retail, DTC e-commerce, wholesale, outlet). Includes planned net sales, planned COGS, planned gross margin, planned GMROI, planned inventory turns, planned markdown dollars, channel-specific pricing strategy, and channel inventory allocation percentages. Serves as the financial planning backbone and GMROI target-setting mechanism for the merchandising organization. Managed in Anaplan.' .

ind:SizeCurve rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Size Curve' ;
    rdfs:comment 'Size curve profile master defining the expected unit sales distribution across size runs (alpha: XS/S/M/L/XL/XXL, numeric: 28-42, shoe: 5-14) for a style, merchandise class, or product category by channel, region, and store cluster. Captures curve type (standard, fitted, oversized), historical sell-through basis period, confidence level, and seasonal adjustment factors. Used to optimize buy plan size ratios, allocation size breaks, replenishment size packs, and initial distribution. Critical for minimizing size-related markdowns and stockouts in apparel where size fragmentation drives 15-20% of excess inventory. Managed in Oracle Retail and Anaplan.' .

ind:Season rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Season' ;
    rdfs:comment 'Merchandise season master reference defining trading seasons (Spring/Summer, Fall/Winter, Resort, Pre-Fall, Holiday, Cruise) with start and end dates, delivery windows, market week dates, T&A calendar milestones, financial planning periods, and markdown cadence calendar. Every planning entity in the merchandising domain (assortment, collection, OTB, buy plan, allocation, MFP) references a season as its temporal anchor. Serves as the canonical time-boundary definition for merchandise planning cycles. Managed in Oracle Retail Merchandising System.' .

ind:PriceChangeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Price Change Event' ;
    rdfs:comment 'Transactional record of any retail price modification event including permanent markdowns, temporary markdowns, markups, clearance pricing, and promotional price changes applied to a style or SKU' .

ind:RetailStore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Retail Store' ;
    rdfs:comment 'Master record for each physical retail store location operated by Apparel Fashion. Captures store identity, format (flagship, outlet, pop-up, shop-in-shop, concession), trading area classification, gross and net selling square footage, register inventory (terminal count, types, configurations), lease terms and rent structure, regional/district/territory hierarchy, climate zone, and operational status (pre-open, trading, temporarily closed, permanently closed). SSOT for store-level dimensional attributes referenced by POS, inventory, workforce, and omnichannel systems. Conforms to NRF ARTS RetailStore entity. Sourced from SAP S/4HANA Real Estate and SAP Customer Activity Repository.' .

ind:PosTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Pos Transaction' ;
    rdfs:comment 'Captures every point-of-sale transaction processed at a retail store register, including sale, return, exchange, void, and no-sale events. Records transaction date/time, register ID, cashier/associate, tender split (cash, credit, debit, mobile wallet, gift card, store credit), total amount, tax by jurisdiction, discount applied, loyalty points earned/redeemed, and channel flag (in-store, BOPIS pickup, endless aisle). Conforms to NRF ARTS POSLog standard for transaction classification. Primary transactional heartbeat of the store domain. Sourced from SAP Customer Activity Repository.' .

ind:PosTransactionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Pos Transaction Line' ;
    rdfs:comment 'Individual line-item detail within a POS transaction. Records SKU, UPC, style, colorway, size, quantity sold, unit retail price (AUR), markdown amount, IMU, MMU, COGS, and line-level discount reason. Enables STR, ASP, and AUR analytics at the SKU-store-day grain. Sourced from SAP Customer Activity Repository.' .

ind:DailySalesSummary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Daily Sales Summary' ;
    rdfs:comment 'End-of-day store-level sales reconciliation record capturing total net sales, gross sales, returns, markdowns, units sold, transaction count, AUR, ASP, STR, and cash/card/digital tender breakdown. Used for daily sales reconciliation, OTB tracking, and store performance reporting. Sourced from SAP Customer Activity Repository daily close process.' .

ind:Associate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Associate' ;
    rdfs:comment 'Store-domain view of sales associates and floor staff assigned to a retail store. Captures associate role (sales associate, keyholder, department lead, store manager), assigned store, department, employment type, hire date, and active status. Distinct from the workforce domain employee master — this entity tracks store-operational assignment and role context for POS attribution, commission, and scheduling purposes.' .

ind:BopisOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Bopis Order' ;
    rdfs:comment 'Manages Buy Online Pick Up In Store (BOPIS) fulfillment orders assigned to a specific retail store. Captures order reference (from order domain), assigned store, pick status, pick associate, ready-for-pickup timestamp, customer notification status, pickup confirmation, and expiry/cancellation details. Enables omnichannel fulfillment SLA tracking.' .

ind:ShipFromStore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Ship From Store' ;
    rdfs:comment 'Tracks ship-from-store fulfillment requests where a retail store acts as a mini-DC to fulfill e-commerce or wholesale orders. Records order reference, assigned store, SKU, quantity, pick/pack/ship timestamps, carrier, tracking number, and OTIF status. Supports omnichannel fulfillment performance and store-level capacity management.' .

ind:ReturnTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Return Transaction' ;
    rdfs:comment 'Records customer merchandise returns processed at a retail store, including original POS transaction reference, return reason code (fit, quality defect, changed mind, wrong item), SKU, quantity, condition assessment, refund method (original tender, store credit, exchange), processing associate, and disposition routing (restock to floor, return to vendor/RTV, damage write-off, outlet transfer). Supports return rate analysis by reason, RTV processing workflows, loss prevention flagging of serial returners, and warranty claim tracking.' .

ind:VisualMerchandisingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Visual Merchandising Plan' ;
    rdfs:comment 'Captures visual merchandising directives, planogram assignments, and compliance audit results for a store or store cluster. Includes fixture layout, product placement by zone/wall/table/window, seasonal collection display guidelines, mannequin styling instructions, signage specifications, compliance deadline, audit scores, non-compliant zones, and corrective action tracking. After merge with vm_compliance_check, this entity is SSOT for both the plan and its execution verification. Sourced from Oracle Retail Merchandising System and Centric PLM collection management.' .

ind:MarkdownEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Markdown Event' ;
    rdfs:comment 'Records markdown pricing events executed at the store level, including SKU, original MSRP, markdown price, markdown percentage, effective date, end date, markdown reason (clearance, seasonal, competitive), and authorization reference. Supports MD tracking, GMROI analysis, and OTB reconciliation. Sourced from Oracle Retail Price Management.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Profile' ;
    rdfs:comment 'SSOT master record and golden identity for every individual consumer (B2C) across DTC, retail, and e-commerce channels. Captures full identity attributes including name, date of birth, gender, preferred language, contact details, GDPR/CCPA consent flags, communication opt-ins, household membership, and CRM source system identifiers. Embeds the complete identity resolution graph linking multiple cross-channel identifiers (email, phone, cookie ID, device ID, loyalty card number, POS customer ID, Salesforce contact ID, Adobe ECID) with link type, link confidence scores, resolution methods (deterministic, probabilistic), source systems, and active status. Serves as the anchor entity for loyalty, preferences, interactions, CLTV, and all downstream personalization.' .

ind:WholesaleAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Wholesale Account' ;
    rdfs:comment 'SSOT master record for B2B wholesale buyers, retail partners, and enterprise accounts. Captures legal entity name, DUNS number, tax ID, credit terms, payment terms, assigned sales rep, account tier, EDI capability, MOQ agreements, and parent-child hierarchy relationships for franchise networks, buying groups, and corporate group structures. Includes full contact person management: each contact with first name, last name, job title, department, email, phone, preferred communication channel, buying authority level, relationship status, and Salesforce Contact object mapping. Supports multi-contact management per account with role-based access patterns for buying, logistics, and finance contacts.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact persons associated with a wholesale account or enterprise partnership. Captures first name, last name, job title, department, email, phone, preferred communication channel, buying authority level, and relationship status. Supports B2B relationship management and maps to Salesforce Contact object. Multiple contacts can be linked to a single wholesale account.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Standardized address records for both B2C profiles and B2B wholesale accounts. Captures address type (billing, shipping, store, warehouse), street lines, city, state/province, postal code, country ISO code, geocoordinates, address validation status, and default flag. Supports multi-address per customer for DTC shipping, store pickup, and wholesale delivery routing.' .

ind:LoyaltyProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Loyalty Program' ;
    rdfs:comment 'Master definition of loyalty program tiers, rules, and configurations offered by Apparel Fashion. Captures program name, tier structure (e.g., Silver, Gold, Platinum), points earning rules, redemption thresholds, expiry policies, eligible channel flags (DTC, retail, e-commerce), program launch date, and program status. Serves as the reference template against which individual enrollments are tracked.' .

ind:LoyaltyEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Loyalty Enrollment' ;
    rdfs:comment 'Tracks each customer\'s active enrollment in a loyalty program including current tier status, points balance, and full transaction history of points movements. Captures enrollment date, current tier, tier qualification/expiry dates, lifetime points earned, redeemable balance, enrollment channel, and a ledger of all earn/redeem/adjust/expire/bonus events with timestamps, triggering references, and running balances. Provides complete loyalty lifecycle per customer.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Defines named market segments used to classify B2C and B2B customers for personalization, merchandising, and marketing targeting. Captures segment name, segment type (behavioral, demographic, psychographic, RFM, channel-based), definition criteria, segment owner (marketing vs. merchandising), creation date, and active status. Segments are managed in Adobe Experience Platform and synced to CRM for campaign activation.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'SSOT for all explicit and inferred customer preferences, body measurements, and size profiles across apparel categories. Captures style affinities, fit preferences, color palettes, brand preferences, communication channel preferences, and detailed size/measurement data per category (tops, bottoms, outerwear, footwear, accessories). For each preference or measurement: records type, source (self-declared, behavioral inference, stylist-assigned, in-store body scan, virtual try-on), value with units, preferred brand size per category, confidence level, and last updated timestamp. Consolidates all personalization and fit inputs to feed recommendation engines, enable size/fit personalization, and reduce return rates in Adobe Experience Platform.' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Tracks customer consent and privacy preferences in compliance with GDPR and CCPA regulations. Captures consent type (marketing email, SMS, push notification, data sharing, profiling, cookies), consent status (granted, withdrawn, pending), consent timestamp, consent version, collection channel, IP address at time of consent, and regulatory jurisdiction. Mandatory for FTC and GDPR compliance across all customer touchpoints.' .

ind:ServiceRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Request' ;
    rdfs:comment 'Tracks post-purchase customer service cases including returns inquiries, exchange requests, product complaints, order issues, loyalty disputes, and general support tickets. Captures case type, priority, status (open, in-progress, resolved, closed), channel of submission (store, email, chat, phone), assigned agent, resolution notes, resolution date, SLA breach flag, and linked order or return reference. Managed via Salesforce Service Cloud.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Stores tokenized payment instruments on file for a customer, enabling one-click checkout and recurring billing. Captures payment type (credit card, debit card, digital wallet, gift card, buy-now-pay-later), card brand, last four digits, expiry date, billing address reference, tokenization provider, default flag, and active status. PCI-DSS compliant — no raw card data stored; only tokenized references from Salesforce Commerce Cloud.' .

ind:SizeProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Size Profile' ;
    rdfs:comment 'Stores a customer\'s body measurements and size preferences across apparel categories (tops, bottoms, outerwear, footwear, accessories). Captures measurement type (chest, waist, hip, inseam, shoulder width, foot length), measurement value, unit of measure, measurement source (self-reported, in-store scan, virtual try-on), measurement date, and preferred brand size per category. Enables fit personalization and reduces return rates driven by sizing issues.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Core master record of current stock levels for each SKU across all locations (warehouses, DCs, retail stores, 3PL facilities). Tracks on-hand quantity, reserved quantity, ATS (Available to Sell), ATP (Available to Promise), in-transit quantity, damaged/held quantity, WOS (Weeks of Supply), and aging bucket (current season, prior season, aged). Serves as the real-time inventory position SSOT feeding omnichannel fulfillment, allocation engines, markdown triggers, and financial reporting.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts, goods issues, inter-location transfers, stock adjustments, returns, write-offs, and corrections. Captures movement type, quantity, unit of measure, source and destination locations, reference document (PO, STO, RTV, delivery note, ASN), posting date, movement reason code, and adjustment approval reference. Serves as the single audit trail for all inventory quantity changes across all channels and locations.' .

ind:WarehouseLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Hierarchical master record of all inventory storage locations from facility level down to individual bin positions. Encompasses facilities (owned DCs, 3PL sites, retail stockrooms, bonded warehouses, cross-docks), zones, aisles, racks, shelves, and bins. Captures location type, capacity (units and cubic), temperature zone, RFID capability, customs bonded status, zone assignment, and operational status. Supports directed putaway, slotting optimization, and omnichannel fulfillment routing.' .

ind:SkuLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Sku Location' ;
    rdfs:comment 'Association entity linking SKUs to their assigned storage locations within a facility, capturing slotting rules, primary pick location, overflow location, min/max replenishment levels, reorder point, safety stock quantity, NOS (Never Out of Stock) classification tier and policy attributes, and VMI (Vendor Managed Inventory) indicator. Drives replenishment triggers, NOS compliance monitoring, and omnichannel fulfillment positioning.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Operational record of scheduled and ad-hoc physical inventory cycle count events at a location or zone level, including line-level SKU count details. Header captures count plan date, count type (full, partial, ABC-class, RFID-assisted), assigned counter, count status, and variance threshold. Line-level detail records expected quantity, counted quantity, variance, recount flag, and final approved quantity. Drives stock adjustment postings when variance exceeds tolerance.' .

ind:TransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Transfer Order' ;
    rdfs:comment 'Operational record of internal stock transfer requests and executions between locations (warehouse-to-store, DC-to-DC, store-to-store, 3PL-to-DC). Captures transfer reference, source location, destination location, requested quantity, confirmed quantity, transfer type (replenishment, rebalancing, recall), priority, and OTIF status.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Operational record of store or DC replenishment requests generated by min/max rules, MRP, or demand-driven algorithms. Captures replenishment type (automatic, manual, VMI), source location, destination location, SKU, requested quantity, approved quantity, replenishment trigger (below reorder point, NOS breach, OTB-driven), status (proposed, approved, released, fulfilled), and expected delivery date.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Transactional record of inventory reservations that earmark stock for specific orders, channels, or events before physical allocation. Captures reservation type (sales order, e-commerce cart, wholesale commitment, event hold, photo shoot hold, sample pull, trunk show), reserved quantity, reservation expiry timestamp, priority rank, fulfillment channel, and soft vs hard reservation indicator. Feeds ATS and ATP calculations across omnichannel fulfillment.' .

ind:StockValuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Valuation' ;
    rdfs:comment 'Master record of inventory valuation parameters and current book value for each SKU at each valuation area. Captures valuation method (standard cost, moving average, FIFO), standard cost, moving average price, total stock value, last valuation date, currency, valuation class, markdown reserve, seasonal write-down percentage, and aged inventory provision. Supports COGS calculation, balance sheet inventory reporting, end-of-season markdown accounting, and inventory obsolescence provisioning critical for fashion\'s seasonal lifecycle.' .

ind:Asn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Asn' ;
    rdfs:comment 'Record of Advance Shipment Notices received from suppliers, factories, or 3PLs prior to physical goods arrival, including line-level SKU detail. Captures ASN number, supplier reference, expected arrival date, ship-from/ship-to locations, carrier, tracking number, carton count, total units, line-level SKU/UPC/quantity breakdown, lot numbers, country of origin, and HS codes. Enables pre-receiving planning, dock scheduling, carton-level receiving reconciliation, and landed cost allocation upon receipt.' .

ind:LotBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot Batch' ;
    rdfs:comment 'Master record of production lots or batches for inventory traceability, critical for dye-lot consistency in apparel, certified material tracking (OEKO-TEX, GOTS, BCI cotton), and regulatory recall compliance. Captures lot number, batch origin (factory, mill), production date, expiry date, certification references, dye lot code, colorway consistency grade, and lot status (active, quarantined, consumed, expired). Supports CPSC recall traceability and customer claims resolution.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core manufacturing work order authorizing production of a specific quantity of a style/SKU at a designated factory. Captures work order number, style reference, factory assignment, ordered and confirmed quantities, production start/end dates, CMT type (Cut/Make/Trim), status lifecycle (draft → released → in-progress → completed → closed), SAP PP order number, season, collection, priority, customer PO reference, and target ex-factory date. SSOT for all bulk production execution instructions. Links downstream to operations, confirmations, cut orders, T&A milestones, and production lots.' .

ind:WorkOrderOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Order Operation' ;
    rdfs:comment 'Individual manufacturing operation or routing step within a work order, representing each discrete production activity (cutting, sewing, finishing, pressing, packing). Captures operation sequence number, operation code, work center, standard time (SAM — Standard Allowed Minutes), actual time, planned quantity, confirmed quantity, operation status, and yield percentage. Derived from SAP PP routing operations.' .

ind:OrderConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Order Confirmation' ;
    rdfs:comment 'Goods confirmation event recording actual output quantities, scrap, rework, and labor hours against a work order operation. Captures confirmation date, confirmed yield quantity, scrap quantity, rework quantity, actual machine time, actual labor time, shift, operator ID, and confirmation type (partial, final). Represents the SAP PP goods confirmation transaction (CO11N/CO15).' .

ind:ProductionFactory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Factory' ;
    rdfs:comment 'Master record for each manufacturing facility (CMT factory, OEM, ODM) engaged in production. Captures factory code, factory name, legal entity name, country, city, address, factory type (CMT/OEM/ODM/internal), production capabilities (woven, knit, denim, footwear, accessories), certified capacity (units/week), compliance certifications (WRAP, BSCI, FLA, OEKO-TEX, SA8000), audit status, lead time profile, minimum order quantity, and active flag. SSOT for factory identity within the production domain; supplier domain owns the broader vendor relationship and commercial terms.' .

ind:FactoryCapacity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Factory Capacity' ;
    rdfs:comment 'Weekly or monthly capacity plan and reservation record for a factory, capturing available machine hours, labor hours, allocated capacity (units), reserved capacity by season/booking, efficiency rate, utilization percentage, and booking status by production line or department. Supports OTB capacity planning, T&A scheduling, forward capacity booking, and load balancing across manufacturing partners.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Master production schedule (MPS) record linking work orders to factory capacity slots, defining planned cut dates, sew start dates, sew end dates, finishing dates, and ex-factory dates by production line. Captures schedule version, schedule status (draft, confirmed, locked), season, delivery window, critical path flags, and schedule change reason. Supports T&A calendar management, on-time delivery tracking (OTIF), and weekly production planning meetings with factory partners.' .

ind:ProductionTnaMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Production Tna Milestone' ;
    rdfs:comment 'Time and Action (T&A) calendar milestone record tracking each critical event in the production lifecycle for a style or work order, including both planned and actual execution data. Captures milestone type (fabric approval, PP sample submission/approval, bulk fabric receipt, cut start, sew start, finishing, QC inspection, ex-factory, cargo receipt), planned date, revised date, actual date, actual timestamp, days variance, quantity at milestone, responsible party, milestone status (pending, in-progress, completed, overdue), delay reason code, and recorded-by reference. Core tool for production milestone tracking and OTIF performance measurement.' .

ind:PpSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Pp Sample' ;
    rdfs:comment 'Pre-Production (PP) sample master record tracking each sample submitted for approval during production development, including structured review feedback. Captures sample type (PP1, PP2, TOP, Salesman, Photoshoot), style reference, colorway, size, factory, submission/approval dates, approval status (submitted, approved, approved-with-comments, rejected), fit comments, construction comments, reviewer annotations by category (fit, construction, fabric, trim, labeling, packaging) with severity and resolution status, and revision round. Manages the complete PP sample approval workflow including feedback loops between design, technical, and factory teams.' .

ind:BulkFabricReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Bulk Fabric Receipt' ;
    rdfs:comment 'Record of bulk fabric or raw material receipt at the CMT factory prior to cutting, capturing receipt date, fabric article reference, supplier/mill, purchase order number, ordered vs received quantity (meters/yards/kg), AQL inspection result, fabric width, weight, shrinkage test result, shade lot number, and receipt status. Tracks inbound material availability at the factory level to gate cut-start decisions and support production scheduling. Owned by production as the factory-floor receipt event; supply domain owns the upstream PO and logistics owns transit.' .

ind:CutOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Cut Order' ;
    rdfs:comment 'Cutting order record authorizing the cutting of fabric panels for a specific style, colorway, and size ratio within a work order. Captures cut order number, cut date, marker reference (CAD marker ID), fabric consumption per unit, total fabric allocated (meters/yards), planned vs actual panels cut, size ratio breakdown, ply count, cut efficiency percentage (vs marker plan), cut room supervisor, and cut status (planned, in-progress, completed). Represents the first physical production step in CMT manufacturing and gates downstream sewing operations.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Manufacturing routing master defining the standard sequence of operations and work centers required to produce a style at a specific factory. Captures routing version, total SAM (Standard Allowed Minutes), number of operations, machine type requirements, skill level requirements, line balancing targets, routing status, and effective date range. Derived from SAP PP routing master (CA01). Used for capacity planning, CMT cost calculation, and as the template from which work_order_operations are generated.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Work center master record representing a production unit (sewing line, cutting room, finishing department, pressing station, packing line) within a factory. Captures work center code, work center name, factory reference, department type, available capacity (hours/day), efficiency rate, number of machines, number of operators, work center category (machine, labor, mixed), and active status. Used for capacity planning and production routing in SAP PP.' .

ind:Style rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Style' ;
    rdfs:comment 'Core master entity representing a unique apparel or footwear style — the foundational design unit in PLM (Infor PLM, Centric PLM). Captures style number, name, gender, silhouette, product type (athletic, lifestyle, luxury), category, subcategory, division, season, collection, lifecycle stage (concept, development, commercialized, discontinued), target channel (DTC, wholesale, retail), MSRP, and design ownership. This is the top-level product identity before colorway and size differentiation. Parent entity in the style→colorway→SKU hierarchy.' .

ind:Colorway rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Colorway' ;
    rdfs:comment 'Represents a specific color variant of a style, combining the style with a defined color palette. Tracks colorway code, colorway name, primary color, secondary color, color standard (Pantone, NCS), color story, season relevance, colorway status (active, discontinued, carry-over), and launch date. A style may have multiple colorways; each colorway is a distinct sellable variant managed in PLM and Oracle Retail.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The atomic sellable unit in apparel — a unique Stock Keeping Unit representing the intersection of style, colorway, and size. Stores SKU code, UPC/EAN barcode, RFID tag reference, size label, size run position, weight, dimensions, country of origin, HS code, GSP eligibility, MSRP, cost (COGS), IMU, ATS flag, NOS flag, and active/inactive status. SSOT for all downstream inventory, order, and e-commerce references. Sourced from SAP S/4HANA MM and PLM systems.' .

ind:SizeScale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Size Scale' ;
    rdfs:comment 'Defines the size run and size labeling system used for a product category or brand (e.g., XS-XXL, 28-40 waist, EU 36-46, US 6-14, One Size). Captures size scale code, size scale name, measurement system (US, EU, UK, JP), size labels ordered by run position, gender applicability, product category applicability, and regional market mapping. Enables consistent size normalization across channels and geographies.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Category' ;
    rdfs:comment 'Hierarchical classification taxonomy for all apparel and fashion products. Defines the multi-level category tree (division → department → class → subclass) used across merchandising, PLM, and retail systems. Stores category code, category name, level in hierarchy, parent category, gender, product type (clothing, footwear, accessories), channel applicability, and Oracle Retail category mapping. Enables consistent product classification across OMS, WMS, and e-commerce.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Bill of Materials and Product Costing master for a style or colorway — the single authoritative record of all raw materials, fabrics, trims, labels, and components required to manufacture the product, combined with complete product cost buildup. Captures BOM version, effective date, BOM status (draft, approved, production), and all cost components: total material cost, CMT cost breakdown (cut, make, trim), FOB cost, LDP (Landed Duty Paid) cost, duty rate, freight cost, target COGS, costing stage (initial estimate, final costing, actual), cost version, cost approval status, and IMU/MMU calculation inputs. Fabric content percentage supports FTC labeling compliance. Managed in Infor PLM and Centric PLM costing modules. SSOT for product costing, material composition, and cost buildup — no other product in this domain stores cost data. Critical for sourcing decisions, margin management, and regulatory labeling.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual line item within a Bill of Materials, representing a single material, fabric, trim, or component. Stores BOM line number, material type (shell fabric, lining, zipper, button, label, hang tag, packaging), material code, supplier material reference, unit of measure, quantity per unit, placement description, color specification, and unit cost. Enables granular costing, sourcing, and material compliance tracking at the component level.' .

ind:TechPack rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Tech Pack' ;
    rdfs:comment 'Technical specification and fit package for a style — the single comprehensive design, construction, fit, graded measurement, and dimensional specification document used to communicate all manufacturing and fit requirements to factories. Captures tech pack version, construction details, stitch type, seam allowance, care instructions (ISO 3758 symbols), labeling requirements, base size measurements, grade rules (increment per size), measurement point descriptions (chest, waist, hip, inseam, sleeve length, etc.), tolerance ranges by measurement point, fit model reference, and fit evaluation criteria for sample approval (PP sample, pre-production, size-set). Managed in Centric PLM. Links to BOM and T&A calendar. SSOT for ALL dimensional, construction, grading, and fit specifications — no other product in this domain stores measurement or grading data.' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Material' ;
    rdfs:comment 'Master record for all raw materials, fabrics, and trims used in product manufacturing. Stores material code, material name, material type (woven, knit, leather, synthetic, trim), fiber composition (cotton %, polyester %, etc.), weight (GSM), width, finish, sustainability certifications (GOTS, OEKO-TEX, BCI), country of origin, HS code, and approved supplier list. SSOT for material identity referenced by BOM lines and sourcing. Managed in Infor PLM material library.' .

ind:Sample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sample' ;
    rdfs:comment 'Tracks physical product samples throughout the design-to-production lifecycle including proto samples, fit samples, salesman samples, and production samples. Includes graded measurement specifications and fit evaluation data for each sample iteration.' .

ind:Collection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Collection' ;
    rdfs:comment 'Defines a seasonal or thematic product collection grouping styles for a specific season, brand, and channel. Captures collection code, collection name, season (SS, FW, Resort, Pre-Fall), year, brand, target channel (DTC, wholesale, retail), launch date, theme, creative direction notes, total style count, and collection status (planning, design, commercialized, closed). Managed in Centric PLM and Anaplan collection planning. Links to merchandising OTB plans.' .

ind:MsrpPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'Manufacturer\'s Suggested Retail Price record for a SKU or style by market, currency, and effective date range. Stores MSRP amount, currency code, market/region, price tier (good/better/best), effective start and end dates, initial markup (IMU) percentage, average unit retail (AUR) target, and price approval status. Supports multi-currency and multi-market pricing for DTC, wholesale, and retail channels. Managed in Oracle Retail Price Management and SAP S/4HANA SD. SSOT for product-level suggested pricing; actual selling prices and markdowns are owned by the merchandising domain.' .

ind:CostSheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Cost Sheet' ;
    rdfs:comment 'Detailed product costing record capturing all cost components for a style or SKU including FOB cost, CMT cost (cut, make, trim), material cost, duty rate, freight cost, LDP (Landed Duty Paid) cost, and target COGS. Tracks cost version, costing stage (initial estimate, final costing, actual), season, and cost approval status. Enables IMU and MMU calculation. Managed in Infor PLM costing module and SAP S/4HANA CO.' .

ind:SalesOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Sales Order' ;
    rdfs:comment 'Core master record for all outbound sales orders across DTC e-commerce, retail POS, and wholesale EDI channels. Captures order header data including channel type, order date, customer/account reference, billing and shipping addresses, currency, total amounts, payment terms, order source system (SAP S/4HANA SD or Salesforce Commerce Cloud), priority tier, and overall lifecycle status. Tracks order-level amendments (quantity changes, address updates, cancellations) as audit-trail change records. Serves as the SSOT for all outbound sales order transactions in the apparel-fashion business.' .

ind:SalesOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Sales Order Line' ;
    rdfs:comment 'Individual line-item detail within a sales order, representing a specific SKU (style/colorway/size) and quantity requested. Captures product reference, quantity ordered, quantity confirmed, unit price, MSRP, applied discount (amount, type, source), IMU percentage, line status, requested ship date, cancel date, and ATP confirmation flag. Supports both single-unit DTC orders and multi-line wholesale EDI orders with size-curve breakdowns. Each line drives downstream allocation, fulfillment, and backorder processing.' .

ind:OrderPurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Purchase Order' ;
    rdfs:comment 'Purchase orders issued for replenishment (NOS restocking, VMI, min-max), wholesale buying, and drop-ship fulfillment. Captures PO number, buyer entity, vendor/supplier reference, PO type (replenishment, wholesale, drop-ship, demand-driven), FOB terms, LC reference, MOQ compliance flag, total PO value, currency, incoterms, expected delivery date, replenishment trigger (reorder point, WOS target), source/destination locations, and PO status. Sourced from SAP S/4HANA MM and supports OTIF tracking for inbound goods flow. Consolidates all inbound demand order types into a single entity differentiated by PO type.' .

ind:OrderPurchaseOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Purchase Order Line' ;
    rdfs:comment 'Line-item detail for a purchase order, capturing individual SKU-level quantities, unit cost (CMT/FOB), material description, HS code, country of origin, MOQ per line, confirmed quantity, open quantity, and line delivery schedule. Supports inbound goods receipt matching and OTIF measurement at the SKU level. Linked to the purchase_order header and drives supply chain visibility.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Tracks the fulfillment execution record for a sales order or order line, capturing pick, pack, and ship activities including ASN (Advance Shipment Notice) generation for wholesale buyers. Includes fulfillment status, warehouse/DC location, 3PL carrier assignment, ship date, promised delivery date, actual delivery date, tracking number, EDI 856 ASN reference, total cartons, total units, OTIF flag, and fulfillment channel (store, DC, drop-ship). Sourced from Manhattan Associates WMS and SAP WM. Serves as the single source of truth for all outbound shipment events linking orders to physical delivery.' .

ind:Allocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Allocation' ;
    rdfs:comment 'Records the inventory allocation decisions made against sales order lines, capturing allocated SKU, allocated quantity, allocation source location (DC, store, 3PL), allocation date, ATS at time of allocation, ATP confirmation, allocation method (FIFO, priority, channel-based), and allocation status. Supports OTB-driven allocation strategies and NOS replenishment logic. Owned by the order domain as the bridge between demand and available inventory.' .

ind:Backorder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Backorder' ;
    rdfs:comment 'Captures unfulfilled demand when a sales order line cannot be immediately allocated due to insufficient ATS or ATP. Tracks original order line reference, backordered SKU (style/color/size), backordered quantity, backorder creation date, expected replenishment date, reason code (stockout, production delay, allocation exhausted), priority tier based on customer segment, notification status, and resolution action (cancel, substitute, hold for next drop). Triggers WOS-based replenishment and supports customer service SLA management for apparel seasonal and NOS programs.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Merchandise Authorization record managing the end-to-end returns and after-sales service process. Captures RMA number, originating order reference, return reason code (defect, wrong item, size exchange, buyer remorse), return channel (DTC, store, wholesale RTV), return condition assessment, refund or exchange decision, credit memo reference, restocking eligibility flag, and RMA status. Supports both consumer returns and wholesale RTV processing per FTC and CPSC compliance requirements.' .

ind:RmaLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma Line' ;
    rdfs:comment 'Line-item detail for a Return Merchandise Authorization, capturing the specific SKU being returned, quantity returned, unit refund amount, return condition (new, damaged, defective), disposition action (restock, destroy, RTV to vendor), inspection result, and restocking fee if applicable. Enables granular tracking of returned merchandise at the SKU level and feeds inventory disposition workflows.' .

ind:OrderPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Payment' ;
    rdfs:comment 'Payment record associated with a sales order, POS transaction, or wholesale invoice, capturing payment method (credit card, PayPal, Apple Pay, gift card, store credit, net terms, letter of credit, factoring), payment amount, currency, authorization code, payment gateway reference, payment status (authorized, captured, settled, refunded, failed, disputed), payment date, settlement date, and installment/BNPL plan details if applicable. Covers DTC digital payments via Salesforce Commerce Cloud, wholesale net-terms and LC payments via SAP FI/AR, and POS tender types. Supports payment reconciliation, chargeback management, and AR aging for wholesale accounts.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Unified organizational cost and profit object master in SAP S/4HANA FI/CO, representing cost centers (overhead allocation receivers), profit centers (autonomous profitability segments), and the allocation cycles that distribute costs between them. Captures organizational attributes (number, name, hierarchy, responsible manager, controlling area, company code, validity period, activity type, segment classification by brand/channel/product line/region) and allocation transactions (cycle, sender, receiver, method, allocated amount, fiscal period). Supports overhead allocation, COGS buildup, budget control, channel-level profitability (DTC vs. wholesale vs. retail), EBITDA reporting, and internal cost distribution for apparel operations.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for profit centers in SAP S/4HANA CO-PCA, representing autonomous business segments (e.g., brand, channel, product line, region) for which profitability is measured independently. Tracks revenue, COGS, gross margin, and EBITDA contribution by profit center. Essential for channel-level (DTC vs. wholesale vs. retail) and product-line profitability analysis in apparel fashion.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Chart of accounts master defining every general ledger account used in SAP S/4HANA FI for the apparel fashion enterprise. Includes account number, account type (P&L vs. balance sheet), account group, reconciliation account flag, currency, tax category, IFRS/GAAP classification, and controlling relevance. Underpins all journal entries, statutory reporting, and financial consolidation.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'Represents parallel accounting ledgers in SAP S/4HANA FI for the apparel fashion group, supporting IFRS, local GAAP, and management accounting views simultaneously. Captures ledger type, accounting principle, currency, fiscal year variant, and posting period controls. Includes complete period-end close management: EOM close checklist steps, responsible owners, planned/actual completion dates, status (open, in-progress, complete, blocked), blocking reasons, sign-off approvals, and the structured close calendar including depreciation runs, accruals, intercompany reconciliation, and statutory reporting milestones for each fiscal period and company code. Enables statutory reporting, financial consolidation, and multi-GAAP compliance across global markets.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core accounting document in SAP S/4HANA FI capturing every financial posting at both header and line-item granularity. Header attributes include document number, posting date, fiscal period, ledger, company code, currency, reversal status, and IFRS/GAAP classification. Line items capture GL account, cost center, profit center, debit/credit amounts in transaction and local currency, tax code, assignment field, WBS element, and business area. Covers manual journal entries, automated postings from SD/MM/PP, period-end accruals, reclassifications, and intercompany eliminations. Provides the complete authoritative audit trail for all financial movements in the apparel fashion enterprise.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line item within a journal entry document in SAP S/4HANA FI. Captures GL account, cost center, profit center, WBS element, business area, amount in transaction and local currency, tax code, assignment field, and line item text. Provides the granular posting detail required for cost allocation, COGS analysis, and statutory reporting in apparel fashion.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable invoice record in SAP S/4HANA FI-AP capturing vendor invoices for raw materials, CMT services, freight, and operating expenses. Stores vendor reference, invoice date, due date, payment terms, gross amount, tax amount, discount terms, three-way match status (PO/GR/IR), payment block reason, and IFRS accrual flag. Central to landed cost (LDP) accounting and COGS recognition for apparel sourcing.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable invoice record in SAP S/4HANA FI-AR capturing customer billing documents for wholesale, DTC, and retail channel sales. Stores customer account, billing date, due date, payment terms, gross amount, tax amount, discount and rebate deductions, dunning level, clearing status, and revenue recognition method per IFRS 15. Drives revenue recognition, DSO tracking, and channel profitability analysis.' .

ind:FinancePayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Payment' ;
    rdfs:comment 'Records outgoing vendor payments and incoming customer receipts processed through SAP S/4HANA FI, including wire transfers, Letters of Credit (LC), ACH/SEPA, checks, and intercompany netting settlements. Captures payment method, house bank and bank account, value date, clearing document reference, exchange rate at payment date, payment run ID, reconciliation status, and bank statement matching result. Supports AP/AR clearing, cash positioning, LC settlement for apparel import transactions, and bank reconciliation.' .

ind:CogsEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cogs Entry' ;
    rdfs:comment 'Cost of Goods Sold accounting entry capturing the COGS recognition event for each apparel product sold, derived from SAP S/4HANA MM/PP and SD integration. Stores SKU, style, colorway, size, sales order reference, quantity sold, standard cost, actual cost, cost variance, landed cost components (FOB, freight, duty, LDP), and COGS GL account. Foundational for gross margin analysis, GMROI calculation, and IMU/MMU tracking by product and channel.' .

ind:LandedCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Landed Cost' ;
    rdfs:comment 'Captures the full landed duty paid (LDP) cost breakdown for imported apparel goods, including FOB price, ocean/air freight, insurance, customs duty, HS code tariff rate, GSP preference utilization, port handling, and inland freight. Linked to purchase orders and goods receipts in SAP S/4HANA MM. Provides the authoritative LDP cost basis for inventory valuation, COGS recognition, and margin analysis by sourcing origin.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Master record for each legal entity (company code) within the apparel fashion group as defined in SAP S/4HANA FI. Captures company code, company name, country, currency, chart of accounts, fiscal year variant, controlling area, tax jurisdiction, and IFRS/local GAAP accounting principle. Serves as the organizational anchor for statutory reporting, financial consolidation, and intercompany accounting.' .

ind:IntercompanyTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Intercompany Transaction' ;
    rdfs:comment 'Records intercompany financial transactions between legal entities within the apparel fashion group, including intercompany sales of finished goods (e.g., sourcing entity to retail entity), royalty and license fee charges, shared service allocations, management fees, and intercompany loans. Captures sending and receiving company codes, transaction type, amount in transaction and group currency, elimination status, netting position, transfer pricing method, and IFRS 10 consolidation treatment. Essential for financial consolidation, transfer pricing documentation (OECD guidelines), and group statutory reporting.' .

ind:TaxItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Item' ;
    rdfs:comment 'Captures tax line items associated with financial transactions in SAP S/4HANA FI, including VAT, sales tax, import duty, withholding tax, and GST. Stores tax code, tax type, taxable base amount, tax amount, tax jurisdiction, reporting period, tax return reference, and filing status. Supports indirect tax compliance, statutory tax reporting, and customs duty reconciliation for apparel fashion global operations.' .

ind:Rfq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Rfq' ;
    rdfs:comment 'Request for Quotation master record capturing the formal solicitation sent to vendors or mills for CMT, FOB, or material pricing. Tracks RFQ number, season, style references, target cost, submission deadline, currency, incoterms, and lifecycle status (draft, issued, under evaluation, awarded, closed). SSOT for all sourcing quote requests.' .

ind:RfqLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Rfq Line' ;
    rdfs:comment 'Individual line item within an RFQ representing a specific style, colorway, or material being quoted. Captures style number, material description, target FOB/CMT cost, MOQ, lead time requested, quantity break tiers, and vendor response status. Enables granular cost comparison across multiple vendor responses for vendor selection.' .

ind:VendorQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Vendor Quote' ;
    rdfs:comment 'Vendor response to an RFQ capturing the quoted FOB price, CMT rate, MOQ, lead time, payment terms, validity period, and any counter-terms. Tracks quote version, currency, landed duty paid (LDP) estimate, and acceptance status. Enables cost negotiation, benchmark comparison, and vendor selection decisions.' .

ind:VendorCostQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Vendor Cost Quote' ;
    rdfs:comment 'Detailed cost breakdown record for a style or material capturing CMT cost components (cut, make, trim), fabric cost, accessories cost, freight, duty, agent commission, and total FOB/LDP cost. Tracks IMU target, COGS estimate, season, cost version, and approval status. Authoritative costing record for pre-production financial planning and margin analysis.' .

ind:SourcingPurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Sourcing Purchase Order' ;
    rdfs:comment 'Approved purchase order issued to a vendor or mill for finished goods, fabric, or trim procurement. Captures PO number, vendor, factory, season, delivery window, FOB port, incoterms, currency, total order value, payment terms (LC, TT), and OTIF tracking flags. The commercial procurement instrument for all sourcing commitments — distinct from production work orders.' .

ind:SourcingPurchaseOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Sourcing Purchase Order Line' ;
    rdfs:comment 'Individual line item on a sourcing purchase order representing a specific SKU, fabric roll, or trim component. Captures style/material reference, ordered quantity, unit cost, UOM, confirmed ship date, and line-level delivery status. Enables granular OTIF tracking and goods receipt reconciliation.' .

ind:TnaCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Tna Calendar' ;
    rdfs:comment 'Time and Action (T&A) calendar master record defining the milestone schedule for a sourcing event or style development cycle during pre-production. Captures season, style, vendor, factory, critical path milestones (fabric approval, PP sample, bulk production start, ex-factory date), planned vs. actual dates, and overall on-track status. SSOT for pre-production T&A management within sourcing scope (post-order production T&A owned by supply/production domains).' .

ind:SourcingTnaMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Sourcing Tna Milestone' ;
    rdfs:comment 'Individual milestone record within a T&A calendar capturing the milestone name (e.g., fabric approval, PP sample submission, bulk cut start), planned date, actual date, responsible party, delay reason code, and completion status. Enables critical path analysis and proactive delay escalation during the pre-production sourcing phase.' .

ind:SampleRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Sample Request' ;
    rdfs:comment 'Sample Management System (SMS) record tracking the full sample lifecycle from request through factory submission and evaluation. Captures sample type (proto, salesman, PP, TOP, counter, fit), season, style reference, colorway, size, requested delivery date, recipient, factory submission date, measurement conformance, evaluation comments (fit, construction, color accuracy, measurement deviations), evaluator, revision round, corrective actions, and final approval decision (approved, approved with comments, rejected). SSOT for all sample requests, counter-sample submissions, and their evaluation outcomes within sourcing.' .

ind:SampleEvaluation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Sample Evaluation' ;
    rdfs:comment 'Evaluation record for a received sample capturing fit comments, construction quality, material compliance, color accuracy, measurement deviations, and overall approval decision (approved, approved with comments, rejected). Tracks evaluator, evaluation date, revision round, and required corrective actions. Drives the PP approval workflow within the sourcing sample management process.' .

ind:LabDip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sourcing ;
    rdfs:label 'Lab Dip' ;
    rdfs:comment 'Lab dip approval record tracking the color development and approval process for a fabric or material. Captures colorway reference, Pantone/color standard, dye lot, mill submission date, evaluation result (approved, rejected, resubmit), delta-E measurement, submission round number, and final approval date. Critical for color accuracy compliance before bulk fabric production commitment.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all supplier and vendor entities in the apparel-fashion supply chain, including CMT factories, OEM/ODM partners, fabric mills, trim suppliers, 3PL providers, and raw material vendors. Captures legal entity name, registration number, country of origin, vendor type (CMT/OEM/ODM/Mill/Trim/3PL), tier classification (Tier 1/2/3), business status, primary contact, headquarters address, currency, payment terms, incoterms, FOB port, lead time, MOQ thresholds, EDI capability flag, VMI eligibility, onboarding stage, onboarding checklist completion percentage, onboarding manager, target go-live date, onboarding completion date, go-live date, and final approval date. SSOT for all vendor identity, commercial terms, and lifecycle status (including onboarding workflow state) across sourcing, production, and supply chain domains.' .

ind:SupplierFactory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Supplier Factory' ;
    rdfs:comment 'Detailed operational profile of a manufacturing facility associated with a vendor, capturing factory name, physical address, country, region, factory type (Cut-Make-Trim, Full Package, Knitting, Weaving, Dyeing, Finishing, Embroidery), production capacity (units/month), number of production lines, workforce headcount, floor area (sqm), machinery types, product categories manufactured, gender specialization (menswear/womenswear/kidswear), minimum order quantity (MOQ), lead time (days), shift structure, and operational status. Distinct from the vendor legal entity — one vendor may operate multiple factories.' .

ind:VendorContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Contact' ;
    rdfs:comment 'Individual contact persons associated with a vendor or factory, capturing full name, job title, department, email, phone, WhatsApp/WeChat handle, preferred communication channel, language, role type (Account Manager, QC Liaison, Compliance Officer, Logistics Coordinator, Finance Contact), primary contact flag, and active status. Supports multi-contact management per vendor for sourcing, production, compliance, and logistics workflows.' .

ind:VendorBankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'Banking and payment settlement details for vendors, including bank name, bank country, account holder name, IBAN/account number, SWIFT/BIC code, routing number, currency, payment method (Wire/ACH/LC/TT), Letter of Credit (LC) terms, LC issuing bank, LC expiry date, preferred payment terms (Net 30/60/90, FOB, LDP), and account verification status. Critical for AP processing, LC issuance, and cross-border payment compliance. Owned by the supplier domain as part of vendor master.' .

ind:FactoryCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Factory Certification' ;
    rdfs:comment 'Tracks all compliance certifications and ethical manufacturing accreditations held by a factory, including certification type (WRAP, FLA, GOTS, OEKO-TEX Standard 100, BCI, ISO 9001, ISO 14001, ISO 45001, SA8000, BSCI, Sedex/SMETA), certifying body, certificate number, issue date, expiry date, scope of certification, audit grade (A/B/C/D), corrective action required flag, certificate document URL, and renewal status. Enables compliance tracking against FTC, CPSC, and ESG reporting obligations.' .

ind:ComplianceAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Compliance Audit' ;
    rdfs:comment 'Records of factory compliance and social responsibility audits conducted by internal teams, third-party auditors, or certification bodies. Captures audit type (Social Compliance, Environmental, Quality, Fire Safety, Chemical/REACH), audit date, auditor name, auditing firm, factory score, findings summary, number of critical/major/minor non-conformances (NCRs), corrective action plan (CAP) required flag, CAP due date, re-audit required flag, and final audit status (Pass/Conditional Pass/Fail). Supports FLA, WRAP, BSCI, and Sedex audit workflows.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual non-conformance findings (NCRs) identified during a compliance or quality audit, capturing finding reference number, audit reference, finding category (Labor, Health & Safety, Environmental, Chemical, Fire Safety, Wages, Working Hours), severity level (Critical/Major/Minor/Observation), finding description, root cause, corrective action required, responsible party at factory, target closure date, actual closure date, evidence document URL, and closure status. Enables granular CAP tracking and repeat-finding analysis.' .

ind:CapacityProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Capacity Profile' ;
    rdfs:comment 'Seasonal and rolling production capacity commitments at the factory level, capturing season (SS25, FW25), product category, allocated/reserved/available capacity (units/month), utilization percentage, peak season flags, lead time by product type, minimum and maximum run sizes, and capacity confirmation date. Drives OTB (Open-to-Buy) planning, production scheduling, and factory loading decisions. One factory may have multiple capacity profiles across seasons and product categories.' .

ind:VendorScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Scorecard' ;
    rdfs:comment 'Periodic performance evaluation of vendor and factory performance across operational KPIs, generated monthly/quarterly/seasonally. Captures OTIF (On-Time In-Full) rate, AQL defect rate, on-time sample submission, PP sample approval rate, compliance audit score, sustainability score, responsiveness rating, cost competitiveness index, overall weighted score, performance tier (Preferred/Approved/Conditional/Probation/Delisted), and evaluation period. Drives strategic sourcing decisions, vendor tiering, allocation preferences, and exit/remediation actions.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Structured risk assessment records for vendors and factories, capturing risk assessment date, risk category (Geopolitical, Financial, Compliance, Capacity, Quality, Environmental, Labor, Logistics, Currency), risk description, likelihood score (1-5), impact score (1-5), inherent risk rating (Low/Medium/High/Critical), mitigation strategy, residual risk rating, risk owner, next review date, and assessment status. Supports supply chain resilience planning and ESG risk reporting.' .

ind:VendorAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Agreement' ;
    rdfs:comment 'Master vendor agreements and framework contracts governing the commercial relationship with a supplier, including agreement type (Master Supply Agreement, CMT Contract, FOB Contract, Fabric Supply Agreement, 3PL SLA), agreement reference number, effective date, expiry date, auto-renewal flag, governing law jurisdiction, incoterms version, payment terms, currency, credit limit, exclusivity clause flag, IP ownership clause, termination notice period, and agreement status (Draft/Active/Expired/Terminated). SSOT for vendor contractual terms within the supplier domain.' .

ind:MaterialSupplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Material Supplier' ;
    rdfs:comment 'Qualified supplier-material association linking approved raw materials, fabrics, and trims to their vetted vendor sources within the Approved Vendor List (AVL). Captures material type (Fabric, Yarn, Trim, Button, Zipper, Label, Packaging), fiber content, composition, supplier item code, UoM, MOQ, lead time, sample lead time, unit cost (FOB), currency, approved colorways, sustainability attributes (organic, recycled, BCI cotton), OEKO-TEX certification flag, qualification date, and approval status. SSOT for vendor-side material qualification and AVL maintenance. Distinct from sourcing domain\'s material development workflow — this product records WHICH vendors are approved to supply WHICH materials after qualification is complete.' .

ind:DeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Time and Action (T&A) calendar defining the critical path from design handoff to ex-factory shipment for a production order or style at a specific factory. Contains calendar header (season, style reference, factory, T&A template version, overall status) and embedded milestone records (milestone name, type such as Sample/Approval/Production/Shipment, planned date, actual date, days variance, responsible party, completion status, escalation flag, comments). Standard milestones include design approval, tech pack issue, fabric booking, PP sample submission/approval, bulk fabric in-house, cut date, sew completion, finishing, final inspection, and ex-factory date. SSOT for factory-execution T&A tracking within the supplier domain. Sourcing domain owns strategic T&A planning; this product owns operational milestone execution at the factory level.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for all marketing campaigns including brand awareness, seasonal launch, performance, influencer, and acquisition initiatives. Captures campaign identity, type, channel mix, target audience segment, budget (planned, allocated, spent, remaining by channel and fiscal period), start/end dates, status, owning brand, season/collection association, CAC target, objectives, and approval workflow. SSOT for campaign definitions and marketing investment planning. Integrates with Adobe Experience Platform for audience activation and Anaplan for financial plan alignment.' .

ind:CampaignExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Execution' ;
    rdfs:comment 'Transactional record capturing actual execution of campaign flights, activations, media placements, and earned media across all paid, owned, and earned channels. Covers paid search, display, programmatic, paid social, email, OOH, print, TV/streaming, influencer activations, PR/earned media placements (publication, journalist, media value, sentiment), and event activations. Tracks flight dates, channel, platform, placement name, ad format, creative asset reference, targeting parameters, bid strategy, daily/lifetime budget, impressions, clicks, reach, frequency, spend, ROAS, and execution status. SSOT for all marketing execution activity regardless of channel type — consolidates paid media placement details and PR/earned media placement tracking.' .

ind:BrandAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Brand Asset' ;
    rdfs:comment 'Master catalog of all brand and creative assets including images, videos, copy, lookbooks, campaign visuals, logo files, and style guides. Captures asset name, type, format, resolution, file size, usage rights, expiry date, brand/collection association, season, channel suitability flags, approval status, and DAM (Digital Asset Management) reference ID. Supports omnichannel creative deployment across retail, e-commerce, and wholesale.' .

ind:Influencer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Influencer' ;
    rdfs:comment 'Master and transactional record for influencer and brand ambassador relationship management. Captures influencer profile (name, handle, platforms, follower count, engagement rate, audience demographics, content niche, tier, geographic market, brand safety score, exclusivity flags) and engagement history including each collaboration event (engagement type, deliverables, content format, fees, payment terms, posting schedule, actual post dates, platform-reported reach/impressions/engagement, link clicks, promo code usage, attributed revenue, gifting details, takeover and event appearances). SSOT for all influencer partnerships, gifting programs, and ambassador activations.' .

ind:InfluencerEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Influencer Engagement' ;
    rdfs:comment 'Transactional record of each influencer collaboration or activation event. Captures engagement type (gifting, paid post, takeover, event appearance, affiliate), contracted deliverables, content format (reel, story, post, blog, video), agreed fee, payment terms, posting schedule, actual post dates, platform-reported reach, impressions, engagement count, link clicks, promo code usage, and attributed revenue. Links to influencer master and campaign.' .

ind:AudienceSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Audience Segment' ;
    rdfs:comment 'Master record defining marketing audience segments used for campaign targeting, personalization, and suppression across channels. Captures segment name, definition logic (rules or ML-derived), segment type (behavioral, demographic, psychographic, lookalike, RFM-based, lifecycle stage), channel applicability, estimated and actual reach, source system (Adobe Experience Platform CDP), refresh frequency, activation status, and associated brand or product category. Enables precision targeting for DTC, wholesale, and retail campaigns.' .

ind:EmailCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Email Campaign' ;
    rdfs:comment 'Master and transactional record for email marketing programs covering promotional blasts, drip sequences, lifecycle communications, and transactional triggers. Captures campaign definition (name, type, subject line, sender, target segment, send schedule, template, personalization, A/B variants, ESP ID, GDPR/CCPA opt-in basis) and recipient-level send events (delivery status, open/click timestamps, bounce type, unsubscribe/spam flags, device type, email client, geolocation). SSOT for email channel performance measurement, deliverability monitoring, and engagement attribution. Sourced from Adobe Experience Platform and ESP event streams.' .

ind:EmailSendEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Email Send Event' ;
    rdfs:comment 'Transactional record of each individual email send event capturing recipient-level delivery and engagement data. Tracks send timestamp, delivery status, open timestamp, click timestamp, clicked URL, unsubscribe flag, bounce type (hard/soft), spam complaint flag, device type, email client, and geolocation. Sourced from Adobe Experience Platform and ESP event streams. Enables deliverability monitoring and engagement attribution.' .

ind:SocialPost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Social Post' ;
    rdfs:comment 'Master and transactional record for owned social media content across brand channels (Instagram, TikTok, Pinterest, Facebook, X/Twitter, YouTube). Captures post definition (platform, type, caption, hashtags, product tags, collection association, publish timestamp, boosted flag, content creator) and engagement events (likes, comments, shares, saves, clicks, video plays, story views with event timestamps, user pseudonyms per GDPR/CCPA, device type, geographic market). Supports brand content calendar management, organic performance measurement, and engagement rate tracking by collection or season.' .

ind:PromoCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Master and transactional record for promotional codes, discount vouchers, and their redemption lifecycle across DTC, e-commerce, and retail channels. Captures code definition (discount type, value, minimum order, applicable categories/SKUs, channel restrictions, usage limits, validity dates, campaign association, status) and redemption events (timestamp, order reference, customer reference, channel, discount applied, order value before/after, redemption status). Enables CAC tracking, campaign ROI measurement, promo abuse fraud detection, and commission reconciliation.' .

ind:PromoRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Promo Redemption' ;
    rdfs:comment 'Transactional record of each promotional code redemption event. Captures redemption timestamp, promo code reference, order reference, customer reference, channel (DTC, e-commerce, retail POS), discount amount applied, order value before and after discount, and redemption status. Enables campaign effectiveness measurement, CAC calculation, and fraud detection for promo abuse.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Event' ;
    rdfs:comment 'Master record for physical and virtual marketing events including runway shows, pop-up activations, trade shows, press days, brand experiences, and wholesale previews. Captures event name, event type, venue, city/market, event date(s), target audience (press, buyers, consumers, VIPs), expected attendance, actual attendance, budget, associated season/collection, sponsorship details, and event status. Coordinates brand experience activations across markets.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Core master record for every inbound and outbound shipment movement in the apparel supply chain. Captures shipment type (FOB, LDP, DTC, wholesale, inter-facility transfer), origin and destination facilities, carrier assignment, transport mode (ocean FCL/LCL, air, ground, courier, rail), booking reference, ETD/ETA and actual departure/arrival timestamps, carton count, gross weight, cubic volume, freight cost estimate, insurance value, current milestone status, and priority flag. Serves as the SSOT for shipment identity across the logistics domain, linking to purchase orders, sales orders, 3PL partners, customs entries, and freight bookings. Supports both pre-retail (factory-to-DC) and post-retail (DC-to-store, DC-to-consumer) movements.' .

ind:ShipmentMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Milestone' ;
    rdfs:comment 'Transactional event log capturing every status milestone reached by a shipment throughout its lifecycle — booked, departed origin port, arrived transshipment hub, customs cleared, arrived destination DC, delivered to store or customer. Records milestone code, actual timestamp, location (port, facility, GPS coordinates), responsible party (carrier, 3PL, customs broker), exception flag, and variance from planned milestone date. Enables OTIF tracking and SLA compliance monitoring for apparel shipments.' .

ind:FreightBooking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Freight Booking' ;
    rdfs:comment 'Records the formal booking of freight capacity with a carrier or freight forwarder for apparel shipments. Captures booking reference number, carrier/forwarder identity, service type (FCL, LCL, air charter, express courier), vessel or flight details, port of loading, port of discharge, booking date, cut-off date, confirmed space allocation, rate agreement reference, and booking status. Supports capacity planning and carrier performance management for seasonal collection launches.' .

ind:CustomsEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Customs Entry' ;
    rdfs:comment 'Manages customs clearance declarations for apparel and footwear imports and exports. Stores entry type (formal, informal, in-bond), entry number, filing date, port of entry, importer of record, customs broker, declared value, duty amount, applicable trade program (GSP, FTA), HS code references, country of origin, and clearance status. Tracks holds, exams, and release dates. Manages associated trade compliance documents including certificates of origin, commercial invoices, and ISF (10+2) filings as structured attributes. Critical for FTC labeling compliance and trade compliance reporting across all sourcing countries.' .

ind:HsCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Reference master for Harmonized System (HS) tariff classification codes applicable to apparel, footwear, and accessories. Stores HS code, chapter, heading, subheading, full description, applicable duty rate, preferential duty rates by trade agreement, restricted/prohibited flag, CPSC safety classification, FTC fiber content labeling requirement flag, and effective date range. Enables accurate duty calculation, GSP utilization, and customs entry filing across all import/export lanes.' .

ind:DutyCalculation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Duty Calculation' ;
    rdfs:comment 'Transactional record of landed duty paid (LDP) calculations performed for apparel purchase orders and shipments. Captures FOB value, freight cost, insurance, CIF value, applicable HS code, duty rate applied, GSP or FTA preference claimed, anti-dumping/countervailing duty amounts, MPF, HMF, total duty and tax, calculated LDP unit cost, and calculation timestamp. Feeds COGS and financial planning in Anaplan and SAP FI/CO for accurate margin management.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all transportation carriers engaged by the apparel business — ocean shipping lines (Maersk, MSC, CMA CGM), air freight carriers, domestic LTL/FTL truckers, last-mile couriers (FedEx, UPS, DHL), and rail operators. Stores SCAC code, DOT number, carrier name, carrier type, service modes, contract reference, preferred/approved/probation status, insurance certificate, on-time performance score, and active status. SSOT for carrier identity referenced by freight bookings, shipments, routing guides, SLAs, and freight invoices.' .

ind:RoutingGuide rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Routing Guide' ;
    rdfs:comment 'Defines the approved transportation routing rules and carrier assignments for apparel shipments by lane, origin-destination pair, shipment type, and season. Captures lane origin region, destination DC or store, preferred carrier, backup carrier, service level (standard, expedite, direct), mode of transport, maximum transit days, freight terms (FOB, prepaid, collect), effective date range, and compliance requirement flag. Used by sourcing and logistics teams to enforce carrier compliance and cost controls.' .

ind:DistributionCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Distribution Center' ;
    rdfs:comment 'Master record for all distribution centers, fulfillment centers, cross-dock facilities, and returns processing centers in the apparel logistics network. Captures DC code, facility name, full address, facility type (owned DC, 3PL-operated, cross-dock, returns center, forward stocking location), total square footage, storage capacity by zone (bulk, pick, hanging, cold), throughput capacity (units/day), WMS instance (Manhattan Associates), operating hours, supported channels (wholesale, DTC, retail replenishment, outlet), and active status. SSOT for facility identity referenced by inventory, shipment, and allocation processes.' .

ind:ThirdPartyLogistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Third Party Logistics' ;
    rdfs:comment 'Master record for all third-party logistics (3PL) providers engaged to operate warehousing, fulfillment, transportation, or customs brokerage services for the apparel business. Stores 3PL partner identifier, company name, service type (warehousing, fulfillment, freight forwarding, customs brokerage, last-mile delivery), contract reference, geographic coverage regions, EDI capability flag, WMS integration type (API, EDI 940/945, flat file), SLA tier, composite performance rating, insurance coverage amount, onboarding status, and relationship effective dates. Distinct from the supplier domain which covers manufacturing vendors — this entity specifically governs logistics service providers. Note: PK uses legacy _3pl_partner_id naming convention pending infrastructure-level schema generation fix.' .

ind:SlaAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Sla Agreement' ;
    rdfs:comment 'Defines the service level agreements governing logistics performance commitments between the apparel business and its 3PL partners, carriers, and distribution network nodes. Captures SLA type (transit time, OTIF, order accuracy, damage rate, customs clearance time), counterparty identity, applicable lane or facility scope, target metric value, measurement frequency, penalty structure, bonus structure, effective date range, and review cycle. Enables automated SLA breach detection and carrier scorecard generation.' .

ind:PackingList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Packing List' ;
    rdfs:comment 'Shipping document record capturing the detailed contents of each shipment carton or container for apparel and footwear exports. Stores packing list number, associated shipment reference, carton count, total units, SKU-level breakdown (style, color, size, quantity per carton), gross weight, net weight, cubic measurement, carton dimensions, and packing method (flat pack, hanging, polybag). Required for customs clearance, DC receiving, and RFID-enabled carton scanning at Manhattan Associates WMS.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Master record for bank accounts maintained in SAP S/4HANA FI (house banks and account IDs) used for payment processing, cash pooling, and treasury management. Captures bank key, account number, IBAN, SWIFT/BIC, currency, GL reconciliation account, account type (operating, payroll, LC), daily balance, and bank relationship details. Essential for cash flow management, payment run configuration, and Letter of Credit settlement in apparel fashion global operations.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Lot' ;
    rdfs:comment 'Production lot or batch record representing a discrete manufacturing run of a style/SKU at a factory, enabling end-to-end traceability from raw materials through finished goods. Captures lot number, work order reference, factory, style/SKU, production date range, quantity produced, fabric shade lot references, cut order references, operator/line assignment, lot status (open, closed, on-hold), and traceability chain linking upstream material lots to downstream carton/shipment IDs. Supports recall scenarios, customer complaint investigation, regulatory compliance (CPSIA, EU textile regulation), and batch-level quality metrics. SSOT for production batch identity within the production domain.' .

ind:LetterOfCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Letter Of Credit' ;
    rdfs:comment 'Letter of Credit documentary credit record managing trade finance for international supplier payments including LC type, amount, beneficiary, and document requirements' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of goods at a warehouse, DC, or port of entry against a purchase order including receipt date, received quantities, and quality status' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master reference table for brand. Referenced by brand_id.' .

ind:PriceBook rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Price Book' ;
    rdfs:comment 'Master reference table for price_book. Referenced by price_book_id.' .

ind:Zone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Zone' ;
    rdfs:comment 'Master reference table for zone. Referenced by zone_id.' .

ind:Lane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Lane' ;
    rdfs:comment 'Master reference table for lane. Referenced by lane_id.' .

ind:Cluster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Cluster' ;
    rdfs:comment 'Master reference table for store_cluster. Referenced by store_cluster_id.' .

ind:Division rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Division' ;
    rdfs:comment 'Master reference table for division. Referenced by division_id.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Master reference table for channel. Referenced by channel_id.' .

ind:Region rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Region' ;
    rdfs:comment 'Master reference table for region. Referenced by region_id.' .

ind:AllocationRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Allocation Rule' ;
    rdfs:comment 'Master reference table for allocation_rule. Referenced by allocation_rule_id.' .

ind:Marker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Marker' ;
    rdfs:comment 'Master reference table for marker. Referenced by marker_id.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Line' ;
    rdfs:comment 'Master reference table for production_line. Referenced by production_line_id.' .

ind:DeliveryWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Production ;
    rdfs:label 'Delivery Window' ;
    rdfs:comment 'Master reference table for delivery_window. Referenced by delivery_window_id.' .

ind:Register rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Register' ;
    rdfs:comment 'Master reference table for register. Referenced by register_id.' .

ind:District rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'District' ;
    rdfs:comment 'Master reference table for district. Referenced by district_id.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Master reference table for contract. Referenced by contract_id.' .

ind:Planogram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Planogram' ;
    rdfs:comment 'Master reference table for planogram. Referenced by planogram_id.' .

ind:SegmentMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment Membership' ;
    rdfs:comment 'This association product represents the Membership relationship between a consumer profile and a named market segment. It captures the operational assignment of a profile to a segment as managed in Adobe Experience Platform and synced to Salesforce CRM. Each record links one profile to one segment and carries attributes that exist only in the context of that membership — including when the assignment occurred, how it was triggered, how strongly the profile qualifies, and whether the membership is currently active.. Existence Justification: In apparel fashion CDP/CRM operations (Adobe Experience Platform, Salesforce Marketing Cloud), segment membership is an explicitly managed operational concept: profiles are evaluated against segment criteria, assigned to segments, and removed when criteria are no longer met. A single consumer profile belongs to multiple segments simultaneously (e.g., \'High-Value Loyalist\', \'Summer Campaign Target\', \'Size-M Women\'s Activewear\'), and each segment contains thousands of profiles. The business actively creates, updates, and expires these memberships as part of campaign activation workflows — this is not derivable from transactional joins alone.' .

# --- Attribute Properties ---
ind:assortmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Assortment Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the assortment plan record in the Databricks Silver Layer. Primary key generated by the lakehouse ingestion pipeline from Oracle Retail Merchandising System assortment planning module.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentPlan .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Assortment plans are sized to support seasonal marketing campaigns. Merchandisers need campaign timing, expected lift, and channel mix to plan OTB budgets and style counts. This link enables campaign-' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:clusterId rdf:type rdf:Property ;
    rdfs:label 'Cluster Id' ;
    rdfs:comment 'Reference to the store cluster grouping used for assortment localization. Store clusters segment stores by volume tier, climate zone, or customer demographics to enable differentiated assortment depth and size curve optimization within Oracle Retail allocation module.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cluster .

ind:collectionId rdf:type rdf:Property ;
    rdfs:label 'Collection Id' ;
    rdfs:comment 'Reference to the parent collection or line plan in Centric PLM or Oracle Retail. Links the assortment plan to the upstream collection planning and product design lifecycle managed in Centric PLM collection management module.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collection .

ind:collectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Collection Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.collection_plan. Business justification: Assortment plans operationalize collection plans by defining the specific SKU-level assortments, store clusters, and channel strategies for a collection. The collection_plan defines the thematic visio' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionPlan .

ind:colorwayId rdf:type rdf:Property ;
    rdfs:label 'Colorway Id' ;
    rdfs:comment 'Foreign key linking to product.colorway. Business justification: Assortment plans track colorway_count_planned and drive color depth decisions per season. Planners select specific colorways for inclusion in an assortment. This FK enables colorway-level assortment a' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Colorway .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Assortment plans are budgeted and tracked against cost centers for departmental P&L accountability. Merchandising teams must report plan performance (sales, margin, markdown) by cost center for financ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Assortment plans target specific customer segments (Gen Z urban, affluent suburban, value-conscious families). Segment demographics and preferences drive category mix, price points, and style selectio' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:distributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Receipt planning and DC allocation strategy: assortment plans must identify the receiving DC to enable inbound capacity planning and channel allocation. Apparel planners assign assortments to DCs to c' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Assortment plans contain markdown_budget_amount and IMU/MMU targets that map to GL accounts for markdown expense and inventory valuation. Finance uses GL account assignment on assortment plans for mar' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:merchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Merchandise Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to merchandising.merchandise_hierarchy. Business justification: Assortment plans have department_id, class_id, subclass_id but no FK to merchandise_hierarchy master. Adding merchandise_hierarchy_id FK normalizes merchandise classification and removes redundant hie' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:otbBudgetId rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Id' ;
    rdfs:comment 'Foreign key linking to merchandising.otb_budget. Business justification: Assortment plans reference OTB budget amounts but have no FK to otb_budget master. Adding otb_budget_id FK normalizes budget reference and removes redundant otb_budget_amount. FK will reference mercha' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtbBudget .

ind:productionFactoryId rdf:type rdf:Property ;
    rdfs:label 'Production Factory Id' ;
    rdfs:comment 'Foreign key linking to production.factory. Business justification: Strategic assortment plans designate preferred factories based on capability, capacity, and cost structure. Drives sourcing strategy and factory capacity reservation for seasonal collections.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionFactory .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Assortment plans drive revenue and margin by channel/brand, tracked via profit centers. Financial reporting requires linking planned vs actual performance (sales, GMROI, STR) to profit centers for seg' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to sourcing.rfq. Business justification: Assortment planning directly triggers RFQ issuance in apparel sourcing. Merchandisers finalize the assortment plan and sourcing issues RFQs against it. This link enables assortment-to-sourcing traceab' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Foreign key linking to merchandising.season. Business justification: Assortment plans are inherently seasonal; season_code exists but no FK to season master. Adding season_id FK normalizes season reference and removes redundant season_code. FK will reference merchandis' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:styleId rdf:type rdf:Property ;
    rdfs:label 'Style Id' ;
    rdfs:comment 'Foreign key linking to product.style. Business justification: Assortment planning is the core merchandising process of selecting which styles enter a season\'s range. Planners build style-level assortment decisions (range reviews, OTB by style, style count target' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Style .

ind:tnaCalendarId rdf:type rdf:Property ;
    rdfs:label 'Tna Calendar Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_tna_calendar. Business justification: Assortment plans drive TNA calendar creation — the TNA calendar tracks all milestones required to deliver the assortment on time. Buyers and planners monitor TNA calendars against assortment plan floo' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TnaCalendar .

ind:vendorCostQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Cost Quote Id' ;
    rdfs:comment 'Foreign key linking to sourcing.vendor_cost_quote. Business justification: Assortment planners validate IMU targets against vendor cost quotes during plan finalization. The assortment plan\'s imu_target_pct and aur_target are directly validated against vendor_cost_quote.fob_c' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorCostQuote .

ind:allocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Allocation Strategy' ;
    rdfs:comment 'Inventory allocation methodology applied to this assortment plan. top_down = corporate-driven allocation to stores; bottom_up = store-requested replenishment; hybrid = combination approach; vmi = Vendor Managed Inventory (VMI) where the supplier manages replenishment. Drives Oracle Retail allocation module configuration.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the assortment plan was formally approved and the OTB budget was committed. Marks the transition from \'submitted\' to \'approved\' status and triggers downstream PO generation and T&A calendar activation in SAP S/4HANA and Infor PLM.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aurTarget rdf:type rdf:Property ;
    rdfs:label 'Aur Target' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price for the assortment, representing the expected average selling price per unit across all styles and colorways in the plan. A key KPI in Anaplan merchandise financial planning used to project net sales and validate GMROI targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryForwardPct rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Pct' ;
    rdfs:comment 'Percentage of styles in this assortment plan that are carried forward from the prior season versus new introductions. A key collection planning metric used by merchants to balance newness investment against proven performers. Expressed as a percentage of total style count.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Distribution channel for which this assortment plan is defined. Drives channel-specific assortment depth, pricing strategy, and OTB budget allocation. DTC (Direct-to-Consumer) includes both retail stores and e-commerce. Values: retail (brick-and-mortar stores), ecommerce (Salesforce Commerce Cloud digital storefront), wholesale (partner accounts), dtc (combined direct channels), outlet (off-price stores).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Colorway Count Planned' ;
    rdfs:comment 'Number of distinct colorways planned across all styles in the assortment. Colorway depth is a key assortment decision in apparel fashion, balancing color story cohesion against inventory fragmentation risk.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the assortment plan record was first created in the Oracle Retail Merchandising System and ingested into the Databricks Silver Layer. Serves as the RECORD_AUDIT_CREATED for this entity. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary values in this assortment plan (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency wholesale and DTC channels in SAP S/4HANA FI/CO and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imuTargetPct rdf:type rdf:Property ;
    rdfs:label 'Imu Target Pct' ;
    rdfs:comment 'Target Initial Markup (IMU) percentage for the assortment plan, expressed as a percentage of retail price. IMU = (Retail Price − Cost) / Retail Price × 100. Drives cost negotiation targets with suppliers and is a primary input to GMROI optimization in Anaplan merchandise financial planning.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinalVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Version' ;
    rdfs:comment 'Indicates whether this record represents the final approved version of the assortment plan (True) or a superseded draft/revision (False). Used to filter active plan versions in reporting and analytics without requiring version_number logic.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Required' ;
    rdfs:comment 'Indicates whether suppliers fulfilling this assortment plan must hold active FLA (Fair Labor Association) or WRAP (Worldwide Responsible Accredited Production) certification. Enforced during supplier onboarding in Infor PLM sourcing and SAP S/4HANA MM vendor master.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Amount' ;
    rdfs:comment 'Total markdown (MD) budget allocated to this assortment plan for planned price reductions during the selling season. Markdown budget is a key input to MMU calculation and is managed in Anaplan merchandise financial planning and Oracle Retail Price Management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmuTargetPct rdf:type rdf:Property ;
    rdfs:label 'Mmu Target Pct' ;
    rdfs:comment 'Target Maintained Markup (MMU) percentage after accounting for planned markdowns (MD), shrinkage, and employee discounts. MMU reflects the realized margin and is the primary profitability metric tracked in Anaplan merchandise financial planning alongside GMROI.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpMax rdf:type rdf:Property ;
    rdfs:label 'Msrp Max' ;
    rdfs:comment 'Highest Manufacturer\'s Suggested Retail Price (MSRP) point within the assortment plan\'s price architecture. Defines the ceiling price tier and is used alongside msrp_min to establish the price range strategy and IMU targets for the planned assortment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpMin rdf:type rdf:Property ;
    rdfs:label 'Msrp Min' ;
    rdfs:comment 'Lowest Manufacturer\'s Suggested Retail Price (MSRP) point within the assortment plan\'s price architecture. Defines the entry price tier for the planned assortment and is used in IMU (Initial Markup) and AUR (Average Unit Retail) calculations in Oracle Retail Price Management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbUnitsPlanned rdf:type rdf:Property ;
    rdfs:label 'Otb Units Planned' ;
    rdfs:comment 'Total number of units planned for procurement under this assortment plan\'s OTB budget. Used to calculate average unit cost, validate MOQ (Minimum Order Quantity) compliance with suppliers, and drive purchase order (PO) generation in SAP S/4HANA MM.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known business identifier for the assortment plan, assigned by the Oracle Retail Merchandising System. Used by merchants and planners to reference the plan across systems (e.g., ORM-AP-2025-FALL-WMN-001). Serves as the BUSINESS_IDENTIFIER for this entity.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Date on which the assortment plan expires or the season closes. Marks the end of the active selling window and triggers end-of-season markdown (MD) and clearance processes. Serves as the EFFECTIVE_UNTIL for this entity. Nullable for open-ended NOS assortments.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the assortment plan (e.g., \'Fall 2025 Women\'s Outerwear – North America DTC\'). Used by merchants and planners to identify the plan in reporting dashboards and Anaplan merchandise financial planning views. Serves as the IDENTITY_LABEL for this entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date on which the assortment plan becomes effective for in-season execution — i.e., the first floor-set or go-live date for the planned assortment. Used to align T&A (Time and Action) calendar milestones and pre-production (PP) sample review schedules. Serves as the EFFECTIVE_FROM for this MASTER_AGREEMENT-role entity.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the assortment plan within the Oracle Retail Merchandising System workflow. Drives downstream OTB budget release, allocation activation, and collection planning milestones. Valid states: draft (initial creation), submitted (pending merchant approval), approved (OTB committed), active (in-season execution), closed (season ended), cancelled (plan voided). Serves as the LIFECYCLE_STATUS for this entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the assortment plan by merchandise strategy. seasonal = time-bound seasonal collection; core = evergreen carry-forward styles; nos = Never Out of Stock (NOS) replenishment assortment; capsule = limited-edition capsule collection; collab = brand collaboration or licensed assortment. Drives OTB budget methodology and replenishment logic.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentEligible rdf:type rdf:Property ;
    rdfs:label 'Replenishment Eligible' ;
    rdfs:comment 'Indicates whether styles within this assortment plan are eligible for automated replenishment (True) or are one-time buys with no replenishment (False). NOS (Never Out of Stock) assortments are always True. Drives replenishment trigger logic in Oracle Retail allocation and Manhattan Associates WMS.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonYear rdf:type rdf:Property ;
    rdfs:label 'Season Year' ;
    rdfs:comment 'Four-digit calendar year associated with the merchandise season (e.g., 2025). Used for year-over-year sell-through rate (STR) comparisons and GMROI trend analysis in Anaplan financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeRange rdf:type rdf:Property ;
    rdfs:label 'Size Range' ;
    rdfs:comment 'Planned size range for the assortment (e.g., \'XS-3XL\', \'00-24\', \'5-13\'). Defines the inclusive size offering for the plan and is used to validate size curve alignment with store cluster demographics and FTC textile labeling requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this assortment plan record originated. ORM = Oracle Retail Merchandising System; ANAPLAN = Anaplan Merchandise Planning; CENTRIC = Centric PLM; MANUAL = manually entered override. Used for data lineage tracking in the Databricks Silver Layer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sourcing Country Code' ;
    rdfs:comment 'ISO 3166-1 Alpha-3 country code of the primary manufacturing/sourcing country for this assortment plan (e.g., BGD=Bangladesh, VNM=Vietnam, CHN=China). Used for landed duty paid (LDP) cost modeling, HS Code tariff classification, and GSP eligibility assessment in SAP S/4HANA MM and Infor PLM sourcing.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strTargetPct rdf:type rdf:Property ;
    rdfs:label 'Str Target Pct' ;
    rdfs:comment 'Target Sell-Through Rate (STR) for the assortment plan, expressed as a percentage of units sold versus units received. STR = (Units Sold / Units Received) × 100. Used to set end-of-season inventory clearance expectations and validate OTB buy depth in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:styleCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Style Count Planned' ;
    rdfs:comment 'Number of distinct styles (parent product silhouettes) planned in the assortment, independent of colorway or size. Style count is a key assortment breadth metric used by merchants to balance newness versus carry-forward depth in collection planning.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityCertified rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified' ;
    rdfs:comment 'Indicates whether the assortment plan requires sustainability certification compliance (True) such as GOTS (Global Organic Textile Standard), OEKO-TEX Standard 100, or BCI (Better Cotton Initiative). Drives supplier qualification requirements in Infor PLM sourcing and compliance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSkuCountPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count Planned' ;
    rdfs:comment 'Total number of distinct SKUs (Stock Keeping Units) planned within this assortment, representing the breadth of the assortment. Includes all style-color-size combinations. Used to assess assortment productivity and compare planned vs. actual SKU rationalization outcomes.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the assortment plan record in the source system or Silver Layer. Tracks plan revisions, OTB reforecasts, and status transitions. Serves as the RECORD_AUDIT_UPDATED for this entity. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Incremental version number of the assortment plan, starting at 1. Incremented each time the plan is revised (e.g., OTB reforecast, style additions/deletions). Enables version history tracking and comparison of plan iterations in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wosTarget rdf:type rdf:Property ;
    rdfs:label 'Wos Target' ;
    rdfs:comment 'Target Weeks of Supply (WOS) for the assortment plan, representing the planned number of weeks of inventory coverage at the expected rate of sale. WOS = On-Hand Units / Average Weekly Sales. Used to calibrate buy depth and replenishment triggers in Oracle Retail allocation module.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Reference to the brand under which this collection is planned and marketed (e.g., athletic, lifestyle, luxury sub-brand). Supports multi-brand portfolio planning and brand-level GMROI reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:divisionId rdf:type rdf:Property ;
    rdfs:label 'Division Id' ;
    rdfs:comment 'Reference to the merchandise division (e.g., Womens, Mens, Kids, Accessories) to which this collection plan belongs. Aligns with Oracle Retail Merchandising System merchandise hierarchy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the business stakeholder (e.g., VP Merchandising, Creative Director) who formally approved this collection plan. Supports audit trail and governance requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the collection plan received formal business approval. Marks the transition from planning to execution phase and triggers downstream T&A calendar activities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelAllocationStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Allocation Strategy' ;
    rdfs:comment 'Planned channel distribution strategy for this collection. DTC (Direct-to-Consumer) First = prioritize own retail and e-commerce; Wholesale First = prioritize wholesale partners; Balanced = equal distribution. Drives allocation decisions in Oracle Retail and Salesforce Commerce Cloud.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTheme rdf:type rdf:Property ;
    rdfs:label 'Collection Theme' ;
    rdfs:comment 'Descriptive thematic concept or creative narrative for the collection (e.g., \'Urban Nomad\', \'Coastal Luxe\', \'Performance Elevated\'). Guides design direction, marketing storytelling, and visual merchandising.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection by commercial strategy. Mainline = full seasonal assortment; Capsule = focused limited assortment; Collaboration = co-branded with external partner; Limited_Edition = restricted volume; Carry_Over = NOS (Never Out of Stock) continuity styles; Core = foundational basics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBriefUrl rdf:type rdf:Property ;
    rdfs:label 'Design Brief Url' ;
    rdfs:comment 'URL or document path to the creative design brief for this collection plan stored in Centric PLM or a connected document management system. Provides access to mood boards, color palettes, and thematic direction.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Dtc Allocation Pct' ;
    rdfs:comment 'Planned percentage of total collection inventory allocated to Direct-to-Consumer (DTC) channels (own retail stores and e-commerce). Expressed as a decimal (e.g., 0.6000 = 60%). Used in channel allocation planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'First Delivery Date' ;
    rdfs:comment 'Planned date of the first merchandise delivery to distribution centers or stores for this collection. Anchors the T&A (Time and Action) calendar and drives pre-production planning milestones.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Primary gender demographic target for this collection plan. Drives assortment architecture, sizing standards, and marketing segmentation. Aligns with Oracle Retail merchandise hierarchy gender classification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Planned date of the final merchandise delivery for this collection. Defines the end of the inbound supply window and informs markdown timing and end-of-season clearance planning.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this collection plan record. Supports change tracking, incremental data loading, and audit compliance in the Databricks Silver Layer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineArchitectureVersion rdf:type rdf:Property ;
    rdfs:label 'Line Architecture Version' ;
    rdfs:comment 'Version identifier for the line architecture document associated with this collection plan (e.g., v1.0, v2.3). Tracks iterative changes to style count, category mix, and price tier targets during the planning process in Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbLockDate rdf:type rdf:Property ;
    rdfs:label 'Otb Lock Date' ;
    rdfs:comment 'Date on which the OTB (Open-to-Buy) budget for this collection plan is locked and committed. After this date, budget changes require formal approval. Managed in Anaplan Merchandise Planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAurAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Aur Amount' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price for the collection in the planning currency. Represents the expected average selling price per unit across all styles and channels, used in revenue and unit planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCogsAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cogs Amount' ;
    rdfs:comment 'Total planned Cost of Goods Sold (COGS) for this collection plan in the planning currency. Used to calculate planned gross margin and GMROI targets in Anaplan financial planning.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Planned Gross Margin Pct' ;
    rdfs:comment 'Planned gross margin percentage for the collection, expressed as a decimal (e.g., 0.6200 = 62.00%). Derived from planned revenue and COGS targets; stored as a planning input in Anaplan to support IMU (Initial Markup) and MMU (Maintained Markup) targets.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue Amount' ;
    rdfs:comment 'Total planned net sales revenue target for this collection plan in the planning currency. Used as the top-line financial KPI for merchandise financial planning and GMROI optimization in Anaplan.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStrPct rdf:type rdf:Property ;
    rdfs:label 'Planned Str Pct' ;
    rdfs:comment 'Target Sell-Through Rate (STR) for the collection, expressed as a decimal (e.g., 0.8500 = 85%). Represents the planned percentage of received inventory expected to sell at full price or planned markdown cadence before end of season.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceTierDistribution rdf:type rdf:Property ;
    rdfs:label 'Price Tier Distribution' ;
    rdfs:comment 'Planned percentage distribution of styles across price tiers (e.g., \'Entry:20%|Mid:50%|Premium:30%\'). Guides assortment architecture to balance accessibility and margin. Stored as a structured string; detailed tier breakdowns managed in Anaplan.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryMix rdf:type rdf:Property ;
    rdfs:label 'Product Category Mix' ;
    rdfs:comment 'Planned distribution of styles across product categories within the collection (e.g., \'Tops:35%|Bottoms:25%|Outerwear:20%|Footwear:15%|Accessories:5%\'). Stored as a structured string; detailed breakdowns managed in Anaplan and Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Range Review Date' ;
    rdfs:comment 'Scheduled date for the formal range review meeting where the collection plan is presented to commercial and creative stakeholders for approval. A key milestone in the T&A (Time and Action) calendar.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the retail season type for this collection plan. Drives line architecture, delivery cadence, and OTB budget allocation. [ENUM-REF-CANDIDATE: Spring/Summer|Fall/Winter|Resort|Pre-Fall|Holiday|Cruise — promote to reference product if additional seasons are added]' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellEndDate rdf:type rdf:Property ;
    rdfs:label 'Sell End Date' ;
    rdfs:comment 'Planned date when the collection is retired from active selling. Triggers end-of-season markdown strategy and clearance allocation. Effective-until date for the collection\'s commercial lifecycle.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sellStartDate rdf:type rdf:Property ;
    rdfs:label 'Sell Start Date' ;
    rdfs:comment 'Planned date when the collection becomes available for sale to consumers across channels. Aligns with marketing campaign launch and store floor set dates. Effective-from date for the collection\'s commercial lifecycle.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityRating rdf:type rdf:Property ;
    rdfs:label 'Sustainability Rating' ;
    rdfs:comment 'Planned sustainability certification tier for the collection based on material sourcing and production standards. Reflects compliance with GOTS, BCI, OEKO-TEX, and FLA standards. Drives supplier selection and marketing claims.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainableMaterialPct rdf:type rdf:Property ;
    rdfs:label 'Sustainable Material Pct' ;
    rdfs:comment 'Planned percentage of styles in the collection using certified sustainable materials (organic cotton, recycled polyester, BCI cotton, etc.). Expressed as a decimal (e.g., 0.4000 = 40%). Supports ESG reporting and FTC textile labeling compliance.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarketRegion rdf:type rdf:Property ;
    rdfs:label 'Target Market Region' ;
    rdfs:comment 'Primary geographic market region(s) for which this collection is planned (e.g., \'NAM\', \'EMEA\', \'APAC\', \'GLOBAL\'). Influences sizing standards, labeling requirements, and channel allocation strategy. [ENUM-REF-CANDIDATE: NAM|EMEA|APAC|LATAM|GLOBAL|DOMESTIC — promote to reference product]' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSkuCount rdf:type rdf:Property ;
    rdfs:label 'Target Sku Count' ;
    rdfs:comment 'Planned total number of SKUs (Stock Keeping Units) across all styles, colors, and sizes in this collection. Drives warehouse capacity planning, OTB budget, and assortment depth decisions.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetStyleCount rdf:type rdf:Property ;
    rdfs:label 'Target Style Count' ;
    rdfs:comment 'Planned number of distinct styles (SKU families) to be included in this collection. A key line architecture metric used to manage assortment breadth and design resource allocation in Centric PLM.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Wholesale Allocation Pct' ;
    rdfs:comment 'Planned percentage of total collection inventory allocated to wholesale and distribution partners. Expressed as a decimal (e.g., 0.4000 = 40%). Complements DTC allocation to sum to 100% of planned inventory.' ;
    rdfs:domain ind:CollectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Multi-entity apparel companies scope OTB budgets to a legal entity (company code) for statutory financial reporting and intercompany inventory transfer planning. Finance requires company code on OTB b' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: OTB budgets are maintained within a specific accounting ledger for period-close reconciliation of planned vs. actual receipts. Multi-GAAP apparel companies require ledger assignment on OTB budgets to ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:merchandiseFinancialPlanId rdf:type rdf:Property ;
    rdfs:label 'Merchandise Financial Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.merchandise_financial_plan. Business justification: OTB budgets are the tactical monthly execution of the strategic merchandise financial plan. The MFP sets top-down financial targets (planned sales, COGS, GM%, IMU%, markdown budget) for a season/depar' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseFinancialPlan .

ind:retailStoreId rdf:type rdf:Property ;
    rdfs:label 'Retail Store Id' ;
    rdfs:comment 'Reference to the channel or location (e.g., retail store, e-commerce, wholesale) for which this OTB budget is defined. Enables channel-level OTB tracking across DTC and wholesale.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:actualReceiptsCost rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts Cost' ;
    rdfs:comment 'The actual merchandise receipt value at cost consumed by confirmed purchase orders (POs) for the OTB budget month to date. Used for open-to-buy cost-basis tracking and cash flow management. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts Retail' ;
    rdfs:comment 'The actual merchandise receipt value at retail price consumed by confirmed buy plans and purchase orders (POs) for the OTB budget month to date. Compared against planned receipts to compute remaining OTB. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Percent' ;
    rdfs:comment 'The variance threshold percentage (e.g., 0.10 = 10%) at which a merchant alert is triggered for this OTB budget record. When actual receipts or sales deviate from plan by more than this threshold, an alert is raised for merchant review and OTB recalculation.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertTriggered rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered' ;
    rdfs:comment 'Indicates whether a merchant alert has been triggered for this OTB budget record due to variance exceeding the defined alert threshold. True = alert active and pending merchant review; False = within acceptable variance range.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:anaplanModelCode rdf:type rdf:Property ;
    rdfs:label 'Anaplan Model Code' ;
    rdfs:comment 'The unique identifier of the Anaplan model and workspace from which this OTB budget record was sourced. Enables traceability back to the originating Anaplan planning model for reconciliation and audit.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomInventoryCost rdf:type rdf:Property ;
    rdfs:label 'Bom Inventory Cost' ;
    rdfs:comment 'The value of on-hand inventory at cost (landed duty paid) at the beginning of the OTB budget month. Used for COGS tracking and gross margin analysis. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomInventoryRetail rdf:type rdf:Property ;
    rdfs:label 'Bom Inventory Retail' ;
    rdfs:comment 'The value of on-hand inventory at retail (selling) price at the beginning of the OTB budget month. Used as the opening inventory position in the OTB formula: OTB = Planned EOM Inventory + Planned Sales + Planned Markdowns - BOM Inventory. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetMonth rdf:type rdf:Property ;
    rdfs:label 'Budget Month' ;
    rdfs:comment 'The calendar month (1–12) to which this OTB budget record applies. OTB is recalculated monthly; this field identifies the specific planning month within the budget year.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the OTB budget record. Draft: under construction by planner. Submitted: pending merchant approval. Approved: authorized for buying. Locked: frozen for the period. Closed: period ended. Revised: re-opened for adjustment.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of the OTB budget record, incremented each time the budget is revised or re-submitted. Supports version control and audit trail for merchandise financial planning changes in Anaplan.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'The fiscal or calendar year (e.g., 2025) to which this OTB budget record applies. Used for annual merchandise financial planning and year-over-year variance analysis.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The last date through which this OTB budget record is effective. Typically the last day of the budget month. After this date, the budget is closed and actuals are reconciled.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The first date from which this OTB budget record is effective and binding for merchandise purchasing decisions. Typically the first day of the budget month.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eomInventoryTargetRetail rdf:type rdf:Property ;
    rdfs:label 'Eom Inventory Target Retail' ;
    rdfs:comment 'The planned ending inventory value at retail price at the end of the OTB budget month. This is the target stock position that feeds into the next month\'s BOM inventory and is a key driver of the OTB formula. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imuPercent rdf:type rdf:Property ;
    rdfs:label 'Imu Percent' ;
    rdfs:comment 'The Initial Markup (IMU) percentage applied to convert retail values to cost values for this OTB budget period. IMU = (Retail - Cost) / Retail. Used to derive OTB at cost from OTB at retail and to assess margin health.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Recalculation Timestamp' ;
    rdfs:comment 'The exact date and time when the OTB budget values were last recalculated in Anaplan. Supports audit trail and ensures merchants are working with the most current OTB position.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes entered by the merchant or planner to document assumptions, exceptions, or rationale for OTB budget decisions (e.g., promotional event impact, supply chain disruption, vendor delay). Supports audit trail and planning transparency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbCost rdf:type rdf:Property ;
    rdfs:label 'Otb Cost' ;
    rdfs:comment 'The remaining open-to-buy dollars at cost available for the OTB budget month. Derived from OTB at retail adjusted by the Initial Markup (IMU) percentage. Used for purchase order (PO) commitment and cash flow management. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbRetail rdf:type rdf:Property ;
    rdfs:label 'Otb Retail' ;
    rdfs:comment 'The remaining open-to-buy dollars at retail price available for the OTB budget month. Calculated as: Planned EOM Inventory + Planned Sales + Planned Markdowns - BOM Inventory - Actual Receipts at Retail. A positive value indicates buying capacity; negative indicates over-bought. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGmroi rdf:type rdf:Property ;
    rdfs:label 'Planned Gmroi' ;
    rdfs:comment 'The planned Gross Margin Return on Investment (GMROI) for the OTB budget period. GMROI = Gross Margin / Average Inventory at Cost. Measures the return generated per dollar of inventory investment. Used to prioritize department and class-level OTB allocations.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Retail' ;
    rdfs:comment 'The planned markdown (MD) dollar amount at retail for the OTB budget month. Markdowns reduce the retail inventory value and are a key input to the OTB formula and Maintained Markup (MMU) calculation. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsCost rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Cost' ;
    rdfs:comment 'The total planned merchandise receipt value at cost (landed duty paid / LDP) for the OTB budget month. Used for cash flow planning, purchase order (PO) commitment tracking, and COGS forecasting. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Retail' ;
    rdfs:comment 'The total planned merchandise receipt value at retail price for the OTB budget month. Represents the maximum retail value of goods the merchant plans to receive. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Retail' ;
    rdfs:comment 'The planned net sales revenue at retail price for the OTB budget month, as defined in the merchandise financial plan. Drives the OTB calculation and sell-through rate (STR) targets. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Units' ;
    rdfs:comment 'The planned number of units to be sold during the OTB budget month. Used alongside planned sales at retail to derive the Average Unit Retail (AUR) and validate unit-level buy quantities.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Rate' ;
    rdfs:comment 'The planned Sell-Through Rate (STR) for the OTB budget month, expressed as a decimal (e.g., 0.75 = 75%). STR = Units Sold / (Beginning Inventory Units + Received Units). Used to validate receipt plans and assess inventory productivity.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Planned Weeks Of Supply' ;
    rdfs:comment 'The planned Weeks of Supply (WOS) at the end of the OTB budget month. WOS = EOM Inventory Units / Average Weekly Sales Units. Used to assess inventory coverage and prevent stockouts or overstock situations.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Recalculation Trigger Date' ;
    rdfs:comment 'The date on which the weekly OTB recalculation was last triggered for this budget record. OTB is recalculated weekly in Anaplan based on updated actual receipts, sales actuals, and revised forecasts.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record from which this OTB budget record originated. Anaplan is the primary planning system; Oracle Retail provides actuals integration; SAP S/4HANA provides cost and PO data; Manual indicates planner-entered overrides.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReceiptsRetail rdf:type rdf:Property ;
    rdfs:label 'Variance Receipts Retail' ;
    rdfs:comment 'The variance between planned receipts at retail and actual receipts at retail for the OTB budget month. Positive = under-received vs plan; Negative = over-received vs plan. Triggers merchant alerts when variance exceeds the defined threshold. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceSalesRetail rdf:type rdf:Property ;
    rdfs:label 'Variance Sales Retail' ;
    rdfs:comment 'The variance between planned sales at retail and actual sales at retail for the OTB budget month. Used to assess sales performance against plan and trigger OTB recalculation when variance exceeds the alert threshold. Expressed in the operating currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyPlanId rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the seasonal merchandise buy plan record. Primary key for the buy_plan data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyPlan .

ind:awardedVendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Quote Id' ;
    rdfs:comment 'Foreign key linking to sourcing.vendor_quote. Business justification: Buy plans are awarded based on accepted vendor quotes. Tracks which specific quote was selected for procurement, enabling cost reconciliation and vendor performance tracking. Essential for procurement' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuote .

ind:hsCodeId rdf:type rdf:Property ;
    rdfs:label 'Hs Code Id' ;
    rdfs:comment 'Foreign key linking to logistics.hs_code. Business justification: Import duty classification and trade compliance: buy_plan.hs_code is a denormalized plain attribute. Proper FK to logistics.hs_code enables duty rate lookup, Section 301 tariff flagging, and GSP eligi' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsCode .

ind:routingGuideId rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Id' ;
    rdfs:comment 'Foreign key linking to logistics.routing_guide. Business justification: LDP cost modeling during buy planning: buyers select a routing guide to estimate freight cost, transit time, and incoterm compliance per lane. Apparel planners routinely embed routing guide selection ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingGuide .

ind:sourcingPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_purchase_order. Business justification: Buy plans convert to sourcing POs upon approval. Tracks execution of planned buys and enables plan-vs-actual reconciliation for cost, timing, and quantity variances. Critical for procurement performan' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPurchaseOrder .

ind:supplierFactoryId rdf:type rdf:Property ;
    rdfs:label 'Supplier Factory Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_factory. Business justification: Each buy plan in apparel sourcing is executed at a specific supplier factory. This link enables factory-level capacity checks, compliance status validation, and audit clearance verification before a b' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierFactory .

ind:vendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_agreement. Business justification: Buy plans must reference the governing vendor agreement to enforce contractual terms (payment terms, MOQ, incoterms, exclusivity). Apparel buyers validate agreement validity and compliance before fina' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAgreement .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the primary supplier/vendor committed to fulfilling this buy plan. Links to the vendor master in SAP S/4HANA MM. Drives purchase order creation and supplier commitment tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:buyPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the buy plan, used in cross-system communication with Oracle Retail Merchandising System, Anaplan, and SAP S/4HANA MM. Follows the format BP-{YEAR}-{ALPHANUMERIC_CODE}.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Merchandise distribution channel for which this buy plan is created. Drives channel-specific assortment and allocation strategies. DTC (Direct-to-Consumer) includes both retail stores and e-commerce. [ENUM-REF-CANDIDATE: retail|ecommerce|wholesale|dtc|outlet|marketplace — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayCount rdf:type rdf:Property ;
    rdfs:label 'Colorway Count' ;
    rdfs:comment 'Number of distinct colorways (color/material combinations) included in this buy plan. Used for assortment breadth analysis and collection planning in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the merchandise is manufactured. Required for customs duty calculation, HS Code classification, GSP eligibility, and FTC textile labeling compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Date' ;
    rdfs:comment 'Planned date on which finished goods are expected to leave the manufacturing facility (ex-factory). Key milestone in the T&A (Time and Action) calendar. Used to calculate transit lead times and planned receipt dates.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorSetDate rdf:type rdf:Property ;
    rdfs:label 'Floor Set Date' ;
    rdfs:comment 'Planned date for merchandise to be on the retail floor or live on the e-commerce site. Aligns with the seasonal collection launch calendar and marketing campaign timing.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fobCost rdf:type rdf:Property ;
    rdfs:label 'Fob Cost' ;
    rdfs:comment 'Free on Board unit cost agreed with the vendor, representing the product cost at the point of origin before freight, duties, and insurance. Used as the base cost in COGS and IMU calculations. Expressed in the plan currency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inDcDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Date' ;
    rdfs:comment 'Planned date for merchandise to arrive at the distribution center. Drives inbound scheduling in Manhattan Associates WMS and store allocation timing. Critical for floor-set and launch date compliance.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) governing the transfer of risk and cost responsibility between buyer and vendor for this buy plan shipment. Determines the point at which ownership and risk transfer. [ENUM-REF-CANDIDATE: FOB|CIF|EXW|DDP|FCA|CFR|DAP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Flag indicating whether the merchandise in this buy plan is an exclusive product (e.g., retailer-exclusive colorway, channel-exclusive style). Exclusives may have different MOQ, pricing, and allocation rules.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNos rdf:type rdf:Property ;
    rdfs:label 'Is Nos' ;
    rdfs:comment 'Flag indicating whether this buy plan is for a Never Out of Stock (NOS) / core replenishment item that is carried across multiple seasons, as opposed to a seasonal fashion buy. NOS items follow continuous replenishment planning rules.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldpCost rdf:type rdf:Property ;
    rdfs:label 'Ldp Cost' ;
    rdfs:comment 'Landed Duty Paid unit cost inclusive of FOB cost, ocean/air freight, customs duties, insurance, and port handling charges. Represents the true total cost of goods at the destination DC. Used for COGS, GMROI, and IMU calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum Order Quantity committed to the vendor for this buy plan. Sourced from vendor negotiation terms in SAP S/4HANA MM. Buy plan units must meet or exceed MOQ to trigger purchase order creation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer\'s Suggested Retail Price for the planned style. Used as the reference retail price for IMU (Initial Markup) and AUR (Average Unit Retail) calculations in merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Vendor payment terms agreed for this buy plan (e.g., LC 90 days, Net 60, FOB 30). Includes Letter of Credit (LC) terms where applicable. Sourced from SAP S/4HANA MM vendor payment terms configuration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReceiptEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt End Date' ;
    rdfs:comment 'Latest planned date for all merchandise receipts under this buy plan to be completed. Defines the receipt window for seasonal floor-set readiness and OTB period closure.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReceiptStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Start Date' ;
    rdfs:comment 'Earliest planned date for merchandise receipts to arrive at the destination DC or store. Drives the receipt flow schedule and warehouse inbound planning in Manhattan Associates WMS.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStrPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Str Percent' ;
    rdfs:comment 'Planned Sell-Through Rate (STR) percentage for this buy plan, representing the expected proportion of units sold at full price by end of season. Used as a key input for OTB budget sizing and markdown risk assessment in Anaplan.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Planned Total Cost' ;
    rdfs:comment 'Total planned cost commitment for this buy plan, calculated as planned_units × ldp_cost. Represents the OTB budget consumption amount in the merchandise financial plan. Expressed in the plan currency.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalRetail rdf:type rdf:Property ;
    rdfs:label 'Planned Total Retail' ;
    rdfs:comment 'Total planned retail value of the buy plan, calculated as planned_units × MSRP. Used for OTB retail budget tracking and GMROI planning in Anaplan merchandise financial planning.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Units' ;
    rdfs:comment 'Total number of units planned for purchase in this buy plan across all sizes and colorways. Represents the gross buy quantity before MOQ adjustments. Used as the primary quantity driver for OTB consumption calculation.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'SAP S/4HANA MM Purchase Order number generated from this buy plan upon approval. Links the financial buy plan to the operational procurement execution. A buy plan may generate one or multiple POs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingType rdf:type rdf:Property ;
    rdfs:label 'Sourcing Type' ;
    rdfs:comment 'Manufacturing sourcing model for this buy plan. CMT (Cut Make Trim) = vendor provides labor only; OEM (Original Equipment Manufacturer) = vendor manufactures to spec; ODM (Original Design Manufacturer) = vendor designs and manufactures; direct = owned factory.' ;
    rdfs:domain ind:BuyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyPlanLineId rdf:type rdf:Property ;
    rdfs:label 'Buy Plan Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each line-level record within a seasonal buy plan. Primary key for the buy_plan_line entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyPlanLine .

ind:rfqLineId rdf:type rdf:Property ;
    rdfs:label 'Rfq Line Id' ;
    rdfs:comment 'Foreign key linking to sourcing.rfq_line. Business justification: Line-level traceability from RFQ response to buy plan execution. Critical for cost variance analysis, comparing target costs in RFQ to planned costs in buy plan. Supports vendor performance evaluation' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfqLine .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the specific Stock Keeping Unit (SKU) being purchased on this buy plan line, representing the unique combination of style, color, and size.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:sourcingPurchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Purchase Order Line Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sourcing_purchase_order_line. Business justification: Line-level traceability from buy plan to actual PO. Critical for unit cost variance analysis, delivery tracking, and SKU-level plan-vs-actual reconciliation. Enables precise margin analysis and vendor' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPurchaseOrderLine .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to production.work_order. Business justification: Line-level work order link enables granular production tracking, variance analysis between planned and produced quantities, and SKU-level delivery status. Essential for inventory accuracy and fulfillm' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The timestamp when this buy plan line was formally approved by the merchandising team, authorizing the purchase commitment and OTB charge. Distinct from creation and update timestamps as it marks a specific business lifecycle event.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The distribution channel for which this buy plan line is intended: DTC (Direct-to-Consumer retail stores), WHOLESALE (wholesale partners), ECOMM (e-commerce), OUTLET, or FRANCHISE. Drives channel-specific allocation and OTB management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedUnits rdf:type rdf:Property ;
    rdfs:label 'Confirmed Units' ;
    rdfs:comment 'The number of units formally confirmed with the supplier via Purchase Order (PO). May differ from planned or revised units due to Minimum Order Quantity (MOQ) constraints or supplier capacity limitations.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Indicates the cost basis for the unit cost on this line: CMT (Cut Make Trim), FOB (Free on Board), LDP (Landed Duty Paid), DDP (Delivered Duty Paid), or EXW (Ex Works). Determines what logistics and duty costs are included in the unit cost figure.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricContent rdf:type rdf:Property ;
    rdfs:label 'Fabric Content' ;
    rdfs:comment 'The fiber/material composition of the product on this buy plan line (e.g., 100% Cotton, 60% Polyester 40% Nylon). Required for FTC textile labeling compliance, OEKO-TEX certification tracking, and sustainability reporting under GOTS/BCI standards.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Pct' ;
    rdfs:comment 'The Initial Markup (IMU) percentage for this buy plan line, calculated as (MSRP - Unit Cost) / MSRP. Represents the planned gross margin at full retail price before any markdowns. Key metric in merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNeverOutOfStock rdf:type rdf:Property ;
    rdfs:label 'Is Never Out Of Stock' ;
    rdfs:comment 'Indicates whether this buy plan line is designated as a Never Out of Stock (NOS) item, meaning it is a core replenishment SKU that must be continuously available. NOS items receive priority in allocation and replenishment planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent buy plan, used to order and reference individual SKU-level purchase commitments within a single seasonal buy plan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'The current workflow status of this buy plan line, tracking its lifecycle from initial planning through receipt. [ENUM-REF-CANDIDATE: draft|submitted|approved|po_issued|in_production|shipped|received|cancelled — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownAllowancePct rdf:type rdf:Property ;
    rdfs:label 'Markdown Allowance Pct' ;
    rdfs:comment 'The planned markdown (MD) allowance percentage for this buy plan line, representing the anticipated price reduction from MSRP to clear end-of-season inventory. Used in Maintained Markup (MMU) calculations and merchandise financial planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCancelDate rdf:type rdf:Property ;
    rdfs:label 'Original Cancel Date' ;
    rdfs:comment 'The original date by which the purchase order for this buy plan line must be cancelled if the supplier cannot fulfill. Established at the time of initial buy plan creation as part of the Time and Action (T&A) calendar.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The planned date on which the units for this buy plan line are expected to be received at the distribution center or warehouse. Drives inventory flow planning, OTB timing, and Weeks of Supply (WOS) calculations.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSellThroughPct rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Pct' ;
    rdfs:comment 'The planned Sell-Through Rate (STR) percentage for this buy plan line, representing the expected proportion of units sold at full price or within the season. Used as a benchmark for post-season performance analysis and future buy plan calibration.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preProductionSampleStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Production Sample Status' ;
    rdfs:comment 'The approval status of the Pre-Production (PP) sample for this buy plan line. PP sample approval is a prerequisite for production release in the T&A calendar. Tracked in the PLM system.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The high-level product category for this buy plan line (e.g., Tops, Bottoms, Outerwear, Footwear, Accessories). Used for cross-category OTB analysis and assortment balance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Purchase Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the unit cost is denominated (e.g., USD, EUR, CNY). Required for multi-currency buy plan consolidation and financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedCancelDate rdf:type rdf:Property ;
    rdfs:label 'Revised Cancel Date' ;
    rdfs:comment 'The most recently revised cancel date for this buy plan line, updated during the T&A (Time and Action) calendar review process. Tracks changes to delivery commitments and supplier negotiation outcomes.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedUnits rdf:type rdf:Property ;
    rdfs:label 'Revised Units' ;
    rdfs:comment 'The most recently revised unit quantity for this buy plan line, reflecting any adjustments made after the initial plan was set. Enables tracking of buy plan changes against original commitments and OTB impact analysis.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'The merchandising season code to which this buy plan line belongs (e.g., SS25 for Spring/Summer 2025, FW25 for Fall/Winter 2025). Drives collection planning, OTB budgeting, and sell-through rate (STR) analysis by season.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCode rdf:type rdf:Property ;
    rdfs:label 'Size Code' ;
    rdfs:comment 'The size designation for this buy plan line (e.g., XS, S, M, L, XL, 28x30, 7.5). Represents the specific size within the size run being committed to in this purchase. Drives size curve analysis and allocation planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRunType rdf:type rdf:Property ;
    rdfs:label 'Size Run Type' ;
    rdfs:comment 'Indicates whether this buy plan line represents a full size run, partial size run, core size run (best-selling sizes only), or extended size run (including plus/petite). Drives assortment breadth decisions and size curve planning.' ;
    rdfs:domain ind:BuyPlanLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The negotiated cost per unit for this buy plan line, expressed in the purchase currency. May represent CMT (Cut Make Trim) cost or FOB (Free on Board) cost depending on the sourcing arrangement. Core input for COGS and GMROI calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment 'The Universal Product Code (UPC) barcode identifier for the specific SKU on this buy plan line. Used for downstream POS scanning, warehouse receiving, and EDI transactions with suppliers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentHierarchyMerchandiseHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Merchandise Hierarchy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent node in the merchandise hierarchy. A Division node has a null parent; a Department references its Division; a Class references its Department; a Subclass references its Class. Enables hierarchical roll-up for OTB, GMROI, and financial planning.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandiseHierarchy .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Indicates which sales channels this merchandise hierarchy node applies to: all channels, retail stores, e-commerce (DTC digital), wholesale, or direct-to-consumer (DTC). Governs channel-specific assortment planning, OTB allocation, and pricing strategies in Oracle Retail and Salesforce Commerce Cloud.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Alphanumeric code identifying the Class level node within a Department (e.g., \'JKT\' for Jackets, \'PNT\' for Pants). Null for Division and Department-level records. Used in Oracle Retail for class-level assortment planning, price management, and STR analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Descriptive name of the Class (e.g., \'Jackets\', \'Pants\', \'T-Shirts\', \'Sneakers\'). Null for Division and Department-level records. Displayed in Oracle Retail assortment planning, allocation, and price management modules.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscRegulated rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated' ;
    rdfs:comment 'Indicates whether products in this merchandise hierarchy node are subject to Consumer Product Safety Commission (CPSC) safety standards (e.g., childrens apparel flammability, drawstring regulations). Triggers mandatory safety testing and compliance documentation requirements in Infor PLM and quality management workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Alphanumeric code identifying the Department level node (e.g., \'ACT\' for Activewear, \'OTW\' for Outerwear). Null for Division-level records. Used in Oracle Retail for department-level OTB budgeting, allocation strategies, and merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Descriptive name of the Department (e.g., \'Activewear\', \'Outerwear\', \'Denim\', \'Footwear\'). Null for Division-level records. Denormalized for flat reporting in assortment planning, OTB dashboards, and Anaplan merchandise financial plans.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Alphanumeric code identifying the top-level Division to which this hierarchy node belongs (e.g., \'MNS\' for Mens, \'WMN\' for Womens, \'KDS\' for Kids). Populated at all levels for denormalized reporting and OTB budget allocation in Anaplan.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Descriptive name of the top-level Division (e.g., \'Mens\', \'Womens\', \'Kids\', \'Accessories\'). Denormalized at all hierarchy levels to support flat reporting in Oracle Retail, Anaplan, and BI dashboards without requiring joins.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Erp Category Code' ;
    rdfs:comment 'Corresponding material group or product category code in SAP S/4HANA (MM module) that maps to this merchandise hierarchy node. Ensures alignment between Oracle Retail merchandise taxonomy and SAP procurement, inventory valuation, and COGS reporting.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberContentRequired rdf:type rdf:Property ;
    rdfs:label 'Fiber Content Required' ;
    rdfs:comment 'Indicates whether products in this merchandise hierarchy node require fiber content disclosure on product labels per FTC Textile and Apparel Labeling regulations. Drives compliance requirements in Infor PLM tech pack specifications and product labeling workflows.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderAffinity rdf:type rdf:Property ;
    rdfs:label 'Gender Affinity' ;
    rdfs:comment 'Gender classification associated with this merchandise hierarchy node, used to segment assortments, OTB budgets, and marketing campaigns. Aligns with Oracle Retail Merchandising System division and department structures for gender-based merchandise financial planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies this hierarchy node within the Oracle Retail Merchandising System. Used as the business key in OTB budgets, assortment plans, and financial reporting across Oracle Retail and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of this node in the hierarchy tree: 1=Division, 2=Department, 3=Class, 4=Subclass. Supports hierarchical traversal, roll-up aggregation, and level-specific filtering in OTB and GMROI reporting.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Indicates the level of this node within the four-tier merchandise classification structure: Division > Department > Class > Subclass. Governs how OTB budgets, assortment plans, and GMROI reporting are structured and rolled up in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable name of the merchandise hierarchy node (e.g., \'Mens Activewear\', \'Outerwear\', \'Footwear\'). Displayed in assortment planning, OTB reporting, and financial planning dashboards in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of this merchandise hierarchy node. Active nodes are available for assortment planning, OTB budgeting, and SKU assignment. Inactive or archived nodes are retained for historical reporting but excluded from new planning cycles in Oracle Retail and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNosEligible rdf:type rdf:Property ;
    rdfs:label 'Is Nos Eligible' ;
    rdfs:comment 'Indicates whether products in this merchandise hierarchy node are designated as Never Out of Stock (NOS) items requiring continuous replenishment. NOS-eligible nodes receive dedicated OTB budget allocation and automated replenishment triggers in Oracle Retail and Manhattan Associates WMS.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this merchandise hierarchy node is designated for private label (own-brand) products as opposed to national or licensed brands. Affects sourcing strategy (CMT, OEM, ODM), IMU targets, and margin planning in Infor PLM and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborComplianceStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Compliance Standard' ;
    rdfs:comment 'Labor compliance certification standard required for suppliers producing goods in this merchandise hierarchy node (e.g., FLA, WRAP, SA8000, SEDEX). Governs supplier qualification, factory audit requirements, and sourcing decisions in SAP S/4HANA MM and Infor PLM sourcing modules.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this merchandise hierarchy record was last updated in the Oracle Retail Merchandising System or the Databricks silver layer. Used for incremental data pipeline processing, change detection, and audit compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifestyleCategory rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Category' ;
    rdfs:comment 'Lifestyle or end-use category classification for this hierarchy node, distinguishing athletic performance, lifestyle, luxury, workwear, casual, and outdoor segments. Supports brand positioning, collection planning, and targeted marketing strategies in Adobe Experience Platform and Anaplan.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Strategy' ;
    rdfs:comment 'Markdown (MD) strategy designation for this merchandise hierarchy node, indicating the planned approach to price reductions during the selling season. Governs Oracle Retail Price Management markdown rules, Anaplan financial planning assumptions, and MMU maintenance targets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseHierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Merchandise Hierarchy Description' ;
    rdfs:comment 'Free-text business description of this merchandise hierarchy node, providing additional context about the product category, its scope, and any special planning or sourcing considerations. Maintained in Oracle Retail Merchandising System and used in buyer-facing assortment planning documentation.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseType rdf:type rdf:Property ;
    rdfs:label 'Merchandise Type' ;
    rdfs:comment 'Broad merchandise type classification indicating the nature of products within this hierarchy node. Drives category-specific planning rules, margin targets, and allocation strategies in Oracle Retail and Anaplan merchandise financial planning.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbBudgetMethod rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Method' ;
    rdfs:comment 'Indicates the Open-to-Buy (OTB) budget planning methodology applied to this merchandise hierarchy node: top-down (executive-driven), bottom-up (buyer-driven), or hybrid. Determines how Anaplan merchandise financial plans are structured and reconciled with Oracle Retail OTB budgets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Plm Category Code' ;
    rdfs:comment 'Corresponding category code in the Infor PLM or Centric PLM system that maps to this merchandise hierarchy node. Enables cross-system alignment between the Oracle Retail merchandise taxonomy and the PLM product design and BOM management classification for collection planning and tech pack organization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonApplicability rdf:type rdf:Property ;
    rdfs:label 'Season Applicability' ;
    rdfs:comment 'Seasonal classification indicating which selling seasons this hierarchy node is active for. Drives seasonal buy plan creation, OTB budget phasing, and collection planning cycles in Oracle Retail Merchandising System and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortSequence rdf:type rdf:Property ;
    rdfs:label 'Sort Sequence' ;
    rdfs:comment 'Numeric ordering sequence for displaying this hierarchy node among its siblings within the same parent. Controls the display order in Oracle Retail Merchandising System screens, assortment planning tools, and reporting dashboards.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subclassCode rdf:type rdf:Property ;
    rdfs:label 'Subclass Code' ;
    rdfs:comment 'Alphanumeric code identifying the Subclass level node within a Class (e.g., \'PUFF\' for Puffer Jackets, \'WNDBRKR\' for Windbreakers). Null for Division, Department, and Class-level records. The most granular level for SKU assignment, OTB allocation, and STR tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subclassName rdf:type rdf:Property ;
    rdfs:label 'Subclass Name' ;
    rdfs:comment 'Descriptive name of the Subclass (e.g., \'Puffer Jackets\', \'Windbreakers\', \'Slim Fit Jeans\'). Null for Division, Department, and Class-level records. Used in Oracle Retail for the most granular assortment planning, allocation, and markdown optimization.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGmroi rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi' ;
    rdfs:comment 'Target Gross Margin Return on Investment (GMROI) for this merchandise hierarchy node, calculated as gross margin dollars divided by average inventory cost. A primary KPI for merchandise financial planning and OTB budget justification in Anaplan and Oracle Retail.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImuPct rdf:type rdf:Property ;
    rdfs:label 'Target Imu Pct' ;
    rdfs:comment 'Target Initial Markup (IMU) percentage for products within this merchandise hierarchy node, representing the planned markup from cost to MSRP at the time of first receipt. A key financial planning metric in Anaplan OTB and Oracle Retail Price Management for setting pricing strategy and GMROI targets.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStrPct rdf:type rdf:Property ;
    rdfs:label 'Target Str Pct' ;
    rdfs:comment 'Target Sell-Through Rate (STR) percentage for this merchandise hierarchy node, representing the planned proportion of received inventory sold within a season. Used in Oracle Retail and Anaplan to evaluate assortment performance, trigger markdown decisions, and set OTB buy quantities.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWos rdf:type rdf:Property ;
    rdfs:label 'Target Wos' ;
    rdfs:comment 'Target Weeks of Supply (WOS) for this merchandise hierarchy node, representing the planned number of weeks of inventory on hand relative to forecasted sales rate. Drives replenishment triggers, OTB phasing, and allocation strategies in Oracle Retail and Manhattan Associates WMS.' ;
    rdfs:domain ind:MerchandiseHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceMasterId rdf:type rdf:Property ;
    rdfs:label 'Price Master Id' ;
    rdfs:comment 'Unique surrogate identifier for each price master record in the Databricks Silver Layer. Serves as the primary key for the price_master data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceMaster .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Reference to the sales channel for which this price record is applicable (e.g., DTC retail store, e-commerce, wholesale). Supports channel-specific pricing strategies.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:dutyCalculationId rdf:type rdf:Property ;
    rdfs:label 'Duty Calculation Id' ;
    rdfs:comment 'Foreign key linking to logistics.duty_calculation. Business justification: LDP cost build-up for price master: price_master.landed_duty_paid_cost is derived from duty calculations. Apparel pricing teams reference the specific duty calculation that produced the LDP cost to su' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyCalculation .

ind:priceBookId rdf:type rdf:Property ;
    rdfs:label 'Price Book Id' ;
    rdfs:comment 'Foreign key linking to merchandising.price_book. Business justification: Each price master record is governed by a price book that defines the pricing strategy, channel scope, and regional applicability. price_master has no price_book_id FK currently. Adding this FK normal' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Reference to the geographic region or market for which this price record applies. Supports regional pricing strategies across domestic and international markets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow approval status of the price record within the Oracle Retail Price Management approval process. Prices must be approved before becoming active. Supports governance and audit trail for pricing decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aur rdf:type rdf:Property ;
    rdfs:label 'Aur' ;
    rdfs:comment 'Average Unit Retail (AUR) — the average price at which a unit is actually sold after accounting for promotions, markdowns (MD), and clearance events. A key KPI in merchandise financial planning and STR (Sell-Through Rate) analysis. Managed in Anaplan merchandise planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Price' ;
    rdfs:comment 'The observed or benchmarked competitor price for a comparable product at the time of pricing decision. Used to support competitive pricing analysis and market positioning strategy. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The landed cost price of the product including COGS (Cost of Goods Sold) components such as CMT (Cut Make Trim), materials, LDP (Landed Duty Paid) duties, and freight. Used as the denominator for IMU (Initial Markup) and MMU (Maintained Markup) calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code identifying the specific country market for which this price record applies. Supports country-level pricing compliance, VAT/tax treatment, and international trade reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedDutyPaidCost rdf:type rdf:Property ;
    rdfs:label 'Landed Duty Paid Cost' ;
    rdfs:comment 'Total LDP (Landed Duty Paid) cost including FOB (Free on Board) price, import duties, freight, insurance, and customs clearance charges. Used as the true cost basis for margin calculations and sourcing decisions.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPercent rdf:type rdf:Property ;
    rdfs:label 'Markdown Percent' ;
    rdfs:comment 'The percentage reduction from MSRP applied during a markdown (MD) event, calculated as (MSRP - Markdown Price) / MSRP × 100. Used to track markdown depth, promotional cadence, and margin erosion in merchandise financial planning.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPrice rdf:type rdf:Property ;
    rdfs:label 'Markdown Price' ;
    rdfs:comment 'The reduced selling price applied during a markdown (MD) event, clearance, or end-of-season promotion. Tracked separately from MSRP to enable markdown depth analysis and STR (Sell-Through Rate) optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Min Advertised Price' ;
    rdfs:comment 'The minimum price at which wholesale partners and retailers are contractually permitted to advertise this product. Enforced to protect brand equity and prevent price erosion in wholesale and marketplace channels.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmuPercent rdf:type rdf:Property ;
    rdfs:label 'Mmu Percent' ;
    rdfs:comment 'Maintained Markup Percentage (MMU%) — the actual markup percentage realized after all markdowns (MD), promotions, and shrinkage adjustments. Reflects true profitability versus the initial pricing plan. Used in GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification or reason code for the price change event (e.g., seasonal markdown, competitive response, cost increase, promotional event, clearance). Supports pricing audit trail and merchandise financial planning analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceElasticityIndex rdf:type rdf:Property ;
    rdfs:label 'Price Elasticity Index' ;
    rdfs:comment 'A numeric index representing the price sensitivity of demand for this SKU/style, derived from historical sales and pricing data in Anaplan. Used to optimize markdown timing, promotional depth, and AUR (Average Unit Retail) planning.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceMasterCode rdf:type rdf:Property ;
    rdfs:label 'Price Master Code' ;
    rdfs:comment 'Externally-known business identifier for the price master record as assigned in Oracle Retail Price Management. Used for cross-system reference and EDI (Electronic Data Interchange) integration with wholesale partners and ERP systems.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the price master record. Active records are currently in use; pending records are approved but not yet effective; expired records have passed their effective end date; superseded records have been replaced by a newer price version.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'Classification of the product\'s price positioning within the brand\'s pricing architecture. Drives assortment planning, channel allocation, and marketing strategy. [ENUM-REF-CANDIDATE: luxury|premium|mid_market|value|outlet|off_price — promote to reference product if tiers expand beyond 6]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Categorizes the nature of the price record — regular everyday price, promotional price, clearance/end-of-season price, wholesale price, cost price, or internal transfer price. Governs which price is applied in each transaction context.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVersion rdf:type rdf:Property ;
    rdfs:label 'Price Version' ;
    rdfs:comment 'Sequential version number of the price record, incremented each time the price is updated or superseded. Enables price history tracking and point-in-time pricing reconstruction for audit and analytics purposes.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceZoneCode rdf:type rdf:Property ;
    rdfs:label 'Price Zone Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based price zone to which this price record belongs. Price zones allow differentiated pricing across markets (e.g., US_EAST, EU_WEST, APAC) within Oracle Retail Price Management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelType rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Type' ;
    rdfs:comment 'The type of sales channel for which this price is applicable. DTC (Direct-to-Consumer) retail, DTC e-commerce, wholesale, outlet, marketplace, or franchise. Enables channel-specific pricing strategy and margin analysis.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the MSRP and selling prices include applicable taxes (VAT, GST, sales tax). True = tax-inclusive pricing (common in EU/UK markets); False = tax-exclusive pricing (common in US markets). Governs POS and e-commerce price display.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'The internal price used for inter-company or inter-division product transfers (e.g., from distribution center to retail store, or between legal entities). Used in SAP S/4HANA FI/CO for intercompany accounting and IFRS transfer pricing compliance.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'Universal Product Code (UPC) barcode identifier for the SKU. Used for POS (Point of Sale) scanning, RFID (Radio Frequency Identification) tagging, and retail shelf management. Conforms to GS1 UPC-A or EAN-13 standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'The applicable VAT (Value Added Tax) or GST rate percentage for this product in the specified country/region. Used for tax-inclusive price calculation, consumer receipt display, and regulatory tax reporting.' ;
    rdfs:domain ind:PriceMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesalePrice rdf:type rdf:Property ;
    rdfs:label 'Wholesale Price' ;
    rdfs:comment 'The price at which the product is sold to wholesale partners, department stores, and distribution accounts. Used in wholesale margin analysis, partner negotiations, and GMROI (Gross Margin Return on Investment) reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Unique system-generated identifier for the promotion record. Primary key for the promotion data product in the merchandising domain.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.audience_segment. Business justification: Promotions are deployed to specific marketing audience segments (lapsed customers, loyalty tier, new acquires) distinct from CRM customer_segment_id. Marketing teams activate promotions via audience s' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Foreign key linking to marketing.event. Business justification: Promotional events (flash sales, trunk shows, end-of-season events) activate specific promotions. Merchandising teams track promotional lift per marketing event for markdown budget accountability. A f' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Reference to the loyalty program associated with loyalty-linked promotions. Null for non-loyalty promotion types. Links to CRM (Customer Relationship Management) loyalty program master data in Adobe Experience Platform or Salesforce.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:promoCodeId rdf:type rdf:Property ;
    rdfs:label 'Promo Code Id' ;
    rdfs:comment 'Foreign key linking to marketing.promo_code. Business justification: Marketing promo codes trigger merchandising promotions at checkout. This link connects the code distribution mechanism (marketing) to the discount rules and budget impact (merchandising). Essential fo' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:sourcePromotionId rdf:type rdf:Property ;
    rdfs:label 'Source Promotion Id' ;
    rdfs:comment 'Original promotion identifier as recorded in the source operational system (e.g., Oracle Retail promotion number, SAP SD condition record number). Enables traceability and reconciliation between the Databricks Silver Layer and source systems of record.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:actualLiftPct rdf:type rdf:Property ;
    rdfs:label 'Actual Lift Pct' ;
    rdfs:comment 'Realized percentage increase in unit sales or revenue achieved by this promotion compared to baseline, captured post-promotion from SAP CAR POS data and Salesforce Commerce Cloud. Compared against planned_lift_pct for STR (Sell-Through Rate) analysis and future promotion planning.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRevenue rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue' ;
    rdfs:comment 'Realized gross revenue generated during the promotion period, sourced from SAP CAR POS transactions and Salesforce Commerce Cloud order data. Compared against planned_revenue for post-promotion performance analysis and GMROI optimization.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Units' ;
    rdfs:comment 'Realized number of units sold during the promotion period, sourced from SAP CAR POS and Salesforce Commerce Cloud. Used in STR (Sell-Through Rate) analysis and post-promotion inventory reconciliation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Alphanumeric coupon or voucher code that customers enter at POS or e-commerce checkout to activate the promotion when coupon_required is True (e.g., SAVE20, LOYALTY10). Null when coupon_required is False.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRequired rdf:type rdf:Property ;
    rdfs:label 'Coupon Required' ;
    rdfs:comment 'Indicates whether the customer must present or enter a coupon code to redeem the promotion. True = coupon code required at POS or e-commerce checkout; False = automatic/stackable promotion applied without customer action.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Markdown (MD) percentage applied to the original MSRP or AUR (Average Unit Retail) for percentage-off promotion types. Expressed as a percentage (e.g., 25.00 = 25% off). Null for non-percentage promotion types such as fixed_price or bogo. Used in IMU/MMU (Initial Markup/Maintained Markup) impact analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the promotion expires and is no longer applicable. Nullable for open-ended evergreen promotions. Used to calculate WOS (Weeks of Supply) impact and OTB (Open-to-Buy) planning in Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Price Amount' ;
    rdfs:comment 'Absolute promotional selling price applied to eligible items for fixed_price promotion types (e.g., $29.99). Null for percentage-off or BOGO mechanics. Represents the promotional AUR (Average Unit Retail) override in Oracle Retail Price Management.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes where the promotion is valid (e.g., USA|CAN|GBR). Null = global applicability. Supports multi-market promotional planning and compliance with regional consumer protection regulations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiImpact rdf:type rdf:Property ;
    rdfs:label 'Gmroi Impact' ;
    rdfs:comment 'Estimated or realized GMROI (Gross Margin Return on Investment) impact of the promotion, calculated as gross margin dollars generated per dollar of inventory investment during the promotional period. A core KPI in apparel merchandising financial planning. Classified confidential as it reveals margin strategy.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLoyaltyExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Exclusive' ;
    rdfs:comment 'Indicates whether this promotion is exclusively available to loyalty program members. True = restricted to loyalty members only (tracked via Adobe Experience Platform or CRM); False = available to all customers. Supports CLTV (Customer Lifetime Value) and loyalty program ROI analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownBudget rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget' ;
    rdfs:comment 'Allocated markdown (MD) budget for this promotion, representing the maximum planned reduction in gross margin approved by the merchandising team. Expressed in currency_code. Managed in Anaplan OTB (Open-to-Buy) financial planning. Classified confidential as it reflects internal pricing strategy.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandiseScope rdf:type rdf:Property ;
    rdfs:label 'Merchandise Scope' ;
    rdfs:comment 'Level of the merchandise hierarchy to which the promotion applies. Determines eligible SKUs (Stock Keeping Units) in Oracle Retail: all_merchandise (storewide), department (e.g., Footwear), class (e.g., Running Shoes), subclass (e.g., Men\'s Running), sku (specific SKU), style (all colorways of a style). Drives assortment planning and allocation strategies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum transaction value (in local currency) a customer must reach to qualify for the promotion. Used for threshold-based promotions (e.g., spend $100 get 20% off). Supports AOV (Average Order Value) uplift strategies in Salesforce Commerce Cloud and SAP CAR.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of units a customer must purchase to qualify for the promotion. Relevant for BOGO, bundle, and quantity-threshold promotions. Aligns with MOQ (Minimum Order Quantity) concepts in wholesale channel promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLiftPct rdf:type rdf:Property ;
    rdfs:label 'Planned Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in unit sales or revenue expected from this promotion compared to baseline, as planned in Anaplan merchandise financial planning. Used to set OTB (Open-to-Buy) budgets and evaluate GMROI (Gross Margin Return on Investment) impact pre-promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRevenue rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue' ;
    rdfs:comment 'Forecasted gross revenue expected to be generated during the promotion period, as modeled in Anaplan merchandise financial planning. Expressed in the currency defined by currency_code. Used for OTB budget setting and GMROI planning.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking used to resolve conflicts when multiple non-stackable promotions apply to the same transaction or item. Lower number = higher priority. Managed in Oracle Retail Price Management and SAP SD condition access sequences.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Externally-known alphanumeric code used to identify and reference the promotion across Oracle Retail, SAP SD, and customer-facing channels (e.g., SUMMER25, BOGO-DENIM). Used in EDI transactions, POS systems, and e-commerce storefronts.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Free-text business description of the promotion\'s terms, conditions, and marketing narrative as communicated to customers and store associates (e.g., \'Get 25% off all women\'s outerwear this weekend only\'). Used in POS displays, e-commerce banners, and marketing collateral.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable business name of the promotion as displayed in merchandising systems and marketing materials (e.g., \'Summer Clearance 2025\', \'Buy One Get One Denim\'). Used in Oracle Retail and Anaplan merchandise financial planning.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion record within Oracle Retail and SAP SD workflow. Draft: under construction; Approved: authorized by merchandising; Active: currently running; Paused: temporarily suspended; Expired: past end date; Cancelled: terminated before activation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Categorical classification of the promotion\'s discount mechanic. Drives how the discount is calculated at POS and in e-commerce. Values: percentage_off (e.g., 20% off), fixed_price (e.g., $29.99), bogo (Buy One Get One), bundle (multi-item offer), loyalty (loyalty program linked reduction), clearance (end-of-season markdown). [ENUM-REF-CANDIDATE: percentage_off|fixed_price|bogo|bundle|loyalty|clearance|gift_with_purchase|threshold_discount — promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of available promotional inventory sold during the promotion period (units sold / units available × 100). A key KPI in apparel merchandising for evaluating promotion effectiveness and informing future markdown (MD) and clearance strategies. Sourced post-promotion from Oracle Retail and SAP CAR.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this promotion can be combined with other active promotions on the same transaction. True = can stack with other promotions; False = exclusive promotion, cannot be combined. Critical for margin protection and MMU (Maintained Markup) management.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the promotion becomes effective and eligible for application at POS, e-commerce, and wholesale channels. Aligns with the T&A (Time and Action) calendar in Anaplan merchandise planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this promotion. Null = unlimited per customer. Enforced at POS via SAP CAR and at e-commerce checkout via Salesforce Commerce Cloud to prevent abuse.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Total' ;
    rdfs:comment 'Maximum total number of times this promotion can be redeemed across all customers and transactions. Null = unlimited redemptions. Used for limited-time flash sales and exclusive loyalty offers to control promotional liability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryCapacityId rdf:type rdf:Property ;
    rdfs:label 'Factory Capacity Id' ;
    rdfs:comment 'Foreign key linking to production.factory_capacity. Business justification: Merchandise financial plans set planned receipt amounts and OTB that drive factory capacity booking decisions. Apparel planning teams reference MFP planned_receipts_amt when approving factory capacity' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FactoryCapacity .

ind:channelInventoryAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Channel Inventory Allocation Pct' ;
    rdfs:comment 'Percentage of total planned inventory allocated to this specific distribution channel (DTC retail, DTC e-commerce, wholesale, outlet). Drives channel-level receipt planning and allocation strategies in Oracle Retail.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal quarter or period identifier within the fiscal year to which this plan applies (e.g., FY2025-Q1). Supports quarterly OTB budget reviews and financial reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The company\'s fiscal year to which this merchandise financial plan belongs. May differ from calendar year depending on the company\'s fiscal calendar (e.g., fiscal year ending January 31).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this merchandise financial plan has been locked and frozen for execution. When True, no further edits are permitted and the plan serves as the official baseline for OTB budget management and performance tracking.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the merchandise financial plan (e.g., v1.0, v2.3). Supports iterative planning cycles where plans are revised across pre-season, in-season, and post-season phases.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAur rdf:type rdf:Property ;
    rdfs:label 'Planned Aur' ;
    rdfs:comment 'Planned AUR (Average Unit Retail) representing the expected average selling price per unit across the department/class/channel combination. Drives unit sales plan derivation from the net sales dollar plan.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBopInventoryAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Bop Inventory Amt' ;
    rdfs:comment 'Planned inventory value at retail at the beginning of the planning period. Used as the opening stock position for OTB calculations and inventory flow modeling.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCogsAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Cogs Amt' ;
    rdfs:comment 'Planned COGS (Cost of Goods Sold) for the season, representing the total cost of merchandise expected to be sold. Used to derive planned gross margin and GMROI targets.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEopInventoryAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Eop Inventory Amt' ;
    rdfs:comment 'Planned inventory value at retail at the end of the planning period (EOM). Represents the target closing stock position and feeds into the next season\'s BOP. Critical for OTB and WOS (Weeks of Supply) planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrossMarginAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Gross Margin Amt' ;
    rdfs:comment 'Planned gross margin in absolute dollar terms (planned net sales minus planned COGS). Represents the financial contribution of the merchandise category before operating expenses.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedImuPct rdf:type rdf:Property ;
    rdfs:label 'Planned Imu Pct' ;
    rdfs:comment 'Planned IMU (Initial Markup) percentage representing the difference between the cost of merchandise and its original retail price, expressed as a percentage of retail. Establishes the pricing floor before markdowns.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedInventoryTurns rdf:type rdf:Property ;
    rdfs:label 'Planned Inventory Turns' ;
    rdfs:comment 'Planned number of times inventory is expected to sell through and be replenished during the season (COGS / average inventory at cost). Drives OTB budget and receipt flow planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Amt' ;
    rdfs:comment 'Total planned markdown (MD) dollars for the season representing the anticipated reduction from original retail price to drive sell-through. Directly impacts MMU and gross margin performance.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownPct rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Pct' ;
    rdfs:comment 'Planned markdown as a percentage of planned net sales. Used to benchmark markdown aggressiveness across departments and channels and to set MMU expectations.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMmuPct rdf:type rdf:Property ;
    rdfs:label 'Planned Mmu Pct' ;
    rdfs:comment 'Planned MMU (Maintained Markup) percentage representing the actual markup achieved after markdowns and promotions, expressed as a percentage of net sales. Reflects the realized pricing performance versus IMU.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMsrpAvg rdf:type rdf:Property ;
    rdfs:label 'Planned Msrp Avg' ;
    rdfs:comment 'Planned average MSRP (Manufacturer\'s Suggested Retail Price) across the SKUs in this department/class/channel plan. Establishes the retail price anchor for IMU calculation and consumer-facing pricing.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedNetSalesAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Net Sales Amt' ;
    rdfs:comment 'Total planned net sales revenue (gross sales minus returns and allowances) for the season, department, class, and channel combination. Core financial target in the merchandise financial plan. Expressed in the plan\'s currency.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOtbAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Otb Amt' ;
    rdfs:comment 'Planned OTB (Open-to-Buy) budget in dollars representing the amount of merchandise the buyer is authorized to purchase for the season. Calculated as planned EOP inventory + planned sales + planned markdowns - planned BOP inventory.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsAmt rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts Amt' ;
    rdfs:comment 'Total planned merchandise receipts (inbound inventory) at retail value for the season. Represents the planned flow of new inventory into the channel to support the sales plan.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Planned Units Sold' ;
    rdfs:comment 'Total planned number of units expected to be sold during the season for the department/class/channel combination. Derived from planned net sales divided by planned AUR. Feeds into allocation and replenishment planning.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWos rdf:type rdf:Property ;
    rdfs:label 'Planned Wos' ;
    rdfs:comment 'Planned WOS (Weeks of Supply) representing the number of weeks the current inventory position is expected to last at the planned rate of sale. Used to identify over/under-stock risk and trigger replenishment actions.' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Indicates the planning phase this plan represents: pre-season (initial buy plan before season starts), in-season (revised plan during active selling), or post-season (actuals reconciliation and hindsight).' ;
    rdfs:domain ind:MerchandiseFinancialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Planned pricing strategy for this channel and merchandise category: full_price (MSRP-driven), promotional (planned promotional events), value (everyday low price positioning), or outlet (clearance/off-price). Informs IMU and MMU targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCurveId rdf:type rdf:Property ;
    rdfs:label 'Size Curve Id' ;
    rdfs:comment 'Unique surrogate identifier for the size curve profile record in the merchandising system. Primary key for the size_curve data product. Entity role: MASTER_RESOURCE — this is a planning reference resource defining expected unit sales distribution across size runs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SizeCurve .

ind:sizeScaleId rdf:type rdf:Property ;
    rdfs:label 'Size Scale Id' ;
    rdfs:comment 'Foreign key linking to product.size_scale. Business justification: Size curves define percentage distributions across size ranges and must reference the actual size scale (XS-XXL, numeric, etc.) to be operationally meaningful. Allocation planning requires mapping cur' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SizeScale .

ind:basisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Basis Period End Date' ;
    rdfs:comment 'End date of the historical sell-through data period used to derive this size curve\'s distribution percentages. Together with basis_period_start_date, defines the historical window for statistical calibration of size ratios.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Basis Period Start Date' ;
    rdfs:comment 'Start date of the historical sell-through data period used to derive this size curve\'s distribution percentages. Defines the lookback window for statistical calibration. Typically covers 1-3 prior seasons of comparable selling history.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level of the size curve based on the volume and quality of historical sell-through data used in derivation. High confidence curves are used directly in buy plans; low confidence curves require planner override review. Drives curve applicability flags in Anaplan.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveCode rdf:type rdf:Property ;
    rdfs:label 'Curve Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the size curve profile, used in Oracle Retail Merchandising System and Anaplan for cross-system reference. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveDerivationMethod rdf:type rdf:Property ;
    rdfs:label 'Curve Derivation Method' ;
    rdfs:comment 'Method used to derive the size distribution percentages for this curve. Historical STR uses actual sell-through data; planner_override reflects manual planner judgment; vendor_recommended uses supplier-provided size ratios; statistical_model uses algorithmic forecasting; blended combines multiple methods. Affects confidence level assignment.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Human-readable descriptive name for the size curve profile (e.g., \'Women\'s Fitted Tops Standard\', \'Men\'s Denim 28-42 Bell Curve\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity. Used in Oracle Retail and Anaplan planning interfaces.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the size curve profile indicating the fit and silhouette category that drives the distribution shape. Standard curves follow bell-curve distributions; fitted curves skew toward smaller sizes; oversized curves skew toward larger sizes. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: standard|fitted|oversized|petite|plus|tall|slim|relaxed — promote to reference product]' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultForClass rdf:type rdf:Property ;
    rdfs:label 'Is Default For Class' ;
    rdfs:comment 'Indicates whether this size curve is the default curve applied to new styles within the associated merchandise class when no style-specific curve exists. True = default fallback curve for the class. Used in Oracle Retail automated allocation and buy plan generation.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReplenishmentEligible rdf:type rdf:Property ;
    rdfs:label 'Is Replenishment Eligible' ;
    rdfs:comment 'Indicates whether this size curve is approved for use in automated replenishment size pack calculations in Manhattan Associates WMS. True = curve can drive replenishment size breaks. False = curve is restricted to initial buy plan and allocation use only.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this size curve was last reviewed and validated by a merchandise planner. Curves not reviewed within a defined period (e.g., 2 seasons) are flagged for re-validation to ensure continued accuracy. Supports governance of curve quality.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Markdown Risk Index' ;
    rdfs:comment 'Composite risk score (0.00-100.00) indicating the likelihood of size-related markdown exposure if this curve is applied to a buy plan. Derived from historical size fragmentation patterns and STR variance across sizes. Higher scores indicate greater markdown risk from size imbalance. Critical for GMROI optimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numericSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Numeric Size Distribution' ;
    rdfs:comment 'Serialized representation of the size distribution percentages for numeric size runs (waist sizes 28-42 or equivalent), stored as a delimited string of size:percentage pairs (e.g., \'28:5.0|30:12.0|32:22.0|34:25.0|36:18.0|38:12.0|40:4.0|42:2.0\'). Null for alpha or shoe size scale types. Used when the number of numeric sizes exceeds the available discrete percentage columns.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctL rdf:type rdf:Property ;
    rdfs:label 'Pct L' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size L in the alpha size run. Expressed as a percentage (e.g., 25.00 = 25%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and replenishment size pack optimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctM rdf:type rdf:Property ;
    rdfs:label 'Pct M' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size M in the alpha size run. Expressed as a percentage (e.g., 28.00 = 28%). Typically the modal size in standard bell-curve distributions. Null for numeric or shoe size scale types.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctS rdf:type rdf:Property ;
    rdfs:label 'Pct S' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size S in the alpha size run. Expressed as a percentage (e.g., 18.00 = 18%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and allocation size breaks.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXl rdf:type rdf:Property ;
    rdfs:label 'Pct Xl' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XL in the alpha size run. Expressed as a percentage (e.g., 14.00 = 14%). Null for numeric or shoe size scale types. Used in buy plan size ratio calculations and initial distribution planning.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXs rdf:type rdf:Property ;
    rdfs:label 'Pct Xs' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XS in the alpha size run. Expressed as a percentage (e.g., 8.50 = 8.5%). Null for numeric or shoe size scale types. All size distribution percentages must sum to 100.00 for a valid curve. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctXxl rdf:type rdf:Property ;
    rdfs:label 'Pct Xxl' ;
    rdfs:comment 'Expected percentage of total unit sales allocated to size XXL in the alpha size run. Expressed as a percentage (e.g., 6.50 = 6.5%). Null for numeric or shoe size scale types. Monitoring XXL distribution is critical for plus-size assortment planning and markdown minimization.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region for which this size curve applies (e.g., \'NA\', \'EMEA\', \'APAC\', \'LATAM\'). Size distributions vary significantly by region due to demographic differences. Used to apply region-specific size ratios in allocation and buy planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or user identifier of the merchandise planner who last reviewed and validated this size curve. Provides accountability for curve quality and supports audit trail requirements for merchandise planning governance.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleUnitCount rdf:type rdf:Property ;
    rdfs:label 'Sample Unit Count' ;
    rdfs:comment 'Total number of units sold in the historical basis period used to derive this size curve. Higher sample counts yield higher statistical confidence. Used to validate confidence_level assignment — curves based on fewer than a threshold number of units are flagged as low confidence.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to the base size distribution percentages to account for seasonal demand shifts (e.g., 1.0500 = 5% upward adjustment). Captures known seasonal size preference changes such as outerwear seasons skewing larger. Applied in Anaplan seasonal buy plan calculations.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shoeSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Shoe Size Distribution' ;
    rdfs:comment 'Serialized representation of the size distribution percentages for shoe size runs (US sizes 5-14 or equivalent), stored as a delimited string of size:percentage pairs (e.g., \'7:8.0|7.5:10.0|8:15.0|8.5:18.0|9:17.0|9.5:14.0|10:12.0|10.5:6.0\'). Null for alpha or numeric apparel size scale types.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCount rdf:type rdf:Property ;
    rdfs:label 'Size Count' ;
    rdfs:comment 'Total number of discrete sizes in the size run covered by this curve (e.g., 6 for XS-XXL alpha, 8 for 28-42 even numeric). Drives the number of size break columns populated in allocation and replenishment size pack calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeCurveStatus rdf:type rdf:Property ;
    rdfs:label 'Size Curve Status' ;
    rdfs:comment 'Current lifecycle status of the size curve profile. Active curves are used in live buy plans and allocation runs. Draft curves are under development. Archived curves are retained for historical analysis but excluded from new planning cycles. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeMax rdf:type rdf:Property ;
    rdfs:label 'Size Range Max' ;
    rdfs:comment 'The largest size in the size run covered by this curve (e.g., \'XXL\', \'42\', \'14\'). Combined with size_range_min to define the full size run span. Used to validate that buy plan size breaks fall within the defined range.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeMin rdf:type rdf:Property ;
    rdfs:label 'Size Range Min' ;
    rdfs:comment 'The smallest size in the size run covered by this curve (e.g., \'XS\', \'28\', \'5\'). Combined with size_range_max to define the full size run span. Used to validate that buy plan size breaks fall within the defined range.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strBasisPct rdf:type rdf:Property ;
    rdfs:label 'Str Basis Pct' ;
    rdfs:comment 'The minimum Sell-Through Rate (STR) achieved in the historical basis period for the data to be considered statistically valid for curve derivation. Expressed as a percentage (e.g., 75.00 means 75% STR). Curves derived from low-STR periods may be flagged as low-confidence.' ;
    rdfs:domain ind:SizeCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'The distribution channel scope for which this season is planned. \'All\' covers all channels; \'DTC\' covers direct-to-consumer retail and e-commerce; \'Wholesale\' covers wholesale and distribution partners. Drives channel-specific OTB allocation and assortment planning in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceEndDate rdf:type rdf:Property ;
    rdfs:label 'Clearance End Date' ;
    rdfs:comment 'The date by which all clearance selling for this season must be completed. After this date, remaining inventory is subject to return-to-vendor (RTV), off-price channel transfer, or write-off. Defines the final boundary of the season\'s sell-through window.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalHalf rdf:type rdf:Property ;
    rdfs:label 'Fiscal Half' ;
    rdfs:comment 'The fiscal half-year period (H1 or H2) to which this season is aligned. Spring/Summer and Resort seasons typically fall in H1; Fall/Winter, Pre-Fall, and Holiday seasons in H2. Used for semi-annual merchandise financial planning (MFP) and OTB budget allocation in Anaplan.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this season is currently active and available for use in planning, buying, and allocation transactions. Set to True when the season status is \'active\'; False for planning, closed, or archived seasons. Used to filter active seasons in Oracle Retail Merchandising System and Anaplan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownCadence rdf:type rdf:Property ;
    rdfs:label 'Markdown Cadence' ;
    rdfs:comment 'The planned frequency of markdown (MD) events during the clearance phase of this season. Drives the markdown calendar in Oracle Retail Merchandising System Price Management and informs maintained markup (MMU) forecasting in Anaplan.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStartDate rdf:type rdf:Property ;
    rdfs:label 'Markdown Start Date' ;
    rdfs:comment 'The date on which the first planned markdown (MD) event for this season begins. Initiates the end-of-season clearance cadence. Drives markdown (MD) planning in Oracle Retail Merchandising System Price Management and Anaplan merchandise financial planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Market Week End Date' ;
    rdfs:comment 'The end date of the industry market week associated with this season. Together with market_week_start_date, defines the window during which wholesale buyers finalize orders and assortment commitments.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Market Week Start Date' ;
    rdfs:comment 'The start date of the industry market week (trade show / buying week) associated with this season, during which buyers review collections and place wholesale orders. Key date for collection planning and wholesale distribution calendars.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mfpVersion rdf:type rdf:Property ;
    rdfs:label 'Mfp Version' ;
    rdfs:comment 'The version identifier of the approved merchandise financial plan (MFP) associated with this season in Anaplan (e.g., \'v1.0-Initial\', \'v2.1-Revised\'). Tracks plan revisions through the planning cycle and ensures alignment between OTB budgets and financial targets.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numPlannedSkus rdf:type rdf:Property ;
    rdfs:label 'Num Planned Skus' ;
    rdfs:comment 'The total number of distinct SKUs (Stock Keeping Units) planned for this season across all styles, colors, and sizes. Used to manage assortment breadth, warehouse capacity planning in Manhattan Associates WMS, and OTB unit buy planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numPlannedStyles rdf:type rdf:Property ;
    rdfs:label 'Num Planned Styles' ;
    rdfs:comment 'The total number of distinct styles (SKU parent-level products) planned for this season\'s assortment. Set during collection planning in Centric PLM and used to manage line architecture, OTB depth-versus-breadth trade-offs, and assortment productivity analysis.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Order Deadline Date' ;
    rdfs:comment 'The final date by which all purchase orders (POs) for this season must be submitted to suppliers to ensure on-time delivery within the season\'s delivery window. Critical T&A calendar milestone managed in SAP S/4HANA MM and Centric PLM.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otbBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Amount' ;
    rdfs:comment 'The total approved Open-to-Buy (OTB) budget in the company\'s reporting currency for this season. Represents the maximum planned merchandise spend authorized for buying activities. Set during merchandise financial planning (MFP) in Anaplan and tracked against actual PO commitments in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Amount' ;
    rdfs:comment 'The total planned net sales revenue in the company\'s reporting currency for this season as set during merchandise financial planning (MFP). Serves as the top-line revenue target against which actual sell-through rate (STR) and average unit retail (AUR) performance are measured.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The date on which internal merchandise planning activities formally begin for this season, including OTB budget setting, assortment planning, and buy plan development in Anaplan and Oracle Retail Merchandising System. Precedes the trading start date by several months.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Production Start Date' ;
    rdfs:comment 'The date on which pre-production (PP) activities commence for this season, including fabric and trim approvals, fit samples, and pre-production sample sign-off. Key milestone in the T&A calendar tracked in Centric PLM and Infor PLM.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regionScope rdf:type rdf:Property ;
    rdfs:label 'Region Scope' ;
    rdfs:comment 'The geographic region or market scope for which this season is defined (e.g., \'Global\', \'North America\', \'EMEA\', \'APAC\'). Supports multi-regional merchandise planning where season start/end dates and delivery windows may vary by market. Used in Oracle Retail Merchandising System and Anaplan regional planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonDescription rdf:type rdf:Property ;
    rdfs:label 'Season Description' ;
    rdfs:comment 'Free-text narrative description of the season, capturing key strategic intent, collection positioning, target consumer profile, or planning notes. Used by merchandising and planning teams for context in Oracle Retail Merchandising System and Anaplan.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable full name of the merchandise season (e.g., \'Spring/Summer 2025\', \'Fall/Winter 2024\', \'Holiday 2024\', \'Resort 2025\'). Used in reporting, planning dashboards, and buyer-facing documents.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle state of the merchandise season. \'planning\' indicates the season is in pre-production planning; \'active\' indicates the season is currently trading; \'closed\' indicates the season has ended trading; \'archived\' indicates the season is retained for historical reference only. Controls visibility in planning tools and reporting.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Source System Season Code' ;
    rdfs:comment 'The native season identifier as recorded in the originating operational system of record (e.g., Oracle Retail Merchandising System season number, Anaplan season key). Enables traceability and reconciliation between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Tna Calendar Code' ;
    rdfs:comment 'Reference code linking this season to its associated Time and Action (T&A) calendar template in Centric PLM or Infor PLM. The T&A calendar defines all critical path milestones from design brief through to final delivery for the season.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply Target' ;
    rdfs:comment 'The target number of weeks of supply (WOS) to be maintained during the peak trading period of this season. Used to calibrate inventory depth in buy plans and allocation strategies, ensuring sufficient stock without excess inventory build-up.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeEventId rdf:type rdf:Property ;
    rdfs:label 'Price Change Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each price change event record in the merchandising system. Primary key for the price_change_event data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChangeEvent .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Price changes (especially markdowns) are often timed to marketing campaigns. This link tracks which campaign drove the pricing decision, enabling analysis of campaign-driven markdown effectiveness and' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized reason code from Oracle Retail Merchandising System explaining the business rationale for the price change (e.g., SEASONAL_MD, COMPETITIVE_RESPONSE, CLEARANCE, PROMO, CORRECTION). Supports markdown (MD) analysis and GMROI reporting. [ENUM-REF-CANDIDATE: promote to reference product]' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text narrative description providing additional context for the price change event beyond the standardized reason code. Entered by the merchandising planner or buyer.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the price change event by its business purpose. Permanent Markdown (MD) reduces the retail price indefinitely; Temporary Markdown is time-bound; Markup (MU) increases price; Clearance applies end-of-season liquidation pricing; Promotional applies campaign-driven pricing. [ENUM-REF-CANDIDATE: permanent_markdown|temporary_markdown|markup|clearance|promotional — promote to reference product]' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The calendar date on which the new price becomes active and visible to customers across applicable channels. Used for scheduling future price changes in advance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the price change event within the Oracle Retail Merchandising System workflow. Drives whether the price change is visible and applied at POS and e-commerce channels.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise real-world date and time when the price change event was executed or became effective in the system of record. This is the principal business event time, distinct from audit timestamps.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isClearance rdf:type rdf:Property ;
    rdfs:label 'Is Clearance' ;
    rdfs:comment 'Indicates whether this price change event designates the SKU or style as a clearance item. Once flagged as clearance, the item is typically excluded from future regular-price replenishment and tracked separately for end-of-season liquidation reporting.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompetitiveResponse rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Response' ;
    rdfs:comment 'Indicates whether this price change event was triggered by a competitive pricing response to a market competitor\'s price action. Supports competitive pricing analytics and brand positioning strategy.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPosApplied rdf:type rdf:Property ;
    rdfs:label 'Is Pos Applied' ;
    rdfs:comment 'Indicates whether this price change event has been successfully transmitted and applied at the Point of Sale (POS) system via SAP Customer Activity Repository. Supports reconciliation between merchandising system and store operations.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Sequence Number' ;
    rdfs:comment 'Sequential number indicating the ordinal position of this markdown (MD) event within the seasonal markdown cadence for the affected SKU or style (e.g., 1st markdown, 2nd markdown, 3rd markdown). Supports sell-through rate (STR) analysis and markdown optimization.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newRetailPrice rdf:type rdf:Property ;
    rdfs:label 'New Retail Price' ;
    rdfs:comment 'The updated retail selling price applied to the SKU or style as a result of this price change event. Represents the Average Unit Retail (AUR) post-change and is used in sell-through rate (STR) and GMROI analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Original Retail Price' ;
    rdfs:comment 'The retail selling price of the SKU or style immediately prior to this price change event. Serves as the baseline for calculating markdown (MD) depth, sell-through rate (STR) impact, and maintained markup (MMU).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'The absolute monetary value of the price change (new_retail_price minus original_retail_price). A negative value indicates a markdown (MD); a positive value indicates a markup (MU). Used in merchandise financial planning and OTB impact analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeLevel rdf:type rdf:Property ;
    rdfs:label 'Price Change Level' ;
    rdfs:comment 'Indicates the merchandise hierarchy level at which this price change event was initiated. A style-level change cascades to all associated SKUs; a SKU-level change applies only to the specific variant.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Price Change Number' ;
    rdfs:comment 'Externally-known business identifier for the price change event as assigned by Oracle Retail Merchandising System or SAP S/4HANA SD module. Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePercent rdf:type rdf:Property ;
    rdfs:label 'Price Change Percent' ;
    rdfs:comment 'The percentage change in retail price relative to the original retail price. Calculated as (price_change_amount / original_retail_price) * 100. Used for markdown (MD) depth reporting and sell-through rate (STR) analysis in Anaplan.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Zone Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based pricing zone to which this price change event applies. Pricing zones group locations with identical pricing strategies in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strAtChange rdf:type rdf:Property ;
    rdfs:label 'Str At Change' ;
    rdfs:comment 'The Sell-Through Rate (STR) for the affected SKU or style at the time of this price change event, expressed as a decimal (e.g., 0.65 = 65%). Provides context for the markdown decision and is used in post-event STR lift analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsOnHand rdf:type rdf:Property ;
    rdfs:label 'Units On Hand' ;
    rdfs:comment 'The inventory quantity on hand for the affected SKU at the time of this price change event. Used to calculate the total markdown (MD) dollar exposure and weeks of supply (WOS) impact in merchandise financial planning.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wosAtChange rdf:type rdf:Property ;
    rdfs:label 'Wos At Change' ;
    rdfs:comment 'The Weeks of Supply (WOS) for the affected SKU at the time of this price change event, calculated as units on hand divided by average weekly sales rate. Used to assess inventory urgency and justify markdown (MD) depth decisions.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Foreign key linking to store.district. Business justification: Retail stores belong to districts for regional management hierarchy. retail_store currently has district_name (STRING) which is redundant once district_id FK is added. The district table contains dist' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:primaryBrandId rdf:type rdf:Property ;
    rdfs:label 'Primary Brand Id' ;
    rdfs:comment 'Foreign key linking to product.brand. Business justification: Many apparel retail stores are mono-brand (Nike store, Gucci boutique, Levi\'s outlet). primary_brand_id on retail_store drives brand compliance reporting, brand-mandated store standards, co-op marketi' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:primaryDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Each store is assigned a primary DC for replenishment routing, inventory allocation planning, and freight cost modeling. Fundamental supply chain network design relationship used in allocation and tra' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:replenishmentRoutingGuideId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Routing Guide Id' ;
    rdfs:comment 'Foreign key linking to logistics.routing_guide. Business justification: In apparel fashion, each retail store follows a specific routing guide governing inbound replenishment shipments from DC — specifying carrier, service level, and delivery windows. Store-level routing ' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingGuide .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the retail store location. Used for logistics, lease documentation, customer store-finder, and regulatory filings. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the retail store (suite, floor, unit, mall name, or building identifier). Supplements address_line1 for precise location identification in complex retail environments such as shopping malls or department stores.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBaseRent rdf:type rdf:Property ;
    rdfs:label 'Annual Base Rent' ;
    rdfs:comment 'Annual base rent amount payable under the store lease agreement in the store\'s local currency. Used for occupancy cost analysis, GMROI (Gross Margin Return on Investment) calculation, and store profitability modelling. Excludes turnover/percentage rent and service charges.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality in which the retail store is located. Used for geographic reporting, tax jurisdiction determination, and regional performance analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Köppen-based climate zone classification for the store\'s geographic location. Drives seasonal assortment planning, markdown timing, and inventory allocation decisions for weather-sensitive apparel categories (outerwear, swimwear, knitwear).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the store permanently ceased trading operations. Nullable for active stores. Used for store network rationalization reporting, lease surrender tracking, and historical performance analysis. Populated only when operational_status is permanently_closed.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary operational email address for the retail store location. Used for internal communications, vendor coordination, and omnichannel order notifications. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fittingRoomCount rdf:type rdf:Property ;
    rdfs:label 'Fitting Room Count' ;
    rdfs:comment 'Total number of fitting rooms (changing rooms/dressing rooms) available in the store. Used for store capacity planning, customer experience benchmarking, and visual merchandising layout design. Relevant for apparel conversion rate analytics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossSellingSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Selling Sqft' ;
    rdfs:comment 'Total gross interior square footage of the retail store including all selling, back-of-house, stockroom, and ancillary areas. Used for lease cost-per-square-foot analysis, capital expenditure planning, and store portfolio benchmarking.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Headcount Capacity' ;
    rdfs:comment 'Maximum approved headcount (number of employees) for the store as defined in the workforce plan. Used for labour scheduling, Workday HCM position management, and compliance with local employment regulations. Drives OTB labour cost budgeting.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Enabled' ;
    rdfs:comment 'Indicates whether the store is configured and operationally enabled to fulfil Buy Online Pick Up In Store (BOPIS) orders. Drives omnichannel order routing logic in Salesforce Commerce Cloud and SAP Customer Activity Repository. True = BOPIS active; False = BOPIS not available at this location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether the store is equipped with Radio Frequency Identification (RFID) infrastructure for inventory tracking, cycle counting, and loss prevention. RFID-enabled stores support real-time inventory accuracy and ATS (Available to Sell) visibility. True = RFID infrastructure active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether the store is configured to fulfil e-commerce orders by shipping directly to customers from store inventory. Enables distributed fulfilment network capabilities. Drives order routing in Salesforce Commerce Cloud and Manhattan Associates WMS. True = ship-from-store active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the retail store location in decimal degrees (WGS84). Used for store-finder applications, trade area mapping, proximity-based marketing, and omnichannel routing (BOPIS, ship-from-store).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Expiration date of the current lease agreement for the store premises. Used for lease renewal pipeline management, store closure planning, and IFRS 16 lease liability amortization schedule. Nullable for month-to-month or perpetual arrangements.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Commencement date of the current lease agreement for the store premises as recorded in SAP S/4HANA Real Estate module. Used for lease term tracking, IFRS 16 right-of-use asset calculation, and lease renewal planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the retail store location in decimal degrees (WGS84). Used alongside latitude for geospatial analytics, trade area delineation, and omnichannel fulfillment routing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSellingSqft rdf:type rdf:Property ;
    rdfs:label 'Net Selling Sqft' ;
    rdfs:comment 'Net productive selling floor area in square feet, excluding stockroom, fitting rooms, cash wrap, and back-of-house. Primary denominator for sales-per-square-foot (SPF) KPI, visual merchandising density planning, and fixture capacity modelling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date on which the store first opened for trading to customers. Used for store age calculations, comparable store (comp-store) sales analysis, and new store ramp-up performance benchmarking.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the store location within Apparel Fashion\'s retail network. Pre-open indicates the store is in fit-out or pre-launch phase; trading indicates active selling operations; temporarily_closed covers seasonal or refurbishment closures; permanently_closed indicates the store has ceased operations. Drives inclusion/exclusion in POS reporting, inventory allocation, and workforce scheduling.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary customer-facing telephone number for the retail store location. Used for customer service, click-and-collect (BOPIS) coordination, and store directory listings. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Classification of the POS terminal configuration deployed in the store. Fixed terminals are traditional counter-based registers; mobile POS (mPOS) enables floor-based selling; self-checkout enables customer-operated transactions; mixed indicates a combination. Drives IT infrastructure planning and customer experience design.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the retail store location. Used for trade area analysis, catchment modelling, demographic profiling, and logistics routing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the geographic region within Apparel Fashion\'s retail organizational hierarchy (e.g., North America, EMEA, APAC). Top tier of the region/district/territory hierarchy used for regional performance reporting and resource allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerCount rdf:type rdf:Property ;
    rdfs:label 'Register Count' ;
    rdfs:comment 'Total number of active Point of Sale (POS) terminals (registers) installed in the store. Used for transaction throughput capacity planning, queue management, and SAP Customer Activity Repository (CAR) terminal configuration management.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remodelDate rdf:type rdf:Property ;
    rdfs:label 'Remodel Date' ;
    rdfs:comment 'Date of the most recent store remodel or significant capital refurbishment. Used to assess store condition age, plan future capital expenditure cycles, and correlate store investment with post-remodel sales uplift.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentStructureType rdf:type rdf:Property ;
    rdfs:label 'Rent Structure Type' ;
    rdfs:comment 'Classification of the rent payment structure under the store lease. Fixed rent is a flat periodic payment; turnover rent is a percentage of net sales; fixed_plus_turnover combines a base rent with a sales-linked top-up; concession_percentage applies to shop-in-shop and concession formats. Drives financial planning and OTB (Open-to-Buy) modelling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTradingHours rdf:type rdf:Property ;
    rdfs:label 'Standard Trading Hours' ;
    rdfs:comment 'Standard weekly operating hours for the store expressed as a structured string (e.g., \'Mon-Sat 09:00-21:00; Sun 11:00-18:00\'). Used for customer-facing store finder, workforce scheduling in Workday HCM, and daily sales reconciliation cut-off timing in SAP Customer Activity Repository.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region in which the retail store is located. Used for tax jurisdiction mapping, regional hierarchy assignment, and regulatory compliance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockroomSqft rdf:type rdf:Property ;
    rdfs:label 'Stockroom Sqft' ;
    rdfs:comment 'Total square footage of the store\'s back-of-house stockroom area. Used for inventory capacity planning, WMS (Warehouse Management System) configuration, and the calculation of net-to-gross selling area ratio. Informs replenishment frequency and NOS (Never Out of Stock) capability.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCode rdf:type rdf:Property ;
    rdfs:label 'Store Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the store, used across SAP S/4HANA, SAP Customer Activity Repository (CAR), Oracle Retail, and EDI integrations. Conforms to NRF ARTS store numbering convention. Unique across all store formats and geographies.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'Operational format classification of the store that determines merchandising strategy, assortment depth, pricing authority, and capital investment profile. Flagship stores carry full-price full-assortment; outlet stores carry clearance/off-price; pop-up stores are temporary; shop-in-shop and concession operate within a host retailer\'s space.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'Official trading name of the retail store location as displayed on signage, customer receipts, and marketing materials. Used for customer-facing communications and brand management reporting.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax authority jurisdiction code assigned to the store location for sales tax, VAT, or GST calculation and remittance. Sourced from SAP S/4HANA FI/CO tax configuration. Used for POS transaction tax determination and regulatory tax reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Name of the territory or cluster within the district hierarchy. Lowest tier of the organizational hierarchy above individual store level, used for territory manager assignments and localized assortment planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the store\'s local operating time zone (e.g., America/New_York, Europe/London). Critical for accurate POS transaction timestamping, daily sales reconciliation, and omnichannel order cut-off time management in SAP Customer Activity Repository.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Trading Area Classification' ;
    rdfs:comment 'Classification of the retail trading environment in which the store operates. Determines foot traffic patterns, trading hours, lease structure, and competitive benchmarking peer group. Used in store performance analytics and site selection models. [ENUM-REF-CANDIDATE: high_street|shopping_mall|outlet_center|airport|resort|standalone|department_store — promote to reference product]' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Primary key for pos_transaction' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: B2B wholesale transactions processed at retail locations generate AR invoices for trade customers. Common in apparel brands with hybrid retail/wholesale models where stores serve business accounts req' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:cashierAssociateId rdf:type rdf:Property ;
    rdfs:label 'Cashier Associate Id' ;
    rdfs:comment 'Reference to the sales associate or cashier who processed the transaction. Used for associate-level performance tracking, commission calculation, and loss prevention audits.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the identified customer (loyalty member or registered account) associated with this transaction. Nullable for anonymous/walk-in transactions. Enables Customer Lifetime Value (CLTV) and loyalty analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:registerId rdf:type rdf:Property ;
    rdfs:label 'Register Id' ;
    rdfs:comment 'Reference to the specific POS register (terminal) at which the transaction was processed within the store. Supports register-level reconciliation and shrinkage analysis.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Register .

ind:returnOriginalTransactionPosTransactionId rdf:type rdf:Property ;
    rdfs:label 'Return Original Transaction Pos Transaction Id' ;
    rdfs:comment 'For RETURN or EXCHANGE transaction types, references the original sale transaction being returned against. Enables return merchandise authorization (RMA) traceability and shrinkage analysis. Null for non-return transactions.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to order.rma. Business justification: In-store returns with defects or warranty claims generate RMA records for vendor credit processing (RTV authorization). Business process: store return disposition triggers formal RMA when item require' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the associated omnichannel sales order in SAP S/4HANA SD or Salesforce Commerce Cloud for BOPIS, ship-from-store, or endless aisle transactions. Null for standard in-store transactions. Enables cross-channel order traceability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'The fiscal/retail business date to which this transaction is attributed for daily sales reconciliation and End-of-Month (EOM) reporting. May differ from the wall-clock date for transactions processed after midnight during extended trading hours.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary value of all discounts and markdowns (MD) applied to the transaction, including promotional discounts, employee discounts, coupon redemptions, and loyalty-funded discounts. Used in Maintained Markup (MMU) and Sell-Through Rate (STR) analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total pre-discount, pre-tax merchandise value of all items in the transaction at their selling price. Represents the sum of line-item extended prices before any adjustments. Used in Average Unit Retail (AUR) and Average Selling Price (ASP) calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of individual unit items (units) included in the transaction across all line items. Used for basket size analytics, Average Order Value (AOV) benchmarking, and store traffic conversion metrics.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'Total number of distinct line items (SKU entries) in the transaction. Differs from item_count when multiple units of the same SKU are purchased. Used for transaction complexity analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty reward points earned by the customer on this transaction based on the applicable loyalty program earn rate. Used for loyalty liability accrual and Customer Relationship Management (CRM) analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty reward points redeemed by the customer as a form of payment or discount on this transaction. Used for loyalty liability reduction and redemption rate analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether a manager authorization override was required to complete this transaction (e.g., for price overrides, high-value returns, or discount exceptions). Critical for loss prevention and exception-based reporting.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount tendered by the customer: gross_amount minus discount_amount plus tax_amount. Represents the total cash obligation of the transaction. Primary revenue figure for daily sales reconciliation and KPI reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Price Override Flag' ;
    rdfs:comment 'Indicates whether a manual price override was applied to one or more items in this transaction, bypassing the system-calculated selling price. Used in loss prevention audits and markdown (MD) exception reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Delivery Method' ;
    rdfs:comment 'Method by which the transaction receipt was delivered to the customer: PRINT (paper receipt), EMAIL (digital email receipt), SMS (text message receipt), NONE (no receipt requested). Supports sustainability reporting and digital engagement analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Customer-facing receipt identifier printed on the physical or digital receipt. May differ from transaction_number in some POS configurations. Used for customer service, return authorization, and receipt lookup.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Coded reason for a merchandise return (e.g., DEFECTIVE, WRONG_SIZE, CHANGED_MIND, GIFT_RETURN). Populated only for RETURN and EXCHANGE transaction types. Used in product quality analysis, CPSC compliance, and Return to Vendor (RTV) decisions. [ENUM-REF-CANDIDATE: DEFECTIVE|WRONG_SIZE|CHANGED_MIND|GIFT_RETURN|WRONG_ITEM|NOT_AS_DESCRIBED — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Verified Flag' ;
    rdfs:comment 'Indicates whether the items in this transaction were verified via Radio Frequency Identification (RFID) scanning at the point of sale. Supports inventory accuracy, shrinkage reduction, and omnichannel Available to Sell (ATS) reconciliation.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax collected across all applicable tax jurisdictions for this transaction. Aggregated from jurisdiction-level tax lines. Supports tax remittance reporting and compliance with FTC and state tax authorities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderCashAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Cash Amount' ;
    rdfs:comment 'Amount of the transaction settled by cash tender. Used in daily cash drawer reconciliation and loss prevention audits. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Credit Amount' ;
    rdfs:comment 'Amount of the transaction settled by credit card tender. Supports PCI DSS compliance reporting and payment reconciliation. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Debit Amount' ;
    rdfs:comment 'Amount of the transaction settled by debit card tender. Supports payment reconciliation and PCI DSS compliance. Part of the tender split breakdown.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderGiftCardAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Gift Card Amount' ;
    rdfs:comment 'Amount of the transaction settled by gift card redemption. Used for gift card liability tracking, breakage analysis, and revenue recognition per IFRS/GAAP deferred revenue rules.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderMobileWalletAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Mobile Wallet Amount' ;
    rdfs:comment 'Amount of the transaction settled via mobile wallet payment (e.g., Apple Pay, Google Pay, Samsung Pay). Tracks digital payment adoption trends and supports omnichannel payment analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderStoreCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Store Credit Amount' ;
    rdfs:comment 'Amount of the transaction settled using store credit (issued from prior returns or promotions). Supports Return to Vendor (RTV) and return merchandise authorization liability tracking.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModeFlag rdf:type rdf:Property ;
    rdfs:label 'Training Mode Flag' ;
    rdfs:comment 'Indicates whether this transaction was processed in POS training/demo mode and should be excluded from financial reporting and sales analytics. Critical for data quality and accurate daily sales reconciliation.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business identifier for the transaction as printed on the customer receipt and recorded in SAP Customer Activity Repository. Unique within a store and business date combination. Conforms to NRF ARTS POSLog SequenceNumber.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the transaction in the POS workflow. COMPLETED: fully tendered and closed; VOIDED: reversed before completion; SUSPENDED: parked mid-transaction for later recall; CANCELLED: abandoned; PENDING: awaiting tender confirmation (e.g., BOPIS pickup).' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time when the transaction was initiated at the register, as recorded by the POS system. Principal business event timestamp. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for intraday traffic analytics and hourly sales reporting.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the transaction event per NRF ARTS POSLog standard. SALE: standard purchase; RETURN: merchandise returned for refund; EXCHANGE: simultaneous return and sale; VOID: cancelled transaction before completion; NO_SALE: register opened without a sale; LAYAWAY: deferred payment purchase.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Coded reason for voiding a transaction (e.g., OPERATOR_ERROR, CUSTOMER_CHANGED_MIND, SYSTEM_ERROR, MANAGER_OVERRIDE). Populated only for VOID transaction types. Used in loss prevention and exception reporting. [ENUM-REF-CANDIDATE: OPERATOR_ERROR|CUSTOMER_CHANGED_MIND|SYSTEM_ERROR|MANAGER_OVERRIDE|PRICE_OVERRIDE|DUPLICATE_TRANSACTION — promote to reference product]' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workstationNumber rdf:type rdf:Property ;
    rdfs:label 'Workstation Number' ;
    rdfs:comment 'Human-readable identifier of the POS workstation/terminal as configured in SAP Customer Activity Repository (e.g., REG-01, KIOSK-03). Used for register-level reconciliation and store layout analytics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionLineId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Line Id' ;
    rdfs:comment 'Primary key for pos_transaction_line' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Cogs Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.cogs_entry. Business justification: Every POS transaction line sold triggers a COGS recognition entry in the finance system. Apparel retail P&L reporting and gross margin reconciliation at the line level require linking each unit sold t' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:salesAssociateId rdf:type rdf:Property ;
    rdfs:label 'Sales Associate Id' ;
    rdfs:comment 'Reference to the sales associate who processed or assisted with this transaction line. Used for associate-level sales performance tracking, commission calculation, and clienteling analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:salesOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.sales_order_line. Business justification: Omnichannel order fulfillment reconciliation requires linking POS transaction lines to the originating sales order lines for BOPIS and click-and-collect scenarios. Line-level linkage enables precise r' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrderLine .

ind:cogs rdf:type rdf:Property ;
    rdfs:label 'Cogs' ;
    rdfs:comment 'Cost of Goods Sold (COGS) for this line item representing the total cost of the units sold. Used to calculate gross margin, GMROI, and MMU at the SKU-store-day grain. Sourced from SAP S/4HANA material valuation.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discount Reason Code' ;
    rdfs:comment 'Code identifying the business reason for any discount or markdown applied to this line item (e.g., EMPLOYEE, LOYALTY, COUPON, CLEARANCE, PROMO, DAMAGE). Used for discount analytics, shrinkage investigation, and promotional effectiveness reporting. [ENUM-REF-CANDIDATE: EMPLOYEE|LOYALTY|COUPON|CLEARANCE|PROMO|DAMAGE|PRICE_MATCH|MANAGER_OVERRIDE — promote to reference product]' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'Indicates the omnichannel fulfillment method for this line item. Distinguishes standard in-store purchases from BOPIS (Buy Online Pick Up In Store), ship-from-store, curbside pickup, and endless aisle orders. Critical for DTC omnichannel analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imuPct rdf:type rdf:Property ;
    rdfs:label 'Imu Pct' ;
    rdfs:comment 'Initial Markup (IMU) percentage for this SKU at the time of the transaction, representing the difference between the original retail price and COGS as a percentage of retail. Key metric for margin planning and merchandise financial performance.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this record was ingested into the Databricks Silver layer from the source system. Used for data freshness monitoring, SLA compliance tracking, and incremental load auditing.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isClearanceItem rdf:type rdf:Property ;
    rdfs:label 'Is Clearance Item' ;
    rdfs:comment 'Indicates whether the SKU on this line was designated as a clearance item at the time of sale. Clearance items are end-of-lifecycle SKUs being liquidated. Distinct from is_markdown_item which covers all markdowns including promotional.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMarkdownItem rdf:type rdf:Property ;
    rdfs:label 'Is Markdown Item' ;
    rdfs:comment 'Indicates whether the SKU on this line was sold at a marked-down price at the time of the transaction. True if the item was on permanent or promotional markdown. Used to segment full-price vs. markdown sales for AUR and margin analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidScanned rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Scanned' ;
    rdfs:comment 'Indicates whether this line item was identified via RFID (Radio Frequency Identification) tag scan rather than traditional barcode/UPC scan at the POS. Supports RFID adoption tracking, inventory accuracy measurement, and shrinkage reduction analytics.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Additional point-of-sale discount amount applied to this specific line item beyond the ticketed markdown, such as employee discounts, loyalty rewards, or coupon redemptions. Distinct from markdown_amount which reflects price management markdowns.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineExtendedAmount rdf:type rdf:Property ;
    rdfs:label 'Line Extended Amount' ;
    rdfs:comment 'Total net sales amount for this line item (unit_retail_price × quantity_sold minus line_discount_amount). Represents the actual revenue recognized for this line. Used in daily sales reconciliation and financial reporting.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the transaction line indicating whether it represents a sale, return, exchange, void, or layaway. Drives revenue recognition logic, inventory adjustment direction, and return analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Amount' ;
    rdfs:comment 'Total markdown (MD) dollar amount applied to this line item, calculated as the difference between the original retail price and the unit retail price multiplied by quantity. Tracks permanent and promotional markdowns for MMU and margin analytics.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmuPct rdf:type rdf:Property ;
    rdfs:label 'Mmu Pct' ;
    rdfs:comment 'Maintained Markup (MMU) percentage for this line item, reflecting the actual margin achieved after all markdowns and discounts. Calculated as (unit_retail_price - unit_cost) / unit_retail_price. Core KPI for merchandise financial planning.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'Number of units sold on this transaction line. Positive for sales, negative for returns/voids. Core metric for sell-through rate (STR), weeks of supply (WOS), and inventory depletion analytics. Aligns with TRANSACTION_LINE role LINE_QUANTITY category.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this record in the Silver layer, reflecting corrections, late-arriving data, or restatements from the source system. Supports data quality monitoring and change data capture.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:registerCode rdf:type rdf:Property ;
    rdfs:label 'Register Code' ;
    rdfs:comment 'Identifier of the POS register or terminal where this transaction line was processed. Used for register-level reconciliation, shrinkage investigation, and store operations auditing.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineReference rdf:type rdf:Property ;
    rdfs:label 'Source System Line Reference' ;
    rdfs:comment 'The native transaction line identifier from the source system (SAP Customer Activity Repository). Preserves the original system reference for data lineage, reconciliation, and audit trail purposes in the Silver layer.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Calendar date on which the POS transaction occurred. Primary grain dimension for daily sales reconciliation, STR reporting, and store performance KPI dashboards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The actual retail price charged per unit on this line after all markdowns and promotions have been applied. Represents the AUR (Average Unit Retail) at the transaction level. Core input for ASP and AUR analytics. Aligns with TRANSACTION_LINE role LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailySalesSummaryId rdf:type rdf:Property ;
    rdfs:label 'Daily Sales Summary Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily sales summary record. Primary key for the daily_sales_summary data product in the store domain.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Daily sales summaries post to GL as journal entries for revenue recognition and cash reconciliation. Standard retail accounting practice; enables audit trail from store operations to financial stateme' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code for any post-close adjustment applied to this daily sales summary. Only populated when is_adjusted = True. Used for audit trail and financial control reporting. [ENUM-REF-CANDIDATE: system_correction|manual_override|return_reclass|shrinkage_update|tax_correction|other — promote to reference product]' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asp rdf:type rdf:Property ;
    rdfs:label 'Asp' ;
    rdfs:comment 'Average selling price (ASP) per transaction on the business date, calculated as net sales amount divided by transaction count. Distinct from AUR which is per unit; ASP reflects basket-level pricing performance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisOrderCount rdf:type rdf:Property ;
    rdfs:label 'Bopis Order Count' ;
    rdfs:comment 'Number of buy-online-pick-up-in-store (BOPIS) orders fulfilled at this store on the business date. Key omnichannel fulfillment metric used to assess store capacity utilization and DTC channel performance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Card Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via credit or debit card on the business date. Reconciled against card processor settlement reports as part of daily sales reconciliation. Includes all card network types (Visa, Mastercard, Amex, etc.).' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Tender Amount' ;
    rdfs:comment 'Total sales amount tendered in cash on the business date. Used for daily cash reconciliation, safe count verification, and bank deposit preparation as part of end-of-day store close procedures.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Closing Inventory Units' ;
    rdfs:comment 'Total on-hand inventory unit count at the end of the business date after all sales, returns, receipts, and adjustments. Used for weeks-of-supply (WOS) calculation and next-day opening inventory.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Percentage of customer visits that resulted in a completed purchase transaction on the business date (transaction count / customer traffic count), expressed as a decimal. Key store performance KPI for associate effectiveness and visual merchandising impact.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerTrafficCount rdf:type rdf:Property ;
    rdfs:label 'Customer Traffic Count' ;
    rdfs:comment 'Total number of customer visits (door count) recorded at the store on the business date via traffic counting systems. Used to calculate conversion rate (transaction count / traffic count) as a store performance KPI.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via digital payment methods (mobile wallets, gift cards, buy-now-pay-later, loyalty points redemption) on the business date. Tracked separately for digital payment adoption analytics.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardTenderAmount rdf:type rdf:Property ;
    rdfs:label 'Gift Card Tender Amount' ;
    rdfs:comment 'Total sales amount tendered via gift cards on the business date. Tracked separately from other digital tenders for gift card liability reconciliation and breakage accounting per IFRS/GAAP deferred revenue standards.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue for the business date before deducting returns, markdowns, or discounts. Represents the sum of all POS transaction line amounts at full selling price prior to any adjustments.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdjusted rdf:type rdf:Property ;
    rdfs:label 'Is Adjusted' ;
    rdfs:comment 'Boolean flag indicating whether this daily sales summary record has been subject to a post-close adjustment (True). Adjusted records require additional audit scrutiny and are tracked for financial control compliance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Boolean flag indicating whether the daily sales summary has been formally reconciled (True) or is still pending reconciliation (False). Used to filter confirmed records for financial reporting and OTB updates.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Total net sales revenue for the business date after deducting returns and markdowns from gross sales. The primary revenue figure used for store performance reporting, OTB tracking, and STR calculation.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Opening Inventory Units' ;
    rdfs:comment 'Total on-hand inventory unit count at the start of the business date (beginning of day). Used as the denominator for daily sell-through rate (STR) calculation and OTB tracking.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pos Close Timestamp' ;
    rdfs:comment 'The exact date and time when the POS end-of-day close process was completed for this store on the business date. Represents the principal business event timestamp for this summary record. Sourced from SAP Customer Activity Repository daily close process.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'The date and time when the daily sales summary was formally reconciled and approved by the store manager or back-office team. Distinct from POS close timestamp; represents the human-verified sign-off event.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Return Transaction Count' ;
    rdfs:comment 'Total number of return transactions processed at the store on the business date. Used to calculate return rate and assess customer satisfaction and product quality issues.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total monetary value of customer merchandise returns processed at the store on the business date. Subtracted from gross sales to derive net sales. Sourced from SAP CAR return transaction aggregation.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromStoreOrderCount rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Order Count' ;
    rdfs:comment 'Number of e-commerce orders fulfilled via ship-from-store on the business date. Reflects the store\'s contribution to omnichannel fulfillment and impacts available-to-sell (ATS) inventory levels.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shrinkageAmount rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Amount' ;
    rdfs:comment 'Estimated or recorded shrinkage (inventory loss due to theft, damage, or administrative error) value for the business date. Used for loss prevention reporting and COGS adjustment. Sourced from cycle count variances and known loss events.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The externally-known alphanumeric store identifier as assigned in the retail merchandising and POS systems (e.g., \'STR-0042\'). Used for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:str rdf:type rdf:Property ;
    rdfs:label 'Str' ;
    rdfs:comment 'Sell-through rate (STR) for the business date, expressed as a decimal (e.g., 0.0325 = 3.25%). Calculated as units sold divided by beginning-of-day on-hand inventory units. Used for inventory productivity and OTB management.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:summaryStatus rdf:type rdf:Property ;
    rdfs:label 'Summary Status' ;
    rdfs:comment 'Current lifecycle status of the daily sales summary record. \'open\' indicates the trading day is in progress; \'pending_reconciliation\' indicates end-of-day close initiated; \'reconciled\' indicates cash and card tenders have been balanced; \'closed\' indicates the record is finalized; \'adjusted\' indicates a post-close correction was applied; \'voided\' indicates the record was invalidated. [ENUM-REF-CANDIDATE: open|pending_reconciliation|reconciled|closed|adjusted|voided — promote to reference product]' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of completed POS sales transactions (excluding voids and returns) processed at the store on the business date. Used as the denominator for average order value (AOV) and average unit retail (AUR) calculations.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Units Per Transaction' ;
    rdfs:comment 'Average number of units sold per sales transaction on the business date (units sold divided by transaction count). A key store productivity KPI used to measure associate selling effectiveness and cross-sell performance.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsReturned rdf:type rdf:Property ;
    rdfs:label 'Units Returned' ;
    rdfs:comment 'Total number of individual units returned by customers on the business date. Used to calculate gross units sold and return rate metrics for store performance analysis.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of individual units (SKUs) sold on the business date, net of returns. Used for sell-through rate (STR) calculation, average unit retail (AUR) computation, and inventory depletion tracking.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Void Transaction Count' ;
    rdfs:comment 'Total number of voided POS transactions on the business date. Elevated void counts may indicate training issues, fraud risk, or system errors and are monitored as part of loss prevention.' ;
    rdfs:domain ind:DailySalesSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associateId rdf:type rdf:Property ;
    rdfs:label 'Associate Id' ;
    rdfs:comment 'Primary key for associate' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the associate\'s store assignment. Controls POS login eligibility, scheduling inclusion, and commission accrual. \'transferred\' indicates the associate has moved to another store.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associateNumber rdf:type rdf:Property ;
    rdfs:label 'Associate Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the associate, used on POS terminals, scheduling systems, and commission reports. Sourced from SAP Customer Activity Repository operator configuration.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisFulfillmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Bopis Fulfillment Enabled' ;
    rdfs:comment 'Indicates whether the associate is authorized and trained to fulfill Buy Online Pick Up In Store (BOPIS) orders. Supports omnichannel fulfillment assignment in Salesforce Commerce Cloud and SAP Customer Activity Repository.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether the associate is eligible to earn sales commission. Eligibility is determined by store role, employment type, and department assignment per the compensation policy.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Code identifying the commission plan structure assigned to the associate (e.g., tiered, flat-rate, department-specific). References the commission plan configuration in SAP Customer Activity Repository.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Individual commission rate applied to the associate\'s attributed net sales, expressed as a decimal (e.g., 0.0250 = 2.50%). Used for commission accrual calculations in SAP FI/CO. Confidential compensation data.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the associate\'s employment arrangement. Determines scheduling eligibility, benefit entitlements, and labor cost categorization. Sourced from Workday HCM worker type.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the store associate as recorded in Workday HCM. Used for scheduling displays, POS operator identification, and customer-facing name badges.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the associate was originally hired by the company. Used for tenure calculations, anniversary recognition, and benefit eligibility determination. Sourced from Workday HCM.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyholderFlag rdf:type rdf:Property ;
    rdfs:label 'Keyholder Flag' ;
    rdfs:comment 'Indicates whether the associate holds store key access and is authorized to open or close the store. Keyholders have elevated POS and alarm system permissions.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Primary language spoken by the associate, expressed as an IETF BCP 47 language tag (e.g., en-US, es-MX, fr-FR). Used for customer service routing and multilingual store staffing analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name of the store associate as recorded in Workday HCM. Combined with first_name for full identity display on POS, commission statements, and performance reports.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the associate\'s most recent formal performance review. Used to track review cycle compliance and identify associates overdue for evaluation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Loss Prevention Flag' ;
    rdfs:comment 'Indicates whether the associate has an active loss prevention alert or investigation flag. Confidential — access restricted to store management and loss prevention teams. Used for shrinkage management.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScoreAvg rdf:type rdf:Property ;
    rdfs:label 'Nps Score Avg' ;
    rdfs:comment 'Average Net Promoter Score (NPS) received by the associate from customer satisfaction surveys attributed to their POS transactions. Ranges from -100 to 100. Used for associate-level service quality monitoring.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent formal performance rating assigned to the associate during the annual or mid-year review cycle. Confidential HR data used for promotion eligibility, commission tier adjustments, and workforce planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posLoginEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Login Enabled' ;
    rdfs:comment 'Indicates whether the associate is currently authorized to log in to POS terminals. Set to false during suspension, leave, or post-termination to prevent unauthorized transactions.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Pos Operator Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the associate on POS terminals for transaction attribution, cash drawer assignment, and sales performance tracking. Configured in SAP Customer Activity Repository.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Preferred or commonly-used name of the associate for scheduling boards, name badges, and internal communications. May differ from legal first name.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Primary Department Code' ;
    rdfs:comment 'Alphanumeric code identifying the associate\'s primary assigned department within the store (e.g., FTWR for Footwear, APRL for Apparel). Used for floor coverage planning and department-level sales attribution.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productKnowledgeTier rdf:type rdf:Property ;
    rdfs:label 'Product Knowledge Tier' ;
    rdfs:comment 'Certified level of product knowledge attained by the associate across the brand\'s apparel, footwear, and accessories categories. Drives assignment to high-value customer interactions and specialist floor zones.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidBadgeCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Badge Code' ;
    rdfs:comment 'Unique RFID chip identifier embedded in the associate\'s access badge. Used for store entry/exit access control, time and attendance tracking, and loss prevention audit trails.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesFloorZone rdf:type rdf:Property ;
    rdfs:label 'Sales Floor Zone' ;
    rdfs:comment 'Designated zone or area of the sales floor to which the associate is assigned (e.g., Front-of-House, Back Wall, Fitting Room, Cash Wrap). Supports visual merchandising coverage and traffic analytics.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours Per Week' ;
    rdfs:comment 'Standard contracted or scheduled weekly hours for the associate. Used for labor cost planning, overtime threshold monitoring, and workforce scheduling in the store operations context.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether the associate is authorized to process ship-from-store fulfillment orders, including picking, packing, and carrier handoff. Supports omnichannel DTC fulfillment operations.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeAssignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Store Assignment End Date' ;
    rdfs:comment 'Date the associate\'s assignment to the current store ended due to transfer, termination, or leave. Null if the assignment is currently active. Enables historical store assignment tracking.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeAssignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Store Assignment Start Date' ;
    rdfs:comment 'Date the associate was assigned to the current store. Distinct from hire_date — an associate may transfer between stores. Used for store-level tenure and performance benchmarking.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeRole rdf:type rdf:Property ;
    rdfs:label 'Store Role' ;
    rdfs:comment 'Operational role of the associate within the retail store context. Drives POS operator permissions, commission tier eligibility, scheduling authority, and floor coverage responsibilities. Distinct from HR job title in Workday HCM.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date the associate\'s employment was formally terminated. Null for active employees. Used for access revocation, final commission settlement, and workforce analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date the associate completed mandatory onboarding and product training for their current store role. Used to confirm readiness for floor assignment and POS activation.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uniformSizeBottom rdf:type rdf:Property ;
    rdfs:label 'Uniform Size Bottom' ;
    rdfs:comment 'Apparel size for the associate\'s uniform bottom garment. Used by store operations for uniform inventory management and replenishment ordering.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformSizeTop rdf:type rdf:Property ;
    rdfs:label 'Uniform Size Top' ;
    rdfs:comment 'Apparel size for the associate\'s uniform top garment. Used by store operations for uniform inventory management and replenishment ordering.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address assigned to the associate for internal communications, scheduling notifications, and system access. Sourced from Workday HCM.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Work or store-assigned phone number for the associate, used for scheduling contact and store operations communication.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisOrderId rdf:type rdf:Property ;
    rdfs:label 'Bopis Order Id' ;
    rdfs:comment 'Unique identifier for the BOPIS order fulfillment record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BopisOrder .

ind:primaryBopisPickAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Bopis Pick Associate Id' ;
    rdfs:comment 'Reference to the store associate who picked the items for this BOPIS order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order was assigned to the fulfilling store.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notes' ;
    rdfs:comment 'Free-text notes providing additional context about the BOPIS order cancellation.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason why the BOPIS order was cancelled.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order was cancelled, either by customer request, store action, or system expiry.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:curbsideFlag rdf:type rdf:Property ;
    rdfs:label 'Curbside Flag' ;
    rdfs:comment 'Indicates whether the customer requested curbside pickup service for this BOPIS order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Timestamp' ;
    rdfs:comment 'The date and time when the customer was notified that their BOPIS order is ready for pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order will expire if not picked up. Typically set based on store policy (e.g., 3-7 days after ready notification).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle status of the BOPIS order fulfillment workflow. Tracks progression from assignment through pickup or cancellation. [ENUM-REF-CANDIDATE: assigned|picking|picked|ready_for_pickup|picked_up|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The communication channel used to notify the customer that their order is ready for pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable business identifier for the originating sales order. Used for customer communication and operational tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'The date and time when the customer placed the original online order. Principal business event timestamp.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The total monetary value of the BOPIS order including all items, taxes, and fees.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Complete Timestamp' ;
    rdfs:comment 'The date and time when all items for this BOPIS order were successfully picked and staged.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'The date and time when the store associate began picking items for this BOPIS order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupLocationType rdf:type rdf:Property ;
    rdfs:label 'Pickup Location Type' ;
    rdfs:comment 'The type of pickup location within or near the store where the customer will collect their order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Timestamp' ;
    rdfs:comment 'The date and time when the customer picked up the BOPIS order from the store.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Pickup Verification Method' ;
    rdfs:comment 'The method used to verify customer identity and authorize order handoff at pickup.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this BOPIS order has been marked as priority for expedited fulfillment (e.g., VIP customer, urgent request).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readyForPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready For Pickup Timestamp' ;
    rdfs:comment 'The date and time when the BOPIS order was marked ready for customer pickup and customer notification was triggered.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'The actual number of minutes elapsed from order assignment to ready-for-pickup status. Used for SLA compliance tracking.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the BOPIS order fulfillment met the defined SLA target time. True if actual time is less than or equal to target time.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The target number of minutes from order assignment to ready-for-pickup status, as defined by store operations policy.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text special instructions or notes from the customer regarding pickup preferences or requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total number of units (quantity across all items) included in this BOPIS order.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Description' ;
    rdfs:comment 'Description of the customer\'s vehicle (make, model, color) for curbside pickup identification.' ;
    rdfs:domain ind:BopisOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromStoreId rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Id' ;
    rdfs:comment 'Unique surrogate identifier for each ship-from-store fulfillment record in the Silver layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipFromStore .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Ship-from-store fulfillment ships to a customer\'s delivery address. Five denormalized destination address columns exist on ship_from_store. Normalizing via FK to customer.address supports carrier rout' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: ship_from_store has denormalized carrier_code (plain column). Normalizing to carrier_id enables carrier performance reporting (OTIF, damage rates) per SFS fulfillment, carrier cost analysis, and SLA c' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:fulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Id' ;
    rdfs:comment 'Foreign key linking to order.fulfillment. Business justification: Ship-from-store execution must link to the central fulfillment record for unified OTIF reporting, carrier tracking reconciliation, and omnichannel fulfillment cost analysis. ship_from_store has shipme' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fulfillment .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_shipment. Business justification: Ship-from-store fulfillment creates outbound logistics shipments that must be tracked for carrier handoff, delivery status, OTIF compliance, and customer service inquiries. Core omnichannel fulfillmen' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'The shipping service tier selected for this fulfillment (e.g., ground, 2-day, overnight). Drives carrier cost, delivery promise, and customer experience SLA compliance reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code capturing the type of exception encountered during the ship-from-store fulfillment process. Used for exception management workflows, store associate coaching, and process improvement analytics. [ENUM-REF-CANDIDATE: ITEM_NOT_FOUND|DAMAGED_ITEM|LABEL_FAILURE|CARRIER_PICKUP_MISSED|ADDRESS_INVALID|SYSTEM_TIMEOUT — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Request Number' ;
    rdfs:comment 'Externally-known business identifier for the ship-from-store fulfillment request, used for cross-system traceability across Salesforce Commerce Cloud, Manhattan Associates WMS, and SAP S/4HANA SD. Corresponds to the outbound delivery document number in WMS. [BUSINESS_IDENTIFIER category]' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the shipped_quantity equals the ordered_quantity, confirming complete fulfillment. Enables decomposed OTIF analysis separating fullness from timeliness dimensions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the order was shipped on or before the promised_ship_date, independent of quantity completeness. Enables decomposed OTIF analysis separating timeliness from fullness dimensions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The number of units of the SKU requested for fulfillment in this ship-from-store record. Represents the demand quantity as received from the originating sales order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this ship-from-store fulfillment met the OTIF (On Time In Full) standard — shipped on or before the promised_ship_date with the full shipped_quantity equal to ordered_quantity. Core KPI for omnichannel fulfillment performance and store capacity management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the packing of the ship-from-store order was completed and the parcel was sealed and labeled. Used to measure pack cycle time and overall fulfillment throughput.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Package Weight Kg' ;
    rdfs:comment 'Actual weight of the packed parcel in kilograms as measured at the store packing station. Used for carrier rate calculation, dimensional weight billing reconciliation, and shipping cost allocation.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialFulfillmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Fulfillment Flag' ;
    rdfs:comment 'Indicates that the shipped_quantity is less than the ordered_quantity, resulting in a partial shipment. Triggers downstream processes such as backorder creation, customer notification, or alternate store sourcing.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the store associate completed the pick operation for this fulfillment request. Used to measure pick cycle time and store fulfillment throughput performance.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'The actual number of units physically picked from store inventory during the pick operation. May differ from ordered_quantity due to inventory discrepancies, shrinkage, or partial fulfillment scenarios.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The customer-facing delivery date committed at the time of order placement. Distinct from promised_ship_date; used for customer experience SLA tracking and carrier service level selection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'The committed date by which the store must ship the order to meet the customer-facing delivery promise. Used as the SLA (Service Level Agreement) target for OTIF measurement and store performance KPI reporting.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The date and time when the ship-from-store fulfillment request was created and assigned to the store, representing the principal business event time. Used for OTIF (On Time In Full) SLA measurement and store capacity planning. [BUSINESS_EVENT_TIMESTAMP category]' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retailValueAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Value Amount' ;
    rdfs:comment 'The total retail selling value (AUR × shipped_quantity) of the merchandise shipped in this fulfillment request, at the current selling price. Used for store-level revenue attribution, omnichannel sales reporting, and shrinkage risk assessment.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the parcel was tendered to the carrier and the shipment was confirmed. Used as the primary timestamp for OTIF (On Time In Full) compliance measurement against the SLA target.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'The actual number of units packed and handed to the carrier for shipment. Used in OTIF (On Time In Full) calculation and sell-through rate (STR) reporting at the store level.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Amount' ;
    rdfs:comment 'Actual carrier shipping cost incurred for this ship-from-store parcel in the transaction currency. Used for omnichannel fulfillment cost analysis, store P&L allocation, and COGS (Cost of Goods Sold) reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingLabelReference rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Reference' ;
    rdfs:comment 'Internal identifier for the shipping label generated by the WMS for this parcel. Used to reconcile label costs, void labels on cancellations, and audit label generation events in Manhattan Associates WMS.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeInventoryDeductedFlag rdf:type rdf:Property ;
    rdfs:label 'Store Inventory Deducted Flag' ;
    rdfs:comment 'Indicates whether the shipped_quantity has been successfully deducted from the store\'s on-hand inventory in the WMS and ERP systems. Used to detect inventory reconciliation failures and ensure ATS (Available to Sell) accuracy.' ;
    rdfs:domain ind:ShipFromStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'The carrier-assigned parcel tracking number generated at the time of shipment label creation. Used for customer shipment visibility, carrier claim management, and post-ship exception resolution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTransactionId rdf:type rdf:Property ;
    rdfs:label 'Return Transaction Id' ;
    rdfs:comment 'Primary key for return_transaction' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnTransaction .

ind:primaryReturnSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Sku Id' ;
    rdfs:comment 'Identifier of the specific Stock Keeping Unit (SKU) being returned. Enables return rate analysis by product, style, color, and size.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:processingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Processing Associate Id' ;
    rdfs:comment 'Identifier of the sales associate or cashier who processed the return transaction at the Point of Sale (POS). Used for associate performance tracking and loss prevention audit trails.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:returnShipmentId rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: In apparel fashion, in-store returns that require RTV (Return to Vendor) or DC consolidation generate an outbound shipment. Linking return_transaction to the resulting shipment enables RTV logistics t' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:daysSincePurchase rdf:type rdf:Property ;
    rdfs:label 'Days Since Purchase' ;
    rdfs:comment 'Number of calendar days elapsed between the original purchase date and the return transaction date. Used for return policy compliance validation and return window analytics. Stored as a business attribute to avoid repeated calculation in reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Routing decision for the physical merchandise after the return is processed. \'restock_floor\' returns item to selling floor inventory; \'rtv\' initiates Return to Vendor (RTV) workflow; \'damage_writeoff\' records as shrinkage/loss; \'outlet_transfer\' routes to outlet channel; \'quarantine\' holds for quality inspection or loss prevention review.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemConditionCode rdf:type rdf:Property ;
    rdfs:label 'Item Condition Code' ;
    rdfs:comment 'Condition assessment of the returned merchandise as evaluated by the processing associate at Point of Sale (POS). Drives disposition routing decisions: new_with_tags and new_without_tags are eligible for floor restock; worn and damaged route to outlet transfer or damage write-off; defective routes to Return to Vendor (RTV).' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsReversed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Reversed' ;
    rdfs:comment 'Number of loyalty program points deducted from the customer\'s account as a result of the return transaction. Reverses the points originally earned on the purchase.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalOrderChannel rdf:type rdf:Property ;
    rdfs:label 'Original Order Channel' ;
    rdfs:comment 'Sales channel through which the original purchase was made. Enables cross-channel return analysis (e.g., online purchase returned in-store) and Direct-to-Consumer (DTC) return rate reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Date' ;
    rdfs:comment 'Date on which the merchandise was originally purchased. Used to calculate days since purchase for return policy eligibility validation and warranty period determination.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTenderType rdf:type rdf:Property ;
    rdfs:label 'Original Tender Type' ;
    rdfs:comment 'Payment method used in the original purchase transaction. Required to determine refund eligibility and routing when refund_method is \'original_tender\'. Sourced from the original POS transaction record.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units of the Stock Keeping Unit (SKU) being returned in this transaction. Used for inventory restock calculations and return rate analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Receipt Presented Flag' ;
    rdfs:comment 'Indicates whether the customer presented the original purchase receipt at the time of return. Affects return policy eligibility, refund method options, and loss prevention risk scoring.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund is issued to the customer. \'original_tender\' returns funds to the original payment instrument; \'store_credit\' issues a store credit balance; \'exchange\' swaps for another item; \'gift_card\' issues a gift card; \'cash\' provides cash refund regardless of original tender.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnChannel rdf:type rdf:Property ;
    rdfs:label 'Return Channel' ;
    rdfs:comment 'Channel through which the return was initiated or processed. Supports omnichannel return analytics including Buy Online Pick Up In Store (BOPIS) returns and ship-from-store returns.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Return Discount Amount' ;
    rdfs:comment 'Total discount amount that was applied to the original purchase and is being reversed or credited back as part of the return. Ensures accurate net refund calculation.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Return Gross Amount' ;
    rdfs:comment 'Total gross merchandise value of the returned items before any adjustments, calculated as unit_retail_price multiplied by quantity_returned. Used for return rate and Sell-Through Rate (STR) impact analysis.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnNetAmount rdf:type rdf:Property ;
    rdfs:label 'Return Net Amount' ;
    rdfs:comment 'Net amount refunded to the customer after applying discounts and taxes. Equals return_gross_amount minus return_discount_amount plus return_tax_amount. Used for financial reconciliation and daily sales reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'Externally visible, human-readable return authorization number printed on the return receipt and used for customer-facing communication, warranty claims, and Return to Vendor (RTV) processing. Generated by SAP Customer Activity Repository (CAR).' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Return Policy Code' ;
    rdfs:comment 'Code identifying the specific return policy applied to this transaction (e.g., standard 30-day, extended holiday, loyalty member extended window, final sale). Determines return eligibility and refund method options.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text narrative provided by the associate or customer elaborating on the return reason beyond the standardized return_reason_code. Supports qualitative analysis and warranty claim documentation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return transaction workflow. \'pending\' indicates awaiting manager approval; \'approved\' indicates authorized but refund not yet issued; \'completed\' indicates fully processed with refund issued; \'rejected\' indicates denied by loss prevention or policy; \'voided\' indicates cancelled after initial entry.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Return Tax Amount' ;
    rdfs:comment 'Tax amount being refunded to the customer as part of the return transaction. Calculated based on the applicable tax jurisdiction and original tax paid.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Date and time when the return transaction was processed at the Point of Sale (POS) terminal. Principal business event timestamp for the return. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtvAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Rtv Authorization Number' ;
    rdfs:comment 'Vendor-issued Return to Vendor (RTV) authorization number assigned when disposition_code is \'rtv\'. Required for vendor credit processing and Electronic Data Interchange (EDI) transaction matching with the supplier.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialReturnerFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Returner Flag' ;
    rdfs:comment 'Indicates whether the customer associated with this return has been identified as a serial returner based on return frequency thresholds. Distinct from loss_prevention_flag which covers broader fraud patterns. Used for targeted loss prevention intervention.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeCreditVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Store Credit Voucher Number' ;
    rdfs:comment 'Voucher or store credit account number issued to the customer when refund_method is \'store_credit\'. Used for store credit redemption tracking and liability reporting.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Warranty claim reference number assigned when the return is associated with a product defect or warranty issue. Links the return to the warranty claim tracking workflow in SAP S/4HANA.' ;
    rdfs:domain ind:ReturnTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualMerchandisingPlanId rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the visual merchandising plan record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramId rdf:type rdf:Property ;
    rdfs:label 'Planogram Id' ;
    rdfs:comment 'Foreign key linking to store.planogram. Business justification: A visual merchandising plan is executed against a specific planogram — this is a core business relationship in apparel retail. The visual_merchandising_plan table currently stores planogram_document_u' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Planogram .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Foreign key linking to sourcing.sample_request. Business justification: VM teams in apparel request pre-production or salesman samples via sourcing\'s sample_request process to confirm display product for window and floor installations. VM planners must verify sample appro' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleRequest .

ind:vmAssociateId rdf:type rdf:Property ;
    rdfs:label 'Vm Associate Id' ;
    rdfs:comment 'Identifier of the visual merchandising associate or field representative responsible for executing and auditing this plan at the store level. References the workforce/associate master.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Calendar date on which the most recent visual merchandising compliance audit was conducted for this plan.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numeric compliance audit score (0.00–100.00) assigned during the most recent VM compliance audit. Reflects the degree to which the store has executed the plan per directive. Populated after merge with vm_compliance_check.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current status of the compliance audit for this visual merchandising plan. Drives corrective action workflows and escalation triggers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDisplayGuidelines rdf:type rdf:Property ;
    rdfs:label 'Collection Display Guidelines' ;
    rdfs:comment 'Narrative description of the seasonal collection display guidelines, including brand story, lifestyle theme, hero product callouts, and cross-category adjacency rules. Sourced from Centric PLM collection management.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorBlockingDirection rdf:type rdf:Property ;
    rdfs:label 'Color Blocking Direction' ;
    rdfs:comment 'Prescribed color sequencing strategy for merchandise presentation on fixtures and walls. Drives visual consistency across stores within the same cluster.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The hard deadline by which store teams must complete the floor set and submit photographic or audit evidence of compliance. May precede the effective_start_date to allow pre-opening setup.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The date by which the store team must resolve all non-compliant zones and resubmit evidence for re-audit. Drives escalation workflows in SAP Customer Activity Repository.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionNotes rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Notes' ;
    rdfs:comment 'Free-text description of the corrective actions prescribed by the VM field team or regional manager to remediate non-compliant zones identified during the audit.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a corrective action is required following the compliance audit. Set to True when audit_status is \'failed\' or non_compliant_zone_count exceeds the acceptable threshold.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureLayoutCode rdf:type rdf:Property ;
    rdfs:label 'Fixture Layout Code' ;
    rdfs:comment 'Code identifying the prescribed fixture configuration for the store floor (e.g., gondola arrangement, wall system, freestanding unit layout). References the fixture library in Oracle Retail or Centric PLM.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mannequinCount rdf:type rdf:Property ;
    rdfs:label 'Mannequin Count' ;
    rdfs:comment 'Total number of mannequins specified in the visual merchandising plan, including window and interior mannequins. Drives mannequin styling instruction tracking.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mannequinStylingNotes rdf:type rdf:Property ;
    rdfs:label 'Mannequin Styling Notes' ;
    rdfs:comment 'Free-text instructions for mannequin outfit composition, accessory pairings, pose direction, and wig/hair styling as specified by the VM creative team. Sourced from Centric PLM tech pack directives.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompliantZoneCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Zone Count' ;
    rdfs:comment 'Number of merchandising zones found to be non-compliant during the most recent audit. Used to prioritize corrective action and track improvement over audit cycles.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonCompliantZoneNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliant Zone Notes' ;
    rdfs:comment 'Free-text description of the specific zones, fixtures, or product placements found to be non-compliant during the audit, including the nature of each deviation from the plan directive.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Flag' ;
    rdfs:comment 'Indicates whether this visual merchandising plan includes omnichannel fulfillment zone directives such as BOPIS (Buy Online Pick Up In Store) or ship-from-store staging area setup.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the visual merchandising plan, used in communications with store teams, regional managers, and VM field representatives. Format: VM- followed by 4–20 alphanumeric characters.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Planogram Document Url' ;
    rdfs:comment 'URL or file path to the planogram PDF or digital asset stored in the content management system. Provides store teams direct access to the fixture layout and product placement diagrams.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPlacementZoneNotes rdf:type rdf:Property ;
    rdfs:label 'Product Placement Zone Notes' ;
    rdfs:comment 'Narrative instructions describing product placement by zone, wall, table, and window. Captures hero product positioning, color blocking direction, and adjacency rules for the floor set.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the visual merchandising plan was published and made available to store teams via the distribution channel (e.g., Oracle Retail portal, intranet).' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signageNotes rdf:type rdf:Property ;
    rdfs:label 'Signage Notes' ;
    rdfs:comment 'Free-text notes detailing specific signage placement instructions, size requirements, and messaging guidelines for this visual merchandising plan.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signageSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Signage Specification Code' ;
    rdfs:comment 'Code referencing the signage package specification (e.g., price tickets, lifestyle imagery, campaign headers, promotional banners) prescribed for this plan. Links to the signage asset library.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRunDisplayStandard rdf:type rdf:Property ;
    rdfs:label 'Size Run Display Standard' ;
    rdfs:comment 'Standard governing how size runs are displayed on the sales floor (e.g., full size run on fixture, key sizes only on mannequin). Aligns with Oracle Retail size curve and assortment planning.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Flag' ;
    rdfs:comment 'Indicates whether the visual merchandising plan materials (fixtures, signage, packaging) comply with the company\'s sustainability standards, including GOTS, BCI, and OEKO-TEX requirements for display materials.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowDisplayCount rdf:type rdf:Property ;
    rdfs:label 'Window Display Count' ;
    rdfs:comment 'Number of storefront window displays included in this visual merchandising plan. Used to track window execution compliance separately from interior floor sets.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCount rdf:type rdf:Property ;
    rdfs:label 'Zone Count' ;
    rdfs:comment 'Total number of distinct merchandising zones (e.g., front-of-store, mid-floor, back wall, window) covered by this visual merchandising plan.' ;
    rdfs:domain ind:VisualMerchandisingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markdownEventId rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Id' ;
    rdfs:comment 'Primary key for markdown_event' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarkdownEvent .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'Reference number or code from the authorization workflow that approved this markdown event. Typically sourced from Oracle Retail Price Management approval chain. Required for audit compliance and financial controls.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintainedMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Maintained Markup Pct' ;
    rdfs:comment 'Maintained Markup (MMU) percentage after applying the markdown, reflecting the actual margin retained post-markdown. Calculated as (markdown_price minus cost_price) / markdown_price. Critical for GMROI analysis and financial planning in Anaplan.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownEventNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Number' ;
    rdfs:comment 'Externally-known business identifier for the markdown event as assigned by Oracle Retail Price Management. Used for cross-system reference, audit trails, and reconciliation with source system records.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownLevel rdf:type rdf:Property ;
    rdfs:label 'Markdown Level' ;
    rdfs:comment 'Granularity at which the markdown event is defined and applied within the merchandise hierarchy. SKU-level markdowns are the most granular; department-level markdowns apply broadly across a category.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Pct' ;
    rdfs:comment 'Percentage reduction from the original retail price to the markdown price, expressed as a decimal (e.g., 0.3000 = 30%). Key metric for MD depth analysis, OTB reconciliation, and maintained markup (MMU) tracking.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReasonCode rdf:type rdf:Property ;
    rdfs:label 'Markdown Reason Code' ;
    rdfs:comment 'Business reason driving the markdown event. [ENUM-REF-CANDIDATE: clearance|seasonal|competitive|slow_seller|overstock|damage|end_of_line — promote to reference product]' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Classification of the markdown event by pricing permanence. Permanent markdowns reduce the ongoing retail price; temporary markdowns revert after the event period; promotional markdowns are tied to a campaign; clearance markdowns are end-of-lifecycle reductions.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'The original Manufacturer\'s Suggested Retail Price (MSRP) for the SKU prior to any markdown. Serves as the baseline for markdown percentage calculation and IMU/MMU analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Store-level on-hand inventory quantity for the SKU at the time the markdown event is created. Captured to support sell-through rate (STR) analysis, weeks of supply (WOS) calculation, and OTB reconciliation.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Applied Flag' ;
    rdfs:comment 'Indicates whether the markdown price has been successfully pushed to and activated at the store Point of Sale (POS) system (SAP Customer Activity Repository). True when the markdown is live at POS; False when pending or failed.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceLabelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Price Label Required Flag' ;
    rdfs:comment 'Indicates whether physical price label reprinting is required for store fixtures and merchandise as part of this markdown event. Drives visual merchandising and store operations task management.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidRepricedFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Repriced Flag' ;
    rdfs:comment 'Indicates whether RFID-tagged units for this SKU have been repriced and relabeled in the store as part of the markdown event execution. Supports RFID-enabled inventory accuracy and shrinkage control.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Native primary key or record identifier of this markdown event in the originating source system (Oracle Retail Price Management). Enables exact record traceability and idempotent Silver Layer upserts.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsSoldDuringEvent rdf:type rdf:Property ;
    rdfs:label 'Units Sold During Event' ;
    rdfs:comment 'Total number of units of the SKU sold at the markdown price during the event period. Populated at event close or via daily reconciliation from SAP Customer Activity Repository. Supports STR and markdown effectiveness analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmContactId rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Id' ;
    rdfs:comment 'Native contact identifier from Salesforce CRM (Salesforce Contact ID). Used to cross-reference the golden profile with the operational CRM record for campaign management, service interactions, and sales activity tracking.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:mergedIntoProfileId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Profile Id' ;
    rdfs:comment 'When profile_status = \'merged\', this field contains the profile_id of the surviving golden master profile into which this record was consolidated. Enables identity resolution audit trails and supports data subject access requests (DSAR) under GDPR Article 15 by tracing merged identities.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:adobeEcid rdf:type rdf:Property ;
    rdfs:label 'Adobe Ecid' ;
    rdfs:comment 'Adobe Experience Cloud Identity (ECID) assigned by Adobe Experience Platform (AEP) for cross-channel identity stitching, personalization, and real-time audience segmentation. Core identifier in the identity resolution graph.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Consumer\'s date of birth in yyyy-MM-dd format. Used for age verification, birthday loyalty reward triggers, demographic segmentation, and compliance with COPPA (Children\'s Online Privacy Protection Act) for consumers under 13.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the California consumer has exercised their right to opt out of the sale or sharing of personal information under CCPA. True = opted out of data sale/sharing; False = no opt-out exercised. Applicable to California residents. Must be honored within 15 business days per CCPA Section 1798.120.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the consumer\'s country of residence. Determines applicable privacy regulations (GDPR for EU residents, CCPA for California residents), tax jurisdiction, and eligible product catalog.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of the consumer profile by relationship type. Distinguishes Direct-to-Consumer (DTC) retail shoppers, Business-to-Business (B2B) wholesale account contacts, VIP/high-value consumers, employee accounts, brand influencers, and anonymous guest profiles. Drives differential pricing, service levels, and personalization strategies. [ENUM-REF-CANDIDATE: b2c_consumer|b2b_wholesale|vip|employee|influencer|anonymous — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Retention Flag' ;
    rdfs:comment 'Indicates whether the consumer has consented to extended data retention beyond the minimum operational period. True = extended retention consented; False = standard minimum retention applies. Supports GDPR Article 5(1)(e) storage limitation principle and data governance policy enforcement.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Consumer\'s primary email address used for Direct-to-Consumer (DTC) communications, e-commerce account login, loyalty enrollment, and marketing campaign delivery. Serves as a key deterministic identity resolution signal.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit consent to receive marketing emails. True = opted in; False = opted out or no consent given. Mandatory compliance flag for CAN-SPAM, GDPR Article 6, and CCPA opt-out requirements. Must be honored in all email campaign execution.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Consumer\'s legal family name (last name or surname) as captured at registration or point of sale. Combined with given_name to form the full display name for communications and identity resolution.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer has provided valid GDPR consent for personal data processing. True = consent granted; False = consent not granted or withdrawn. Applicable to EU/EEA residents. Mandatory for lawful data processing under GDPR Article 6(1)(a). Must be re-evaluated upon consent withdrawal.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Consumer\'s self-reported gender identity. Used for personalized product recommendations, size guidance, targeted marketing, and assortment planning analytics. Collected with explicit consent per GDPR and CCPA requirements.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'Consumer\'s legal given name (first name) as captured at registration or point of sale. Used for personalized communications, loyalty program enrollment, and CRM record matching.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Numeric confidence score (0.0000 to 1.0000) representing the certainty of the identity resolution linking multiple cross-channel identifiers to this golden profile. Higher scores indicate stronger deterministic signal overlap. Used to prioritize profile merge decisions and flag low-confidence profiles for manual review in Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Resolution Method' ;
    rdfs:comment 'The method used to resolve and stitch cross-channel identifiers into this golden profile. \'deterministic\' uses exact-match signals (email, loyalty card); \'probabilistic\' uses statistical inference (device fingerprint, behavioral signals); \'hybrid\' combines both; \'manual\' indicates agent-assisted resolution. Sourced from Adobe Experience Platform Identity Service.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s identity has been verified through email confirmation, phone OTP, or document verification. True = identity verified; False = unverified or pending. Verified profiles receive higher identity confidence scores and are eligible for full loyalty benefits and personalization features.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyCardNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Number' ;
    rdfs:comment 'Physical or digital loyalty program card number issued to the consumer. Used as a cross-channel identifier linking in-store POS transactions, e-commerce orders, and loyalty reward accruals to the golden profile.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the consumer enrolled in the brand\'s loyalty program. Used to calculate loyalty tenure, anniversary reward triggers, and cohort-based loyalty program performance analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current unredeemed loyalty points balance for the consumer. Represents accrued reward currency from purchases, referrals, and engagement activities. Used for redemption eligibility checks, tier qualification calculations, and loyalty liability reporting.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) survey response from the consumer, ranging from 0 (detractor) to 10 (promoter). Used to classify consumers as Promoters (9-10), Passives (7-8), or Detractors (0-6) for brand health tracking and CRM segmentation in Salesforce.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent Net Promoter Score (NPS) survey response was recorded. Used to assess recency of sentiment data and determine eligibility for follow-up NPS surveys based on survey frequency rules.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Consumer\'s primary contact phone number in E.164 international format. Used for SMS marketing opt-ins, order notifications, loyalty communications, and as a probabilistic identity resolution signal.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posCustomerCode rdf:type rdf:Property ;
    rdfs:label 'Pos Customer Code' ;
    rdfs:comment 'Customer identifier assigned within the SAP Customer Activity Repository (CAR) POS system for in-store transaction linkage. Enables reconciliation of retail store purchases to the golden consumer profile.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Consumer\'s preferred communication language expressed as an IETF BCP 47 language tag (e.g., en-US, fr-FR, de-DE). Drives localized content delivery, email template selection, and customer service routing in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShoeSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Shoe Size' ;
    rdfs:comment 'Consumer\'s self-reported or purchase-history-derived preferred footwear size including size system notation (e.g., US 10, EU 44, UK 9). Used for footwear product recommendations, inventory allocation, and size curve analytics in Oracle Retail Merchandising System.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSizeBottom rdf:type rdf:Property ;
    rdfs:label 'Preferred Size Bottom' ;
    rdfs:comment 'Consumer\'s self-reported or algorithmically inferred preferred size for bottoms/lower body apparel (e.g., waist/inseam measurements or S/M/L sizing). Used for personalized product recommendations, size-based filtering, and returns reduction analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSizeTop rdf:type rdf:Property ;
    rdfs:label 'Preferred Size Top' ;
    rdfs:comment 'Consumer\'s self-reported or algorithmically inferred preferred size for tops/upper body apparel (e.g., XS, S, M, L, XL, XXL, or numeric sizing). Used for personalized product recommendations, size-based filtering, and fit analytics in Salesforce Commerce Cloud and Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the consumer profile record. \'active\' indicates a verified, engaged consumer; \'merged\' indicates the record has been consolidated into a master golden profile; \'pending_verification\' indicates email or identity not yet confirmed. Drives CRM suppression lists and data governance workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the consumer has enabled push notifications on their registered mobile device(s) for the brand\'s mobile application. True = enabled; False = disabled. Drives mobile engagement campaign eligibility in Adobe Experience Platform.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'The operational system of record from which this consumer profile was originally created or first ingested. Identifies whether the profile originated from Salesforce Commerce Cloud (e-commerce), Adobe Experience Platform (digital), SAP Customer Activity Repository (POS/in-store), mobile app, or manual entry. Critical for data lineage and source system reconciliation. [ENUM-REF-CANDIDATE: salesforce_commerce_cloud|adobe_aep|sap_car_pos|mobile_app|in_store_tablet|wholesale_portal|manual_entry — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit consent to receive SMS/text message marketing communications. True = opted in; False = opted out. Required for TCPA (Telephone Consumer Protection Act) compliance in the US and equivalent regulations in other jurisdictions.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the wholesale account record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:parentAccountWholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Wholesale Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent wholesale account record. Supports parent-child hierarchy modeling for franchise networks, buying groups, and corporate group structures. Null for top-level accounts.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor. Business justification: Wholesale accounts (retailers, distributors) often have preferred vendor relationships for private label manufacturing, co-branding, or exclusive production agreements. Critical for vendor allocation,' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known alphanumeric account number assigned to the wholesale buyer in the ERP system (SAP S/4HANA SD Customer Number). Used as the primary business identifier on purchase orders, invoices, and EDI transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the wholesale account. Controls order acceptance, credit extension, and EDI transaction processing. \'On Hold\' blocks new purchase orders pending credit review.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier classification of the wholesale account reflecting revenue contribution, strategic importance, and service priority. Platinum and Gold accounts receive dedicated sales reps, priority allocation, and preferential credit terms.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the wholesale account by channel and business model. Drives assortment planning, pricing strategy, and service level agreements. [ENUM-REF-CANDIDATE: department_store|specialty_retailer|boutique|online_retailer|franchise|buying_group|distributor|corporate_group — promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for the wholesale account\'s billing location. Used on invoices, credit documents, and financial correspondence.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and geographic sales reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the wholesale account\'s billing address. Drives VAT/GST applicability, currency assignment, and cross-border trade compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the wholesale account\'s billing address. Used for tax jurisdiction mapping, freight zone calculation, and geographic analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Buying Authority Level' ;
    rdfs:comment 'Level of purchasing authority held by the primary contact at the wholesale account. \'Full\' = can commit to purchase orders independently; \'Limited\' = requires co-approval; \'None\' = informational contact only. Used to ensure correct approval routing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the current wholesale trading agreement. Null indicates an open-ended agreement. Used to trigger contract renewal workflows and prevent order acceptance on expired terms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current wholesale trading agreement or master service agreement with this account. Defines the period during which agreed pricing, MOQ, and credit terms are binding.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance approved for this wholesale account in the account\'s transaction currency. Enforced by SAP S/4HANA FI credit management to block orders when exceeded.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit risk rating assigned to the wholesale account. Informs credit limit setting, payment term negotiation, and order hold decisions. Aligned with Dun & Bradstreet or internal credit scoring models. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|D — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) identifier uniquely identifying the legal business entity globally. Used for credit risk assessment, EDI partner setup, and supplier onboarding.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the wholesale account is set up for Electronic Data Interchange (EDI) transaction processing (purchase orders, invoices, advance ship notices). True = EDI-enabled; False = manual/portal-based ordering.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Code' ;
    rdfs:comment 'EDI interchange qualifier and sender/receiver ID assigned to the wholesale account for EDI transaction routing. Required for X12 850 (PO), 810 (Invoice), and 856 (ASN) message exchange.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibility between Apparel Fashion and the wholesale account. FOB and DDP are most common in apparel wholesale. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySegment rdf:type rdf:Property ;
    rdfs:label 'Industry Segment' ;
    rdfs:comment 'Primary apparel industry segment the wholesale account operates in. Used for targeted collection planning, assortment curation, and marketing alignment. [ENUM-REF-CANDIDATE: athletic|lifestyle|luxury|outdoor|workwear|childrenswear|accessories|footwear — promote to reference product]' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the wholesale account as filed with the relevant government authority. Used for contracts, invoicing, and regulatory compliance. Sourced from SAP S/4HANA SD Customer Master.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnits rdf:type rdf:Property ;
    rdfs:label 'Moq Units' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in units agreed with this wholesale account per purchase order or per style. Enforced during order entry to ensure production viability and margin targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the wholesale account was formally onboarded and activated for trading. Used to calculate account tenure, cohort analysis, and anniversary-based relationship milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key (e.g., NET30, NET60, 2/10NET30) defining the due date and early payment discount structure for invoices issued to this wholesale account. Directly impacts cash flow forecasting and DSO metrics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Comm Channel' ;
    rdfs:comment 'The wholesale account\'s preferred channel for receiving business communications including order confirmations, collection previews, and account updates. Drives outreach strategy in Salesforce and Adobe Experience Platform.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactDepartment rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Department' ;
    rdfs:comment 'Department of the primary contact person within the wholesale account organization. Used to route communications to the correct functional team (e.g., buying team for assortment decisions, logistics for shipment coordination). [ENUM-REF-CANDIDATE: buying|merchandising|logistics|finance|marketing|operations|executive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact person at the wholesale account. Used for order confirmations, collection previews, and account communications. Mapped to Salesforce Contact Email field.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct business phone number of the primary contact person at the wholesale account. Used for urgent order communications, sales calls, and account management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the wholesale account (e.g., Head Buyer, VP Merchandising, Procurement Director). Used to assess buying authority and route communications appropriately.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current health and strategic status of the commercial relationship with the wholesale account. \'At Risk\' triggers proactive account management intervention. Used in CRM pipeline and NPS-driven retention programs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Indicates whether the wholesale account requires Radio Frequency Identification (RFID) tagging on shipped merchandise for inventory tracking and compliance with the account\'s receiving standards.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or channel-based sales territory to which this wholesale account is assigned. Used for quota allocation, territory performance reporting, and sales rep assignment.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Unique identifier of the corresponding Account object in Salesforce CRM. Enables bi-directional synchronization between the data lakehouse and Salesforce for sales pipeline, opportunity, and contact management.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the US, VAT registration number in the EU) for the wholesale account. Required for invoicing, customs documentation, and regulatory reporting.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or \'doing business as\' (DBA) name of the wholesale account, which may differ from the legal entity name. Used for commercial communications and brand recognition.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the contact person record within the Apparel Fashion customer domain. Primary key for the contact data product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this contact has exercised their CCPA right to opt out of the sale or sharing of their personal information. When True, the contact\'s data must not be sold or shared with third parties per California law.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Functional classification of the contact\'s role in the B2B relationship. Buyer contacts are involved in purchasing decisions; merchandiser contacts manage product assortment; finance contacts handle invoicing and payments; logistics contacts manage shipping and fulfillment. [ENUM-REF-CANDIDATE: buyer|merchandiser|finance|logistics|executive|legal|operations|other — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the originating system or method through which this contact record was created or last updated. Supports data lineage, quality assessment, and reconciliation between Salesforce CRM, Adobe Experience Platform, and the Databricks lakehouse silver layer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business department or functional area within the wholesale account or enterprise partner organization where the contact works (e.g., Buying, Merchandising, Finance, Logistics). Supports targeted B2B communication routing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which GDPR consent was most recently granted or withdrawn by this contact. Required for regulatory audit trails demonstrating lawful basis for data processing under GDPR Article 7.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this contact\'s personal data for marketing and communication purposes. \'granted\' indicates explicit consent; \'withdrawn\' triggers suppression from marketing campaigns; \'not_applicable\' for contacts outside GDPR jurisdiction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive invoices, payment reminders, and financial communications for the associated wholesale account. Supports accounts receivable workflows in SAP S/4HANA FI/CO module.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has final decision-making authority for purchasing, contract signing, or strategic partnership agreements. Used by sales and account management teams to prioritize engagement and escalation paths.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary point of contact for the associated wholesale account or enterprise partnership. Only one contact per account should be flagged as primary. Used to route default communications and account management activities.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShippingContact rdf:type rdf:Property ;
    rdfs:label 'Is Shipping Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive shipping notifications, delivery confirmations, and logistics communications. Supports OTIF tracking and 3PL coordination for wholesale order fulfillment.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact person within their organization (e.g., Head Buyer, VP Merchandising, Procurement Manager). Critical for understanding the contact\'s role in the B2B purchasing process.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent business interaction with this contact, including calls, emails, meetings, or trade show engagements. Used by account managers to monitor relationship health and identify contacts requiring re-engagement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact. Used by account managers and sales teams for relationship intelligence, pre-meeting research, and social selling in B2B wholesale and enterprise partnership contexts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in conjunction with mailing_street for physical correspondence and geographic segmentation of wholesale accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address country (e.g., USA, GBR, DEU). Used for international shipping, customs documentation, and regional account management assignment.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address line for the contact\'s mailing address. Used for sending physical samples, lookbooks, seasonal collection materials, and formal correspondence to wholesale buyers and enterprise partners.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact person in E.164 international format. Supports SMS notifications, WhatsApp business communications, and urgent B2B outreach for wholesale account management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowupDate rdf:type rdf:Property ;
    rdfs:label 'Next Followup Date' ;
    rdfs:comment 'Scheduled date for the next planned follow-up interaction with this contact. Used by account managers and sales representatives to manage their B2B outreach cadence and ensure timely engagement with wholesale buyers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred channel for business communications. Drives outreach strategy for account managers and sales representatives managing wholesale and enterprise partnerships. Supports personalization in CRM workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'External identifier from the Salesforce CRM system corresponding to the Contact object. Used for cross-system reconciliation and data lineage between the lakehouse silver layer and Salesforce.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or salutation prefix for the contact person (e.g., Mr., Ms., Dr.). Used in formal written and email correspondence with wholesale buyers and enterprise partners.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressSource rdf:type rdf:Property ;
    rdfs:label 'Address Source' ;
    rdfs:comment 'The originating channel or system through which this address was captured. Supports data lineage tracking and quality scoring. EDI-sourced addresses originate from wholesale partner Electronic Data Interchange transactions; POS addresses from SAP Customer Activity Repository in-store capture. [ENUM-REF-CANDIDATE: ecommerce|pos|crm|edi|manual|import|wholesale_portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Functional classification of the address indicating its business purpose. Billing addresses are used for invoicing and payment processing; shipping addresses for DTC order fulfillment and wholesale delivery routing; store_pickup for BOPIS (Buy Online Pick Up In Store) orders; warehouse for distribution center addresses; return for RTV (Return to Vendor) and consumer return processing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRouteCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Route Code' ;
    rdfs:comment 'USPS carrier route code assigned to the address, identifying the specific mail carrier delivery route. Used for bulk mail rate optimization, direct mail marketing campaigns, and last-mile delivery planning.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the country_code. Stored for display and reporting purposes to avoid repeated lookups against reference data.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Composite quality score (0.00–100.00) assigned to the address record based on validation status, standardization, geocoding accuracy, and completeness. Used to prioritize address cleansing campaigns and filter high-confidence addresses for marketing and fulfillment operations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Free-text special instructions for carriers and fulfillment teams regarding delivery at this address (e.g., \'Leave at reception\', \'Dock 3 only\', \'Requires appointment\', \'Signature required\'). Passed to Manhattan Associates WMS and 3PL partners during shipment creation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Administrative district, county, or sub-regional area of the address. Used for tax jurisdiction determination (county-level sales tax), regional sales territory assignment, and wholesale distribution zone mapping.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpvConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation Code' ;
    rdfs:comment 'USPS Delivery Point Validation (DPV) confirmation code indicating the deliverability of the address. Y = confirmed deliverable; S = confirmed with secondary number missing; D = confirmed primary but secondary not confirmed; N = not confirmed. Used to assess address quality and reduce undeliverable-as-addressed (UAA) mail.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this address record is considered valid and active for business use. Supports bi-temporal data modeling for address history tracking, enabling accurate reconstruction of customer address state at any point in time for order dispute resolution and compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date until which this address record is valid. Null indicates the address is currently active with no planned expiry. Used for managing temporary addresses (e.g., seasonal warehouse locations, pop-up store addresses) and tracking address change history.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAddressCode rdf:type rdf:Property ;
    rdfs:label 'External Address Code' ;
    rdfs:comment 'Address identifier from the originating source system (e.g., Salesforce Commerce Cloud address ID, SAP S/4HANA partner address number, Adobe Experience Platform profile address key). Enables cross-system reconciliation and deduplication during data integration.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoordinates assigned to this address. Rooftop indicates exact parcel-level accuracy; range_interpolated is street-level; geometric_center is centroid of a region; approximate is low-precision. Drives confidence scoring for proximity-based analytics and last-mile routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default billing address used for invoice generation and payment processing. Only one address per customer should have this flag set to true at any given time.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the customer\'s default shipping address for DTC order fulfillment. Pre-populated at checkout to streamline the purchase experience. Only one address per customer should have this flag set to true.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Customer-assigned friendly label for the address (e.g., \'Home\', \'Office\', \'NYC Warehouse\', \'LA Showroom\'). Displayed in the customer\'s address book in the DTC e-commerce storefront and CRM to facilitate address selection at checkout.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'Primary street address line including street number, street name, and directional indicators. Required field for all address records used in order fulfillment, wholesale delivery routing, and store operations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Secondary address line for suite, apartment, unit, floor, building, or care-of information. Optional field used to capture additional location detail for B2C consumers and B2B wholesale accounts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line3' ;
    rdfs:comment 'Tertiary address line used for international addresses requiring additional locality, district, or neighborhood detail. Primarily applicable for wholesale accounts in markets with complex addressing conventions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxFlag rdf:type rdf:Property ;
    rdfs:label 'Po Box Flag' ;
    rdfs:comment 'Indicates whether the address is a Post Office (PO) Box. PO Box addresses are ineligible for certain carrier services (e.g., UPS, FedEx ground) and require USPS routing. Used in carrier selection logic during order fulfillment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual or business entity designated to receive deliveries at this address. May differ from the account holder name for gift shipments, B2B receiving departments, or wholesale distribution contacts.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Flag' ;
    rdfs:comment 'Indicates whether the address is classified as residential (True) or commercial/business (False). Carrier surcharges differ between residential and commercial deliveries; this flag drives accurate shipping cost calculation and carrier rate shopping.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizedFlag rdf:type rdf:Property ;
    rdfs:label 'Standardized Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal authority format (e.g., USPS CASS normalization, Canada Post, Royal Mail PAF). Standardized addresses improve carrier label accuracy and reduce failed delivery rates.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the address location (e.g., \'America/New_York\', \'Europe/London\'). Used for scheduling delivery windows, store pickup time slots, and localizing customer communications in marketing campaigns.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for address quality management and vendor SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed deliveries and carrier surcharges. Invalid addresses are flagged for customer outreach before order fulfillment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is required based on data freshness policies and carrier compliance requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Partner Vendor Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor. Business justification: Apparel loyalty programs frequently operate Partner Earn Programs where customers earn points through co-branded vendor partnerships (e.g., co-branded credit cards, partner retail earn). The loyalty_p' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:pointsLiabilityGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Points Liability Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Under IFRS 15 / ASC 606, loyalty points represent deferred revenue liability posted to a specific GL account. Apparel retailers must link each loyalty program to its GL account for points liability ac' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:annualFee rdf:type rdf:Property ;
    rdfs:label 'Annual Fee' ;
    rdfs:comment 'Recurring annual fee charged to maintain active membership in the loyalty program. A value of 0.00 indicates no annual fee. Used for subscription-based program revenue recognition.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:birthdayBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Birthday Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to a member during their birthday month or on their birthday date as a program benefit. A value of 0 indicates no birthday bonus.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOutSupported rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Supported' ;
    rdfs:comment 'Indicates whether this loyalty program supports the California Consumer Privacy Act (CCPA) right to opt out of the sale of personal information, applicable to members in California.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvSegmentEligible rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment Eligible' ;
    rdfs:comment 'Indicates whether members enrolled in this program are included in Customer Lifetime Value (CLTV) segmentation models run through Adobe Experience Platform for personalization and targeted marketing.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes identifying the geographic markets where this loyalty program is available for enrollment (e.g., \'USA,CAN,GBR\'). Null indicates global availability.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentFee rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee' ;
    rdfs:comment 'One-time fee charged to a customer upon joining the loyalty program. A value of 0.00 indicates the program is free to join. Applicable primarily to subscription-type programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether explicit GDPR consent must be captured from members at enrollment for this program, applicable to programs operating in EU jurisdictions. Drives consent management workflows.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDtcEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dtc Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points through the Direct-to-Consumer (DTC) channel, including brand-owned retail stores and owned digital storefronts.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points through the e-commerce channel, including the brand\'s online store and digital marketplace integrations.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartnerEarnEligible rdf:type rdf:Property ;
    rdfs:label 'Is Partner Earn Eligible' ;
    rdfs:comment 'Indicates whether members can earn loyalty points through purchases or activities with third-party partner brands or co-branded programs affiliated with Apparel Fashion.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetailStoreEligible rdf:type rdf:Property ;
    rdfs:label 'Is Retail Store Eligible' ;
    rdfs:comment 'Indicates whether members can earn and redeem points at physical retail store locations via POS transactions tracked through SAP Customer Activity Repository.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWholesaleEligible rdf:type rdf:Property ;
    rdfs:label 'Is Wholesale Eligible' ;
    rdfs:comment 'Indicates whether B2B wholesale account holders are eligible to participate in this loyalty program and earn rewards on wholesale purchase volumes.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Calendar date on which the loyalty program became publicly available and open for customer enrollment. Used for program age calculations and anniversary promotions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Max Points Balance' ;
    rdfs:comment 'Maximum cumulative points balance a member may hold at any time. Enforces program liability ceiling and prevents excessive point accumulation. Null indicates no cap.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Points Per Transaction' ;
    rdfs:comment 'Cap on the number of loyalty points that can be earned in a single transaction. Prevents abuse of promotional multipliers and controls program liability exposure per event.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nps Tracking Enabled' ;
    rdfs:comment 'Indicates whether Net Promoter Score (NPS) surveys are triggered for members of this loyalty program to measure customer satisfaction and advocacy. Supports CRM and brand management analytics.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Indicates whether Adobe Experience Platform personalization and AI-driven offer targeting is activated for members of this loyalty program, enabling tailored product recommendations and promotions.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsEarningRate rdf:type rdf:Property ;
    rdfs:label 'Points Earning Rate' ;
    rdfs:comment 'Base number of loyalty points awarded per unit of currency spent (e.g., 1.0000 point per USD spent). Tier-specific multipliers may override this base rate at the enrollment level.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Months' ;
    rdfs:comment 'Number of months after which unspent loyalty points expire from a member\'s account if no qualifying activity occurs. A value of 0 or null indicates points do not expire.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Rule governing when points expire: rolling resets the expiry window on each qualifying activity; fixed_anniversary expires points on the member\'s enrollment anniversary; no_expiry means points never expire; calendar_year expires all points at year-end.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsMonetaryValue rdf:type rdf:Property ;
    rdfs:label 'Points Monetary Value' ;
    rdfs:comment 'Monetary value assigned to a single loyalty point at redemption (e.g., 0.010000 USD per point). Used to calculate reward discount amounts and program liability on the balance sheet.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsRedemptionThreshold rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Threshold' ;
    rdfs:comment 'Minimum accumulated points balance a member must hold before they are eligible to redeem points for rewards or discounts. Enforces program economics and prevents micro-redemptions.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the loyalty program across all channels and systems (e.g., \'AF_REWARDS_2024\'). Used in EDI, CRM, and POS integrations as the canonical business identifier.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Full marketing and operational description of the loyalty program, including its value proposition, key benefits, and eligibility criteria as communicated to customers and internal stakeholders.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable marketing name of the loyalty program as presented to customers across DTC, retail, and e-commerce channels (e.g., \'Apparel Fashion Rewards\').' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty program. Active programs accept new enrollments and transactions; draft programs are in configuration; suspended programs are temporarily halted; retired programs are closed to new activity.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure. Points-based programs award redeemable points per transaction; tiered programs unlock benefits at spend thresholds; cashback returns a percentage of spend; subscription requires a membership fee; hybrid combines multiple mechanics.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIncrement rdf:type rdf:Property ;
    rdfs:label 'Redemption Increment' ;
    rdfs:comment 'Minimum unit of points that can be redeemed in a single transaction (e.g., points must be redeemed in multiples of 100). Ensures redemption amounts align with reward value denominations.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points' ;
    rdfs:comment 'Number of loyalty points awarded to an existing member when they successfully refer a new customer who enrolls in the program. Supports member acquisition through word-of-mouth incentives.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Terms Effective Date' ;
    rdfs:comment 'Date on which the current version of the loyalty program terms and conditions became legally effective. Members enrolled before this date may require re-consent notification.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the loyalty program\'s terms and conditions document currently in effect (e.g., \'v2.1\'). Used to track member consent to specific T&C versions and manage regulatory compliance.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Total number of distinct membership tiers defined within this loyalty program (e.g., 3 for Silver, Gold, Platinum). Drives tier configuration and progression rule setup.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Metric' ;
    rdfs:comment 'The primary metric used to determine a member\'s tier eligibility and progression (e.g., cumulative spend amount, total points earned, number of transactions, or units purchased within the qualification period).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Period Months' ;
    rdfs:comment 'Rolling or fixed window in months over which a member\'s qualifying activity is measured for tier assignment or maintenance (e.g., 12 months for annual tier review).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welcomeBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Welcome Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to a new member upon successful enrollment in the program. A value of 0 indicates no welcome bonus is offered.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each loyalty program enrollment record. One record per customer-program combination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyEnrollment .

ind:acquisitionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Loyalty enrollments are frequently driven by specific acquisition campaigns (sign-up bonuses, enrollment promotions). Essential for calculating campaign-specific CAC, measuring enrollment campaign eff' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:enrollingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Enrolling Associate Id' ;
    rdfs:comment 'Foreign key linking to store.associate. Business justification: Loyalty enrollments in apparel retail are facilitated by store associates who earn incentives for enrollments. No associate FK exists on loyalty_enrollment. Associate enrollment attribution is require' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:enrollmentEventId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Id' ;
    rdfs:comment 'Foreign key linking to marketing.event. Business justification: Event-driven loyalty enrollment attribution: pop-ups, trunk shows, and brand events drive loyalty sign-ups. This FK attributes enrollments to the specific event for event ROI measurement, enrollment c' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:enrollmentSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Sales Order Id' ;
    rdfs:comment 'Foreign key linking to order.sales_order. Business justification: In apparel loyalty programs, enrollment is frequently triggered by a qualifying purchase. Linking enrollment to the originating sales_order supports enrollment attribution reporting, first-purchase lo' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:primaryLoyaltyProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Profile Id' ;
    rdfs:comment 'Reference to the customer who is enrolled in the loyalty program. Links to the customer master record in the CRM/CDP.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:welcomePromoCodeId rdf:type rdf:Property ;
    rdfs:label 'Welcome Promo Code Id' ;
    rdfs:comment 'Foreign key linking to marketing.promo_code. Business justification: Loyalty enrollment welcome promo assignment: when a customer enrolls in a loyalty program, a welcome promo code is issued. This FK links the enrollment to the specific promo code for redemption tracki' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'The Direct-to-Consumer (DTC) or wholesale channel through which the customer enrolled in the loyalty program. Supports channel attribution and omnichannel analytics.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the customer formally enrolled in the loyalty program. Used for anniversary calculations, tenure segmentation, and cohort analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally visible, human-readable enrollment reference number used in customer communications, receipts, and CRM lookups. Follows the format LYL-XXXXXXXXXX.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty enrollment. Active = earning and redeeming; Suspended = temporarily blocked; Terminated = permanently closed; Pending = awaiting verification; Frozen = points locked pending investigation.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent qualifying loyalty activity (earn, redeem, or bonus event) by this member. Used to identify inactive members, trigger re-engagement campaigns, and enforce inactivity-based points expiry policies.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase transaction that generated a loyalty points earn event. Distinct from last_activity_date which may include non-purchase activities such as profile updates or bonus events.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total cumulative points earned by the customer since enrollment inception, including all earn, bonus, and adjustment credits. Used for Customer Lifetime Value (CLTV) analysis and VIP qualification.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Total cumulative points that have expired due to inactivity or program policy since enrollment inception. Used for program liability management and customer re-engagement targeting.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total cumulative points redeemed by the customer since enrollment inception. Used to measure program engagement and redemption rate analytics.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCardNumber rdf:type rdf:Property ;
    rdfs:label 'Member Card Number' ;
    rdfs:comment 'Physical or virtual loyalty card number issued to the member. Used for in-store Point of Sale (POS) identification, RFID scanning, and customer service lookups. Classified as confidential PII identifier.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCardType rdf:type rdf:Property ;
    rdfs:label 'Member Card Type' ;
    rdfs:comment 'Format of the loyalty card issued to the member. Physical = plastic card; Virtual = app-based barcode; RFID = contactless chip card; Digital Wallet = Apple/Google Wallet pass.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty-related email communications including points statements, tier upgrade notifications, and exclusive member offers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the member has opted in to receive mobile push notifications for loyalty events such as points earned, tier changes, and reward availability.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty-related SMS/text message communications including points alerts and promotional offers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pendingPoints rdf:type rdf:Property ;
    rdfs:label 'Pending Points' ;
    rdfs:comment 'Points earned from recent transactions that are not yet confirmed as redeemable, typically held during a return window or fraud review period before being credited to the redeemable balance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current redeemable points balance available to the customer for redemption against purchases, rewards, or experiences. Reflects all earned, redeemed, adjusted, and expired points.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'Date on which the current redeemable points balance (or the oldest tranche of points) will expire if no qualifying activity occurs. Drives expiry notification campaigns.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralSourceCode rdf:type rdf:Property ;
    rdfs:label 'Referral Source Code' ;
    rdfs:comment 'Campaign or referral code used at enrollment to attribute the sign-up to a specific marketing campaign, influencer, or existing member referral. Supports Customer Acquisition Cost (CAC) and campaign ROI analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemMemberCode rdf:type rdf:Property ;
    rdfs:label 'Source System Member Code' ;
    rdfs:comment 'The member or enrollment identifier as recorded in the originating source system (e.g., AEP profile ID, Salesforce Contact ID). Used for cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the loyalty enrollment was terminated. Used for compliance reporting, program analytics, and customer win-back strategy.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the customer\'s current tier status became effective. Used to calculate tier tenure and determine when the next tier review is due.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date on which the customer\'s current tier qualification expires and is subject to re-evaluation based on qualifying spend or activity. Null for lifetime tiers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Spend' ;
    rdfs:comment 'Cumulative qualifying spend amount (in program currency) accumulated by the customer within the current tier qualification period. Compared against tier thresholds to determine tier status.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent segment when this segment is a sub-segment or refinement of a broader segment hierarchy (e.g., \'High-Value Female Loyalists\' as a child of \'High-Value Loyalists\'). Supports hierarchical segment structures for nested targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:ageBandMax rdf:type rdf:Property ;
    rdfs:label 'Age Band Max' ;
    rdfs:comment 'Maximum age (in years) of the target demographic for this segment. Used in demographic segmentation to define the upper bound of the age range for personalization and marketing targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageBandMin rdf:type rdf:Property ;
    rdfs:label 'Age Band Min' ;
    rdfs:comment 'Minimum age (in years) of the target demographic for this segment. Used in demographic segmentation to define the lower bound of the age range for personalization and marketing targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Usd' ;
    rdfs:comment 'Planned marketing spend budget allocated to campaigns targeting this segment, expressed in USD. Used for marketing financial planning in Anaplan and ROI measurement. Classified as confidential as it reflects internal budget allocation strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Status' ;
    rdfs:comment 'Current synchronization status of this segment to Salesforce CRM for campaign activation. Synced indicates the segment definition and membership are current in CRM; pending indicates a sync is queued; failed indicates a sync error requiring investigation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crm Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of this segment to Salesforce CRM. Used to monitor data freshness and SLA compliance for campaign activation pipelines.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerClass rdf:type rdf:Property ;
    rdfs:label 'Customer Class' ;
    rdfs:comment 'Indicates whether the segment targets B2C (individual consumers), B2B (wholesale accounts), household-level groupings, or enterprise partnerships. Drives different activation logic and CRM workflows in Salesforce and Adobe Experience Platform.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Data Consent Required' ;
    rdfs:comment 'Indicates whether activation of this segment requires verified customer consent under GDPR or CCPA regulations. When true, only profiles with explicit consent records in Adobe Experience Platform may be included in segment activations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Data Sensitivity Level' ;
    rdfs:comment 'Data classification level assigned to this segment definition based on the sensitivity of its qualifying criteria and the customer data it processes. Restricted segments may involve sensitive demographic or behavioral data requiring heightened access controls per GDPR and CCPA.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Human-readable description of the business rules and logic used to qualify customers into this segment (e.g., \'Customers with 3+ purchases in last 90 days, AOV > $150, active loyalty member\'). Serves as the business specification for technical implementation in Adobe Experience Platform.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionExpression rdf:type rdf:Property ;
    rdfs:label 'Definition Expression' ;
    rdfs:comment 'Structured query expression or rule set (e.g., PQL — Profile Query Language from Adobe Experience Platform) that technically defines segment membership criteria. Enables automated re-evaluation and sync to CRM activation systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Estimated count of customer profiles qualifying for this segment at the last evaluation run. Used for campaign reach planning, budget allocation, and marketing ROI forecasting. Sourced from Adobe Experience Platform segment evaluation output.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'How frequently the segment membership is re-evaluated and refreshed. Real-time segments update continuously via streaming; daily/weekly/monthly segments are refreshed on a scheduled batch cadence. Impacts campaign activation timeliness and system resource planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Evaluation Method' ;
    rdfs:comment 'Method by which Adobe Experience Platform evaluates segment membership. Batch evaluation runs on a scheduled cadence; streaming evaluation updates membership in near-real-time as profile events occur; edge evaluation enables on-device personalization at the point of interaction.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The customer lifecycle stage this segment targets. Acquisition segments target new prospects; activation targets first-time buyers; retention targets active loyal customers; reactivation targets declining customers; winback targets lapsed customers. Aligns with CRM and CLTV (Customer Lifetime Value) strategy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Linked' ;
    rdfs:comment 'Indicates whether this segment is linked to a loyalty program tier or reward structure. Loyalty-linked segments receive differentiated offers, early access to collections, and exclusive promotions managed through Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Target Flag' ;
    rdfs:comment 'Indicates whether this segment is designated as a target population for NPS (Net Promoter Score) survey distribution. NPS-targeted segments are used to measure customer satisfaction and brand loyalty across DTC and wholesale channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerFunction rdf:type rdf:Property ;
    rdfs:label 'Owner Function' ;
    rdfs:comment 'The business function responsible for defining, maintaining, and activating this segment. Marketing-owned segments drive campaign targeting; merchandising-owned segments inform assortment and OTB planning; CRM-owned segments support loyalty and NPS programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the individual business owner or manager accountable for this segment\'s definition, quality, and activation. Supports data stewardship and governance workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationUseCase rdf:type rdf:Property ;
    rdfs:label 'Personalization Use Case' ;
    rdfs:comment 'Primary personalization or activation use case this segment supports (e.g., \'Email re-engagement campaign\', \'Homepage product recommendation\', \'Loyalty tier upgrade offer\', \'Wholesale reorder reminder\'). Guides campaign brief creation and Adobe Experience Platform activation configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmTier rdf:type rdf:Property ;
    rdfs:label 'Rfm Tier' ;
    rdfs:comment 'RFM (Recency, Frequency, Monetary) classification tier assigned to this segment when segment_type is \'rfm\'. Champions are highest-value active buyers; loyal are consistent purchasers; at_risk are declining in engagement; lapsed have not purchased recently; prospects are new or low-activity customers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the segment (e.g., \'LOYAL_VIP_B2C\', \'WHOLESALE_TIER1\'). Used as the stable reference key across Adobe Experience Platform, Salesforce CRM, and campaign activation systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable display name of the customer segment (e.g., \'High-Value Loyalists\', \'Lapsed Wholesale Accounts\', \'Gen-Z Streetwear Enthusiasts\'). Used in campaign briefs, merchandising plans, and personalization dashboards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment. Active segments are available for campaign targeting and personalization. Draft segments are under construction. Inactive segments are paused. Archived segments are retained for historical analysis but not used in live activations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the methodology used to define the segment. Behavioral segments are based on purchase/browse actions; demographic on age/gender/location; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; channel_based on preferred shopping channel (DTC, wholesale, retail).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeLastEvaluatedDate rdf:type rdf:Property ;
    rdfs:label 'Size Last Evaluated Date' ;
    rdfs:comment 'Date on which the segment membership count (estimated_size) was last computed by Adobe Experience Platform. Indicates data freshness for campaign planning and audience activation decisions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Segment Code' ;
    rdfs:comment 'The native identifier of this segment in the originating source system (e.g., Adobe Experience Platform Segment GUID, Salesforce CRM Segment Record ID). Enables bidirectional traceability and sync reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this segment is a suppression list used to exclude customers from specific campaigns or communications (e.g., recent purchasers suppressed from acquisition campaigns, opted-out customers). Critical for compliance with GDPR and CCPA opt-out requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagsList rdf:type rdf:Property ;
    rdfs:label 'Tags List' ;
    rdfs:comment 'Comma-separated list of free-form business tags applied to this segment for discoverability, governance, and cross-functional search (e.g., \'loyalty,high-value,email-only,seasonal\'). Supports segment catalog management in Adobe Experience Platform and internal data governance portals.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique system-generated identifier for each customer preference or measurement record. Serves as the primary key for the preference data product.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Previous Preference Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior version of this preference record when it was superseded or updated. Enables preference history chaining and change tracking without a separate history table. Null for the initial version of a preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The brand to which the preferred_brand_size or brand preference applies. Enables brand-specific size mapping and brand affinity tracking for personalization and assortment planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelOfCapture rdf:type rdf:Property ;
    rdfs:label 'Channel Of Capture' ;
    rdfs:comment 'The business channel through which this preference was captured or inferred. Supports omnichannel preference reconciliation and channel-specific personalization strategies. Distinct from source_system (technical system) — this represents the customer-facing channel. [ENUM-REF-CANDIDATE: ecommerce|retail_store|mobile_app|style_quiz|loyalty_portal|wholesale|call_center|social_commerce|pop_up_event — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPalette rdf:type rdf:Property ;
    rdfs:label 'Color Palette' ;
    rdfs:comment 'Customer\'s preferred color palette or specific color preferences (e.g., \'neutrals\', \'earth tones\', \'navy,white,grey\', \'bold primaries\'). Used to filter product recommendations and personalize marketing communications. May store comma-separated color values.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Customer\'s preferred channel for receiving marketing communications, personalized recommendations, and promotional offers. Drives omnichannel campaign orchestration in Adobe Experience Platform and Salesforce CRM. Null indicates no stated preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Communication Frequency' ;
    rdfs:comment 'Customer\'s preferred frequency for receiving marketing and personalization communications. Used to govern outreach cadence in campaign management and suppress over-communication. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence level (0.00–100.00) indicating the reliability of this preference or measurement. Self-declared and body scan data typically score highest; behavioral inference scores reflect signal strength from purchase/browse history. Used by recommendation engines to weight preference inputs.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the customer provided consent for this preference data to be collected and used. Required for GDPR and CCPA audit trails. Null for preferences captured prior to consent framework implementation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for this preference data to be collected, stored, and used for personalization purposes. Mandatory for GDPR and CCPA compliance. False values trigger suppression from personalization pipelines.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fitPreference rdf:type rdf:Property ;
    rdfs:label 'Fit Preference' ;
    rdfs:comment 'Customer\'s preferred garment fit silhouette for the associated apparel category. Drives fit-based filtering in recommendation engines and reduces return rates by surfacing appropriately fitted products. [ENUM-REF-CANDIDATE: slim|regular|relaxed|oversized|athletic|tailored|skinny|straight|wide_leg — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'Version identifier of the AI/ML model used to infer this preference from behavioral data (e.g., \'style_affinity_v2.3\', \'fit_inference_v1.1\'). Null for self-declared or manually assigned preferences. Supports model governance, A/B testing, and reproducibility audits.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'IETF BCP 47 locale code representing the language and regional context in which this preference was captured (e.g., \'en-US\', \'fr-FR\', \'de-DE\'). Ensures size system and communication preferences are interpreted in the correct regional context.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialPreference rdf:type rdf:Property ;
    rdfs:label 'Material Preference' ;
    rdfs:comment 'Customer\'s preferred fabric or material types (e.g., \'organic cotton\', \'merino wool\', \'recycled polyester\', \'linen\'). Supports sustainability-aligned personalization and allergy/sensitivity filtering. May store comma-separated material values.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericValue rdf:type rdf:Property ;
    rdfs:label 'Numeric Value' ;
    rdfs:comment 'Parsed numeric representation of the preference value for body measurements and quantitative preferences (e.g., chest circumference 92.50, inseam 76.00, shoe size 10.5). Null for non-numeric preferences. Used by recommendation engines for size matching algorithms.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occasionPreference rdf:type rdf:Property ;
    rdfs:label 'Occasion Preference' ;
    rdfs:comment 'Customer\'s preferred occasions or use cases for apparel (e.g., \'workwear\', \'casual\', \'formal\', \'activewear\', \'evening\'). Supports occasion-based product filtering and targeted collection recommendations. May store comma-separated occasion values.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this preference record was manually overridden by a stylist, customer service agent, or the customer themselves, superseding a previously inferred value. When true, the record takes precedence over behavioral inference for the same preference type.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level category classifying the type of preference or measurement captured. Drives segmentation and personalization routing in Adobe Experience Platform. [ENUM-REF-CANDIDATE: style|fit|color|size|brand|communication|sustainability|material|fragrance|occasion|price_range — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Lifecycle status of this preference record. Active records are used in personalization; superseded records have been replaced by a newer version; expired records have passed their validity window; withdrawn records reflect customer opt-out; pending_verification awaits confirmation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Specific type of preference or measurement within the category (e.g., \'neckline_style\', \'waist_fit\', \'chest_circumference_cm\', \'preferred_color_palette\', \'inseam_length_cm\'). Provides granular classification for recommendation engine targeting.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The actual value of the preference or measurement (e.g., \'slim fit\', \'navy blue\', \'92.5\', \'XL\', \'Nike\'). For numeric measurements, this stores the string representation; numeric_value stores the parsed decimal. Supports both categorical and quantitative preference data.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredBrandSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Brand Size' ;
    rdfs:comment 'Customer\'s preferred size label as used by a specific brand for the associated apparel category (e.g., \'M\', \'L\', \'32x30\', \'10.5\'). Captures brand-specific sizing conventions which differ from standardized measurements, enabling brand-aware size recommendations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRangePreference rdf:type rdf:Property ;
    rdfs:label 'Price Range Preference' ;
    rdfs:comment 'Customer\'s preferred price tier for apparel purchases, aligned to the brand\'s pricing architecture. Informs personalized product recommendations and promotional targeting. Derived from purchase history behavioral inference or self-declared via style profile.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Method by which this preference or measurement was captured. Drives confidence scoring and consent management. Self-declared data from customer profiles, behavioral inference from purchase/browse history, stylist-assigned from in-store consultations, in-store body scan from 3D measurement technology, virtual try-on from digital fitting tools.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleAffinity rdf:type rdf:Property ;
    rdfs:label 'Style Affinity' ;
    rdfs:comment 'Customer\'s preferred aesthetic style or fashion archetype (e.g., \'minimalist\', \'streetwear\', \'classic\', \'bohemian\', \'athleisure\'). Captured via style quiz, behavioral inference from browse/purchase patterns, or stylist assessment. Feeds personalization and collection recommendation engines.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityPreference rdf:type rdf:Property ;
    rdfs:label 'Sustainability Preference' ;
    rdfs:comment 'Indicates whether the customer has expressed a preference for sustainably sourced, ethically produced, or eco-certified products. When true, recommendation engines prioritize GOTS-certified, BCI cotton, and OEKO-TEX certified products.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit associated with the numeric preference value (e.g., \'cm\' for body measurements, \'in\' for imperial measurements, \'EU\'/\'UK\'/\'US\' for shoe sizing systems). Null for non-numeric or unitless preferences. [ENUM-REF-CANDIDATE: cm|in|mm|kg|lbs|EU|UK|US|JP — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Date after which this preference record expires and should no longer be applied in personalization. Null indicates an open-ended preference with no expiry. Supports seasonal preference windows and time-limited style profiles.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this preference record is considered valid and applicable for personalization. Supports temporal preference management, enabling seasonal or time-bounded preferences (e.g., summer color preferences).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consent .

ind:parentConsentRecordConsentId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Consent Id' ;
    rdfs:comment 'Self-referencing identifier linking this consent record to a prior version or parent consent record. Enables full consent history lineage tracking when a customer updates or re-grants consent under a new policy version.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consent .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The touchpoint or channel through which the customer\'s consent was collected. Supports omnichannel compliance tracking across DTC e-commerce (Salesforce Commerce Cloud), POS (SAP CAR), in-store, and wholesale portals. [ENUM-REF-CANDIDATE: web|mobile_app|pos|email|sms|call_center|in_store_kiosk|wholesale_portal — promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The mechanism by which consent was obtained. Explicit = active affirmative action by the customer; Implicit = inferred from behavior; Pre-ticked = checkbox pre-selected (non-compliant under GDPR); Opt-out = consent assumed unless declined.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of the consent record indicating whether the customer has actively granted, withdrawn, or has a pending or expired consent for the specified consent type.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being captured, indicating the specific processing activity or communication channel for which the customer is granting or withdrawing permission. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectAgeVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Age Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s age was verified prior to consent capture to ensure compliance with child data protection requirements (e.g., GDPR Article 8 requires parental consent for children under 16). True = age verified; False = not verified.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The category of device used by the customer when providing consent. Supports channel analytics and helps identify consent collection patterns across DTC digital touchpoints and in-store POS terminals.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the customer completed a double opt-in verification process (e.g., email confirmation link clicked) to confirm their consent. True = double opt-in confirmed; False = single opt-in only. Relevant for marketing email compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The exact date and time when the customer completed the double opt-in verification step. Null if double opt-in was not required or not completed. Supports email marketing compliance audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this consent record is considered active and enforceable. May differ from the granted timestamp if consent is scheduled to take effect at a future date (e.g., post-enrollment cooling-off period).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the consent record expires and must be re-obtained from the customer. Used to enforce time-limited consent policies and trigger re-consent workflows in Adobe Experience Platform.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Granted Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the customer actively granted consent. This is the principal business event timestamp for the consent record and is mandatory for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address of the device from which the customer submitted their consent. Captured at the moment of consent for regulatory audit purposes. May be considered PII under GDPR in certain jurisdictions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under which customer data is being processed, as required by GDPR Article 6. Consent is one of six possible legal bases. Mandatory for GDPR compliance documentation and DPA audit responses.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'The IETF BCP 47 locale code (e.g., en-US, fr-FR, de-DE) representing the language and region in which the consent notice was presented to the customer. Ensures the customer received consent information in their preferred language.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeUrl rdf:type rdf:Property ;
    rdfs:label 'Notice Url' ;
    rdfs:comment 'The URL of the privacy notice, cookie policy, or consent form that was presented to the customer at the time of consent capture. Provides an auditable link to the exact disclosure document shown.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to receiving Net Promoter Score (NPS) survey invitations. Derived from the consent record for survey/feedback consent type. Used by the CRM and customer experience teams to build eligible NPS survey audiences.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained on behalf of a minor customer. Required under GDPR Article 8 for data subjects under the age of digital consent in the applicable jurisdiction.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to data-driven personalization of their shopping experience, including product recommendations and targeted content. Consumed by Adobe Experience Platform personalization workflows.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCenterCode rdf:type rdf:Property ;
    rdfs:label 'Preference Center Code' ;
    rdfs:comment 'Reference to the preference center session or interaction through which the customer managed their consent preferences. Links to the preference management module in Adobe Experience Platform or Salesforce Marketing Cloud.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfConsentReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Consent Reference' ;
    rdfs:comment 'A reference identifier (e.g., document ID, audit log reference, or digital signature hash) pointing to the stored proof of consent artifact. Supports regulatory audit responses and dispute resolution under GDPR Article 7(1) burden-of-proof requirements.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the customer due to a policy change, expiry, or regulatory update. True = re-consent workflow must be triggered; False = consent is current and valid.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Re Consent Sent Timestamp' ;
    rdfs:comment 'The date and time when a re-consent request was dispatched to the customer via the applicable communication channel. Supports SLA tracking for re-consent campaigns and regulatory response timelines.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this consent record was first created in the Silver Layer lakehouse. Serves as the audit creation timestamp for data lineage and compliance reporting.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The applicable data privacy regulatory framework under which this consent record was captured. Determines the legal basis, retention rules, and customer rights applicable to this record. Supports multi-jurisdiction compliance for global apparel operations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why a customer has been suppressed from communications of this consent type. Supports compliance reporting and operational triage for marketing and CRM teams. [ENUM-REF-CANDIDATE: customer_request|regulatory_requirement|bounce|complaint|deceased|fraud|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textSnapshot rdf:type rdf:Property ;
    rdfs:label 'Text Snapshot' ;
    rdfs:comment 'A verbatim snapshot or hash reference of the consent language presented to the customer at the time of consent. Preserves the exact wording for regulatory audit and dispute resolution purposes.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to their data being shared with third-party partners (e.g., wholesale partners, affiliate marketers, analytics vendors). Critical for CCPA \'Do Not Sell\' compliance and GDPR data sharing agreements.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent submission for digital channels. Used for technical audit trails and device fingerprinting in compliance investigations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the consent notice, privacy policy, or terms and conditions document that was presented to the customer at the time of consent capture. Enables tracking of consent obtained under different policy versions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the customer withdrew or revoked a previously granted consent. Null if consent has not been withdrawn. Required for GDPR right-to-withdraw audit compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Unique identifier for the customer service request case. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:goodwillPromoCodeId rdf:type rdf:Property ;
    rdfs:label 'Goodwill Promo Code Id' ;
    rdfs:comment 'Foreign key linking to marketing.promo_code. Business justification: Customer service recovery promo issuance: when resolving complaints or returns, associates issue goodwill promo codes. This FK links the service request to the issued promo code for cost tracking, pro' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCode .

ind:handlingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Handling Associate Id' ;
    rdfs:comment 'Foreign key linking to store.associate. Business justification: Service requests handled by store associates (in-store returns, complaints, styling consultations) require associate-level tracking for performance reviews, training needs identification, customer sat' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name or identifier of the customer service team responsible for handling this case type. Used for workload distribution and routing.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible case number provided to the customer for tracking and reference purposes. Human-readable identifier.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the service request. Tracks progression from initial submission through resolution and closure.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the service request type. Categorizes the nature of the customer inquiry or issue.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the service request was formally closed. May differ from resolved timestamp if additional administrative steps were required.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address used by the customer for this specific service request. May differ from primary customer email if submitted by alternate contact.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number used by the customer for this specific service request. Used for follow-up communication and case resolution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer after case resolution. Typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicator of whether this service request was escalated to a higher support tier or management. True if escalation occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the service request was escalated. Captures business justification for escalation to higher support tiers.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the first response was provided to the customer by a service agent. Used for Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments visible only to service agents and management. Contains sensitive operational details not shared with customers.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsAdjustment rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Adjustment' ;
    rdfs:comment 'Number of loyalty program points added or deducted as part of the service request resolution. Positive for credits, negative for deductions.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the service request based on urgency and business impact. Determines Service Level Agreement (SLA) targets.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier of the product related to this service request, if applicable. Used for product-specific complaints or inquiries.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount refunded to the customer as part of the service request resolution, if applicable. Excludes currency code.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionCategory rdf:type rdf:Property ;
    rdfs:label 'Resolution Category' ;
    rdfs:comment 'Classification of how the service request was resolved. Used for analytics on resolution patterns and customer satisfaction drivers.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the actions taken and resolution provided to the customer. Captures final outcome and customer satisfaction details.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the service request was marked as resolved. Indicates when the issue was addressed to customer satisfaction.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Detailed description of the customer issue, inquiry, or complaint as initially reported. Captures full context of the service request.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicator of whether the Service Level Agreement (SLA) target was breached for this case. True if response or resolution exceeded target timeframes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Hours' ;
    rdfs:comment 'Target number of hours within which the case should be resolved based on case priority and Service Level Agreement (SLA) rules.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Hours' ;
    rdfs:comment 'Target number of hours within which the first response should be provided based on case priority and Service Level Agreement (SLA) rules.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary or title of the service request. Provides quick overview of the customer issue or inquiry.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the customer submitted the service request. Tracks customer contact preferences and channel effectiveness. [ENUM-REF-CANDIDATE: store|email|chat|phone|web|mobile_app|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Survey Response Date' ;
    rdfs:comment 'Date when the customer completed the satisfaction or Net Promoter Score (NPS) survey related to this service request.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Unique identifier for the payment method record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Reference to the billing address associated with this payment method. Links to customer address record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addedChannel rdf:type rdf:Property ;
    rdfs:label 'Added Channel' ;
    rdfs:comment 'The channel or interface through which the customer added this payment method (web storefront, mobile app, physical store, call center, API integration).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'The date when the customer added this payment method to their account.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoUpdateEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Update Enabled' ;
    rdfs:comment 'Flag indicating whether this payment method is enrolled in automatic card updater services that refresh expiry dates and card numbers when cards are reissued.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bnplProvider rdf:type rdf:Property ;
    rdfs:label 'Bnpl Provider' ;
    rdfs:comment 'The buy-now-pay-later service provider when payment_type is buy_now_pay_later (Klarna, Afterpay, Affirm, Sezzle, Zip, QuadPay). Null for non-BNPL payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The card network or brand (Visa, Mastercard, American Express, Discover, JCB, Diners Club). Null for non-card payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardFundingType rdf:type rdf:Property ;
    rdfs:label 'Card Funding Type' ;
    rdfs:comment 'The funding mechanism of the card (credit, debit, prepaid, charge card, or deferred debit). Null for non-card payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'The name of the cardholder as it appears on the payment instrument. Used for verification and display purposes.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Date' ;
    rdfs:comment 'The date when this payment method record is scheduled for deletion or archival according to data retention policies and regulatory requirements.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalWalletType rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Type' ;
    rdfs:comment 'The specific digital wallet provider when payment_type is digital_wallet (Apple Pay, Google Pay, PayPal, Samsung Pay, Venmo, Alipay, WeChat Pay). Null for non-wallet payment types. [ENUM-REF-CANDIDATE: apple_pay|google_pay|paypal|samsung_pay|venmo|alipay|wechat_pay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1-12). Null for non-expiring payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The expiration year of the payment card (four-digit year). Null for non-expiring payment types.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'The total number of failed or declined transaction attempts using this payment method. High failure counts may trigger automatic suspension.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudCheckDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Date' ;
    rdfs:comment 'The date when the most recent fraud risk assessment was performed on this payment method.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'A risk score (0.00 to 100.00) assigned by fraud detection systems indicating the likelihood that this payment method is associated with fraudulent activity. Higher scores indicate higher risk.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the customers default payment method for one-click checkout and recurring billing. Only one payment method per customer should be marked as default.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'The name of the financial institution that issued the card or payment instrument. Derived from Bank Identification Number (BIN) lookup.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the country where the payment instrument was issued. Used for fraud detection and regional compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the card number or account number, used for customer identification and display purposes. PCI-DSS compliant truncated value.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this payment method was last successfully used for a transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Optional customer-defined nickname or label for this payment method to help identify it in their account (e.g., \'Work Visa\', \'Personal Amex\').' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Method Status' ;
    rdfs:comment 'Current lifecycle status of the payment method. Active methods are available for transactions; expired methods have passed their expiry date; suspended methods are temporarily blocked; pending or failed verification indicates incomplete validation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'The category of payment instrument (credit card, debit card, digital wallet such as Apple Pay or Google Pay, gift card, buy-now-pay-later services such as Klarna or Afterpay, or store credit).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Flag' ;
    rdfs:comment 'Flag confirming that this payment method record complies with PCI-DSS requirements (no raw card data stored, only tokenized references).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurringBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Recurring Billing Enabled' ;
    rdfs:comment 'Flag indicating whether this payment method is authorized for recurring billing or subscription charges without additional customer authentication.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeDSecureEnrolled rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Enrolled' ;
    rdfs:comment 'Flag indicating whether this payment method is enrolled in 3D Secure authentication (Verified by Visa, Mastercard SecureCode, etc.) for enhanced transaction security.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'The tokenized reference to the actual payment instrument, provided by the payment gateway or tokenization service. No raw card data is stored. PCI-DSS compliant token.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationProvider rdf:type rdf:Property ;
    rdfs:label 'Tokenization Provider' ;
    rdfs:comment 'The name of the payment gateway or tokenization service that issued the token (e.g., Stripe, Adyen, Braintree, Salesforce Commerce Cloud Payment Gateway).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'The total number of successful transactions processed using this payment method since it was added.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the payment method was last verified or validation was attempted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the payment method has been successfully verified through Address Verification Service (AVS), Card Verification Value (CVV) check, or other validation mechanisms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeProfileId rdf:type rdf:Property ;
    rdfs:label 'Size Profile Id' ;
    rdfs:comment 'Unique identifier for the customer size profile record. Primary key.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyShapeType rdf:type rdf:Property ;
    rdfs:label 'Body Shape Type' ;
    rdfs:comment 'Optional classification of the customer\'s body shape (e.g., \'athletic\', \'pear\', \'rectangle\', \'hourglass\', \'inverted_triangle\'). Used for advanced fit personalization and style recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:braBandSize rdf:type rdf:Property ;
    rdfs:label 'Bra Band Size' ;
    rdfs:comment 'Bra band size measurement (e.g., \'32\', \'34\', \'36\'). Specific to women\'s intimate apparel and activewear.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:braCupSize rdf:type rdf:Property ;
    rdfs:label 'Bra Cup Size' ;
    rdfs:comment 'Bra cup size measurement (e.g., \'A\', \'B\', \'C\', \'D\', \'DD\'). Specific to women\'s intimate apparel and activewear.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chestMeasurement rdf:type rdf:Property ;
    rdfs:label 'Chest Measurement' ;
    rdfs:comment 'Chest circumference measurement. Critical for tops, outerwear, and activewear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The source system or platform from which this size profile data originated (e.g., \'Adobe Experience Platform\', \'Salesforce Commerce Cloud\', \'In-Store Kiosk\', \'Mobile App\').' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:footLengthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Foot Length Measurement' ;
    rdfs:comment 'Foot length measurement from heel to toe. Critical for footwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:footWidthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Foot Width Measurement' ;
    rdfs:comment 'Foot width measurement at the widest point. Used for footwear width sizing (narrow, medium, wide).' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'The customer\'s height measurement. Critical for inseam, sleeve length, and overall garment length recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightUnit rdf:type rdf:Property ;
    rdfs:label 'Height Unit' ;
    rdfs:comment 'The unit in which height is expressed (inches, centimeters, or feet).' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipMeasurement rdf:type rdf:Property ;
    rdfs:label 'Hip Measurement' ;
    rdfs:comment 'Hip circumference measurement. Critical for bottoms and activewear sizing, particularly for women\'s apparel.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inseamMeasurement rdf:type rdf:Property ;
    rdfs:label 'Inseam Measurement' ;
    rdfs:comment 'Inseam length measurement from crotch to ankle. Critical for pants and jeans sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryProfile rdf:type rdf:Property ;
    rdfs:label 'Is Primary Profile' ;
    rdfs:comment 'Indicates whether this is the customer\'s primary size profile used for default fit recommendations and personalization. Only one profile per customer should be marked as primary.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'The date when the customer last verified or confirmed their size profile measurements. Used to prompt customers to update outdated profiles.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when this measurement was captured or last updated. Body measurements can change over time; recent measurements are prioritized for fit recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The method by which the measurement was captured. Self-reported measurements may be less accurate than professional scans or tailor measurements. Used to weight fit recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'The specific body measurement captured (e.g., chest, waist, hip, inseam, shoulder_width, foot_length, neck, sleeve_length, rise, thigh). Varies by apparel category.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'The numeric value of the body measurement. Precision supports fractional measurements for accurate fit personalization.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:neckMeasurement rdf:type rdf:Property ;
    rdfs:label 'Neck Measurement' ;
    rdfs:comment 'Neck circumference measurement. Critical for dress shirts, formal wear, and outerwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Profile Completeness Percentage' ;
    rdfs:comment 'Percentage (0-100) indicating how complete this size profile is based on the number of measurements captured relative to the ideal set for the apparel category. Used to prompt customers to complete their profiles.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRateImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Return Rate Impact Flag' ;
    rdfs:comment 'Indicates whether this size profile has been effective in reducing the customer\'s return rate for sizing-related issues. Used to measure the business impact of fit personalization.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shoulderWidthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Shoulder Width Measurement' ;
    rdfs:comment 'Shoulder width measurement from shoulder point to shoulder point. Critical for tops, outerwear, and formal wear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Size Confidence Score' ;
    rdfs:comment 'A calculated confidence score (0-100) indicating the reliability of this size profile based on measurement source, recency, and consistency with purchase history. Higher scores indicate more reliable fit recommendations.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sleeveLengthMeasurement rdf:type rdf:Property ;
    rdfs:label 'Sleeve Length Measurement' ;
    rdfs:comment 'Sleeve length measurement from shoulder to wrist. Critical for tops, outerwear, and formal wear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stylistNotes rdf:type rdf:Property ;
    rdfs:label 'Stylist Notes' ;
    rdfs:comment 'Optional free-text notes from personal stylists or store associates regarding the customer\'s fit preferences, body shape considerations, or special sizing needs. Treated as confidential business data.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualTryOnEnabled rdf:type rdf:Property ;
    rdfs:label 'Virtual Try On Enabled' ;
    rdfs:comment 'Indicates whether this size profile is enabled for virtual try-on experiences in the e-commerce platform. Requires sufficient measurement data and customer consent.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waistMeasurement rdf:type rdf:Property ;
    rdfs:label 'Waist Measurement' ;
    rdfs:comment 'Waist circumference measurement. Critical for bottoms, activewear, and outerwear sizing.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'The customer\'s weight measurement. Optional field used for advanced fit modeling and size recommendations. Treated as confidential business data.' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'The unit in which weight is expressed (pounds or kilograms).' ;
    rdfs:domain ind:SizeProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Unique identifier for the stock position record. Primary key for the stock position entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: stock_position tracks inventory at lot/batch level (critical for dye-lot consistency in apparel). The lot_number STRING field is a denormalized copy of lot_batch.lot_number. Adding lot_batch_id FK nor' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Identifier for the physical location where inventory is held. References warehouse, distribution center (DC), retail store, or third-party logistics (3PL) facility.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of inventory based on time in stock and seasonal relevance. Current season represents fresh merchandise, prior season is last season carryover, aged is multi-season old inventory, and clearance is marked for liquidation. Drives markdown strategies and inventory valuation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationGroup rdf:type rdf:Property ;
    rdfs:label 'Allocation Group' ;
    rdfs:comment 'Classification code used to group inventory for allocation planning. Allocation groups define how inventory is distributed across channels and locations based on demand forecasts, store grades, and strategic priorities.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'Quantity available for future customer commitments, including current ATS plus expected inbound receipts minus planned outbound allocations. Used for forward order promising and pre-order management.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atsQuantity rdf:type rdf:Property ;
    rdfs:label 'Ats Quantity' ;
    rdfs:comment 'Quantity available for new customer orders. Calculated as on-hand quantity minus reserved quantity minus damaged/held quantity. This is the inventory pool visible to e-commerce and point-of-sale systems for order promising.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountVariance rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance' ;
    rdfs:comment 'Difference between system on-hand quantity and physical count quantity from the last cycle count. Positive values indicate physical surplus, negative values indicate shortage. Used to measure inventory accuracy and identify shrinkage.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'Quantity of inventory identified as damaged, defective, or unsellable. This inventory is physically present but excluded from available-to-sell calculations pending disposition decisions (repair, return to vendor, or disposal).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which the inventory should not be sold or used. Applicable to items with shelf life such as cosmetics, fragrances, or performance fabrics with time-sensitive treatments. Null for non-perishable apparel.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heldQuantity rdf:type rdf:Property ;
    rdfs:label 'Held Quantity' ;
    rdfs:comment 'Quantity placed on administrative hold for quality inspection, regulatory compliance review, or investigation. Inventory is physically present but temporarily unavailable for sale or allocation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International tariff classification code for the product. Used for customs clearance, duty calculation, and trade compliance. Essential for cross-border inventory movements and landed cost calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity currently being transported to this location from suppliers, manufacturing facilities, or other distribution points. Includes goods in-transit via ocean freight, air freight, and ground transportation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent inventory adjustment transaction at this location. Adjustments include cycle count corrections, damage write-offs, and system corrections. Used for audit trail and inventory accuracy monitoring.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count performed for this SKU at this location. Supports inventory accuracy monitoring and audit compliance.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date of the most recent inventory receipt at this location. Used to track inventory freshness and identify slow-moving stock.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent sale or allocation of this SKU from this location. Used to identify dormant inventory and trigger markdown or transfer decisions.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nosFlag rdf:type rdf:Property ;
    rdfs:label 'Nos Flag' ;
    rdfs:comment 'Indicates whether this SKU is designated as a never-out-of-stock item requiring continuous availability. NOS items receive priority replenishment and higher safety stock levels to prevent stockouts.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical inventory quantity currently present at the location. Represents the actual count of units physically available in the facility, verified through cycle counts and RFID tracking.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates the legal ownership of the inventory. Owned is company-owned stock, consignment is supplier-owned until sold, vendor-owned is VMI stock, and customer-owned is inventory held on behalf of wholesale customers.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level that triggers automatic replenishment. When on-hand quantity falls below the reorder point, a purchase order or transfer order is generated. Calculated as lead time demand plus safety stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'Strategy used to replenish inventory at this location. Automatic uses system-driven reorder points, manual requires planner intervention, VMI is supplier-managed, cross-dock bypasses storage, and drop-ship ships directly from supplier to customer.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of inventory allocated to specific orders or commitments but not yet shipped. Includes customer orders, store allocations, and wholesale commitments that are pending fulfillment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether this SKU at this location is tracked using RFID technology. RFID enables real-time inventory visibility, automated cycle counting, and improved inventory accuracy.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Minimum inventory buffer maintained to protect against demand variability and supply chain disruptions. Safety stock levels are calculated based on demand volatility, lead time variability, and desired service level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Business date for which this stock position record represents the inventory state. Enables point-in-time inventory analysis and historical trend reporting. Updated daily through batch processing.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current operational status of the inventory at this location. Available indicates sellable stock, reserved is allocated to orders, quarantine is under quality review, damaged is unsellable, in-transit is being received, and blocked is administratively restricted.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Financial accounting classification for inventory valuation. Determines the general ledger accounts used for inventory asset and cost of goods sold postings. Supports multi-GAAP reporting requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Flag' ;
    rdfs:comment 'Indicates whether this inventory is managed under a vendor-managed inventory program where the supplier monitors stock levels and triggers replenishment. VMI programs shift inventory management responsibility to suppliers.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wos rdf:type rdf:Property ;
    rdfs:label 'Wos' ;
    rdfs:comment 'Number of weeks the current on-hand inventory will last based on forecasted demand. Calculated as on-hand quantity divided by average weekly sales rate. Key metric for inventory health and replenishment planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement record.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Foreign key linking to inventory.asn. Business justification: Stock movements triggered by ASN receipts should link to the originating ASN. The reference_document_type and reference_document_number fields suggest generic document linking, but a structured FK to ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:customsEntryId rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Id' ;
    rdfs:comment 'Foreign key linking to logistics.customs_entry. Business justification: Import receipts tied to customs entries. Linking enables duty allocation to inventory, landed cost accuracy, trade compliance audit trail, and duty drawback claims—fundamental for apparel import opera' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomsEntry .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_cycle_count. Business justification: Stock adjustment movements resulting from cycle count variances should reference the cycle count event that identified the discrepancy. This provides audit trail from count → variance → adjustment mov' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:destinationLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the location to which inventory is being moved. Null for goods issues to customers or write-offs. Links to warehouse, store, or distribution center master.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to inventory.goods_receipt. Business justification: Stock movements resulting from goods receipt postings should link directly to the goods_receipt record. This enables traceability from inventory movement back to the physical receipt event, supporting' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:primaryStockWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Location Id' ;
    rdfs:comment 'Identifier of the location from which inventory is being moved. Null for goods receipts from external suppliers. Links to warehouse, store, or distribution center master.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:productionLotId rdf:type rdf:Property ;
    rdfs:label 'Production Lot Id' ;
    rdfs:comment 'Foreign key linking to production.lot. Business justification: Finished goods receipts from production must link to production lot for batch traceability, quality tracking, and recall management. Critical for apparel compliance (country of origin, labor certifica' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.replenishment_order. Business justification: Stock movements triggered by replenishment orders should reference the originating replenishment order. This allows tracing which movements fulfilled which replenishment requests. New FK attribute nee' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Foreign key linking to inventory.reservation. Business justification: When reserved inventory is allocated or released, the stock movement should reference the reservation record. This links the physical movement to the logical reservation that triggered it, enabling re' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reservation .

ind:thirdPartyLogisticsId rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Id' ;
    rdfs:comment 'Foreign key linking to logistics.third_party_logistics. Business justification: 3PL-operated facilities generate movements. Linking enables 3PL billing validation, performance measurement, cost allocation, and SLA compliance tracking—standard for apparel brands using 3PL warehous' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyLogistics .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.transfer_order. Business justification: Stock movements executed as part of transfer orders should link to the originating transfer_order. This connects the transactional movement record to the operational transfer request, enabling trackin' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the movement was approved. Part of the audit trail for compliance and internal controls.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business code for the destination location (e.g., warehouse code, store number, DC identifier). Human-readable identifier for reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classification of the destination location to enable location-type-specific analytics and reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document that triggered the movement (e.g., PO date, transfer order date, physical count date). May differ from posting date due to processing delays.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level classification of the movement transaction type for reporting and analytics. Groups detailed movement types into business-meaningful categories.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Document Number' ;
    rdfs:comment 'The externally-known business document number for this inventory movement (e.g., goods receipt number, transfer order number, adjustment document number). Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The quantity of inventory moved in this transaction. Positive for receipts and negative for issues. Expressed in the base unit of measure.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the stock movement transaction. Indicates whether the movement has been finalized in inventory records or is still in process.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Precise date and time when the physical inventory movement occurred or was recorded in the warehouse management system. Used for real-time inventory tracking and RFID event correlation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'Three-digit code classifying the nature of the inventory movement (e.g., 101=Goods Receipt from PO, 311=Transfer Posting, 551=Scrapping, 601=Goods Issue for Delivery). Aligns with SAP movement type taxonomy.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The business date on which the inventory movement was posted to the ledger and inventory balances were updated. This is the official date of record for inventory valuation and financial reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code indicating the business reason for the movement, especially for adjustments, returns, and write-offs (e.g., damaged, obsolete, cycle count correction, customer return, quality hold release).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the movement reason. Used when reason code alone is insufficient to explain the transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Number' ;
    rdfs:comment 'The line item number within the reference document that this movement relates to. Enables line-level traceability.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The business document number of the source transaction (e.g., PO number, sales order number, STO number, RTV number, ASN number). Used for audit trail and reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document that triggered or authorized this inventory movement. Enables traceability back to originating business transaction. [ENUM-REF-CANDIDATE: purchase_order|sales_order|transfer_order|return_authorization|adjustment_request|delivery_note|asn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this movement is a reversal of a previous transaction. True if this is a correcting entry that negates a prior movement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The movement document number of the original transaction being reversed. Populated only when reversal_indicator is true. Enables audit trail of corrections.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for serialized inventory items (e.g., high-value accessories, luxury goods). Enables item-level tracking and authentication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Business code for the source location (e.g., warehouse code, store number, DC identifier). Human-readable identifier for reporting.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationType rdf:type rdf:Property ;
    rdfs:label 'Source Location Type' ;
    rdfs:comment 'Classification of the source location to enable location-type-specific analytics and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of inventory status indicating availability and ownership. Unrestricted stock is available for sale; other types have restrictions or special handling requirements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the movement (movement_quantity × unit_cost). Posted to inventory accounts and used for financial reporting and COGS calculation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The inventory valuation method applied to this movement for financial accounting purposes. Determines how cost is calculated and posted to the general ledger.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Foreign key linking to inventory.zone. Business justification: Warehouse locations currently have zone_code (STRING) but should FK to the zone master table for referential integrity. The zone_code string should be removed and replaced with zone_id FK, allowing pr' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'Identifier for the physical aisle where the location resides. Used for travel optimization and picker routing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Identifier for the individual bin or position within the shelf. Represents the most granular storage unit.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether this location is within a customs bonded area where imported goods can be stored without paying duties until they are released for domestic consumption.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Meters' ;
    rdfs:comment 'Maximum cubic volume (in cubic meters) that can be stored in this location. Used for dimensional slotting and space utilization analysis.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Maximum number of inventory units (eaches, cases, pallets) that can be stored in this location. Used for slotting optimization and capacity planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity (in kilograms) for this location. Used to ensure safe storage and compliance with structural load limits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Number of days between scheduled cycle counts for this location. High-value or high-velocity locations typically have shorter frequencies.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'Indicates whether this location is certified and approved for storing hazardous materials (e.g., certain dyes, chemicals, aerosols) in compliance with safety regulations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Unique business identifier for the warehouse location within the facility. Used for directed putaway, picking, and cycle count operations. Typically follows facility-specific naming conventions (e.g., A-01-02-03 for Aisle-Rack-Shelf-Bin).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the warehouse location for operational reference and reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the warehouse location. Determines whether the location is available for putaway, picking, or other warehouse operations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the warehouse location by its operational purpose. Determines handling rules, slotting strategies, and fulfillment routing logic. [ENUM-REF-CANDIDATE: bin|shelf|rack|aisle|zone|staging|dock|receiving|shipping|quarantine|returns|bulk|reserve|forward_pick|cross_dock|bonded|stockroom — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether inventory from different lots or batches of the same SKU can be stored together in this location. Important for lot traceability and FIFO compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether multiple different SKUs can be stored in this location simultaneously. Forward pick locations typically allow mixed SKUs while reserve locations may be single-SKU.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence used to optimize picker travel paths during order fulfillment. Lower numbers are visited first in the pick route.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayPriority rdf:type rdf:Property ;
    rdfs:label 'Putaway Priority' ;
    rdfs:comment 'Priority ranking for directed putaway operations. Higher priority locations are filled first during receiving and replenishment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier for the rack or bay within the aisle. Part of the hierarchical location structure.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTriggerLevel rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Level' ;
    rdfs:comment 'Inventory quantity threshold that triggers automatic replenishment from reserve to forward pick locations. Supports Never Out of Stock (NOS) strategies.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Code' ;
    rdfs:comment 'Identifier for the shelf or level within the rack. Part of the hierarchical location structure.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the location. Critical for storing temperature-sensitive apparel materials, adhesives, or specialty items.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorManagedInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Managed Inventory Flag' ;
    rdfs:comment 'Indicates whether this location is designated for Vendor Managed Inventory programs where suppliers own and manage inventory until point of sale or consumption.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal coordinate (X-axis) of the location within the facility floor plan. Used for travel distance calculations and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical coordinate (Y-axis) of the location within the facility floor plan. Used for travel distance calculations and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zCoordinate rdf:type rdf:Property ;
    rdfs:label 'Z Coordinate' ;
    rdfs:comment 'Height coordinate (Z-axis) of the location representing vertical position or level. Used for multi-level warehouse operations and automated storage systems.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuLocationId rdf:type rdf:Property ;
    rdfs:label 'Sku Location Id' ;
    rdfs:comment 'Unique identifier for the SKU-location association record. Primary key for the sku_location entity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuLocation .

ind:vmiVendorId rdf:type rdf:Property ;
    rdfs:label 'Vmi Vendor Id' ;
    rdfs:comment 'Reference to the vendor responsible for managing inventory replenishment under the VMI program for this SKU-location.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Date when the SKU-location assignment became or will become effective. Used for planning seasonal slotting changes and location transitions.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Expiration Date' ;
    rdfs:comment 'Date when the SKU-location assignment expires or is scheduled to be deactivated. Null for permanent assignments.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Units' ;
    rdfs:comment 'Maximum capacity of the storage location expressed in inventory units (e.g., number of units, cases, or pallets that can be stored).' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCapacityVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Volume Cubic Meters' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location expressed in cubic meters. Used for space utilization and slotting optimization.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCapacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Location Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location expressed in kilograms. Ensures safe loading and compliance with facility structural limits.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Stock Quantity' ;
    rdfs:comment 'Maximum inventory quantity that should be stored at this location. Defines the upper limit for replenishment to prevent overstocking.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Stock Quantity' ;
    rdfs:comment 'Minimum inventory quantity that should be maintained at this location to trigger replenishment. Part of min-max inventory control strategy.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Scheduled date for the next cycle count of this SKU at this location based on the cycle count frequency.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nosClassificationTier rdf:type rdf:Property ;
    rdfs:label 'Nos Classification Tier' ;
    rdfs:comment 'Classification tier indicating the priority level for NOS (Never Out of Stock) strategy. Tier 1 represents highest priority items that must always be in stock.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nosPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Nos Policy Code' ;
    rdfs:comment 'Code identifying the specific NOS policy applied to this SKU-location combination, defining replenishment rules, safety stock levels, and escalation procedures.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowLocationCode rdf:type rdf:Property ;
    rdfs:label 'Overflow Location Code' ;
    rdfs:comment 'Code identifying the overflow or secondary storage location for this SKU when primary location capacity is exceeded.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence Number' ;
    rdfs:comment 'Sequence number defining the order in which this location should be picked during wave picking or batch picking operations to optimize picker travel path.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPickLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Location Flag' ;
    rdfs:comment 'Indicates whether this location is designated as the primary pick location for the SKU. True if this is the first location pickers should retrieve inventory from.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level at which replenishment should be triggered for this SKU at this location. When ATS (Available to Sell) falls below this threshold, a replenishment order is generated.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Number of days required to replenish inventory at this location from the time a replenishment order is triggered until goods are received and available.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slottingPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Slotting Priority Rank' ;
    rdfs:comment 'Numerical rank indicating the priority of this SKU for optimal warehouse slotting. Lower numbers indicate higher priority for placement in prime pick locations.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmiIndicator rdf:type rdf:Property ;
    rdfs:label 'Vmi Indicator' ;
    rdfs:comment 'Indicates whether this SKU-location is managed under a VMI (Vendor Managed Inventory) program where the supplier is responsible for monitoring and replenishing inventory levels.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wosCurrent rdf:type rdf:Property ;
    rdfs:label 'Wos Current' ;
    rdfs:comment 'Current WOS (Weeks of Supply) calculated as current stock quantity divided by average weekly demand. Indicates how many weeks the current inventory will last.' ;
    rdfs:domain ind:SkuLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Counting Associate Id' ;
    rdfs:comment 'Foreign key linking to store.associate. Business justification: Retail store cycle counts are performed by specific store associates. Apparel loss prevention and audit processes require knowing which associate conducted each count for accountability, variance inve' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification of the SKU determining cycle count frequency: A (high value, frequent counts), B (medium value, moderate counts), C (low value, infrequent counts).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Financial value of the inventory adjustment calculated as variance quantity multiplied by unit cost. Impacts COGS and inventory valuation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Document Number' ;
    rdfs:comment 'Reference number of the inventory adjustment document posted to SAP or ERP system as a result of the approved variance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicator that the variance has been posted to inventory records and financial ledgers. True when adjustment posted, False when pending.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Final quantity approved by supervisor or system after count validation and any required recounts. This quantity is posted to inventory records.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'Actual date and time when the physical counting activity was completed and submitted for review.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Technology or process used to perform the physical count: manual (visual count and paper), handheld_scanner (barcode scanning device), rfid_reader (RFID tag reading), automated_system (automated storage and retrieval system count).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text comments or observations recorded by the counter during the cycle count, documenting issues, discrepancies, or special conditions.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count event, typically formatted as CC-YYYYMMDD-NNNNNN for external reference and tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReason rdf:type rdf:Property ;
    rdfs:label 'Count Reason' ;
    rdfs:comment 'Business reason triggering the cycle count: scheduled (routine calendar-based), variance_triggered (system detected discrepancy), stock_adjustment (manual correction needed), audit (compliance or quality check), neveroutofstock (NOS item verification), receiving_discrepancy (inbound variance), returns_verification (RTV or customer return validation). [ENUM-REF-CANDIDATE: scheduled|variance_triggered|stock_adjustment|audit|neveroutofstock|receiving_discrepancy|returns_verification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'Actual date and time when the physical counting activity began, captured from WMS or handheld device.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count: planned (scheduled but not started), assigned (counter designated), in_progress (counting underway), completed (count finished pending review), approved (variance accepted and posted), rejected (count invalidated), recount_required (variance exceeds threshold). [ENUM-REF-CANDIDATE: planned|assigned|in_progress|completed|approved|rejected|recount_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count methodology: full (complete location inventory), partial (sample-based), abc_class (frequency based on item value), rfid_assisted (RFID technology enabled), blind (no system quantity shown), targeted (specific SKU focus).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity counted by the assigned counter during the cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'System-recorded quantity on hand for the SKU at the location prior to the physical count, sourced from perpetual inventory records.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Quality and availability status of the counted inventory: available (ATS), reserved (allocated to orders), quarantine (quality hold), damaged (not sellable), expired (past shelf life), return_to_vendor (RTV candidate).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when the cycle count record was last updated, tracking changes through the count lifecycle.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicator that the variance exceeds tolerance and a recount is required before posting adjustment. True when recount needed, False otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating how many times this item has been recounted. Zero for initial count, increments with each recount attempt.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the cycle count event to be executed, based on ABC classification frequency or calendar-driven schedule.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance quantity expressed as a percentage of expected quantity, used to determine if recount threshold is exceeded.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Calculated difference between expected quantity and counted quantity (counted minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Configured tolerance percentage for acceptable variance. Variances exceeding this threshold trigger recount or management approval requirements.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTransferWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Warehouse Location Id' ;
    rdfs:comment 'Identifier of the originating location from which inventory is being transferred (warehouse, distribution center, retail store, or third-party logistics facility).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:slaAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sla Agreement Id' ;
    rdfs:comment 'Foreign key linking to logistics.sla_agreement. Business justification: Transfer OTIF SLA compliance tracking: transfer_order.otif_status is measured against a governing SLA agreement (especially for 3PL-managed inter-DC transfers). Apparel logistics teams require this li' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaAgreement .

ind:sourceRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Source Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Inter-store transfers originate from source retail stores for stock balancing, allocation optimization, and ship-from-store fulfillment - requires tracking source store for inventory deduction, transf' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date the inventory was received at the destination location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFreightCost rdf:type rdf:Property ;
    rdfs:label 'Actual Freight Cost' ;
    rdfs:comment 'The actual transportation cost incurred for the transfer order in the base currency.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date the inventory was shipped from the source location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the transfer order was cancelled, if applicable.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when the transfer order was fully received and closed in the system.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The actual quantity of units confirmed available and allocated for transfer at the source location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'The estimated transportation cost for the transfer order in the base currency.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining who bears the cost and risk of transportation: prepaid, collect, third party, Free on Board (FOB) origin, or FOB destination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Indicates whether the transferred inventory contains hazardous materials requiring special handling and compliance documentation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Performance indicator showing whether the transfer was delivered on time and in full quantity as requested.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the transfer order determining processing sequence and resource allocation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of units received and accepted at the destination location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the inventory is requested to arrive at the destination location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of units originally requested to be transferred from source to destination location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date by which the inventory is requested to be shipped from the source location.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTracked rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracked' ;
    rdfs:comment 'Indicates whether the transferred inventory is tracked using RFID technology for real-time visibility.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'The transportation mode used for the transfer: ground, air, ocean, rail, intermodal, or courier service.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'Reference number of the upstream business document that triggered this transfer order (e.g., allocation plan ID, replenishment rule ID).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of upstream business document or process that triggered the creation of this transfer order.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the transfer requires temperature-controlled transportation and storage conditions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-facing unique reference number for the transfer order, used for tracking and communication across systems and stakeholders.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the transfer order indicating its progression through the fulfillment workflow. [ENUM-REF-CANDIDATE: draft|approved|in_transit|received|cancelled|partially_received|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer order purpose: replenishment (store restocking), rebalancing (inventory optimization), recall (product withdrawal), return (reverse logistics), consolidation (inventory centralization), or emergency (urgent fulfillment).' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Destination Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Store replenishment orders from DC to retail stores must track destination store for fulfillment planning, store WOS management, replenishment lead time tracking, and store-level inventory flow optimi' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:primaryReplenishmentWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse, distribution center, or 3PL facility from which inventory will be shipped to fulfill this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:sourceDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Source Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: DC-to-store replenishment wave planning: replenishment orders originate from a specific DC. Apparel DC operations require direct source DC identification for capacity planning, outbound wave schedulin' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:atsQuantityAtRequest rdf:type rdf:Property ;
    rdfs:label 'Ats Quantity At Request' ;
    rdfs:comment 'The ATS (Available to Sell) inventory quantity at the destination location when the replenishment order was created, representing on-hand minus allocated/reserved inventory.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledReason rdf:type rdf:Property ;
    rdfs:label 'Cancelled Reason' ;
    rdfs:comment 'Free-text explanation of why the replenishment order was cancelled, if applicable (e.g., inventory no longer needed, source location stockout, budget constraints).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'The planned date when the source location will ship the replenishment order, calculated based on lead time and requested delivery date.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'The transportation cost incurred for shipping this replenishment order, used for landed cost calculation and logistics analytics.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The expected number of days from order release to delivery at the destination location, based on historical performance and carrier SLA.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'The target maximum inventory level at the destination location, used in min/max replenishment logic to determine order quantity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityAtRequest rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity At Request' ;
    rdfs:comment 'The physical inventory quantity available at the destination location at the time the replenishment order was created, used to calculate replenishment need.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment order: proposed (system-generated, awaiting review), approved (planner-approved), released (sent to WMS for execution), in_transit (shipment en route), received (goods received at destination), fulfilled (order complete), cancelled (order voided), rejected (approval denied). [ENUM-REF-CANDIDATE: proposed|approved|released|in_transit|received|fulfilled|cancelled|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger' ;
    rdfs:comment 'The business rule or condition that triggered this replenishment order: below reorder point, NOS (Never Out of Stock) breach, OTB (Open-to-Buy) driven, demand forecast, safety stock breach, or allocation plan execution.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of how the replenishment order was initiated: automatic (system-triggered by min/max rules or MRP), manual (planner-initiated), VMI (Vendor Managed Inventory), emergency (expedited NOS breach), seasonal (collection-driven), or promotional (event-driven).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'The minimum inventory buffer maintained at the destination location to protect against demand variability and supply disruptions.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The delivery speed commitment for the replenishment shipment: standard (5-7 days), expedited (2-3 days), next_day, two_day, economy (7-10 days).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationId rdf:type rdf:Property ;
    rdfs:label 'Allocation Id' ;
    rdfs:comment 'Reference to the allocation record if this reservation has been converted to a physical allocation. Null while reservation is still pending or active.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Allocation .

ind:extendedCount rdf:type rdf:Property ;
    rdfs:label 'Extended Count' ;
    rdfs:comment 'Number of times the reservation expiry has been extended beyond the original expiry timestamp. Used to track reservation aging and potential inventory lock issues.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfilledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Timestamp' ;
    rdfs:comment 'Date and time when the reservation was converted to a physical allocation and inventory was committed for shipment or pickup. Null if not yet fulfilled.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'Sales and fulfillment channel for which inventory is reserved: ecommerce (online direct-to-consumer), retail_store (brick-and-mortar), wholesale (B2B partner), marketplace (third-party platform), bopis (buy online pick up in store), ship_from_store (store fulfillment for online orders).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardReservationFlag rdf:type rdf:Property ;
    rdfs:label 'Hard Reservation Flag' ;
    rdfs:comment 'Indicates whether this is a hard reservation (true - guaranteed allocation, cannot be overridden) or soft reservation (false - tentative hold, can be reallocated based on priority).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExtendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Extended Timestamp' ;
    rdfs:comment 'Date and time of the most recent reservation expiry extension. Null if reservation has never been extended.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User identifier or system account that last modified the reservation record. Supports change tracking and audit trail.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the reservation was released and inventory returned to the Available to Sell (ATS) pool. Null if reservation is still active.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Business-facing unique reservation number used for tracking and reference across systems and channels.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation: active (currently holding inventory), expired (reservation period elapsed), released (inventory returned to available pool), fulfilled (reservation converted to allocation), cancelled (reservation voided), pending (awaiting confirmation).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'Date and time when the inventory reservation was created in the system. Represents the business event time when stock was earmarked.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationType rdf:type rdf:Property ;
    rdfs:label 'Reservation Type' ;
    rdfs:comment 'Classification of the reservation purpose: sales order (committed to customer order), ecommerce cart (held in online shopping cart), wholesale commitment (allocated to wholesale partner), event_hold (reserved for marketing or promotional event), photo_shoot_hold (reserved for photography or content creation), sample_pull (reserved for product sampling or showroom).' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source system that initiated this reservation, enabling end-to-end traceability.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or system account that created the reservation record. Supports audit trail and accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Unique identifier for the stock valuation record.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costSheetId rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Id' ;
    rdfs:comment 'Foreign key linking to product.cost_sheet. Business justification: Standard cost variance analysis in apparel requires linking inventory valuation records to the approved cost sheet used as the standard cost basis. This supports purchase price variance reporting, mar' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostSheet .

ind:lastInventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Cycle Count Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_cycle_count. Business justification: stock_valuation tracks last_physical_count_date as a denormalized field. The authoritative source for physical count dates and results is inventory_cycle_count. Adding last_inventory_cycle_count_id to' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:agedInventoryProvision rdf:type rdf:Property ;
    rdfs:label 'Aged Inventory Provision' ;
    rdfs:comment 'Provision amount for obsolete, slow-moving, or aged inventory that may not be sold at full value. Reflects inventory obsolescence risk.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Amount' ;
    rdfs:comment 'Portion of inventory value allocated to COGS for goods sold during the period. Used for profit and loss calculation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Cost center responsible for managing this inventory (e.g., warehouse operations, retail store). Used for management accounting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUnitCost rdf:type rdf:Property ;
    rdfs:label 'Current Unit Cost' ;
    rdfs:comment 'The effective unit cost currently applied for valuation, based on the valuation method in use (standard cost or moving average price).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'General Ledger account number to which this inventory valuation is posted for balance sheet reporting.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days inventory remains in stock before being sold. Calculated as (average inventory value / COGS) × 365. Key metric for inventory efficiency.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryWriteDownAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Write Down Amount' ;
    rdfs:comment 'Total amount written down from book value to net realizable value when NRV is lower than cost. Impacts Cost of Goods Sold (COGS) and profitability.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCostUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Update Date' ;
    rdfs:comment 'Date when the unit cost (standard cost or moving average price) was last updated or recalculated.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Reserve Amount' ;
    rdfs:comment 'Reserve amount set aside to account for anticipated future markdowns on seasonal or slow-moving inventory. Reduces net realizable value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Reserve Percentage' ;
    rdfs:comment 'Percentage of total stock value reserved for anticipated markdowns, typically based on historical markdown rates and seasonal lifecycle stage.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average unit cost recalculated with each goods receipt when moving average valuation method is used.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRealizableValue rdf:type rdf:Property ;
    rdfs:label 'Net Realizable Value' ;
    rdfs:comment 'Estimated selling price in the ordinary course of business less estimated costs of completion and sale. Inventory must be valued at lower of cost or NRV.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Difference between standard cost and actual purchase price for goods received. Tracked separately in standard costing environments.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center to which this inventory valuation is attributed for profitability analysis (e.g., product line, brand, region).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalWriteDownPercentage rdf:type rdf:Property ;
    rdfs:label 'Seasonal Write Down Percentage' ;
    rdfs:comment 'Percentage write-down applied to inventory value for end-of-season or aged seasonal merchandise to reflect lower net realizable value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Predetermined unit cost used for valuation when standard costing method is applied. Includes material, labor, and overhead components.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total book value of inventory calculated as total stock quantity multiplied by current unit cost. Represents balance sheet inventory value.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Valuation Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for any manual adjustment made to the valuation (e.g., physical count variance, damage, theft, pricing error).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which this valuation snapshot was taken. Typically end-of-month (EOM) or end-of-season for financial reporting.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current status of the valuation record: active (current), frozen (locked for period close), adjusted (manual adjustment applied), written_off (inventory disposed), under_review (pending audit).' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Number of weeks the current inventory level will last based on forecasted or historical sales rate. Critical for replenishment planning.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asnShipToLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Asn Ship To Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the destination location (distribution center, warehouse, retail store, or 3PL) where goods will be received.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:asnWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Asn Warehouse Location Id' ;
    rdfs:comment 'Identifier of the origin location (supplier facility, factory, warehouse, or 3PL) from which goods are shipped.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Foreign key linking to supplier.delivery_schedule. Business justification: ASNs are generated against supplier delivery schedules in apparel critical path management. Linking ASN to delivery_schedule enables OTIF measurement — comparing actual shipment notification dates aga' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliverySchedule .

ind:packingListId rdf:type rdf:Property ;
    rdfs:label 'Packing List Id' ;
    rdfs:comment 'Foreign key linking to logistics.packing_list. Business justification: ASN contains packing list details. Linking enables receiving validation (expected vs. actual), carton-level traceability, receiving productivity measurement (scan vs. manual), and vendor compliance sc' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackingList .

ind:shipToDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Ship To Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: ASN destination is the receiving DC. Role-prefixed to distinguish from origin. Enables dock appointment scheduling, labor planning, inbound volume forecasting, and DC capacity management—critical for ' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:shipToRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Ship To Retail Store Id' ;
    rdfs:comment 'Foreign key linking to store.retail_store. Business justification: Store-bound advance ship notices must identify destination retail store for receiving appointment scheduling, dock door assignment, labor planning, and inbound logistics coordination at store receivin' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the ASN was acknowledged by the receiving system or warehouse management system.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment physically arrived at the destination location.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'Scheduled date and time for the shipment to be received at the destination facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known unique business identifier for the advance shipment notice, typically provided by supplier or 3PL.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle status of the ASN in the receiving workflow. [ENUM-REF-CANDIDATE: draft|transmitted|acknowledged|in_transit|arrived|receiving|received|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN based on shipment purpose and origin.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Commercial Invoice Number' ;
    rdfs:comment 'Commercial invoice number associated with this shipment for customs and payment reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'Shipping container identification number for ocean or intermodal freight.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsValueAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Value Amount' ;
    rdfs:comment 'Declared customs value of the shipment for duty and tax calculation purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Customs Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the customs value amount.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorAssignment rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment' ;
    rdfs:comment 'Assigned dock door or bay number at the receiving facility for unloading this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Anticipated date when the shipment will arrive at the destination location for receiving.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International commercial term defining the responsibilities and costs between buyer and seller for this shipment. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Flag indicating whether the shipment contains hazardous materials requiring special handling and compliance.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Completed Timestamp' ;
    rdfs:comment 'Date and time when physical receiving of the shipment was completed and goods were put away.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Started Timestamp' ;
    rdfs:comment 'Date and time when physical receiving of the shipment began at the destination facility.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the container or trailer for tamper detection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date when the goods were shipped from the origin location.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling requirements such as fragile, temperature-controlled, or hazardous materials.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'Supplier\'s internal reference or packing list number for this shipment.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Flag indicating whether the shipment requires temperature-controlled handling and storage.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or packages included in this ASN shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets included in this ASN shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total number of individual units (SKUs) across all line items in this ASN.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of the shipment in cubic meters.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Date and time when the ASN was electronically transmitted to the receiving system via EDI or API.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labDipId rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Id' ;
    rdfs:comment 'Foreign key linking to sourcing.lab_dip. Business justification: Dye-lot traceability: apparel quality teams trace physical inventory lots back to the approved lab dip to verify color consistency, support recall scoping by colorway, and satisfy retailer compliance ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabDip .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to product.material. Business justification: Apparel material lot tracking links fabric/trim batches to specific materials for restricted substance compliance (REACH, CPSC), sustainability certification traceability, and recall management. lot_b' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch purpose: production (regular manufacturing), sample (pre-production samples), prototype (design validation), rework (quality correction), return (customer returns).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the certification for this lot expires. Null if certification does not expire or is perpetual.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate or license number issued by the certifying body (e.g., OEKO-TEX certificate number, GOTS transaction certificate). Used for audit verification and customer transparency claims.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of industry certification held by this lot. [ENUM-REF-CANDIDATE: OEKO-TEX Standard 100|GOTS|BCI Cotton|Fair Trade|Bluesign|Cradle to Cradle|ISO 14001|WRAP|FLA|Organic Content Standard|Recycled Claim Standard — promote to reference product]' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayConsistencyGrade rdf:type rdf:Property ;
    rdfs:label 'Colorway Consistency Grade' ;
    rdfs:comment 'Quality grade for color consistency within the lot: A (excellent match), B (acceptable variation), C (minor deviation), D (noticeable deviation), F (failed, not usable). Used for quality control and customer claims resolution.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Landed Duty Paid (LDP) cost per unit for this lot, including Free on Board (FOB) cost, freight, duties, and tariffs. Used for Cost of Goods Sold (COGS) calculation and margin analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Percentage' ;
    rdfs:comment 'Percentage of defective units identified during quality inspection. Used for supplier scorecarding and Acceptable Quality Level (AQL) compliance tracking.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Status' ;
    rdfs:comment 'Current lifecycle state of the lot: active (available for use), quarantined (quality hold), consumed (fully allocated), expired (past shelf life), recalled (CPSC recall), disposed (destroyed).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business identifier for the production lot. Externally-known unique code used for traceability across supply chain partners, factories, and regulatory reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Fiber content and composition percentages for the lot (e.g., \'60% Cotton, 40% Polyester\'). Required for Federal Trade Commission (FTC) textile labeling compliance and customer product information.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:millOriginCode rdf:type rdf:Property ;
    rdfs:label 'Mill Origin Code' ;
    rdfs:comment 'Identifier of the textile mill or raw material supplier that produced the fabric or material in this lot. Critical for material traceability and certification verification.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the lot was manufactured or produced. Critical for shelf-life calculation, warranty tracking, and regulatory compliance.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current available quantity remaining in the lot after consumption and allocation. Used for Available to Sell (ATS) and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'Total quantity manufactured in this lot. Unit of measure varies by product category (units for garments, yards/meters for fabric, kilograms for raw materials).' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine Date' ;
    rdfs:comment 'Date when the lot was placed into quarantine status. Null if lot has never been quarantined.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Business reason for placing the lot in quarantine status (e.g., \'Failed color fastness test\', \'Pending certification verification\', \'Customer complaint investigation\'). Null if lot has never been quarantined.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when the recall was initiated for this lot. Null if lot has never been recalled.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this lot is subject to a Consumer Product Safety Commission (CPSC) recall or voluntary recall. True if recalled, False otherwise.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official recall identification number issued by Consumer Product Safety Commission (CPSC) or internal recall tracking number. Null if lot has never been recalled.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the lot was released from quarantine and made available for use. Null if lot has never been quarantined or is currently quarantined.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTagApplied rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Applied' ;
    rdfs:comment 'Indicates whether Radio Frequency Identification (RFID) tags have been applied to units in this lot for automated tracking and inventory accuracy. True if RFID-enabled, False otherwise.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'FK to product.bom.bom_id — MUST-HAVE: Links production work orders to the authoritative BOM in the product domain, enabling material requirements planning and cost tracking. Critical after production.bom removal.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:productionCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Production Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Production orders must allocate manufacturing costs to cost centers for standard costing, variance analysis, and factory overhead allocation—core requirement in apparel manufacturing accounting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Foreign key linking to production.routing. Business justification: Every work order executes a specific manufacturing routing that defines the sequence of operations, work centers, and standard times. This is core SAP PP functionality. The routing defines HOW to manu' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:techPackId rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Id' ;
    rdfs:comment 'Foreign key linking to product.tech_pack. Business justification: Work orders must reference the specific tech pack version issued to the factory to ensure production conforms to approved specifications. Apparel compliance and quality audits require traceability fro' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechPack .

ind:actualExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ex Factory Date' ;
    rdfs:comment 'Actual date when finished goods departed the factory. Used to measure OTIF performance and update logistics schedules.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Limit standard applied for inspection (e.g., 2.5, 4.0). Defines the maximum acceptable defect rate per ISO 2859 sampling standards.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmtType rdf:type rdf:Property ;
    rdfs:label 'Cmt Type' ;
    rdfs:comment 'Manufacturing service model defining the scope of work performed by the factory. Cut-Make-Trim includes all production steps; Make-Trim excludes cutting; Full Package includes material sourcing.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Required' ;
    rdfs:comment 'Indicates whether this work order requires compliance certifications (e.g., OEKO-TEX, GOTS, WRAP, FLA). True if certifications must be provided before shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the final destination of finished goods. Used for customs, compliance, and logistics planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producedQuantity rdf:type rdf:Property ;
    rdfs:label 'Produced Quantity' ;
    rdfs:comment 'Actual quantity completed and confirmed through production execution. Updated as production progresses and goods are received.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionEndDate rdf:type rdf:Property ;
    rdfs:label 'Production End Date' ;
    rdfs:comment 'Planned or actual date when production execution is completed. Marks readiness for final inspection and shipment preparation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Planned or actual date when production execution begins at the factory. Key milestone in Time and Action (TNA) calendar.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of quality inspection for this work order. Passed status is required before goods can be shipped.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity rejected during quality inspection. Represents units that failed quality standards and cannot be shipped.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPpOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Pp Order Number' ;
    rdfs:comment 'SAP S/4HANA PP module production order number. System of record identifier linking this work order to the ERP production planning system.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMode rdf:type rdf:Property ;
    rdfs:label 'Shipping Mode' ;
    rdfs:comment 'Primary transportation mode for delivering finished goods from factory to destination. Impacts lead time and logistics cost.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Target Ex Factory Date' ;
    rdfs:comment 'Target date for goods to leave the factory. Critical milestone for logistics planning and On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User ID or name of the person who last modified this work order. Audit trail for change tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known business identifier for the work order. Human-readable unique reference used across manufacturing systems and communications with factory partners.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order. Tracks progression from initial creation through production execution to final closure. [ENUM-REF-CANDIDATE: draft|released|confirmed|in_progress|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderOperationId rdf:type rdf:Property ;
    rdfs:label 'Work Order Operation Id' ;
    rdfs:comment 'Unique identifier for the work order operation. Primary key for this entity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderOperation .

ind:operationCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Operation Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Individual operations require cost center assignment for activity-based costing, labor cost allocation by department, and detailed production cost variance analysis—standard in apparel manufacturing c' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Reference to the work center (production resource or machine) where this operation is performed. Links to factory floor resources.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual time taken to complete this operation, measured in minutes. Used to calculate efficiency variance against SAM.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the operation execution was completed on the factory floor, captured from production confirmation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the operation execution began on the factory floor, captured from production confirmation.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Unique confirmation document number generated when the operation is confirmed in the system, linking to goods movement and time confirmation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the operation was confirmed in the system, marking the official completion record.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'SAP control key that determines how the operation is processed, including scheduling, costing, and confirmation requirements (e.g., PP01, PP02, PP03).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the operation cost amount (e.g., USD, EUR, CNY, INR, BDT).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Efficiency Percentage' ;
    rdfs:comment 'Operation efficiency calculated as (standard_allowed_minutes / actual_duration_minutes) * 100. Measures operator and work center performance against standard.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Factory Location Code' ;
    rdfs:comment 'Three-letter code identifying the manufacturing facility or factory where this operation is performed (e.g., BDH for Bangladesh Dhaka, CNS for China Shenzhen).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Quality inspection lot number assigned to this operation for tracking quality control results and defects.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether quality inspection is required after completing this operation. True if inspection is mandatory, False otherwise.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours consumed for this operation, including direct production time, setup, and teardown. Used for labor costing and capacity analysis.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineHours rdf:type rdf:Property ;
    rdfs:label 'Machine Hours' ;
    rdfs:comment 'Total machine or equipment hours utilized for this operation. Used for machine costing and utilization tracking.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCode rdf:type rdf:Property ;
    rdfs:label 'Operation Code' ;
    rdfs:comment 'Standardized code identifying the type of manufacturing operation (e.g., CUT, SEW, FINISH, PRESS, PACK, INSPECT, EMBROIDER, PRINT).' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Operation Cost Amount' ;
    rdfs:comment 'Total cost incurred for this operation, including labor, machine, overhead, and material costs. Used for production costing and variance analysis.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Detailed textual description of the manufacturing operation, including specific instructions, techniques, or requirements for execution.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'The unique operation number within the routing sequence, typically a 4-digit code (e.g., 0010, 0020, 0030) that defines the order of manufacturing steps.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'Sequential order of this operation within the work order routing. Determines the execution order of manufacturing steps.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow. [ENUM-REF-CANDIDATE: planned|released|in_progress|completed|confirmed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when this operation is planned to be completed based on standard times and production scheduling.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity of units planned to be processed in this operation based on the work order requirements.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when this operation is planned to begin execution based on production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier for the production line or assembly line where this operation is executed. Used for line balancing and capacity planning.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality inspection result status for this operation indicating whether output meets quality standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of units requiring rework or reprocessing due to quality issues identified during or after this operation.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of units rejected or scrapped during this operation due to quality defects or production errors.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Time required to prepare the work center, tools, and materials before starting production for this operation, measured in minutes.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift during which this operation was executed. Used for shift performance analysis and labor scheduling.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardAllowedMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Allowed Minutes' ;
    rdfs:comment 'Standard time allocated for completing this operation per unit, measured in minutes. Used for capacity planning, costing, and efficiency measurement in apparel manufacturing.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Time required to clean up, reset, or prepare the work center for the next operation after completing this operation, measured in minutes.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Percentage of good output relative to input for this operation, calculated as (confirmed_quantity / planned_quantity) * 100. Key metric for production efficiency.' ;
    rdfs:domain ind:WorkOrderOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production order confirmation record. Primary key for the goods confirmation transaction.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to production.lot. Business justification: An order_confirmation records actual goods output (yield_quantity, scrap_quantity, rework_quantity) against a work_order_operation. In CMT apparel manufacturing, confirmations are posted at the lot/ba' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:reversedConfirmationOrderConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Confirmation Order Confirmation Id' ;
    rdfs:comment 'Reference to the original confirmation record that this reversal transaction is cancelling. Creates audit trail for corrections.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderConfirmation .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Classification of the production activity performed during this operation. Used for activity-based costing and capacity planning.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'The total number of labor hours consumed to complete this operation. Used for labor cost calculation and capacity planning.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineHours rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Hours' ;
    rdfs:comment 'The total number of machine or equipment hours utilized during this operation. Used for equipment utilization analysis and maintenance scheduling.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether component materials were automatically consumed via backflushing when this confirmation was posted. Used for automated material consumption.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The production batch or lot number assigned to the output from this confirmation. Used for traceability and quality control.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The calendar date on which the production activity was completed and confirmed. Represents the actual manufacturing event date.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the confirmation record indicating whether it is in draft, submitted for approval, posted to inventory, cancelled, or reversed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation transaction indicating whether this is a partial completion, final completion, milestone achievement, rework confirmation, or scrap reporting.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConfirmationIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Indicator' ;
    rdfs:comment 'Indicates whether this is the final confirmation for the operation, signaling that no further output is expected and the operation can be closed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsMovementPosted rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Posted' ;
    rdfs:comment 'Indicates whether the confirmed quantities have been posted to inventory through a goods receipt transaction. Links confirmation to inventory update.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The material document number generated when confirmed output was posted to inventory. Used for inventory reconciliation and traceability.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether this confirmation triggers a mandatory quality inspection before the output can be moved to finished goods inventory.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:setupTimeHours rdf:type rdf:Property ;
    rdfs:label 'Setup Time Hours' ;
    rdfs:comment 'The time spent preparing equipment, tooling, and materials before production could begin. Separate from actual production time.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeHours rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Hours' ;
    rdfs:comment 'The time spent cleaning, resetting, or breaking down equipment after the production operation was completed.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text explanation providing additional context about production variances, quality issues, or operational challenges encountered during this confirmation.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating the reason for any variance between planned and actual quantities or times. Used for root cause analysis of production inefficiencies.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The actual quantity of good output produced and confirmed for this operation. Represents conforming units that passed quality inspection.' ;
    rdfs:domain ind:OrderConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the factory is currently active and available for new production orders. Inactive factories are retained for historical reference but excluded from sourcing and planning.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the factory facility. Used for shipping, audits, and official correspondence.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as building name, floor, or suite number.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedCapacityUnitsPerWeek rdf:type rdf:Property ;
    rdfs:label 'Certified Capacity Units Per Week' ;
    rdfs:comment 'Maximum production capacity in units per week as certified by the factory and validated through capacity audits. Used for production planning and allocation decisions.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees working at the factory. Used for capacity assessment, social compliance monitoring, and risk evaluation.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilitySizeSqm rdf:type rdf:Property ;
    rdfs:label 'Facility Size Sqm' ;
    rdfs:comment 'Total floor area of the factory in square meters. Used for capacity planning and facility assessment.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryCode rdf:type rdf:Property ;
    rdfs:label 'Factory Code' ;
    rdfs:comment 'Externally-known unique business identifier for the factory, used across systems and documentation. Typically alphanumeric code assigned during factory onboarding.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryName rdf:type rdf:Property ;
    rdfs:label 'Factory Name' ;
    rdfs:comment 'Common business name of the manufacturing facility as used in operational communications and planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryType rdf:type rdf:Property ;
    rdfs:label 'Factory Type' ;
    rdfs:comment 'Classification of the manufacturing relationship model. CMT (Cut Make Trim) = factory provides labor only; OEM (Original Equipment Manufacturer) = factory manufactures to buyer specs; ODM (Original Design Manufacturer) = factory provides design and manufacturing; INTERNAL = company-owned facility; HYBRID = mixed model; SUBCONTRACTOR = secondary tier supplier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance or quality audit conducted at the factory. Used to track audit recency and schedule follow-up audits.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next compliance or quality audit. Used for audit planning and vendor compliance monitoring.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifPerformancePct rdf:type rdf:Property ;
    rdfs:label 'Otif Performance Pct' ;
    rdfs:comment 'Percentage of orders delivered On Time In Full over the trailing 12 months. Key performance indicator for factory reliability and used in allocation decisions.' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this factory has preferred vendor status based on performance, quality, compliance, and strategic relationship. Preferred vendors receive priority allocation and longer-term commitments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionCapabilities rdf:type rdf:Property ;
    rdfs:label 'Production Capabilities' ;
    rdfs:comment 'Comma-separated list of product categories and manufacturing techniques the factory is equipped to produce (e.g., woven, knit, denim, footwear, accessories, leather goods, outerwear, activewear, swimwear, intimate apparel).' ;
    rdfs:domain ind:ProductionFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Letter grade quality rating based on defect rates, inspection results, and customer returns. A = excellent (defect rate <1%), B = good (1-2%), C = acceptable (2-4%), D = needs improvement (4-6%), F = unacceptable (>6%).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk classification for the factory based on compliance history, audit findings, geographic risk, and operational stability. Used for sourcing decisions and monitoring frequency.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Composite sustainability score (0-100) based on environmental practices, energy efficiency, waste management, water usage, and chemical compliance. Used for ESG reporting and sustainable sourcing initiatives.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Capacity planning by product category (knits vs wovens, footwear vs apparel) reflects different machine/skill requirements. Enables category-level capacity allocation and booking. Removes denormalized' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:allocatedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity Units' ;
    rdfs:comment 'Production capacity units already allocated to confirmed purchase orders (PO) or work orders during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Units' ;
    rdfs:comment 'Remaining production capacity units available for new bookings, calculated as total capacity minus allocated and reserved capacity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableLaborHours rdf:type rdf:Property ;
    rdfs:label 'Available Labor Hours' ;
    rdfs:comment 'Total labor hours available for production during the planning period, based on workforce headcount and shift schedules.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableMachineHours rdf:type rdf:Property ;
    rdfs:label 'Available Machine Hours' ;
    rdfs:comment 'Total machine hours available for production during the planning period, accounting for scheduled maintenance and downtime.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Booking Cutoff Date' ;
    rdfs:comment 'Last date by which new production orders can be booked for this capacity period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current booking status of the capacity period, indicating whether additional orders can be accepted.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAllocationPriority rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Priority' ;
    rdfs:comment 'Priority level for capacity allocation, used to manage competing demands from multiple customers or product lines.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityBufferPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Buffer Percent' ;
    rdfs:comment 'Safety buffer percentage applied to capacity planning to account for variability, quality issues, or unexpected delays.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Operational status of the factory or production line during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to express production capacity (e.g., pieces, garments, dozens, pairs).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficiencyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Rate Percent' ;
    rdfs:comment 'Factory or production line efficiency rate as a percentage, representing actual output versus theoretical maximum capacity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineCount rdf:type rdf:Property ;
    rdfs:label 'Machine Count' ;
    rdfs:comment 'Total number of production machines or equipment units available during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity (MOQ) in units that the factory requires for accepting new production bookings during this period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeHoursAvailable rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Available' ;
    rdfs:comment 'Additional overtime hours available for production if needed to meet demand during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Total hours of planned downtime for maintenance, changeovers, or scheduled breaks during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the capacity planning period (weekly or monthly bucket).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the capacity planning period (weekly or monthly bucket).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the capacity planning period (daily, weekly, or monthly).' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Reserved Capacity Units' ;
    rdfs:comment 'Production capacity units reserved for specific seasons, collections, or customers but not yet confirmed by purchase order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCount rdf:type rdf:Property ;
    rdfs:label 'Shift Count' ;
    rdfs:comment 'Number of production shifts per day during the planning period (e.g., 1, 2, or 3 shifts).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardMinuteValue rdf:type rdf:Property ;
    rdfs:label 'Standard Minute Value' ;
    rdfs:comment 'Average standard minute value (SMV) per unit for the product mix planned during this capacity period, used for capacity calculation.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Units' ;
    rdfs:comment 'Total production capacity expressed in units (pieces, garments, or SKUs) that can be manufactured during the planning period.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Capacity utilization rate as a percentage, calculated as allocated capacity divided by total available capacity.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of production workers assigned to the factory or production line during the planning period.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'Number of working days available during the planning period, excluding holidays and factory closures.' ;
    rdfs:domain ind:FactoryCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique identifier for the production schedule record. Primary key for the master production schedule (MPS) entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:deliveryWindowId rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Id' ;
    rdfs:comment 'Reference to the target delivery window or time bucket for finished goods. Aligns production schedule with retail distribution calendar and store delivery requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryWindow .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Reference to the specific production line or work center within the factory allocated for this schedule. Represents the capacity slot assignment.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:actualCutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cut Date' ;
    rdfs:comment 'Actual date when fabric cutting operations began. Used for On-Time In-Full (OTIF) performance tracking and schedule variance analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFinishingDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finishing Date' ;
    rdfs:comment 'Actual date when finishing operations completed. Used for quality gate tracking and final production milestone confirmation.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSewEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual Sew End Date' ;
    rdfs:comment 'Actual date when sewing operations completed. Used for cycle time analysis and production efficiency measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSewStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Sew Start Date' ;
    rdfs:comment 'Actual date when sewing operations commenced. Used for production milestone tracking and factory performance measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason for the most recent schedule change or revision. Captures rationale for date shifts, quantity adjustments, or factory reassignments to support root cause analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this schedule is on the critical path for seasonal delivery. True for schedules with no slack time that directly impact retail delivery deadlines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:factoryCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Factory Capacity Utilization Pct' ;
    rdfs:comment 'Percentage of factory production line capacity consumed by this schedule. Used for capacity planning and factory loading optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier of the person who most recently updated this production schedule record. Used for accountability and change management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedBy rdf:type rdf:Property ;
    rdfs:label 'Locked By' ;
    rdfs:comment 'User identifier of the planner or manager who locked this schedule. Locked schedules are committed to factory and cannot be changed without approval.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Locked Timestamp' ;
    rdfs:comment 'Date and time when this schedule was locked. Marks the point when the schedule became committed and change-controlled.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Target Flag' ;
    rdfs:comment 'Indicates whether this schedule met the On-Time In-Full (OTIF) delivery target. True if actual ex-factory date matched planned date and full quantity was delivered.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCutDate rdf:type rdf:Property ;
    rdfs:label 'Planned Cut Date' ;
    rdfs:comment 'Scheduled date for fabric cutting operations to begin. First milestone in the Cut-Make-Trim (CMT) production process, marking when raw materials are cut into garment pieces.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedExFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ex Factory Date' ;
    rdfs:comment 'Scheduled date for finished goods to leave the factory. Critical milestone for Free On Board (FOB) shipment and supply chain handoff to logistics partners.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFinishingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finishing Date' ;
    rdfs:comment 'Scheduled date for finishing operations including washing, pressing, quality inspection, and packaging. Final production milestone before ex-factory shipment.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSewEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Sew End Date' ;
    rdfs:comment 'Scheduled date for sewing operations to complete. Marks the end of garment assembly before finishing operations begin.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSewStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Sew Start Date' ;
    rdfs:comment 'Scheduled date for sewing operations to commence. Marks the beginning of garment assembly on the production line.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group or team responsible for this schedule. Used for workload distribution and organizational reporting.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionMethod rdf:type rdf:Property ;
    rdfs:label 'Production Method' ;
    rdfs:comment 'Manufacturing model for this production schedule. Cut-Make-Trim (CMT) is contract manufacturing, Free On Board (FOB) is full-package manufacturing, Original Design Manufacturer (ODM) provides design and manufacturing, Original Equipment Manufacturer (OEM) manufactures to buyer specifications, and in-house is internal production.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of production run type. Pre-production (PP) samples are for approval, bulk production is main volume manufacturing, pilot runs are small test batches, and reorders are repeat production of proven styles.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the production schedule record. Human-readable schedule number used in communications with factory partners and internal planning teams.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the production schedule. Draft schedules are under planning, confirmed schedules are committed to factory, locked schedules cannot be changed, in-progress schedules are actively executing, completed schedules are finished, cancelled schedules are voided, and on-hold schedules are temporarily suspended. [ENUM-REF-CANDIDATE: draft|confirmed|locked|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'Total quantity of units scheduled for production in this schedule record. Represents the planned output volume for the production run.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeDate rdf:type rdf:Property ;
    rdfs:label 'Change Date' ;
    rdfs:comment 'Date when the most recent schedule change was made. Used for change frequency analysis and schedule stability measurement.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionTnaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Production Tna Milestone Id' ;
    rdfs:comment 'Unique identifier for the Time and Action milestone record. Primary key for tracking critical production lifecycle events.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionTnaMilestone .

ind:approverContactId rdf:type rdf:Property ;
    rdfs:label 'Approver Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Critical TNA milestones (fabric approval, sample approval, shipment authorization) require buyer contact approval in B2B workflows. Linking enables approval routing, notification, and compliance track' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:bulkFabricReceiptId rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Receipt Id' ;
    rdfs:comment 'Foreign key linking to production.bulk_fabric_receipt. Business justification: T&A calendars track fabric receipt as a critical milestone (milestone_type = \'FABRIC_RECEIPT\', \'FABRIC_INSPECTION_COMPLETE\'). When a T&A milestone represents a fabric receipt event, it must reference ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BulkFabricReceipt .

ind:cutOrderId rdf:type rdf:Property ;
    rdfs:label 'Cut Order Id' ;
    rdfs:comment 'Foreign key linking to production.cut_order. Business justification: T&A calendars in apparel production track cutting milestones (fabric cut date, cut completion) as critical path events. When a T&A milestone represents a cutting event (milestone_type = \'CUT_START\', \'' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CutOrder .

ind:ppSampleId rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Id' ;
    rdfs:comment 'Foreign key linking to production.pp_sample. Business justification: Time and Action (T&A) calendars in apparel production explicitly track sample submission and approval milestones (proto sample, fit sample, PP sample, TOP sample). When a T&A milestone represents a sa' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpSample .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual date when the milestone was achieved or completed. Used for OTIF (On Time In Full) performance measurement and variance analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'Precise timestamp when the milestone was completed, including time of day. Provides granular tracking for time-sensitive milestones and shift-level analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Flag indicating whether this milestone requires formal approval before proceeding to the next stage (e.g., PP sample approval, fabric approval). True if approval gate exists.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes about this milestone execution. Captures additional context, issues, or observations from the responsible party or production team.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysVariance rdf:type rdf:Property ;
    rdfs:label 'Days Variance' ;
    rdfs:comment 'Number of days difference between planned (or revised) date and actual date. Positive values indicate delay, negative values indicate early completion. Key metric for OTIF performance.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for milestone delay if the milestone was not achieved on time. Used for root cause analysis and process improvement. Null if milestone was on time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'Detailed description or notes explaining the reason for the delay. Provides context beyond the standardized delay reason code. Null if milestone was on time.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Flag indicating whether this milestone is on the critical path for the production schedule. True if any delay to this milestone will delay the overall ex-factory date.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomerVisible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Visible' ;
    rdfs:comment 'Flag indicating whether this milestone is visible to the customer or buyer in external milestone tracking reports. True for customer-facing milestones like PP sample approval and ex-factory.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Sequential order of this milestone within the production lifecycle for the work order or style. Used to establish the chronological flow of production events.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current execution status of the milestone. Indicates whether the milestone is pending, in-progress, completed, overdue, cancelled, or on hold.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'The type of production milestone being tracked. Defines the specific critical event in the Time and Action calendar (fabric approval, PP sample submission/approval, bulk fabric receipt, cut start, sew start, finishing, QC inspection, ex-factory, cargo receipt). [ENUM-REF-CANDIDATE: fabric_approval|pp_sample_submission|pp_sample_approval|bulk_fabric_receipt|cut_start|sew_start|finishing_start|qc_inspection|ex_factory|cargo_receipt — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Original planned date for achieving this milestone as defined in the initial Time and Action calendar. Baseline for measuring schedule adherence.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'External purchase order number from the buyer or customer associated with this production milestone. Used for customer-facing milestone reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAtMilestone rdf:type rdf:Property ;
    rdfs:label 'Quantity At Milestone' ;
    rdfs:comment 'The quantity of units (pieces, garments, SKUs) that reached this milestone. Enables tracking of partial completions and yield analysis across production stages.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedBy rdf:type rdf:Property ;
    rdfs:label 'Recorded By' ;
    rdfs:comment 'Name or identifier of the user or system that recorded this milestone completion. Provides audit trail for data entry accountability.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Timestamp when this milestone record was created or updated in the system. Distinct from actual_timestamp which represents the real-world event time.' ;
    rdfs:domain ind:ProductionTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the party responsible for this milestone. Denormalized for reporting convenience and historical tracking even if party master data changes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'The type of party responsible for completing this milestone (internal team, factory, supplier, vendor, logistics provider, quality agency). Categorizes accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedDate rdf:type rdf:Property ;
    rdfs:label 'Revised Date' ;
    rdfs:comment 'Updated target date for the milestone if the original plan was revised. Captures schedule adjustments due to delays, expedites, or other changes. Null if no revision occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Pre-production sample charges are invoiced by factories and tracked as AP items — the \'Sample Cost Management\' process in apparel product development. Finance teams reconcile sample_cost against AP in' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:reviewerContactId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Wholesale buyer contacts are the named individuals who review and approve samples. Linking to contact enables approval workflow routing, notification delivery, and audit trail of who approved what. re' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:constructionApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Construction Approval Status' ;
    rdfs:comment 'Specific approval decision for the construction dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionComments rdf:type rdf:Property ;
    rdfs:label 'Construction Comments' ;
    rdfs:comment 'Consolidated feedback on the construction quality, stitching, and assembly of the sample.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Issue Flag' ;
    rdfs:comment 'Indicates whether the sample has critical defects that must be resolved before production (True = critical issues present, False = no critical issues).' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fabricApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Status' ;
    rdfs:comment 'Specific approval decision for the fabric dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricComments rdf:type rdf:Property ;
    rdfs:label 'Fabric Comments' ;
    rdfs:comment 'Feedback on fabric quality, hand feel, color accuracy, and material performance.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fit Approval Status' ;
    rdfs:comment 'Specific approval decision for the fit dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitComments rdf:type rdf:Property ;
    rdfs:label 'Fit Comments' ;
    rdfs:comment 'Consolidated feedback on the fit and sizing of the sample garment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueSeverity rdf:type rdf:Property ;
    rdfs:label 'Issue Severity' ;
    rdfs:comment 'Overall severity classification of issues found during sample review.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Labeling Approval Status' ;
    rdfs:comment 'Specific approval decision for the labeling dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingComments rdf:type rdf:Property ;
    rdfs:label 'Labeling Comments' ;
    rdfs:comment 'Feedback on care labels, brand labels, size tags, and regulatory labeling compliance.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallComments rdf:type rdf:Property ;
    rdfs:label 'Overall Comments' ;
    rdfs:comment 'General feedback and summary notes from the review team covering all aspects of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Approval Status' ;
    rdfs:comment 'Specific approval decision for the packaging dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingComments rdf:type rdf:Property ;
    rdfs:label 'Packaging Comments' ;
    rdfs:comment 'Feedback on packaging materials, folding, hangtags, and presentation.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the sample was physically received by the brand or design team for evaluation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of issue resolution and corrective action implementation.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Target date by which the sample review and approval decision must be completed.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionRound rdf:type rdf:Property ;
    rdfs:label 'Revision Round' ;
    rdfs:comment 'Sequential number indicating which iteration of the sample this represents (1 = first submission, 2 = first revision, etc.).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Business identifier for the sample, typically assigned by the PLM or production system.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample stage in the pre-production workflow (PP1 = first pre-production sample, PP2 = second pre-production sample, TOP = top of production, Salesman = sales sample, Photoshoot = marketing sample). [ENUM-REF-CANDIDATE: PP1|PP2|TOP|Salesman|Photoshoot|Size Set|Fit|Proto — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size of the sample garment (e.g., S, M, L, XL, or numeric sizing).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the sample was submitted for review by the factory or supplier.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetProductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Production Date' ;
    rdfs:comment 'Planned date for bulk production to commence following sample approval.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:techPackVersion rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Version' ;
    rdfs:comment 'Version number of the technical specification package that this sample was produced against.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Status' ;
    rdfs:comment 'Specific approval decision for the trim dimension of the sample.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimComments rdf:type rdf:Property ;
    rdfs:label 'Trim Comments' ;
    rdfs:comment 'Feedback on trims, accessories, buttons, zippers, and embellishments.' ;
    rdfs:domain ind:PpSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForProductionDate rdf:type rdf:Property ;
    rdfs:label 'Approved For Production Date' ;
    rdfs:comment 'The date on which the fabric was officially approved and released for use in production cutting. Gates the start of cutting operations.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aqlInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Aql Inspection Result' ;
    rdfs:comment 'The outcome of the AQL-based statistical sampling inspection. Indicates whether the fabric lot meets the agreed quality standards.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFastnessResult rdf:type rdf:Property ;
    rdfs:label 'Color Fastness Result' ;
    rdfs:comment 'The outcome of the color fastness test, indicating whether the fabric color is resistant to fading or bleeding during washing, rubbing, or light exposure.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'The total number of defects identified during the fabric inspection. Used to calculate defect rate and determine acceptance or rejection.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Description of the primary types of defects found during inspection (e.g., holes, stains, weaving flaws, color inconsistency). Supports root cause analysis and supplier feedback.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The originally scheduled delivery date from the purchase order or supplier commitment. Used to calculate delivery performance and OTIF metrics.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The date on which the fabric quality inspection was completed. Used to track inspection cycle time and compliance with receiving procedures.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'The current status of the quality inspection process for the received fabric. Determines whether the fabric can be released for cutting.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'The name of the quality inspector who performed the fabric inspection. Supports accountability and quality audit trails.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListNumber rdf:type rdf:Property ;
    rdfs:label 'Packing List Number' ;
    rdfs:comment 'The packing list or delivery note number accompanying the fabric shipment. Used for cross-verification during receiving and inspection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date on which the fabric was physically received at the CMT factory. Gates the earliest possible cut-start date for production scheduling.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'The overall status of the fabric receipt in the factory workflow. Tracks progression from physical receipt through inspection to production release.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The precise date and time when the fabric receipt was recorded in the warehouse management system. Supports detailed logistics and lead time analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for capturing additional notes, observations, or special handling instructions related to the fabric receipt. Supports communication between receiving, quality, and production teams.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollCount rdf:type rdf:Property ;
    rdfs:label 'Roll Count' ;
    rdfs:comment 'The number of fabric rolls received in this shipment. Used for physical inventory verification and warehouse space planning.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shadeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Shade Lot Number' ;
    rdfs:comment 'The dye lot or shade lot number assigned by the mill. Ensures color consistency within a production run, as different lots may have slight color variations.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkagePercentageLength rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Percentage Length' ;
    rdfs:comment 'The measured shrinkage percentage in the length (warp) direction after washing. Used to verify compliance with technical specifications.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkagePercentageWidth rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Percentage Width' ;
    rdfs:comment 'The measured shrinkage percentage in the width (weft) direction after washing. Used to verify compliance with technical specifications.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageTestResult rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Test Result' ;
    rdfs:comment 'The outcome of the fabric shrinkage test, indicating whether the fabric meets the specified shrinkage tolerance after washing. Critical for garment fit and quality.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The warehouse location or bin where the received fabric is stored. Supports efficient material retrieval for cutting operations.' ;
    rdfs:domain ind:BulkFabricReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuttingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Cutting Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cutting operations track cost centers for fabric utilization efficiency, cutting department cost allocation, and marker efficiency variance analysis—standard in apparel production costing.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:markerId rdf:type rdf:Property ;
    rdfs:label 'Marker Id' ;
    rdfs:comment 'Reference to the CAD marker layout used for this cut. The marker defines the pattern piece arrangement on fabric for optimal material utilization.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Marker .

ind:actualPanelsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Panels Count' ;
    rdfs:comment 'Actual number of fabric panels cut during execution. Used for yield tracking and quality control.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleTicketGenerated rdf:type rdf:Property ;
    rdfs:label 'Bundle Ticket Generated' ;
    rdfs:comment 'Indicates whether bundle tickets have been generated for the cut panels to track them through sewing operations. True when cut panels are bundled and tagged for downstream workflow.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutDate rdf:type rdf:Property ;
    rdfs:label 'Cut Date' ;
    rdfs:comment 'The date on which the cutting operation was executed. Primary business event timestamp for this cut order.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Cut Efficiency Percentage' ;
    rdfs:comment 'Actual cutting efficiency achieved versus the marker plan, expressed as a percentage. Calculated as (actual fabric consumed / planned fabric consumption) * 100. Key KPI for material utilization and waste reduction.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cut End Timestamp' ;
    rdfs:comment 'Precise timestamp when the cutting operation was completed. Used for cycle time calculation and throughput analysis.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Cut Order Number' ;
    rdfs:comment 'Business identifier for the cut order, externally visible and used for tracking and communication with cut room supervisors and production planners.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cut Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the cutting operation began. Used for cycle time analysis and labor productivity tracking.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutStatus rdf:type rdf:Property ;
    rdfs:label 'Cut Status' ;
    rdfs:comment 'Current lifecycle status of the cut order. Tracks progression through the cutting workflow and gates downstream sewing operations.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuttingMachineCode rdf:type rdf:Property ;
    rdfs:label 'Cutting Machine Code' ;
    rdfs:comment 'Reference to the cutting equipment used (manual table, straight knife, die cutter, laser cutter, automated spreader). Links to equipment asset master.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectNotes rdf:type rdf:Property ;
    rdfs:label 'Defect Notes' ;
    rdfs:comment 'Free-text description of defects encountered during cutting (e.g., fabric flaws, miscuts, pattern misalignment). Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricConsumptionPerUnit rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Per Unit' ;
    rdfs:comment 'Planned fabric consumption per garment unit based on marker efficiency, measured in meters or yards. Used for material costing and yield analysis.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricConsumptionUom rdf:type rdf:Property ;
    rdfs:label 'Fabric Consumption Uom' ;
    rdfs:comment 'Unit of measure for fabric consumption (meters, yards, or feet).' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Marker Efficiency Percentage' ;
    rdfs:comment 'Theoretical marker efficiency from the CAD marker layout, representing the percentage of fabric utilized in the marker versus waste. Baseline for cut efficiency comparison.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markerReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Marker Reference Code' ;
    rdfs:comment 'External marker code from CAD system used for cross-reference and traceability to the digital marker file.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPanelsCount rdf:type rdf:Property ;
    rdfs:label 'Planned Panels Count' ;
    rdfs:comment 'Number of fabric panels planned to be cut based on the marker layout and order quantity.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plyCount rdf:type rdf:Property ;
    rdfs:label 'Ply Count' ;
    rdfs:comment 'Number of fabric layers (plies) stacked and cut simultaneously in this cut order. Higher ply counts improve efficiency but require precision equipment.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledCutDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Cut Date' ;
    rdfs:comment 'Originally planned date for the cutting operation based on production scheduling and TNA (Time and Action) calendar.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sizeRatioBreakdown rdf:type rdf:Property ;
    rdfs:label 'Size Ratio Breakdown' ;
    rdfs:comment 'Size distribution for this cut order, typically expressed as ratio notation (e.g., XS:2, S:4, M:6, L:4, XL:2). Defines the quantity of each size to be cut.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFabricAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Fabric Allocated' ;
    rdfs:comment 'Total fabric quantity allocated to this cut order in the specified unit of measure. Represents the material reservation for this cutting operation.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFabricConsumed rdf:type rdf:Property ;
    rdfs:label 'Total Fabric Consumed' ;
    rdfs:comment 'Actual fabric quantity consumed during cutting execution. Captured post-cut for variance analysis and material accounting.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsCut rdf:type rdf:Property ;
    rdfs:label 'Total Units Cut' ;
    rdfs:comment 'Actual number of garment units cut and passed to downstream sewing operations. May differ from planned due to fabric defects or cutting errors.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Units Planned' ;
    rdfs:comment 'Total number of garment units planned to be produced from this cut order across all sizes.' ;
    rdfs:domain ind:CutOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmtCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cmt Cost Per Unit' ;
    rdfs:comment 'Calculated CMT (Cut Make Trim) cost per unit based on total SAM, labor rates, and overhead allocation. Used for product costing and pricing decisions.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complexityRating rdf:type rdf:Property ;
    rdfs:label 'Complexity Rating' ;
    rdfs:comment 'Overall complexity rating of this routing based on number of operations, skill requirements, and technical difficulty. Used for capacity planning and factory assignment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathOperations rdf:type rdf:Property ;
    rdfs:label 'Critical Path Operations' ;
    rdfs:comment 'Comma-separated list of operation sequence numbers that form the critical path for this routing. These operations determine the minimum production time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when this routing record was last modified. Used to track routing changes and improvements over time.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineBalancingTarget rdf:type rdf:Property ;
    rdfs:label 'Line Balancing Target' ;
    rdfs:comment 'Target line balancing efficiency percentage for this routing. Represents the ideal distribution of work across operations to minimize bottlenecks.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTypeRequirements rdf:type rdf:Property ;
    rdfs:label 'Machine Type Requirements' ;
    rdfs:comment 'Comma-separated list of machine types required to execute this routing (e.g., single needle, overlock, flatlock, buttonhole, bartack, pressing).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum production batch size that this routing can handle without requiring line reconfiguration or additional resources.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum production batch size for which this routing is economically viable. Below this quantity, setup costs make production inefficient.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'Total number of discrete manufacturing operations defined in this routing sequence.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineType rdf:type rdf:Property ;
    rdfs:label 'Production Line Type' ;
    rdfs:comment 'Type of production line configuration required for this routing. Modular lines use flexible workstations, progressive bundle systems move work in batches, unit production systems use overhead conveyors, and lean cells use cellular manufacturing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckPoints rdf:type rdf:Property ;
    rdfs:label 'Quality Check Points' ;
    rdfs:comment 'Number of quality inspection checkpoints defined within this routing sequence to ensure product quality standards.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'Business identifier for the routing, typically a combination of style code and factory code.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed description of the manufacturing routing including special instructions, quality requirements, and production notes.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingName rdf:type rdf:Property ;
    rdfs:label 'Routing Name' ;
    rdfs:comment 'Descriptive name of the routing, typically including style name and factory name for easy identification.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Draft routings are under development, approved routings are ready for use, active routings are in production, inactive routings are temporarily suspended, and obsolete routings are retired.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing based on its purpose. Standard routings are the default process, alternative routings are backup options, prototype routings are for PP (Pre-Production) samples, sample routings are for SMS (Sample Management System), and bulk production routings are for high-volume manufacturing.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevelRequirements rdf:type rdf:Property ;
    rdfs:label 'Skill Level Requirements' ;
    rdfs:comment 'Minimum operator skill level required to execute this routing. Used for workforce planning and training needs assessment.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Required' ;
    rdfs:comment 'Comma-separated list of special equipment or tools required for this routing beyond standard sewing machines (e.g., heat press, ultrasonic welder, laser cutter, embroidery machine).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEfficiencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Efficiency Percentage' ;
    rdfs:comment 'Target production efficiency percentage for this routing. Used to calculate expected output and labor costs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOutputPerHour rdf:type rdf:Property ;
    rdfs:label 'Target Output Per Hour' ;
    rdfs:comment 'Expected number of units that can be produced per hour when this routing is executed at standard efficiency.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSam rdf:type rdf:Property ;
    rdfs:label 'Total Sam' ;
    rdfs:comment 'Total Standard Allowed Minutes for completing all operations in the routing. Used for capacity planning, CMT (Cut Make Trim) cost calculation, and labor costing. Sum of SAM values across all operations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Capacity category code used for grouping work centers with similar capacity characteristics in capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Day' ;
    rdfs:comment 'Available production capacity of the work center measured in hours per day. Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID of the person who created this work center record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Type of production department this work center belongs to within the apparel manufacturing process. [ENUM-REF-CANDIDATE: cutting|sewing|finishing|pressing|packing|embroidery|printing|quality_inspection — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulaKey rdf:type rdf:Property ;
    rdfs:label 'Formula Key' ;
    rdfs:comment 'Key identifying the formula used to calculate standard values (setup time, machine time, labor time) for operations at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Labor Time Per Unit Minutes' ;
    rdfs:comment 'Standard labor time per production unit, measured in minutes. Used for workforce planning and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID of the person who last modified this work center record.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Physical location description within the factory (e.g., Building A Floor 2, Production Hall 3 Zone B).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Machine Time Per Unit Minutes' ;
    rdfs:comment 'Standard machine processing time per production unit, measured in minutes. Used for capacity planning and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Move Time Minutes' ;
    rdfs:comment 'Standard time required to move materials to the next work center after operation completion, measured in minutes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfMachines rdf:type rdf:Property ;
    rdfs:label 'Number Of Machines' ;
    rdfs:comment 'Total count of machines or equipment units available in this work center.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfOperators rdf:type rdf:Property ;
    rdfs:label 'Number Of Operators' ;
    rdfs:comment 'Total count of operators or workers assigned to this work center for production operations.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Code' ;
    rdfs:comment 'Quality certification or compliance code applicable to this work center (e.g., ISO 9001, WRAP, OEKO-TEX).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Queue Time Minutes' ;
    rdfs:comment 'Standard queue time (waiting time before operation starts) at this work center, measured in minutes. Used in production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Scheduling method used for operations at this work center: forward scheduling from start date, backward scheduling from due date, or midpoint scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Operating shift pattern for this work center (single shift, two shifts, three shifts, or continuous 24/7 operation).' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardValueUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Value Unit' ;
    rdfs:comment 'Unit of measure for standard time values (minutes, hours, seconds, days) used in capacity and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this work center record becomes effective and available for production planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this work center record remains effective. Null indicates no planned end date.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Classification of the work center based on resource type: machine-intensive, labor-intensive, or mixed operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Business identifier for the work center used in production planning and routing. Externally-known unique code used in SAP PP module.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center (e.g., Sewing Line 3, Cutting Room A, Finishing Department B).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center in its lifecycle. Determines availability for production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveWholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Exclusive Wholesale Account Id' ;
    rdfs:comment 'Foreign key linking to customer.wholesale_account. Business justification: Style-level wholesale exclusivity (e.g., a Costco-exclusive style, a department-store-exclusive silhouette) is a standard apparel wholesale practice. The style table has is_exclusive flag but no FK id' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:targetCustomerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Merchandising teams design styles for specific customer segments (e.g., Gen-Z athleisure, luxury high-net-worth). Product development briefs explicitly identify target segments. This link enables segm' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:careInstructions rdf:type rdf:Property ;
    rdfs:label 'Care Instructions' ;
    rdfs:comment 'Garment care and washing instructions. Required for consumer product labeling and compliance with FTC Care Labeling Rule.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Standard Cost of Goods Sold (COGS) for the style including materials, labor, and manufacturing overhead. Foundation for margin analysis, Initial Markup (IMU), and profitability reporting.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designOwner rdf:type rdf:Property ;
    rdfs:label 'Design Owner' ;
    rdfs:comment 'Name or identifier of the designer or design team responsible for creating the style. Used for attribution, collaboration tracking, and design portfolio management.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the style is discontinued and removed from active assortment. Used for lifecycle management, markdown planning, and inventory liquidation strategies.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Business division or brand line to which the style belongs. Used for P&L reporting, brand portfolio management, and organizational accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Target gender demographic for the style. Critical for merchandising, assortment planning, and store allocation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoreStyle rdf:type rdf:Property ;
    rdfs:label 'Is Core Style' ;
    rdfs:comment 'Boolean flag indicating whether this is a core, never-out-of-stock (NOS) style that is continuously replenished. Core styles receive priority in inventory allocation and replenishment planning.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the style by market positioning and intended use case. Aligns with brand portfolio segmentation strategy.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Product safety certifications and compliance standards met by the style. Required for consumer product safety and regulatory compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:silhouette rdf:type rdf:Property ;
    rdfs:label 'Silhouette' ;
    rdfs:comment 'Design silhouette or fit profile of the style (e.g., slim fit, relaxed fit, oversized, tailored). Key attribute for product differentiation and customer preference matching.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleDescription rdf:type rdf:Property ;
    rdfs:label 'Style Description' ;
    rdfs:comment 'Detailed narrative description of the style including design features, aesthetic attributes, and intended use. Used for marketing copy and product catalogs.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleName rdf:type rdf:Property ;
    rdfs:label 'Style Name' ;
    rdfs:comment 'Human-readable marketing name or title of the style. Used in catalogs, e-commerce, and merchandising communications.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleNumber rdf:type rdf:Property ;
    rdfs:label 'Style Number' ;
    rdfs:comment 'Externally-known unique business identifier for the style. Used across PLM, merchandising, and supply chain systems. Typically alphanumeric code assigned during design phase.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Sustainability or ethical certifications held by the style (e.g., GOTS, OEKO-TEX, BCI, Fair Trade). Supports ESG reporting and consumer transparency initiatives.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Intended sales and distribution channel strategy for the style. Supports Direct-to-Consumer (DTC), wholesale, retail, and omnichannel planning. May include multiple channels separated by delimiter.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackReference rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Reference' ;
    rdfs:comment 'Reference identifier or document link to the technical specification package (tech pack) containing detailed construction, measurements, and manufacturing instructions.' ;
    rdfs:domain ind:Style ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageGroup rdf:type rdf:Property ;
    rdfs:label 'Age Group' ;
    rdfs:comment 'The target age group for the colorway. Used for merchandising and assortment planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFamily rdf:type rdf:Property ;
    rdfs:label 'Color Family' ;
    rdfs:comment 'The broad color family or category that the colorway belongs to, used for filtering and search in e-commerce and merchandising systems. [ENUM-REF-CANDIDATE: red|blue|green|yellow|orange|purple|pink|brown|black|white|gray|multi — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStandard rdf:type rdf:Property ;
    rdfs:label 'Color Standard' ;
    rdfs:comment 'The color standard system used to define the colorway (e.g., Pantone, Natural Color System (NCS), RAL, CMYK, RGB, HEX).' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStory rdf:type rdf:Property ;
    rdfs:label 'Color Story' ;
    rdfs:comment 'The thematic narrative or inspiration behind the colorway, often tied to seasonal trends, brand campaigns, or design concepts (e.g., \'Ocean Breeze\', \'Urban Jungle\', \'Retro Revival\').' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayCode rdf:type rdf:Property ;
    rdfs:label 'Colorway Code' ;
    rdfs:comment 'Unique business identifier for the colorway, typically a short alphanumeric code used in Product Lifecycle Management (PLM) systems, Oracle Retail, and across supply chain operations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayName rdf:type rdf:Property ;
    rdfs:label 'Colorway Name' ;
    rdfs:comment 'Human-readable name for the colorway, often descriptive and marketing-friendly (e.g., \'Midnight Navy\', \'Sunset Orange\', \'Forest Green\').' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorwayStatus rdf:type rdf:Property ;
    rdfs:label 'Colorway Status' ;
    rdfs:comment 'Current lifecycle status of the colorway. Active colorways are available for sale; discontinued colorways are no longer produced; carry-over colorways continue from a previous season; pending colorways are in development.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Description' ;
    rdfs:comment 'Details about the exclusivity arrangement, such as the specific retailer, channel, or region where the colorway is exclusively available.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishType rdf:type rdf:Property ;
    rdfs:label 'Finish Type' ;
    rdfs:comment 'The surface finish or texture applied to the colorway (e.g., matte, glossy, metallic, satin). Relevant for footwear, accessories, and certain apparel categories.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hexColorCode rdf:type rdf:Property ;
    rdfs:label 'Hex Color Code' ;
    rdfs:comment 'The hexadecimal color code for the primary color, used for digital representation in e-commerce and marketing materials.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'The URL or file path to the primary product image for this colorway, used in e-commerce, Point of Sale (POS), and marketing materials.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLimitedEdition rdf:type rdf:Property ;
    rdfs:label 'Is Limited Edition' ;
    rdfs:comment 'Indicates whether the colorway is a limited edition release with restricted production quantities. True for limited editions, False for standard releases.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The username or identifier of the user who last modified the colorway record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleRetailItemCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Retail Item Code' ;
    rdfs:comment 'The unique identifier for this colorway in Oracle Retail Merchandising System. Used for integration with merchandising, allocation, and pricing modules.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pantoneCode rdf:type rdf:Property ;
    rdfs:label 'Pantone Code' ;
    rdfs:comment 'The Pantone Matching System (PMS) code for the primary color, used for precise color matching in manufacturing and printing.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Plm System Code' ;
    rdfs:comment 'The unique identifier for this colorway in the source Product Lifecycle Management (PLM) system (Infor PLM or Centric PLM). Used for system integration and traceability.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColor rdf:type rdf:Property ;
    rdfs:label 'Primary Color' ;
    rdfs:comment 'The dominant color of the colorway. This is the main color that defines the visual appearance of the product.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printPattern rdf:type rdf:Property ;
    rdfs:label 'Print Pattern' ;
    rdfs:comment 'Description of any print or pattern applied to the colorway (e.g., \'Floral\', \'Geometric\', \'Camouflage\', \'Solid\'). Null for solid colors without patterns.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swatchImageUrl rdf:type rdf:Property ;
    rdfs:label 'Swatch Image Url' ;
    rdfs:comment 'The URL or file path to the color swatch image for this colorway, used for color selection in e-commerce and merchandising tools.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tertiaryColor rdf:type rdf:Property ;
    rdfs:label 'Tertiary Color' ;
    rdfs:comment 'The third accent color of the colorway, if applicable. Used for multi-color designs.' ;
    rdfs:domain ind:Colorway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsFlag rdf:type rdf:Property ;
    rdfs:label 'Ats Flag' ;
    rdfs:comment 'Indicates whether the SKU is currently available for sale across channels. Drives e-commerce availability and order promising.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Short alphanumeric code representing the color variant. Used in SKU construction and merchandising systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorName rdf:type rdf:Property ;
    rdfs:label 'Color Name' ;
    rdfs:comment 'Marketing-friendly name of the color variant for customer-facing displays and e-commerce.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'The landed cost of the SKU including manufacturing, materials, labor, and freight. Used for margin and profitability analysis.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit EAN barcode identifier used for international retail distribution and point-of-sale operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gspEligible rdf:type rdf:Property ;
    rdfs:label 'Gsp Eligible' ;
    rdfs:comment 'Indicates whether the SKU qualifies for GSP duty-free treatment based on country of origin and product classification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment '14-digit global trade item number for supply chain and logistics tracking across international markets.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'The height dimension of the packaged SKU in centimeters. Used for carton planning and warehouse space optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'The length dimension of the packaged SKU in centimeters. Used for carton planning and warehouse space optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidTagReference rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Reference' ;
    rdfs:comment 'RFID tag identifier for automated inventory tracking, anti-theft, and supply chain visibility. Enables real-time location tracking.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRunPosition rdf:type rdf:Property ;
    rdfs:label 'Size Run Position' ;
    rdfs:comment 'Numeric position of this size within the size curve or size run. Used for allocation and assortment planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'The business identifier for the SKU. Externally-known unique code used across all systems for inventory, order, and e-commerce references.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU. Controls visibility, ordering, and inventory management across all channels.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'The weight of the SKU in kilograms. Used for shipping cost calculation, freight planning, and logistics optimization.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'The width dimension of the packaged SKU in centimeters. Used for carton planning and warehouse space optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandApplicability rdf:type rdf:Property ;
    rdfs:label 'Brand Applicability' ;
    rdfs:comment 'Comma-separated list of brand codes or names this size scale is applicable to. Allows for brand-specific sizing standards (e.g., luxury brands may use different scales than athletic brands).' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTableReference rdf:type rdf:Property ;
    rdfs:label 'Conversion Table Reference' ;
    rdfs:comment 'Reference identifier or URL to the size conversion table that maps this scale to other regional or brand scales. Enables cross-market size normalization.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultForCategory rdf:type rdf:Property ;
    rdfs:label 'Default For Category' ;
    rdfs:comment 'Indicates whether this size scale is the default scale for its product category and gender combination. Used to auto-populate size scales during product creation in PLM systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'External identifier for this size scale in the ERP system (SAP S/4HANA). Used for integration with merchandising, allocation, and inventory management modules.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitModelReference rdf:type rdf:Property ;
    rdfs:label 'Fit Model Reference' ;
    rdfs:comment 'Reference identifier to the fit model or body form specifications used to validate this size scale. Links to sample development and fit approval processes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderApplicability rdf:type rdf:Property ;
    rdfs:label 'Gender Applicability' ;
    rdfs:comment 'The gender or demographic segment this size scale is designed for (mens, womens, unisex, boys, girls, infant, toddler). Aligns with product categorization and merchandising hierarchy. [ENUM-REF-CANDIDATE: mens|womens|unisex|boys|girls|infant|toddler — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingRuleReference rdf:type rdf:Property ;
    rdfs:label 'Grading Rule Reference' ;
    rdfs:comment 'Reference identifier to the grading rule set used for pattern grading across sizes in this scale. Links to technical design specifications in PLM systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the size scale: draft (under development), active (in use), deprecated (phasing out), retired (no longer used). Governs availability for new product assignments.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement System' ;
    rdfs:comment 'The regional measurement system or standard used for this size scale (US, EU, UK, JP, CN, AU, KR, INT for International). Determines the sizing convention and labeling standards. [ENUM-REF-CANDIDATE: US|EU|UK|JP|CN|AU|KR|INT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measurement used for size specifications in this scale (inches, centimeters, waist_inseam for bottoms, chest_length for tops, not_applicable for alpha or one-size scales).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalMarket rdf:type rdf:Property ;
    rdfs:label 'Regional Market' ;
    rdfs:comment 'Comma-separated list of 3-letter ISO country codes where this size scale is used (e.g., USA,CAN,MEX for North America). Enables regional size mapping and localization.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeChartUrl rdf:type rdf:Property ;
    rdfs:label 'Size Chart Url' ;
    rdfs:comment 'URL or file path to the customer-facing size chart document or image for this scale. Used for e-commerce display and customer service reference.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeIncrement rdf:type rdf:Property ;
    rdfs:label 'Size Increment' ;
    rdfs:comment 'The increment or step between consecutive sizes in numeric scales (e.g., 2 for waist sizes 28,30,32,34). Not applicable for alpha scales.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeLabels rdf:type rdf:Property ;
    rdfs:label 'Size Labels' ;
    rdfs:comment 'Ordered comma-separated list of size labels in this scale run (e.g., XS,S,M,L,XL,XXL or 28,30,32,34,36,38,40 or 6,8,10,12,14). Order represents the size progression from smallest to largest.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Size Range End' ;
    rdfs:comment 'The largest size label in this scale (e.g., XXL, 40, 14). Represents the upper bound of the size run.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Size Range Start' ;
    rdfs:comment 'The smallest size label in this scale (e.g., XS, 28, 6). Represents the lower bound of the size run.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleCode rdf:type rdf:Property ;
    rdfs:label 'Size Scale Code' ;
    rdfs:comment 'Business identifier code for the size scale (e.g., MENS_TOPS_US, WOMENS_BOTTOMS_EU, FOOTWEAR_UK). Used as the externally-known unique code for this size scale across systems.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleDescription rdf:type rdf:Property ;
    rdfs:label 'Size Scale Description' ;
    rdfs:comment 'Detailed description of the size scale, including its intended use, product categories, and any special characteristics or measurement guidelines.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleName rdf:type rdf:Property ;
    rdfs:label 'Size Scale Name' ;
    rdfs:comment 'Human-readable name of the size scale (e.g., Men\'s Tops US Standard, Women\'s Bottoms EU, Footwear UK Sizing). Provides clear business context for the size run.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeType rdf:type rdf:Property ;
    rdfs:label 'Size Type' ;
    rdfs:comment 'Classification of the size labeling system: alpha (XS-XXL), numeric (28-40, 6-14), hybrid (combination of alpha and numeric), or one_size. Determines display and conversion logic.' ;
    rdfs:domain ind:SizeScale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the immediate parent category in the merchandise hierarchy. Null for top-level divisions.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the category within the merchandising hierarchy. Used as business key across Oracle Retail, PLM, and e-commerce systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the product category including scope, product types included, and merchandising guidelines.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full descriptive name of the product category as displayed in merchandising, e-commerce, and reporting systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category. Inactive categories are excluded from new product assignments and assortment planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the product category by major product type. Aligns with design and sourcing organizational structure.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorPaletteStrategy rdf:type rdf:Property ;
    rdfs:label 'Color Palette Strategy' ;
    rdfs:comment 'Color assortment strategy for this category. Core colors are year-round; seasonal and trend colors change by collection.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginPrimary rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Primary' ;
    rdfs:comment 'Primary country of origin for products in this category (ISO 3166-1 alpha-3 code). Influences sourcing strategy and compliance labeling.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Percent' ;
    rdfs:comment 'Average import duty rate percentage for products in this category. Used for LDP (Landed Duty Paid) cost calculations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecommerceDisplaySequence rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Display Sequence' ;
    rdfs:comment 'Sort order for displaying this category in e-commerce navigation menus and product listing pages.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftcLabelingRequired rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Required' ;
    rdfs:comment 'Indicates whether products in this category require FTC textile and apparel labeling (fiber content, country of origin, care instructions).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Hs Code Prefix' ;
    rdfs:comment 'Common HS Code prefix for products in this category. Used for customs classification, duty calculation, and international trade compliance.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensed rdf:type rdf:Property ;
    rdfs:label 'Is Licensed' ;
    rdfs:comment 'Indicates whether products in this category require licensing agreements (e.g., sports leagues, entertainment properties).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSustainable rdf:type rdf:Property ;
    rdfs:label 'Is Sustainable' ;
    rdfs:comment 'Indicates whether this category is designated for sustainable or eco-friendly products meeting GOTS, BCI, or OEKO-TEX standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWebVisible rdf:type rdf:Property ;
    rdfs:label 'Is Web Visible' ;
    rdfs:comment 'Indicates whether this category is visible on e-commerce storefronts. Inactive or wholesale-only categories may be hidden from web.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Target Percent' ;
    rdfs:comment 'Target gross margin percentage for products within this category. Used for pricing strategy and financial planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Markdown Risk Level' ;
    rdfs:comment 'Historical markdown risk classification based on sell-through rate (STR) and inventory turnover patterns. Influences OTB (Open-to-Buy) planning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this category record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oracleRetailCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Retail Category Code' ;
    rdfs:comment 'External category identifier from Oracle Retail Merchandising System. Used for system integration and data synchronization.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Strategic product line classification indicating brand positioning and target market segment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Inventory replenishment approach for this category. NOS (Never Out of Stock) applies to core basics; fashion items use allocation-driven strategies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeScaleType rdf:type rdf:Property ;
    rdfs:label 'Size Scale Type' ;
    rdfs:comment 'Standard sizing system used for products in this category: numeric (2-16), alpha (XS-XXL), footwear (US/EU/UK), one-size, or custom.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically assigned by the PLM system. Used for external communication with suppliers and factories.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM indicating its approval state and readiness for production use.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use case: engineering BOM for design, manufacturing BOM for production, costing BOM for financial analysis, or planning BOM for procurement.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmtCost rdf:type rdf:Property ;
    rdfs:label 'Cmt Cost' ;
    rdfs:comment 'Total labor and manufacturing cost charged by the factory for cutting, making, and trimming the garment. Does not include material costs.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Approval Status' ;
    rdfs:comment 'Approval status of the cost buildup by finance or merchandising teams. Approved costs are used for margin analysis and pricing decisions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Cost Approved Date' ;
    rdfs:comment 'Date when the cost buildup was approved. Used for audit trail and version control.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'Version identifier for the cost buildup to track changes in costing assumptions, material prices, or factory quotes over time.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingStage rdf:type rdf:Property ;
    rdfs:label 'Costing Stage' ;
    rdfs:comment 'Stage of the costing process indicating the maturity and accuracy of cost data: initial estimate during design, preliminary costing after sampling, final costing before production, or actual costing post-production.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutCost rdf:type rdf:Property ;
    rdfs:label 'Cut Cost' ;
    rdfs:comment 'Labor cost component for cutting fabric and materials. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyCost rdf:type rdf:Property ;
    rdfs:label 'Duty Cost' ;
    rdfs:comment 'Import duty cost per unit calculated by applying the duty rate to the FOB cost. Varies by destination country and trade agreements.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRate rdf:type rdf:Property ;
    rdfs:label 'Duty Rate' ;
    rdfs:comment 'Import duty rate percentage applied to the product based on its HS Code and country of origin. Used to calculate duty cost.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fabricContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fabric Content Percentage' ;
    rdfs:comment 'Detailed breakdown of fabric composition by material type and percentage (e.g., 60% Cotton, 40% Polyester). Required for FTC labeling compliance and OEKO-TEX certification.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imuPercentage rdf:type rdf:Property ;
    rdfs:label 'Imu Percentage' ;
    rdfs:comment 'Initial markup percentage calculated as (MSRP - LDP Cost) / MSRP. Key profitability metric for merchandising and pricing decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeCost rdf:type rdf:Property ;
    rdfs:label 'Make Cost' ;
    rdfs:comment 'Labor cost component for sewing and assembling the garment. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFabricType rdf:type rdf:Property ;
    rdfs:label 'Primary Fabric Type' ;
    rdfs:comment 'Dominant fabric material used in the product (e.g., Cotton, Polyester, Wool, Silk, Nylon). Used for merchandising classification and sustainability reporting.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCogs rdf:type rdf:Property ;
    rdfs:label 'Target Cogs' ;
    rdfs:comment 'Target cost of goods sold set during product development to achieve desired margin objectives. Used as a benchmark against actual LDP cost.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Sum of all raw material, fabric, trim, and component costs required to manufacture one unit of the product. Expressed in the costing currency.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimCost rdf:type rdf:Property ;
    rdfs:label 'Trim Cost' ;
    rdfs:comment 'Labor cost component for finishing, trimming, and quality inspection. Part of the CMT cost breakdown.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:bomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOM line. Tracks whether the line is active for production, pending approval, or has been obsoleted or superseded by a newer version.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorSpecification rdf:type rdf:Property ;
    rdfs:label 'Color Specification' ;
    rdfs:comment 'Color code or description for the material. May reference Pantone codes, supplier color names, or internal color standards.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the material against regulatory and safety standards. Tracks whether material meets FTC labeling, CPSC safety, and restricted substance requirements.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this BOM line calculated as quantity per unit multiplied by unit cost. Represents the material cost contribution to one finished unit.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementDescription rdf:type rdf:Property ;
    rdfs:label 'Placement Description' ;
    rdfs:comment 'Textual description of where the material is used or placed on the garment. Examples: front panel, back yoke, sleeve cuff, center front zipper, care label at side seam.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Unit' ;
    rdfs:comment 'Amount of material required to produce one finished unit of the parent product. Critical for material planning, costing, and procurement calculations.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedSubstanceTested rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Tested' ;
    rdfs:comment 'Flag indicating whether the material has been tested for restricted substances per OEKO-TEX or similar standards. Critical for product safety and regulatory compliance.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Size Specification' ;
    rdfs:comment 'Size or dimension specification for the material component. Examples: button diameter, zipper length, label dimensions.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Reference' ;
    rdfs:comment 'Supplier\'s own material code or reference number. Used for cross-referencing with vendor catalogs and purchase orders.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastePercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Percentage' ;
    rdfs:comment 'Expected material waste or scrap percentage during manufacturing. Used to adjust material requirements for procurement and yield planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSize rdf:type rdf:Property ;
    rdfs:label 'Base Size' ;
    rdfs:comment 'The base size from which all grading is calculated. All measurements in this tech pack are specified for the base size, and grade rules define increments for other sizes.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDescription rdf:type rdf:Property ;
    rdfs:label 'Construction Description' ;
    rdfs:comment 'Detailed narrative description of garment construction methods, assembly sequence, and structural details. Communicates how the garment is built.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricWeightGsm rdf:type rdf:Property ;
    rdfs:label 'Fabric Weight Gsm' ;
    rdfs:comment 'Fabric weight in grams per square meter. Key specification for fabric quality and performance characteristics.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitEvaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Criteria' ;
    rdfs:comment 'Detailed criteria for evaluating fit during sample approval process. Defines acceptable fit characteristics, critical fit points, and pass/fail criteria for fit sessions.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitType rdf:type rdf:Property ;
    rdfs:label 'Fit Type' ;
    rdfs:comment 'Intended fit classification for the garment. Defines the silhouette and ease allowances in measurements.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeRules rdf:type rdf:Property ;
    rdfs:label 'Grade Rules' ;
    rdfs:comment 'Grading increment specifications defining how measurements change per size step. Specifies the dimensional increment (positive or negative) for each measurement point as sizes increase or decrease from the base size.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedToFactoryDate rdf:type rdf:Property ;
    rdfs:label 'Issued To Factory Date' ;
    rdfs:comment 'Date on which this tech pack was officially issued to the manufacturing factory. Marks the start of factory production preparation.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirements' ;
    rdfs:comment 'Comprehensive labeling requirements including content labels, care labels, brand labels, size labels, country of origin, and regulatory compliance labels per FTC Textile and Wool Acts.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPoints rdf:type rdf:Property ;
    rdfs:label 'Measurement Points' ;
    rdfs:comment 'Comprehensive list of all measurement points with descriptions and base size values. Includes body measurements (chest, waist, hip, inseam, sleeve length, etc.) and garment measurements (length, width, circumference at key points).' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Detailed notes describing changes made in this version compared to the previous version. Tracks evolution of specifications through the development cycle.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seamAllowanceCm rdf:type rdf:Property ;
    rdfs:label 'Seam Allowance Cm' ;
    rdfs:comment 'Standard seam allowance measurement in centimeters. Defines the fabric margin beyond the seam line for construction.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stitchType rdf:type rdf:Property ;
    rdfs:label 'Stitch Type' ;
    rdfs:comment 'Primary stitch type(s) used in garment construction, using ISO 4915 stitch classification (e.g., 301 lockstitch, 504 overedge, 401 chainstitch).' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Sustainability Notes' ;
    rdfs:comment 'Notes regarding sustainable materials, ethical manufacturing requirements, or environmental compliance specifications (GOTS, OEKO-TEX, BCI, etc.).' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackName rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Name' ;
    rdfs:comment 'Human-readable name or title of the tech pack, typically including style name and season reference.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackNumber rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Number' ;
    rdfs:comment 'The externally-known unique business identifier for this tech pack document. Used for communication with factories and internal teams. Managed in Centric PLM.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackStatus rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Status' ;
    rdfs:comment 'Current lifecycle status of the tech pack document. Tracks progression from draft through approval to factory issuance.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaCalendarReference rdf:type rdf:Property ;
    rdfs:label 'Tna Calendar Reference' ;
    rdfs:comment 'Reference identifier linking this tech pack to its Time and Action calendar. TNA calendar tracks all critical milestones from design through production delivery.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceRange rdf:type rdf:Property ;
    rdfs:label 'Tolerance Range' ;
    rdfs:comment 'Acceptable tolerance range for measurements, typically expressed as +/- value. Defines quality acceptance criteria for dimensional accuracy.' ;
    rdfs:domain ind:TechPack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bciCertified rdf:type rdf:Property ;
    rdfs:label 'Bci Certified' ;
    rdfs:comment 'Indicates whether the cotton content is sourced through Better Cotton Initiative. True if certified, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Cost Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the standard cost (meter, yard, kilogram, piece, roll, unit).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cottonPercentage rdf:type rdf:Property ;
    rdfs:label 'Cotton Percentage' ;
    rdfs:comment 'Percentage of cotton fiber in the material composition. Used for sustainability reporting and sourcing decisions.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material record was first created in the system. Used for audit trail and material lifecycle tracking.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiberComposition rdf:type rdf:Property ;
    rdfs:label 'Fiber Composition' ;
    rdfs:comment 'Detailed breakdown of fiber content by percentage (e.g., \'100% Organic Cotton\', \'60% Cotton 40% Polyester\', \'100% Full Grain Leather\'). Required for labeling compliance.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishTreatment rdf:type rdf:Property ;
    rdfs:label 'Finish Treatment' ;
    rdfs:comment 'Description of any chemical or mechanical finish applied to the material (e.g., \'Water Repellent\', \'Anti-Microbial\', \'Enzyme Wash\', \'Brushed\', \'Calendered\').' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gotsCertified rdf:type rdf:Property ;
    rdfs:label 'Gots Certified' ;
    rdfs:comment 'Indicates whether the material is certified under Global Organic Textile Standard. True if certified, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material record was last updated. Used for change tracking and data governance.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level grouping of the material for procurement and inventory purposes (fabric, trim, accessory, component, packaging).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the material used across PLM, sourcing, and manufacturing systems. Business identifier for material lookup and BOM references.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Detailed textual description of the material including construction, hand feel, performance characteristics, and intended use. Supports design and sourcing decisions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name of the material (e.g., \'Organic Cotton Jersey\', \'Italian Leather\', \'YKK Zipper\').' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material (active, inactive, discontinued, pending_approval, restricted, obsolete). Controls availability for new product development and sourcing.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the material by construction or category (woven fabric, knit fabric, leather, synthetic, trim, hardware, packaging, label, thread, elastic). [ENUM-REF-CANDIDATE: woven|knit|leather|synthetic|trim|hardware|packaging|label|thread|elastic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for this material. Critical for procurement planning and cost optimization.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity (meter, yard, kilogram, piece, roll, unit).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oekoTexCertified rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Certified' ;
    rdfs:comment 'Indicates whether the material is certified under OEKO-TEX Standard 100 for harmful substance testing. True if certified, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:polyesterPercentage rdf:type rdf:Property ;
    rdfs:label 'Polyester Percentage' ;
    rdfs:comment 'Percentage of polyester fiber in the material composition. Tracked for performance characteristics and sustainability metrics.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recycled Content Percentage' ;
    rdfs:comment 'Percentage of recycled material content (post-consumer or post-industrial). Critical for sustainability goals and eco-labeling.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedSubstanceCompliant rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Compliant' ;
    rdfs:comment 'Indicates whether the material complies with restricted substance lists (e.g., REACH, California Prop 65, CPSIA). True if compliant, False otherwise.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required storage conditions for the material to maintain quality (e.g., \'Store in cool, dry place\', \'Avoid direct sunlight\', \'Temperature controlled\').' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Code' ;
    rdfs:comment 'Material code or reference number used by the supplier. Facilitates cross-referencing and order accuracy.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference number or identifier for quality and compliance test reports (e.g., lab test reports, certification documents). Links to external document management systems.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGsm rdf:type rdf:Property ;
    rdfs:label 'Weight Gsm' ;
    rdfs:comment 'Weight of the material measured in grams per square meter. Key specification for fabric performance, drape, and costing.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier for the product sample record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:fitEvaluationResult rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Result' ;
    rdfs:comment 'Outcome of the fit evaluation process for fit samples, determining if the sample meets graded measurement specifications.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iterationNumber rdf:type rdf:Property ;
    rdfs:label 'Iteration Number' ;
    rdfs:comment 'Sequential iteration number tracking how many times this sample has been revised or resubmitted (e.g., 1st sample, 2nd sample, 3rd sample).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Current physical location or storage area where the sample is kept (e.g., design studio, sample room, warehouse).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementChestCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Chest Cm' ;
    rdfs:comment 'Graded measurement specification for chest circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementHipCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Hip Cm' ;
    rdfs:comment 'Graded measurement specification for hip circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementLengthCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Length Cm' ;
    rdfs:comment 'Graded measurement specification for garment length in centimeters (e.g., center back length, inseam), critical for fit evaluation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWaistCm rdf:type rdf:Property ;
    rdfs:label 'Measurement Waist Cm' ;
    rdfs:comment 'Graded measurement specification for waist circumference in centimeters, critical for fit evaluation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'URL or file path to digital photographs of the sample for visual reference and documentation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefects rdf:type rdf:Property ;
    rdfs:label 'Quality Defects' ;
    rdfs:comment 'Detailed description of any quality defects identified during inspection, including severity and location.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Outcome of the quality inspection process evaluating construction, stitching, finishing, and overall workmanship.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the sample was requested from the factory or design team.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Unique business identifier for the sample used across PLM and production systems.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the sample in the approval and evaluation workflow. [ENUM-REF-CANDIDATE: requested|in_development|submitted|approved|rejected|on_hold|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the sample was submitted for review and approval.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Expected date for sample delivery based on TNA (Time and Action) calendar milestones.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:washTestCompleted rdf:type rdf:Property ;
    rdfs:label 'Wash Test Completed' ;
    rdfs:comment 'Indicates whether the sample has undergone wash testing to evaluate colorfastness, shrinkage, and durability.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washTestResult rdf:type rdf:Property ;
    rdfs:label 'Wash Test Result' ;
    rdfs:comment 'Outcome of wash testing evaluation for colorfastness, shrinkage, and fabric integrity.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGrams rdf:type rdf:Property ;
    rdfs:label 'Weight Grams' ;
    rdfs:comment 'Physical weight of the sample garment in grams, used for shipping calculations and product specifications.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date when the collection was made available for sale or distribution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageUnitRetail rdf:type rdf:Property ;
    rdfs:label 'Average Unit Retail' ;
    rdfs:comment 'Average retail price per unit across all SKUs in the collection. Confidential pricing information.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of external partner or designer for collaboration collections (e.g., celebrity, artist, brand partnership).' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCode rdf:type rdf:Property ;
    rdfs:label 'Collection Code' ;
    rdfs:comment 'Externally-known unique business identifier for the collection used across PLM, merchandising, and retail systems.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Human-readable name of the collection for marketing and merchandising purposes.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the collection: Planning (concept phase), Design (creative development), Development (pre-production), Commercialized (ready for market), Active (in-market), Closed (end of lifecycle), or Cancelled. [ENUM-REF-CANDIDATE: PLANNING|DESIGN|DEVELOPMENT|COMMERCIALIZED|ACTIVE|CLOSED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDirectionNotes rdf:type rdf:Property ;
    rdfs:label 'Creative Direction Notes' ;
    rdfs:comment 'Detailed creative direction, design inspiration, and aesthetic guidance for the collection. Confidential business information.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Date when the collection is planned to be discontinued or phased out from active selling.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Primary geographic market or region for which the collection is designed (e.g., North America, Europe, Asia Pacific).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Merchandising System Code' ;
    rdfs:comment 'Unique identifier for the collection in the Oracle Retail Merchandising System.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Planned date for the collection to be available for sale or distribution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Planning System Code' ;
    rdfs:comment 'Unique identifier for the collection in the Anaplan merchandise planning system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationType rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Type' ;
    rdfs:comment 'Type of sustainability certification achieved by the collection (e.g., GOTS, OEKO-TEX, BCI, Bluesign, Cradle to Cradle, Fair Trade, Organic Content, Recycled Content). [ENUM-REF-CANDIDATE: GOTS|OEKO-TEX|BCI|BLUESIGN|CRADLE_TO_CRADLE|FAIR_TRADE|ORGANIC_CONTENT|RECYCLED_CONTENT — promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for the collection, used in merchandise financial planning. Confidential financial metric.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Creative theme or inspiration for the collection, used for marketing and merchandising storytelling.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of SKUs (style-color-size combinations) in the collection.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStyleCount rdf:type rdf:Property ;
    rdfs:label 'Total Style Count' ;
    rdfs:comment 'Total number of unique styles included in the collection.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpPriceId rdf:type rdf:Property ;
    rdfs:label 'Msrp Price Id' ;
    rdfs:comment 'Unique identifier for the MSRP price record. Primary key for the MSRP price entity.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorBenchmarkPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Benchmark Price' ;
    rdfs:comment 'Reference price from competitor analysis used to inform MSRP positioning. Supports competitive pricing strategy and market positioning.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Basis' ;
    rdfs:comment 'The cost of goods sold (COGS) or landed cost used as the basis for calculating the initial markup percentage. Business-confidential financial data.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Three-letter ISO country code representing the market or region where this MSRP applies (e.g., USA, CAN, GBR, DEU, CHN).' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Advertised Price' ;
    rdfs:comment 'The minimum price at which retailers are allowed to advertise this product. Used to protect brand positioning and prevent price erosion in wholesale channels.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Amount' ;
    rdfs:comment 'The suggested retail price amount set by the manufacturer for this SKU or style in the specified market and currency. This is the recommended selling price to consumers.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePointStrategy rdf:type rdf:Property ;
    rdfs:label 'Price Point Strategy' ;
    rdfs:comment 'The pricing strategy classification for this MSRP: penetration (low to gain share), premium (high for exclusivity), competitive (market-aligned), value (cost-plus), or psychological (charm pricing).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceZone rdf:type rdf:Property ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Geographic or market-based pricing zone code used for regional price differentiation within a country or market. Supports localized pricing strategies.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedMarkdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Recommended Markdown Percentage' ;
    rdfs:comment 'Suggested markdown percentage for promotional or clearance pricing. Used for planning maintained markup (MMU) and sell-through rate (STR) targets.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Inclusive Flag' ;
    rdfs:comment 'Indicates whether the MSRP amount includes VAT or other consumption taxes. True if tax-inclusive, false if tax-exclusive.' ;
    rdfs:domain ind:MsrpPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualCogs rdf:type rdf:Property ;
    rdfs:label 'Actual Cogs' ;
    rdfs:comment 'Actual Cost of Goods Sold realized after production and delivery, used for financial reporting and variance analysis.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSheetNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Number' ;
    rdfs:comment 'Business identifier or document number for the cost sheet, used for external reference and tracking.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSheetStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Sheet Status' ;
    rdfs:comment 'Current approval and workflow status of the cost sheet within the PLM and costing approval process.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'Three-letter ISO country code representing the destination market or country of import for this cost sheet.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricCost rdf:type rdf:Property ;
    rdfs:label 'Fabric Cost' ;
    rdfs:comment 'Cost of fabric materials used in the garment or product, subset of total material cost.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Direct labor cost for manufacturing operations, may overlap with or be part of CMT cost depending on costing methodology.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Total cost of all raw materials including fabrics, trims, accessories, and packaging materials used in the product.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'Manufacturing overhead and indirect costs allocated to the product including factory utilities, supervision, and facility costs.' ;
    rdfs:domain ind:CostSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Cost of packaging materials including polybags, hangtags, cartons, and shipping materials.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Reference to the shipping address for order delivery. Links to customer address master. Used for fulfillment and logistics planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the logistics carrier assigned to deliver this order. Examples include UPS, FedEx, DHL, USPS, or 3PL (Third-Party Logistics) provider codes.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'System-confirmed delivery date based on ATP (Available to Promise) and logistics capacity. May differ from requested date due to inventory or capacity constraints.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer-provided purchase order number for wholesale and B2B orders. Required for EDI (Electronic Data Interchange) orders and accounts payable matching. Null for DTC (Direct-to-Consumer) orders.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Customer-provided gift message for gift orders. Printed on packing slip or gift card. Null for non-gift orders.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Flag indicating whether this order is a gift. True for gift orders requiring special packaging and gift message inclusion. False for regular orders.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'Sales channel through which the order was placed. E-commerce includes DTC (Direct-to-Consumer) web orders, retail POS (Point of Sale) captures in-store transactions, wholesale EDI (Electronic Data Interchange) handles B2B orders, call center represents phone orders, mobile app captures mobile commerce, and marketplace includes third-party platforms.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The date when the sales order was placed by the customer. Represents the business event timestamp for order creation. Used for sales reporting, trend analysis, and OTIF (On Time In Full) tracking.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes or special instructions for order fulfillment. May include customer requests, delivery instructions, or internal processing notes.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Order Source System' ;
    rdfs:comment 'Operational system of record where the order was originally created. SAP S/4HANA SD handles wholesale and B2B orders, Salesforce Commerce Cloud manages DTC e-commerce, SAP CAR (Customer Activity Repository) captures retail POS transactions, Oracle Retail handles store operations.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the sales order. Draft orders are incomplete, submitted orders await confirmation, confirmed orders are accepted, allocated orders have inventory reserved, picked orders are in warehouse fulfillment, packed orders are ready to ship, shipped orders are in transit, delivered orders are complete, cancelled orders are voided, returned orders are processing RMA (Return Merchandise Authorization). [ENUM-REF-CANDIDATE: draft|submitted|confirmed|allocated|picked|packed|shipped|delivered|cancelled|returned — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTime rdf:type rdf:Property ;
    rdfs:label 'Order Time' ;
    rdfs:comment 'Precise timestamp when the order was placed, including time zone. Used for order sequencing, fulfillment prioritization, and customer service.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the sales order by business purpose. Standard orders are regular sales, rush orders require expedited fulfillment, pre-orders are for future collection releases, backorders are for out-of-stock items, sample orders are for sales representatives, and return orders process RMA (Return Merchandise Authorization).' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Status of payment processing for the order. Pending indicates awaiting payment, authorized means funds are reserved, captured means payment is collected, partially paid applies to installment orders, fully paid indicates complete payment, refunded applies to returns, failed indicates payment rejection. [ENUM-REF-CANDIDATE: pending|authorized|captured|partially_paid|fully_paid|refunded|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Fulfillment priority classification. VIP orders are for high-value customers, rush orders require expedited processing, high priority orders are time-sensitive, standard orders follow normal processing, backorder priority applies to replenishment orders.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'Sales organization code responsible for this order. Represents the legal entity or business unit that owns the customer relationship and revenue. Used for financial reporting and commission calculation.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges for order delivery. May be zero for free shipping promotions or wholesale FOB (Free on Board) orders.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Delivery method selected for the order. Standard is regular ground shipping, express is expedited delivery, overnight is next-day, two-day is second-day, ground is economy shipping, freight is for large wholesale orders, pickup is for BOPIS (Buy Online Pickup In Store). [ENUM-REF-CANDIDATE: standard|express|overnight|two_day|ground|freight|pickup — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item amounts before taxes, shipping, and discounts. Represents the gross merchandise value of the order.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final order total including subtotal, taxes, shipping, minus discounts. Represents the total amount charged to the customer or invoiced to the wholesale account.' ;
    rdfs:domain ind:SalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmed Flag' ;
    rdfs:comment 'Indicates whether this line item has been confirmed against available inventory through ATP check. True if inventory is reserved, false if pending or backordered.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelDate rdf:type rdf:Property ;
    rdfs:label 'Cancel Date' ;
    rdfs:comment 'The date on which this line item was cancelled. Populated only for cancelled lines. Used for order cancellation analysis.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'The date on which the business has confirmed it can ship this line item. May differ from requested date based on ATP availability.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage discount applied to the unit price for this line item. Used for promotional pricing and markdown tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The category or reason for the discount applied. Used for promotional effectiveness analysis and margin tracking. [ENUM-REF-CANDIDATE: promotional|seasonal|volume|employee|wholesale|markdown|clearance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'The extended price for this line item before tax. Calculated as (unit_price * quantity_ordered) - discount_amount.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'The final total amount for this line item including all discounts and taxes. Represents the customer\'s payment obligation for this line.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which this order line was captured. Enables channel-specific analytics and fulfillment routing.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Business-readable product identifier or style number for the item ordered. Used for display and reporting purposes.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name or description of the product ordered on this line. Includes style name and key attributes for business user recognition.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBackordered rdf:type rdf:Property ;
    rdfs:label 'Quantity Backordered' ;
    rdfs:comment 'The quantity of units on backorder due to insufficient inventory at time of order processing. Awaiting future stock availability.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'The quantity of units cancelled from this line item, either by customer request or due to inability to fulfill.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Quantity Confirmed' ;
    rdfs:comment 'The quantity of units confirmed for fulfillment after ATP (Available to Promise) check. May differ from quantity ordered due to inventory constraints.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of units requested by the customer for this line item. Represents the original order request before any adjustments.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'The actual quantity of units shipped to the customer for this line item. Updated as shipments are processed.' ;
    rdfs:domain ind:SalesOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The selling price per unit for this line item before any discounts or adjustments. Represents the base transaction price.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Order Purchase Order Id' ;
    rdfs:comment 'Unique identifier for the purchase order record in the lakehouse.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderPurchaseOrder .

ind:capacityProfileId rdf:type rdf:Property ;
    rdfs:label 'Capacity Profile Id' ;
    rdfs:comment 'Foreign key linking to supplier.capacity_profile. Business justification: PO placement consumes supplier capacity. Linking PO to the capacity profile used at booking enables capacity utilization tracking, over-booking prevention, and season-level capacity consumption report' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityProfile .

ind:primaryOrderWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Warehouse Location Id' ;
    rdfs:comment 'Reference to the vendor facility or origin location from which goods will ship. Used for logistics planning and landed cost calculation.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contact. Business justification: order_purchase_order stores vendor_contact_email and vendor_contact_name as denormalized plain-text columns. A proper FK to vendor_contact normalizes this, enables contact management, and supports PO ' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:ediAcknowledgmentReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Acknowledgment Received Flag' ;
    rdfs:comment 'Indicates whether vendor has sent EDI 855 Purchase Order Acknowledgment confirming receipt and acceptance of the PO. True if acknowledgment received, False if pending or not applicable.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTransmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Flag' ;
    rdfs:comment 'Indicates whether this purchase order was transmitted to vendor via EDI (True) or through manual/email channel (False). Used for process automation tracking.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fobTerms rdf:type rdf:Property ;
    rdfs:label 'Fob Terms' ;
    rdfs:comment 'Specific FOB terms detailing the point at which ownership and risk transfer from vendor to buyer. May include location details beyond standard Incoterms.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Estimated or actual freight and logistics cost for this shipment. May be buyer or vendor responsibility depending on Incoterms. Expressed in currency_code.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcReference rdf:type rdf:Property ;
    rdfs:label 'Lc Reference' ;
    rdfs:comment 'Reference number for letter of credit securing payment for this purchase order. Used for international trade finance. Nullable for domestic or non-LC transactions.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether this purchase order meets the vendor\'s minimum order quantity requirements. True if compliant, False if exception was granted.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date the purchase order was issued to the vendor. Principal business event timestamp for the transaction.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks progression from draft through vendor acknowledgment, production, shipment, receipt, and closure. Cancelled indicates order was terminated before completion. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|in_production|shipped|received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order by business purpose: replenishment (NOS restocking, VMI, min-max), wholesale (bulk buying for resale), drop-ship (direct-to-customer fulfillment), demand-driven (responsive to actual demand signal), consignment (vendor-owned inventory), or sample (pre-production or marketing samples).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Urgency classification for this purchase order. Rush and critical orders may incur premium freight or vendor surcharges. Used for vendor capacity allocation and logistics planning.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Code identifying the buyer or buying team responsible for this PO. Used for workload distribution and performance tracking.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Code identifying the organizational unit responsible for procurement. May represent centralized or decentralized buying structure.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLandedCost rdf:type rdf:Property ;
    rdfs:label 'Total Landed Cost' ;
    rdfs:comment 'Total cost to land goods at destination including PO value, taxes, freight, duties, and other charges. Used for inventory valuation and profitability analysis. Expressed in currency_code.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before taxes and freight. Expressed in currency_code.' ;
    rdfs:domain ind:OrderPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPurchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Purchase Order Line Id' ;
    rdfs:comment 'Primary key for purchase_order_line' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderPurchaseOrderLine .

ind:lineCategory rdf:type rdf:Property ;
    rdfs:label 'Line Category' ;
    rdfs:comment 'Classification of the purchase order line type. Determines procurement process and inventory handling. Values: standard (normal purchase), consignment (supplier-owned inventory), subcontracting (CMT with buyer-supplied materials), stock_transfer (inter-company transfer).' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or special instructions for this line item. May include packing requirements, labeling instructions, or quality specifications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value for this line. Calculated as ordered quantity multiplied by unit cost.' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received. Calculated as confirmed quantity minus received quantity. Used for backorder tracking.' ;
    rdfs:domain ind:OrderPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code for this line item. Determines applicable VAT, GST, or sales tax rates based on jurisdiction and product category.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Fulfillment carries fully denormalized ship-to address fields that duplicate customer.address. Normalizing via FK supports carrier integration, address validation reporting, delivery performance analy' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Precise date and time the shipment was delivered to the customer, including time zone. Captured from carrier proof of delivery.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Reference Number' ;
    rdfs:comment 'EDI 856 ASN document reference number sent to wholesale buyers notifying them of inbound shipment details.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Carrier-provided estimated date of delivery based on service level and transit time. May differ from promised date.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Number' ;
    rdfs:comment 'Business-facing unique identifier for the fulfillment record. Used for tracking and customer communication.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Complete Timestamp' ;
    rdfs:comment 'Date and time when all items were packed into shipping cartons and ready for carrier pickup.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Date and time when packing activity began for this fulfillment. Marks the transition from picking to packing operations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date the shipment was handed over to the carrier and departed the fulfillment location. Key milestone for OTIF (On Time In Full) tracking.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Email Address' ;
    rdfs:comment 'Email address for the delivery recipient. Used for shipment tracking notifications and delivery confirmations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToName rdf:type rdf:Property ;
    rdfs:label 'Ship To Name' ;
    rdfs:comment 'Name of the recipient or delivery contact for this shipment. May differ from the ordering customer for gift orders.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ship To Phone Number' ;
    rdfs:comment 'Contact phone number for the delivery recipient. Used by carrier for delivery coordination and customer notification.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the shipping cost amount.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:comment 'Total number of shipping cartons or packages in this fulfillment. Used for warehouse capacity planning and carrier billing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of individual SKU (Stock Keeping Unit) units included in this fulfillment across all cartons.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volumetric measurement of the shipment in cubic meters. Used for warehouse space planning and dimensional weight pricing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Id' ;
    rdfs:comment 'Foreign key linking to order.allocation_rule. Business justification: Allocations are executed according to allocation rules. The allocation table has an allocation_method STRING field but no FK to the governing allocation_rule. Adding allocation_rule_id creates a direc' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of SKU units allocated to this order line from available inventory.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity Uom' ;
    rdfs:comment 'Unit of measure for the allocated quantity (e.g., each, pieces, pairs).' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the allocation decision was made.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The allocation strategy or rule applied to determine inventory assignment (First In First Out, priority, channel-based, proximity). [ENUM-REF-CANDIDATE: FIFO|LIFO|FEFO|priority_based|channel_based|proximity_based|cost_optimized — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-readable unique allocation document number for tracking and reference.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the allocation record indicating its fulfillment state.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'The precise date and time when the allocation was created in the system.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atpConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Flag' ;
    rdfs:comment 'Indicates whether the allocation was confirmed against Available to Promise inventory rules.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atpConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Timestamp' ;
    rdfs:comment 'The date and time when ATP confirmation was received for this allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atsAtAllocation rdf:type rdf:Property ;
    rdfs:label 'Ats At Allocation' ;
    rdfs:comment 'Snapshot of the Available to Sell inventory quantity at the source location at the time of allocation.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this allocation is for a backordered item awaiting future inventory availability.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Customer segment classification influencing allocation priority and method.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Fulfilled Quantity' ;
    rdfs:comment 'The actual quantity fulfilled against this allocation, which may differ from allocated quantity due to shortages or adjustments.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preorderFlag rdf:type rdf:Property ;
    rdfs:label 'Preorder Flag' ;
    rdfs:comment 'Indicates whether this allocation is for a preorder item not yet available in inventory.' ;
    rdfs:domain ind:Allocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backorderId rdf:type rdf:Property ;
    rdfs:label 'Backorder Id' ;
    rdfs:comment 'Unique identifier for the backorder record. Primary key.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backorderSkuId rdf:type rdf:Property ;
    rdfs:label 'Backorder Sku Id' ;
    rdfs:comment 'Reference to the SKU (style-color-size combination) that is backordered.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:backorderSubstituteSkuId rdf:type rdf:Property ;
    rdfs:label 'Backorder Substitute Sku Id' ;
    rdfs:comment 'Reference to an alternative SKU offered or accepted as a substitute for the backordered item, if applicable.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Date' ;
    rdfs:comment 'The actual date when the backorder was fulfilled and shipped, null if still pending.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderNumber rdf:type rdf:Property ;
    rdfs:label 'Backorder Number' ;
    rdfs:comment 'Human-readable business identifier for the backorder, used for tracking and customer communication.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderStatus rdf:type rdf:Property ;
    rdfs:label 'Backorder Status' ;
    rdfs:comment 'Current lifecycle status of the backorder indicating its fulfillment stage. [ENUM-REF-CANDIDATE: open|allocated|in_production|ready_to_ship|shipped|cancelled|substituted — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Backordered Quantity' ;
    rdfs:comment 'The quantity of units that could not be fulfilled and are on backorder.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when the backorder was cancelled, either by the customer or by the business, null if still active.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'The precise timestamp when the backorder record was created in the system.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOnBackorder rdf:type rdf:Property ;
    rdfs:label 'Days On Backorder' ;
    rdfs:comment 'The number of days the order has been on backorder status, calculated from backorder_creation_date to current date or fulfillment date.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Expected Fulfillment Date' ;
    rdfs:comment 'The estimated date when the backorder will be fulfilled and shipped to the customer.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Expected Replenishment Date' ;
    rdfs:comment 'The anticipated date when inventory will be replenished and available to fulfill this backorder.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'The total monetary value of the backordered quantity (backordered_quantity × unit_price).' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date when the backorder notification was sent to the customer.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Status indicating whether the customer has been notified about the backorder and any follow-up communications.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRequestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Requested Quantity' ;
    rdfs:comment 'The original quantity requested on the sales order line before partial fulfillment or backorder split.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'The action taken or planned to resolve the backorder (hold for next drop, cancel, substitute with alternative SKU, split shipment, upgrade).' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'The number of days within which the backorder should be fulfilled per the customer service SLA.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'The date when the backorder was created, typically when the order line could not be allocated.' ;
    rdfs:domain ind:Backorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnFromAddressId rdf:type rdf:Property ;
    rdfs:label 'Return From Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Return label generation and carrier pickup scheduling require the customer\'s canonical return-from address. Apparel returns operations link RMAs to the specific address record for logistics processing' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:rmaExchangeOrderSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Exchange Order Sales Order Id' ;
    rdfs:comment 'Reference to the new order created if the disposition type is exchange.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:rmaSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order that this RMA is associated with.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesOrder .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date when the RMA process was fully completed including refund, exchange, or credit issuance.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the RMA complies with FTC and CPSC requirements for consumer returns and product safety standards.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'Action taken on the return: full refund, exchange for different item, store credit issued, repair and return, or rejection of return.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes recorded by the inspector during the condition assessment of returned merchandise.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectCode rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Code' ;
    rdfs:comment 'Standardized code identifying the specific quality defect found during inspection, if applicable.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned merchandise is eligible to be restocked into available inventory based on condition assessment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for processing the return, if applicable per return policy.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Assessment of the physical condition of returned merchandise upon inspection: new/unused, opened but unused, lightly used, damaged, defective, or missing parts.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelType rdf:type rdf:Property ;
    rdfs:label 'Return Label Type' ;
    rdfs:comment 'Indicates who paid for the return shipping label: prepaid by retailer, paid by customer, or paid by vendor.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Return Policy Version' ;
    rdfs:comment 'Version identifier of the return policy that was in effect at the time of the original purchase, ensuring compliance with applicable terms.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of return shipping, which may be borne by customer, retailer, or supplier depending on return policy and reason.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from original purchase date within which the return was allowed per policy.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Business-facing unique RMA number used for customer communication and tracking.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA: requested, approved, rejected, in transit, received at warehouse, inspected, completed, or cancelled. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Unique identifier for the RMA line item. Primary key for the RMA line entity.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'The action to be taken with the returned merchandise. RESTOCK=return to sellable inventory, DESTROY=dispose of item, RTV=Return to Vendor, LIQUIDATE=sell through secondary channel, REPAIR=send for refurbishment, DONATE=charitable donation.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned item. PASS=item meets restocking criteria, FAIL=item does not meet criteria, PENDING=inspection in progress, NOT_INSPECTED=inspection not yet performed.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Line Refund Amount' ;
    rdfs:comment 'Total refund amount for this line item, calculated as quantity returned multiplied by unit refund amount, minus any restocking fees or adjustments.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'The original unit price paid by the customer at the time of purchase. Used for refund calculation and variance analysis.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingBinLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Bin Location' ;
    rdfs:comment 'Specific bin or staging location within the warehouse where the returned item is physically stored pending disposition. Enables precise inventory tracking.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Timestamp when the refund for this line item was successfully processed and issued to the customer. Used for SLA tracking and customer communication.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation if the return line item was rejected. Captures why the return was not accepted per return policy guidelines.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Refund Amount' ;
    rdfs:comment 'The refund amount per unit for this SKU. May differ from original unit price due to promotions, discounts, or partial refund policies.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorRmaNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Rma Number' ;
    rdfs:comment 'RMA number issued by the vendor for items being returned to vendor (RTV). Used for tracking vendor returns and processing vendor credits.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or distribution center where the returned item was received and inspected. Used for inventory tracking and logistics.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Order Payment Id' ;
    rdfs:comment 'Unique identifier for the payment record. Primary key for the payment entity.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Total monetary amount of the payment transaction in the specified currency. Represents the gross payment value before any adjustments or fees.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization or approval code returned by the payment processor or issuing bank. Used for payment verification and reconciliation. Business-confidential transaction identifier.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Response code from Address Verification Service check. Indicates match status between billing address provided and address on file with card issuer. Used for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (apartment, suite, unit number). Optional field for additional address details.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region of the billing address. Used for AVS verification and tax jurisdiction determination.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Date' ;
    rdfs:comment 'Date when a chargeback was initiated by the cardholder or issuing bank. Null if no chargeback has occurred. Used for dispute management and financial reconciliation.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'Standardized reason code provided by card network for the chargeback. Used to categorize disputes and identify root causes for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Response Code' ;
    rdfs:comment 'Response code from CVV/CVC verification check. Indicates whether the card security code provided matches the issuer records. Used for fraud prevention.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is due for net terms or trade credit transactions. Used for AR aging and collections management. Null for immediate payments.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this payment has been flagged as potentially fraudulent by automated systems or manual review. True if flagged, false otherwise.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatewayName rdf:type rdf:Property ;
    rdfs:label 'Gateway Name' ;
    rdfs:comment 'Name of the payment gateway or payment service provider that processed the transaction. Examples include Stripe, Adyen, PayPal, Authorize.Net, or internal payment systems.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for tracing payment through external systems and for dispute resolution.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequential number of this installment payment within the plan. For example, 1 for first payment, 2 for second payment. Null for non-installment payments.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Installment Plan Flag' ;
    rdfs:comment 'Indicates whether this payment is part of an installment or Buy Now Pay Later (BNPL) plan. True if installment plan is active, false otherwise.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net amount received after deducting processing fees and adjustments. Represents actual funds deposited to merchant account.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date when the payment transaction was initiated or authorized. Represents the business event date for the payment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Payment instrument or method used by the customer or wholesale account. Includes digital wallets, card payments, trade credit instruments, and Buy Now Pay Later (BNPL) options. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|store_credit|net_terms|letter_of_credit|factoring|bnpl|wire_transfer|ach|cash|check — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Precise date and time when the payment transaction was initiated or authorized. Includes timezone information for accurate cross-region reconciliation.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the payment processor or gateway for this transaction. Used for Cost of Goods Sold (COGS) calculation and profitability analysis.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally visible unique payment reference number or transaction identifier used for customer communication and reconciliation. Generated by payment gateway or internal system.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund was processed. Null if no refund has been issued. Used for returns processing and customer service tracking.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Fraud risk score assigned by payment gateway or internal fraud detection system. Higher scores indicate higher risk. Used for fraud prevention and order review workflows.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date when the payment was settled and funds were transferred to the merchant account. May differ from payment date due to processing delays.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Precise date and time when the payment was settled. Used for cash flow analysis and reconciliation with bank statements.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:terms rdf:type rdf:Property ;
    rdfs:label 'Terms' ;
    rdfs:comment 'Payment terms for wholesale or trade accounts. Examples include Net 30, Net 60, 2/10 Net 30. Null for immediate DTC payments. Used for Accounts Receivable (AR) aging and credit management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInstallments rdf:type rdf:Property ;
    rdfs:label 'Total Installments' ;
    rdfs:comment 'Total number of installments in the payment plan. Used to calculate payment schedule and remaining balance. Null for non-installment payments.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or cost driver associated with this cost center (e.g., \'Machine Hours\', \'Labor Hours\', \'Square Footage\', \'Headcount\'). Used for activity-based costing and allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCostYtd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Ytd' ;
    rdfs:comment 'The cumulative actual costs posted to this cost center from the beginning of the fiscal year to the current period. Used for budget variance and EOM close reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCycleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Code' ;
    rdfs:comment 'The identifier of the allocation cycle in which this cost center participates as sender or receiver. Used for overhead distribution and internal cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'The brand or label to which this cost center is aligned (e.g., \'MAIN\', \'PREMIUM\', \'OUTLET\'). Used for brand-level profitability analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual budget amount allocated to this cost center for the current fiscal year. Used for budget control and variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the budget amount (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business area or division to which this cost center is assigned (e.g., \'Apparel\', \'Footwear\', \'Accessories\'). Used for segment reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCostYtd rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Ytd' ;
    rdfs:comment 'The cumulative committed costs (purchase orders, contracts) against this cost center from the beginning of the fiscal year to the current period. Used for funds availability and budget control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP Controlling Area (CO) code to which this cost center belongs. Controlling area is the organizational unit in SAP FI/CO for cost accounting and internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects: direct (traced to specific receivers), assessment (fixed allocation), distribution (variable allocation), activity-based (driver-based), percentage (proportional split).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended textual description of the cost center\'s purpose, scope, and responsibilities. Used for documentation and user guidance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The descriptive name of the cost center (e.g., \'Design Studio NYC\', \'Warehouse Operations LA\', \'Marketing Digital\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Center Number' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the cost center in SAP S/4HANA FI/CO. Used for posting, reporting, and budget control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active: operational and accepting postings. Inactive: closed, no new postings. Blocked: temporarily suspended. Planned: future cost center not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional purpose: production (manufacturing/CMT), service (support functions), administration (overhead), sales (retail/wholesale), marketing (brand/campaigns), distribution (logistics/3PL), research and development (PLM/design). [ENUM-REF-CANDIDATE: production|service|administration|sales|marketing|distribution|research_development — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The cost element group or category to which the majority of costs in this cost center belong (e.g., \'Labor\', \'Materials\', \'Overhead\', \'Depreciation\'). Used for COGS buildup and cost-of-sales reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The functional classification of the cost center (e.g., \'Manufacturing\', \'Logistics\', \'Sales\', \'Marketing\', \'Administration\'). Used for cost-of-sales accounting and COGS buildup.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The hierarchical node or group to which this cost center belongs in the organizational cost center hierarchy. Used for roll-up reporting and consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Boolean flag indicating whether this cost center is locked and cannot accept new cost postings. Used during period close and cost center deactivation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverheadReceiver rdf:type rdf:Property ;
    rdfs:label 'Is Overhead Receiver' ;
    rdfs:comment 'Boolean flag indicating whether this cost center receives allocated overhead costs from other cost centers. True if this cost center is a receiver in allocation cycles.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverheadSender rdf:type rdf:Property ;
    rdfs:label 'Is Overhead Sender' ;
    rdfs:comment 'Boolean flag indicating whether this cost center sends (distributes) overhead costs to other cost centers or cost objects. True if this cost center is a sender in allocation cycles.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'The product line or category to which this cost center is aligned (e.g., \'MENS\', \'WOMENS\', \'KIDS\', \'ATHLETIC\'). Used for product-level cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The budget variance amount (budget minus actual cost YTD). Positive indicates under-budget, negative indicates over-budget.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisPeriod rdf:type rdf:Property ;
    rdfs:label 'Analysis Period' ;
    rdfs:comment 'Fiscal period for which profit center performance is analyzed. Format YYYYMM (e.g., 202312 for December 2023). Used for period-over-period EBITDA and margin analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP Business Area code for cross-company code reporting. Enables consolidated financial statements across multiple legal entities for a specific business segment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code identifying the consolidation unit for group-level financial consolidation. Used for eliminating intercompany transactions and preparing consolidated financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area to which this profit center is assigned. Controlling area represents the organizational unit for cost accounting and profitability analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code identifying the group of cost centers that roll up into this profit center for cost allocation and overhead absorption in COGS calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region for regional profit centers. Used for regional profitability analysis and landed cost (LDP) accounting by market.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the profit center is locked for transaction posting. True when locked (no new postings allowed); False when unlocked (normal operations). Used during EOM close and financial consolidation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Planning granularity level for financial planning and budgeting. Strategic for division-level; tactical for brand/channel-level; operational for store/product-line level.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full descriptive name of the profit center. Human-readable label identifying the business segment (e.g., \'Mens Footwear DTC\', \'Womens Apparel Wholesale\', \'EMEA Retail Operations\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accumulate financial transactions; planned profit centers are configured but not yet operational; inactive profit centers are temporarily suspended; closed profit centers are permanently retired.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension. Indicates whether the profit center represents a brand, sales channel (DTC/wholesale/retail), product line, geographic region, individual store, or business division.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the profit center manager for financial reporting notifications and EBITDA analysis distribution.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the business leader or manager accountable for the profit centers financial performance. Typically a brand director, channel head, regional VP, or product line manager.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center used in reports and dashboards for space-constrained displays.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Transfer pricing method for intercompany transactions between profit centers. Used for internal revenue recognition and OECD transfer pricing compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Account group classification code that controls field status, number range, and account behavior in SAP FI. Groups accounts with similar characteristics and posting rules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongText rdf:type rdf:Property ;
    rdfs:label 'Account Long Text' ;
    rdfs:comment 'Extended description providing detailed explanation of the account purpose, usage guidelines, and posting rules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the general ledger account for display and reporting purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Classification for balance sheet accounts distinguishing current vs non-current assets and liabilities. Not applicable for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to obsolete or suspended accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification of the account for cash flow statement preparation per IFRS/GAAP. Categorizes cash movements into operating, investing, or financing activities.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelClassification rdf:type rdf:Property ;
    rdfs:label 'Channel Classification' ;
    rdfs:comment 'Classification of the account by sales channel (DTC, wholesale, e-commerce, retail store) for channel-specific profitability analysis in apparel fashion business.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Four-character code identifying the chart of accounts to which this account belongs. Supports multi-COA scenarios for global enterprises.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Relevant Flag' ;
    rdfs:comment 'Indicates whether this account is included in COGS calculation. Essential for gross margin analysis and inventory valuation in apparel manufacturing and retail.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'Account number in the group chart of accounts used for financial consolidation and elimination of intercompany transactions at corporate level.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. Enforces cost allocation discipline for expense accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of cost element as primary (posted from FI) or secondary (internal CO allocations). Not applicable for non-cost-element accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this account is relevant for Controlling (CO) module and functions as a cost element for cost center accounting, internal orders, or profitability analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebitdaRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Relevant Flag' ;
    rdfs:comment 'Indicates whether postings to this account are included in EBITDA calculation. Critical for apparel fashion profitability analysis and investor reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Four-character code defining which fields are required, optional, or suppressed when posting to this account. Controls data entry behavior in SAP FI.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Detailed financial statement line item classification for statutory reporting. Maps account to specific line items in balance sheet, income statement, or cash flow statement per IFRS/GAAP requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'US GAAP classification code for accounts used in US statutory reporting. Supports dual-reporting requirements for multinational apparel companies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:comment 'Current lifecycle status of the general ledger account indicating whether it is actively used, retired, or awaiting approval for use.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiCategory rdf:type rdf:Property ;
    rdfs:label 'Gmroi Category' ;
    rdfs:comment 'Classification for GMROI analysis in apparel merchandising. Links account to inventory investment and margin performance metrics by product category or channel.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'Detailed IFRS standard and paragraph reference for account classification. Ensures compliance with international accounting standards for statutory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Indicator' ;
    rdfs:comment 'Code indicating whether and how interest is calculated on balances in this account. Used for customer/vendor interest calculation and treasury management.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostComponent rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Component' ;
    rdfs:comment 'Classification of the account as a component of landed cost calculation (freight, duty, insurance, customs). Critical for apparel import cost accounting and FOB to LDP reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this account. Required for detailed transaction analysis and audit trails.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether the account is managed on an open item basis, requiring explicit clearing of line items. Essential for AP, AR, and clearing accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct manual or automated postings are permitted to this account. Some accounts may be restricted to system-only postings or blocked entirely.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. Used to enforce segment reporting and profitability analysis by business unit.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Classification' ;
    rdfs:comment 'Detailed classification for income statement accounts including COGS, operating expenses, EBITDA components, and non-operating items. Used for margin analysis and profitability reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed postings from subsidiary ledgers such as Accounts Payable (AP), Accounts Receivable (AR), or asset accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-character code controlling the allocation and sorting of line items within the account. Used for automatic payment programs and dunning.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax classification code indicating whether the account is subject to input tax, output tax, non-taxable, or tax-exempt treatment. Used for VAT/GST reporting and compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Four-character code defining posting and clearing tolerances for the account. Controls maximum amounts and variances permitted in transactions.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or framework applied in this ledger (e.g., IFRS, US GAAP, local country GAAP, management accounting, tax accounting). Determines valuation rules, recognition policies, and reporting requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Posting Status' ;
    rdfs:comment 'Status of accrual and deferral postings for the current period. Accruals ensure expenses and revenues are recognized in the correct period per the applicable accounting principle (IFRS, GAAP). Pending indicates accruals not yet posted; complete indicates all accruals posted; partial indicates some accruals posted.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency for this ledger (e.g., USD, EUR, GBP). All financial amounts in this ledger are expressed or translated into this currency.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'The chart of accounts used in this ledger, defining the structure and numbering of general ledger (GL) accounts. Supports operational, group, and country-specific charts of accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeBlockingReason rdf:type rdf:Property ;
    rdfs:label 'Close Blocking Reason' ;
    rdfs:comment 'Free-text description of the issue preventing period close completion when close_checklist_status is blocked. Examples: unreconciled intercompany balances, missing accruals, pending depreciation run, outstanding approvals.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCalendarTemplate rdf:type rdf:Property ;
    rdfs:label 'Close Calendar Template' ;
    rdfs:comment 'Identifier or name of the close calendar template defining the structured sequence of close tasks, milestones, and deadlines for this ledger. Templates standardize close processes across periods and company codes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Close Checklist Status' ;
    rdfs:comment 'Overall status of the period-end close checklist for the current period. Not started indicates close has not begun; in progress indicates active close tasks; complete indicates all steps finished and approved; blocked indicates close is halted due to issues.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeResponsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Close Responsible Owner' ;
    rdfs:comment 'Name or identifier of the finance team member or role responsible for managing the period-end close process for this ledger. Accountable for completing close checklist steps and obtaining sign-off approvals.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier of the consolidation group or reporting entity to which this ledger belongs. Used for group-level financial consolidation and statutory reporting across multiple company codes and legal entities.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger is used for group consolidation and statutory reporting. True if the ledger feeds consolidation systems; false for local or management ledgers.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency perspective for this ledger. Company code currency is local operational currency; group currency is the consolidation currency; hard currency is a stable reference currency; index currency supports inflation-adjusted reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Current Fiscal Year' ;
    rdfs:comment 'The fiscal year currently active for posting and reporting in this ledger (e.g., 2024). Updated at fiscal year rollover.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPostingPeriod rdf:type rdf:Property ;
    rdfs:label 'Current Posting Period' ;
    rdfs:comment 'The posting period currently open for transaction entry in this ledger (1-16, where 1-12 are regular periods and 13-16 are special periods for adjustments). Controlled by period-end close process.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationRunStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Status' ;
    rdfs:comment 'Status of the periodic depreciation calculation and posting run for fixed assets in this ledger. Depreciation run is a mandatory step in the End of Month (EOM) close process.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal calendar structure for this ledger (number of periods, period start/end dates, year-end date). Supports calendar year, non-calendar year, and special period configurations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Reconciliation Status' ;
    rdfs:comment 'Status of intercompany balance reconciliation for the current period. Reconciled indicates all intercompany transactions match between trading partners; variance identified indicates discrepancies requiring resolution before close.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCloseDate rdf:type rdf:Property ;
    rdfs:label 'Last Close Date' ;
    rdfs:comment 'The date on which the most recent period close was completed and signed off. Represents the last successful End of Month (EOM) close milestone.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Last Closed Period' ;
    rdfs:comment 'The most recent posting period that has completed the End of Month (EOM) close process and is locked for further postings. Used to track close progress and enforce period controls.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadingLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Leading Ledger Flag' ;
    rdfs:comment 'Indicates whether this is the leading ledger (primary book of record) for the organization. True for the leading ledger; false for extension or special purpose ledgers. Only one leading ledger is permitted per client.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Short alphanumeric code identifying the ledger in SAP S/4HANA (e.g., 0L for leading ledger, 2L for IFRS ledger). Used as the business identifier for the ledger across financial transactions and reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the accounting ledger (e.g., Leading Ledger, IFRS Ledger, Management Accounting Ledger). Human-readable label for business users.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger. Active ledgers accept postings; inactive ledgers are configured but not yet in use; closed ledgers are archived and read-only; suspended ledgers are temporarily blocked.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger role in the accounting architecture. Leading ledger is the primary book of record; extension ledgers support parallel accounting views (IFRS, local GAAP); special purpose ledgers support management accounting or simulation scenarios.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiGaapComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Gaap Compliance Flag' ;
    rdfs:comment 'Indicates whether this ledger is part of a multi-GAAP parallel accounting setup, supporting simultaneous compliance with multiple accounting standards (e.g., IFRS and US GAAP). True if multi-GAAP; false if single standard.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCloseDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Close Due Date' ;
    rdfs:comment 'The target date by which the next period close must be completed. Drives the close calendar and task scheduling for depreciation runs, accruals, intercompany reconciliation, and statutory reporting milestones.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parallelAccountingScenario rdf:type rdf:Property ;
    rdfs:label 'Parallel Accounting Scenario' ;
    rdfs:comment 'Describes the specific parallel accounting use case this ledger supports (e.g., IFRS 16 Leases, US GAAP Revenue Recognition, Local Tax Reporting). Free-text field for business context.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Period Lock Status' ;
    rdfs:comment 'Indicates whether the current posting period is open for all users, locked to prevent further postings, or partially locked (open only for specific user groups or account ranges). Managed during End of Month (EOM) close.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'SAP posting period variant controlling the number of posting periods and special periods (e.g., 12 regular periods plus 4 special periods for year-end adjustments). Governs period open/close controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffApprover rdf:type rdf:Property ;
    rdfs:label 'Sign Off Approver' ;
    rdfs:comment 'Name or identifier of the senior finance leader (e.g., CFO, Controller, Finance Director) responsible for final approval and sign-off of the period close for this ledger. Approval confirms financial statements are complete and accurate.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The date on which the sign-off approver formally approved the period close and financial statements for this ledger. Marks the official completion of the close process.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statutoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Statutory Reporting Status' ;
    rdfs:comment 'Status of statutory financial reporting deliverables for this ledger and period (e.g., balance sheet, income statement, cash flow statement per IFRS or local GAAP). Not started indicates reports not yet generated; submitted indicates reports filed with authorities; approved indicates reports signed off by auditors or management.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The valuation approach applied in this ledger. Legal valuation follows local statutory rules; group valuation applies corporate consolidation policies; profit center and segment valuations support internal management reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item in the document currency (transaction currency). Used for multi-currency reporting and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of the journal entry line item in the company code\'s local currency. Used for statutory financial statements and local GAAP reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text field used for additional sorting and grouping of line items. Often contains purchase order numbers, project codes, or other business references for reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicator for debit (S=Soll/debit) or credit (H=Haben/credit) posting. Fundamental accounting classification for double-entry bookkeeping.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level. Provides business context for the entire document (e.g., \'Month-end accrual for freight costs\', \'Intercompany elimination Q1 2024\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known accounting document number assigned by SAP S/4HANA FI. Unique within company code and fiscal year. Used for audit trail and cross-reference.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code classifying the journal entry by business transaction type (e.g., SA=GL account document, DR=customer invoice, KR=vendor invoice, AB=accounting document). Controls number ranges and posting rules.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date when the journal entry was physically entered into the SAP system by the user. Used for audit trail and process monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate used to convert document currency to local currency. Applied at document header level for all line items.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Code identifying the type of exchange rate used (e.g., M=average rate, B=bank buying rate, G=bank selling rate). Determines which rate table is used for currency conversion.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an intercompany transaction requiring elimination during financial consolidation. True for intercompany, False for external transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the line item level providing business context for the specific posting (e.g., \'Accrued freight for shipment #12345\', \'COGS adjustment for SKU ABC123\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code\'s local currency. Used for statutory reporting and local GAAP compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls the type of posting (debit/credit) and the account type (GL, customer, vendor, asset). Determines field status and posting behavior in SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this journal entry was reversed, if applicable. Null if not reversed. Used for tracking accrual reversals and corrections.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Organizational unit for segment reporting per IFRS 8. Represents an operating segment for which discrete financial information is available and regularly reviewed by chief operating decision maker.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Identifier for the intercompany trading partner in intercompany transactions. Used for intercompany eliminations and consolidation in multi-entity organizations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-code) used to create this journal entry (e.g., FB01, FB50, F-02). Indicates whether entry was manual or automated from SD/MM/PP modules.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationDate rdf:type rdf:Property ;
    rdfs:label 'Translation Date' ;
    rdfs:comment 'The date used to determine the exchange rate for currency translation. Typically the posting date or document date.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project Systems work breakdown structure element for project-related postings. Enables project cost tracking and capital expenditure management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line detail record.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount of the line item converted to the corporate group reporting currency. Used for consolidated financial statements and group-level EBITDA analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Monetary amount of the line item in the original transaction currency. Used for multi-currency operations and foreign exchange tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date for payment terms calculation. Starting point for determining due dates and cash discount periods in AP/AR processing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when this line item was cleared or settled. Used for open item management in AP/AR and reconciliation processes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing transaction that settled this line item. Links open items to their corresponding payment or offset entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer account number for accounts receivable postings. Links financial transactions to customer master data for AR aging and revenue recognition.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting. Distinguishes between production, sales, administration, and other functional cost categories per IFRS/GAAP requirements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the corporate group reporting currency. Used for consolidation and group-level financial analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order number for overhead cost collection and allocation. Used for tracking costs of internal activities, events, or short-term projects.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Manufacturing plant or distribution center code for location-specific cost allocation. Used for multi-site COGS analysis and supply chain cost tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of goods or materials associated with this line item. Used for inventory movements, COGS calculation, and unit cost analysis.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceKey1 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 1' ;
    rdfs:comment 'First reference key field for linking to source documents or external systems. Commonly used for invoice numbers, PO numbers, or EDI transaction references.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey2 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 2' ;
    rdfs:comment 'Second reference key field for additional cross-reference tracking. Supports multi-level document traceability and reconciliation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey3 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 3' ;
    rdfs:comment 'Third reference key field for extended reference data. Used in complex allocation scenarios or multi-system integration environments.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversal transaction if this line item was reversed. Maintains complete audit trail for corrected entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Storage location within a plant for detailed inventory tracking. Enables warehouse-level cost allocation and inventory valuation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner company code for intercompany transactions. Identifies the counterparty legal entity in cross-company postings for consolidation elimination.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction amount. Represents the currency in which the original business transaction occurred.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Value date for cash management and bank reconciliation. Represents the effective date when funds are available or debited.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Vendor account number for accounts payable postings. Links financial transactions to supplier master data for AP aging and payment processing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS element for project-related postings. Links financial transactions to specific project phases or deliverables in PLM and capital project accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Recognition Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice is recognized as part of COGS for apparel sourcing and manufacturing costs.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the cash discount per payment terms.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ifrsAccrualFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Accrual Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice has been accrued for IFRS financial reporting purposes prior to receipt of the vendor invoice.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'The business category of the invoice expense: raw materials, CMT (Cut Make Trim) services, freight, operating expenses, capital expenditure, or other.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. This is the principal business event timestamp for the invoice.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor-provided invoice number as printed on the invoice document. This is the external business identifier for the invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow. [ENUM-REF-CANDIDATE: draft|posted|blocked|approved|paid|cancelled|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'The type of invoice document: standard invoice, credit memo (vendor refund), debit memo (additional charge), prepayment, or recurring invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostFlag rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Flag' ;
    rdfs:comment 'Boolean flag indicating whether this invoice contributes to landed cost (LDP) accounting for imported goods, including freight, duties, and customs charges.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether payment for this invoice is currently blocked pending resolution of discrepancies or approval.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'The reason code or description explaining why payment is blocked (e.g., price variance, quantity variance, missing goods receipt, pending approval).' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number assigned when payment is made, linking the invoice to the payment transaction for reconciliation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order (PO), goods receipt (GR), and invoice receipt (IR). Critical for invoice approval and payment release.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'An additional reference number provided by the vendor for their internal tracking or cross-reference purposes.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment to the vendor per local tax regulations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingBlockReason rdf:type rdf:Property ;
    rdfs:label 'Billing Block Reason' ;
    rdfs:comment 'Free-text or coded reason if the invoice was blocked from posting. Common reasons include credit limit exceeded, pricing errors, incomplete delivery, or customer account on hold. Null for unblocked invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The date the invoice was issued to the customer. Serves as the baseline for payment terms calculation and revenue recognition timing per IFRS 15.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date the most recent dunning notice was sent to the customer for this overdue invoice. Used to track collections activity and determine next dunning action timing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections reminder) level for overdue invoices. Typically ranges from 0 (no dunning) to 3+ (final notice before legal action). Increments with each escalation cycle.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceNotes rdf:type rdf:Property ;
    rdfs:label 'Invoice Notes' ;
    rdfs:comment 'Free-text field for additional invoice-level comments, special instructions, or customer-specific billing notes. May include payment instructions, dispute details, or special handling requirements.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Equals net_amount minus any payments received. Used for AR aging reports, DSO calculation, and cash collection forecasting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Customer rebates and retrospective discounts accrued or applied to this invoice. Common in wholesale channel for volume-based incentives. Tracked separately from standard discounts for rebate accrual accounting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date revenue from this invoice is recognized in the general ledger per IFRS 15 criteria. May differ from billing date based on performance obligation fulfillment (e.g., shipment date, delivery date, or service completion date).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method used to recognize revenue from this invoice per IFRS 15. Point-in-time is standard for product sales at shipment or delivery. Over-time applies to service contracts. Deferred applies to advance payments. Milestone applies to custom manufacturing or ODM (Original Design Manufacturer) contracts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The channel through which the sale was made. Wholesale represents B2B sales to retailers, DTC (Direct-to-Consumer) online represents e-commerce sales, DTC store represents company-owned retail, retail represents third-party retail, and marketplace represents platform sales. Critical for channel profitability analysis and GMROI (Gross Margin Return on Investment) calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financePaymentId rdf:type rdf:Property ;
    rdfs:label 'Finance Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancePayment .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Payments are made from/to bank accounts. Normalizing STRING bank_account_number to FK bank_account_id → bank_account.bank_account_id. Remove redundant bank_account_number and house_bank_id STRING colu' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:letterOfCreditId rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Id' ;
    rdfs:comment 'Foreign key linking to finance.letter_of_credit. Business justification: Payments can be linked to letters of credit for trade finance. Normalizing STRING lc_number to FK letter_of_credit_id → letter_of_credit.letter_of_credit_id. Remove redundant lc_number and lc_issuing_' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfCredit .

ind:vendorBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_bank_account. Business justification: AP payment disbursement to vendors requires tracing which specific vendor bank account received each payment. Apparel fashion payment audit trails and bank reconciliation processes require this link t' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorBankAccount .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Fees charged by the bank for processing the payment transaction, including wire transfer fees, LC handling fees, or foreign exchange fees.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankStatementDate rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Date' ;
    rdfs:comment 'The date on which this payment appeared on the bank statement, used for bank reconciliation and cash positioning.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryBankName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Name' ;
    rdfs:comment 'The name of the beneficiary\'s bank institution receiving or sending the payment.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code of the beneficiary\'s bank, used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'The name of the payment recipient (vendor, supplier, or customer). For outgoing payments, this is the payee; for incoming receipts, this is the payer.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockIndicator rdf:type rdf:Property ;
    rdfs:label 'Block Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the payment is blocked for processing due to approval requirements, compliance holds, or dispute resolution. True if blocked, False if released.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text explanation for why the payment is blocked, such as pending approval, invoice dispute, compliance review, or missing documentation.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'The payment amount converted to the company\'s local reporting currency for consolidation and statutory reporting per IFRS/GAAP requirements.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date when this payment was successfully reconciled with the bank statement, completing the cash management cycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of bank statement reconciliation: matched to bank statement, unmatched, partially matched, or under review by treasury team.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Identifier for the automated payment run batch in SAP S/4HANA FI that grouped multiple payments for processing. Used for batch reconciliation and audit trails.' ;
    rdfs:domain ind:FinancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostId rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.landed_cost. Business justification: COGS entries in apparel fashion capture LDP cost components (ldp_cost, fob_cost, duty_cost, freight_cost) that are derived from landed cost records. Adding landed_cost_id links the COGS recognition ev' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandedCost .

ind:originalEntryCogsEntryId rdf:type rdf:Property ;
    rdfs:label 'Original Entry Cogs Entry Id' ;
    rdfs:comment 'Reference to the original COGS entry ID if this entry is a reversal or adjustment, supporting audit trail and reconciliation.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CogsEntry .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The actual cost per unit incurred for this SKU, including all manufacturing and procurement costs.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'The difference between standard cost and actual cost per unit, used for cost control and variance analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'The inventory costing method applied to calculate the COGS for this entry (standard, average, FIFO, LIFO, or specific identification).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'The merchandise category code for the product, enabling category-level profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which the COGS was recognized, typically aligned with revenue recognition per IFRS 15 or GAAP ASC 606.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'The geographic region code where the sale occurred, enabling regional profitability analysis.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCogsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cogs Amount' ;
    rdfs:comment 'The total COGS amount for this entry, calculated as actual cost multiplied by quantity sold.' ;
    rdfs:domain ind:CogsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Air Freight Amount' ;
    rdfs:comment 'The cost of air freight transportation if goods were shipped by air. Component of landed cost for expedited shipments.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which the landed cost calculation was performed. Used for financial period assignment and audit purposes.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsBrokerageAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Brokerage Amount' ;
    rdfs:comment 'The fee paid to customs brokers for handling import documentation and customs clearance procedures.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'The customs duty paid to import the goods into the destination country. Calculated based on HS code tariff rate and customs value.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fob Price Amount' ;
    rdfs:comment 'The FOB price of the goods as agreed with the supplier. Represents the cost of goods before international freight and insurance.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which the landed cost was posted to the general ledger. Determines the financial period for COGS recognition and inventory valuation.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which the goods were physically received into inventory. Determines the accounting period for cost recognition.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gspPreferenceApplied rdf:type rdf:Property ;
    rdfs:label 'Gsp Preference Applied' ;
    rdfs:comment 'Indicates whether a GSP tariff preference was applied to reduce or eliminate customs duty. True if GSP benefits were utilized.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gspPreferenceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Gsp Preference Rate Percent' ;
    rdfs:comment 'The reduced tariff rate percentage applied under GSP preference. Null if no GSP preference was applied.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'The Incoterms 2020 code defining the terms of delivery and cost responsibility between buyer and seller. Common values: FOB, CIF, EXW, FCA, CPT, CIP, DAP, DPU, DDP. [ENUM-REF-CANDIDATE: FOB|CIF|EXW|FCA|CPT|CIP|DAP|DPU|DDP — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inlandFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Inland Freight Amount' ;
    rdfs:comment 'The cost of domestic transportation from the port of discharge to the final warehouse or distribution center.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'The cost of cargo insurance covering the goods during international transit. Component of landed cost.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedCostNumber rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Number' ;
    rdfs:comment 'Business identifier for the landed cost calculation. Human-readable reference number used in financial reporting and audit trails.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCostStatus rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Status' ;
    rdfs:comment 'The current status of the landed cost record in the financial workflow. Values: draft (initial calculation), calculated (computation complete), approved (reviewed and approved), posted (recorded to general ledger), reversed (corrected or cancelled).' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterOfCreditNumber rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Number' ;
    rdfs:comment 'The letter of credit number used to secure payment for this shipment. Links to trade finance instruments.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oceanFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Ocean Freight Amount' ;
    rdfs:comment 'The cost of ocean freight transportation from the port of loading to the port of discharge. Component of landed cost.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country of manufacture or origin for the goods. Used for customs duty calculation and trade compliance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portHandlingAmount rdf:type rdf:Property ;
    rdfs:label 'Port Handling Amount' ;
    rdfs:comment 'The cost of port handling services including unloading, storage, and terminal fees at the port of discharge.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfDischarge rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge' ;
    rdfs:comment 'The seaport or airport where the goods were unloaded upon arrival. Used for customs clearance and port handling cost allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'The seaport or airport from which the goods were shipped. Used for freight cost allocation and logistics tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The quantity of goods received in this shipment. Used to calculate unit landed cost and allocate costs across units.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tariff Rate Percent' ;
    rdfs:comment 'The customs duty rate percentage applied to the goods based on the HS code and origin country. Used to calculate the customs duty amount.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLandedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Landed Cost Amount' ;
    rdfs:comment 'The total landed duty paid cost per unit or shipment. Sum of FOB price, freight, insurance, customs duty, and all other charges. Authoritative cost basis for inventory valuation and COGS.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLandedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Landed Cost Amount' ;
    rdfs:comment 'The landed cost per individual unit of the SKU. Calculated by dividing total landed cost by quantity received. Used for per-unit inventory valuation.' ;
    rdfs:domain ind:LandedCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the company code was activated in the SAP S/4HANA FI system and began posting financial transactions.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Primary business segment classification for this company code within the apparel fashion group. Used for segment reporting, profitability analysis, and strategic planning.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character alphanumeric code uniquely identifying the legal entity within the SAP S/4HANA FI system. This is the business identifier used across all financial transactions and statutory reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Full legal name of the company as registered with statutory authorities. Used for financial statements, tax filings, and legal documentation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyNameShort rdf:type rdf:Property ;
    rdfs:label 'Company Name Short' ;
    rdfs:comment 'Abbreviated or trading name of the company used for internal reporting and operational displays.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyStatus rdf:type rdf:Property ;
    rdfs:label 'Company Status' ;
    rdfs:comment 'Current operational status of the company code. Active indicates the entity is operational and posting transactions. Inactive, dormant, liquidation, or merged indicate non-operational states.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entity Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code is included in group-level financial consolidation. True indicates the entity participates in consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting entity to which this company code belongs. Used for multi-level consolidation hierarchies and segment reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfSalesAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Of Sales Accounting Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code uses cost-of-sales accounting (income statement by function) or period accounting (income statement by nature). True indicates cost-of-sales method.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area responsible for managing customer credit limits and credit exposure for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the company code was deactivated or ceased operations. Null if the entity is still active.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the company code, if applicable. Used for formal legal and regulatory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusVariant rdf:type rdf:Property ;
    rdfs:label 'Field Status Variant' ;
    rdfs:comment 'Four-character code defining the field status variant that controls which fields are required, optional, or suppressed during financial document posting for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was incorporated or registered with the statutory authority. Used for legal compliance and entity lifecycle tracking.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this company code participates in automated intercompany clearing and reconciliation processes. True indicates intercompany transactions are tracked and cleared.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'Code identifying the standard profit center hierarchy used for profitability analysis and internal management reporting for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or sales tax registration number assigned by the local tax authority. Required for VAT reporting and cross-border transactions within VAT jurisdictions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for the intercompany transaction entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Intercompany transactions track sending legal entity for intercompany reconciliation. Normalizing STRING sending_company_code to FK sending_company_code_id → company_code.company_code_id (first FK to ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:sendingProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Intercompany transactions track sending profit center for segment reporting. Normalizing STRING sending_profit_center_code to FK sending_profit_center_id → profit_center.profit_center_id (first FK to ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date when the intercompany transaction was eliminated during the financial consolidation process. Null if elimination is still pending.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'The current status of the intercompany transaction in the consolidation elimination process. Pending indicates awaiting elimination; eliminated means fully removed from consolidated statements; partially eliminated for complex multi-step transactions; exception for transactions requiring manual review.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'The geographic region code associated with the intercompany transaction, used for regional segment reporting and transfer pricing documentation by jurisdiction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction translated into the group reporting currency using the applicable exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingPosition rdf:type rdf:Property ;
    rdfs:label 'Netting Position' ;
    rdfs:comment 'Indicates the settlement position of the intercompany transaction from the group perspective. Payable means the sending entity owes the receiving entity; receivable means the opposite; settled indicates payment completed; offset means netted against other transactions.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The company code of the legal entity that is the receiver or consumer in the intercompany transaction. Represents the entity being charged or receiving goods/services. Typically a 4-character alphanumeric code per SAP standard.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Profit Center Code' ;
    rdfs:comment 'The profit center code within the receiving company that is charged for the intercompany transaction. Used for internal profitability analysis and segment reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'The mechanism used to settle the intercompany transaction. Cash payment for direct fund transfer; netting for multilateral settlement; offset against other balances; loan conversion for capitalization; waiver for forgiveness.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction in the transaction currency. Represents the gross amount charged or transferred before any adjustments.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferPriceAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Adjustment Amount' ;
    rdfs:comment 'Any adjustment amount applied to the intercompany transaction to align with transfer pricing policy and arms-length principles. Positive values indicate upward adjustments; negative values indicate downward adjustments.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'The withholding tax rate percentage applied to the intercompany transaction based on applicable tax treaties and local regulations. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxItemId rdf:type rdf:Property ;
    rdfs:label 'Tax Item Id' ;
    rdfs:comment 'Unique identifier for the tax line item record in the financial system.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTaxItemId rdf:type rdf:Property ;
    rdfs:label 'Original Tax Item Id' ;
    rdfs:comment 'Reference to the original tax item record if this entry is a reversal or adjustment, enabling audit trail and reconciliation.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxItem .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'The customs declaration or entry number associated with import duty tax items, used for customs clearance tracking.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current status of this tax item in the filing and payment lifecycle: pending (not yet filed), filed (submitted to authorities), paid (payment completed), reconciled (confirmed by authorities), or disputed (under review or appeal).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the parent financial document, used for ordering and referencing individual tax entries.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Date' ;
    rdfs:comment 'The date used to determine the applicable tax rate and rules, typically the transaction date or delivery date.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is input tax (tax paid on purchases, recoverable) or output tax (tax collected on sales, payable to authorities).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The certificate or authorization number supporting the tax exemption claim, required for audit and compliance verification.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Code' ;
    rdfs:comment 'Code indicating the reason for tax exemption or reduced rate, if applicable (e.g., export exemption, diplomatic exemption, zero-rated goods).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Full name of the tax jurisdiction or authority (e.g., United States - California, European Union, HM Revenue & Customs UK).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The percentage rate applied to calculate the tax amount (e.g., 20.00 for 20% VAT, 5.50 for 5.5% import duty).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The fiscal period or reporting period to which this tax item belongs (e.g., 2024-Q1, 2024-03, 2024-FY).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'Reference number or identifier of the tax return filing in which this tax item is included for statutory reporting to tax authorities.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax applied: VAT (Value Added Tax), sales tax, import duty, excise duty, withholding tax, or GST (Goods and Services Tax).' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The base amount on which the tax is calculated, before tax is applied. Represents the net value subject to taxation.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this tax item represents withholding tax deducted at source from vendor payments.' ;
    rdfs:domain ind:TaxItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor or mill that was selected and awarded the business as a result of this RFQ evaluation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'The date when the RFQ was awarded to the selected vendor.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedQuoteAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Quote Amount' ;
    rdfs:comment 'The final quoted unit price from the awarded vendor.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Any regulatory, labor, or ethical compliance requirements that vendors must meet (e.g., WRAP certification, FLA compliance, CPSC safety standards).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume' ;
    rdfs:comment 'The anticipated total order volume or quantity that may be placed if the RFQ results in an award.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricComposition rdf:type rdf:Property ;
    rdfs:label 'Fabric Composition' ;
    rdfs:comment 'The fiber content and blend percentages for fabric RFQs (e.g., 80% Cotton 20% Polyester).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date when the RFQ was formally issued and sent to vendors or mills.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'The unit of measure for the MOQ (e.g., pieces, yards, meters, kilograms).' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'The quality specifications, testing standards, or acceptance criteria that vendors must meet (e.g., AQL 2.5, ISO 9001, specific performance requirements).' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Quote Received Count' ;
    rdfs:comment 'The number of vendor quotations received in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business-facing unique identifier for the RFQ, used in vendor communications and sourcing documentation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ: draft (being prepared), issued (sent to vendors), under evaluation (quotes received and being reviewed), awarded (vendor selected), closed (process complete), cancelled (RFQ withdrawn).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on sourcing scope: CMT (Cut Make Trim), FOB (Free on Board), material procurement, trim sourcing, fabric sourcing, or full package manufacturing.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Required Flag' ;
    rdfs:comment 'Indicates whether vendors are required to submit physical samples as part of their quotation response.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Sample Submission Deadline' ;
    rdfs:comment 'The deadline by which vendors must submit physical samples if required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Shipping Origin Country' ;
    rdfs:comment 'Three-letter ISO country code for the country from which goods will be shipped (e.g., CHN for China, VNM for Vietnam, IND for India).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingRegion rdf:type rdf:Property ;
    rdfs:label 'Sourcing Region' ;
    rdfs:comment 'The geographic region being targeted for sourcing through this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleReference rdf:type rdf:Property ;
    rdfs:label 'Style Reference' ;
    rdfs:comment 'The style number or design reference code that this RFQ is requesting quotes for.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The final date by which vendors must submit their quotations in response to this RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityRequirement rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirement' ;
    rdfs:comment 'Any sustainability or certification requirements specified in the RFQ (e.g., GOTS certified, BCI cotton, OEKO-TEX Standard 100, recycled materials, organic).' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCost rdf:type rdf:Property ;
    rdfs:label 'Target Cost' ;
    rdfs:comment 'The desired or budgeted unit cost that the business is aiming to achieve through this RFQ process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCount rdf:type rdf:Property ;
    rdfs:label 'Vendor Count' ;
    rdfs:comment 'The number of vendors or mills to whom this RFQ has been issued.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Notes' ;
    rdfs:comment 'Internal notes from the buyer or sourcing team regarding special requirements, constraints, or context for this line item.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderClassification rdf:type rdf:Property ;
    rdfs:label 'Gender Classification' ;
    rdfs:comment 'Target gender demographic for the product. Used for merchandising planning and assortment allocation.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingRequirement rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirement' ;
    rdfs:comment 'Packaging specifications for this line item. Includes polybag requirements, hangtags, labels, carton specifications, and shipping marks.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityBreakTier1 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 1' ;
    rdfs:comment 'First quantity threshold for tiered pricing. Vendors provide different unit costs based on volume commitments.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBreakTier2 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 2' ;
    rdfs:comment 'Second quantity threshold for tiered pricing. Enables cost comparison across different volume scenarios.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBreakTier3 rdf:type rdf:Property ;
    rdfs:label 'Quantity Break Tier 3' ;
    rdfs:comment 'Third quantity threshold for tiered pricing. Supports complex volume-based sourcing strategies.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which vendors must submit their quotations for this line item. Critical for Time and Action (TNA) calendar management.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCmtCost rdf:type rdf:Property ;
    rdfs:label 'Target Cmt Cost' ;
    rdfs:comment 'Target CMT cost per unit for manufacturing services only. Excludes material costs, represents labor and production overhead.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFobCost rdf:type rdf:Property ;
    rdfs:label 'Target Fob Cost' ;
    rdfs:comment 'Target FOB cost per unit that the buyer is seeking from vendors. Represents the price at the port of origin before shipping.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingRequirement rdf:type rdf:Property ;
    rdfs:label 'Testing Requirement' ;
    rdfs:comment 'Laboratory testing requirements for materials or finished goods. May include colorfastness, shrinkage, pilling, flammability, or chemical content testing.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Notes' ;
    rdfs:comment 'Notes or comments provided by vendors in their quotation response. May include production constraints, alternative suggestions, or clarification requests.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Status' ;
    rdfs:comment 'Current status of vendor responses for this RFQ line. Tracks the quotation lifecycle from request through vendor selection.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Id' ;
    rdfs:comment 'Unique identifier for the vendor quote record. Primary key.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuote .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Foreign key linking to logistics.lane. Business justification: Apparel vendor quotes include freight cost estimates based on specific logistics lanes (origin port → destination DC). Linking vendor_quote to lane enables freight cost benchmarking — comparing quoted' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date the buyer formally accepted this quote. Triggers conversion to purchase order or contract.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Buyer decision status on this quote. Indicates whether the quote has been accepted, rejected, or is under negotiation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkScore rdf:type rdf:Property ;
    rdfs:label 'Benchmark Score' ;
    rdfs:comment 'Comparative score assigned to this quote during vendor selection analysis. Enables objective comparison across multiple vendor quotes.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAvailableUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Available Units' ;
    rdfs:comment 'Production capacity available from the vendor for this quote period. Indicates maximum units the vendor can produce within the lead time window.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmtRate rdf:type rdf:Property ;
    rdfs:label 'Cmt Rate' ;
    rdfs:comment 'Quoted CMT rate per unit. Represents the manufacturing labor cost for cutting fabric, making the garment, and trimming/finishing, excluding material costs.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterTerms rdf:type rdf:Property ;
    rdfs:label 'Counter Terms' ;
    rdfs:comment 'Any counter-proposals, exceptions, or deviations from the original RFQ terms proposed by the vendor. Captures negotiation points.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fobPrice rdf:type rdf:Property ;
    rdfs:label 'Fob Price' ;
    rdfs:comment 'Quoted FOB price per unit. Represents the cost of goods loaded onto the shipping vessel at the port of origin, excluding freight and insurance.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Estimate' ;
    rdfs:comment 'Estimated freight cost per unit from port of loading to destination. May be provided by vendor or calculated internally.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpEstimate rdf:type rdf:Property ;
    rdfs:label 'Ldp Estimate' ;
    rdfs:comment 'Estimated total landed cost per unit including FOB price, freight, insurance, duties, and taxes. Provides a complete cost view for comparison.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality certifications or standards the vendor commits to for this quote (e.g., OEKO-TEX Standard 100, GOTS, ISO 9001, WRAP). Ensures compliance with quality and ethical standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date the vendor submitted or issued this quote.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Vendor-assigned unique identifier for this quotation. Used for external reference and vendor communication.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quote in the sourcing workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|rejected|expired|withdrawn|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteVersion rdf:type rdf:Property ;
    rdfs:label 'Quote Version' ;
    rdfs:comment 'Version number of this quote. Increments when vendor revises or resubmits the quote in response to negotiation or clarification.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleCost rdf:type rdf:Property ;
    rdfs:label 'Sample Cost' ;
    rdfs:comment 'Cost per sample unit for pre-production (PP) samples. Samples are typically required for approval before bulk production.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sample Lead Time Days' ;
    rdfs:comment 'Number of days required to produce and deliver pre-production samples for approval. Critical for Sample Management System (SMS) workflow.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolingCost rdf:type rdf:Property ;
    rdfs:label 'Tooling Cost' ;
    rdfs:comment 'One-time cost for tooling, molds, dies, or setup required for production. May be amortized across order quantity or charged separately.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'Expiration date of the quote. After this date, the vendor is not obligated to honor the quoted terms.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Destination Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Apparel vendor cost quotes calculate LDP costs to a specific destination DC. Linking vendor_cost_quote to distribution_center enables DC-level LDP cost benchmarking, freight cost accuracy validation, ' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:agentCommission rdf:type rdf:Property ;
    rdfs:label 'Agent Commission' ;
    rdfs:comment 'Commission paid to sourcing agent or buying office per unit. Typically a percentage of FOB cost, expressed as absolute amount per unit.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsEstimate rdf:type rdf:Property ;
    rdfs:label 'Cogs Estimate' ;
    rdfs:comment 'Estimated COGS per unit including all landed costs and internal allocation of overhead. Used for financial planning and margin calculation.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:embellishmentCost rdf:type rdf:Property ;
    rdfs:label 'Embellishment Cost' ;
    rdfs:comment 'Additional cost for embellishments such as embroidery, printing, appliqué, or special finishes. Optional cost component for decorated styles.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImuPercent rdf:type rdf:Property ;
    rdfs:label 'Target Imu Percent' ;
    rdfs:comment 'Target initial markup percentage for this style based on merchandising strategy. Used to validate if the quoted cost supports desired retail price and margin.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Target Retail Price' ;
    rdfs:comment 'Target retail price for this style. Used with cost quote to calculate achievable margin and validate pricing strategy.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingCertificationCost rdf:type rdf:Property ;
    rdfs:label 'Testing Certification Cost' ;
    rdfs:comment 'Cost per unit for product testing and certifications (OEKO-TEX, GOTS, CPSC compliance testing, etc.). Amortized across production quantity.' ;
    rdfs:domain ind:VendorCostQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'UN/LOCODE 5-character code for the destination port where goods will be received (e.g., USNYC for New York, DEHAM for Hamburg).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Total customs duty amount for imported goods in the specified currency. Relevant for international sourcing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobPortCode rdf:type rdf:Property ;
    rdfs:label 'Fob Port Code' ;
    rdfs:comment 'UN/LOCODE 5-character code for the port where goods are loaded and ownership transfers from vendor to buyer (e.g., CNSHA for Shanghai, VNSGN for Ho Chi Minh City).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landedCost rdf:type rdf:Property ;
    rdfs:label 'Landed Cost' ;
    rdfs:comment 'Total landed cost including product value, freight, duties, taxes, and all other costs to deliver goods to final destination. Used for true Cost of Goods Sold (COGS) calculation.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Approval Status' ;
    rdfs:comment 'Status of pre-production (PP) sample approval for this purchase order: not_required (bulk order without sample), pending (awaiting review), approved (sample accepted), rejected (sample failed), conditional (approved with modifications).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window End Date' ;
    rdfs:comment 'Latest acceptable date for the vendor to ship goods. Defines the end of the delivery window.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window Start Date' ;
    rdfs:comment 'Earliest acceptable date for the vendor to ship goods. Defines the beginning of the delivery window.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Tna Milestone Status' ;
    rdfs:comment 'Overall status of Time and Action calendar milestones for this purchase order: on_track (meeting deadlines), at_risk (potential delay), delayed (missed milestone), completed (all milestones met).' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the purchase order in the specified currency, including all line items before taxes and duties.' ;
    rdfs:domain ind:SourcingPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of units ordered across all line items on this purchase order.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'The actual date this line item was received and recorded in the warehouse management system. Used for goods receipt reconciliation.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Delivery performance status for this line item. Used for OTIF (On Time In Full) tracking and supplier performance measurement.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'The expected date for receiving this line item at the destination warehouse or facility. Used for inbound planning.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineTotalCost rdf:type rdf:Property ;
    rdfs:label 'Line Total Cost' ;
    rdfs:comment 'The total cost for this line item, calculated as ordered quantity multiplied by unit cost. Represents the extended line value.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'The remaining quantity yet to be received for this line item. Calculated as ordered quantity minus received quantity.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Status' ;
    rdfs:comment 'The approval status for pre-production samples associated with this line item. Critical gate in the TNA calendar before bulk production.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:styleCode rdf:type rdf:Property ;
    rdfs:label 'Style Code' ;
    rdfs:comment 'The style or design code associated with this line item. Links to the product design and collection in PLM systems.' ;
    rdfs:domain ind:SourcingPurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkProductionStartActualDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Production Start Actual Date' ;
    rdfs:comment 'Actual date when bulk production started. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bulkProductionStartPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Production Start Planned Date' ;
    rdfs:comment 'Planned date for bulk production to commence at the factory. Follows PP approval.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayDays rdf:type rdf:Property ;
    rdfs:label 'Delay Days' ;
    rdfs:comment 'Total number of days the T&A calendar is delayed relative to planned milestones. Calculated field for reporting.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Free-text explanation of the primary cause of delay if T&A is at risk or delayed. Used for root cause analysis.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exFactoryActualDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Actual Date' ;
    rdfs:comment 'Actual date when goods left the factory. Null if milestone not yet achieved.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exFactoryPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Ex Factory Planned Date' ;
    rdfs:comment 'Planned date for goods to leave the factory. Critical milestone for shipment and logistics planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Actual Date' ;
    rdfs:comment 'Actual date when fabric approval was completed. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Approval Planned Date' ;
    rdfs:comment 'Planned date for fabric approval milestone. Critical pre-production milestone for material sign-off.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inDcActualDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Actual Date' ;
    rdfs:comment 'Actual date when goods arrived at the distribution center. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inDcPlannedDate rdf:type rdf:Property ;
    rdfs:label 'In Dc Planned Date' ;
    rdfs:comment 'Planned date for goods to arrive at the distribution center. End of pre-production T&A scope.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Order Quantity' ;
    rdfs:comment 'Total quantity planned for this production run. May exceed MOQ based on demand forecast.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Actual Date' ;
    rdfs:comment 'Actual date when pre-production sample was approved. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Planned Date' ;
    rdfs:comment 'Planned date for pre-production sample approval. Gate for bulk production authorization.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Actual Date' ;
    rdfs:comment 'Actual date when pre-production sample was submitted. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSamplePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Planned Date' ;
    rdfs:comment 'Planned date for pre-production sample submission. Critical milestone for final fit and construction approval before bulk production.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaCode rdf:type rdf:Property ;
    rdfs:label 'Tna Code' ;
    rdfs:comment 'Business identifier for the Time and Action calendar. Externally-known unique code used across PLM and sourcing systems.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaStatus rdf:type rdf:Property ;
    rdfs:label 'Tna Status' ;
    rdfs:comment 'Current lifecycle status of the T&A calendar. Indicates overall health and progress of the sourcing timeline. [ENUM-REF-CANDIDATE: draft|active|on_track|at_risk|delayed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tnaType rdf:type rdf:Property ;
    rdfs:label 'Tna Type' ;
    rdfs:comment 'Classification of the T&A calendar type. Indicates the phase of product lifecycle this calendar governs.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Actual Date' ;
    rdfs:comment 'Actual date when trim approval was completed. Null if milestone not yet achieved.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trimApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Trim Approval Planned Date' ;
    rdfs:comment 'Planned date for trim and accessories approval milestone. Includes buttons, zippers, labels, and other components.' ;
    rdfs:domain ind:TnaCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcingTnaMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Tna Milestone Id' ;
    rdfs:comment 'Unique identifier for the sourcing TNA milestone record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingTnaMilestone .

ind:freightBookingId rdf:type rdf:Property ;
    rdfs:label 'Freight Booking Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_booking. Business justification: In apparel TNA management, the \'freight booking confirmed\' milestone is directly validated against the actual freight booking record. This FK enables TNA milestone completion verification against book' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightBooking .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the individual who provided the approval decision. Null if approval is not required or not yet provided.' ;
    rdfs:domain ind:SourcingTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferDays rdf:type rdf:Property ;
    rdfs:label 'Buffer Days' ;
    rdfs:comment 'Number of buffer days built into the schedule for this milestone to absorb potential delays. Part of risk mitigation planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current state of the milestone in its lifecycle. Tracks progress from planning through completion.' ;
    rdfs:domain ind:SourcingTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the milestone was escalated to management. Null if no escalation has occurred.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'High-level classification of the milestone type. Groups milestones into functional categories for analysis and reporting.' ;
    rdfs:domain ind:SourcingTnaMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized short code for the milestone type (e.g., FAB_APPR, PP_SMPL, BULK_CUT, TRIM_APPR, LAB_DIP, FIT_SMPL). Enables consistent reporting and system integration.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Business name of the milestone event (e.g., Fabric Approval, Pre-Production (PP) Sample Submission, Bulk Cut Start, Trim Approval, Lab Dip Approval, Strike-Off Approval, Fit Sample Due, Size Set Approval, Top of Production).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final approval decision for the sample: approved (sample meets all requirements and production can proceed), approved_with_comments (sample acceptable with minor notes for production), rejected (sample does not meet requirements and must be revised).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorAccuracyEvaluation rdf:type rdf:Property ;
    rdfs:label 'Color Accuracy Evaluation' ;
    rdfs:comment 'Assessment of how accurately the sample color matches the approved lab dip or Pantone standard, including any color correction instructions.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionEvaluationComments rdf:type rdf:Property ;
    rdfs:label 'Construction Evaluation Comments' ;
    rdfs:comment 'Evaluation comments on the construction quality of the sample, including seam quality, stitching, finishing, and adherence to construction specifications in the tech pack.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed list of corrective actions that the factory must implement before submitting the next sample revision, including specific changes to fit, construction, materials, or measurements.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the sample evaluation was completed and documented.' ;
    rdfs:domain ind:Sourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Factory Submission Date' ;
    rdfs:comment 'Actual date when the factory submitted the sample for evaluation.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitEvaluationComments rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Comments' ;
    rdfs:comment 'Detailed comments from the fit evaluation session describing how the sample fits on the fit model, including any adjustments needed to silhouette, ease, or proportions.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialFabricReference rdf:type rdf:Property ;
    rdfs:label 'Material Fabric Reference' ;
    rdfs:comment 'Reference code for the fabric used in the sample, linking to the material library in PLM system for fabric specifications and sourcing details.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementConformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Conformance Status' ;
    rdfs:comment 'Indicates whether the sample measurements conform to the tech pack specifications: pass (all measurements within tolerance), fail (critical measurements out of spec), within_tolerance (acceptable variance), out_of_spec (unacceptable variance).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDeviationDetails rdf:type rdf:Property ;
    rdfs:label 'Measurement Deviation Details' ;
    rdfs:comment 'Specific details of any measurement deviations from tech pack specifications, including which measurements are out of tolerance and by how much.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientLocation rdf:type rdf:Property ;
    rdfs:label 'Recipient Location' ;
    rdfs:comment 'Office or facility location where the sample should be delivered (e.g., headquarters, regional office, showroom).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier for the sample request, externally visible and used for tracking and communication with factories and internal teams.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the sample request: draft (being prepared), submitted (sent to factory), in_production (factory is making sample), shipped (sample in transit), received (sample arrived), under_evaluation (being evaluated), approved (evaluation complete and approved), rejected (evaluation complete and rejected), cancelled (request cancelled). [ENUM-REF-CANDIDATE: draft|submitted|in_production|shipped|received|under_evaluation|approved|rejected|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the sample cost (e.g., USD, EUR, CNY).' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCostFob rdf:type rdf:Property ;
    rdfs:label 'Sample Cost Fob' ;
    rdfs:comment 'Cost charged by the factory for producing the sample on a FOB (Free on Board) basis, used for budgeting and cost tracking.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimReference rdf:type rdf:Property ;
    rdfs:label 'Trim Reference' ;
    rdfs:comment 'Reference codes for trims and accessories used in the sample (buttons, zippers, labels, etc.), linking to the material library.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Sample Evaluation Id' ;
    rdfs:comment 'Primary key for sample_evaluation' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Color Accuracy Score' ;
    rdfs:comment 'Assessment of color match against approved lab dip or color standard. Evaluates color consistency across all materials and components.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorComments rdf:type rdf:Property ;
    rdfs:label 'Color Comments' ;
    rdfs:comment 'Detailed observations on color accuracy including shade variations, color matching between components, and lighting condition notes. Critical for color approval decisions.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Construction Quality Score' ;
    rdfs:comment 'Assessment of garment construction quality including seam quality, stitching consistency, finishing, and workmanship. Evaluates adherence to construction specifications in tech pack.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Duration Minutes' ;
    rdfs:comment 'Time spent conducting the evaluation in minutes. Used for resource planning and process efficiency analysis.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'General notes and observations from the evaluation that do not fit into specific category comments. Captures additional context and evaluator insights.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the evaluation record. Externally visible evaluation tracking number used in communications with suppliers and internal teams.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the evaluation. Pending = awaiting evaluator assignment, In Progress = evaluation underway, Approved = sample meets all requirements, Approved with Comments = sample acceptable with minor notes, Rejected = sample fails requirements and must be revised, On Hold = evaluation paused pending additional information.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Full name of the person who conducted the evaluation. Captured for audit trail and communication purposes.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorRole rdf:type rdf:Property ;
    rdfs:label 'Evaluator Role' ;
    rdfs:comment 'Functional role of the evaluator. Determines evaluation focus area and approval authority level.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Fit Evaluation Score' ;
    rdfs:comment 'Overall assessment of garment fit against technical specifications. Pass = meets all fit requirements, Fail = significant fit issues, Acceptable = minor fit deviations within tolerance, Needs Improvement = fit issues requiring correction.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComments rdf:type rdf:Property ;
    rdfs:label 'Material Comments' ;
    rdfs:comment 'Detailed notes on material compliance including fabric hand feel, weight deviations, trim substitutions, and any material quality concerns. Documents material approval or rejection reasons.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Material Compliance Score' ;
    rdfs:comment 'Assessment of whether materials used match approved specifications. Evaluates fabric type, weight, composition, and trim components against Bill of Materials (BOM).' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementComments rdf:type rdf:Property ;
    rdfs:label 'Measurement Comments' ;
    rdfs:comment 'Detailed documentation of specific measurement points that deviate from specifications, including actual vs. target measurements and tolerance analysis.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Deviation Flag' ;
    rdfs:comment 'Indicates whether any measurements fall outside acceptable tolerance ranges defined in the tech pack. True = deviations exist, False = all measurements within tolerance.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallApprovalDecision rdf:type rdf:Property ;
    rdfs:label 'Overall Approval Decision' ;
    rdfs:comment 'Final approval decision for the sample. Approved = sample passes all criteria and can proceed to production, Approved with Comments = sample acceptable with documented notes, Rejected = sample fails and requires revision.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Flag' ;
    rdfs:comment 'Indicates whether photographic documentation was captured during evaluation. True = photos attached, False = no photos. Photos are critical for communicating issues to suppliers.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Date' ;
    rdfs:comment 'Date when Pre-Production (PP) approval was granted. Critical milestone in the sourcing timeline that triggers production authorization.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Approval Flag' ;
    rdfs:comment 'Indicates whether this evaluation resulted in Pre-Production (PP) approval, which authorizes the supplier to proceed with bulk production. True = PP approved, False = PP not approved.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Category' ;
    rdfs:comment 'Primary category of rejection when sample is not approved. Helps categorize supplier performance issues and track common failure modes. [ENUM-REF-CANDIDATE: fit|construction|material|color|measurement|workmanship|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required Flag' ;
    rdfs:comment 'Indicates whether supplier must resubmit a revised sample. True = resubmission required, False = no resubmission needed (approved or approved with minor comments).' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Notified Date' ;
    rdfs:comment 'Date when evaluation results were communicated to the supplier. Tracks communication timeliness and supplier response time.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetResubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resubmission Date' ;
    rdfs:comment 'Expected date for supplier to resubmit revised sample. Drives Time and Action (TNA) calendar updates and production timeline management.' ;
    rdfs:domain ind:SampleEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualLabA rdf:type rdf:Property ;
    rdfs:label 'Actual Lab A' ;
    rdfs:comment 'Measured green-red axis value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLabB rdf:type rdf:Property ;
    rdfs:label 'Actual Lab B' ;
    rdfs:comment 'Measured blue-yellow axis value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLabL rdf:type rdf:Property ;
    rdfs:label 'Actual Lab L' ;
    rdfs:comment 'Measured lightness value of the submitted lab dip in CIELAB color space.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorFastnessRating rdf:type rdf:Property ;
    rdfs:label 'Color Fastness Rating' ;
    rdfs:comment 'Rating (1-5 scale) indicating the color fastness performance of the dyed fabric. Higher values indicate better resistance to fading. Based on ISO 105 testing standards.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStandardType rdf:type rdf:Property ;
    rdfs:label 'Color Standard Type' ;
    rdfs:comment 'Type of color standard used for matching specification (Pantone, LAB values, RGB, CMYK, or physical swatch).' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deltaEValue rdf:type rdf:Property ;
    rdfs:label 'Delta E Value' ;
    rdfs:comment 'Calculated color difference (Delta E) between target and actual color. Lower values indicate closer match. Typically acceptable range is Delta E < 1.0 for critical color matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalImageUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Image Url' ;
    rdfs:comment 'URL link to digital photograph or scan of the lab dip sample. Enables remote review and digital archiving.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dyeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Dye Lot Number' ;
    rdfs:comment 'Batch identifier for the dye lot used in this lab dip submission. Critical for traceability and consistency in bulk production.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dyeRecipeCode rdf:type rdf:Property ;
    rdfs:label 'Dye Recipe Code' ;
    rdfs:comment 'Code identifying the specific dye formulation and recipe used for this color. Links to dye house technical specifications.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStrikeOffRequired rdf:type rdf:Property ;
    rdfs:label 'Is Strike Off Required' ;
    rdfs:comment 'Boolean flag indicating whether a larger strike-off sample (printed or dyed fabric yardage) is required after lab dip approval before bulk production commitment.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labDipNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Dip Number' ;
    rdfs:comment 'Business identifier for the lab dip submission. Externally-known reference number used across PLM systems and vendor communications.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightFastnessGrade rdf:type rdf:Property ;
    rdfs:label 'Light Fastness Grade' ;
    rdfs:comment 'Grade (1-8 scale) measuring resistance to color change from light exposure. Grade 8 is excellent, grade 1 is poor.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pantoneReference rdf:type rdf:Property ;
    rdfs:label 'Pantone Reference' ;
    rdfs:comment 'Pantone color standard reference code used as the target color specification for matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePhysicalLocation rdf:type rdf:Property ;
    rdfs:label 'Sample Physical Location' ;
    rdfs:comment 'Physical storage location of the lab dip sample swatch (e.g., design studio, quality lab, archive). Used for sample retrieval and reference.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrophotometerReadingFile rdf:type rdf:Property ;
    rdfs:label 'Spectrophotometer Reading File' ;
    rdfs:comment 'File path or reference to the spectrophotometer measurement data file. Contains detailed color measurement data for technical analysis.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionRound rdf:type rdf:Property ;
    rdfs:label 'Submission Round' ;
    rdfs:comment 'Sequential number indicating which submission attempt this represents (1 for first submission, 2 for resubmit, etc.). Tracks iteration count in color approval process.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetBulkProductionDate rdf:type rdf:Property ;
    rdfs:label 'Target Bulk Production Date' ;
    rdfs:comment 'Planned date for bulk fabric production to begin. Drives urgency of lab dip approval process within TNA calendar.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetLabA rdf:type rdf:Property ;
    rdfs:label 'Target Lab A' ;
    rdfs:comment 'Target green-red axis value in CIELAB color space. Negative values indicate green, positive indicate red.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLabB rdf:type rdf:Property ;
    rdfs:label 'Target Lab B' ;
    rdfs:comment 'Target blue-yellow axis value in CIELAB color space. Negative values indicate blue, positive indicate yellow.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLabL rdf:type rdf:Property ;
    rdfs:label 'Target Lab L' ;
    rdfs:comment 'Target lightness value in CIELAB color space (0-100 scale). Used for precise color measurement and matching.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:washFastnessGrade rdf:type rdf:Property ;
    rdfs:label 'Wash Fastness Grade' ;
    rdfs:comment 'Grade (1-5 scale) measuring resistance to color change from washing. Grade 5 is excellent, grade 1 is poor.' ;
    rdfs:domain ind:LabDip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendor\'s bank account number used for electronic payment transfers and settlements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the vendor maintains their primary business banking account.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official government-issued business registration or tax identification number for the vendor entity.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStatus rdf:type rdf:Property ;
    rdfs:label 'Business Status' ;
    rdfs:comment 'Current operational status of the vendor relationship indicating whether the vendor is actively engaged, suspended, or terminated.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of compliance certifications held by the vendor, such as WRAP, FLA, GOTS, OEKO-TEX, ISO 9001, ISO 14001, ISO 45001, BCI, or other industry-recognized standards.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor has the technical capability to exchange business documents electronically using EDI standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the vendor received final executive or procurement approval to be added to the approved vendor list.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fobPort rdf:type rdf:Property ;
    rdfs:label 'Fob Port' ;
    rdfs:comment 'Name of the port or location where goods are loaded for shipment and where ownership and risk transfer from vendor to buyer under FOB terms.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Actual date when the vendor became operational and began fulfilling orders or providing services to the business.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full physical address of the vendor\'s primary headquarters or registered office location.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcTermsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lc Terms Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor requires payment to be secured through a letter of credit for international transactions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqValue rdf:type rdf:Property ;
    rdfs:label 'Moq Value' ;
    rdfs:comment 'Minimum monetary value required for a purchase order to be accepted by the vendor, expressed in the vendor\'s currency.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Actual date when all onboarding activities and checklist items were completed and the vendor was approved for activation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Percentage' ;
    rdfs:comment 'Percentage of onboarding checklist items completed, calculated as completed tasks divided by total required tasks, expressed as a decimal (0.00 to 100.00).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingManager rdf:type rdf:Property ;
    rdfs:label 'Onboarding Manager' ;
    rdfs:comment 'Name of the internal employee or team responsible for managing the vendor onboarding process and ensuring completion of all required steps.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the vendor onboarding workflow process, tracking progress from initial documentation through final approval and system setup. [ENUM-REF-CANDIDATE: Not Started|Documentation|Compliance Review|Factory Audit|Contract Negotiation|System Setup|Approved|Completed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the vendor organization for operational communications.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCapacityUnitsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Units Per Month' ;
    rdfs:comment 'Maximum number of units the vendor can produce or supply per month based on their current production capacity and resources.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRatingScore rdf:type rdf:Property ;
    rdfs:label 'Quality Rating Score' ;
    rdfs:comment 'Vendor quality performance score based on defect rates, compliance with specifications, and quality audit results, typically on a scale of 0.00 to 5.00.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'International bank identifier code used for cross-border wire transfers and international payments to the vendor.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Go Live Date' ;
    rdfs:comment 'Planned date when the vendor is expected to be fully operational and ready to begin fulfilling orders or providing services.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Government-issued tax identification number used for tax reporting and compliance purposes in the vendor\'s country of operation.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Supply chain tier level indicating the vendor\'s position in the supply chain hierarchy. Tier 1 represents direct suppliers, Tier 2 represents suppliers to Tier 1, and so on.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the type of goods or services provided. CMT (Cut Make Trim) for contract manufacturers, OEM (Original Equipment Manufacturer), ODM (Original Design Manufacturer), Fabric Mill for textile suppliers, Trim Supplier for accessories, 3PL (Third-Party Logistics) for logistics providers. [ENUM-REF-CANDIDATE: CMT|OEM|ODM|Fabric Mill|Trim Supplier|3PL|Raw Material|Packaging|Logistics|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor is eligible and approved to participate in vendor-managed inventory programs where they manage stock levels at buyer locations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifications rdf:type rdf:Property ;
    rdfs:label 'Certifications' ;
    rdfs:comment 'Comma-separated list of current valid certifications held by the factory (e.g., WRAP, FLA, GOTS, OEKO-TEX Standard 100, ISO 9001, ISO 14001, ISO 45001, BCI, BSCI). Required for compliance verification and ethical sourcing.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the factory was originally established or began operations. Indicates factory maturity and operational experience.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total manufacturing floor space in square meters. Used to assess factory scale, capacity utilization, and compliance with workplace safety standards.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderSpecialization rdf:type rdf:Property ;
    rdfs:label 'Gender Specialization' ;
    rdfs:comment 'Primary gender category focus of the factory production capability. Some factories specialize in specific gender categories due to sizing, fit, and construction expertise.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent purchase order placed with this factory. Used to identify inactive suppliers and manage supplier lifecycle.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:machineryTypes rdf:type rdf:Property ;
    rdfs:label 'Machinery Types' ;
    rdfs:comment 'Comma-separated list of key machinery and equipment types available at the factory (e.g., single-needle machines, overlock machines, flatlock machines, buttonhole machines, pressing equipment, cutting tables). Determines production capabilities and product suitability.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfProductionLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Production Lines' ;
    rdfs:comment 'Total count of active production lines or assembly lines operating within the factory. Indicates scale and parallel production capability.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoriesManufactured rdf:type rdf:Property ;
    rdfs:label 'Product Categories Manufactured' ;
    rdfs:comment 'Comma-separated list of product categories the factory is equipped to manufacture (e.g., T-shirts, Dresses, Outerwear, Denim, Activewear, Footwear, Accessories). Used for supplier selection and product allocation.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broader geographic region classification for sourcing strategy and logistics planning (e.g., South Asia, Southeast Asia, East Asia, Europe, Americas).' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStructure rdf:type rdf:Property ;
    rdfs:label 'Shift Structure' ;
    rdfs:comment 'Daily shift operation model of the factory. Indicates production hours and capacity flexibility. Triple shift operations provide maximum throughput but require strong labor compliance oversight.' ;
    rdfs:domain ind:SupplierFactory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of decision-making authority the contact has within the vendor organization (e.g., Operational, Managerial, Executive). Used to determine appropriate escalation paths and approval workflows.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCredentials rdf:type rdf:Property ;
    rdfs:label 'Certification Credentials' ;
    rdfs:comment 'Professional certifications or credentials held by the contact relevant to their role (e.g., WRAP Auditor, GOTS Certified, Six Sigma Black Belt, ISO 9001 Lead Auditor). Supports compliance verification and quality assurance.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name or given name of the vendor contact person.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFullName rdf:type rdf:Property ;
    rdfs:label 'Contact Full Name' ;
    rdfs:comment 'Full legal name of the vendor contact person, including first name, middle name, and last name.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name or family name of the vendor contact person.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the vendor contact record. Indicates whether the contact is actively engaged, temporarily unavailable, or no longer with the vendor organization.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Number' ;
    rdfs:comment 'Emergency contact phone number for urgent situations requiring immediate vendor response, such as production issues, quality failures, or compliance incidents.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Primary language(s) spoken by the contact for business communications. Supports multilingual vendor management and reduces miscommunication risk. Use ISO 639-1 two-letter codes (e.g., EN, ZH, ES, FR, IT, PT, DE, JA, KO, VI, BN, HI).' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this vendor contact. Used for relationship management and engagement tracking.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number of the vendor contact person for urgent communications and field coordination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or site where the contact is based within the vendor organization (e.g., factory name, office branch, city). Used for site visit planning and logistics coordination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingManagerName rdf:type rdf:Property ;
    rdfs:label 'Reporting Manager Name' ;
    rdfs:comment 'Name of the contact\'s direct manager or supervisor within the vendor organization. Used for escalation paths and organizational context.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Standardized role classification indicating the primary function of the contact in the vendor relationship. Used for routing communications and workflow assignments.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationArea rdf:type rdf:Property ;
    rdfs:label 'Specialization Area' ;
    rdfs:comment 'Specific area of expertise or specialization of the contact within their role (e.g., Fabric Sourcing, Garment Construction, Chemical Compliance, Export Documentation, Quality Testing). Used for routing specialized inquiries.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wechatHandle rdf:type rdf:Property ;
    rdfs:label 'Wechat Handle' ;
    rdfs:comment 'WeChat contact identifier or username used for instant messaging communication with the vendor contact, commonly used for China-based suppliers.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whatsappHandle rdf:type rdf:Property ;
    rdfs:label 'Whatsapp Handle' ;
    rdfs:comment 'WhatsApp contact identifier (typically phone number) used for instant messaging communication with the vendor contact, commonly used in international sourcing operations.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Number of years of professional experience the contact has in their field or role. Used for assessing vendor capability and relationship strength.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Account Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the bank account. Determines the settlement currency for payments and impacts foreign exchange requirements.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Must match vendor legal name for payment processing and compliance verification.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Address' ;
    rdfs:comment 'Full address of the bank branch or headquarters. Required for international payment routing and compliance documentation.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Code' ;
    rdfs:comment 'Branch identifier or sort code used for domestic payment routing. Format varies by country (e.g., UK sort code, Indian IFSC code).' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held. Used for domestic payment routing and vendor communication.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the bank\'s domicile. Critical for cross-border payment routing, foreign exchange, and compliance with international sanctions and trade regulations.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAddress rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Address' ;
    rdfs:comment 'Full address of the account beneficiary. Required for international wire transfers and compliance with anti-money laundering (AML) regulations.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External identifier for this bank account in the source system or vendor portal. Used for cross-system reconciliation and data integration.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for cross-border payments within SEPA and other regions. Standardized format for international payment routing.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Name of the intermediary or correspondent bank used for routing international payments when direct settlement is not available. Common in cross-border transactions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the intermediary bank. Required for routing payments through correspondent banking networks in international transactions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment processed to this bank account in the account currency. Used for payment pattern analysis and fraud detection.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment processed to this bank account. Used for account activity monitoring and dormant account identification.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lc Expiry Date' ;
    rdfs:comment 'Expiration date of the current Letter of Credit arrangement for this vendor account. After this date, a new LC must be issued for continued payment processing.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcIssuingBank rdf:type rdf:Property ;
    rdfs:label 'Lc Issuing Bank' ;
    rdfs:comment 'Name of the bank that issues Letters of Credit on behalf of the buyer (Apparel Fashion) for payments to this vendor. Required when LC payment method is used.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lc Required Flag' ;
    rdfs:comment 'Indicates whether a Letter of Credit is required for payments to this vendor account. True if LC is mandatory for trade finance compliance or vendor risk mitigation.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcTerms rdf:type rdf:Property ;
    rdfs:label 'Lc Terms' ;
    rdfs:comment 'Specific terms and conditions governing Letter of Credit issuance for this vendor, including sight/usance terms, document requirements, and negotiation conditions.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority ranking for this bank account when multiple accounts exist for a vendor. Lower numbers indicate higher priority. Used by AP automation to select payment account.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Account Flag' ;
    rdfs:comment 'Indicates whether this is the primary/default bank account for the vendor. True if this account should be used by default for payment processing when multiple accounts exist.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'ABA routing number for US domestic payments (ACH and wire transfers). Nine-digit code identifying the financial institution.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the bank account: micro-deposit test transactions, document review (bank statement/voided check), third-party verification service, manual verification, or bank letter confirmation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factoryCertificationId rdf:type rdf:Property ;
    rdfs:label 'Factory Certification Id' ;
    rdfs:comment 'Unique identifier for the factory certification record. Primary key.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FactoryCertification .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the national or international accreditation body that accredits the certifying body (e.g., ANAB, UKAS, DAkkS, CNAS). Provides additional assurance of the certifying body\'s competence.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditGrade rdf:type rdf:Property ;
    rdfs:label 'Audit Grade' ;
    rdfs:comment 'Grade or rating assigned during the certification audit. A indicates excellent compliance with no major findings. B indicates good compliance with minor findings. C indicates acceptable compliance with moderate findings requiring corrective action. D indicates poor compliance with major findings. Not Graded indicates the certification does not use a grading system.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'URL or file path to the detailed audit report document. Contains findings, observations, and recommendations from the certification audit.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the certification certificate document stored in the document management system or cloud storage. Used for verification and audit trail purposes.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCost rdf:type rdf:Property ;
    rdfs:label 'Certification Cost' ;
    rdfs:comment 'Total cost incurred for obtaining or renewing the certification, including audit fees, consulting fees, and administrative costs. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Certification Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost (e.g., USD, EUR, GBP, CNY).' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Level or tier of certification achieved, if the certification standard has multiple levels (e.g., \'Gold\', \'Silver\', \'Bronze\', \'Level 1\', \'Level 2\'). Null if the certification does not have levels.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Numerical compliance score assigned during the audit, typically expressed as a percentage (0.00 to 100.00). Higher scores indicate better compliance with certification standards. Null if the certification does not use numerical scoring.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which corrective actions must be completed and verified. Format: yyyy-MM-dd. Null if no corrective actions are required.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether corrective actions are required to address audit findings. True if corrective action plan (CAP) is required. False if no corrective actions are needed.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action plan. Not required indicates no corrective actions are needed. Pending indicates corrective actions have been identified but not yet started. In progress indicates corrective actions are being implemented. Completed indicates corrective actions have been implemented and are awaiting verification. Verified indicates corrective actions have been verified by the certifying body. Overdue indicates corrective actions have not been completed by the due date.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certification is included in Environmental, Social, and Governance (ESG) reporting and sustainability disclosures. True if included in ESG reporting. False otherwise.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformities or critical findings identified during the certification audit. Major findings typically require immediate corrective action and may impact certification status.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformities or observations identified during the certification audit. Minor findings require corrective action but do not immediately threaten certification status.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next surveillance or recertification audit. Format: yyyy-MM-dd. Null if not yet scheduled.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'Specific product categories or types covered by the certification (e.g., \'Woven apparel\', \'Knit garments\', \'Footwear\', \'Accessories\'). Indicates which product lines are certified.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Boolean flag indicating whether this certification is publicly disclosed on the company\'s website or in sustainability reports. True if publicly disclosed. False if confidential.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Initiated Date' ;
    rdfs:comment 'Date on which the certification renewal process was formally initiated. Format: yyyy-MM-dd. Null if renewal has not been initiated.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Status of the certification renewal process. Not due indicates renewal is not yet required. Renewal initiated indicates renewal process has been started. Renewal in progress indicates renewal audit or documentation review is underway. Renewal completed indicates certification has been successfully renewed. Renewal failed indicates renewal was not successful and certification may expire or be revoked.' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'Detailed description of the scope and coverage of the certification, including specific product categories, processes, or facilities covered (e.g., \'Cut-Make-Trim operations for woven garments\', \'Dyeing and finishing of cotton fabrics\', \'Full manufacturing facility including warehousing\').' ;
    rdfs:domain ind:FactoryCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Id' ;
    rdfs:comment 'Unique identifier for the compliance audit record. Primary key for the compliance audit entity.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:announcedFlag rdf:type rdf:Property ;
    rdfs:label 'Announced Flag' ;
    rdfs:comment 'Boolean indicator of whether the audit was announced to the supplier in advance. True indicates the supplier was notified ahead of time; False indicates an unannounced surprise audit.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees, travel expenses, and certification body charges. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of days spent conducting the on-site audit fieldwork. Includes partial days represented as decimals (e.g., 2.5 days).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date when the audit fieldwork concluded. For multi-day audits, this represents the last day of on-site inspection.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFramework rdf:type rdf:Property ;
    rdfs:label 'Audit Framework' ;
    rdfs:comment 'The compliance standard or framework against which the audit was conducted. Examples include FLA Workplace Code of Conduct, WRAP 12 Principles, BSCI Code of Conduct, Sedex SMETA, GOTS, OEKO-TEX Standard 100, ISO 14001, SA8000.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique audit reference number assigned by the auditing organization or internal compliance team.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'The date when the audit fieldwork began. For multi-day audits, this represents the first day of on-site inspection.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its focus area. Social Compliance covers labor practices and working conditions; Environmental covers sustainability and environmental impact; Quality covers product quality systems; Fire Safety covers fire prevention and emergency preparedness; Chemical REACH covers chemical safety and REACH compliance; Structural Safety covers building and facility structural integrity.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingFirm rdf:type rdf:Property ;
    rdfs:label 'Auditing Firm' ;
    rdfs:comment 'Name of the third-party auditing organization or certification body that conducted the audit. Examples include Bureau Veritas, SGS, Intertek, UL, TUV. Null if the audit was conducted by internal compliance team.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor who conducted the compliance audit. May be an internal compliance officer or external third-party auditor.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Approved Flag' ;
    rdfs:comment 'Boolean indicator of whether the submitted Corrective Action Plan has been reviewed and approved by the compliance team or auditing body. True indicates approval; False indicates rejection or pending review.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capDueDate rdf:type rdf:Property ;
    rdfs:label 'Cap Due Date' ;
    rdfs:comment 'The deadline by which the supplier must submit a formal Corrective Action Plan addressing all identified non-conformances. Null if no CAP is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal Corrective Action Plan is required from the supplier to address identified non-conformances. True indicates CAP is mandatory; False indicates no CAP required (typically for audits with no significant findings).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Cap Submitted Date' ;
    rdfs:comment 'The date when the supplier submitted their Corrective Action Plan in response to audit findings. Null if CAP has not yet been submitted or is not required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification body issuing the compliance certificate or audit credential. Relevant for WRAP, FLA, GOTS, OEKO-TEX, BSCI, and Sedex audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Certification Valid From Date' ;
    rdfs:comment 'The effective start date of the compliance certification issued as a result of this audit. Applicable for certification audits (WRAP, FLA, GOTS, OEKO-TEX). Null for non-certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Certification Valid Until Date' ;
    rdfs:comment 'The expiration date of the compliance certification issued as a result of this audit. Applicable for certification audits (WRAP, FLA, GOTS, OEKO-TEX). Null for non-certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalNcrCount rdf:type rdf:Property ;
    rdfs:label 'Critical Ncr Count' ;
    rdfs:comment 'Number of critical non-conformances identified during the audit. Critical NCRs represent severe violations that pose immediate risk to worker safety, health, or fundamental rights (e.g., child labor, forced labor, unsafe structural conditions).' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factoryScore rdf:type rdf:Property ;
    rdfs:label 'Factory Score' ;
    rdfs:comment 'Overall numerical score assigned to the factory based on audit findings. Scoring scale varies by audit framework (e.g., 0-100 for some frameworks, A-F letter grades converted to numeric for others). Higher scores indicate better compliance.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Final Audit Status' ;
    rdfs:comment 'The final outcome determination of the audit after all reviews and corrective actions. Pass indicates full compliance; Conditional Pass indicates compliance with minor issues requiring monitoring; Fail indicates non-compliance requiring immediate action; Pending Corrective Action indicates awaiting CAP implementation; Certification Granted/Denied applies to certification audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level narrative summary of the key audit findings, including strengths, weaknesses, and areas of concern identified during the inspection. Provides context for the numerical scores and NCR counts.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Major Ncr Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major NCRs represent significant violations of compliance standards that require corrective action but do not pose immediate critical risk.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementInterviewsCount rdf:type rdf:Property ;
    rdfs:label 'Management Interviews Count' ;
    rdfs:comment 'Number of factory management personnel interviewed during the audit to assess management systems, policies, and commitment to compliance.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcrCount rdf:type rdf:Property ;
    rdfs:label 'Minor Ncr Count' ;
    rdfs:comment 'Number of minor non-conformances identified during the audit. Minor NCRs represent less severe violations or areas for improvement that do not significantly impact compliance status.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reauditDueDate rdf:type rdf:Property ;
    rdfs:label 'Reaudit Due Date' ;
    rdfs:comment 'The scheduled date for the follow-up re-audit to verify corrective action implementation. Null if no re-audit is required.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reauditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reaudit Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a follow-up re-audit is required to verify that corrective actions have been implemented and non-conformances have been resolved. True indicates re-audit is mandatory; False indicates no re-audit needed.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerInterviewsCount rdf:type rdf:Property ;
    rdfs:label 'Worker Interviews Count' ;
    rdfs:comment 'Number of factory workers interviewed during the audit as part of the social compliance assessment. Worker interviews are a key component of FLA, WRAP, and BSCI audits.' ;
    rdfs:domain ind:ComplianceAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the supplier audit finding record. Primary key for the supplier audit finding entity.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the corrective action was completed, verified, and the finding was formally closed. Null if the finding remains open.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Additional notes, observations, or context provided by the auditor regarding the finding, including mitigating factors, supplier cooperation, or special circumstances.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Description of the potential or actual business impact of the finding, including production delays, quality issues, regulatory penalties, reputational risk, or supply chain disruption.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current status of the finding in the corrective action lifecycle. Open: newly identified, action not started. In Progress: corrective action underway. Pending Verification: action completed, awaiting verification. Closed: verified and accepted. Overdue: past target closure date without completion.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToRemediate rdf:type rdf:Property ;
    rdfs:label 'Cost To Remediate' ;
    rdfs:comment 'Estimated or actual cost incurred by the supplier to implement the corrective action and remediate the finding, including infrastructure upgrades, training, process changes, or equipment purchases.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Url' ;
    rdfs:comment 'URL or file path to supporting evidence documentation for the finding, including photographs, audit reports, corrective action plans, or verification records stored in the document management system.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Primary classification of the non-conformance finding based on the compliance domain. Categories include Labor (working conditions, child labor, forced labor), Health & Safety (workplace safety, PPE, ergonomics), Environmental (waste management, emissions, water usage), Chemical (restricted substances, OEKO-TEX compliance), Fire Safety (exits, extinguishers, evacuation plans), and Wages (minimum wage, overtime pay, payroll records).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance finding, including specific observations, conditions found, and evidence collected during the audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Finding Identified Date' ;
    rdfs:comment 'Date when the non-conformance finding was first identified during the audit inspection or assessment.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Business-readable unique reference number assigned to this non-conformance finding for tracking and communication purposes.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSubcategory rdf:type rdf:Property ;
    rdfs:label 'Finding Subcategory' ;
    rdfs:comment 'Detailed subcategory or specific compliance area within the primary finding category, providing granular classification for analysis and reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFindingReference rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Reference' ;
    rdfs:comment 'Reference number of the previous finding if this is identified as a repeat finding, enabling linkage and trend analysis of recurring non-conformances.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the specific regulatory requirement, standard clause, or compliance framework that was violated or not met, such as WRAP Principle 3, FLA Code Section 2.1, or OEKO-TEX Standard 100 Annex 6.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Boolean indicator (True/False) identifying whether this finding is a repeat occurrence of a previously identified and closed non-conformance at the same supplier, indicating systemic compliance issues or ineffective corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePartyTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Title' ;
    rdfs:comment 'Job title or position of the responsible party at the supplier factory, such as Factory Manager, Compliance Officer, or Health & Safety Coordinator.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause of the non-conformance, identifying systemic issues, process gaps, or resource constraints that led to the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Classification of the finding\'s severity based on risk and impact. Critical: immediate threat to worker safety or legal compliance, requires immediate action. Major: significant non-compliance requiring corrective action. Minor: low-risk non-compliance requiring improvement. Observation: opportunity for improvement without formal non-compliance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed and the finding closed, based on severity level and agreed-upon remediation timeline.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name of the auditor, compliance officer, or third-party inspector who verified the corrective action completion and effectiveness.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Confirmation Date' ;
    rdfs:comment 'Date when the factory formally confirmed or committed to this capacity allocation.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Capacity Risk Level' ;
    rdfs:comment 'Risk assessment level for capacity availability based on factory performance, compliance, and external factors (low, medium, high, critical).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityType rdf:type rdf:Property ;
    rdfs:label 'Capacity Type' ;
    rdfs:comment 'Classification of capacity status: allocated (assigned to orders), reserved (held for future orders), available (open for booking), committed (contractually bound), or planned (forecasted).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Month' ;
    rdfs:comment 'Total production capacity expressed in units per month for the specified product category and season.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Valid From Date' ;
    rdfs:comment 'Start date of the period for which this capacity profile is valid and applicable.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityValidToDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Valid To Date' ;
    rdfs:comment 'End date of the period for which this capacity profile is valid and applicable.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Current status of factory compliance certifications (WRAP, FLA, GOTS, OEKO-TEX) relevant to this capacity profile.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum number of units that can be produced in a single production run or order cycle for this product category.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target percentage for on-time and in-full delivery performance expected from this factory for this capacity profile.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Season Flag' ;
    rdfs:comment 'Indicator whether this capacity profile represents a peak production season with higher demand and tighter lead times.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningSystemSource rdf:type rdf:Property ;
    rdfs:label 'Planning System Source' ;
    rdfs:comment 'Name of the source planning system or module from which this capacity profile was created or synchronized (e.g., Anaplan, SAP PP, Oracle RMS).' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCount rdf:type rdf:Property ;
    rdfs:label 'Production Line Count' ;
    rdfs:comment 'Number of production lines or assembly lines dedicated to this product category during the capacity period.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Historical quality acceptance rate (percentage of units passing quality inspection) for this factory and product category.' ;
    rdfs:domain ind:CapacityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of total capacity currently utilized, calculated as (allocated + reserved) / total capacity * 100.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorScorecardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Id' ;
    rdfs:comment 'Unique identifier for the vendor scorecard evaluation record.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aqlDefectRatePercent rdf:type rdf:Property ;
    rdfs:label 'Aql Defect Rate Percent' ;
    rdfs:comment 'Percentage of defective units found during quality inspections based on AQL sampling standards. Lower values indicate better quality performance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of vendor production capacity allocated to this business during the evaluation period. Indicates strategic partnership depth and allocation priority.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimRatePercent rdf:type rdf:Property ;
    rdfs:label 'Claim Rate Percent' ;
    rdfs:comment 'Percentage of orders resulting in quality claims, chargebacks, or Return to Vendor (RTV) actions during the evaluation period. Lower is better.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceAuditScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Score' ;
    rdfs:comment 'Composite score from social compliance and labor standards audits (WRAP, FLA, BSCI, Sedex). Typically scored 0-100 or letter grade converted to numeric.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCompetitivenessIndex rdf:type rdf:Property ;
    rdfs:label 'Cost Competitiveness Index' ;
    rdfs:comment 'Index comparing vendor pricing against market benchmarks and peer vendors. Values above 100 indicate above-market pricing; below 100 indicates competitive pricing.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Score' ;
    rdfs:comment 'Subjective score evaluating vendor contributions to product innovation, material development, process improvements, and value engineering initiatives.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimePerformanceDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Performance Days' ;
    rdfs:comment 'Average lead time in days from purchase order issuance to delivery during the evaluation period. Shorter lead times improve supply chain agility.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeSampleSubmissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Sample Submission Rate Percent' ;
    rdfs:comment 'Percentage of product samples (SMS, PP samples) submitted on or before the scheduled deadline per the Time and Action (TNA) calendar.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Order Fill Rate Percent' ;
    rdfs:comment 'Percentage of ordered quantity successfully fulfilled without shortages or cancellations. Measures vendor reliability and inventory management.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRatePercent rdf:type rdf:Property ;
    rdfs:label 'Otif Rate Percent' ;
    rdfs:comment 'Percentage of purchase orders delivered on time and in full during the evaluation period. Key operational KPI for supply chain reliability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallWeightedScore rdf:type rdf:Property ;
    rdfs:label 'Overall Weighted Score' ;
    rdfs:comment 'Composite weighted score aggregating all KPI dimensions (OTIF, quality, compliance, cost, responsiveness, sustainability) per the scorecard weighting methodology. Primary ranking metric.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Vendor classification tier based on overall weighted score. Preferred vendors receive priority allocation; Probation/Delisted vendors face restrictions or exit.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppSampleApprovalRatePercent rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Rate Percent' ;
    rdfs:comment 'Percentage of pre-production samples approved on first submission without requiring rework or resubmission. Indicates design and technical capability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'Vendor performance tier from the prior evaluation period. Enables trend analysis and tier movement tracking.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Strategic sourcing recommendation based on scorecard results. Drives allocation decisions, remediation plans, or vendor exit strategies.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the vendor must complete remediation actions and demonstrate improvement. Null if no remediation is required.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal corrective action or remediation plan is required due to performance deficiencies (True) or not (False).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsivenessRating rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Rating' ;
    rdfs:comment 'Subjective rating (typically 1-5 or 1-10 scale) assessing vendor communication quality, issue resolution speed, and collaboration effectiveness.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Change Flag' ;
    rdfs:comment 'Indicates whether the vendor tier changed from the previous evaluation period (True) or remained the same (False).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPoCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Count' ;
    rdfs:comment 'Total number of purchase orders issued to this vendor during the evaluation period. Indicates transaction volume and relationship scale.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Po Value Usd' ;
    rdfs:comment 'Total value in USD of all purchase orders issued to this vendor during the evaluation period. Provides spend context for performance assessment.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the supplier risk assessment record. Primary key.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which this risk assessment was conducted or recorded.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The methodology or approach used to conduct the risk assessment. Self-Assessment relies on supplier-provided information. Third-Party Audit uses independent auditors. Site Visit involves on-site inspection. Document Review analyzes certifications and records. Questionnaire uses structured surveys. Scorecard applies a standardized rating framework. Hybrid combines multiple methods. [ENUM-REF-CANDIDATE: Self-Assessment|Third-Party Audit|Site Visit|Document Review|Questionnaire|Scorecard|Hybrid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'The current workflow status of the risk assessment record. Draft indicates the assessment is being prepared. Under Review indicates it is awaiting approval. Approved indicates it has been validated and accepted. Closed indicates the risk has been resolved or is no longer relevant. Escalated indicates the risk requires senior management attention.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'The type or trigger of the risk assessment. Initial assessments occur during supplier onboarding, periodic assessments follow a schedule, triggered assessments respond to specific events or incidents.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactArea rdf:type rdf:Property ;
    rdfs:label 'Business Impact Area' ;
    rdfs:comment 'The primary business function or area that would be affected if the risk materializes. Supports prioritization and cross-functional risk management.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationReference rdf:type rdf:Property ;
    rdfs:label 'Certification Reference' ;
    rdfs:comment 'Reference number or identifier of any relevant certification or compliance audit that informed this risk assessment, such as WRAP, FLA, GOTS, OEKO-TEX, or ISO certifications.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Flag' ;
    rdfs:comment 'Indicates whether this risk assessment is related to Environmental, Social, or Governance (ESG) criteria. True if the risk has ESG implications, False otherwise. Supports ESG reporting and sustainability initiatives.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRiskRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Risk Region' ;
    rdfs:comment 'The geographic region or country associated with this risk, if the risk is location-specific. Supports geopolitical and regional risk analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'A numeric score representing the severity of consequences if the risk materializes. Typically scored on a scale of 1 to 5, where 1 is Negligible and 5 is Catastrophic. Considers financial, operational, reputational, and compliance impacts.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'The overall risk level before any mitigation measures are applied. Typically derived from the combination of likelihood and impact scores. Low indicates minimal concern, Medium requires monitoring, High requires active management, and Critical demands immediate action and escalation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'A numeric score representing the probability that the risk will materialize. Typically scored on a scale of 1 to 5, where 1 is Very Unlikely and 5 is Very Likely. Used in conjunction with impact score to calculate inherent risk rating.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationCost rdf:type rdf:Property ;
    rdfs:label 'Mitigation Cost' ;
    rdfs:comment 'The estimated or actual cost of implementing the mitigation strategy, in the company\'s reporting currency. Supports cost-benefit analysis and risk management budgeting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'The current implementation status of the mitigation strategy. Tracks progress from planning through execution.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'A detailed description of the actions, controls, or measures implemented or planned to reduce the likelihood or impact of the risk. May include supplier development programs, contract clauses, diversification strategies, audits, or contingency plans.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next review or reassessment of this risk. Ensures periodic monitoring and updates to risk status and mitigation effectiveness.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'The risk level remaining after mitigation measures have been applied. Represents the accepted or tolerated risk level. Used to determine if additional mitigation is required or if the risk is within acceptable tolerance.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the risk was resolved, closed, or deemed no longer relevant. Supports risk lifecycle tracking and historical analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'The standard interval at which this risk should be reviewed. High and Critical risks typically require more frequent review than Low risks.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'The primary category of risk being assessed. Geopolitical includes trade restrictions and political instability. Financial covers supplier solvency and payment risk. Compliance includes labor standards, environmental regulations, and certifications. Capacity addresses production volume and lead time risk. Quality covers defect rates and product safety. Environmental includes sustainability and carbon footprint. Labor covers working conditions and fair labor practices. Logistics includes transportation and delivery risk. Currency covers foreign exchange volatility. Reputational includes brand and ethical risk. Cybersecurity covers data protection and IT security. [ENUM-REF-CANDIDATE: Geopolitical|Financial|Compliance|Capacity|Quality|Environmental|Labor|Logistics|Currency|Reputational|Cybersecurity — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'A detailed narrative description of the identified risk, including context, potential triggers, and specific concerns. Provides qualitative detail for risk understanding and communication.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'A more granular classification of the risk within the primary category. For example, under Compliance, subcategories might include Child Labor, Forced Labor, Wage Violations, or Chemical Safety. Allows for detailed risk taxonomy.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the vendor agreement, typically formatted with prefix and numeric sequence.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the vendor agreement indicating its operational validity and enforceability.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the vendor agreement based on the nature of the commercial relationship and scope of services or goods covered.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments or addendums executed against this agreement since its original signing.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Frequency at which the vendor is subject to compliance audits (social, environmental, quality) as stipulated in the agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at expiry unless either party provides termination notice.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of mandatory compliance certifications the vendor must maintain (e.g., WRAP, FLA, BCI, GOTS, ISO 14001, ISO 45001).' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a confidentiality or non-disclosure clause protecting proprietary business information.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Total estimated or committed contract value over the agreement term, if applicable. Nullable for open-ended or volume-based agreements.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding payable amount allowed under this agreement before additional approvals or holds are required.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultIncoterm rdf:type rdf:Property ;
    rdfs:label 'Default Incoterm' ;
    rdfs:comment 'The default Incoterm rule applied to shipments under this agreement unless otherwise specified on the purchase order (PO). Common values include FOB (Free on Board), CIF (Cost Insurance Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The agreed method for resolving disputes arising under this agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an exclusivity clause restricting the vendor from supplying similar goods or services to competitors.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a force majeure clause excusing performance due to extraordinary events beyond the parties\' control.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction and governing law under which the agreement is interpreted and enforced (e.g., State of New York, England and Wales).' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsVersion rdf:type rdf:Property ;
    rdfs:label 'Incoterms Version' ;
    rdfs:comment 'The version of International Commercial Terms (Incoterms) governing the delivery, risk transfer, and cost allocation for goods under this agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Description of insurance coverage the vendor is required to maintain (e.g., general liability, product liability, workers compensation).' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipClause rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Clause' ;
    rdfs:comment 'Summary of the intellectual property ownership terms, specifying whether designs, patterns, tech packs, or product innovations remain with the buyer, vendor, or are jointly owned.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum to the agreement. Nullable if no amendments have been made.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount either party is exposed to under the agreement, excluding cases of gross negligence or willful misconduct.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is required to provide a performance bond or bank guarantee to secure contractual obligations.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required to prevent auto-renewal or to initiate renewal discussions.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatoryNameBuyer rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Buyer' ;
    rdfs:comment 'Name of the authorized signatory representing the buyer (Apparel Fashion) on the agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNameVendor rdf:type rdf:Property ;
    rdfs:label 'Signatory Name Vendor' ;
    rdfs:comment 'Name of the authorized signatory representing the vendor on the agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which the agreement was signed by authorized representatives of both parties.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance written notice required by either party to terminate the agreement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Material Supplier Id' ;
    rdfs:comment 'Unique identifier for the material-supplier association record in the Approved Vendor List (AVL). Primary key for this data product.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedColorways rdf:type rdf:Property ;
    rdfs:label 'Approved Colorways' ;
    rdfs:comment 'List of approved color options or colorways that this supplier is qualified to provide for this material. Supports collection planning and merchandising.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Per Month' ;
    rdfs:comment 'Supplier\'s monthly production capacity for this material in the specified unit of measure. Used for capacity planning and allocation decisions.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositionPercentage rdf:type rdf:Property ;
    rdfs:label 'Composition Percentage' ;
    rdfs:comment 'Detailed percentage breakdown of material composition by component. Supports multi-component materials and blends.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Rating' ;
    rdfs:comment 'Supplier delivery performance rating based on OTIF (On Time In Full) metrics. Critical for supply chain reliability and TNA (Time and Action) planning.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this supplier-material association and its terms remain valid. Null indicates open-ended agreement. Supports contract lifecycle management.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiberContent rdf:type rdf:Property ;
    rdfs:label 'Fiber Content' ;
    rdfs:comment 'Detailed fiber composition of the material (e.g., 100% Cotton, 60% Polyester 40% Cotton). Required for FTC (Federal Trade Commission) textile labeling compliance.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBciCotton rdf:type rdf:Property ;
    rdfs:label 'Is Bci Cotton' ;
    rdfs:comment 'Indicates whether cotton content is BCI (Better Cotton Initiative) certified. Supports sustainable sourcing commitments and supply chain transparency.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOekoTexCertified rdf:type rdf:Property ;
    rdfs:label 'Is Oeko Tex Certified' ;
    rdfs:comment 'Indicates whether this material holds OEKO-TEX Standard 100 certification for textile safety. Required for certain retail partners and consumer safety compliance.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganic rdf:type rdf:Property ;
    rdfs:label 'Is Organic' ;
    rdfs:comment 'Indicates whether this material is certified organic. Supports sustainability reporting and GOTS (Global Organic Textile Standard) compliance.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecycled rdf:type rdf:Property ;
    rdfs:label 'Is Recycled' ;
    rdfs:comment 'Indicates whether this material contains recycled content. Supports sustainability initiatives and circular economy reporting.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oekoTexCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Oeko Tex Certificate Number' ;
    rdfs:comment 'The OEKO-TEX Standard 100 certificate number for this material, if certified. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is a preferred or strategic supplier for this material. Influences sourcing decisions and allocation strategies.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when this supplier-material combination was qualified and approved for the AVL (Approved Vendor List). Establishes the start of the supplier relationship for this material.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierItemCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Item Code' ;
    rdfs:comment 'The supplier\'s internal item code or SKU (Stock Keeping Unit) for this material. Used for purchase orders and supplier communication.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityAttributes rdf:type rdf:Property ;
    rdfs:label 'Sustainability Attributes' ;
    rdfs:comment 'Additional sustainability certifications or attributes for this material (e.g., Fair Trade, Cradle to Cradle, bluesign). Supports ESG (Environmental Social Governance) reporting.' ;
    rdfs:domain ind:MaterialSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkFabricInhouseActualDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Inhouse Actual Date' ;
    rdfs:comment 'Actual date when bulk fabric arrived at the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bulkFabricInhousePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Bulk Fabric Inhouse Planned Date' ;
    rdfs:comment 'Planned date for bulk fabric to arrive at the factory and be available for cutting.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutActualDate rdf:type rdf:Property ;
    rdfs:label 'Cut Actual Date' ;
    rdfs:comment 'Actual date when fabric cutting began.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Cut Planned Date' ;
    rdfs:comment 'Planned date for fabric cutting to begin in the Cut Make Trim (CMT) process.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Design Approval Actual Date' ;
    rdfs:comment 'Actual date when design was approved. Variance from planned date impacts downstream milestones.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Design Approval Planned Date' ;
    rdfs:comment 'Planned date for final design approval milestone before tech pack issue.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricBookingActualDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Booking Actual Date' ;
    rdfs:comment 'Actual date when bulk fabric was booked.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabricBookingPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Fabric Booking Planned Date' ;
    rdfs:comment 'Planned date for booking bulk fabric with mills or suppliers.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionActualDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Actual Date' ;
    rdfs:comment 'Actual date when final quality inspection was completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Planned Date' ;
    rdfs:comment 'Planned date for final quality inspection before shipment authorization.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finishingActualDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Actual Date' ;
    rdfs:comment 'Actual date when finishing operations were completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finishingPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Planned Date' ;
    rdfs:comment 'Planned date for completing finishing operations including pressing, tagging, and packaging.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallDaysVariance rdf:type rdf:Property ;
    rdfs:label 'Overall Days Variance' ;
    rdfs:comment 'Total number of days the schedule is ahead (negative) or behind (positive) the planned ex-factory date. Key metric for supplier performance.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppSampleApprovalActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Actual Date' ;
    rdfs:comment 'Actual date when pre-production samples were approved.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleApprovalPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Approval Planned Date' ;
    rdfs:comment 'Planned date for approving pre-production samples and authorizing bulk production.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleSubmissionActualDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Submission Actual Date' ;
    rdfs:comment 'Actual date when pre-production samples were submitted.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppSampleSubmissionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Pp Sample Submission Planned Date' ;
    rdfs:comment 'Planned date for factory to submit pre-production samples for approval.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleComments rdf:type rdf:Property ;
    rdfs:label 'Schedule Comments' ;
    rdfs:comment 'Free-text comments and notes regarding schedule status, delays, risks, or special instructions for this T&A calendar.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStartDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Start Date' ;
    rdfs:comment 'Planned start date of the T&A calendar, typically the design handoff or tech pack issue date.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewCompletionActualDate rdf:type rdf:Property ;
    rdfs:label 'Sew Completion Actual Date' ;
    rdfs:comment 'Actual date when sewing was completed.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewCompletionPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Sew Completion Planned Date' ;
    rdfs:comment 'Planned date for completing the sewing phase of production.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentTerms rdf:type rdf:Property ;
    rdfs:label 'Shipment Terms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities and costs for shipping, such as Free on Board (FOB) or Delivered Duty Paid (DDP).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techPackIssueActualDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Issue Actual Date' ;
    rdfs:comment 'Actual date when tech pack was issued to the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:techPackIssuePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Tech Pack Issue Planned Date' ;
    rdfs:comment 'Planned date for issuing the technical specification package to the factory.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnaTemplateVersion rdf:type rdf:Property ;
    rdfs:label 'Tna Template Version' ;
    rdfs:comment 'Version identifier of the T&A template used to define the milestone structure and critical path for this schedule.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredSkuId rdf:type rdf:Property ;
    rdfs:label 'Featured Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: SKU-level campaign targeting is a real business process in apparel (e.g., end-of-season liquidation campaigns, hero SKU launch campaigns). campaign already has featured_style_id for style-level; a fea' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:featuredStyleId rdf:type rdf:Property ;
    rdfs:label 'Featured Style Id' ;
    rdfs:comment 'Foreign key linking to product.style. Business justification: Campaigns feature hero styles (signature sneaker launch, flagship jacket). Required for creative briefing, asset production planning, and campaign performance attribution to specific products. Standar' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Style .

ind:fulfillmentDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to logistics.distribution_center. Business justification: Regional or channel-specific campaigns (DTC, wholesale, outlet) in apparel-fashion are fulfilled from designated DCs. Campaign planners and supply chain teams link campaigns to fulfillment DCs for inv' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount formally allocated and approved for the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all budget amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlannedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Planned Amount' ;
    rdfs:comment 'Total planned marketing investment budget for the campaign across all channels and fiscal periods.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRemainingAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Remaining Amount' ;
    rdfs:comment 'Remaining unspent budget available for the campaign, calculated as allocated minus spent.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent to date on campaign execution across all channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Target Amount' ;
    rdfs:comment 'Target Customer Acquisition Cost (CAC) per new customer for acquisition-focused campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'Primary call-to-action message or instruction presented to the audience (e.g., Shop Now, Learn More, Sign Up).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign, used across systems and reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign for identification and reporting purposes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by strategic purpose: brand awareness, seasonal launch, performance marketing, influencer partnership, customer acquisition, or retention.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list of marketing channels utilized in this campaign (e.g., email, social_media, paid_search, display, influencer, in_store, direct_mail).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'High-level description of the creative theme, messaging, and visual concept for the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCampaignCode rdf:type rdf:Property ;
    rdfs:label 'External Campaign Code' ;
    rdfs:comment 'Campaign identifier in the external marketing platform or activation system for integration and reconciliation.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationPlatform rdf:type rdf:Property ;
    rdfs:label 'Integration Platform' ;
    rdfs:comment 'Name of the marketing platform or system where the campaign is activated and managed (e.g., Adobe Experience Platform, Salesforce Marketing Cloud).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'Primary landing page URL where campaign traffic is directed for conversion.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Objective Description' ;
    rdfs:comment 'Detailed description of the campaign\'s strategic objectives, goals, and success criteria.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant or lead marketing channel for this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConversions rdf:type rdf:Property ;
    rdfs:label 'Target Conversions' ;
    rdfs:comment 'Planned number of conversions (purchases, sign-ups, or other defined actions) the campaign aims to drive.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions or views the campaign aims to achieve across all channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReach rdf:type rdf:Property ;
    rdfs:label 'Target Reach' ;
    rdfs:comment 'Planned number of unique individuals or households the campaign aims to reach.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Code' ;
    rdfs:comment 'Unique tracking or UTM code used to attribute traffic, conversions, and performance to this campaign in analytics platforms.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Unique identifier for the campaign execution record. Primary key for tracking individual campaign flight activations across all paid, owned, and earned channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandAssetId rdf:type rdf:Property ;
    rdfs:label 'Brand Asset Id' ;
    rdfs:comment 'Foreign key linking to marketing.brand_asset. Business justification: campaign_execution has creative_asset_reference (STRING) which is a text reference to brand assets. This should be normalized to a proper FK to the brand_asset table, which serves as the authoritative' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Foreign key linking to marketing.influencer. Business justification: campaign_execution currently stores influencer_name and influencer_tier as STRING attributes. When an execution involves an influencer activation, it should reference the influencer entity directly. T' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Influencer .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'Creative format or media type used in the execution. Examples: banner, video, carousel, story, native, sponsored content, interview, product placement, experiential activation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'Total revenue attributed to this campaign execution based on the attribution model. Used to calculate ROAS and campaign effectiveness. Expressed in campaign currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution methodology used to assign credit for conversions and revenue to this execution. Examples: last-click, first-click, linear, time-decay, position-based, data-driven.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStrategy rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy' ;
    rdfs:comment 'Bidding approach used for paid media placements. Examples: CPC (Cost Per Click), CPM (Cost Per Mille), CPA (Cost Per Acquisition), target ROAS (Return on Ad Spend), maximize conversions. Not applicable for owned or earned media.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Specific marketing channel through which the campaign execution is delivered. Includes paid search, display, programmatic, paid social, email, out-of-home (OOH), print, TV, streaming, influencer, public relations (PR), and event activations. [ENUM-REF-CANDIDATE: paid_search|display|programmatic|paid_social|email|ooh|print|tv|streaming|influencer|pr|event — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of user clicks on the creative asset or call-to-action. Applicable to digital paid and owned channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Total number of conversions attributed to this execution. Conversions may include purchases, sign-ups, downloads, or other defined goal completions.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Budget Amount' ;
    rdfs:comment 'Daily spending limit allocated to this execution flight. Applicable primarily to paid media channels. Expressed in campaign currency.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceTarget rdf:type rdf:Property ;
    rdfs:label 'Device Target' ;
    rdfs:comment 'Device type targeting for digital executions. CTV refers to Connected TV for streaming video placements.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total number of user engagements with the execution. Includes likes, shares, comments, saves, and other interaction types depending on channel. Applicable to digital and social channels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionNotes rdf:type rdf:Property ;
    rdfs:label 'Execution Notes' ;
    rdfs:comment 'Free-text field for operational notes, learnings, or context about this execution. Used by marketing teams to document insights, issues, or special circumstances.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle state of the campaign execution. Tracks progression from planning through completion or cancellation.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'Scheduled end date for the campaign execution flight. Nullable for ongoing or evergreen activations.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Business-friendly name for this specific campaign flight or activation wave. Used for operational identification and reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'Scheduled start date for the campaign execution flight. Represents when the activation goes live or when earned media is published.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Average number of times each unique individual was exposed to the campaign execution. Calculated as impressions divided by reach.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoTarget rdf:type rdf:Property ;
    rdfs:label 'Geo Target' ;
    rdfs:comment 'Geographic targeting specification for this execution. May include country codes, regions, DMAs, postal codes, or radius targeting around specific locations.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the creative asset was displayed or the content was viewed. Applicable to paid and owned digital channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalistName rdf:type rdf:Property ;
    rdfs:label 'Journalist Name' ;
    rdfs:comment 'Name of the journalist, editor, or content creator who produced the earned media placement. Applicable to PR and influencer activations.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Budget Amount' ;
    rdfs:comment 'Total budget allocated to this execution flight across its entire duration. Applicable to paid media and event activations. Expressed in campaign currency.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaValueAmount rdf:type rdf:Property ;
    rdfs:label 'Media Value Amount' ;
    rdfs:comment 'Estimated advertising equivalency value of earned media placement. Calculated based on comparable paid media rates for the same placement. Expressed in campaign currency.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementName rdf:type rdf:Property ;
    rdfs:label 'Placement Name' ;
    rdfs:comment 'Detailed placement identifier within the platform. For paid media: ad group or placement ID. For earned media: article title or segment name. For events: booth or activation area.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Specific advertising or media platform where the execution is placed. Examples include Google Ads, Meta, TikTok, Vogue, CNN, specific event venue names, or publication names for earned media.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationName rdf:type rdf:Property ;
    rdfs:label 'Publication Name' ;
    rdfs:comment 'Name of the publication, media outlet, or platform where earned media was placed. Applicable to PR and earned media executions. Examples: Vogue, WWD, Business of Fashion.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Unique number of individuals or households exposed to the campaign execution. Deduplicated audience count across the flight period.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on Ad Spend ratio calculated as revenue attributed to this execution divided by spend amount. Key performance indicator for paid media effectiveness.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Qualitative assessment of the tone and sentiment of earned media coverage. Applicable to PR placements and social media mentions.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Actual amount spent on this execution flight. For paid media: media cost. For events: activation cost. For earned media: estimated media value or zero if tracking impressions only.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingParameters rdf:type rdf:Property ;
    rdfs:label 'Targeting Parameters' ;
    rdfs:comment 'Audience targeting criteria applied to this execution. Includes demographic, geographic, behavioral, and contextual targeting specifications. Stored as structured text or JSON.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Percentage of video views that were watched to completion. Calculated as completed views divided by total views, expressed as a percentage.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views for video creative assets. Applicable to video ad formats across paid social, streaming, and TV channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAssetBrandAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Brand Asset Id' ;
    rdfs:comment 'Reference to the parent or original asset if this is a derivative, localized, or resized version. Enables asset lineage tracking.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Aspect ratio of the image or video (e.g., 16:9, 4:3, 1:1, 9:16). Determines suitability for different digital platforms and display formats.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the brand asset. Used for identification and search within the Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the brand asset by media type. Determines how the asset is used across channels and what technical specifications apply. [ENUM-REF-CANDIDATE: image|video|copy|lookbook|campaign_visual|logo|style_guide|audio|document — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelEcommerceFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Ecommerce Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for use on e-commerce platforms (website, mobile app, product pages).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelEmailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Email Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for email marketing campaigns and newsletters.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelPrintFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Print Flag' ;
    rdfs:comment 'Indicates whether the asset meets technical specifications for print media (catalogs, magazines, outdoor advertising). Requires high resolution and color profile compliance.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelRetailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Retail Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for use in physical retail store environments (in-store displays, signage, POS materials).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSocialMediaFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Social Media Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and optimized for social media platforms (Instagram, Facebook, TikTok, Pinterest).' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelWholesaleFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Wholesale Flag' ;
    rdfs:comment 'Indicates whether the asset is approved and suitable for distribution to wholesale partners and third-party retailers.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space profile of the asset. Critical for ensuring color consistency across digital and print channels.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatorType rdf:type rdf:Property ;
    rdfs:label 'Creator Type' ;
    rdfs:comment 'Classification of the asset creator. User-Generated Content (UGC) requires special rights management and compliance review.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'External unique identifier from the Digital Asset Management system (Adobe Experience Platform). Used for cross-system asset tracking and retrieval.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of video or audio assets in seconds. Used for media planning, ad placement, and content scheduling.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical file format of the asset. Determines compatibility with various platforms and channels. [ENUM-REF-CANDIDATE: jpg|png|svg|mp4|mov|pdf|docx|psd|ai|eps|gif|webp|tiff — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the asset file in megabytes. Used for storage management, bandwidth planning, and determining load times for digital channels.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags for asset search and discovery within the DAM system. Includes product categories, colors, styles, and themes.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic market or region the asset is intended for. Used for localization and regional campaign management.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Image or video resolution in pixels (e.g., 1920x1080, 4096x2160). Critical for determining channel suitability and print vs digital usage.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'Fashion season the asset is associated with (e.g., Spring/Summer 2024, Fall/Winter 2024, Holiday 2024). Critical for time-bound campaign planning.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'Cloud storage URL or file path where the asset is stored. Used for programmatic access and integration with content delivery networks.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to a low-resolution thumbnail preview of the asset. Used for quick browsing and selection in DAM interfaces.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Legal usage rights classification for the asset. Determines where and how the asset can be deployed without legal risk.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsDetail rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Detail' ;
    rdfs:comment 'Detailed description of usage rights, restrictions, and licensing terms. Includes geographic restrictions, channel limitations, and exclusivity clauses.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateLink rdf:type rdf:Property ;
    rdfs:label 'Affiliate Link' ;
    rdfs:comment 'Unique affiliate tracking URL assigned to the influencer for digital attribution and commission tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Primary email address for the influencers agency or management contact for contract and campaign coordination.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the talent agency or management company representing the influencer, if applicable.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ambassadorStatus rdf:type rdf:Property ;
    rdfs:label 'Ambassador Status' ;
    rdfs:comment 'Current lifecycle status of the influencer relationship: active (currently engaged), inactive (no recent activity), suspended (temporarily paused), pending (onboarding), terminated (relationship ended).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceAgeRange rdf:type rdf:Property ;
    rdfs:label 'Audience Age Range' ;
    rdfs:comment 'Predominant age range of the influencers audience (e.g., 18-24, 25-34, 35-44). Used for campaign targeting alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGenderSplit rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split' ;
    rdfs:comment 'Gender distribution of the influencers audience (e.g., 60% female, 40% male). Used for product line alignment.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audiencePrimaryGeography rdf:type rdf:Property ;
    rdfs:label 'Audience Primary Geography' ;
    rdfs:comment 'Primary geographic market or country where the majority of the influencers audience is located (e.g., USA, GBR, FRA). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSecondaryGeographies rdf:type rdf:Property ;
    rdfs:label 'Audience Secondary Geographies' ;
    rdfs:comment 'Comma-separated list of secondary geographic markets with significant audience presence. Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyScore rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Score' ;
    rdfs:comment 'Quantitative score (0.00 to 5.00) assessing the influencers content safety, controversy risk, and alignment with brand values. Higher scores indicate lower risk.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentNiche rdf:type rdf:Property ;
    rdfs:label 'Content Niche' ;
    rdfs:comment 'Primary content category or niche the influencer specializes in (e.g., fashion, lifestyle, fitness, beauty, streetwear, luxury, athleisure, sustainability).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed contract or agreement document stored in the document management system.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRatePercent rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate Percent' ;
    rdfs:comment 'Average engagement rate (likes, comments, shares divided by followers) expressed as a percentage. Key metric for campaign ROI forecasting.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity agreement period, if applicable.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity agreement period, if applicable.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Legal or professional full name of the influencer or brand ambassador.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influencerTier rdf:type rdf:Property ;
    rdfs:label 'Influencer Tier' ;
    rdfs:comment 'Classification of influencer based on follower count and reach: nano (<10K), micro (10K-100K), mid-tier (100K-500K), macro (500K-1M), mega (1M+), celebrity (established public figure).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCollaborationDate rdf:type rdf:Property ;
    rdfs:label 'Last Collaboration Date' ;
    rdfs:comment 'Date of the most recent completed collaboration or campaign with this influencer.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredContentFormats rdf:type rdf:Property ;
    rdfs:label 'Preferred Content Formats' ;
    rdfs:comment 'Comma-separated list of content formats the influencer specializes in (e.g., static post, video, reel, story, IGTV, YouTube video, TikTok, blog post, unboxing).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryHandle rdf:type rdf:Property ;
    rdfs:label 'Primary Handle' ;
    rdfs:comment 'The primary social media username or handle used by the influencer across platforms (e.g., @username). Serves as the operational identifier for engagement tracking.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPlatform rdf:type rdf:Property ;
    rdfs:label 'Primary Platform' ;
    rdfs:comment 'The primary social media platform where the influencer has the largest following and engagement. [ENUM-REF-CANDIDATE: instagram|tiktok|youtube|facebook|twitter|pinterest|snapchat — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPlatformFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Primary Platform Follower Count' ;
    rdfs:comment 'Follower count on the influencers primary social media platform.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Unique promotional code assigned to the influencer for tracking conversions and attributing sales (e.g., INFLUENCER20).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of business relationship: one-time (single campaign), recurring (multiple campaigns), ambassador (long-term partnership), affiliate (commission-based), gifting (product seeding only).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fee Amount' ;
    rdfs:comment 'Standard fee amount charged by the influencer for a typical sponsored post or collaboration. Used for budget planning and negotiation baseline.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAttributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Attributed Revenue' ;
    rdfs:comment 'Cumulative revenue attributed to this influencers campaigns based on promo code usage, affiliate links, and marketing attribution models. Tracked in base currency.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCollaborationsCount rdf:type rdf:Property ;
    rdfs:label 'Total Collaborations Count' ;
    rdfs:comment 'Total number of completed collaborations or campaigns with this influencer since relationship inception.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Total Follower Count' ;
    rdfs:comment 'Aggregate follower count across all active social media platforms. Updated periodically to reflect current reach.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Influencer Engagement Id' ;
    rdfs:comment 'Unique identifier for each influencer collaboration or activation event.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialPostId rdf:type rdf:Property ;
    rdfs:label 'Social Post Id' ;
    rdfs:comment 'Foreign key linking to marketing.social_post. Business justification: An influencer engagement contract/activation results in specific social posts being published. Linking influencer_engagement to social_post connects the commercial agreement (fees, deliverables, conte' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SocialPost .

ind:actualPostDate rdf:type rdf:Property ;
    rdfs:label 'Actual Post Date' ;
    rdfs:comment 'Actual date when the influencer published the content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Fee Amount' ;
    rdfs:comment 'Total fee amount agreed upon for the influencer engagement.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedOrderCount rdf:type rdf:Property ;
    rdfs:label 'Attributed Order Count' ;
    rdfs:comment 'Number of orders attributed to this influencer engagement through promo code usage and affiliate link tracking.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Brand Sentiment Score' ;
    rdfs:comment 'Sentiment analysis score of comments and reactions to the influencer content, ranging from -1 (negative) to +1 (positive).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commentCount rdf:type rdf:Property ;
    rdfs:label 'Comment Count' ;
    rdfs:comment 'Number of comments received on the influencer content.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Content Approval Date' ;
    rdfs:comment 'Date when the brand approved the influencer content for publication.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Content Approval Status' ;
    rdfs:comment 'Status of brand approval for the influencer content before publication (pending, approved, rejected, revision requested).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Format of content to be created by the influencer (reel, story, post, blog, video, carousel, live stream). [ENUM-REF-CANDIDATE: reel|story|post|blog|video|carousel|live_stream — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'Direct URL link to the published influencer content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'Date when the influencer engagement contract was signed or agreed upon.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPerEngagement rdf:type rdf:Property ;
    rdfs:label 'Cost Per Engagement' ;
    rdfs:comment 'Calculated cost per engagement (agreed fee divided by engagement count).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Number of content pieces contracted for this engagement.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the contracted deliverables, including content requirements, messaging guidelines, and brand specifications.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Business identifier for the influencer engagement, used for tracking and reporting.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the influencer engagement (draft, contracted, in progress, completed, cancelled, disputed).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Type of influencer collaboration activity (gifting, paid post, takeover, event appearance, affiliate, ambassador, unboxing). [ENUM-REF-CANDIDATE: gifting|paid_post|takeover|event_appearance|affiliate|ambassador|unboxing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Total number of times the influencer content was displayed, as reported by the platform.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likeCount rdf:type rdf:Property ;
    rdfs:label 'Like Count' ;
    rdfs:comment 'Number of likes received on the influencer content.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkClickCount rdf:type rdf:Property ;
    rdfs:label 'Link Click Count' ;
    rdfs:comment 'Number of clicks on links included in the influencer content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Social media platform where the content will be published (Instagram, TikTok, YouTube, Facebook, Twitter, Pinterest, Blog). [ENUM-REF-CANDIDATE: instagram|tiktok|youtube|facebook|twitter|pinterest|blog — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeUsageCount rdf:type rdf:Property ;
    rdfs:label 'Promo Code Usage Count' ;
    rdfs:comment 'Number of times the promotional code was used by customers.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reachCount rdf:type rdf:Property ;
    rdfs:label 'Reach Count' ;
    rdfs:comment 'Total number of unique users who saw the influencer content, as reported by the platform.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnOnInvestmentPercent rdf:type rdf:Property ;
    rdfs:label 'Return On Investment Percent' ;
    rdfs:comment 'Calculated return on investment as a percentage ((attributed revenue minus agreed fee) divided by agreed fee times 100).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saveCount rdf:type rdf:Property ;
    rdfs:label 'Save Count' ;
    rdfs:comment 'Number of times the influencer content was saved by users.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPostDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Post Date' ;
    rdfs:comment 'Planned date for the influencer to publish the content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shareCount rdf:type rdf:Property ;
    rdfs:label 'Share Count' ;
    rdfs:comment 'Number of times the influencer content was shared by users.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDestinations rdf:type rdf:Property ;
    rdfs:label 'Activation Destinations' ;
    rdfs:comment 'Comma-separated list of downstream systems or platforms where this segment has been activated for campaign execution (e.g., Salesforce Marketing Cloud, Google Ads, Facebook Ads, email service provider).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current state of segment activation to downstream marketing channels: not activated (segment exists but not pushed), activated (successfully synced to destinations), activation pending (in progress), or activation failed (error during sync).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReach rdf:type rdf:Property ;
    rdfs:label 'Actual Reach' ;
    rdfs:comment 'Current count of unique customers or profiles who actively qualify for this segment based on the latest evaluation run.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aovCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Aov Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the AOV target amount.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, target audience characteristics, and intended use cases for campaign planning and execution.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageOrderValueTarget rdf:type rdf:Property ;
    rdfs:label 'Average Order Value Target' ;
    rdfs:comment 'Target Average Order Value expected from customers in this segment, used for campaign ROI planning and performance benchmarking.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAssociation rdf:type rdf:Property ;
    rdfs:label 'Brand Association' ;
    rdfs:comment 'Brand or sub-brand this segment is associated with for targeted brand campaigns and product launches.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'Strategic marketing goal this segment supports: customer acquisition, retention, cross-sell, upsell, win-back, loyalty engagement, seasonal campaign, new product launch.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cac Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the CAC target amount.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacTarget rdf:type rdf:Property ;
    rdfs:label 'Cac Target' ;
    rdfs:comment 'Target Customer Acquisition Cost for campaigns using this segment, representing the maximum acceptable cost to acquire a new customer from this audience.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'Business rules or machine learning model logic defining segment membership criteria. May include attribute filters, event conditions, propensity scores, or SQL-like expressions.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionType rdf:type rdf:Property ;
    rdfs:label 'Definition Type' ;
    rdfs:comment 'Method used to define segment membership: rule-based (attribute/event filters), ML-derived (propensity/clustering models), hybrid (rules + ML), or manual upload (static list).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Projected number of unique customers or profiles expected to qualify for this segment based on historical data or model predictions.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedConversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Expected Conversion Rate Percent' ;
    rdfs:comment 'Anticipated percentage of segment members expected to convert (purchase, sign-up, engagement) based on historical performance or predictive models.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when the segment membership was last evaluated and updated.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next segment membership evaluation run.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the marketing team member or business owner responsible for managing and maintaining this segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which segment membership is re-evaluated and updated: real-time (streaming), hourly, daily, weekly, monthly, or on-demand (manual trigger).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailCampaignId rdf:type rdf:Property ;
    rdfs:label 'Email Campaign Id' ;
    rdfs:comment 'Unique identifier for the email campaign. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailCampaign .

ind:espCampaignId rdf:type rdf:Property ;
    rdfs:label 'Esp Campaign Id' ;
    rdfs:comment 'External identifier assigned by the Email Service Provider system for tracking and reconciliation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:abTestEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ab Test Enabled Flag' ;
    rdfs:comment 'Indicates whether this campaign includes A/B testing of subject lines, content, or send times.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abTestVariantCount rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Count' ;
    rdfs:comment 'Number of variants being tested in the A/B test (e.g., 2 for A/B, 3 for A/B/C).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestWinningVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Winning Variant' ;
    rdfs:comment 'Identifier of the winning variant selected based on test results (e.g., A, B, C). Null if test is incomplete.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Send Timestamp' ;
    rdfs:comment 'Actual date and time when the email campaign send was initiated by the Email Service Provider (ESP).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:campaignBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Amount' ;
    rdfs:comment 'Total budget allocated for this email campaign including creative, ESP costs, and promotional discounts.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignGoal rdf:type rdf:Property ;
    rdfs:label 'Campaign Goal' ;
    rdfs:comment 'Primary business objective of the campaign (e.g., drive sales, increase engagement, promote new collection, recover abandoned carts).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this campaign meets CCPA requirements for consumer data rights and opt-out mechanisms.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when all emails in the campaign were fully processed and sent by the ESP.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'Legal basis for sending this email under GDPR and CCPA regulations. Critical for compliance and audit trails.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espName rdf:type rdf:Property ;
    rdfs:label 'Esp Name' ;
    rdfs:comment 'Name of the Email Service Provider platform used to send this campaign (e.g., Adobe Campaign, Salesforce Marketing Cloud, Mailchimp).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this campaign meets GDPR requirements for consent, data processing, and right to unsubscribe.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hardBounceCount rdf:type rdf:Property ;
    rdfs:label 'Hard Bounce Count' ;
    rdfs:comment 'Number of emails that permanently failed delivery due to invalid email addresses or blocked domains.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether dynamic personalization (name, product recommendations, location-based content) is enabled for this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationFields rdf:type rdf:Property ;
    rdfs:label 'Personalization Fields' ;
    rdfs:comment 'Comma-separated list of personalization tokens used in the email (e.g., first_name, last_purchase_date, recommended_products).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preheaderText rdf:type rdf:Property ;
    rdfs:label 'Preheader Text' ;
    rdfs:comment 'Preview text displayed after the subject line in email clients. Used to provide additional context and improve open rates.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Reply To Email Address' ;
    rdfs:comment 'Email address where recipient replies will be directed. May differ from sender address.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'Planned date and time when the email campaign is scheduled to be sent to recipients.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:senderEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Sender Email Address' ;
    rdfs:comment 'Email address used as the from address for the campaign (e.g., marketing@apparelfashion.com).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Display name shown as the sender of the email (e.g., Apparel Fashion, Customer Service Team).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softBounceCount rdf:type rdf:Property ;
    rdfs:label 'Soft Bounce Count' ;
    rdfs:comment 'Number of emails that temporarily failed delivery due to full mailboxes or server issues.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spamComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Count' ;
    rdfs:comment 'Number of recipients who marked this email as spam or junk. Critical metric for sender reputation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The subject line text displayed in recipient inboxes. Critical for open rate optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'Total number of recipients in the target segment at the time of campaign creation.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBounceCount rdf:type rdf:Property ;
    rdfs:label 'Total Bounce Count' ;
    rdfs:comment 'Total number of emails that bounced (hard bounces plus soft bounces).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClickCount rdf:type rdf:Property ;
    rdfs:label 'Total Click Count' ;
    rdfs:comment 'Total number of clicks on links within the email (includes multiple clicks by same recipient).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Total Delivered Count' ;
    rdfs:comment 'Total number of emails successfully delivered to recipient inboxes (sent minus bounces).' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOpenCount rdf:type rdf:Property ;
    rdfs:label 'Total Open Count' ;
    rdfs:comment 'Total number of times emails in this campaign were opened by recipients (includes multiple opens by same recipient).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSentCount rdf:type rdf:Property ;
    rdfs:label 'Total Sent Count' ;
    rdfs:comment 'Total number of emails successfully sent by the ESP for this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueClickCount rdf:type rdf:Property ;
    rdfs:label 'Unique Click Count' ;
    rdfs:comment 'Number of unique recipients who clicked at least one link in the email.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueOpenCount rdf:type rdf:Property ;
    rdfs:label 'Unique Open Count' ;
    rdfs:comment 'Number of unique recipients who opened the email at least once.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeCount rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Count' ;
    rdfs:comment 'Number of recipients who unsubscribed from the email list after receiving this campaign.' ;
    rdfs:domain ind:EmailCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailSendEventId rdf:type rdf:Property ;
    rdfs:label 'Email Send Event Id' ;
    rdfs:comment 'Unique identifier for each individual email send event. Primary key for the email send event record.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'The variant identifier for A/B or multivariate testing. Indicates which version of the email (subject line, content, CTA) was sent to this recipient.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'Detailed reason code or message explaining why the email bounced. Sourced from SMTP error response. Null if no bounce occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceType rdf:type rdf:Property ;
    rdfs:label 'Bounce Type' ;
    rdfs:comment 'Classification of bounce event. Hard bounce indicates permanent delivery failure (invalid address), soft bounce indicates temporary issue (mailbox full). Null if no bounce occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedFlag rdf:type rdf:Property ;
    rdfs:label 'Clicked Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient clicked any link within the email. True if at least one click event was tracked, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickedUrl rdf:type rdf:Property ;
    rdfs:label 'Clicked Url' ;
    rdfs:comment 'The first URL clicked by the recipient within the email. Used for primary engagement attribution. Null if no clicks occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the email was successfully delivered to the recipient mail server. Null if delivery failed.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emailClient rdf:type rdf:Property ;
    rdfs:label 'Email Client' ;
    rdfs:comment 'The email client application used by the recipient to view the email (e.g., Gmail, Outlook, Apple Mail). Derived from user agent string.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espMessageReference rdf:type rdf:Property ;
    rdfs:label 'Esp Message Reference' ;
    rdfs:comment 'Unique message identifier assigned by the Email Service Provider. Used for tracking and troubleshooting delivery issues.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstClickTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Click Timestamp' ;
    rdfs:comment 'The date and time of the first recorded click event for any link in this email. Null if no clicks occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Open Timestamp' ;
    rdfs:comment 'The date and time of the first recorded open event for this email. Null if the email was never opened.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fromAddress rdf:type rdf:Property ;
    rdfs:label 'From Address' ;
    rdfs:comment 'The sender email address displayed in the From field of the email. Used for sender reputation tracking.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromName rdf:type rdf:Property ;
    rdfs:label 'From Name' ;
    rdfs:comment 'The sender name displayed in the From field of the email (e.g., brand name or representative name).' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'The city where the recipient opened the email. Derived from IP address geolocation.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location of the recipient at the time of email interaction. Derived from IP address geolocation.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'The state, province, or region where the recipient opened the email. Derived from IP address geolocation.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedFlag rdf:type rdf:Property ;
    rdfs:label 'Opened Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient opened the email. True if at least one open event was tracked, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'The operating system of the device used to open the email (e.g., iOS, Android, Windows, macOS). Derived from user agent string.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Applied Flag' ;
    rdfs:comment 'Boolean indicator of whether dynamic personalization (name, product recommendations, location-based content) was applied to this email send.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Email Address' ;
    rdfs:comment 'The email address to which this message was sent. Personally identifiable information subject to GDPR and CCPA.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendPriority rdf:type rdf:Property ;
    rdfs:label 'Send Priority' ;
    rdfs:comment 'The priority level assigned to this email send event. High priority emails are processed first by the ESP.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'The exact date and time when the email was sent from the Email Service Provider (ESP). Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spamComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient marked this email as spam or junk. True if spam complaint was filed, False otherwise. Critical for sender reputation monitoring.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spamComplaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Timestamp' ;
    rdfs:comment 'The date and time when the spam complaint was registered. Null if no complaint was filed.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'The date and time when the recipient clicked the unsubscribe link. Null if no unsubscribe action occurred.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unsubscribedFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Flag' ;
    rdfs:comment 'Boolean indicator of whether the recipient unsubscribed from the email list as a result of this send event. True if unsubscribe action was taken, False otherwise.' ;
    rdfs:domain ind:EmailSendEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountHandle rdf:type rdf:Property ;
    rdfs:label 'Account Handle' ;
    rdfs:comment 'Brand social media account handle or username that published the post (e.g., @brandname). Supports multi-account brand architecture.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'Actual date and time when the post went live on the platform. Primary timestamp for engagement rate calculations and time-series analysis.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Boost Budget Amount' ;
    rdfs:comment 'Total paid media budget allocated to boost this post. Used for paid social ROI calculation and CAC (Customer Acquisition Cost) attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Boost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for boost budget amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boostedFlag rdf:type rdf:Property ;
    rdfs:label 'Boosted Flag' ;
    rdfs:comment 'Indicates whether the post received paid promotion or boosting. True if paid media budget was allocated to amplify organic reach.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brandSafetyFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Flag' ;
    rdfs:comment 'Indicates whether the post passed brand safety review. False if content contains inappropriate comments or context that could harm brand reputation.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionText rdf:type rdf:Property ;
    rdfs:label 'Caption Text' ;
    rdfs:comment 'Full text caption or description accompanying the social media post. Includes copy, emojis, and call-to-action messaging.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of clicks on links within the post. Measures DTC (Direct-to-Consumer) traffic generation and conversion funnel entry.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory compliance review for posts containing claims, endorsements, or sponsored content. Ensures FTC (Federal Trade Commission) and advertising standards compliance.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTheme rdf:type rdf:Property ;
    rdfs:label 'Content Theme' ;
    rdfs:comment 'Thematic category or content pillar for the post (e.g., sustainability, athlete spotlight, product launch, lifestyle). Supports content strategy analysis.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatorName rdf:type rdf:Property ;
    rdfs:label 'Creator Name' ;
    rdfs:comment 'Name of the content creator, photographer, or agency responsible for producing the post content. Supports creator performance tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when ephemeral content expires (e.g., Instagram Stories, Facebook Stories). Null for permanent posts.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags included in the post. Supports hashtag performance tracking and trend analysis.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMetricsRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Metrics Refresh Timestamp' ;
    rdfs:comment 'Date and time when engagement metrics were last refreshed from platform APIs. Indicates data currency for reporting and analytics.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkUrl rdf:type rdf:Property ;
    rdfs:label 'Link Url' ;
    rdfs:comment 'Destination URL included in the post (e.g., product page, landing page, blog article). Supports click-through attribution and DTC (Direct-to-Consumer) conversion tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postExternalReference rdf:type rdf:Property ;
    rdfs:label 'Post External Reference' ;
    rdfs:comment 'Platform-native unique identifier for the post (e.g., Instagram post ID, TikTok video ID, YouTube video ID). Used for API reconciliation and platform-specific tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle status of the social media post. Tracks content from creation through publication to archival.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'Content format type of the social media post. Enables content format performance analysis. [ENUM-REF-CANDIDATE: photo|video|carousel|story|reel|short|live|poll|article — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTags rdf:type rdf:Property ;
    rdfs:label 'Product Tags' ;
    rdfs:comment 'Comma-separated list of product SKUs (Stock Keeping Units) or product identifiers tagged in the post. Enables product-level social attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'Planned date and time for post publication. Used for content calendar management and scheduling optimization.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended audience segment or demographic for the post (e.g., Gen Z athletes, luxury shoppers, sustainability advocates). Supports audience-specific content performance analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmParameters rdf:type rdf:Property ;
    rdfs:label 'Utm Parameters' ;
    rdfs:comment 'Urchin Tracking Module (UTM) parameters appended to link URL for campaign tracking (utm_source, utm_medium, utm_campaign). Enables granular traffic source attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate Percent' ;
    rdfs:comment 'Percentage of viewers who watched the video to completion. Key quality metric for video content effectiveness.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViewCount rdf:type rdf:Property ;
    rdfs:label 'Video View Count' ;
    rdfs:comment 'Total number of video views for video posts. Platform-specific view definitions apply (e.g., 3-second view threshold).' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleCustomerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Eligible Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Promo codes are often segment-restricted (VIP-only codes, new customer codes, loyalty tier codes). Enforces eligibility rules, tracks segment-specific promotion performance, and enables segment-target' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:affiliateCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Affiliate Commission Rate' ;
    rdfs:comment 'The commission percentage paid to affiliates or influencers for sales generated using this promotional code. Used for commission reconciliation.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableSkus rdf:type rdf:Property ;
    rdfs:label 'Applicable Skus' ;
    rdfs:comment 'Comma-separated list of specific SKU codes that this promotional code can be applied to. Null if category-level restrictions apply instead.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this promotional code is automatically applied at checkout for eligible customers without requiring manual entry. True if auto-applied, False if manual entry required.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cacAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Allocation Amount' ;
    rdfs:comment 'The allocated customer acquisition cost budget for this promotional code, used to calculate CAC and marketing efficiency metrics.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Channel Restrictions' ;
    rdfs:comment 'Specifies which sales channels this promotional code is valid for: all channels, Direct-to-Consumer (DTC) only, e-commerce only, retail stores only, or wholesale excluded.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeName rdf:type rdf:Property ;
    rdfs:label 'Code Name' ;
    rdfs:comment 'Internal descriptive name for the promotional code used for campaign tracking and reporting purposes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Specifies which customer segments are eligible to use this promotional code (e.g., new customers, loyalty members, VIP tier). Null if available to all customers.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'The numeric value of the discount. For percentage discounts, this is the percentage (e.g., 15.00 for 15% off). For fixed amount discounts, this is the dollar amount.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Excluded Product Categories' ;
    rdfs:comment 'Comma-separated list of product category codes or identifiers that are explicitly excluded from this promotional code. Used to prevent discounts on certain product lines.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedSkus rdf:type rdf:Property ;
    rdfs:label 'Excluded Skus' ;
    rdfs:comment 'Comma-separated list of specific SKU codes that are explicitly excluded from this promotional code, even if their category is included.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCodeReference rdf:type rdf:Property ;
    rdfs:label 'External Code Reference' ;
    rdfs:comment 'The unique identifier for this promotional code in the source system, used for integration and reconciliation purposes.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Flag' ;
    rdfs:comment 'Indicates whether this promotional code has been flagged for potential abuse or fraudulent redemption patterns. True if flagged for review, False otherwise.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount' ;
    rdfs:comment 'The maximum discount amount that can be applied when using this code, typically used to cap percentage-based discounts. Null if no cap applies.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'The minimum order subtotal required for this promotional code to be valid. Null if no minimum is required.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoCodeCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code Code' ;
    rdfs:comment 'The actual alphanumeric promotional code string that customers enter at checkout to receive a discount. Must be unique and human-readable.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Code Status' ;
    rdfs:comment 'Current lifecycle status of the promotional code: draft (not yet published), active (available for use), paused (temporarily disabled), expired (past validity date), or cancelled (permanently disabled).' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicVisibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Public Visibility Flag' ;
    rdfs:comment 'Indicates whether this promotional code is publicly advertised or is a private/targeted code. True if public, False if private or invitation-only.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promotional code can be combined with other promotional codes or discounts in a single transaction. True if stackable, False if exclusive.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full text of the legal terms and conditions governing the use of this promotional code, including restrictions, exclusions, and disclaimers.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDiscountGiven rdf:type rdf:Property ;
    rdfs:label 'Total Discount Given' ;
    rdfs:comment 'The cumulative discount amount granted across all redemptions of this promotional code. Used for financial reconciliation and campaign cost tracking.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionsCount rdf:type rdf:Property ;
    rdfs:label 'Total Redemptions Count' ;
    rdfs:comment 'The cumulative number of times this promotional code has been successfully redeemed to date. Used for tracking against usage limits.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Attributed' ;
    rdfs:comment 'The cumulative gross revenue (before discount) from all orders where this promotional code was successfully applied. Used for campaign ROI measurement.' ;
    rdfs:domain ind:PromoCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique identifier for the promotional code redemption event.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The marketing source or touchpoint that led to this promo code redemption (e.g., email, social media, influencer, paid search).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstTimeCustomerFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Customer Flag' ;
    rdfs:comment 'Indicates whether this redemption was by a first-time customer (true) or a returning customer (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReason rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason' ;
    rdfs:comment 'Description of the reason why this redemption was flagged as fraudulent, if applicable.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSubtotalAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Subtotal After Discount' ;
    rdfs:comment 'The order subtotal amount after the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSubtotalBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Subtotal Before Discount' ;
    rdfs:comment 'The order subtotal amount before the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderTotalAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total After Discount' ;
    rdfs:comment 'The total order amount including tax and shipping after the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderTotalBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total Before Discount' ;
    rdfs:comment 'The total order amount including tax and shipping before the promotional discount was applied.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The sales channel through which the promo code was redeemed (DTC, e-commerce, retail POS, mobile app, wholesale, call center).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the redemption occurred.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDeviceType rdf:type rdf:Property ;
    rdfs:label 'Redemption Device Type' ;
    rdfs:comment 'The type of device used to redeem the promo code (desktop, mobile, tablet, POS terminal, kiosk, unknown).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionIpAddress rdf:type rdf:Property ;
    rdfs:label 'Redemption Ip Address' ;
    rdfs:comment 'The IP address from which the promo code redemption was initiated, used for fraud detection and geographic analysis.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Exceeded Flag' ;
    rdfs:comment 'Indicates whether the customer attempted to redeem the promo code beyond the allowed usage limit (true) or within limits (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current status of the promo code redemption (applied, pending, failed, reversed, expired).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the promotional code was redeemed by the customer.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The reason why the promo code redemption was reversed (e.g., order cancelled, return processed, fraud detected).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'The date and time when the promo code redemption was reversed, if applicable (e.g., due to order cancellation or return).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stackingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed Flag' ;
    rdfs:comment 'Indicates whether this promo code was allowed to be stacked with other promotions (true) or not (false).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'The UTM campaign parameter captured at the time of redemption for marketing attribution.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'The UTM medium parameter captured at the time of redemption for marketing attribution.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'The UTM source parameter captured at the time of redemption for marketing attribution.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsThirdPartyLogisticsId rdf:type rdf:Property ;
    rdfs:label 'Logistics Third Party Logistics Id' ;
    rdfs:comment 'Foreign key linking to logistics.third_party_logistics. Business justification: Large apparel-fashion marketing events (runway shows, brand activations, trade shows) contract a specific 3PL for event logistics — transport, setup, and returns. Event managers must record which 3PL ' ;
    rdfs:domain ind:Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyLogistics .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Confirmed number of attendees who participated in the event. Captured post-event for performance analysis and ROI calculation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetActualAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Actual Amount' ;
    rdfs:comment 'Total actual expenditure for the event after completion. Used for variance analysis and future event budget calibration.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise timestamp when the event officially concludes, including time zone. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Business identifier code for the event, used for external reference and tracking across systems. Typically alphanumeric code assigned during event planning.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Full descriptive name of the marketing event (e.g., Spring 2024 Runway Show, NYC Pop-Up Launch, Paris Fashion Week Press Day).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the marketing event format and purpose. Determines audience, venue requirements, and success metrics. [ENUM-REF-CANDIDATE: runway_show|pop_up_activation|trade_show|press_day|brand_experience|wholesale_preview|influencer_event|product_launch|store_opening|virtual_event|fashion_week|trunk_show — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendance rdf:type rdf:Property ;
    rdfs:label 'Expected Attendance' ;
    rdfs:comment 'Projected number of attendees based on invitations sent and historical response rates. Used for capacity planning and budget forecasting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVirtualEvent rdf:type rdf:Property ;
    rdfs:label 'Is Virtual Event' ;
    rdfs:comment 'Indicates whether the event is conducted entirely online/virtually (True) or has a physical venue component (False).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaImpressions rdf:type rdf:Property ;
    rdfs:label 'Media Impressions' ;
    rdfs:comment 'Total estimated media impressions generated by the event across press coverage, social media, and digital channels. Captured post-event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressCoverageCount rdf:type rdf:Property ;
    rdfs:label 'Press Coverage Count' ;
    rdfs:comment 'Number of press articles, blog posts, or media mentions generated by the event. Indicates earned media success.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationCount rdf:type rdf:Property ;
    rdfs:label 'Registration Count' ;
    rdfs:comment 'Total number of individuals who registered or RSVP\'d for the event. Used to calculate attendance conversion rate.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Social Engagement Count' ;
    rdfs:comment 'Total social media engagements (likes, shares, comments, mentions) attributed to the event across all platforms. Measured during and post-event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the primary external sponsor or partner co-hosting the event. Null if no external sponsorship.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'Level of external sponsorship secured for the event. Impacts budget offset and co-branding requirements.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipValueAmount rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Value Amount' ;
    rdfs:comment 'Monetary value of sponsorship contribution or in-kind services provided by external sponsor. Reduces net event cost.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise timestamp when the event officially begins, including time zone. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:virtualPlatformName rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform Name' ;
    rdfs:comment 'Name of the digital platform used for virtual events (e.g., Zoom, Microsoft Teams, custom branded platform). Null for physical-only events.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to logistics.contract. Business justification: Every shipment in apparel logistics is executed under a specific carrier or 3PL contract that governs rates, service levels, and terms. Linking shipment directly to contract enables contract utilizati' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:destinationFacilityDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Distribution Center Id' ;
    rdfs:comment 'Identifier of the facility, warehouse, store, or customer location to which the shipment is destined.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:originFactorySupplierFactoryId rdf:type rdf:Property ;
    rdfs:label 'Origin Factory Supplier Factory Id' ;
    rdfs:comment 'Foreign key linking to supplier.supplier_factory. Business justification: Inbound shipments from supplier factories require direct factory tracking for origin verification, GSP/duty calculations, factory OTIF performance metrics, and compliance audits. Multi-factory vendors' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierFactory .

ind:shipmentDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Shipment Distribution Center Id' ;
    rdfs:comment 'Identifier of the facility, warehouse, or manufacturing location from which the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the shipment arrived at the destination facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual timestamp when the shipment departed from the origin facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Legal document number issued by the carrier acknowledging receipt of cargo for shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Carrier or freight forwarder booking reference number for the shipment reservation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or packages included in the shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cubicVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cubic Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment measured in cubic meters, used for freight cost calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentMilestone rdf:type rdf:Property ;
    rdfs:label 'Current Milestone' ;
    rdfs:comment 'Most recent shipment milestone or checkpoint reached in the logistics journey (e.g., departed origin, in customs, out for delivery).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Planned or estimated timestamp when the shipment is expected to arrive at the destination facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Timestamp' ;
    rdfs:comment 'Planned or estimated timestamp when the shipment is expected to depart from the origin facility or port.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment including packaging, measured in kilograms.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gsp Eligible Flag' ;
    rdfs:comment 'Indicates whether the shipment qualifies for GSP tariff preferences, reducing or eliminating customs duties.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Declared value of the shipment for insurance purposes in the company\'s reporting currency.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment was delivered on time and in full per the agreed service level agreement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Total number of pallets included in the shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment, used across systems and with external partners.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the logistics workflow.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on commercial terms and destination type. FOB (Free on Board), LDP (Landed Duty Paid), DTC (Direct-to-Consumer), wholesale, inter-facility transfer, or RTV (Return to Vendor).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Date' ;
    rdfs:comment 'Target delivery date per the service level agreement with the customer or internal business unit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation for the shipment. FCL (Full Container Load), LCL (Less than Container Load). [ENUM-REF-CANDIDATE: ocean_fcl|ocean_lcl|air|ground|courier|rail|intermodal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Shipment Milestone Id' ;
    rdfs:comment 'Unique identifier for the shipment milestone event record.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether customs clearance was completed at this milestone, applicable for international shipments.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'Electronic Data Interchange (EDI) transaction set code that provided this milestone data (e.g., 214 for Transportation Carrier Shipment Status Message).' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed text description of the exception or issue encountered, providing context for root cause analysis and resolution.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this milestone represents an exception or deviation from the planned shipment flow (e.g., delay, damage, customs hold).' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humidityReading rdf:type rdf:Property ;
    rdfs:label 'Humidity Reading' ;
    rdfs:comment 'Relative humidity percentage recorded at this milestone, applicable for shipments requiring controlled environmental conditions.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Timestamp' ;
    rdfs:comment 'The originally planned or scheduled date and time for this milestone, used to calculate variance and On Time In Full (OTIF) performance.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordedByUser rdf:type rdf:Property ;
    rdfs:label 'Recorded By User' ;
    rdfs:comment 'Username or identifier of the system user or automated process that recorded this milestone event.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Code' ;
    rdfs:comment 'Unique identifier or code for the specific carrier, Third-Party Logistics (3PL) provider, customs broker, or other party responsible for this milestone.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this milestone was achieved within the Service Level Agreement (SLA) time window.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReading rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading' ;
    rdfs:comment 'Temperature reading in Celsius recorded at this milestone, applicable for temperature-controlled shipments of apparel with special storage requirements.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'The time difference in hours between planned and actual milestone timestamp, used for Service Level Agreement (SLA) compliance tracking. Positive values indicate delay, negative values indicate early arrival.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselVoyageNumber rdf:type rdf:Property ;
    rdfs:label 'Vessel Voyage Number' ;
    rdfs:comment 'Identifier for the vessel, flight, or voyage number associated with this milestone, applicable for ocean and air freight.' ;
    rdfs:domain ind:ShipmentMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'Date when the freight booking was formally placed with the carrier or freight forwarder. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingNotes rdf:type rdf:Property ;
    rdfs:label 'Booking Notes' ;
    rdfs:comment 'Additional notes or comments related to the freight booking. Captures operational details, exceptions, or coordination information.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Reference Number' ;
    rdfs:comment 'Externally-known unique booking reference number assigned by the carrier or freight forwarder. Used for tracking and communication with logistics partners.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedSpaceAllocation rdf:type rdf:Property ;
    rdfs:label 'Confirmed Space Allocation' ;
    rdfs:comment 'Confirmed cargo space allocated by the carrier for this booking, measured in cubic meters (CBM) or container equivalent units (TEU). Supports capacity planning.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Number of containers booked for this freight booking. Applicable for FCL (Full Container Load) shipments.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of shipping container used for the booking. Includes standard dry containers, high-cube, refrigerated (reefer), and specialized containers. Applicable for ocean freight FCL bookings.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOffDate rdf:type rdf:Property ;
    rdfs:label 'Cut Off Date' ;
    rdfs:comment 'Final date and time by which cargo must be delivered to the carrier or terminal to meet the scheduled departure. Critical for operational planning.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Estimated date when the carrier is scheduled to arrive at the port of discharge or destination terminal.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Date' ;
    rdfs:comment 'Estimated date when the carrier is scheduled to depart from the port of loading or origin terminal.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight charge amount for this booking as per the rate agreement. Excludes surcharges, duties, and taxes.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the freight charge amount. Indicates the currency in which the freight charge is denominated.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Boolean flag indicating whether the shipment contains hazardous materials requiring special handling and documentation. True if hazardous, False otherwise.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether cargo insurance is required for this booking. True if insurance is required, False otherwise.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the cargo for insurance purposes. Used to calculate insurance premiums and coverage limits.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfDischargeCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Code' ;
    rdfs:comment 'UN/LOCODE for the port or terminal where goods are unloaded from the carrier. Five-character alphanumeric code.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Code' ;
    rdfs:comment 'UN/LOCODE (United Nations Code for Trade and Transport Locations) for the port or terminal where goods are loaded onto the carrier. Five-character alphanumeric code.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of freight service booked. FCL (Full Container Load), LCL (Less than Container Load), air charter, express courier, ocean freight, road freight, rail freight, or courier service. [ENUM-REF-CANDIDATE: FCL|LCL|AIR_CHARTER|AIR_EXPRESS|OCEAN_FREIGHT|ROAD_FREIGHT|RAIL_FREIGHT|COURIER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceAllocationUnit rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Unit' ;
    rdfs:comment 'Unit of measure for the confirmed space allocation. CBM (Cubic Meters), TEU (Twenty-foot Equivalent Unit), FEU (Forty-foot Equivalent Unit), KG (Kilograms), or LBS (Pounds).' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the vessel (for ocean freight) or flight number (for air freight) assigned to transport the shipment. Null for road or rail freight.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'Voyage number for ocean freight or flight number for air freight. Identifies the specific journey leg for the shipment.' ;
    rdfs:domain ind:FreightBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'Date when the vessel or aircraft arrived at the U.S. port. Establishes the timeline for entry filing and duty payment deadlines.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Bond Amount Usd' ;
    rdfs:comment 'Face value of the customs bond in U.S. dollars. For single transaction bonds, typically 2-3 times the estimated duties. For continuous bonds, minimum $50,000 or 10% of duties paid in prior year, whichever is greater.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Type of customs bond securing the entry. Single: covers one transaction; Continuous: covers all transactions for one year (minimum $50,000); None: no bond required (e.g., informal entries under $2,500). Bonds guarantee payment of duties and compliance with regulations.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting the claimed country of origin and trade preference eligibility. Required for many FTA and GSP claims. Format varies by issuing authority.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current processing status of the customs entry. Filed: submitted to CBP; Accepted: entry accepted for processing; Hold: flagged for review; Exam: selected for physical or documentary examination; Released: goods authorized for delivery; Liquidated: final duty determination made; Cancelled: entry voided. [ENUM-REF-CANDIDATE: filed|accepted|hold|exam|released|liquidated|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Total declared customs value of the imported goods in U.S. dollars. Represents the transaction value (price paid or payable) adjusted for international freight, insurance, and other costs as required by customs valuation rules. Basis for duty calculation.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Duty Amount Usd' ;
    rdfs:comment 'Total customs duty assessed on the entry in U.S. dollars. Calculated by applying the applicable tariff rate to the dutiable value. May be reduced or eliminated under trade preference programs.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Entry Filing Date' ;
    rdfs:comment 'Date when the customs entry was officially filed with the customs authority. Critical for calculating duty payment deadlines and compliance with entry filing timelines.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Official customs entry number assigned by customs authority. Format: XXX-NNNNNNN-N (port code, sequential number, check digit). Required for all formal entries and used as the primary reference for customs clearance tracking and audit.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entrySummaryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Summary Date' ;
    rdfs:comment 'Date when the entry summary (CBP Form 7501) was filed with CBP. Must be filed within 10 working days of entry release. Contains final classification, valuation, and duty calculation.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of customs entry based on value threshold and processing requirements. Formal entries required for shipments over $2,500 USD; informal for lower values; in-bond for goods in transit; warehouse for deferred duty payment; FTZ (Free Trade Zone) for goods entering foreign trade zones.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examType rdf:type rdf:Property ;
    rdfs:label 'Exam Type' ;
    rdfs:comment 'Type of physical or documentary examination conducted by CBP or Partner Government Agency. Intensive: full container exam; Tailored: targeted inspection; Compliance: verification of entry accuracy; PGA: inspection by FDA, USDA, or other agency; None: no exam required.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftzAdmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Ftz Admission Number' ;
    rdfs:comment 'Admission number assigned when goods are admitted into a Foreign Trade Zone. Allows duty deferral or elimination. Null if goods did not enter an FTZ.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harborMaintenanceFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Harbor Maintenance Fee Usd' ;
    rdfs:comment 'Fee assessed at 0.125% of cargo value for commercial cargo shipped through identified U.S. ports. Used to fund harbor maintenance and dredging. Not applicable to air shipments.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'CBP-assigned code indicating the reason for entry hold or exam. Examples: 01 (intensive exam), 02 (tailored exam), 03 (compliance measurement), PGA (Partner Government Agency hold). Null if no hold.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecordName rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record Name' ;
    rdfs:comment 'Legal name of the entity responsible for ensuring imported goods comply with all laws and regulations and for paying duties, taxes, and fees. The IOR is legally liable for the accuracy of the customs declaration.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record Number' ;
    rdfs:comment 'IRS-assigned Employer Identification Number (EIN) or CBP-assigned importer number used to identify the importer of record. Format: XX-NNNNNNN.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Isf Filing Number' ;
    rdfs:comment 'Reference number for the ISF (10+2) filing submitted to CBP at least 24 hours before ocean cargo is loaded at foreign port. Required for all ocean shipments to the U.S. Links security data to the entry.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of line items (distinct HS code classifications) on this customs entry. Each line represents a different product classification with its own duty rate and origin.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidationDate rdf:type rdf:Property ;
    rdfs:label 'Liquidation Date' ;
    rdfs:comment 'Date when CBP made the final determination of duties, taxes, and fees owed. Liquidation typically occurs within 314 days of entry but may be extended. After liquidation, the entry is considered final unless protested.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandiseProcessingFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Merchandise Processing Fee Usd' ;
    rdfs:comment 'CBP-assessed fee for processing formal entries. Calculated as 0.3464% of entered value with minimum $27.75 and maximum $538.40 per entry (rates subject to periodic adjustment). Informal entries have fixed MPF rates.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which estimated duties, taxes, and fees must be paid to CBP. Typically 10 working days after entry release for non-periodic monthly statement filers. Late payment incurs interest charges.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Four-digit Schedule D port code identifying the U.S. port where goods are entered for customs clearance. Examples: 2704 (Los Angeles/Long Beach), 4601 (New York/Newark), 5301 (Miami).' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfUnladingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Unlading Code' ;
    rdfs:comment 'Four-digit Schedule D port code identifying where goods were physically unloaded from the arriving vessel or aircraft. May differ from port of entry for in-bond shipments.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protestFiledIndicator rdf:type rdf:Property ;
    rdfs:label 'Protest Filed Indicator' ;
    rdfs:comment 'Indicates whether a formal protest has been filed challenging CBP\'s liquidation decision. Protests must be filed within 180 days of liquidation. True if protest filed; False if no protest.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Indicator' ;
    rdfs:comment 'Indicates whether this entry is filed under CBP\'s reconciliation program, which allows importers to file entries with estimated data and reconcile with final data within 15 months. True if reconciliation entry; False if standard entry.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suretyCode rdf:type rdf:Property ;
    rdfs:label 'Surety Code' ;
    rdfs:comment 'Three-digit code identifying the surety company that issued the customs bond. Surety must be on the Treasury Department\'s list of approved sureties.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeProgramCode rdf:type rdf:Property ;
    rdfs:label 'Trade Program Code' ;
    rdfs:comment 'Code identifying the trade preference program under which duty reduction or elimination is claimed. GSP (Generalized System of Preferences), USMCA (United States-Mexico-Canada Agreement), FTA (Free Trade Agreement), AGOA (African Growth and Opportunity Act), CBI (Caribbean Basin Initiative), ATPA (Andean Trade Preference Act), NONE (no preference claimed). [ENUM-REF-CANDIDATE: GSP|USMCA|FTA|AGOA|CBI|ATPA|NONE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Flight Number' ;
    rdfs:comment 'Vessel voyage number or aircraft flight number on which the goods arrived. Links the entry to the specific conveyance manifest filed by the carrier.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antidumpingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Antidumping Duty Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to antidumping duties for imports from specific countries due to unfair pricing practices.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chapter rdf:type rdf:Property ;
    rdfs:label 'Chapter' ;
    rdfs:comment 'The two-digit chapter number of the HS code representing the broad product category (e.g., Chapter 61 for knitted apparel, Chapter 62 for woven apparel, Chapter 64 for footwear).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countervailingDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to countervailing duties for imports from specific countries due to foreign government subsidies.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulated Flag' ;
    rdfs:comment 'Indicates whether products under this HS code are subject to CPSC safety standards and testing requirements (e.g., flammability standards for children\'s sleepwear, lead content limits).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Cpsc Regulation Reference' ;
    rdfs:comment 'Specific CPSC regulation citation applicable to this HS code (e.g., 16 CFR 1610 for flammability, 16 CFR 1501 for small parts). Null if not CPSC regulated.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyRateUnit rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Unit' ;
    rdfs:comment 'Indicates whether the duty rate is ad valorem (percentage of value), specific (per unit/weight), or compound (combination of both).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification Required' ;
    rdfs:comment 'Environmental or sustainability certifications required or recommended for products under this HS code (e.g., OEKO-TEX Standard 100, GOTS, BCI). Null if no specific requirements.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcLabelingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Required Flag' ;
    rdfs:comment 'Indicates whether products under this HS code require FTC-mandated fiber content labeling, country of origin marking, or care labeling per Textile and Wool Acts.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcLabelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Ftc Labeling Requirement' ;
    rdfs:comment 'Specific FTC labeling requirements for this HS code including fiber content disclosure, country of origin, manufacturer identification, and care instructions. Null if not required.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalDutyRate rdf:type rdf:Property ;
    rdfs:label 'General Duty Rate' ;
    rdfs:comment 'The standard Most Favored Nation (MFN) duty rate expressed as a percentage or specific rate applicable to imports from countries without preferential trade agreements. Used for Landed Duty Paid (LDP) calculations.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspBeneficiaryCountries rdf:type rdf:Property ;
    rdfs:label 'Gsp Beneficiary Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes eligible for GSP treatment for this HS code. Null if GSP not applicable.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heading rdf:type rdf:Property ;
    rdfs:label 'Heading' ;
    rdfs:comment 'The four-digit heading number providing a more specific product classification within the chapter (e.g., 6109 for T-shirts, singlets, and other vests).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Hs Code Description' ;
    rdfs:comment 'Full official description of the product classification including material composition, construction method, and intended use as defined by the Harmonized System nomenclature.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Hs Code Status' ;
    rdfs:comment 'Current lifecycle status of this HS code. Active codes are used for current classifications. Deprecated codes have been replaced by new codes in HS updates. Superseded codes reference the replacement code. Pending codes are scheduled for future activation.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsVersion rdf:type rdf:Property ;
    rdfs:label 'Hs Version' ;
    rdfs:comment 'The version year of the Harmonized System nomenclature (e.g., HS2017, HS2022) under which this code is classified. WCO updates the HS every 5 years.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalExtension rdf:type rdf:Property ;
    rdfs:label 'National Extension' ;
    rdfs:comment 'Additional digits beyond the 6-digit subheading added by individual countries for more granular classification (e.g., US uses 10-digit HTS codes). May be null for base 6-digit codes.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCriteria rdf:type rdf:Property ;
    rdfs:label 'Origin Criteria' ;
    rdfs:comment 'Rules of origin criteria that must be met for products under this HS code to qualify for preferential duty treatment (e.g., tariff shift rules, regional value content thresholds, substantial transformation tests).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialDutyRate rdf:type rdf:Property ;
    rdfs:label 'Preferential Duty Rate' ;
    rdfs:comment 'Reduced duty rate available under preferential trade agreements such as USMCA, GSP, or bilateral free trade agreements. Null if no preferential rate applies.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to import or export restrictions, quotas, licensing requirements, or prohibitions by customs authorities.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Type of restriction or special requirement applicable to this HS code. Null if restricted_flag is false.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:section301DutyFlag rdf:type rdf:Property ;
    rdfs:label 'Section 301 Duty Flag' ;
    rdfs:comment 'Indicates whether this HS code is subject to additional Section 301 tariffs imposed on imports from specific countries (e.g., China tariffs).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:section301DutyRate rdf:type rdf:Property ;
    rdfs:label 'Section 301 Duty Rate' ;
    rdfs:comment 'Additional duty rate percentage imposed under Section 301 trade actions. Null if not subject to Section 301 duties.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the HS code for operational use in warehouse management, shipping documents, and internal systems.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subheading rdf:type rdf:Property ;
    rdfs:label 'Subheading' ;
    rdfs:comment 'The six-digit subheading providing internationally standardized product classification. This is the minimum level required for international trade.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByHsCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Hs Code' ;
    rdfs:comment 'The new HS code that replaces this code when status is superseded. Used to maintain continuity during HS version transitions. Null for active codes.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textileCategory rdf:type rdf:Property ;
    rdfs:label 'Textile Category' ;
    rdfs:comment 'Textile category classification used for quota administration and trade monitoring (historically used for Multi-Fiber Arrangement, still relevant for certain trade agreements).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAgreement rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement' ;
    rdfs:comment 'Name of the trade agreement or preferential program under which the preferential duty rate applies (e.g., USMCA, GSP, CAFTA-DR, EU-FTA). Null if general duty rate applies.' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Of Quantity' ;
    rdfs:comment 'The unit of measure required for statistical reporting and quota tracking for this HS code (e.g., dozens for shirts, pairs for footwear, kilograms for fabric).' ;
    rdfs:domain ind:HsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiDumpingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Anti Dumping Duty Amount' ;
    rdfs:comment 'Additional duty imposed to offset unfair pricing practices when goods are sold below fair market value. Applied on top of standard duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Duty Amount' ;
    rdfs:comment 'Standard import duty calculated by applying the duty rate percentage to the CIF value, before any trade preferences or additional duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationNumber rdf:type rdf:Property ;
    rdfs:label 'Calculation Number' ;
    rdfs:comment 'Business-readable unique identifier for the duty calculation, used for reference in customs documentation and financial reporting. Format: DC-XXXXXXXXXX.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current lifecycle status of the duty calculation. Tracks progression from initial calculation through customs approval and payment reconciliation. [ENUM-REF-CANDIDATE: draft|calculated|submitted|approved|rejected|paid|reconciled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when the duty calculation was performed. Critical for audit trail and compliance reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cifValue rdf:type rdf:Property ;
    rdfs:label 'Cif Value' ;
    rdfs:comment 'Total customs value including FOB value, freight, and insurance. The dutiable value upon which import duties and taxes are calculated.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countervailingDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Countervailing Duty Amount' ;
    rdfs:comment 'Additional duty imposed to offset foreign government subsidies that unfairly benefit exporters. Applied on top of standard duties.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exciseTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Excise Tax Amount' ;
    rdfs:comment 'Special excise taxes on specific product categories (e.g., luxury goods, alcohol, tobacco). Applied based on product classification.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobValue rdf:type rdf:Property ;
    rdfs:label 'Fob Value' ;
    rdfs:comment 'The value of goods at the point of shipment, excluding freight and insurance. Base value for duty calculation before transportation costs.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftaClaimedFlag rdf:type rdf:Property ;
    rdfs:label 'Fta Claimed Flag' ;
    rdfs:comment 'Indicates whether preferential duty treatment under a Free Trade Agreement was claimed. FTAs provide reduced or zero duty rates for qualifying goods.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftaName rdf:type rdf:Property ;
    rdfs:label 'Fta Name' ;
    rdfs:comment 'Name of the specific Free Trade Agreement under which preferential treatment is claimed (e.g., USMCA, CAFTA-DR, Korea FTA).' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftaReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Fta Reduction Amount' ;
    rdfs:comment 'Duty reduction amount granted under FTA preferential treatment. Reduces the base duty amount when FTA eligibility is confirmed.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gspClaimedFlag rdf:type rdf:Property ;
    rdfs:label 'Gsp Claimed Flag' ;
    rdfs:comment 'Indicates whether GSP preferential duty treatment was claimed for this shipment. GSP provides duty-free treatment for eligible products from developing countries.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gspReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Gsp Reduction Amount' ;
    rdfs:comment 'Duty reduction amount granted under GSP preferential treatment. Reduces the base duty amount when GSP eligibility is confirmed.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hmfAmount rdf:type rdf:Property ;
    rdfs:label 'Hmf Amount' ;
    rdfs:comment 'U.S. fee assessed on cargo shipped through U.S. ports to fund harbor maintenance. Calculated as a percentage of cargo value.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCost rdf:type rdf:Property ;
    rdfs:label 'Insurance Cost' ;
    rdfs:comment 'Insurance premium for goods in transit. Added to FOB and freight to calculate CIF value for customs valuation.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Ldp Total Amount' ;
    rdfs:comment 'Total landed cost including CIF value, all duties, taxes, and fees. Represents the complete cost to bring goods into the destination country.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldpUnitCost rdf:type rdf:Property ;
    rdfs:label 'Ldp Unit Cost' ;
    rdfs:comment 'Per-unit landed cost calculated by dividing LDP total amount by quantity. Used for COGS calculation and margin analysis in SAP FI/CO.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpfAmount rdf:type rdf:Property ;
    rdfs:label 'Mpf Amount' ;
    rdfs:comment 'U.S. Customs fee for processing imported merchandise. Calculated as a percentage of shipment value with minimum and maximum caps.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portOfEntry rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry' ;
    rdfs:comment 'Official customs port or border crossing where goods entered the destination country. Impacts processing times and local regulations.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the duty calculation was submitted to customs authorities. Critical for compliance and SLA tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Duty Amount' ;
    rdfs:comment 'Sum of all duty components including base duty, anti-dumping, countervailing duties, less any GSP or FTA reductions. Excludes taxes and fees.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fees Amount' ;
    rdfs:comment 'Sum of all customs processing fees including MPF, HMF, and other regulatory fees.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all tax components including VAT, excise taxes, and other applicable import taxes.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation for any variance between calculated and actual duty amounts. Used for process improvement and dispute resolution.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatAmount rdf:type rdf:Property ;
    rdfs:label 'Vat Amount' ;
    rdfs:comment 'Import VAT or sales tax assessed on the total landed value including duties. Applicable in jurisdictions with VAT systems.' ;
    rdfs:domain ind:DutyCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Flag' ;
    rdfs:comment 'Indicates whether the carrier provides API integration for real-time tracking, rate quotes, and booking automation (True/False).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal name of the transportation carrier or logistics service provider (e.g., Maersk Line, FedEx Corporation, United Parcel Service).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational and business relationship status of the carrier. Preferred carriers receive priority routing; approved carriers meet minimum standards; probation indicates performance issues under review; suspended carriers are temporarily blocked; inactive carriers are no longer used.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary classification of the carrier based on transportation mode: ocean shipping line, air freight carrier, ground less-than-truckload (LTL), ground full-truckload (FTL), rail operator, last-mile courier, third-party logistics provider (3PL), or freight forwarder. [ENUM-REF-CANDIDATE: ocean|air|ground_ltl|ground_ftl|rail|courier|3pl|freight_forwarder — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the current carrier contract or service agreement became effective.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current carrier contract or service agreement expires. Null for open-ended or evergreen agreements.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the master service agreement or transportation contract governing the business relationship with this carrier.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageClaimRate rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Rate' ;
    rdfs:comment 'Percentage of shipments handled by this carrier that resulted in damage claims. Lower rates indicate better handling quality.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'US Department of Transportation identification number assigned to commercial motor carriers. Required for regulatory compliance and safety tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the carrier supports EDI for automated booking, shipment status updates, and invoicing (True/False).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic regions, countries, or trade lanes served by this carrier (e.g., North America, Trans-Pacific, Europe-Asia, Last-Mile USA).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the carriers headquarters street address.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carriers headquarters is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the carriers headquarters location (e.g., USA, CHN, DEU).' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the carriers headquarters address.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or region where the carriers headquarters is located.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'Two or three-character airline designator code assigned by IATA for air freight carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Certificate number of the carriers cargo insurance or liability insurance policy on file. Required for risk management and compliance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Maximum liability coverage amount provided by the carriers insurance policy, typically in USD. Used to assess risk exposure for high-value shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the carriers current insurance certificate. Monitored to ensure continuous coverage.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Motor Carrier operating authority number issued by FMCSA for interstate commerce in the United States.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'On Time Performance Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) representing the carriers on-time delivery performance based on historical shipment data. Used for carrier selection and routing optimization.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) representing the carriers performance in delivering shipments both on time and in full (complete quantity, undamaged). Key performance indicator for carrier evaluation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique two-to-four-letter code used to identify transportation companies in North America. Required for EDI transactions and customs documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Comma-separated list of service modes offered by the carrier (e.g., express, standard, economy, next-day, two-day, international, domestic, white-glove).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number (TIN, EIN, VAT number) of the carrier entity. Used for invoicing, tax reporting, and compliance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for shipment tracking on the carriers website. Placeholder tokens (e.g., {tracking_number}) are replaced with actual shipment identifiers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originProductionFactoryId rdf:type rdf:Property ;
    rdfs:label 'Origin Production Factory Id' ;
    rdfs:comment 'Foreign key linking to production.production_factory. Business justification: Routing guides in apparel specify factory-specific shipping instructions — carrier, mode, and lane from a specific origin factory to destination DC. Vendor compliance programs require factory-level ro' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionFactory .

ind:primaryCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Id' ;
    rdfs:comment 'Reference to the preferred carrier assigned to this lane as the first choice for transportation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryRoutingDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Routing Distribution Center Id' ;
    rdfs:comment 'Reference to the specific origin facility, warehouse, or manufacturing plant from which shipments originate.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:tertiaryRoutingLastMileCarrierId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Routing Last Mile Carrier Id' ;
    rdfs:comment 'Reference to the carrier responsible for final delivery to the destination, used for multi-leg shipments.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this routing guide has mandatory compliance requirements such as customs clearance, HS code validation, or GSP utilization.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guideCode rdf:type rdf:Property ;
    rdfs:label 'Guide Code' ;
    rdfs:comment 'Business identifier for the routing guide rule, used for external reference and operational lookup.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guideName rdf:type rdf:Property ;
    rdfs:label 'Guide Name' ;
    rdfs:comment 'Descriptive name of the routing guide rule for business user identification.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCodeValidationRequired rdf:type rdf:Property ;
    rdfs:label 'Hs Code Validation Required' ;
    rdfs:comment 'Flag indicating whether shipments using this routing guide must have validated HS codes for customs clearance.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldpCalculationRequired rdf:type rdf:Property ;
    rdfs:label 'Ldp Calculation Required' ;
    rdfs:comment 'Flag indicating whether landed cost calculations including duties, taxes, and fees must be computed for this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTransitDays rdf:type rdf:Property ;
    rdfs:label 'Max Transit Days' ;
    rdfs:comment 'Maximum number of calendar days allowed for shipment transit from origin to destination under this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumShipmentVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Shipment Volume' ;
    rdfs:comment 'Minimum shipment volume or weight required to utilize this routing guide, enforcing carrier minimum order quantity (MOQ) requirements.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'Primary transportation method to be used for shipments following this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGuideStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Status' ;
    rdfs:comment 'Current lifecycle state of the routing guide rule, controlling whether it is available for shipment assignment.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNotes rdf:type rdf:Property ;
    rdfs:label 'Routing Notes' ;
    rdfs:comment 'Free-text field for additional routing instructions, special handling requirements, or operational notes for logistics teams.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetOtifPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otif Percent' ;
    rdfs:comment 'Target percentage for on-time and in-full delivery performance that carriers must meet under this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'Unit of measure for minimum shipment volume (cartons, pallets, kilograms, pounds, cubic meters, cubic feet).' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of warehouse automation deployed at the distribution center. Manual: labor-intensive operations. Semi-automated: conveyor systems and sortation. Fully automated: automated storage and retrieval systems (AS/RS). Robotic: autonomous mobile robots and advanced automation.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Bulk Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to bulk pallet storage zone for high-volume inventory.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Cold Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to temperature-controlled storage for specialty materials or products requiring climate control.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsBondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the distribution center is a customs bonded warehouse authorized to store imported goods before duties are paid. Critical for international trade and Landed Duty Paid (LDP) calculations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems and documentation. Externally-known unique code for facility identification.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the distribution center was decommissioned and ceased operations. Null for active facilities.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official name of the distribution center or fulfillment facility.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the distribution center by operational model and purpose. Owned DC: company-owned distribution center. 3PL-operated: Third-Party Logistics (3PL) operated facility. Cross-dock: transshipment facility. Returns center: dedicated returns processing. Forward stocking location: regional inventory buffer. Fulfillment center: e-commerce order fulfillment.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hangingStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Hanging Storage Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to hanging garment storage on rails for apparel that requires hanging to maintain quality.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the facility lease expires for leased distribution centers. Null for owned facilities. Used for real estate planning and renewal negotiations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the distribution center (e.g., 24/7, Mon-Fri 6AM-6PM, Mon-Sat 8AM-8PM). Used for scheduling and service level planning.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickZoneCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Pick Zone Capacity Sqft' ;
    rdfs:comment 'Square footage allocated to active picking zones for order fulfillment operations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsDtcChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Dtc Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports Direct-to-Consumer (DTC) e-commerce order fulfillment.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOutletChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Outlet Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports outlet store fulfillment for clearance and off-season merchandise.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRetailReplenishmentChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Retail Replenishment Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports replenishment shipments to company-owned retail stores.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsWholesaleChannel rdf:type rdf:Property ;
    rdfs:label 'Supports Wholesale Channel' ;
    rdfs:comment 'Indicates whether this distribution center supports wholesale distribution to retail partners and department stores.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily processing capacity measured in units that can be received, stored, picked, packed, and shipped. Used for capacity planning and load balancing.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total facility area in square feet including warehouse, office, and support spaces. Used for capacity planning and cost allocation.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Identifier for the Manhattan Associates WMS instance managing this distribution center. Links facility to specific WMS deployment.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Number' ;
    rdfs:comment 'Government-issued license number authorizing the 3PL partner to perform customs brokerage services. Applicable only when service_type includes customs brokerage.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightForwarderCode rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Code' ;
    rdfs:comment 'Standard Carrier Alpha Code (SCAC) or International Air Transport Association (IATA) code for the 3PL partner when acting as a freight forwarder.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle status of the 3PL partner relationship. Prospective indicates evaluation phase, onboarding indicates setup in progress, active indicates operational, suspended indicates temporary hold, terminated indicates contract ended, and inactive indicates no longer used.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Externally-known unique business identifier for the 3PL partner, used in EDI transactions, WMS integrations, and operational communications.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days for invoices from this 3PL partner (e.g., 30, 45, 60 days net).' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnsProcessingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Returns Processing Capable Flag' ;
    rdfs:comment 'Indicates whether the 3PL partner has capabilities to process customer returns, including inspection, restocking, and disposition management.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Contractual service level tier defining performance commitments, response times, and quality standards for this 3PL partnership.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether the 3PL partner holds recognized sustainability or environmental certifications (e.g., ISO 14001, SmartWay, LEED).' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWarehouseSqft rdf:type rdf:Property ;
    rdfs:label 'Total Warehouse Sqft' ;
    rdfs:comment 'Total warehouse storage capacity in square feet across all facilities operated by this 3PL partner.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCount rdf:type rdf:Property ;
    rdfs:label 'Warehouse Count' ;
    rdfs:comment 'Total number of warehouse or distribution center facilities operated by this 3PL partner within their coverage regions.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Type' ;
    rdfs:comment 'Technical integration method used to connect the 3PL partner\'s WMS with internal systems. API indicates real-time REST/SOAP integration, EDI 940/945 uses standard warehouse transaction sets, flat file uses CSV/XML batch files, SFTP uses secure file transfer, and none indicates manual processes.' ;
    rdfs:domain ind:ThirdPartyLogistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Monetary bonus amount per measurement period when SLA performance exceeds upper threshold.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bonus Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for bonus amounts.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusStructure rdf:type rdf:Property ;
    rdfs:label 'Bonus Structure' ;
    rdfs:comment 'Description of financial or operational incentives awarded when SLA targets are exceeded.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Flag' ;
    rdfs:comment 'Indicates whether automated notifications are enabled when SLA thresholds are breached.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the service provider bound by this SLA. 3PL = Third-Party Logistics.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactEmail rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Email' ;
    rdfs:comment 'Email address of the escalation contact for SLA performance issues.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactName rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Name' ;
    rdfs:comment 'Name of the primary contact person for SLA breach escalations and dispute resolution.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContactPhone rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Phone' ;
    rdfs:comment 'Phone number of the escalation contact for urgent SLA breach notifications.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'Cadence at which SLA performance is measured and reported.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Description of how the metric is calculated, including data sources and calculation logic.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the performance metric being measured (e.g., On-Time Delivery Rate, Transit Time, Damage Rate).' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required to terminate or modify the SLA agreement.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the origin facility, port, or distribution center for lane-specific SLAs.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount per breach or per measurement period when SLA is not met.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for penalty amounts.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyStructure rdf:type rdf:Property ;
    rdfs:label 'Penalty Structure' ;
    rdfs:comment 'Description of financial or operational penalties applied when SLA targets are not met.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSystem rdf:type rdf:Property ;
    rdfs:label 'Reporting System' ;
    rdfs:comment 'Name of the system or platform used to track and report SLA performance metrics (e.g., Manhattan Associates WMS, EDI feed).' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which the SLA terms and performance are formally reviewed by both parties.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed textual description of the lanes, facilities, regions, or service types covered by this SLA.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Defines the operational scope to which this SLA applies (e.g., specific shipping lane, warehouse facility, geographic region).' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA agreement.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name or title of the SLA agreement for easy identification.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Number' ;
    rdfs:comment 'Externally-known business identifier for the SLA agreement, used in contracts and communications.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of service level commitment being measured. OTIF = On Time In Full.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnit rdf:type rdf:Property ;
    rdfs:label 'Target Unit' ;
    rdfs:comment 'Unit of measure for the target value (e.g., percentage for OTIF, days for transit time).' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target or threshold value that the service provider commits to achieve.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdLowerBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Bound' ;
    rdfs:comment 'Minimum acceptable performance level before penalties or escalations are triggered.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Bound' ;
    rdfs:comment 'Performance level above which bonus or incentive structures may apply.' ;
    rdfs:domain ind:SlaAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPackingDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Packing Distribution Center Id' ;
    rdfs:comment 'Reference to the manufacturing facility or warehouse where goods were packed. Used for sourcing analytics and quality traceability.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:cartonLabelFormat rdf:type rdf:Property ;
    rdfs:label 'Carton Label Format' ;
    rdfs:comment 'Barcode or label standard used on cartons. GS1-128 for standard supply chain labels, SSCC for serial shipping container codes, UCC-128 for legacy format, custom for proprietary labels.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the goods were manufactured or substantially transformed. Used for GSP eligibility and trade agreement compliance.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description of any receiving discrepancies, damages, or quality issues identified. Used for supplier performance tracking and claims processing.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the invoice value. Used for foreign exchange conversion and financial reporting.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingDate rdf:type rdf:Property ;
    rdfs:label 'Packing Date' ;
    rdfs:comment 'Date when the goods were physically packed and the packing list was prepared. Used for lead time calculation and production schedule tracking.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packingListStatus rdf:type rdf:Property ;
    rdfs:label 'Packing List Status' ;
    rdfs:comment 'Current lifecycle status of the packing list document. Draft indicates in-progress, finalized means ready for shipment, submitted means sent to customs/receiver, received means acknowledged by DC, discrepancy indicates receiving variance, closed means reconciled.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListType rdf:type rdf:Property ;
    rdfs:label 'Packing List Type' ;
    rdfs:comment 'Classification of packing list document. Master for container-level summary, detailed for SKU-level breakdown, consolidated for multi-PO shipments, sample for pre-production shipments.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingMethod rdf:type rdf:Property ;
    rdfs:label 'Packing Method' ;
    rdfs:comment 'Method used to pack the apparel or footwear goods. Flat pack for folded garments, hanging for garments on hangers, polybag for individual poly-bagged items, boxed for footwear in shoeboxes, mixed for combination methods.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether goods in this packing list require quality inspection upon receipt. True if inspection is mandatory before putaway.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Hold Flag' ;
    rdfs:comment 'Indicates whether goods must be placed in quarantine hold upon receipt pending inspection or compliance verification. True if quarantine is required.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the packing list was acknowledged as received at the destination facility. Used for OTIF compliance and transit time calculation.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingDiscrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Receiving Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a discrepancy was identified during receiving (quantity variance, damage, quality issue). True if discrepancy exists and requires resolution.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCubicVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cubic Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment measured in cubic meters. Used for container utilization analysis and dimensional weight pricing.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment including packaging materials, measured in kilograms. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceValue rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Value' ;
    rdfs:comment 'Total declared value of goods on the commercial invoice for this packing list. Used for customs valuation, duty calculation, and insurance coverage.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of the goods excluding packaging materials, measured in kilograms. Used for customs valuation and duty calculation.' ;
    rdfs:domain ind:PackingList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Gl Account Id' ;
    rdfs:comment 'Internal account identifier within the house bank structure. Used in combination with house_bank_id to uniquely identify the account in SAP.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:bankGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Bank accounts are linked to GL accounts for reconciliation and financial reporting. Normalizing STRING gl_account_code to FK gl_account_id → gl_account.gl_account_id. Remove redundant gl_account_code ' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:cashPoolHeaderBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Header Bank Account Id' ;
    rdfs:comment 'Self-referencing FK on bank_account (cash_pool_header_bank_account_id)' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountClosingDate rdf:type rdf:Property ;
    rdfs:label 'Account Closing Date' ;
    rdfs:comment 'Date when the bank account was officially closed. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Account Opening Date' ;
    rdfs:comment 'Date when the bank account was officially opened and activated with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurposeDescription rdf:type rdf:Property ;
    rdfs:label 'Account Purpose Description' ;
    rdfs:comment 'Free-text description of the business purpose and usage of this bank account. Provides context for treasury management and audit purposes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Available Balance Amount' ;
    rdfs:comment 'Available balance after accounting for holds, pending transactions, and reserved funds. Represents actual spendable cash.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 1' ;
    rdfs:comment 'First line of the bank branch physical address. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line 2' ;
    rdfs:comment 'Second line of the bank branch physical address (suite, floor, building). Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier code (e.g., routing number in USA, sort code in UK, bank code in other countries). Used for domestic payment processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Phone Number' ;
    rdfs:comment 'Primary contact phone number for the bank branch. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the bank branch location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State or province where the bank branch is located. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolingIndicator rdf:type rdf:Property ;
    rdfs:label 'Cash Pooling Indicator' ;
    rdfs:comment 'Flag indicating whether this account participates in a cash pooling arrangement for treasury optimization across multiple entities or accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current available balance in the bank account as of the last reconciliation or statement date. Used for cash flow management and liquidity analysis.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'Unique identifier for the house bank in SAP S/4HANA FI. Represents the company\'s banking partner where the account is maintained.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percentage' ;
    rdfs:comment 'Annual interest rate percentage applied to the account balance. May be positive for interest-bearing accounts or negative for certain treasury accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date when the last bank reconciliation was completed for this account. Critical for End of Month (EOM) close and financial reporting accuracy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent bank statement received and processed for this account. Used for reconciliation tracking.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcFacilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Lc Facility Indicator' ;
    rdfs:comment 'Flag indicating whether this account is designated for Letter of Credit (LC) issuance and settlement. Critical for apparel fashion global sourcing and Free on Board (FOB) payment terms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Lc Limit Amount' ;
    rdfs:comment 'Maximum Letter of Credit facility limit available on this account. Used for managing trade finance capacity for international supplier payments.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum balance requirement set by the bank or company policy to avoid fees or maintain account status.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft or credit facility limit extended by the bank for this account. Zero if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this account (e.g., wire transfer, ACH, check, EDI, SWIFT). Used for payment run configuration.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Email' ;
    rdfs:comment 'Email address of the bank relationship manager. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerName rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Name' ;
    rdfs:comment 'Name of the bank relationship manager or account officer responsible for this account. Key contact for banking services and issue resolution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Phone' ;
    rdfs:comment 'Phone number of the bank relationship manager. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkSourceLotId rdf:type rdf:Property ;
    rdfs:label 'Rework Source Lot Id' ;
    rdfs:comment 'Self-referencing FK on lot (rework_source_lot_id)' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Number of units that passed quality inspection and are approved for shipment.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Carton Range End' ;
    rdfs:comment 'Last carton number in the range of shipping cartons packed from this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonRangeStart rdf:type rdf:Property ;
    rdfs:label 'Carton Range Start' ;
    rdfs:comment 'First carton number in the range of shipping cartons packed from this lot, enabling downstream shipment traceability.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Number' ;
    rdfs:comment 'Certificate number for regulatory compliance documentation (e.g., CPSIA certificate, OEKO-TEX certificate) associated with this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical defects (safety hazards, non-compliance issues) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabricShadeLotNumber rdf:type rdf:Property ;
    rdfs:label 'Fabric Shade Lot Number' ;
    rdfs:comment 'Shade lot identifier for the bulk fabric used in this production lot, critical for color consistency and traceability.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishingDate rdf:type rdf:Property ;
    rdfs:label 'Finishing Date' ;
    rdfs:comment 'Date when finishing operations (pressing, trimming, packaging) were completed for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the production lot. Open indicates lot is active and receiving production; in_progress indicates manufacturing underway; closed indicates lot is complete; on_hold indicates temporary suspension; cancelled indicates lot was terminated; quarantined indicates quality hold.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the production lot by purpose. Bulk production is main manufacturing run; pre-production sample is PP sample lot; top sample is first production unit; shipment sample is quality check sample; development sample is design validation; reorder is repeat production; rework is defect correction. [ENUM-REF-CANDIDATE: bulk_production|pre_production_sample|top_sample|shipment_sample|development_sample|reorder|rework — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Major Defect Count' ;
    rdfs:comment 'Number of major defects (functional failures, significant appearance issues) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defect Count' ;
    rdfs:comment 'Number of minor defects (cosmetic issues, small workmanship flaws) found in this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sewEndDate rdf:type rdf:Property ;
    rdfs:label 'Sew End Date' ;
    rdfs:comment 'Date when sewing operations were completed for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sewStartDate rdf:type rdf:Property ;
    rdfs:label 'Sew Start Date' ;
    rdfs:comment 'Date when sewing operations began for this lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendedLetterOfCreditId rdf:type rdf:Property ;
    rdfs:label 'Amended Letter Of Credit Id' ;
    rdfs:comment 'Self-referencing FK on letter_of_credit (amended_letter_of_credit_id)' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfCredit .

ind:issuingBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Letters of credit are issued through a specific bank account maintained in SAP S/4HANA FI. Currently the issuing bank is captured as denormalized STRING fields (issuing_bank_name, issuing_bank_swift_c' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:advisingBankName rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Name' ;
    rdfs:comment 'The name of the bank that advises the letter of credit to the beneficiary, typically located in the beneficiary\'s country.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisingBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Swift Code' ;
    rdfs:comment 'The SWIFT/BIC code of the advising bank for international communication and document handling.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment to the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number tracking amendments made to the original letter of credit. Zero indicates the original LC with no amendments.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantAddress rdf:type rdf:Property ;
    rdfs:label 'Applicant Address' ;
    rdfs:comment 'The full business address of the applicant party requesting the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'The name of the party (buyer/importer) who requests the issuing bank to open the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'The remaining credit amount available for utilization under the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargesAccount rdf:type rdf:Property ;
    rdfs:label 'Charges Account' ;
    rdfs:comment 'Indicates which party (applicant or beneficiary) is responsible for paying the letter of credit charges and fees.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmingBankName rdf:type rdf:Property ;
    rdfs:label 'Confirming Bank Name' ;
    rdfs:comment 'The name of the bank that adds its confirmation to the letter of credit, providing additional payment guarantee to the beneficiary.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRequirements rdf:type rdf:Property ;
    rdfs:label 'Document Requirements' ;
    rdfs:comment 'Detailed description of all documents required to be presented for negotiation under the letter of credit (e.g., commercial invoice, packing list, bill of lading, certificate of origin, inspection certificate).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsDescription rdf:type rdf:Property ;
    rdfs:label 'Goods Description' ;
    rdfs:comment 'Description of the goods or merchandise covered by the letter of credit, including product details, quantities, and specifications.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Shipment Date' ;
    rdfs:comment 'The last permissible date for shipment of goods under the terms of the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcAmount rdf:type rdf:Property ;
    rdfs:label 'Lc Amount' ;
    rdfs:comment 'The maximum monetary value of the letter of credit. This is the principal quantitative fact representing the credit limit available to the beneficiary.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'The externally-known documentary credit number issued by the bank. This is the business identifier used in trade finance communications and documentation.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcStatus rdf:type rdf:Property ;
    rdfs:label 'Lc Status' ;
    rdfs:comment 'Current lifecycle status of the letter of credit in the trade finance workflow. [ENUM-REF-CANDIDATE: draft|issued|advised|confirmed|amended|utilized|expired|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcType rdf:type rdf:Property ;
    rdfs:label 'Lc Type' ;
    rdfs:comment 'Classification of the letter of credit based on its terms and conditions. Determines the level of commitment and transferability.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether partial shipments of goods are permitted under the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presentationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Presentation Period Days' ;
    rdfs:comment 'The maximum number of days after shipment date within which documents must be presented to the bank for negotiation.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revolvingFlag rdf:type rdf:Property ;
    rdfs:label 'Revolving Flag' ;
    rdfs:comment 'Indicates whether the letter of credit automatically renews for additional shipments after each utilization.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any additional special terms, conditions, or instructions specific to this letter of credit that are not covered by standard fields.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenorDays rdf:type rdf:Property ;
    rdfs:label 'Tenor Days' ;
    rdfs:comment 'The number of days after sight or shipment date when payment is due under deferred payment or usance terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'The permissible percentage variance (plus or minus) allowed in the LC amount and quantity as per UCP 600 Article 30.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the letter of credit can be transferred in whole or in part to one or more second beneficiaries.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transshipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Transshipment Allowed' ;
    rdfs:comment 'Indicates whether transshipment (transfer of goods from one vessel to another during transit) is permitted under the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizedAmount rdf:type rdf:Property ;
    rdfs:label 'Utilized Amount' ;
    rdfs:comment 'The cumulative amount that has been drawn or utilized against the letter of credit to date.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctionGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Correction Goods Receipt Id' ;
    rdfs:comment 'Self-referencing FK on goods_receipt (correction_goods_receipt_id)' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:receivingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Receiving Associate Id' ;
    rdfs:comment 'Foreign key linking to store.associate. Business justification: Store goods receipts are processed by specific store associates. Apparel retail operations require associate-level accountability for receiving discrepancies, shrinkage investigations, and compliance ' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Standardized code indicating the type of discrepancy found during goods receipt, if any.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Human-readable description of the product being received, including style, color, and size details.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the goods receipt transaction based on business purpose and origin.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'Specific dock door, staging area, or receiving bay code where goods were physically received.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes recorded by the receiving personnel regarding condition, discrepancies, or special observations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The unique product identifier for the item being received. Core business identifier for inventory tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Reference to the parent brand if this is a sub-brand or brand extension. Null for standalone brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative description of the brand\'s identity, heritage, values, and market positioning used for internal reference and external marketing.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand indicating whether it is actively marketed, discontinued, or in transition.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary market classification of the brand indicating its positioning and target segment within the apparel and fashion industry.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'The year the brand was established or founded, used for heritage marketing and brand storytelling.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'The date when the brand license agreement expires or is set to be renewed. Null for perpetual or owned brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'The date when the brand license agreement became effective. Applicable only for licensed brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Indicates the ownership and licensing model for the brand (owned outright, licensed from another entity, licensed to partners, or joint venture).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Name of the entity that owns the brand intellectual property if the brand is licensed in. Null for owned brands.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL or file path to the official brand logo image file used in digital and print materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the brand manager for internal communication and coordination.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the individual responsible for managing the brand strategy, marketing, and performance.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategories rdf:type rdf:Property ;
    rdfs:label 'Product Categories' ;
    rdfs:comment 'Comma-separated list of primary product categories the brand offers (e.g., footwear, apparel, accessories, equipment).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandles rdf:type rdf:Property ;
    rdfs:label 'Social Media Handles' ;
    rdfs:comment 'JSON or comma-separated string containing the brand\'s official social media account handles across platforms (Instagram, Facebook, Twitter, TikTok, etc.).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifications rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certifications' ;
    rdfs:comment 'Comma-separated list of sustainability and ethical certifications the brand has achieved (e.g., B Corp, Fair Trade Certified, GOTS, OEKO-TEX, bluesign).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'Official marketing tagline or slogan associated with the brand, used in advertising and promotional materials.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'Primary age demographic range the brand targets, expressed as a range or category (e.g., 18-35, youth, mature).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'Primary gender demographic the brand targets with its product offerings.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Price and quality positioning tier of the brand within the portfolio, used for merchandising and pricing strategy.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationCountry rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Country' ;
    rdfs:comment 'Three-letter ISO country code representing the primary jurisdiction where the brand trademark is registered.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official trademark registration number issued by the relevant intellectual property office for the brand name and logo.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the brand\'s primary digital presence and e-commerce platform.' ;
    rdfs:domain ind:ApparelFashion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentVersionPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Version Price Book Id' ;
    rdfs:comment 'Reference to the previous version of this price book, enabling version history tracking and audit trails.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:primaryBasePriceBookId rdf:type rdf:Property ;
    rdfs:label 'Primary Base Price Book Id' ;
    rdfs:comment 'Reference to parent or base price book when this price book is derived or inherits pricing rules from another.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:initialMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Percentage' ;
    rdfs:comment 'Initial markup percentage representing the difference between cost and original retail price for items in this price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintainedMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Maintained Markup Percentage' ;
    rdfs:comment 'Maintained markup percentage after markdowns, representing actual margin achieved for items in this price book.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage' ;
    rdfs:comment 'Default markdown percentage applied across items in this price book for promotional or clearance pricing.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Externally-known unique business identifier for the price book used in merchandising systems and reporting.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Description' ;
    rdfs:comment 'Detailed description of the price book purpose, scope, and application within merchandising operations.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookName rdf:type rdf:Property ;
    rdfs:label 'Price Book Name' ;
    rdfs:comment 'Human-readable name of the price book for identification and reporting purposes.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookStatus rdf:type rdf:Property ;
    rdfs:label 'Price Book Status' ;
    rdfs:comment 'Current lifecycle status of the price book indicating its operational state and availability for use.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book indicating its primary merchandising purpose and pricing strategy application.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Boolean flag indicating whether pricing changes in this price book require management approval before activation.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingRule rdf:type rdf:Property ;
