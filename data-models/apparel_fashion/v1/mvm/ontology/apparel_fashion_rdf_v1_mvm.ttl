ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the primary merchandise planner responsible for assortment and allocation planning for this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
