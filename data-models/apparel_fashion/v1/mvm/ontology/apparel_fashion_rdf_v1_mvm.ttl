    rdfs:range ind:Channel .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) used in merchandise allocation strategies when distributing inventory across channels.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Strategy' ;
    rdfs:comment 'Merchandising assortment strategy defining the breadth and depth of product selection offered through this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Value' ;
    rdfs:comment 'Historical average transaction value in the channel\'s currency, used for financial planning and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
