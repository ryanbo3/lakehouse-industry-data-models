ind:planogramName rdf:type rdf:Property ;
    rdfs:label 'Planogram Name' ;
    rdfs:comment 'Human-readable name or title of the planogram describing its purpose or target category.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramType rdf:type rdf:Property ;
    rdfs:label 'Planogram Type' ;
    rdfs:comment 'Classification of the planogram based on merchandising strategy and product lifecycle stage.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedSalesPerSqmUsd rdf:type rdf:Property ;
    rdfs:label 'Projected Sales Per Sqm Usd' ;
    rdfs:comment 'Forecasted sales revenue per square meter in USD expected from this planogram based on historical performance.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:styleTheme rdf:type rdf:Property ;
    rdfs:label 'Style Theme' ;
    rdfs:comment 'Fashion style theme or aesthetic direction of the planogram (e.g., athleisure, minimalist, bold prints, heritage).' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Capacity' ;
    rdfs:comment 'Maximum number of individual product units that can be displayed when the planogram is fully stocked.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wallSpaceLinearM rdf:type rdf:Property ;
    rdfs:label 'Wall Space Linear M' ;
    rdfs:comment 'Total linear wall space in meters required for wall-mounted fixtures in this planogram.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Primary key for the segment_membership association' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Timestamp when the consumer profile was first assigned or qualified into this segment. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'The system or process that triggered the segment assignment. Indicates whether membership was determined via batch evaluation, real-time streaming, or manual override in Adobe Experience Platform or Salesforce CRM. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipScore rdf:type rdf:Property ;
    rdfs:label 'Membership Score' ;
    rdfs:comment 'Numeric score (0.0000 to 1.0000) indicating how strongly the consumer profile qualifies for this segment based on the segment\'s definition criteria. Higher scores indicate stronger qualification. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
