    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oltAssetId rdf:type rdf:Property ;
    rdfs:label 'Olt Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.olt_asset. Business justification: PON-based enterprise fiber services terminate on specific OLT ports. NOC teams require OLT asset reference for capacity management, port provisioning, and troubleshooting. Essential for GPON/XGS-PON b' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OltAsset .

ind:premiseId rdf:type rdf:Property ;
    rdfs:label 'Premise Id' ;
    rdfs:comment 'Foreign key linking to location.premise. Business justification: Managed services delivered to premises require this link for service qualification validation, last-mile circuit assignment, CPE installation tracking, trouble ticket dispatch, and network element ass' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:primaryManagedInventoryCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Managed Inventory Cpe Asset Id' ;
    rdfs:comment 'Reference to the primary Customer Premises Equipment (CPE) device (router, SD-WAN appliance, firewall) deployed at the customer site for this managed service.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:rackSlotPortId rdf:type rdf:Property ;
    rdfs:label 'Rack Slot Port Id' ;
    rdfs:comment 'Foreign key linking to inventory.rack_slot_port. Business justification: Enterprise handoffs and cross-connects require port-level tracking for demarcation point documentation, circuit turn-up, and billing validation. NOC teams use port assignments for service activation, ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RackSlotPort .

ind:sdwanTopologyId rdf:type rdf:Property ;
    rdfs:label 'Sdwan Topology Id' ;
    rdfs:comment 'Foreign key linking to enterprise.sdwan_topology. Business justification: SD-WAN managed service instances are part of a logical SD-WAN topology (hub-and-spoke or full-mesh). This FK links individual managed service instances to their parent topology, enabling topology-leve' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdwanTopology .

ind:bgpAsn rdf:type rdf:Property ;
    rdfs:label 'Bgp Asn' ;
    rdfs:comment 'Border Gateway Protocol (BGP) Autonomous System Number (ASN) assigned to the customer for BGP peering on this managed service.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeWindow rdf:type rdf:Property ;
    rdfs:label 'Change Window' ;
    rdfs:comment 'Approved maintenance window schedule for planned changes, upgrades, and configuration updates to minimize business impact.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitReference rdf:type rdf:Property ;
