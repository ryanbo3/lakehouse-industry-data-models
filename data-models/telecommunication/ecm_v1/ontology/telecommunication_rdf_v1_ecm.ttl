ind:iotSpecialistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Iot Specialist Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: IoT deployments require specialized technical ownership for platform management, SIM lifecycle, APN configuration, and connectivity optimization. Tracks the IoT specialist responsible for device onboa' ;
    rdfs:domain ind:IotDeployment ;
    rdf:type owl:ObjectProperty ;
