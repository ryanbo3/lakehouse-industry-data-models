# --- Attribute Properties ---
ind:abTestId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Id' ;
    rdfs:comment 'Unique identifier for the A/B test or controlled experiment. Primary key for the ab_test product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTest .

ind:experimentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Experiment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: A/B test ownership accountability for experiment design, result interpretation, and rollout decisions in telecommunications product optimization (e.g., pricing tests, UX experiments). Critical for exp' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:segmentDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Segment Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.segment_definition. Business justification: A/B tests target specific customer segments. One test targets ONE primary segment; one segment can be targeted by MANY tests. Currently target_population_segment is a string; normalizing to FK provide' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SegmentDefinition .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'The actual duration of the experiment in days, from start to conclusion. Null for ongoing experiments.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The method used to assign subjects to treatment and control groups: random (simple randomization), stratified (balanced by segment), cluster (group-level assignment), systematic (rule-based), or adaptive (dynamic based on results).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'The statistical method used to analyze experiment results, such as t-test, chi-square, ANOVA, Bayesian analysis, or regression.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessSponsor rdf:type rdf:Property ;
    rdfs:label 'Business Sponsor' ;
    rdfs:comment 'The business stakeholder or executive sponsor who requested the experiment and will act on the results.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the confidence interval for the observed effect size, typically at 95% confidence level.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the confidence interval for the observed effect size, typically at 95% confidence level.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Control Group Definition' ;
    rdfs:comment 'Definition and criteria for the control group receiving the baseline or current experience, used as the comparison benchmark.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when the experiment record was first created in the system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The operational system or data source from which experiment metrics are collected, such as BSS (Business Support Systems), OSS (Operations Support Systems), or CRM (Customer Relationship Management).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'The business decision made based on experiment results: implement (roll out treatment), reject (keep control), iterate (refine and retest), or monitor (continue observation).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date when the business decision was made based on the experiment results.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'URL or reference to detailed experiment documentation, including design specifications, analysis notebooks, and presentation materials.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date when the experiment concluded or is scheduled to conclude. Null for ongoing experiments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact' ;
    rdfs:comment 'The estimated annual revenue impact (positive or negative) if the treatment is fully implemented, based on observed effect size and population size.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicalReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Ethical Review Flag' ;
    rdfs:comment 'Indicates whether the experiment has undergone ethical review to ensure customer privacy, fairness, and transparency.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:experimentCategory rdf:type rdf:Property ;
    rdfs:label 'Experiment Category' ;
    rdfs:comment 'Business category of the experiment: pricing (plan tests), network_config (infrastructure trials), retention (churn reduction offers), ui_ux (interface personalization), product_feature (new capability tests), or marketing (campaign effectiveness).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The business hypothesis being tested, describing the expected outcome and rationale for the experiment.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when the experiment record was last updated or modified.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect' ;
    rdfs:comment 'The smallest effect size that the experiment is designed to detect with statistical confidence, expressed as a percentage or absolute value.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The user ID or name of the person who last modified the experiment record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedEffectSize rdf:type rdf:Property ;
    rdfs:label 'Observed Effect Size' ;
    rdfs:comment 'The actual measured effect size observed in the experiment, expressed as a percentage change or absolute difference in the primary metric.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'The analytics or data science team responsible for designing, executing, and analyzing this experiment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The calculated p-value from the statistical test, indicating the probability of observing the results under the null hypothesis.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'The planned duration of the experiment in days, based on statistical power calculations and business requirements.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The technology platform or tool used to execute the experiment, such as Optimizely, Adobe Target, or custom in-house platform.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The primary Key Performance Indicator (KPI) used to measure experiment success, such as ARPU (Average Revenue Per User), churn rate, NPS (Net Promoter Score), or conversion rate.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the experiment has been reviewed and approved for compliance with applicable regulations such as FCC (Federal Communications Commission) rules, GDPR, or CPNI (Customer Proprietary Network Information) requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultSummary rdf:type rdf:Property ;
    rdfs:label 'Result Summary' ;
    rdfs:comment 'High-level summary of the experiment results, including whether the hypothesis was supported, rejected, or inconclusive.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Rollout Percentage' ;
    rdfs:comment 'If the decision was to implement, the percentage of the population to which the treatment will be rolled out (0-100).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSizeControl rdf:type rdf:Property ;
    rdfs:label 'Sample Size Control' ;
    rdfs:comment 'The number of subjects (customers, subscribers, or sessions) allocated to the control group.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeTreatment rdf:type rdf:Property ;
    rdfs:label 'Sample Size Treatment' ;
    rdfs:comment 'The number of subjects (customers, subscribers, or sessions) allocated to the treatment group(s).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetrics rdf:type rdf:Property ;
    rdfs:label 'Secondary Metrics' ;
    rdfs:comment 'Comma-separated list of secondary KPIs monitored during the experiment to assess broader impact, such as CSAT (Customer Satisfaction Score), MRR (Monthly Recurring Revenue), or network QoS (Quality of Service) metrics.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when the experiment was launched and data collection began.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statisticalPower rdf:type rdf:Property ;
    rdfs:label 'Statistical Power' ;
    rdfs:comment 'The probability of detecting a true effect if one exists, typically set at 0.80 or 0.90, representing 1 minus the Type II error rate.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalSignificanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Threshold' ;
    rdfs:comment 'The p-value threshold used to determine statistical significance, typically 0.05 or 0.01, representing the acceptable Type I error rate.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Unique business code or identifier for the experiment, used for external reference and integration with analytics platforms.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name of the A/B test or experiment, used for identification and reporting purposes.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the experiment: design (planning), approved (ready to launch), running (active), paused (temporarily stopped), concluded (completed), archived (historical), or cancelled (terminated early). [ENUM-REF-CANDIDATE: design|approved|running|paused|concluded|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of experiment design used: A/B (two variants), multivariate (multiple factors), holdout (control group only), sequential (adaptive), factorial (combination testing), or bandit (dynamic allocation).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentGroupDefinition rdf:type rdf:Property ;
    rdfs:label 'Treatment Group Definition' ;
    rdfs:comment 'Definition and criteria for the treatment group(s) receiving the experimental variant(s), including allocation rules and variant descriptions.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of the experiment design, incremented when the experiment is modified or re-run with different parameters.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user ID or name of the person who created the experiment record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Assignment Id' ;
    rdfs:comment 'Unique identifier for the A/B test assignment record. Primary key for the assignment entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestAssignment .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the billing account assigned to this experiment variant. Used when assignment is at account level rather than individual subscriber level.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Reference to the individual subscriber assigned to this experiment variant. Identifies the telecommunications customer participating in the test.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:assignmentBatchCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Batch Code' ;
    rdfs:comment 'Identifier for the batch or cohort of assignments created together. Used to track assignment waves and support batch-level quality checks.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentHashSeed rdf:type rdf:Property ;
    rdfs:label 'Assignment Hash Seed' ;
    rdfs:comment 'The seed value or salt used in hash-based random assignment algorithms. Enables reproducibility of assignment logic and verification of assignment integrity.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The methodology used to assign the subject to the variant. Random hash uses deterministic hashing for reproducibility, stratified random ensures balanced representation across segments, propensity score uses ML-based matching, manual indicates deliberate assignment, geographic cluster assigns by location, and temporal cohort assigns by time period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The name or identifier of the system that generated this assignment record. Examples include experimentation platform, CRM system, or custom assignment service.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the assignment. Active indicates ongoing participation, completed indicates experiment concluded, withdrawn indicates subject opted out, excluded indicates post-assignment exclusion criteria met, invalidated indicates assignment error or data quality issue.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The precise date and time when the subscriber or account was assigned to the experimental variant. Immutable once set to preserve experimental integrity and enable intent-to-treat analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentVariant rdf:type rdf:Property ;
    rdfs:label 'Assignment Variant' ;
    rdfs:comment 'The experimental variant or treatment group to which the subscriber or account has been assigned. Control represents the baseline, treatment groups represent experimental conditions, and holdout represents subjects excluded from exposure.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentWeight rdf:type rdf:Property ;
    rdfs:label 'Assignment Weight' ;
    rdfs:comment 'Statistical weight applied to this assignment for weighted analysis. Used in inverse propensity weighting, stratification weighting, or other variance reduction techniques. Default value is 1.0 for equal weighting.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlGroupFlag rdf:type rdf:Property ;
    rdfs:label 'Control Group Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment is to the control group (True) or a treatment group (False). Simplifies filtering for control vs treatment comparisons.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Boolean indicator of whether this assignment record has passed all data quality validation rules. False indicates potential data quality issues that may warrant exclusion from analysis.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityNotes rdf:type rdf:Property ;
    rdfs:label 'Data Quality Notes' ;
    rdfs:comment 'Free-text notes documenting any data quality issues, anomalies, or special conditions associated with this assignment. Used for audit trail and analysis exclusion decisions.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The primary device type or Customer Premises Equipment (CPE) associated with the subscriber at the time of assignment. Examples include smartphone model, modem type, or set-top box model. Used for device-specific treatment effects analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Free-text explanation of why the subject was excluded or withdrawn from the experiment after initial assignment. Examples include account closure, service suspension, data quality issues, or violation of inclusion criteria.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exclusion Timestamp' ;
    rdfs:comment 'The date and time when the subject was excluded or withdrawn from the experiment. Used to calculate effective exposure duration.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:experimentEndDate rdf:type rdf:Property ;
    rdfs:label 'Experiment End Date' ;
    rdfs:comment 'The calendar date when the experiment period ends for this assignment. May be null for ongoing experiments. Used to define the analysis window and determine completion status.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:experimentStartDate rdf:type rdf:Property ;
    rdfs:label 'Experiment Start Date' ;
    rdfs:comment 'The calendar date when the experiment period begins for this assignment. Used to define the analysis window and calculate time-in-experiment metrics.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exposureConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Exposure Confirmed Flag' ;
    rdfs:comment 'Boolean indicator of whether the subject was actually exposed to the assigned treatment. True indicates confirmed exposure, False indicates assignment without exposure. Enables as-treated analysis in addition to intent-to-treat analysis.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exposureCount rdf:type rdf:Property ;
    rdfs:label 'Exposure Count' ;
    rdfs:comment 'The cumulative number of times the subject has been exposed to the treatment condition during the experiment period. Supports dose-response analysis.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstExposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Exposure Timestamp' ;
    rdfs:comment 'The date and time when the subject was first exposed to the assigned treatment condition. May differ from assignment timestamp if there is a delay between assignment and actual exposure.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'The geographic market, region, or service area in which the subscriber or account is located at the time of assignment. Used for geographic stratification and subgroup analysis.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The user identifier or system process that last modified this assignment record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preExperimentArpu rdf:type rdf:Property ;
    rdfs:label 'Pre Experiment Arpu' ;
    rdfs:comment 'The average monthly revenue per user for this subscriber or account in the period immediately preceding experiment assignment. Used as a covariate for difference-in-differences analysis and to verify randomization balance.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preExperimentChurnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Pre Experiment Churn Risk Score' ;
    rdfs:comment 'The predicted churn probability (0.0000 to 1.0000) for this subscriber or account at the time of assignment, based on pre-experiment behavior. Used to verify balance across treatment arms and as a covariate in outcome analysis.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preExperimentTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Pre Experiment Tenure Months' ;
    rdfs:comment 'The number of complete months the subscriber or account has been active with the telecommunications provider at the time of assignment. Used as a covariate to control for customer maturity effects.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:propensityScore rdf:type rdf:Property ;
    rdfs:label 'Propensity Score' ;
    rdfs:comment 'The calculated propensity score (0.0000 to 1.0000) representing the predicted likelihood of treatment assignment based on pre-treatment covariates. Used in propensity score matching and weighting for causal inference.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePlanCode rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Code' ;
    rdfs:comment 'The rate plan or pricing plan code associated with the subscriber or account at the time of assignment. Used to control for baseline pricing differences and analyze treatment effects by plan type.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'The primary telecommunications service type associated with the subscriber or account at the time of assignment. Used for service-specific subgroup analysis. [ENUM-REF-CANDIDATE: mobile|fixed_broadband|fiber|iptv|voip|enterprise|converged — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationSegment rdf:type rdf:Property ;
    rdfs:label 'Stratification Segment' ;
    rdfs:comment 'The stratification segment or cohort to which the subject belongs for stratified randomization. Examples include ARPU tier, tenure band, geographic region, or device type to ensure balanced representation across key dimensions.' ;
    rdfs:domain ind:AbTestAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalDatasetId rdf:type rdf:Property ;
    rdfs:label 'Analytical Dataset Id' ;
    rdfs:comment 'Unique identifier for the analytical dataset record within the Databricks Lakehouse registry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalDataset .

ind:analyticalSubjectAreaId rdf:type rdf:Property ;
    rdfs:label 'Analytical Subject Area Id' ;
    rdfs:comment 'Foreign key linking to analytics.analytical_subject_area. Business justification: Analytical datasets belong to analytical subject areas (data marts). One dataset belongs to ONE subject area; one subject area contains MANY datasets. This establishes the organizational ownership and' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalSubjectArea .

ind:datasetOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dataset Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Dataset ownership for data product accountability, SLA management, and access governance in telecommunications analytics platforms. Owner responsible for dataset quality, documentation, and consumer s' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fiberCableId rdf:type rdf:Property ;
    rdfs:label 'Fiber Cable Id' ;
    rdfs:comment 'Foreign key linking to inventory.fiber_cable. Business justification: Fiber infrastructure data is foundational for outside plant analytics, route diversity analysis, capital planning datasets, and fiber-to-the-home expansion modeling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiberCable .

ind:inventorySpectrumAllocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Spectrum Allocation Id' ;
    rdfs:comment 'Foreign key linking to inventory.spectrum_allocation. Business justification: Spectrum holdings are critical dimension in network capacity datasets for coverage analysis, 5G deployment planning, and regulatory compliance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpectrumAllocation .

ind:ipAddressPoolId rdf:type rdf:Property ;
    rdfs:label 'Ip Address Pool Id' ;
    rdfs:comment 'Foreign key linking to inventory.ip_address_pool. Business justification: IP resource inventory is dimension in network analytics for address space utilization tracking, IPv6 adoption analysis, and CGNAT capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:networkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: Equipment inventory is a core dimension in analytical datasets for network capacity analysis, vendor performance benchmarking, and technology refresh planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:ontAssetId rdf:type rdf:Property ;
    rdfs:label 'Ont Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.ont_asset. Business justification: ONT inventory is key dimension in fiber subscriber analytics for technology adoption tracking, service tier analysis, and GPON-to-XGS-PON migration planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:serviceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Analytical datasets for territory-specific analysis (market studies, regional forecasting, competitive analysis) are scoped to territories. Supports decentralized analytics and regional data product o' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Foreign key linking to inventory.spare_part. Business justification: Spare parts inventory is dimension in maintenance analytics for stock optimization, supplier performance analysis, equipment reliability studies, and maintenance cost allocation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:accessClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Access Classification Level' ;
    rdfs:comment 'Data classification level governing access controls and usage restrictions: public (unrestricted), internal (employees only), confidential (business-sensitive), or restricted (PII/PHI/PCI, requires special authorization).' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the analytical dataset received formal approval for production deployment, establishing the baseline for version control and change management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval state of the analytical dataset in the data governance workflow: draft (under development), pending_review (awaiting steward approval), approved (production-ready), or rejected (does not meet quality standards).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name of the data steward, governance committee member, or technical authority who approved this analytical dataset for production use.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPurpose rdf:type rdf:Property ;
    rdfs:label 'Business Purpose' ;
    rdfs:comment 'Detailed description of the business use case, analytical objective, or decision-support function this dataset enables (e.g., \'Predict customer churn risk for retention campaigns\', \'Aggregate network KPIs for NOC dashboards\', \'Calculate ARPU trends by customer segment\').' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:columnCount rdf:type rdf:Property ;
    rdfs:label 'Column Count' ;
    rdfs:comment 'Total number of columns (attributes/features) in the analytical dataset schema, used for schema complexity assessment and feature engineering tracking.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerCount rdf:type rdf:Property ;
    rdfs:label 'Consumer Count' ;
    rdfs:comment 'Number of distinct downstream consumers (users, teams, applications, dashboards, ML models) actively using this analytical dataset, indicating business criticality and impact radius.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containsPiiFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Pii Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the dataset contains personally identifiable information subject to GDPR, CCPA, or other privacy regulations, triggering additional access controls and audit requirements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataFreshnessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Timestamp' ;
    rdfs:comment 'Timestamp indicating when the dataset was last refreshed or updated with new data, critical for assessing data currency and SLA compliance for time-sensitive analytics.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name of the data steward or governance representative responsible for ensuring this dataset complies with data quality standards, retention policies, and regulatory requirements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetCategory rdf:type rdf:Property ;
    rdfs:label 'Dataset Category' ;
    rdfs:comment 'Business domain or analytical category this dataset supports: network analytics (RAN, transport, core performance), customer analytics (segmentation, behavior, CLTV), revenue analytics (ARPU, MRR, billing trends), churn prediction, usage analytics (CDR aggregations), or quality analytics (QoS, SLA compliance).' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetCode rdf:type rdf:Property ;
    rdfs:label 'Dataset Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the analytical dataset for reference in data catalogs, lineage tools, and analytics platforms.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetName rdf:type rdf:Property ;
    rdfs:label 'Dataset Name' ;
    rdfs:comment 'Human-readable name of the analytical dataset, following organizational naming conventions for feature tables, training datasets, scoring datasets, or reporting datasets.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetSizeGb rdf:type rdf:Property ;
    rdfs:label 'Dataset Size Gb' ;
    rdfs:comment 'Total storage size of the analytical dataset in gigabytes, used for capacity planning, cost allocation, and performance optimization.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:datasetType rdf:type rdf:Property ;
    rdfs:label 'Dataset Type' ;
    rdfs:comment 'Classification of the analytical dataset by its primary purpose: training (ML model training), scoring (inference/prediction), reporting (BI dashboards), feature_table (reusable feature store), ad_hoc (one-time analysis), or exploratory (data discovery).' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deltaTablePath rdf:type rdf:Property ;
    rdfs:label 'Delta Table Path' ;
    rdfs:comment 'Fully qualified path to the Delta Lake table in the Databricks Lakehouse (e.g., \'dbfs:/mnt/silver/analytics/customer_churn_features\'), enabling direct access for queries and pipelines.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when the analytical dataset is scheduled for deprecation or retirement, after which it will no longer be maintained or supported (nullable for active datasets with no planned end date).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when the analytical dataset became available for consumption, marking the beginning of its operational lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:featureCount rdf:type rdf:Property ;
    rdfs:label 'Feature Count' ;
    rdfs:comment 'Number of engineered features or derived attributes in the dataset specifically designed for machine learning model training or scoring, distinct from raw operational columns.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grainDescription rdf:type rdf:Property ;
    rdfs:label 'Grain Description' ;
    rdfs:comment 'Textual description of the dataset grain or level of detail, specifying what each row represents (e.g., \'One row per customer per month\', \'One row per cell site per hour\', \'One row per subscriber per day with aggregated CDR metrics\').' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSchemaChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Schema Change Date' ;
    rdfs:comment 'Date of the most recent schema modification (column addition, removal, or type change), used to track schema evolution and assess impact on downstream consumers.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the analytical dataset: active (in production use), deprecated (scheduled for retirement), archived (historical reference only), in_development (under construction), retired (no longer available), or suspended (temporarily unavailable).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partitionKey rdf:type rdf:Property ;
    rdfs:label 'Partition Key' ;
    rdfs:comment 'Column name(s) used for Delta Lake table partitioning (e.g., \'business_date\', \'region_code\'), optimizing query performance and data management operations.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformLayer rdf:type rdf:Property ;
    rdfs:label 'Platform Layer' ;
    rdfs:comment 'Databricks Lakehouse medallion architecture layer where the dataset resides: silver (cleansed, conformed, joined data) or gold (business-level aggregates, curated for analytics and ML).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryConsumerGroup rdf:type rdf:Property ;
    rdfs:label 'Primary Consumer Group' ;
    rdfs:comment 'Name of the primary business unit, analytics team, or application consuming this dataset (e.g., \'Network Operations Center\', \'Customer Retention Team\', \'Revenue Assurance\'), used for prioritization and communication.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Primary Source System' ;
    rdfs:comment 'Name of the primary operational system of record providing the majority of data for this dataset (e.g., \'Amdocs Revenue Management\', \'Nokia NetAct\', \'Salesforce CRM\'), used for data stewardship and issue escalation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshSchedule rdf:type rdf:Property ;
    rdfs:label 'Refresh Schedule' ;
    rdfs:comment 'Frequency at which the analytical dataset is refreshed: real_time (streaming/continuous), hourly, daily, weekly, monthly, or on_demand (manual/ad-hoc refresh).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scope' ;
    rdfs:comment 'Comma-separated list of applicable regulatory frameworks or compliance requirements this dataset must adhere to (e.g., \'GDPR, FCC, 3GPP, TM Forum SID\'), guiding retention, access, and audit policies.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Number of days the analytical dataset is retained before archival or deletion, driven by regulatory requirements, storage cost optimization, and business value decay.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rowCount rdf:type rdf:Property ;
    rdfs:label 'Row Count' ;
    rdfs:comment 'Total number of rows (records) in the analytical dataset as of the last refresh or metadata update, used for dataset size monitoring and capacity planning.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemaVersion rdf:type rdf:Property ;
    rdfs:label 'Schema Version' ;
    rdfs:comment 'Version identifier for the dataset schema (e.g., \'v1.2.3\', \'2024-01\'), tracking schema evolution and ensuring compatibility with downstream consumers.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAvailabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Availability Target Pct' ;
    rdfs:comment 'Target availability percentage for the analytical dataset (e.g., 99.50), defining the uptime commitment for downstream consumers and triggering alerts when breached.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaRefreshTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Refresh Target Minutes' ;
    rdfs:comment 'Maximum allowable time in minutes between dataset refresh completion and data availability to consumers, ensuring timely delivery for time-sensitive analytics and reporting.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceLineageSummary rdf:type rdf:Property ;
    rdfs:label 'Source Lineage Summary' ;
    rdfs:comment 'High-level summary of upstream data sources and transformations that produce this dataset (e.g., \'Derived from bronze.cdr_events, bronze.customer_master, silver.network_kpi via aggregation pipeline job_123\'), supporting impact analysis and data governance.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCount rdf:type rdf:Property ;
    rdfs:label 'Source System Count' ;
    rdfs:comment 'Number of distinct source systems or upstream datasets contributing data to this analytical dataset, indicating integration complexity.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of user-defined tags or labels for dataset categorization, search, and filtering (e.g., \'churn, customer, ml_ready, high_priority\'), supporting data discovery and catalog organization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Free-text field capturing important usage guidance, known limitations, data quality caveats, or special handling instructions for consumers of this analytical dataset.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalModelRegistryId rdf:type rdf:Property ;
    rdfs:label 'Analytical Model Registry Id' ;
    rdfs:comment 'Unique identifier for the analytical model registry entry. Primary key for the analytical model registry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalModelRegistry .

ind:modelOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Model Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: ML model governance in telecommunications requires formal employee ownership for accountability, access control, model risk management, and regulatory compliance (e.g., AI/ML model inventory requireme' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:algorithmName rdf:type rdf:Property ;
    rdfs:label 'Algorithm Name' ;
    rdfs:comment 'Specific algorithm or technique used to build the model. Examples include Random Forest, XGBoost, LSTM, Logistic Regression, K-Means.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Business Impact Description' ;
    rdfs:comment 'Description of the expected or realized business impact of the model. Examples include revenue uplift, cost reduction, churn reduction, or operational efficiency gains.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUseCase rdf:type rdf:Property ;
    rdfs:label 'Business Use Case' ;
    rdfs:comment 'Description of the business problem or opportunity this model addresses. Examples include churn prediction, network anomaly detection, ARPU forecasting, demand planning, customer segmentation, fraud detection, or service quality prediction.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle state of the model in the deployment pipeline. Indicates whether the model is in development, testing, production use, or has been retired.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explainabilityMethod rdf:type rdf:Property ;
    rdfs:label 'Explainability Method' ;
    rdfs:comment 'Technique or method used to explain model predictions. Examples include SHAP, LIME, feature importance, or partial dependence plots.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairnessAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fairness Assessment Status' ;
    rdfs:comment 'Status of fairness and bias assessment for the model. Indicates whether the model has been evaluated for discriminatory outcomes across protected groups.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureList rdf:type rdf:Property ;
    rdfs:label 'Feature List' ;
    rdfs:comment 'Comma-separated or structured list of features (input variables) used by the model. Documents the feature engineering and selection decisions.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:framework rdf:type rdf:Property ;
    rdfs:label 'Framework' ;
    rdfs:comment 'Software framework or library used to develop and train the model. Examples include TensorFlow, PyTorch, Scikit-learn, Spark MLlib, H2O.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hyperparameters rdf:type rdf:Property ;
    rdfs:label 'Hyperparameters' ;
    rdfs:comment 'JSON or structured representation of hyperparameters used to configure the model. Documents tuning decisions and model configuration.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Inference Latency Ms' ;
    rdfs:comment 'Average time in milliseconds required for the model to generate a prediction. Key performance indicator for real-time serving.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDeploymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Deployment Date' ;
    rdfs:comment 'Date when the model was last deployed to a serving environment. Tracks deployment history and release cadence.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date when the model was last trained or retrained. Tracks model freshness and retraining cadence.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Model Artifact Path' ;
    rdfs:comment 'Storage path or URI where the serialized model artifact is stored. Enables model retrieval and deployment.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelCategory rdf:type rdf:Property ;
    rdfs:label 'Model Category' ;
    rdfs:comment 'Learning paradigm category of the model. Distinguishes the training methodology and data requirements.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Unique business code or identifier for the model used across systems and documentation. Externally-known identifier for model reference.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Model Documentation Url' ;
    rdfs:comment 'URL or link to detailed model documentation, including methodology, assumptions, limitations, and usage guidelines.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Model Expiry Date' ;
    rdfs:comment 'Date when the model is scheduled to be retired or replaced. Supports planned model lifecycle management.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name of the analytical or machine learning model. Serves as the primary business identifier for the model.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSizeMb rdf:type rdf:Property ;
    rdfs:label 'Model Size Mb' ;
    rdfs:comment 'Size of the serialized model artifact in megabytes. Impacts storage, deployment, and inference latency considerations.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the analytical model by its algorithmic approach. Defines the fundamental machine learning paradigm used.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier for the model. Supports model versioning and lineage tracking across iterations and retraining cycles.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Monitoring Enabled' ;
    rdfs:comment 'Indicates whether automated monitoring is enabled for the model. Monitoring tracks performance drift, data drift, and prediction quality.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceMetricAccuracy rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Accuracy' ;
    rdfs:comment 'Overall accuracy metric representing the proportion of correct predictions. Applicable to classification models.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricAuc rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Auc' ;
    rdfs:comment 'Area Under the Receiver Operating Characteristic Curve metric for classification models. Measures the models ability to distinguish between classes.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricF1 rdf:type rdf:Property ;
    rdfs:label 'Performance Metric F1' ;
    rdfs:comment 'F1 Score metric for classification models. Harmonic mean of precision and recall, balancing false positives and false negatives.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricMae rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Mae' ;
    rdfs:comment 'Mean Absolute Error metric for regression models. Measures the average absolute difference between predicted and actual values.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricPrecision rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Precision' ;
    rdfs:comment 'Precision metric for classification models. Measures the proportion of positive predictions that are actually correct.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricRecall rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Recall' ;
    rdfs:comment 'Recall (sensitivity) metric for classification models. Measures the proportion of actual positives that are correctly identified.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetricRmse rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Rmse' ;
    rdfs:comment 'Root Mean Squared Error metric for regression models. Measures the average magnitude of prediction errors.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk level associated with the model based on business impact, regulatory requirements, and potential for harm. Drives governance and monitoring requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingEndpoint rdf:type rdf:Property ;
    rdfs:label 'Serving Endpoint' ;
    rdfs:comment 'URL or API endpoint where the model is deployed and accessible for inference requests. Enables real-time or batch scoring.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingPlatform rdf:type rdf:Property ;
    rdfs:label 'Serving Platform' ;
    rdfs:comment 'Platform or infrastructure where the model is deployed for serving. Examples include Databricks Model Serving, SageMaker, Azure ML, Kubernetes.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVariable rdf:type rdf:Property ;
    rdfs:label 'Target Variable' ;
    rdfs:comment 'The dependent variable or outcome that the model predicts or classifies. Defines the models objective.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDatasetSize rdf:type rdf:Property ;
    rdfs:label 'Test Dataset Size' ;
    rdfs:comment 'Number of records or observations used to test the model after training. Provides unbiased evaluation of final model performance.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDataLineage rdf:type rdf:Property ;
    rdfs:label 'Training Data Lineage' ;
    rdfs:comment 'Description of source data domains and data products used to train the model. Captures upstream data dependencies for lineage tracking and impact analysis.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDatasetSize rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Size' ;
    rdfs:comment 'Number of records or observations used to train the model. Indicates the scale of training data.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when the model registry entry was last updated. Tracks changes to model metadata, version, or deployment status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationDatasetSize rdf:type rdf:Property ;
    rdfs:label 'Validation Dataset Size' ;
    rdfs:comment 'Number of records or observations used to validate the model during training. Used for hyperparameter tuning and model selection.' ;
    rdfs:domain ind:AnalyticalModelRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataProductOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Data Product Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Data product ownership is foundational to data mesh operating models in telecommunications. Owner accountability for SLA compliance, consumer support, and product roadmap decisions. Denormalized name/' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataClassificationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Classification Level' ;
    rdfs:comment 'The highest data classification level of any data element within this subject area (public, internal, confidential, restricted), determining access controls and handling requirements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRuleCount rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rule Count' ;
    rdfs:comment 'The number of data quality rules, validation checks, or business rules applied to data within this subject area.' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'The number of days that data in this analytical subject area is retained before archival or deletion, driven by regulatory, compliance, or business requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionCount rdf:type rdf:Property ;
    rdfs:label 'Dimension Count' ;
    rdfs:comment 'The number of analytical dimensions (e.g., time, geography, product, customer segment) associated with this subject area.' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:factTableCount rdf:type rdf:Property ;
    rdfs:label 'Fact Table Count' ;
    rdfs:comment 'The number of fact tables or measurement tables included within this analytical subject area.' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiFamilyCount rdf:type rdf:Property ;
    rdfs:label 'Kpi Family Count' ;
    rdfs:comment 'The number of distinct KPI families or metric groups associated with this analytical subject area.' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The timestamp of the most recent data refresh or load operation for this analytical subject area.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional comments, special instructions, or contextual information about this analytical subject area.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDomain rdf:type rdf:Property ;
    rdfs:label 'Owning Domain' ;
    rdfs:comment 'The primary business domain responsible for this analytical subject area (e.g., Customer, Network, Billing, Product, Order, Service, Workforce, Partner, Usage, Revenue Assurance, Inventory, Interconnect, Content, Compliance, Enterprise). [ENUM-REF-CANDIDATE: customer|network|billing|product|order|service|workforce|partner|usage|revenue_assurance|inventory|interconnect|content|compliance|enterprise — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGrain rdf:type rdf:Property ;
    rdfs:label 'Primary Grain' ;
    rdfs:comment 'The fundamental level of detail or granularity at which data is stored in this subject area (e.g., per customer per day, per cell site per hour, per invoice line item).' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'The frequency at which data in this analytical subject area is refreshed or updated (real-time, near real-time, hourly, daily, weekly, monthly, on-demand). [ENUM-REF-CANDIDATE: real_time|near_real_time|hourly|daily|weekly|monthly|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAreaCode rdf:type rdf:Property ;
    rdfs:label 'Subject Area Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the subject area for system integration and reporting (e.g., NET_ANLYT, CUST_ANLYT, REV_ANLYT).' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAreaName rdf:type rdf:Property ;
    rdfs:label 'Subject Area Name' ;
    rdfs:comment 'The business-friendly name of the analytical subject area (e.g., Network Analytics, Customer Analytics, Revenue Analytics, Usage Analytics, Workforce Analytics).' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAreaType rdf:type rdf:Property ;
    rdfs:label 'Subject Area Type' ;
    rdfs:comment 'Classification of the analytical subject area based on its primary business purpose (operational, strategic, regulatory, customer-facing, network performance, financial).' ;
    rdfs:domain ind:AnalyticalSubjectArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biReportDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Bi Report Definition Id' ;
    rdfs:comment 'Unique identifier for the BI report definition record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiReportDefinition .

ind:networkQosProfileId rdf:type rdf:Property ;
    rdfs:label 'Network Qos Profile Id' ;
    rdfs:comment 'Foreign key linking to network.qos_profile. Business justification: QoS performance reports and SLA dashboards reference specific QoS profiles (e.g., GBR bearers, QCI classes) for service quality analysis. Regulatory reporting and enterprise SLA validation require rep' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkQosProfile .

ind:reportOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Report Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: BI report governance requires formal employee ownership for access management, report certification workflows, decommissioning decisions, and ownership transfer during employee transitions. Denormaliz' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'Data classification level determining who can access the report based on sensitivity of underlying data.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLoadTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Load Time Seconds' ;
    rdfs:comment 'Average time in seconds for the report to load and render, used for performance monitoring.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the report was last certified by the data governance team.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Flag' ;
    rdfs:comment 'Indicates whether the report has been certified by data governance as meeting quality and accuracy standards.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Specific compliance framework or regulation that this report addresses (e.g., SOX, GDPR, FCC reporting).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'Full name of the data steward responsible for data quality and governance for this report.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Decommission Candidate Flag' ;
    rdfs:comment 'Indicates whether the report has been flagged as a candidate for decommissioning due to low usage or redundancy.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business justification for why the report is being or was decommissioned.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportFormats rdf:type rdf:Property ;
    rdfs:label 'Export Formats' ;
    rdfs:comment 'Comma-separated list of supported export formats (e.g., CSV, XLSX, PDF, PNG).' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterCount rdf:type rdf:Property ;
    rdfs:label 'Filter Count' ;
    rdfs:comment 'Number of user-configurable filters available in the report interface.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAnalysisNotes rdf:type rdf:Property ;
    rdfs:label 'Impact Analysis Notes' ;
    rdfs:comment 'Free-text notes documenting upstream data dependencies and potential impact of source data changes on this report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCount rdf:type rdf:Property ;
    rdfs:label 'Kpi Count' ;
    rdfs:comment 'Number of distinct KPIs or metrics displayed in the report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next report data refresh execution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The business unit or department that owns and is responsible for the report content and governance.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDataSource rdf:type rdf:Property ;
    rdfs:label 'Primary Data Source' ;
    rdfs:comment 'The main data product or table that serves as the primary source for this report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationPlatform rdf:type rdf:Property ;
    rdfs:label 'Publication Platform' ;
    rdfs:comment 'The BI platform or tool where the report is published and made available to users.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshTime rdf:type rdf:Property ;
    rdfs:label 'Refresh Time' ;
    rdfs:comment 'Scheduled time of day when the report refresh job executes, in HH:MM format (24-hour).' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory authority or governing body that requires this report, if applicable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this report is required for regulatory compliance or external reporting obligations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportCategory rdf:type rdf:Property ;
    rdfs:label 'Report Category' ;
    rdfs:comment 'Primary subject area or domain that the report addresses, aligned with enterprise data domains.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportCode rdf:type rdf:Property ;
    rdfs:label 'Report Code' ;
    rdfs:comment 'Unique business identifier code for the report, used for external references and API calls.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDescription rdf:type rdf:Property ;
    rdfs:label 'Report Description' ;
    rdfs:comment 'Detailed description of the report purpose, business questions answered, and intended audience.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportName rdf:type rdf:Property ;
    rdfs:label 'Report Name' ;
    rdfs:comment 'Human-readable name of the BI report or dashboard as displayed to end users.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the report definition in the BI content governance process.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the report by its primary business function and usage pattern.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Direct URL link to access the published report in the BI platform.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Semantic version number of the report definition following major.minor.patch convention.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days that historical versions of this report must be retained for audit and compliance purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryDataSources rdf:type rdf:Property ;
    rdfs:label 'Secondary Data Sources' ;
    rdfs:comment 'Comma-separated list of additional data products or tables consumed by this report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLoadTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Load Time Seconds' ;
    rdfs:comment 'Maximum acceptable load time in seconds as defined by the SLA for this report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsDrillDown rdf:type rdf:Property ;
    rdfs:label 'Supports Drill Down' ;
    rdfs:comment 'Indicates whether the report supports drill-down navigation to more detailed data views.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsExport rdf:type rdf:Property ;
    rdfs:label 'Supports Export' ;
    rdfs:comment 'Indicates whether users can export report data to external formats such as CSV, Excel, or PDF.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uniqueUserCountLast30Days rdf:type rdf:Property ;
    rdfs:label 'Unique User Count Last 30 Days' ;
    rdfs:comment 'Number of distinct users who accessed the report in the last 30 days.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageCountLast30Days rdf:type rdf:Property ;
    rdfs:label 'Usage Count Last 30 Days' ;
    rdfs:comment 'Number of times the report was accessed or viewed in the last 30 days, used for decommissioning decisions.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visualizationCount rdf:type rdf:Property ;
    rdfs:label 'Visualization Count' ;
    rdfs:comment 'Number of distinct visualizations (charts, tables, graphs) included in the report.' ;
    rdfs:domain ind:BiReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAnalyticsKpiId rdf:type rdf:Property ;
    rdfs:label 'Customer Analytics Kpi Id' ;
    rdfs:comment 'Unique identifier for the customer analytics KPI measurement record. Primary key for the customer analytics KPI fact table.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAnalyticsKpi .

ind:inventoryCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: CPE-related customer experience KPIs (device uptime, WiFi performance, firmware currency) drive satisfaction analysis, support optimization, and targeted device upgrade campaigns.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:kpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Id' ;
    rdfs:comment 'Foreign key reference to the KPI catalog. Identifies the specific KPI being measured (e.g., ARPU, churn rate, NPS, CSAT, MAU, CLV).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:pipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Id' ;
    rdfs:comment 'The unique identifier of the data pipeline execution or ETL job that generated this KPI measurement. Enables traceability and lineage tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRun .

ind:simStockId rdf:type rdf:Property ;
    rdfs:label 'Sim Stock Id' ;
    rdfs:comment 'Foreign key linking to inventory.sim_stock. Business justification: SIM activation velocity and provisioning time KPIs are tracked per inventory batch for fulfillment efficiency analysis and supplier performance management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SimStock .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'The severity level of the alert when alert_threshold_breached is true. Indicates the urgency of response required for out-of-threshold KPI values.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Breached' ;
    rdfs:comment 'Boolean flag indicating whether this KPI measurement has breached a predefined alert threshold, triggering operational or management attention.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'The source or provider of benchmark data when is_benchmark is true (e.g., GSMA Intelligence, Gartner, internal historical baseline). Null for non-benchmark measurements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'The business calendar date for which this KPI measurement is reported. May differ from measurement_date in cases of late-arriving data or retroactive adjustments.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The mathematical or statistical method used to derive this KPI value from source data. Ensures transparency and reproducibility of KPI calculations. [ENUM-REF-CANDIDATE: sum|average|median|count|ratio|percentage|weighted_average — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The sales or distribution channel through which the customers measured by this KPI were acquired or are served. Enables channel performance analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A numeric score (0-100) representing the completeness and reliability of the source data used to calculate this KPI measurement. Lower scores indicate potential data quality issues affecting KPI accuracy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period identifier (e.g., FY2024-Q2, 2024-06) to which this KPI measurement belongs. Used for financial reporting alignment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBenchmark rdf:type rdf:Property ;
    rdfs:label 'Is Benchmark' ;
    rdfs:comment 'Boolean flag indicating whether this KPI measurement represents a benchmark or baseline value used for comparative analysis (e.g., industry benchmark, historical baseline).' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Kpi Unit Of Measure' ;
    rdfs:comment 'The unit in which the KPI value is expressed. Enables correct interpretation and display of the measured value.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiValue rdf:type rdf:Property ;
    rdfs:label 'Kpi Value' ;
    rdfs:comment 'The measured numeric value of the KPI for this observation period. Interpretation depends on the KPI definition (e.g., currency for ARPU, percentage for churn rate, count for MAU, score for NPS).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The calendar date for which this KPI measurement applies. Used for day-level reporting and time-series analysis.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The cadence at which this KPI is measured and reported. Defines the periodicity of the time-series data.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementGrain rdf:type rdf:Property ;
    rdfs:label 'Measurement Grain' ;
    rdfs:comment 'The level of aggregation or granularity at which this KPI measurement is captured. Indicates whether this is a subscriber-level, account-level, segment-level, or higher-level aggregation.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time when this KPI measurement was captured or calculated. Represents the business event time for the KPI observation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'The KPI value from the previous comparable measurement period (e.g., prior month, prior quarter, year-ago). Used for period-over-period variance analysis.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'The telecommunications product line or service category to which this KPI measurement applies. Enables product-specific performance tracking. [ENUM-REF-CANDIDATE: mobile|fixed_broadband|fiber|enterprise|iptv|ott|iot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'The geographic region or market code for which this KPI is measured. Enables regional performance comparison and market-specific analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of underlying records, subscribers, or transactions used to calculate this KPI measurement. Provides context for statistical significance and confidence intervals.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The name or identifier of the operational system or data pipeline that provided the source data for this KPI calculation (e.g., Amdocs, Salesforce CRM, Netcracker).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The planned or target value for this KPI in this measurement period, as defined by business planning or SLA commitments. Used for target vs actual variance analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Variance Amount' ;
    rdfs:comment 'The absolute difference between the measured KPI value and the target value (kpi_value minus target_value). Indicates performance against plan.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Variance Percentage' ;
    rdfs:comment 'The percentage variance from target, calculated as ((kpi_value - target_value) / target_value) * 100. Null if target value is zero.' ;
    rdfs:domain ind:CustomerAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The absolute difference between the current KPI value and the prior period value (kpi_value minus prior_period_value). Positive indicates improvement for growth KPIs, negative for cost/churn KPIs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The percentage change between the current KPI value and the prior period value, calculated as ((kpi_value - prior_period_value) / prior_period_value) * 100. Null if prior period value is zero.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Dimension Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the dimension hierarchy record. Primary key for the dimension hierarchy entity.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingDimensionId rdf:type rdf:Property ;
    rdfs:label 'Reporting Dimension Id' ;
    rdfs:comment 'Reference to the parent dimension that this hierarchy belongs to (e.g., Geography, Product, Time, Customer Segment). Links this hierarchy structure to its owning dimension definition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingDimension .

ind:aggregationFunction rdf:type rdf:Property ;
    rdfs:label 'Aggregation Function' ;
    rdfs:comment 'Default aggregation function to apply when rolling up measures along this hierarchy. Defines how Key Performance Indicators (KPIs) are calculated at each level. [ENUM-REF-CANDIDATE: sum|average|count|min|max|distinct_count|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name or identifier of the business unit or role responsible for maintaining and governing this hierarchy definition. Supports data governance and stewardship.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Unique business code or identifier for the hierarchy. Used for programmatic reference and integration with Business Intelligence (BI) tools and Online Analytical Processing (OLAP) cubes.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Detailed description of the hierarchy purpose, structure, and business use cases. Explains the drill-down and roll-up semantics for business users.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Business name of the hierarchy structure. Examples: \'Geographic Rollup\', \'Product Category Tree\', \'Organizational Hierarchy\', \'Network Topology Hierarchy\'.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the hierarchy structure. Balanced: all branches have same depth; Ragged: branches may have different depths; Unbalanced: members may skip levels; Network: members may have multiple parents; Parent-Child: recursive self-referencing structure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this hierarchy level is currently active and available for use in reporting and analytics. Inactive hierarchies are retained for historical reference.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Default Hierarchy' ;
    rdfs:comment 'Indicates whether this is the default hierarchy for the dimension. Used by Business Intelligence (BI) tools to select the primary drill-down path when multiple hierarchies exist for a dimension.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelAttributeList rdf:type rdf:Property ;
    rdfs:label 'Level Attribute List' ;
    rdfs:comment 'Comma-separated list of attribute names available at this hierarchy level. Defines which dimensional attributes are exposed for filtering and grouping at this level.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelCardinality rdf:type rdf:Property ;
    rdfs:label 'Level Cardinality' ;
    rdfs:comment 'Approximate number of distinct members at this hierarchy level. Used for query optimization and cube design in Business Intelligence (BI) platforms.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:levelCode rdf:type rdf:Property ;
    rdfs:label 'Level Code' ;
    rdfs:comment 'Unique code or abbreviation for the hierarchy level. Used for programmatic reference in Extract Transform Load (ETL) processes and reporting queries.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelKeyColumn rdf:type rdf:Property ;
    rdfs:label 'Level Key Column' ;
    rdfs:comment 'Name of the column that serves as the unique business key for members at this level. Used for joining and identifying dimension members in star schema queries.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Name of the hierarchical level within the dimension. Examples: \'Country\', \'Region\', \'Market\', \'District\', \'Cell Site\' for geography; \'Product Line\', \'Product Family\', \'Product Category\', \'Product Subcategory\', \'Stock Keeping Unit (SKU)\' for product.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelNameColumn rdf:type rdf:Property ;
    rdfs:label 'Level Name Column' ;
    rdfs:comment 'Name of the column that contains the human-readable display name for members at this level. Used for report labels and user interface presentation.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelOrdinalPosition rdf:type rdf:Property ;
    rdfs:label 'Level Ordinal Position' ;
    rdfs:comment 'Numeric position of this level within the hierarchy, starting from 1 at the top (most aggregated) level. Determines drill-down sequence and roll-up aggregation order in OLAP operations.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:olapCubeName rdf:type rdf:Property ;
    rdfs:label 'Olap Cube Name' ;
    rdfs:comment 'Name of the Online Analytical Processing (OLAP) cube or analytical model that uses this hierarchy. Links the hierarchy definition to deployed Business Intelligence (BI) assets.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLevelName rdf:type rdf:Property ;
    rdfs:label 'Parent Level Name' ;
    rdfs:comment 'Name of the immediate parent level in the hierarchy. Null for the top-most level. Defines the parent-child relationship for roll-up aggregations.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsRollUp rdf:type rdf:Property ;
    rdfs:label 'Supports Roll Up' ;
    rdfs:comment 'Indicates whether this hierarchy supports roll-up aggregation from detailed to summary levels in Online Analytical Processing (OLAP) operations.' ;
    rdfs:domain ind:DimensionHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dqExecutionResultId rdf:type rdf:Property ;
    rdfs:label 'Dq Execution Result Id' ;
    rdfs:comment 'Unique identifier for each data quality rule execution result record. Primary key for the DQ execution result entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqExecutionResult .

ind:dqRuleId rdf:type rdf:Property ;
    rdfs:label 'Dq Rule Id' ;
    rdfs:comment 'Reference to the specific data quality rule that was executed in this run. Links to the DQ rule catalog.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqRule .

ind:dataStewardNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Steward Notified Flag' ;
    rdfs:comment 'Indicates whether the assigned data steward was notified of this rule execution result. True if notification was sent; false otherwise.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error or exception message if the rule execution encountered a technical failure (execution_status = error). Null for successful executions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to execute the data quality rule against the target data product. Used for performance monitoring and optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionMode rdf:type rdf:Property ;
    rdfs:label 'Execution Mode' ;
    rdfs:comment 'Mode in which the data quality rule was executed. Scheduled for automated runs; manual for ad-hoc validation; triggered for event-driven execution; continuous for streaming data validation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Overall outcome status of the data quality rule execution. Passed indicates all records met the rule criteria; failed indicates threshold breach; warning indicates approaching threshold; error indicates execution failure; skipped indicates rule was not applicable.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Precise date and time when the data quality rule execution was initiated. Used for operational audit trail and SLA compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureSampleRecords rdf:type rdf:Property ;
    rdfs:label 'Failure Sample Records' ;
    rdfs:comment 'JSON array containing a sample of records that failed the data quality rule. Includes primary key and relevant attribute values to enable root cause analysis. Limited to first 100 failures for performance.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Failure Threshold Percentage' ;
    rdfs:comment 'Configured threshold percentage below which the rule execution is considered failed. Used to determine execution_status based on pass_rate_percentage.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Rate Percentage' ;
    rdfs:comment 'Percentage of records that passed the data quality rule, calculated as (records_passed_count / records_evaluated_count) * 100. Key metric for DQ dashboard and SLA monitoring.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordsEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Records Evaluated Count' ;
    rdfs:comment 'Total number of records in the target data product that were evaluated against the data quality rule during this execution.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Records Failed Count' ;
    rdfs:comment 'Number of records that did not meet the data quality rule criteria. Used to calculate failure rate and identify data quality issues.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsPassedCount rdf:type rdf:Property ;
    rdfs:label 'Records Passed Count' ;
    rdfs:comment 'Number of records that successfully met the data quality rule criteria. Used to calculate pass rate percentage.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Recommended or automated remediation action to address data quality failures (e.g., quarantine records, trigger data steward notification, auto-correct). Supports operational response workflows.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Classification of the data quality rule based on ISO 25012 quality dimensions. Enables categorization of DQ issues for governance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-friendly code identifier for the executed rule (e.g., CUS-VAL-001 for customer validation rule 001). Enables human-readable rule reference in reports and dashboards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the data quality rule that was executed (e.g., Customer Email Format Validation, MSISDN Length Check).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSeverity rdf:type rdf:Property ;
    rdfs:label 'Rule Severity' ;
    rdfs:comment 'Business impact severity of the data quality rule. Critical rules block downstream processing; low severity rules are informational only.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier of the data quality rule definition at the time of execution. Enables tracking of rule changes over time and historical comparison.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether this execution result meets the defined SLA for data quality. True if pass_rate_percentage meets or exceeds the SLA threshold; false if SLA is breached.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDomain rdf:type rdf:Property ;
    rdfs:label 'Target Domain' ;
    rdfs:comment 'Business domain of the data product being validated (e.g., Customer, Network, Billing, Product). Aligns with enterprise data domain taxonomy.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLayer rdf:type rdf:Property ;
    rdfs:label 'Target Layer' ;
    rdfs:comment 'Lakehouse medallion architecture layer where the target data product resides. Typically silver for curated business entities.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProduct rdf:type rdf:Property ;
    rdfs:label 'Target Product' ;
    rdfs:comment 'Name of the specific data product (table/entity) in the Databricks Lakehouse Silver Layer that was evaluated by this rule execution.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Percentage' ;
    rdfs:comment 'Configured threshold percentage below which the rule execution triggers a warning status. Enables proactive alerting before SLA breach.' ;
    rdfs:domain ind:DqExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dqIssueId rdf:type rdf:Property ;
    rdfs:label 'Dq Issue Id' ;
    rdfs:comment 'Unique identifier for the data quality issue record. Primary key for the DQ issue entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqIssue .

ind:affectedNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Data quality issues in network performance data must be traceable to specific network elements for root cause analysis and remediation. Network operations teams require DQ issue tracking tied to infra' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:locationSiteId rdf:type rdf:Property ;
    rdfs:label 'Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Data quality issues in network data are often traced to specific site equipment or collection points for remediation. Links DQ issues to physical infrastructure for field technician dispatch and equip' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:primaryDqEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dq Employee Id' ;
    rdfs:comment 'Foreign key reference to the data steward responsible for investigating and remediating this DQ issue.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when the assigned data steward acknowledged receipt and ownership of the issue.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedAttribute rdf:type rdf:Property ;
    rdfs:label 'Affected Attribute' ;
    rdfs:comment 'The specific column or attribute within the data product that exhibits the quality defect. Null if the issue is record-level or cross-attribute.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDomain rdf:type rdf:Property ;
    rdfs:label 'Affected Domain' ;
    rdfs:comment 'The data domain where the quality issue was detected (e.g., Customer, Network, Billing, Product). Maps to the enterprise data domain taxonomy.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProduct rdf:type rdf:Property ;
    rdfs:label 'Affected Product' ;
    rdfs:comment 'The specific data product (table/entity) within the domain where the quality issue was identified.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Affected Record Count' ;
    rdfs:comment 'Number of data records impacted by this quality issue. Used to quantify the scope and business impact of the defect.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedReportList rdf:type rdf:Property ;
    rdfs:label 'Affected Report List' ;
    rdfs:comment 'Comma-separated list of business intelligence reports, dashboards, or analytics products impacted by this data quality issue for stakeholder notification.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the issue was verified as resolved and formally closed, completing the issue lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact Flag' ;
    rdfs:comment 'Boolean indicator whether this data quality issue affects regulatory reporting, compliance obligations, or audit requirements requiring special handling.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The date and time when the data quality issue was first identified, marking the start of the issue lifecycle and SLA clock.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the data quality issue was discovered to support effectiveness analysis of detection mechanisms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqDimension rdf:type rdf:Property ;
    rdfs:label 'Dq Dimension' ;
    rdfs:comment 'The data quality dimension violated by this issue per ISO/IEC 25012 framework (e.g., completeness for missing values, accuracy for incorrect values).' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation tier of the issue (0=no escalation, 1=team lead, 2=manager, 3=director, 4=executive) based on severity and SLA breach status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed narrative description of the data quality issue including symptoms, impact, and context discovered during DQ rule execution or manual review.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'Human-readable business identifier for the DQ issue, formatted as DQI-YYYYMMDD for external reference and tracking.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle status of the DQ issue tracking its progression from detection through remediation to closure.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTitle rdf:type rdf:Property ;
    rdfs:label 'Issue Title' ;
    rdfs:comment 'Short descriptive title summarizing the nature of the data quality issue for quick identification and reporting.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this DQ issue record was last updated, supporting audit trail and change history tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Operational priority ranking for issue remediation combining severity, business impact, and resource availability. P1 requires immediate action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean indicator whether this issue is a recurrence of a previously resolved issue, signaling potential systemic problems requiring deeper investigation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation effort tracking progress from planning through implementation to verification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the resolution approach, actions taken, validation results, and lessons learned for knowledge management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'The date and time when the remediation action was completed and the issue was marked as resolved, stopping the SLA clock.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying cause of the data quality issue to support trend analysis and preventive action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDetail rdf:type rdf:Property ;
    rdfs:label 'Root Cause Detail' ;
    rdfs:comment 'Detailed explanation of the root cause analysis findings including specific system, process, or configuration defect identified during investigation.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact severity classification of the DQ issue determining prioritization and response urgency. Critical issues block downstream analytics or violate regulatory requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Boolean indicator whether the issue resolution exceeded the SLA target time, triggering escalation and reporting requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Hours' ;
    rdfs:comment 'The number of hours within which this issue must be resolved per the data quality SLA based on severity level.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rule Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Data quality rule ownership enables accountability for rule maintenance, threshold adjustments, and false-positive resolution. Critical for DQ incident escalation workflows and rule approval processes' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertChannel rdf:type rdf:Property ;
    rdfs:label 'Alert Channel' ;
    rdfs:comment 'The communication channel used to notify stakeholders when this rule is violated beyond threshold. Multiple channels may be comma-separated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertRecipientList rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses, Slack channels, or PagerDuty service keys that should receive alerts when this rule fails. Supports distribution lists and role-based aliases.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Description of the business consequences if this rule is violated. Examples: revenue leakage, SLA breach, customer churn risk, regulatory penalty, network outage, billing dispute.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLineageReference rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Reference' ;
    rdfs:comment 'Reference to the data lineage graph or metadata catalog entry that shows the upstream sources and downstream consumers of the data validated by this rule. Used for impact analysis.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'How often this rule should be executed by the DQ engine. Real-time rules run on streaming data, batch rules run on scheduled intervals, on-demand rules are triggered manually.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionLayer rdf:type rdf:Property ;
    rdfs:label 'Execution Layer' ;
    rdfs:comment 'The lakehouse medallion architecture layer where this rule is executed. Bronze for raw data validation, Silver for cleansed data validation, Gold for aggregated/curated data validation.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Blocking' ;
    rdfs:comment 'Indicates whether violations of this rule should block downstream processing. True means failed records are quarantined and not promoted to the next layer. False means violations are logged but processing continues.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Last Execution Status' ;
    rdfs:comment 'The outcome of the most recent execution of this rule. Success means the rule ran without errors, failure means execution failed, warning means execution succeeded but violations exceeded threshold, skipped means the rule was not executed due to conditions not being met.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'The date and time when this rule was last executed by the DQ engine. Used to monitor execution frequency and detect stale rules.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPassRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Last Pass Rate Percentage' ;
    rdfs:comment 'The percentage of records that passed this rule during the last execution (0.00 to 100.00). Used to track data quality trends over time.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMandate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate' ;
    rdfs:comment 'Reference to the specific regulatory requirement, compliance framework, or industry standard that mandates this rule (e.g., FCC Part 64, GDPR Article 5, 3GPP TS 32.401). Null if the rule is business-driven rather than regulatory.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedKpi rdf:type rdf:Property ;
    rdfs:label 'Related Kpi' ;
    rdfs:comment 'The name or identifier of the business KPI that depends on this data quality rule. Examples: ARPU accuracy, churn prediction reliability, SLA compliance rate, CDR completeness for billing.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationGuidance rdf:type rdf:Property ;
    rdfs:label 'Remediation Guidance' ;
    rdfs:comment 'Step-by-step instructions for data stewards on how to investigate and resolve violations of this rule. May include links to runbooks, contact information for data owners, or automated remediation procedures.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of what the rule validates, why it matters, and the expected outcome. Provides context for business users and data stewards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'The logical expression or SQL predicate that defines the rule logic. May contain Spark SQL syntax, Python expressions, or declarative predicates. Example: \'msisdn IS NOT NULL AND LENGTH(msisdn) = 10\' or \'billing_amount >= 0\'.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of data quality dimension this rule validates. Completeness checks for missing values, uniqueness ensures no duplicates, validity verifies format/range, consistency checks cross-field logic, timeliness measures freshness, accuracy validates correctness against source of truth.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleViolationQuery rdf:type rdf:Property ;
    rdfs:label 'Sample Violation Query' ;
    rdfs:comment 'A SQL query template that data stewards can run to retrieve sample records that violate this rule. Used for investigation and root cause analysis.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAttribute rdf:type rdf:Property ;
    rdfs:label 'Target Attribute' ;
    rdfs:comment 'The specific column or attribute within the target product that this rule validates. Null if the rule applies to the entire record or multiple attributes.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalImplementation rdf:type rdf:Property ;
    rdfs:label 'Technical Implementation' ;
    rdfs:comment 'The technical framework or method used to implement this rule in the DQ execution engine. Spark SQL for native SQL predicates, Python UDF for custom logic, Great Expectations or Deequ for framework-based validation.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate the threshold. Typically \'>=\' for minimum pass rates, \'<=\' for maximum error rates.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Percentage' ;
    rdfs:comment 'The minimum acceptable pass rate for this rule as a percentage (0.00 to 100.00). Example: 99.50 means at least 99.5% of records must pass. Used to trigger alerts when quality falls below threshold.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureStoreDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Feature Store Definition Id' ;
    rdfs:comment 'Unique identifier for the feature store definition record. Primary key for the feature catalog in the Databricks Feature Store.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Business Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Feature store governance in telecommunications ML operations requires business owner accountability for feature definition approval, usage policies, and lifecycle management. Critical for model risk m' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aggregationWindow rdf:type rdf:Property ;
    rdfs:label 'Aggregation Window' ;
    rdfs:comment 'Time window over which aggregation is performed for time-based features (e.g., 7_days, 30_days, 90_days, 12_months). Null for non-aggregated features.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Computation Duration Seconds' ;
    rdfs:comment 'Average duration in seconds required to compute this feature during the last refresh cycle. Used for performance monitoring.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Security classification level of the feature data. Determines access controls and handling requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRule rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rule' ;
    rdfs:comment 'SQL expression or rule definition for validating feature values. Used for automated data quality checks during feature computation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityKeyColumn rdf:type rdf:Property ;
    rdfs:label 'Entity Key Column' ;
    rdfs:comment 'Name of the primary entity key column used to join this feature to other datasets (e.g., subscriber_id, account_id, cell_id). Defines the grain of the feature.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureCategory rdf:type rdf:Property ;
    rdfs:label 'Feature Category' ;
    rdfs:comment 'High-level classification of the feature type based on the nature of the data it represents. Used for feature discovery and organization. [ENUM-REF-CANDIDATE: demographic|behavioral|transactional|network_quality|device|temporal|aggregated|derived — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDataType rdf:type rdf:Property ;
    rdfs:label 'Feature Data Type' ;
    rdfs:comment 'Spark SQL data type of the feature value. Defines the technical data type used for storage and computation. [ENUM-REF-CANDIDATE: STRING|INT|BIGINT|DOUBLE|FLOAT|DECIMAL|BOOLEAN|DATE|TIMESTAMP|ARRAY|STRUCT — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Description' ;
    rdfs:comment 'Detailed business description of what the feature represents, how it is calculated, and its intended analytical use. Supports feature discovery and understanding.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureGroupName rdf:type rdf:Property ;
    rdfs:label 'Feature Group Name' ;
    rdfs:comment 'Logical grouping or namespace for related features. Organizes features by business domain or analytical purpose (e.g., subscriber_behavior, network_performance, billing_patterns).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureImportanceScore rdf:type rdf:Property ;
    rdfs:label 'Feature Importance Score' ;
    rdfs:comment 'Aggregated feature importance score across all models using this feature. Ranges from 0.0000 to 1.0000, with higher values indicating greater predictive power.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureName rdf:type rdf:Property ;
    rdfs:label 'Feature Name' ;
    rdfs:comment 'Unique name of the machine learning feature as registered in the Feature Store. Must be unique within the feature group. Examples: subscriber_tenure_months, avg_monthly_data_consumption_gb, network_quality_score.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Status' ;
    rdfs:comment 'Current lifecycle status of the feature definition. Active features are production-ready and available for model consumption.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureTags rdf:type rdf:Property ;
    rdfs:label 'Feature Tags' ;
    rdfs:comment 'Comma-separated list of custom tags or labels for feature categorization and discovery (e.g., churn_prediction, revenue_optimization, network_analytics).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPii rdf:type rdf:Property ;
    rdfs:label 'Is Pii' ;
    rdfs:comment 'Indicates whether this feature contains or is derived from personally identifiable information. True if feature requires privacy controls per GDPR, CCPA, or CPNI regulations.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComputedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Computed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful feature computation job. Indicates data freshness.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelNames rdf:type rdf:Property ;
    rdfs:label 'Model Names' ;
    rdfs:comment 'Comma-separated list of model names that consume this feature. Establishes downstream lineage to ML models.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelUsageCount rdf:type rdf:Property ;
    rdfs:label 'Model Usage Count' ;
    rdfs:comment 'Number of distinct ML models currently consuming this feature. Indicates feature reuse and criticality.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nullHandlingStrategy rdf:type rdf:Property ;
    rdfs:label 'Null Handling Strategy' ;
    rdfs:comment 'Strategy for handling null or missing values in the feature. Defines how nulls are treated during feature computation and model training. [ENUM-REF-CANDIDATE: drop|impute_mean|impute_median|impute_mode|impute_zero|impute_forward_fill|impute_custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nullPercentage rdf:type rdf:Property ;
    rdfs:label 'Null Percentage' ;
    rdfs:comment 'Percentage of null values in the feature column. Used for data quality monitoring and feature selection.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offlineServingEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Serving Enabled' ;
    rdfs:comment 'Indicates whether this feature is available for batch offline serving for model training and batch inference. True if feature is available in offline store.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineServingEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Serving Enabled' ;
    rdfs:comment 'Indicates whether this feature is available for real-time online serving through the Feature Store API. True if feature is published to online store.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partitionColumns rdf:type rdf:Property ;
    rdfs:label 'Partition Columns' ;
    rdfs:comment 'Comma-separated list of columns used for partitioning the feature table for optimized query performance (e.g., year, month, region).' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDomain rdf:type rdf:Property ;
    rdfs:label 'Source Domain' ;
    rdfs:comment 'Business domain from which the source data originates (e.g., Customer, Network, Billing, Usage). Maps to the data domain taxonomy.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage path or table name where the feature values are persisted in the lakehouse (e.g., dbfs:/feature_store/subscriber_features).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalOwner rdf:type rdf:Property ;
    rdfs:label 'Technical Owner' ;
    rdfs:comment 'Name or identifier of the data engineer or ML engineer responsible for implementing and maintaining this feature.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timestampColumn rdf:type rdf:Property ;
    rdfs:label 'Timestamp Column' ;
    rdfs:comment 'Name of the timestamp column used for point-in-time lookups and time-travel queries. Required for time-series features.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationLanguage rdf:type rdf:Property ;
    rdfs:label 'Transformation Language' ;
    rdfs:comment 'Programming or query language used to define the feature transformation logic.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transformationLogic rdf:type rdf:Property ;
    rdfs:label 'Transformation Logic' ;
    rdfs:comment 'SQL or PySpark expression defining how the feature is computed from source data. Contains the complete transformation code or reference to transformation function.' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Cadence at which the feature values are refreshed or recomputed. Defines the data freshness SLA for this feature. [ENUM-REF-CANDIDATE: real_time|near_real_time|hourly|daily|weekly|monthly|on_demand|batch — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeatureStoreDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glossaryTermId rdf:type rdf:Property ;
    rdfs:label 'Glossary Term Id' ;
    rdfs:comment 'Unique identifier for the business glossary term record. Primary key for the glossary term catalog.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataStewardEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Data Steward Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Business glossary stewardship requires employee linkage for term approval workflows, definition disputes, and metadata governance. Essential for regulatory compliance (e.g., consistent metric definiti' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:replacementTermGlossaryTermId rdf:type rdf:Property ;
    rdfs:label 'Replacement Term Glossary Term Id' ;
    rdfs:comment 'Reference to the glossary term that supersedes this deprecated term. Used to guide users to the current canonical term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlossaryTerm .

ind:businessContext rdf:type rdf:Property ;
    rdfs:label 'Business Context' ;
    rdfs:comment 'Narrative description of how and where this term is used in business operations, including relevant business processes, use cases, and decision-making scenarios.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDefinition rdf:type rdf:Property ;
    rdfs:label 'Business Definition' ;
    rdfs:comment 'Comprehensive business definition of the term written in plain language for business users. Explains what the term means, why it matters, and how it is used in business context.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Mathematical or logical formula used to calculate or derive this term when it represents a metric or KPI. Includes variable definitions and operators.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProductMapping rdf:type rdf:Property ;
    rdfs:label 'Data Product Mapping' ;
    rdfs:comment 'Comma-separated list of data product names where this glossary term is implemented as an attribute or entity. Provides business-to-technical term mapping.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Expected data type for values associated with this term when it is implemented as a data attribute in systems or data products. [ENUM-REF-CANDIDATE: string|numeric|decimal|integer|boolean|date|timestamp|percentage|currency — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationReason rdf:type rdf:Property ;
    rdfs:label 'Deprecation Reason' ;
    rdfs:comment 'Explanation of why this term was deprecated or retired, including replacement term recommendations and migration guidance. Populated only for deprecated terms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryStandardReference rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Reference' ;
    rdfs:comment 'Reference to telecommunications industry standards, specifications, or frameworks that define or govern this term. Examples: 3GPP TS 32.xxx, TM Forum SID, ITU-T recommendations.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive' ;
    rdfs:comment 'Indicates whether this term relates to sensitive, confidential, or personally identifiable information requiring special handling and access controls.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiLinkage rdf:type rdf:Property ;
    rdfs:label 'Kpi Linkage' ;
    rdfs:comment 'Comma-separated list of KPI codes or names that use this glossary term in their definition or calculation. Establishes traceability from terms to metrics.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this glossary term was last reviewed by the data steward or governance council to ensure definition accuracy and relevance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this glossary term to maintain definition currency and alignment with business needs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryAudience rdf:type rdf:Property ;
    rdfs:label 'Primary Audience' ;
    rdfs:comment 'Target user groups or roles who primarily use this term in their work. Examples: network engineers, billing analysts, customer service representatives, executives.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to regulatory requirements, compliance frameworks, or legal mandates that require or govern the use of this term. Examples: FCC regulations, GDPR articles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTerms rdf:type rdf:Property ;
    rdfs:label 'Related Terms' ;
    rdfs:comment 'Comma-separated list of related glossary term names that have semantic relationships with this term. Supports navigation and discovery of connected concepts.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Standard interval in months between scheduled reviews of this glossary term. Ensures regular governance oversight and definition maintenance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Business priority level indicating how critical this term is to strategic decision-making, regulatory compliance, or operational excellence.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synonyms rdf:type rdf:Property ;
    rdfs:label 'Synonyms' ;
    rdfs:comment 'Comma-separated list of alternative names, abbreviations, or aliases for this term used across the organization or industry. Helps users find the canonical term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDefinition rdf:type rdf:Property ;
    rdfs:label 'Technical Definition' ;
    rdfs:comment 'Technical or mathematical definition of the term including formulas, calculation methods, data sources, and system-level specifications. Used by data engineers and analysts.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCategory rdf:type rdf:Property ;
    rdfs:label 'Term Category' ;
    rdfs:comment 'High-level classification of the glossary term indicating the primary business domain or functional area it belongs to. [ENUM-REF-CANDIDATE: network|customer|billing|product|service|revenue|operational|technical|regulatory|financial|workforce|quality — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the term, used for compact reference in systems and reports. Examples: ARPU, MSISDN, CDR, CSSR, MNP.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'The canonical name of the business glossary term as it appears in business communications and documentation. This is the primary label used across the enterprise.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle status of the glossary term indicating its readiness for use and governance approval state.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termSubcategory rdf:type rdf:Property ;
    rdfs:label 'Term Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the term category. Examples: RAN metrics, billing cycles, customer segments.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit of measurement for this term when it represents a quantitative metric. Examples: currency, percentage, count, megabits per second, milliseconds.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageExamples rdf:type rdf:Property ;
    rdfs:label 'Usage Examples' ;
    rdfs:comment 'Concrete examples demonstrating how this term is used in business communications, reports, KPIs, or operational contexts. Helps users understand practical application.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency' ;
    rdfs:comment 'How frequently this term is referenced or used in business operations, reporting, and analytics. Indicates operational relevance.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validValueRange rdf:type rdf:Property ;
    rdfs:label 'Valid Value Range' ;
    rdfs:comment 'Acceptable range or enumeration of valid values for this term. Examples: 0-100 for percentages, active|inactive|suspended for status codes.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'The statistical method used to aggregate raw data into the KPI value: sum, average, count, minimum, maximum, median, percentile, or weighted average. [ENUM-REF-CANDIDATE: sum|average|count|min|max|median|percentile|weighted_average — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregationPeriod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Period' ;
    rdfs:comment 'The time period over which the KPI is calculated and reported: real-time, hourly, daily, weekly, monthly, quarterly, or yearly. [ENUM-REF-CANDIDATE: real_time|hourly|daily|weekly|monthly|quarterly|yearly — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDescription rdf:type rdf:Property ;
    rdfs:label 'Business Description' ;
    rdfs:comment 'Comprehensive business explanation of what the KPI measures, why it matters, and how it supports strategic objectives. Written for business stakeholders.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationLogic rdf:type rdf:Property ;
    rdfs:label 'Calculation Logic' ;
    rdfs:comment 'Detailed step-by-step logic for computing the KPI, including data sources, filters, transformations, and aggregation rules. Complements the formula with implementation guidance.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardVisibility rdf:type rdf:Property ;
    rdfs:label 'Dashboard Visibility' ;
    rdfs:comment 'The audience level for which this KPI is visible in dashboards and reports: executive leadership, management, operational teams, public stakeholders, or restricted access.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceTable rdf:type rdf:Property ;
    rdfs:label 'Data Source Table' ;
    rdfs:comment 'The specific table, view, or dataset within the source system from which KPI input data is extracted.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this KPI definition version became effective and started being used for reporting and analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this KPI definition version was retired or replaced. Null if the definition is still active.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kpiCategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Category' ;
    rdfs:comment 'High-level classification of the KPI by business domain: network performance, customer experience, revenue management, operational efficiency, quality of service, or financial performance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiCode rdf:type rdf:Property ;
    rdfs:label 'Kpi Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the KPI used in reports and dashboards (e.g., CSSR, ARPU, NPS, DCR).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Status' ;
    rdfs:comment 'Current lifecycle status of the KPI definition: active (in use), inactive (not currently tracked), deprecated (replaced by another KPI), under review (being evaluated), or draft (not yet approved).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'The official business name of the KPI as recognized across the enterprise (e.g., Call Setup Success Rate, Average Revenue Per User, Net Promoter Score).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiSubcategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Subcategory' ;
    rdfs:comment 'Detailed classification within the KPI category (e.g., Radio Access Network, Core Network, Billing, Churn, Retention, Fault Management).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDomain rdf:type rdf:Property ;
    rdfs:label 'Owner Domain' ;
    rdfs:comment 'The business domain or organizational unit responsible for defining, maintaining, and governing this KPI (e.g., Network Operations, Customer Experience, Finance, Revenue Assurance).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'The role or job title of the individual or team accountable for this KPI (e.g., Chief Technology Officer, VP Customer Experience, Director of Network Operations).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polarity rdf:type rdf:Property ;
    rdfs:label 'Polarity' ;
    rdfs:comment 'Indicates whether higher values are better (e.g., ARPU, NPS), lower values are better (e.g., churn rate, MTTR), a specific target is optimal, or the KPI is neutral/informational.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Any regulatory or compliance mandate that requires tracking and reporting of this KPI (e.g., Federal Communications Commission (FCC) service quality reporting, Quality of Service (QoS) obligations).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedKpiIds rdf:type rdf:Property ;
    rdfs:label 'Related Kpi Ids' ;
    rdfs:comment 'Comma-separated list of KPI definition IDs that are related to or dependent on this KPI (e.g., component KPIs, parent/child KPIs, correlated metrics).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often the KPI is reported to stakeholders: real-time, hourly, daily, weekly, monthly, quarterly, yearly, or on an ad-hoc basis. [ENUM-REF-CANDIDATE: real_time|hourly|daily|weekly|monthly|quarterly|yearly|ad_hoc — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaApplicable rdf:type rdf:Property ;
    rdfs:label 'Sla Applicable' ;
    rdfs:comment 'Indicates whether this KPI is tied to a contractual Service Level Agreement (SLA) with customers or partners.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'The enterprise strategic objective or business goal that this KPI supports (e.g., Improve Network Quality of Service, Reduce Customer Churn, Increase Average Revenue Per User).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdCriticalHigh rdf:type rdf:Property ;
    rdfs:label 'Threshold Critical High' ;
    rdfs:comment 'The upper bound threshold above which KPI performance is considered critically poor and requires immediate escalation (applicable for lower-is-better KPIs).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdCriticalLow rdf:type rdf:Property ;
    rdfs:label 'Threshold Critical Low' ;
    rdfs:comment 'The lower bound threshold below which KPI performance is considered critically poor and requires immediate escalation.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdWarningHigh rdf:type rdf:Property ;
    rdfs:label 'Threshold Warning High' ;
    rdfs:comment 'The upper bound threshold above which KPI performance triggers a warning alert (applicable for lower-is-better KPIs or range-bound KPIs).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdWarningLow rdf:type rdf:Property ;
    rdfs:label 'Threshold Warning Low' ;
    rdfs:comment 'The lower bound threshold below which KPI performance triggers a warning alert, indicating potential issues.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The current observed trend direction of the KPI over recent reporting periods: improving, declining, stable, volatile, or not applicable.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the KPI definition, incremented when calculation logic, thresholds, or other material attributes are changed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Id' ;
    rdfs:comment 'Unique identifier for the KPI target record. Primary key for the KPI target entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiTarget .

ind:administrativeRegionId rdf:type rdf:Property ;
    rdfs:label 'Administrative Region Id' ;
    rdfs:comment 'Foreign key linking to location.administrative_region. Business justification: Regulatory KPI targets (coverage obligations, quality standards, universal service) are mandated by jurisdiction/region. Essential for compliance tracking and regulatory reporting in telecommunication' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdministrativeRegion .

ind:primaryKpiEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Employee Id' ;
    rdfs:comment 'Reference to the individual or role accountable for achieving this target. Typically links to an employee, manager, or organizational unit responsible for performance delivery.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Target Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Performance targets (availability, utilization, MTTR) are set per network element type or specific critical elements for capacity planning and performance management. Budget planning and operational s' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:targetOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Owner Employee Id' ;
    rdfs:comment 'FK to people.employee' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselinePeriod rdf:type rdf:Property ;
    rdfs:label 'Baseline Period' ;
    rdfs:comment 'The time period from which the baseline value was derived. Examples include \'Q4 2023\', \'FY 2023\', or \'Trailing 12 Months\'. Provides temporal context for baseline comparison.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or current performance level that serves as the starting point for target setting. Provides context for evaluating the ambition level of the target.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Value' ;
    rdfs:comment 'The external benchmark performance level from the specified source. Provides competitive context for evaluating target ambition and performance gaps.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessDimensionType rdf:type rdf:Property ;
    rdfs:label 'Business Dimension Type' ;
    rdfs:comment 'The type of business dimension for which this target is defined. Identifies the analytical axis along which performance is measured (e.g., geographic region, product line, customer segment, distribution channel).' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Dimension Hierarchy Level' ;
    rdfs:comment 'The hierarchical level at which the dimension value is defined. For example, \'National\', \'Regional\', \'Market\', or \'Site\' for geographic dimensions. Supports roll-up and drill-down analysis.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionValue rdf:type rdf:Property ;
    rdfs:label 'Dimension Value' ;
    rdfs:comment 'The specific value of the business dimension for which this target applies. For example, if dimension_type is \'region\', this could be \'Northeast\', \'West\', or \'EMEA\'. Enables dimensional variance analysis.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) to which this target period belongs. Supports quarterly performance tracking and MBO reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this target period belongs. Enables alignment with financial planning and budgeting cycles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible Flag' ;
    rdfs:comment 'Indicates whether achievement of this target is tied to incentive compensation, bonuses, or performance-based rewards. True if the target is part of an MBO or incentive plan.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Incentive Weight Percentage' ;
    rdfs:comment 'The percentage weight of this target in the overall incentive compensation calculation. Used when multiple KPI targets contribute to a composite performance score.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAcceptableThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Threshold' ;
    rdfs:comment 'The minimum performance level that is considered acceptable. Performance below this threshold triggers alerts, escalations, or corrective action plans.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this target is driven by regulatory compliance obligations. True if the target is mandated by FCC, ITU, ETSI, or other governing bodies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'The business justification for revising the target after initial approval. Documents changes in market conditions, strategic priorities, or operational capabilities that necessitated target adjustment.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Applicable Flag' ;
    rdfs:comment 'Indicates whether this target is tied to contractual SLA commitments with customers, partners, or wholesale operators. True if target achievement impacts SLA compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicInitiativeCode rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative Code' ;
    rdfs:comment 'Reference to the strategic initiative, program, or project that this target supports. Links KPI targets to enterprise strategic planning and portfolio management.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'An aspirational performance target that exceeds the standard target. Represents exceptional performance and may be tied to incentive compensation or recognition programs.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImprovementPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Improvement Percentage' ;
    rdfs:comment 'The percentage improvement from baseline to target. Calculated as ((target_value - baseline_value) / baseline_value) * 100. Provides a normalized view of target ambition.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Target Owner Role' ;
    rdfs:comment 'The organizational role or title of the target owner. Examples include Regional Vice President, Product Manager, Network Operations Director, or Customer Experience Lead.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Target Period End Date' ;
    rdfs:comment 'The end date of the measurement period for which this target is effective. Defines the conclusion of the performance evaluation window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Period Start Date' ;
    rdfs:comment 'The start date of the measurement period for which this target is effective. Defines the beginning of the performance evaluation window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Target Period Type' ;
    rdfs:comment 'The measurement period granularity for which this target is set. Defines whether the target applies to a monthly, quarterly, annual, or other time period.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRationale rdf:type rdf:Property ;
    rdfs:label 'Target Rationale' ;
    rdfs:comment 'The business justification and strategic reasoning for setting this target at the specified level. Documents the assumptions, market conditions, historical trends, and strategic objectives that informed the target setting process.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'The current lifecycle status of the KPI target. Tracks the target through planning, approval, activation, and archival stages.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelRunId rdf:type rdf:Property ;
    rdfs:label 'Model Run Id' ;
    rdfs:comment 'Unique identifier for each analytical or machine learning model execution run. Primary key for the model run record.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModelRun .

ind:executedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Executed By User Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Model execution audit trail requires employee linkage for compliance, security investigations, and troubleshooting in telecommunications ML operations. Critical for model risk management and regulator' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inputAnalyticalDatasetId rdf:type rdf:Property ;
    rdfs:label 'Input Analytical Dataset Id' ;
    rdfs:comment 'Foreign key linking to analytics.analytical_dataset. Business justification: Model runs consume input analytical datasets for training or scoring. One run uses ONE primary input dataset; one dataset can be used by MANY runs. Currently input_dataset_path is a string path refere' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalDataset .

ind:parentRunModelRunId rdf:type rdf:Property ;
    rdfs:label 'Parent Run Model Run Id' ;
    rdfs:comment 'Reference to a parent model run if this is a nested or child run (e.g., hyperparameter tuning iteration, cross-validation fold).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModelRun .

ind:trainingFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Training Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to assurance.fraud_case. Business justification: Model training runs use historical fraud cases as labeled training data. Real-world ML operations track which fraud cases were used to train which model versions for reproducibility, bias analysis, an' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:aucScore rdf:type rdf:Property ;
    rdfs:label 'Auc Score' ;
    rdfs:comment 'Area Under the Receiver Operating Characteristic (ROC) Curve score for classification models. Measures model discrimination ability (0.0 to 1.0).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Identifier of the Databricks cluster or compute resource used to execute this model run. Used for cost allocation and performance analysis.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Compute Cost Usd' ;
    rdfs:comment 'Estimated or actual compute cost in USD for executing this model run. Used for cost tracking and optimization of ML operations.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driftDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Drift Detected Flag' ;
    rdfs:comment 'Boolean flag indicating whether data drift or model performance drift was detected during or after this run. True if drift detected, False otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driftScore rdf:type rdf:Property ;
    rdfs:label 'Drift Score' ;
    rdfs:comment 'Quantitative measure of data or model drift detected in this run. Higher values indicate greater drift from baseline or training distribution.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationMetricPrimary rdf:type rdf:Property ;
    rdfs:label 'Evaluation Metric Primary' ;
    rdfs:comment 'Name of the primary evaluation metric used to assess model performance (e.g., AUC, RMSE, F1-score, accuracy, precision, recall, MAE).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationMetricPrimaryValue rdf:type rdf:Property ;
    rdfs:label 'Evaluation Metric Primary Value' ;
    rdfs:comment 'Numeric value of the primary evaluation metric achieved in this model run. Used for performance tracking and model comparison.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Execution Environment' ;
    rdfs:comment 'Computing environment where the model run was executed: Databricks cluster, local machine, Kubernetes, AWS SageMaker, Azure ML, or Google Vertex AI.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Code' ;
    rdfs:comment 'Identifier of the MLflow experiment or model development project that this run belongs to. Groups related model runs for comparison.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:f1Score rdf:type rdf:Property ;
    rdfs:label 'F1 Score' ;
    rdfs:comment 'Harmonic mean of precision and recall for classification models. Provides balanced measure of model performance (0.0 to 1.0).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureImportancePath rdf:type rdf:Property ;
    rdfs:label 'Feature Importance Path' ;
    rdfs:comment 'Storage path where feature importance scores or SHAP values from this model run are saved for model interpretability analysis.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hyperparametersJson rdf:type rdf:Property ;
    rdfs:label 'Hyperparameters Json' ;
    rdfs:comment 'JSON-formatted string containing all hyperparameter configurations used in this model run (learning rate, batch size, epochs, etc.). Essential for model reproducibility.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputRecordCount rdf:type rdf:Property ;
    rdfs:label 'Input Record Count' ;
    rdfs:comment 'Total number of records in the input dataset processed during this model run. Used for data quality validation and performance analysis.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaselineRun rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Run' ;
    rdfs:comment 'Boolean flag indicating whether this run represents a baseline model for performance comparison. True if baseline, False otherwise.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProductionCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Production Candidate' ;
    rdfs:comment 'Boolean flag indicating whether this model run produced a model that is a candidate for production deployment. True if candidate, False otherwise.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maeScore rdf:type rdf:Property ;
    rdfs:label 'Mae Score' ;
    rdfs:comment 'Mean Absolute Error for regression models. Measures average absolute difference between predicted and actual values.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersionCode rdf:type rdf:Property ;
    rdfs:label 'Model Version Code' ;
    rdfs:comment 'Reference to the specific version of the analytical or ML model that was executed in this run. Links to the model version catalog.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Output Artifact Path' ;
    rdfs:comment 'Delta table path, MLflow artifact URI, or storage location where model output artifacts (trained model, predictions, feature importance) are stored.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputModelPath rdf:type rdf:Property ;
    rdfs:label 'Output Model Path' ;
    rdfs:comment 'Specific storage path or URI where the trained model binary or serialized model object is persisted for deployment or future inference.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionScore rdf:type rdf:Property ;
    rdfs:label 'Precision Score' ;
    rdfs:comment 'Precision metric for classification models, representing the ratio of true positives to total predicted positives. Measures prediction accuracy (0.0 to 1.0).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionOutputPath rdf:type rdf:Property ;
    rdfs:label 'Prediction Output Path' ;
    rdfs:comment 'Delta table path or storage location where model predictions or inference results from this run are written.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquaredScore rdf:type rdf:Property ;
    rdfs:label 'R Squared Score' ;
    rdfs:comment 'Coefficient of determination (R²) for regression models. Indicates proportion of variance in the dependent variable explained by the model (-∞ to 1.0).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallScore rdf:type rdf:Property ;
    rdfs:label 'Recall Score' ;
    rdfs:comment 'Recall metric for classification models, representing the ratio of true positives to total actual positives. Measures model sensitivity (0.0 to 1.0).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmseScore rdf:type rdf:Property ;
    rdfs:label 'Rmse Score' ;
    rdfs:comment 'Root Mean Squared Error for regression models. Measures average prediction error magnitude in the same units as the target variable.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds for the model execution run from start to completion. Used for performance monitoring and resource optimization.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Timestamp when the model execution run completed or terminated. Used to calculate total run duration.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name or label assigned to this model run for identification and tracking purposes.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text notes or comments about this model run added by data scientists or ML engineers for documentation and knowledge sharing.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Timestamp when the model execution run was initiated. Represents the beginning of the training or inference process.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current execution status of the model run indicating whether it completed successfully, failed, is still running, or was cancelled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFramework rdf:type rdf:Property ;
    rdfs:label 'Training Framework' ;
    rdfs:comment 'Name and version of the ML framework used for this run (e.g., TensorFlow 2.10, PyTorch 1.12, Scikit-learn 1.1, Spark MLlib 3.3).' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEventCode rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Code' ;
    rdfs:comment 'Identifier of the specific event or job that triggered this model run. May reference a scheduler job ID, API request ID, or drift detection event ID.' ;
    rdfs:domain ind:ModelRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Classification of what initiated this model run: scheduled job, manual execution, automated retraining trigger, drift detection, or external API request.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAnalyticsKpiId rdf:type rdf:Property ;
    rdfs:label 'Network Analytics Kpi Id' ;
    rdfs:comment 'Unique identifier for the network analytics KPI measurement record. Primary key for the network_analytics_kpi product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkAnalyticsKpi .

ind:coverageAreaId rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Id' ;
    rdfs:comment 'Foreign key linking to location.coverage_area. Business justification: Network KPIs must be associated with coverage footprints for regulatory compliance reporting (FCC coverage obligations), coverage quality analysis, and service level verification. Core requirement for' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageArea .

ind:imsNodeId rdf:type rdf:Property ;
    rdfs:label 'Ims Node Id' ;
    rdfs:comment 'Foreign key linking to network.ims_node. Business justification: IMS node KPIs (registration success rate, call setup time, session capacity utilization, codec distribution) are essential for VoLTE/VoWiFi service quality monitoring. Voice service assurance dashboar' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImsNode .

ind:mplsTunnelId rdf:type rdf:Property ;
    rdfs:label 'Mpls Tunnel Id' ;
    rdfs:comment 'Foreign key linking to network.mpls_tunnel. Business justification: MPLS tunnel performance KPIs (bandwidth utilization, packet loss, latency, jitter) are measured per tunnel for IP/MPLS network assurance. Traffic engineering, QoS validation, and enterprise service SL' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MplsTunnel .

ind:networkElementId rdf:type rdf:Property ;
    rdfs:label 'Network Element Id' ;
    rdfs:comment 'Unique identifier of the network element (cell, site, eNodeB, gNodeB, base station, router, switch) that this KPI measurement pertains to. References the network inventory resource.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:networkTopologyId rdf:type rdf:Property ;
    rdfs:label 'Network Topology Id' ;
    rdfs:comment 'Foreign key linking to network.topology. Business justification: Link-level performance KPIs (utilization, latency, packet loss, error rates) are measured per topology link for transport network monitoring. Network planning and SLA assurance require KPI tracking at' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Topology .

ind:popFacilityId rdf:type rdf:Property ;
    rdfs:label 'Pop Facility Id' ;
    rdfs:comment 'Foreign key linking to inventory.pop_facility. Business justification: Facility-level KPIs (power usage effectiveness, environmental conditions, equipment density) are essential for data center operations, energy management, and site consolidation planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopFacility .

ind:slaContractId rdf:type rdf:Property ;
    rdfs:label 'Sla Contract Id' ;
    rdfs:comment 'Foreign key reference to the SLA contract that governs the performance thresholds and compliance requirements for this KPI measurement, if applicable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaContract .

ind:sliceId rdf:type rdf:Property ;
    rdfs:label 'Slice Id' ;
    rdfs:comment 'Foreign key linking to network.network_slice. Business justification: 5G network slice KPIs (latency, throughput, reliability, UE count) are measured per slice instance for slice SLA monitoring and assurance. Enterprise slice customers and regulatory reporting require s' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Slice .

ind:transmissionLinkId rdf:type rdf:Property ;
    rdfs:label 'Transmission Link Id' ;
    rdfs:comment 'Foreign key linking to network.transmission_link. Business justification: Transmission link KPIs (fiber attenuation, BER, availability, latency) are critical for backhaul and fronthaul monitoring. Lease cost optimization and SLA compliance reporting require performance metr' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionLink .

ind:alarmCorrelationCode rdf:type rdf:Property ;
    rdfs:label 'Alarm Correlation Code' ;
    rdfs:comment 'Correlation identifier linking this KPI measurement to related network alarms or fault events that may explain performance degradation.' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The method by which the KPI measurement was collected from the network element (real-time streaming, batch file transfer, scheduled polling, on-demand query).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'The vendor-specific or 3GPP-standard performance counter name from the network element that was used to derive this KPI measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCompletenessFlag rdf:type rdf:Property ;
    rdfs:label 'Data Completeness Flag' ;
    rdfs:comment 'Boolean indicator whether the measurement period had complete data collection (True = complete, False = partial or missing data detected).' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Code representing the geographic region, market, or administrative area where the network element is located (e.g., state, province, metro area code).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the network element in decimal degrees (WGS84 datum). Enables geospatial analysis and heat mapping of network performance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the network element in decimal degrees (WGS84 datum). Enables geospatial analysis and heat mapping of network performance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The numeric value of the KPI measurement as observed during the measurement period. Precision supports both percentage KPIs and high-resolution throughput/signal measurements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementGranularity rdf:type rdf:Property ;
    rdfs:label 'Measurement Granularity' ;
    rdfs:comment 'The time granularity or aggregation period of the KPI measurement (raw event, 15-minute, hourly, daily, weekly, or monthly aggregation).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The end timestamp of the aggregation window for this KPI measurement (e.g., end of the hour for hourly KPIs).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The start timestamp of the aggregation window for this KPI measurement (e.g., start of the hour for hourly KPIs).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The validation status of the KPI measurement (valid, suspect, invalid, estimated, missing) indicating data quality and reliability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkClusterCode rdf:type rdf:Property ;
    rdfs:label 'Network Cluster Code' ;
    rdfs:comment 'Identifier for the logical network cluster or zone that this network element belongs to for capacity planning and performance analysis purposes.' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkElementType rdf:type rdf:Property ;
    rdfs:label 'Network Element Type' ;
    rdfs:comment 'The type or category of network element being measured (cell, site, eNodeB, gNodeB, base station, router, switch, BNG, BRAS, OLT, ONT). [ENUM-REF-CANDIDATE: cell|site|enodeb|gnodeb|base_station|router|switch|bng|bras|olt|ont — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Nms Source System' ;
    rdfs:comment 'The Network Management System (NMS) or Element Management System (EMS) that collected and reported this KPI measurement (e.g., Nokia NetAct, Ericsson Network Manager).' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ranType rdf:type rdf:Property ;
    rdfs:label 'Ran Type' ;
    rdfs:comment 'The type of Radio Access Network (RAN) deployment for this network element (macro cell, micro cell, pico cell, femto cell, small cell, distributed antenna system).' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'The number of raw samples or events aggregated to produce this KPI measurement. Indicates statistical confidence of the measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyGeneration rdf:type rdf:Property ;
    rdfs:label 'Technology Generation' ;
    rdfs:comment 'The network technology generation or standard applicable to this measurement (2G, 3G, 4G/LTE, 5G/5G NR, FTTH, GPON). [ENUM-REF-CANDIDATE: 2G|3G|4G|5G|LTE|5G_NR|FTTH|GPON — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Flag' ;
    rdfs:comment 'Boolean indicator whether the measured value breached the defined threshold for this KPI (True = breach detected, False = within acceptable range).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'The type of threshold applied for breach detection (upper limit, lower limit, or acceptable range).' ;
    rdfs:domain ind:NetworkAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The threshold value that was compared against the measured value to determine breach status. For range thresholds, this represents the primary boundary.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the equipment vendor or manufacturer for the network element (e.g., Nokia, Ericsson, Huawei, Cisco).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Parent Pipeline Run Id' ;
    rdfs:comment 'Reference to the parent pipeline run that triggered this execution, if this pipeline is part of a multi-stage workflow. Null for standalone pipelines. Used for dependency tracking and workflow lineage.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRun .

ind:bytesProcessed rdf:type rdf:Property ;
    rdfs:label 'Bytes Processed' ;
    rdfs:comment 'Total volume of data processed by the pipeline in bytes. Used for cost analysis, capacity planning, and performance optimization.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bytesWritten rdf:type rdf:Property ;
    rdfs:label 'Bytes Written' ;
    rdfs:comment 'Total volume of data written to the target destination in bytes. Used for storage cost tracking and compression ratio analysis.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataFreshnessSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Sla Minutes' ;
    rdfs:comment 'Target maximum age of data in minutes as defined by the SLA. Used to determine if pipeline execution met freshness requirements for downstream analytics and reporting.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:databricksClusterCode rdf:type rdf:Property ;
    rdfs:label 'Databricks Cluster Code' ;
    rdfs:comment 'Identifier of the Databricks compute cluster that executed the pipeline. Used for cost allocation and resource utilization analysis.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databricksJobRunCode rdf:type rdf:Property ;
    rdfs:label 'Databricks Job Run Code' ;
    rdfs:comment 'Native Databricks job run identifier assigned by the platform. Used for linking to Databricks UI and API for detailed execution logs and cluster metrics.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time for the pipeline execution in seconds. Calculated as end_timestamp minus start_timestamp. Used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the pipeline execution completed or terminated. Null if pipeline is still running. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Standardized error code or exception type for categorizing pipeline failures. Enables automated alerting and error pattern analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Username or system account that initiated the pipeline execution. Used for audit trail and access control analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether automated notifications (email, Slack, PagerDuty) were sent for this pipeline execution. True if notifications were triggered, False otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Code' ;
    rdfs:comment 'Unique business identifier or code for the pipeline. Used for cross-system reference and operational tracking.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Name' ;
    rdfs:comment 'Human-readable name of the data pipeline that was executed. Identifies the specific ETL/ELT workflow or data transformation process.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineType rdf:type rdf:Property ;
    rdfs:label 'Pipeline Type' ;
    rdfs:comment 'Classification of the pipeline based on its primary function: ingestion (raw data loading), transformation (data cleansing and enrichment), aggregation (summarization and rollup), model_scoring (ML inference), data_quality (validation and profiling), or orchestration (workflow coordination).' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineVersion rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version' ;
    rdfs:comment 'Version number or Git commit hash of the pipeline code that was executed. Used for change tracking and rollback analysis.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordsProcessedCount rdf:type rdf:Property ;
    rdfs:label 'Records Processed Count' ;
    rdfs:comment 'Total number of records read and processed by the pipeline during this execution. Used for throughput analysis and data volume tracking.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsSkippedCount rdf:type rdf:Property ;
    rdfs:label 'Records Skipped Count' ;
    rdfs:comment 'Number of records intentionally skipped during processing due to business rules, filters, or deduplication logic.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsWrittenCount rdf:type rdf:Property ;
    rdfs:label 'Records Written Count' ;
    rdfs:comment 'Total number of records successfully written to the target destination by the pipeline. Used for data completeness validation and reconciliation.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Number' ;
    rdfs:comment 'Sequential number indicating which retry attempt this execution represents. 0 for initial execution, 1+ for retries after failure. Used for reliability analysis.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachReason rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Reason' ;
    rdfs:comment 'Explanation of why the pipeline execution breached the SLA, if applicable. Examples: upstream delay, cluster unavailability, data volume spike, processing error.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the pipeline execution began. Used for duration calculation and SLA monitoring. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessControlGroup rdf:type rdf:Property ;
    rdfs:label 'Access Control Group' ;
    rdfs:comment 'The security group or role required to access this dimension data (e.g., \'Analytics_Users\', \'Network_Operations\', \'Executive_Dashboard\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeCount rdf:type rdf:Property ;
    rdfs:label 'Attribute Count' ;
    rdfs:comment 'Total number of attributes or columns defined in the dimension table, used for schema complexity assessment.' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessDomain rdf:type rdf:Property ;
    rdfs:label 'Business Domain' ;
    rdfs:comment 'The primary business domain or subject area this dimension belongs to (Customer, Network, Billing, Product, Order, Service, Workforce, Partner, Usage, Revenue Assurance, Inventory, Interconnect, Content, Compliance, Enterprise). [ENUM-REF-CANDIDATE: customer|network|billing|product|order|service|workforce|partner|usage|revenue_assurance|inventory|interconnect|content|compliance|enterprise — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRules rdf:type rdf:Property ;
    rdfs:label 'Business Rules' ;
    rdfs:comment 'Documentation of business rules, constraints, and logic applied to dimension data (e.g., \'Customer segments are mutually exclusive\', \'Technology generation follows 3GPP (3rd Generation Partnership Project) standards\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardinalityEstimate rdf:type rdf:Property ;
    rdfs:label 'Cardinality Estimate' ;
    rdfs:comment 'Estimated number of distinct members or rows in the dimension table, used for capacity planning and query optimization.' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of regulatory or compliance frameworks applicable to this dimension (e.g., \'GDPR\', \'CPNI\', \'FCC\', \'SOX\', \'PCI-DSS\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformedFlag rdf:type rdf:Property ;
    rdfs:label 'Conformed Flag' ;
    rdfs:comment 'Indicates whether this dimension is a conformed dimension shared across multiple fact tables and subject areas (True) or a local dimension specific to one subject area (False).' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityRules rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rules' ;
    rdfs:comment 'Comma-separated list of data quality rules or checks applied to this dimension (e.g., \'completeness > 95%\', \'uniqueness on business key\', \'referential integrity with fact tables\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionCode rdf:type rdf:Property ;
    rdfs:label 'Dimension Code' ;
    rdfs:comment 'Unique business code or abbreviation for the dimension used in reporting and analytics systems (e.g., DIM_TIME, DIM_GEO, DIM_CUST_SEG).' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionDescription rdf:type rdf:Property ;
    rdfs:label 'Dimension Description' ;
    rdfs:comment 'Comprehensive business description of the dimension, its purpose, scope, and how it should be used in analytical queries and reports.' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionName rdf:type rdf:Property ;
    rdfs:label 'Dimension Name' ;
    rdfs:comment 'The business name of the reporting dimension (e.g., Time, Geography, Customer Segment, Network Element, Product, Channel, Technology Generation).' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionOwner rdf:type rdf:Property ;
    rdfs:label 'Dimension Owner' ;
    rdfs:comment 'The business unit, team, or individual responsible for the definition, quality, and governance of this dimension (e.g., \'Network Analytics Team\', \'Customer Insights\', \'Revenue Assurance\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionStatus rdf:type rdf:Property ;
    rdfs:label 'Dimension Status' ;
    rdfs:comment 'Current lifecycle status of the dimension in the analytics platform: active (in production use), deprecated (scheduled for retirement), proposed (under development), retired (no longer used), or under_review (being evaluated for changes).' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'Classification of the dimension based on dimensional modeling patterns: conformed (shared across subject areas), degenerate (stored in fact table), role-playing (single dimension used in multiple contexts), junk (low-cardinality flags), slowly-changing (infrequent updates), or rapidly-changing (frequent updates).' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevels rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Levels' ;
    rdfs:comment 'Comma-separated list of hierarchical levels within the dimension from highest to lowest granularity (e.g., \'Region > Market > Cell Site\', \'Year > Quarter > Month > Day\', \'Technology Generation > Access Type > Service Type\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexingStrategy rdf:type rdf:Property ;
    rdfs:label 'Indexing Strategy' ;
    rdfs:comment 'Description of indexing or partitioning strategy applied to optimize query performance (e.g., \'Clustered on dimension_code\', \'Partitioned by effective_date\', \'Z-order on business_key\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessKey rdf:type rdf:Property ;
    rdfs:label 'Primary Business Key' ;
    rdfs:comment 'The natural business key or keys used to uniquely identify dimension members in source systems (e.g., \'customer_account_number\', \'cell_site_id\', \'product_sku\', \'date\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'The frequency at which dimension data is refreshed from source systems: real_time (streaming), near_real_time (minutes), hourly, daily, weekly, monthly, or on_demand (manual trigger). [ENUM-REF-CANDIDATE: real_time|near_real_time|hourly|daily|weekly|monthly|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedFactTables rdf:type rdf:Property ;
    rdfs:label 'Related Fact Tables' ;
    rdfs:comment 'Comma-separated list of fact tables that reference this dimension (e.g., \'fact_usage\', \'fact_revenue\', \'fact_network_performance\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedKpiCount rdf:type rdf:Property ;
    rdfs:label 'Related Kpi Count' ;
    rdfs:comment 'Number of KPIs (Key Performance Indicators) that use this dimension for slicing, filtering, or grouping in business intelligence reports.' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolePlayingFlag rdf:type rdf:Property ;
    rdfs:label 'Role Playing Flag' ;
    rdfs:comment 'Indicates whether this dimension is used in multiple roles within the same fact table (True), such as a Time dimension used for order_date, ship_date, and delivery_date.' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scdType rdf:type rdf:Property ;
    rdfs:label 'Scd Type' ;
    rdfs:comment 'The slowly-changing-dimension strategy applied to track historical changes: Type 0 (retain original), Type 1 (overwrite), Type 2 (add new row with versioning), Type 3 (add new column), Type 4 (separate history table), Type 6 (hybrid 1+2+3), or not_applicable for non-SCD dimensions. [ENUM-REF-CANDIDATE: type_0|type_1|type_2|type_3|type_4|type_6|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaName rdf:type rdf:Property ;
    rdfs:label 'Schema Name' ;
    rdfs:comment 'The database schema or namespace containing the dimension table (e.g., \'analytics\', \'silver\', \'reporting\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClassification rdf:type rdf:Property ;
    rdfs:label 'Security Classification' ;
    rdfs:comment 'Data classification level for the dimension: public (no restrictions), internal (company use only), confidential (sensitive business data), or restricted (contains PII/PHI/PCI requiring strict access controls).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableName rdf:type rdf:Property ;
    rdfs:label 'Table Name' ;
    rdfs:comment 'The physical table or view name in the data warehouse or lakehouse where dimension data is stored (e.g., \'dim_customer\', \'dim_network_element\', \'dim_product\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'The analytics or data platform where this dimension is physically implemented (e.g., \'Databricks Lakehouse Silver Layer\', \'Snowflake\', \'Azure Synapse\', \'Google BigQuery\').' ;
    rdfs:domain ind:ReportingDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of fact tables, reports, dashboards, or analytical models that reference this dimension, indicating its importance and impact scope.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionModelOutputId rdf:type rdf:Property ;
    rdfs:label 'Retention Model Output Id' ;
    rdfs:comment 'Unique identifier for each retention model scoring record. Primary key for the retention model output entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionModelOutput .

ind:recentTroubleTicketId rdf:type rdf:Property ;
    rdfs:label 'Recent Trouble Ticket Id' ;
    rdfs:comment 'Foreign key linking to assurance.trouble_ticket. Business justification: Churn propensity scores consider recent trouble ticket history as a leading indicator. Real-world retention analytics incorporate service quality incidents into churn models for proactive retention in' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TroubleTicket .

ind:servingRanCellId rdf:type rdf:Property ;
    rdfs:label 'Serving Ran Cell Id' ;
    rdfs:comment 'Foreign key linking to network.ran_cell. Business justification: Churn prediction models incorporate cell-level service quality (RSRP, throughput, congestion) as key features. Retention campaigns targeting subscribers in poor-coverage cells require linking churn sc' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RanCell .

ind:arpuAtScoring rdf:type rdf:Property ;
    rdfs:label 'Arpu At Scoring' ;
    rdfs:comment 'The subscriber\'s monthly average revenue per user at the time of model scoring. Snapshot value used to prioritize high-value at-risk customers.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnPropensityScore rdf:type rdf:Property ;
    rdfs:label 'Churn Propensity Score' ;
    rdfs:comment 'Predicted probability that the subscriber will churn within the forecast horizon. Continuous value between 0.0000 (no churn risk) and 1.0000 (certain churn). Core output of the retention model.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnRiskTier rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Tier' ;
    rdfs:comment 'Categorical segmentation of churn risk based on propensity score thresholds. Used for prioritizing retention campaigns and resource allocation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvAtScoring rdf:type rdf:Property ;
    rdfs:label 'Cltv At Scoring' ;
    rdfs:comment 'The subscriber\'s estimated customer lifetime value at the time of model scoring. Snapshot value used to assess the business impact of potential churn.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveOfferExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Offer Exposure Flag' ;
    rdfs:comment 'Indicates whether the subscriber is in a geographic area with recent competitive promotional activity. True if exposed to competitor offers that may increase churn risk.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date when the subscriber\'s current contract or commitment period ends. Critical for identifying churn risk windows and proactive retention timing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysToContractEnd rdf:type rdf:Property ;
    rdfs:label 'Days To Contract End' ;
    rdfs:comment 'Number of days remaining until the subscriber\'s contract expires at the time of scoring. Key temporal feature for churn prediction near contract renewal periods.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelDriftFlag rdf:type rdf:Property ;
    rdfs:label 'Model Drift Flag' ;
    rdfs:comment 'Indicates whether model drift was detected for this scoring run. True if input data distribution significantly differs from training data, suggesting potential score reliability issues.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'The subscriber\'s most recent Net Promoter Score rating (0-10 scale). Measures customer loyalty and likelihood to recommend the service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictedChurnHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Predicted Churn Horizon Days' ;
    rdfs:comment 'Number of days into the future for which the churn prediction is valid. Represents the forecast window of the model (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousChurnScore rdf:type rdf:Property ;
    rdfs:label 'Previous Churn Score' ;
    rdfs:comment 'The churn propensity score from the previous model run for this subscriber. Enables tracking of score changes and risk trajectory over time.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Status of the scoring record processing. Completed indicates successful scoring; failed or partial indicates data quality or processing issues.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recentComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Recent Complaint Count' ;
    rdfs:comment 'Number of customer complaints or trouble tickets filed by the subscriber in the 90 days prior to scoring. Behavioral indicator of dissatisfaction and churn risk.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recentPaymentFailureCount rdf:type rdf:Property ;
    rdfs:label 'Recent Payment Failure Count' ;
    rdfs:comment 'Number of failed payment attempts in the 90 days prior to scoring. Financial indicator of potential involuntary churn risk.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedRetentionAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Retention Action' ;
    rdfs:comment 'Model-recommended intervention strategy to reduce churn risk for this subscriber. Guides sales and customer success teams on next best action. [ENUM-REF-CANDIDATE: no_action|monitor|outreach|discount_offer|loyalty_program|premium_support|contract_renegotiation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionCampaignEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Campaign Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for proactive retention campaigns based on business rules (e.g., not recently contacted, not in dispute, contract status).' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreChangeDirection rdf:type rdf:Property ;
    rdfs:label 'Score Change Direction' ;
    rdfs:comment 'Indicates whether the churn risk has increased, decreased, or remained stable compared to the previous scoring cycle. New_score indicates first-time scoring for this subscriber.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Score Expiry Date' ;
    rdfs:comment 'Date after which this churn score is considered stale and should not be used for operational decisions. Calculated as scoring_timestamp plus model refresh interval.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoreQualityIndicator rdf:type rdf:Property ;
    rdfs:label 'Score Quality Indicator' ;
    rdfs:comment 'Assessment of the reliability and quality of this particular score based on feature completeness, data freshness, and model confidence. Low quality scores should be used with caution.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scoring Timestamp' ;
    rdfs:comment 'The exact date and time when the churn propensity score was calculated for this subscriber. Represents the business event time of model inference.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenureMonthsAtScoring rdf:type rdf:Property ;
    rdfs:label 'Tenure Months At Scoring' ;
    rdfs:comment 'Number of months the subscriber has been active with the service provider at the time of scoring. Snapshot value used as a key churn predictor feature.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:topContributingFeatures rdf:type rdf:Property ;
    rdfs:label 'Top Contributing Features' ;
    rdfs:comment 'JSON-encoded list of the most influential features driving the churn prediction for this subscriber. Includes feature names and their contribution weights for model explainability.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTrend rdf:type rdf:Property ;
    rdfs:label 'Usage Trend' ;
    rdfs:comment 'Directional trend of the subscriber\'s service usage over the past 90 days. Declining usage is a strong churn predictor.' ;
    rdfs:domain ind:RetentionModelOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAnalyticsKpiId rdf:type rdf:Property ;
    rdfs:label 'Revenue Analytics Kpi Id' ;
    rdfs:comment 'Unique identifier for the revenue analytics KPI measurement record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueAnalyticsKpi .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Reference to the sales or distribution channel dimension for this revenue measurement (e.g., direct, retail, online, partner).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:productLineId rdf:type rdf:Property ;
    rdfs:label 'Product Line Id' ;
    rdfs:comment 'Reference to the product line dimension for which this revenue KPI is measured (e.g., wireless, broadband, fiber, IPTV).' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any manual or automated adjustment applied to the measured value to account for known anomalies, corrections, or business rules.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business justification or explanation for any adjustment applied to the measured value.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The timestamp when this KPI measurement was approved for official reporting and financial planning use.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:budgetTargetValue rdf:type rdf:Property ;
    rdfs:label 'Budget Target Value' ;
    rdfs:comment 'The budgeted or planned target value for this KPI in this period and dimension combination.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationRunCode rdf:type rdf:Property ;
    rdfs:label 'Calculation Run Code' ;
    rdfs:comment 'The unique identifier of the batch or pipeline run that calculated this KPI measurement, enabling traceability and reprocessing.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for monetary KPI values (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month (1-12) to which this KPI measurement belongs within the fiscal year.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOutlier rdf:type rdf:Property ;
    rdfs:label 'Is Outlier' ;
    rdfs:comment 'Flag indicating whether this KPI measurement has been identified as a statistical outlier requiring investigation or special handling.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiStatus rdf:type rdf:Property ;
    rdfs:label 'Kpi Status' ;
    rdfs:comment 'The status of this KPI measurement indicating whether it is final, preliminary, estimated, revised, forecasted, or cancelled.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The end date of the period for which this KPI measurement was calculated.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The start date of the period for which this KPI measurement was calculated.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outlierReason rdf:type rdf:Property ;
    rdfs:label 'Outlier Reason' ;
    rdfs:comment 'Explanation or categorization of why this measurement was flagged as an outlier (e.g., one-time event, data quality issue, business exception).' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToBudget rdf:type rdf:Property ;
    rdfs:label 'Variance To Budget' ;
    rdfs:comment 'The difference between the measured value and the budget target value (measured_value minus budget_target_value).' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToBudgetPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance To Budget Percentage' ;
    rdfs:comment 'The percentage variance between measured value and budget target, calculated as ((measured_value - budget_target_value) / budget_target_value) * 100.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorPeriod rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Period' ;
    rdfs:comment 'The difference between the measured value and the prior period value (measured_value minus prior_period_value).' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorPeriodPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Period Percentage' ;
    rdfs:comment 'The percentage variance between measured value and prior period value, calculated as ((measured_value - prior_period_value) / prior_period_value) * 100.' ;
    rdfs:domain ind:RevenueAnalyticsKpi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicZoneId rdf:type rdf:Property ;
    rdfs:label 'Geographic Zone Id' ;
    rdfs:comment 'Foreign key linking to location.geographic_zone. Business justification: Customer segments are often defined with geographic constraints (urban/rural, regulatory zones, roaming zones) for targeted marketing campaigns, service design, and pricing strategies. Standard segmen' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicZone .

ind:parentSegmentSegmentDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Segment Definition Id' ;
    rdfs:comment 'Reference to a parent segment if this segment is a sub-segment or refinement of a broader segment definition, enabling hierarchical segment taxonomies.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SegmentDefinition .

ind:actualPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Actual Population Size' ;
    rdfs:comment 'Current count of customers or accounts that match the segment definition criteria as of the last refresh.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedCampaignIds rdf:type rdf:Property ;
    rdfs:label 'Associated Campaign Ids' ;
    rdfs:comment 'Comma-separated list of marketing campaign IDs that target this segment, enabling campaign performance tracking by segment.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedReportIds rdf:type rdf:Property ;
    rdfs:label 'Associated Report Ids' ;
    rdfs:comment 'Comma-separated list of report or dashboard IDs that use this segment for filtering, grouping, or analysis.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'Strategic business objective this segment supports (e.g., reduce churn, increase ARPU, drive 5G adoption, improve NPS, expand enterprise market share).' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnerName rdf:type rdf:Property ;
    rdfs:label 'Business Owner Name' ;
    rdfs:comment 'Name of the individual business owner or sponsor accountable for this segment definition and its business outcomes.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'SQL predicate, rule expression, or business logic defining membership in this segment. May reference customer attributes, usage patterns, billing history, or network behavior.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultSegment rdf:type rdf:Property ;
    rdfs:label 'Is Default Segment' ;
    rdfs:comment 'Indicates whether this is a default or catch-all segment for customers who do not match any other segment criteria.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Refresh Timestamp' ;
    rdfs:comment 'Date and time when the segment is scheduled for its next automatic refresh.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:owningAnalyticsTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Analytics Team' ;
    rdfs:comment 'Name of the analytics team or business unit responsible for defining, maintaining, and governing this segment.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Required' ;
    rdfs:comment 'Indicates whether explicit customer consent is required before including them in this segment for marketing or personalization purposes.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'High-level business domain this segment applies to: customer segmentation, market segmentation, product affinity, network usage, revenue tier, or churn risk.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the segment in operational systems and reports.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed business description of the segment, including its purpose, target audience characteristics, and intended use cases.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Business-friendly name of the segment (e.g., High-Value Postpaid, At-Risk Prepaid, Enterprise SME, Youth Digital Native, Roaming Frequent Traveler, Fiber Early Adopter).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition: active (in use), inactive (temporarily disabled), draft (under development), under_review (pending approval), deprecated (being phased out), or archived (historical reference only).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation approach: demographic (age, gender), behavioral (usage patterns), value-based (ARPU, CLTV), lifecycle (new, mature, at-risk), geographic (region, urban/rural), or technographic (device, network preference).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsPersonalization rdf:type rdf:Property ;
    rdfs:label 'Supports Personalization' ;
    rdfs:comment 'Indicates whether this segment is used for personalized marketing, offers, or customer experience customization.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPredictiveAnalytics rdf:type rdf:Property ;
    rdfs:label 'Supports Predictive Analytics' ;
    rdfs:comment 'Indicates whether this segment is used in predictive models for churn prediction, upsell propensity, or other AI/ML applications.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpu rdf:type rdf:Property ;
    rdfs:label 'Target Arpu' ;
    rdfs:comment 'Target or expected Average Revenue Per User for customers in this segment, used for revenue forecasting and performance tracking.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetChurnRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Churn Rate Percentage' ;
    rdfs:comment 'Target or acceptable monthly churn rate percentage for customers in this segment, used for retention strategy and performance monitoring.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCltv rdf:type rdf:Property ;
    rdfs:label 'Target Cltv' ;
    rdfs:comment 'Target or expected Customer Lifetime Value for customers in this segment, representing the total revenue expected over the customer relationship.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNpsScore rdf:type rdf:Property ;
    rdfs:label 'Target Nps Score' ;
    rdfs:comment 'Target Net Promoter Score for customers in this segment, measuring customer satisfaction and loyalty on a scale from -100 to +100.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Target Population Size' ;
    rdfs:comment 'Expected or target number of customers or accounts that should fall into this segment based on the definition criteria.' ;
    rdfs:domain ind:SegmentDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticsSegmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Analytics Segment Membership Id' ;
    rdfs:comment 'Unique identifier for the segment membership record. Primary key for the segment membership association.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticsSegmentMembership .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the marketing or retention campaign that triggered or is associated with this segment membership. Links segment assignment to campaign execution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the business user or analyst who performed the manual override. Supports audit trail and accountability for manual segment adjustments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the subscriber or account was assigned to this segment. Represents the business effective date of the segment membership.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Code' ;
    rdfs:comment 'Code indicating the primary reason or trigger for this segment assignment. Examples include behavioral trigger, demographic match, usage pattern, churn risk, or campaign eligibility.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Description' ;
    rdfs:comment 'Detailed textual description explaining why the subscriber or account was assigned to this segment. Provides business context for the assignment decision.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence score assigned by the machine learning model for this segment membership assignment. Range 0.0000 to 1.0000. Higher values indicate greater model confidence. Null for non-ML assignments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Status of the subscriber or account consent for marketing communications related to this segment. Ensures compliance with privacy regulations such as GDPR and CPNI.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp when marketing consent was granted or last updated for this segment membership. Supports regulatory compliance and audit requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Evaluation Frequency' ;
    rdfs:comment 'Frequency at which this segment membership is evaluated or refreshed. Indicates whether the segment is updated in real-time, on a scheduled batch basis, or triggered by specific events. [ENUM-REF-CANDIDATE: real_time|daily|weekly|monthly|quarterly|on_demand|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether this record represents an exclusion from the segment rather than an inclusion. True when the subscriber or account is explicitly excluded from segment-based campaigns.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Scheduled expiration date for this segment membership. Used for time-bound segments such as promotional campaigns or seasonal cohorts. Null indicates no scheduled expiry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary or dominant segment for the subscriber or account. True when this segment takes precedence over other concurrent segment memberships.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Date' ;
    rdfs:comment 'Date when this segment membership was last evaluated or refreshed by the segmentation engine. Indicates recency of the membership assessment.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the segment membership assignment. Indicates whether the membership is currently active, has expired, or has been suspended or revoked.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Date' ;
    rdfs:comment 'Scheduled date for the next evaluation or refresh of this segment membership. Used for proactive segment maintenance and recalculation scheduling.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this segment membership was manually overridden by a business user or analyst. True when assignment was manually adjusted rather than system-generated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Textual explanation for why this segment membership was manually overridden. Captures business justification for deviating from automated assignment logic.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Timestamp when the manual override was applied. Captures the exact moment of manual intervention for audit purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking of this segment membership when a subscriber or account belongs to multiple segments simultaneously. Lower numbers indicate higher priority for campaign targeting and personalization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentEntryChannel rdf:type rdf:Property ;
    rdfs:label 'Segment Entry Channel' ;
    rdfs:comment 'Channel or touchpoint through which the subscriber or account entered this segment. Examples include web, mobile app, call center, retail store, or automated batch process.' ;
    rdfs:domain ind:AnalyticsSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of this segment membership record in the source system. Enables traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmEventId rdf:type rdf:Property ;
    rdfs:label 'Alarm Event Id' ;
    rdfs:comment 'Unique identifier for the network alarm event record. Primary key for the alarm event entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlarmEvent .

ind:affectedSvcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Affected Svc Instance Id' ;
    rdfs:comment 'Foreign key linking to service.svc_instance. Business justification: Network element alarms affect specific service instances. Required for proactive customer notification, service impact assessment, and correlating network events to customer experience degradation.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:alarmTriggeringKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggering Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Alarms are triggered by KPI threshold breaches. NOC operations link alarm types to KPI definitions for root cause analysis, threshold tuning, and alarm correlation. Real-world assurance systems track ' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:catalogItemId rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Alarms affecting specific services require product context for customer impact assessment, SLA breach determination, and targeted customer notification. Enables product-specific alarm correlation and ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:e911ComplianceId rdf:type rdf:Property ;
    rdfs:label 'E911 Compliance Id' ;
    rdfs:comment 'Foreign key linking to compliance.e911_compliance. Business justification: Alarms on E911 infrastructure (ALI/ANI database failures, PSAP connectivity loss, location server outages) trigger compliance reviews and regulatory reporting. Critical for public safety compliance an' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:E911Compliance .

ind:iptvChannelId rdf:type rdf:Property ;
    rdfs:label 'Iptv Channel Id' ;
    rdfs:comment 'Foreign key linking to content.iptv_channel. Business justification: Network monitoring alarms for multicast stream failures, CDN node errors, or encoder malfunctions must reference the affected channel to enable rapid identification and restoration of broadcast servic' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IptvChannel .

ind:kpiThresholdId rdf:type rdf:Property ;
    rdfs:label 'Kpi Threshold Id' ;
    rdfs:comment 'Reference to the alarm suppression rule applied to this alarm event, if any. Used for managing alarm storms and maintenance windows.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiThreshold .

ind:managedObjectCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Managed Object Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: When managed_object_class=\'CPE\', correlates customer equipment alarms (offline, low signal, reboot loops) with specific device serial numbers for remote troubleshooting, warranty claims, and proactive' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:managedObjectOntAssetId rdf:type rdf:Property ;
    rdfs:label 'Managed Object Ont Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.ont_asset. Business justification: When managed_object_class=\'ONT\', links fiber access alarms (LOS, dying gasp, high temperature) to specific ONT serial numbers for technician dispatch optimization and vendor quality analysis.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:rootCauseAlarmId rdf:type rdf:Property ;
    rdfs:label 'Root Cause Alarm Id' ;
    rdfs:comment 'Reference to the root cause alarm event when this alarm is determined to be a secondary or correlated alarm. Null if this is the root cause alarm.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alarm .

ind:troubleTicketId rdf:type rdf:Property ;
    rdfs:label 'Trouble Ticket Id' ;
    rdfs:comment 'Reference to the ServiceNow ITSM trouble ticket created for this alarm event. Null if no ticket has been generated yet.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Telecommunication .

ind:acknowledgedByUser rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By User' ;
    rdfs:comment 'Username or identifier of the NOC or SOC operator who acknowledged this alarm event.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Minutes' ;
    rdfs:comment 'Actual time in minutes from alarm raised to alarm cleared. Used for MTTR KPI calculation and SLA compliance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalText rdf:type rdf:Property ;
    rdfs:label 'Additional Text' ;
    rdfs:comment 'Free-form additional information or context provided by the network element or OSS system about the alarm event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServiceType rdf:type rdf:Property ;
    rdfs:label 'Affected Service Type' ;
    rdfs:comment 'Type of customer service potentially impacted by this alarm event (e.g., mobile_voice, mobile_data, broadband, iptv, enterprise_vpn).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alarm Acknowledged Timestamp' ;
    rdfs:comment 'Timestamp when the alarm event was acknowledged by NOC or SOC personnel, indicating human review has occurred.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alarmClearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alarm Cleared Timestamp' ;
    rdfs:comment 'Timestamp when the alarm event was cleared, indicating the fault condition has been resolved. Null if alarm is still active.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alarmIdentifier rdf:type rdf:Property ;
    rdfs:label 'Alarm Identifier' ;
    rdfs:comment 'Business identifier for the alarm event, typically assigned by the source OSS system (Nokia NetAct or Ericsson Network Manager).' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmRaisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alarm Raised Timestamp' ;
    rdfs:comment 'Timestamp when the alarm event was first raised by the network element. Represents the real-world fault occurrence time.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alarmSeverity rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity' ;
    rdfs:comment 'Severity level of the alarm event indicating business impact. Critical indicates service-affecting; major indicates significant degradation; minor indicates non-service-affecting; warning indicates potential issue; indeterminate indicates unknown impact.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmState rdf:type rdf:Property ;
    rdfs:label 'Alarm State' ;
    rdfs:comment 'Current lifecycle state of the alarm event. Raised indicates active fault; cleared indicates fault resolved; acknowledged indicates NOC has reviewed; suppressed indicates alarm is temporarily hidden from active view.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmType rdf:type rdf:Property ;
    rdfs:label 'Alarm Type' ;
    rdfs:comment 'Classification of the alarm event by fault category. Communications indicates connectivity failure; quality_of_service indicates performance degradation; processing_error indicates software fault; equipment indicates hardware failure; environmental indicates physical conditions (temperature, power).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedBySystem rdf:type rdf:Property ;
    rdfs:label 'Cleared By System' ;
    rdfs:comment 'System or process that cleared the alarm event (e.g., network element auto-recovery, manual intervention, OSS automation).' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Correlation Identifier' ;
    rdfs:comment 'Identifier used to correlate related alarm events across multiple network elements or systems. Enables root cause analysis and alarm storm management.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Count' ;
    rdfs:comment 'Estimated number of customers or subscribers potentially affected by this alarm event. Used for prioritization and SLA breach assessment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstOccurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Occurrence Timestamp' ;
    rdfs:comment 'Timestamp of the very first occurrence of this alarm condition. Used for tracking recurring or flapping alarms.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market where the affected network element is located. Used for regional NOC routing and reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this alarm event record was ingested into the lakehouse silver layer from the source OSS system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastOccurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Occurrence Timestamp' ;
    rdfs:comment 'Timestamp of the most recent occurrence of this alarm condition. Updated when alarm repeats or flaps.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this alarm event record was last modified in the lakehouse, reflecting state changes or attribute updates.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managedObjectClass rdf:type rdf:Property ;
    rdfs:label 'Managed Object Class' ;
    rdfs:comment 'Object-oriented class name of the network resource that raised the alarm (e.g., eNodeB, BNG, OLT, Router, Optical_Amplifier).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedObjectInstance rdf:type rdf:Property ;
    rdfs:label 'Managed Object Instance' ;
    rdfs:comment 'Unique instance identifier of the managed object within the network element that raised the alarm. Typically a distinguished name or hierarchical path.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttrTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Mttr Target Minutes' ;
    rdfs:comment 'Target resolution time in minutes for this alarm event based on severity and service impact, derived from SLA commitments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDomain rdf:type rdf:Property ;
    rdfs:label 'Network Domain' ;
    rdfs:comment 'High-level network domain classification of the affected network element. RAN indicates Radio Access Network; transport indicates backhaul/fronthaul; core indicates packet core; access indicates GPON/FTTH/DSLAM; edge indicates edge computing nodes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Occurrence Count' ;
    rdfs:comment 'Number of times this alarm condition has occurred since first detection. Used to identify flapping or intermittent faults.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ossSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Oss Source System' ;
    rdfs:comment 'Source OSS system that generated and published this alarm event (Nokia NetAct, Ericsson Network Manager, or other network management system).' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probableCause rdf:type rdf:Property ;
    rdfs:label 'Probable Cause' ;
    rdfs:comment 'Standardized description of the likely root cause of the alarm event as determined by the network element or OSS system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedRepairAction rdf:type rdf:Property ;
    rdfs:label 'Proposed Repair Action' ;
    rdfs:comment 'Recommended corrective action or troubleshooting steps for resolving the alarm condition, typically provided by the OSS system or knowledge base.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAffectingFlag rdf:type rdf:Property ;
    rdfs:label 'Service Affecting Flag' ;
    rdfs:comment 'Boolean indicator whether this alarm event is currently affecting customer service delivery. True indicates active service impact; false indicates no customer impact.' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteIdentifier rdf:type rdf:Property ;
    rdfs:label 'Site Identifier' ;
    rdfs:comment 'Physical site or facility identifier where the affected network element is deployed (e.g., cell site ID, central office code, data center ID).' ;
    rdfs:domain ind:AlarmEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificProblem rdf:type rdf:Property ;
    rdfs:label 'Specific Problem' ;
    rdfs:comment 'Vendor-specific or system-specific problem code providing detailed fault identification beyond the standardized probable cause.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyType rdf:type rdf:Property ;
    rdfs:label 'Technology Type' ;
    rdfs:comment 'Specific technology or protocol of the affected network element (e.g., LTE, 5G NR, GPON, MPLS, IP, Optical).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRuleKpiThresholdId rdf:type rdf:Property ;
    rdfs:label 'Parent Rule Kpi Threshold Id' ;
    rdfs:comment 'Identifier of the parent rule if this rule is a derived or specialized version of another rule configuration. Null if this is a top-level rule.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiThreshold .

ind:applicableServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Type' ;
    rdfs:comment 'Service type or product category to which this rule applies, such as prepaid mobile, postpaid mobile, broadband, IPTV, VoIP, or enterprise services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoTicketCreationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Ticket Creation Flag' ;
    rdfs:comment 'Boolean flag indicating whether breaches or detections triggered by this rule automatically create a trouble ticket in the incident management system.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correlatedAlarmTypes rdf:type rdf:Property ;
    rdfs:label 'Correlated Alarm Types' ;
    rdfs:comment 'Comma-separated list of alarm types or event codes that are correlated with the trigger alarm. Used by alarm correlation rules to identify related or cascading alarms.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlationWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Correlation Window Minutes' ;
    rdfs:comment 'Time window in minutes within which correlated alarms must occur to be grouped together by this correlation rule.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionLogicDescription rdf:type rdf:Property ;
    rdfs:label 'Detection Logic Description' ;
    rdfs:comment 'Detailed textual description of the detection logic, correlation algorithm, threshold condition, or fraud pattern that this rule implements.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveRatePercent rdf:type rdf:Property ;
    rdfs:label 'False Positive Rate Percent' ;
    rdfs:comment 'Estimated or measured false positive rate for this detection rule, expressed as a percentage. Used to track and tune rule accuracy.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudType rdf:type rdf:Property ;
    rdfs:label 'Fraud Type' ;
    rdfs:comment 'Type of fraud or revenue leakage that this detection rule targets, such as subscription fraud, identity theft, SIM box fraud, international revenue share fraud, or usage anomaly. Applicable when rule_category is fraud_detection or revenue_leakage.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTunedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Tuned Timestamp' ;
    rdfs:comment 'Timestamp when this rule or threshold was last tuned, adjusted, or recalibrated based on performance analysis or operational feedback.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Minutes' ;
    rdfs:comment 'Time window in minutes over which the KPI measurement or event count is evaluated before comparing to the threshold. Used for sliding window and aggregation-based detection.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether breaches or detections triggered by this rule require immediate notification to operations teams or management.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Numeric priority level assigned to this rule for processing order or escalation routing. Lower numbers typically indicate higher priority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether breaches or detections triggered by this rule require reporting to regulatory authorities such as Federal Communications Commission (FCC) or International Telecommunication Union (ITU).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseDeterminationLogic rdf:type rdf:Property ;
    rdfs:label 'Root Cause Determination Logic' ;
    rdfs:comment 'Description of the logic or algorithm used to determine the root cause alarm from a set of correlated alarms. Applicable for alarm correlation rules.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Rule Identifier' ;
    rdfs:comment 'Externally-known unique code or identifier for this threshold or rule configuration, used for reference across assurance systems.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current operational status of the rule: active (in production use), inactive (disabled), testing (under evaluation), or deprecated (retired).' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether breaches detected by this rule have potential impact on customer Service Level Agreement (SLA) commitments.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Suppression Duration Minutes' ;
    rdfs:comment 'Duration in minutes for which subsequent alarms of the same type are suppressed after the initial alarm is raised. Applicable for alarm suppression rules.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Direction of threshold breach that triggers an alert: above (greater than), below (less than), equal, or not equal to the threshold value.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value, such as percent, milliseconds, Mbps, count, transactions per minute, or currency.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerAlarmType rdf:type rdf:Property ;
    rdfs:label 'Trigger Alarm Type' ;
    rdfs:comment 'Primary alarm type or event code that triggers this correlation or suppression rule. Applicable when rule_category is alarm_correlation or alarm_suppression.' ;
    rdfs:domain ind:KpiThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRecordId rdf:type rdf:Property ;
    rdfs:label 'Change Record Id' ;
    rdfs:comment 'Unique identifier for the change record in ServiceNow ITSM Change Management. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRecord .

ind:affectedNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Affected Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: Documents which specific equipment underwent maintenance change (firmware upgrade, configuration change, card replacement) for configuration management database, rollback procedures, and change succes' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:capitalProjectId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Id' ;
    rdfs:comment 'Foreign key linking to finance.capital_project. Business justification: Network changes often implement capital projects (new cell sites, fiber deployment, core network upgrades). Required for capex project tracking, asset capitalization timing, and project completion ver' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Planned network changes incur implementation costs (labor, testing, rollback resources) allocated to change management or network operations cost centers. Standard practice for change management cost ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:nocIncidentId rdf:type rdf:Property ;
    rdfs:label 'Noc Incident Id' ;
    rdfs:comment 'Foreign key linking to assurance.noc_incident. Business justification: Change records can be linked to NOC incidents when a planned change triggers or is related to an operational incident. This is N:1 (many changes can relate to one NOC incident). The FK column does not' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocIncident .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Network changes implemented to comply with new regulations: spectrum rule changes, security mandates (STIR/SHAKEN), privacy requirements (CPNI protection). Links change record to regulatory change for' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:relatedProblemProblemRecordId rdf:type rdf:Property ;
    rdfs:label 'Related Problem Problem Record Id' ;
    rdfs:comment 'Problem record ID in ServiceNow ITSM that this change addresses. Links corrective changes to root cause analysis and problem management process.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProblemRecord .

ind:actualDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Downtime Minutes' ;
    rdfs:comment 'Actual duration of service downtime or degradation in minutes during change implementation. Used for variance analysis, SLA breach calculation, and change success metrics.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the change implementation completed. Used for maintenance window compliance tracking and post-implementation review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the change implementation began. Used for variance analysis against planned schedule and accurate SLA exclusion tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedGeography rdf:type rdf:Property ;
    rdfs:label 'Affected Geography' ;
    rdfs:comment 'Geographic region, market, or site affected by this change (e.g., \'Northeast Region\', \'Site-NYC-001\', \'National\'). Used for customer notification targeting and regional SLA tracking.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedNetworkElement rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element' ;
    rdfs:comment 'Specific network element, node, or equipment identifier impacted by this change (e.g., eNodeB ID, BNG hostname, OLT serial number). May reference multiple elements separated by delimiters.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedService rdf:type rdf:Property ;
    rdfs:label 'Affected Service' ;
    rdfs:comment 'Service or service group impacted by this change (e.g., \'Mobile Data\', \'VoLTE\', \'IPTV\', \'Enterprise MPLS\'). Used to identify customer-facing impact and SLA applicability.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the individual or CAB (Change Advisory Board) member who approved this change. For emergency changes, may be the on-call manager or executive authority.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Organizational role or title of the approver (e.g., \'CAB Chair\', \'Network Operations Manager\', \'CTO\', \'Emergency Change Authority\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale for the change including expected benefits, regulatory requirements, customer commitments, or strategic initiatives. Used for CAB approval and investment prioritization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Network domain or system category affected by this change. RAN (Radio Access Network), transport (MPLS/SD-WAN), core (IMS/EPC/5GC), BSS (Business Support Systems), OSS (Operations Support Systems), CPE (Customer Premises Equipment), fiber (FTTH/GPON), backhaul (microwave/fiber transport). [ENUM-REF-CANDIDATE: RAN|transport|core|BSS|OSS|CPE|fiber|backhaul — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed description of the change including technical scope, implementation steps, and business justification. Captures what will be changed, why, and how.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Human-readable unique change identifier assigned by ServiceNow ITSM. Used for external communication and tracking (e.g., CHG0012345).' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changePriority rdf:type rdf:Property ;
    rdfs:label 'Change Priority' ;
    rdfs:comment 'Business priority of the change based on urgency and impact. Critical priority changes receive expedited approval and implementation. Used for resource allocation and scheduling decisions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the change record. Tracks progression from initial draft through CAB approval, implementation, and closure. Failed status indicates unsuccessful implementation; rolled-back indicates reversal to previous state. [ENUM-REF-CANDIDATE: draft|submitted|approved|scheduled|in-progress|completed|failed|rolled-back|cancelled|closed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the purpose and scope of the change (e.g., \'Upgrade RAN software to v21.3 in Northeast region\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change based on urgency, risk, and approval requirements. Standard changes are pre-approved low-risk changes; normal changes require CAB approval; emergency changes bypass normal approval for critical incidents. [ENUM-REF-CANDIDATE: standard|normal|emergency|maintenance-window|preventive|corrective|upgrade|capacity-expansion — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationItemIds rdf:type rdf:Property ;
    rdfs:label 'Configuration Item Ids' ;
    rdfs:comment 'Comma-separated list of Configuration Item (CI) IDs from ServiceNow CMDB that are modified by this change. Links change records to specific network elements, software versions, and infrastructure components.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether advance notification was sent to affected customers about this planned change. Required for customer-impacting changes per regulatory and contractual obligations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCustomerImpactCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Customer Impact Count' ;
    rdfs:comment 'Estimated number of customers (subscribers or accounts) potentially affected by this change. Used for risk assessment and customer notification scope determination.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Minutes' ;
    rdfs:comment 'Estimated duration of service downtime or degradation in minutes during change implementation. Used for customer notification, SLA impact assessment, and maintenance window planning.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Detailed assessment of potential impact including affected services, customer segments, geographic regions, and estimated downtime. Used for CAB (Change Advisory Board) review and approval decisions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementerName rdf:type rdf:Property ;
    rdfs:label 'Implementer Name' ;
    rdfs:comment 'Name of the engineer, technician, or team responsible for executing the change. May be internal staff or vendor personnel.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementerTeam rdf:type rdf:Property ;
    rdfs:label 'Implementer Team' ;
    rdfs:comment 'Organizational team or department responsible for change implementation (e.g., \'RAN Engineering\', \'NOC Operations\', \'Vendor Field Services\').' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Code' ;
    rdfs:comment 'Reference code for the approved maintenance window during which this change is scheduled. Links to predefined maintenance calendar for recurring maintenance periods.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Communication channel used to notify customers about the planned change (e.g., email, SMS, IVR call, mobile app push notification, web portal banner).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when customer notification was sent. Used to verify compliance with advance notice requirements (typically 24-72 hours before planned maintenance).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pirNotes rdf:type rdf:Property ;
    rdfs:label 'Pir Notes' ;
    rdfs:comment 'Detailed notes from the post-implementation review including lessons learned, issues encountered, and recommendations for future similar changes.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled date and time when the change implementation is planned to complete. Used for maintenance window duration calculation and SLA exclusion period definition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when the change implementation is planned to begin. Used for maintenance window scheduling and customer notification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postImplementationReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Post Implementation Review Outcome' ;
    rdfs:comment 'Result of the post-implementation review assessing whether the change achieved its objectives without adverse impact. Successful-with-issues indicates minor problems that were resolved. Used for continuous improvement and change success rate KPIs.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedIncidentIds rdf:type rdf:Property ;
    rdfs:label 'Related Incident Ids' ;
    rdfs:comment 'Comma-separated list of NOC incident IDs that triggered or are related to this change. Used for correlating reactive changes with network incidents and alarm spikes.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessed risk level of the change based on potential impact to service availability, customer experience, and revenue. Critical risk changes require executive approval and extensive rollback planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Executed Flag' ;
    rdfs:comment 'Indicates whether the rollback plan was executed due to change failure or adverse impact. Used for change success rate tracking and root cause analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackPlanDocumentedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan Documented Flag' ;
    rdfs:comment 'Indicates whether a detailed rollback plan has been documented and approved as part of the change request. Required for high-risk and critical-risk changes.' ;
    rdfs:domain ind:ChangeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Exclusion Flag' ;
    rdfs:comment 'Indicates whether downtime or performance degradation during this change is excluded from SLA breach calculations. True for approved maintenance windows; false for emergency changes or changes that exceeded planned duration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Involved Flag' ;
    rdfs:comment 'Indicates whether external vendor or equipment manufacturer personnel are involved in implementing this change. Used for coordination and accountability tracking.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorTicketReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Ticket Reference' ;
    rdfs:comment 'External ticket or case number in the vendor\'s system associated with this change. Used for cross-system tracking and vendor SLA management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAlertId rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Id' ;
    rdfs:comment 'Unique identifier for the fraud alert record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudAlert .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: Real-time fraud alerts trigger on account-level anomalies (unusual spend spikes, payment method changes, velocity attacks). Operational fraud prevention requires immediate account context for blocking' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key to the formal fraud investigation case if this alert was escalated. Null if alert was closed without escalation or is still under initial review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:vodAssetId rdf:type rdf:Property ;
    rdfs:label 'Vod Asset Id' ;
    rdfs:comment 'Foreign key linking to content.vod_asset. Business justification: Real-time fraud detection for abnormal viewing patterns (credential sharing, concurrent stream violations, VPN/proxy abuse) on high-value assets (premium movies, live sports) requires asset-level aler' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VodAsset .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Description of the immediate remediation action taken in response to the alert, such as service suspension, account barring, SIM deactivation, transaction reversal, or customer notification.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual observed value that triggered the alert, such as the number of calls made, total charge amount, or data volume consumed during the detection window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedImei rdf:type rdf:Property ;
    rdfs:label 'Affected Imei' ;
    rdfs:comment 'The IMEI of the device used during the suspected fraudulent activity, enabling device-level tracking and blacklisting. Personally identifiable device information.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedImsi rdf:type rdf:Property ;
    rdfs:label 'Affected Imsi' ;
    rdfs:comment 'The IMSI associated with the subscriber at the time of the alert, used to uniquely identify the subscriber on the network. Personally identifiable information.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMsisdn rdf:type rdf:Property ;
    rdfs:label 'Affected Msisdn' ;
    rdfs:comment 'The mobile phone number (MSISDN) on which the suspicious activity was detected. Personally identifiable information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Timestamp when the alert record was created in the fraud management system, may differ slightly from detection_timestamp due to processing latency.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Human-readable business identifier for the fraud alert, typically formatted as FA- followed by a 10-digit sequence number.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertPriority rdf:type rdf:Property ;
    rdfs:label 'Alert Priority' ;
    rdfs:comment 'Business priority assigned to the alert for queue management and resource allocation, distinct from severity which reflects technical risk.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the fraud alert: new (unreviewed), acknowledged (assigned to analyst), investigating (under review), escalated (promoted to fraud case), closed (resolved), false-positive (dismissed as non-fraud).' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTriggerType rdf:type rdf:Property ;
    rdfs:label 'Alert Trigger Type' ;
    rdfs:comment 'Category of fraud detection trigger that generated the alert: velocity (rapid usage), threshold (limit breach), pattern (behavioral anomaly), blacklist (known fraud entity), anomaly (statistical outlier), or geo-location (impossible travel).' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes entered by the fraud analyst during alert review, documenting findings, rationale for decisions, and any additional context.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the fraud operations team or SOC (Security Operations Center) shift responsible for this alert, such as Fraud-Tier1, SOC-EMEA, Revenue-Assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the suspicious activity was detected, such as USA, GBR, DEU.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Timestamp when the fraud detection system identified the suspicious activity and generated the alert. Represents the real-world event time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Detection Window End' ;
    rdfs:comment 'End timestamp of the time window during which the fraud detection rule evaluated activity. Used for velocity and pattern-based rules.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionWindowStart rdf:type rdf:Property ;
    rdfs:label 'Detection Window Start' ;
    rdfs:comment 'Start timestamp of the time window during which the fraud detection rule evaluated activity. Used for velocity and pattern-based rules.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Timestamp when the alert was escalated to a formal fraud case for investigation. Null if not escalated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Boolean flag indicating whether the alert was determined to be a false positive after analyst review. True if false positive, False if genuine fraud or still under investigation.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudCategory rdf:type rdf:Property ;
    rdfs:label 'Fraud Category' ;
    rdfs:comment 'High-level category grouping fraud types for reporting and analytics: revenue-assurance (billing/charging fraud), network-abuse (traffic pumping, toll fraud), identity-fraud (account takeover, SIM swap), device-fraud (cloning, IMEI manipulation), roaming-fraud, content-fraud (premium SMS, OTT abuse).' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAlertIds rdf:type rdf:Property ;
    rdfs:label 'Related Alert Ids' ;
    rdfs:comment 'Comma-separated list of related fraud alert IDs that are part of the same fraud pattern or campaign, enabling correlation analysis.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk score (0-100) combining fraud likelihood, potential financial impact, and subscriber risk profile. Used for prioritization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemAlertReference rdf:type rdf:Property ;
    rdfs:label 'Source System Alert Reference' ;
    rdfs:comment 'Native alert identifier from the originating fraud detection system, used for traceability and cross-system reconciliation.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Affected Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: When fraud_type=\'DEVICE_CLONING\' or \'MAC_SPOOFING\', links fraudulent activity to specific CPE MAC addresses for device blacklisting, subscriber notification, and device security vulnerability analysis' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:affectedSimStockId rdf:type rdf:Property ;
    rdfs:label 'Affected Sim Stock Id' ;
    rdfs:comment 'Foreign key linking to inventory.sim_stock. Business justification: Tracks which SIM cards are involved in SIM swap fraud, cloning, or IRSF attacks for inventory quarantine, EIR blacklisting, and fraud pattern analysis by SIM batch/manufacturer.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SimStock .

ind:affectedSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Affected Subscriber Id' ;
    rdfs:comment 'Unique identifier of the subscriber account impacted by the fraud incident.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:dataBreachIncidentId rdf:type rdf:Property ;
    rdfs:label 'Data Breach Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_breach_incident. Business justification: Fraud investigations (account takeover, SIM swap, subscription fraud) often uncover data breaches or are caused by breaches. Links fraud case to breach record for root cause analysis, regulatory repor' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataBreachIncident .

ind:dealerId rdf:type rdf:Property ;
    rdfs:label 'Dealer Id' ;
    rdfs:comment 'Foreign key linking to partner.dealer. Business justification: Dealer fraud cases (activation fraud, identity theft, SIM swap fraud) require dealer attribution for investigation, compliance enforcement, dealer termination decisions, and fraud loss recovery from d' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealer .

ind:deviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Device Registration Id' ;
    rdfs:comment 'Foreign key linking to customer.device_registration. Business justification: Device-based fraud (IMEI cloning, stolen devices) requires linking fraud cases to registered devices for investigation, CEIR blocking, and device blacklisting. Real business process: device fraud inve' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:fraudLossGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Fraud Loss General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Confirmed fraud losses post to specific GL accounts (bad debt expense, fraud loss reserve, revenue write-offs). Required for accurate financial reporting, fraud loss provisioning, and regulatory compl' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:fraudPatternId rdf:type rdf:Property ;
    rdfs:label 'Fraud Pattern Id' ;
    rdfs:comment 'Reference to a known fraud pattern or signature that matches the characteristics of this case for trend analysis.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudPattern .

ind:investigationCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Investigation Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Fraud investigation costs (analyst time, forensic tools, legal fees) are allocated to fraud management cost centers. Essential for fraud operations budgeting and cost-benefit analysis of fraud prevent' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:lawfulInterceptOrderId rdf:type rdf:Property ;
    rdfs:label 'Lawful Intercept Order Id' ;
    rdfs:comment 'Foreign key linking to compliance.lawful_intercept_order. Business justification: Fraud cases may trigger law enforcement requests for lawful intercepts to investigate criminal activity (fraud rings, identity theft). Links fraud investigation to intercept order for legal compliance' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LawfulInterceptOrder .

ind:roamingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Roaming Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_roaming_agreement. Business justification: Roaming fraud cases (IRSF, SIM box fraud, bypass fraud) require roaming agreement linkage for liability determination, fraud threshold enforcement, settlement disputes, and potential agreement termina' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoamingAgreement .

ind:svcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Svc Instance Id' ;
    rdfs:comment 'Unique identifier of the telecommunications service instance impacted by the fraud activity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:alertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Timestamp' ;
    rdfs:comment 'Date and time when the fraud detection system generated the initial alert that led to case creation.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Closed Timestamp' ;
    rdfs:comment 'Date and time when the fraud case was formally closed after investigation completion and resolution.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Business-facing unique case number assigned to the fraud investigation for external reference and tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Opened Timestamp' ;
    rdfs:comment 'Date and time when the fraud case was formally opened and assigned for investigation.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Business priority assigned to the fraud case based on severity, financial impact, and urgency for investigation and resolution.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the fraud case indicating investigation progress and resolution state.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedFraudLossAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Fraud Loss Amount' ;
    rdfs:comment 'Verified and confirmed financial loss amount after investigation completion and validation of fraudulent activity.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionRuleReference rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Reference' ;
    rdfs:comment 'Reference identifier for the specific fraud detection rule, algorithm, or model that triggered the alert.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin system or channel that initially detected and raised the fraud alert triggering case creation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFraudLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fraud Loss Amount' ;
    rdfs:comment 'Initial estimated financial loss amount attributed to the fraud incident at the time of detection, before investigation confirmation.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceReferences rdf:type rdf:Property ;
    rdfs:label 'Evidence References' ;
    rdfs:comment 'References to supporting evidence documents, call detail records (CDR), logs, screenshots, or other artifacts collected during investigation.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Confidence Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the likelihood that the detected activity is genuine fraud based on detection algorithms and investigation findings.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudSubtype rdf:type rdf:Property ;
    rdfs:label 'Fraud Subtype' ;
    rdfs:comment 'Detailed subclassification within the primary fraud type for granular categorization and pattern analysis.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Detailed narrative notes documenting investigation activities, findings, interviews, and analysis performed during the fraud case lifecycle.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'Name of the law enforcement agency or department to which the fraud case was referred.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'External case or incident number assigned by the law enforcement agency for tracking the criminal investigation.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Flag' ;
    rdfs:comment 'Indicates whether the fraud case has been referred to law enforcement authorities for criminal investigation and prosecution.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReferralTimestamp rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Referral Timestamp' ;
    rdfs:comment 'Date and time when the fraud case was formally referred to law enforcement agencies.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preventiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Taken' ;
    rdfs:comment 'Description of preventive measures or controls implemented as a result of this fraud case to prevent future similar incidents.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Total amount successfully recovered from the fraudster or through insurance claims and chargebacks.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'Method or mechanism used to recover financial losses from the fraud incident.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedCaseIds rdf:type rdf:Property ;
    rdfs:label 'Related Case Ids' ;
    rdfs:comment 'Comma-separated list of related fraud case IDs that are linked to this case through common perpetrators, patterns, or coordinated attacks.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the identified root cause and contributing factors that allowed the fraud to occur.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPopFacilityId rdf:type rdf:Property ;
    rdfs:label 'Affected Pop Facility Id' ;
    rdfs:comment 'Foreign key linking to inventory.pop_facility. Business justification: Tracks which network facility is incident command center or primary affected site for major incident management, war room coordination, and facility-level incident pattern analysis.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopFacility .

ind:primaryNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Primary Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Major incidents must identify the primary affected network element for vendor escalation, spare parts logistics, and post-incident review. Core NOC operational requirement for incident command and res' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Major outages trigger regulatory reporting obligations (FCC Part 4 outage reporting, EU NIS Directive incident notification). NOC teams must identify which incidents require regulatory filings and tra' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:declaredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Declared Timestamp' ;
    rdfs:comment 'Date and time when the incident was officially declared by NOC/SOC operations, marking the start of the incident lifecycle.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Customer Count' ;
    rdfs:comment 'Estimated number of customers affected by the incident, used for impact assessment and prioritization.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactedGeography rdf:type rdf:Property ;
    rdfs:label 'Impacted Geography' ;
    rdfs:comment 'Geographic region, market, or service area affected by the incident (e.g., Northeast Region, Metro Atlanta, California Central Coast).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedNetworkElements rdf:type rdf:Property ;
    rdfs:label 'Impacted Network Elements' ;
    rdfs:comment 'List of network infrastructure components affected by the incident (e.g., RAN sites, core routers, OLT devices, BNG gateways).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedServicesList rdf:type rdf:Property ;
    rdfs:label 'Impacted Services List' ;
    rdfs:comment 'Comma-separated list of service types or service identifiers affected by the incident (e.g., LTE Data, VoLTE, IPTV, Broadband, 5G NR).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'Operational categorization of the incident based on service impact pattern (complete outage, performance degradation, security compromise, capacity constraint, or maintenance-related event).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCommander rdf:type rdf:Property ;
    rdfs:label 'Incident Commander' ;
    rdfs:comment 'Name or identifier of the NOC/SOC personnel assigned as the incident commander responsible for coordinating response and resolution activities.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known unique incident identifier used for tracking and communication across NOC/SOC teams and stakeholders.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentPriority rdf:type rdf:Property ;
    rdfs:label 'Incident Priority' ;
    rdfs:comment 'Operational priority assigned to the incident based on severity and business impact, determining resource allocation and response time targets (P1=highest, P4=lowest).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSource rdf:type rdf:Property ;
    rdfs:label 'Incident Source' ;
    rdfs:comment 'Origin or detection method through which the incident was first identified (automated monitoring, customer complaint, field observation, proactive analysis, or vendor alert).' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident within the NOC/SOC operational workflow.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the incident based on the nature of the operational event (e.g., network outage, DDoS attack, power failure, fiber cut, environmental hazard, hardware failure).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttrMinutes rdf:type rdf:Property ;
    rdfs:label 'Mttr Minutes' ;
    rdfs:comment 'Calculated time in minutes from incident declaration to resolution, used as a key performance indicator for operational efficiency.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocShift rdf:type rdf:Property ;
    rdfs:label 'Noc Shift' ;
    rdfs:comment 'NOC operational shift during which the incident was declared, used for staffing analysis and shift performance metrics.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postIncidentReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Flag' ;
    rdfs:comment 'Indicates whether a formal post-incident review (PIR) is required or has been completed for this incident, typically mandated for high-severity or customer-impacting events.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rcaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Rca Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the formal RCA document or post-incident review report stored in the document management system.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAlarmIds rdf:type rdf:Property ;
    rdfs:label 'Related Alarm Ids' ;
    rdfs:comment 'Comma-separated list of network alarm identifiers from Nokia NetAct, Ericsson NM, or other NMS/EMS systems that triggered or are associated with this incident.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTroubleTicketIds rdf:type rdf:Property ;
    rdfs:label 'Related Trouble Ticket Ids' ;
    rdfs:comment 'Comma-separated list of trouble ticket identifiers associated with this incident, representing individual customer complaints or network alarms that contributed to incident declaration.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvolved rdf:type rdf:Property ;
    rdfs:label 'Vendor Involved' ;
    rdfs:comment 'Name of the external vendor or equipment manufacturer involved in incident resolution (e.g., Nokia, Ericsson, Cisco, Juniper), if applicable.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warRoomBridgeNumber rdf:type rdf:Property ;
    rdfs:label 'War Room Bridge Number' ;
    rdfs:comment 'Conference bridge phone number or virtual meeting link used for real-time incident coordination and communication among response teams.' ;
    rdfs:domain ind:NocIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageRecordId rdf:type rdf:Property ;
    rdfs:label 'Outage Record Id' ;
    rdfs:comment 'Unique identifier for the outage record. Primary key for the outage event lifecycle tracking from detection through restoration and regulatory notification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutageRecord .

ind:affectedExchangeId rdf:type rdf:Property ;
    rdfs:label 'Affected Exchange Id' ;
    rdfs:comment 'Identifier of the central office or exchange affected by the outage for wireline and core network events.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exchange .

ind:customerAddressId rdf:type rdf:Property ;
    rdfs:label 'Customer Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Outages affect specific geographic areas. Linking to address enables customer impact identification by location, proactive notification to affected addresses, and service restoration prioritization. R' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Regulatory-reportable outages require invoice credits for affected customers. Links outage events to billing adjustments for revenue impact tracking, customer compensation, and regulatory compliance r' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:mvnoProfileId rdf:type rdf:Property ;
    rdfs:label 'Mvno Profile Id' ;
    rdfs:comment 'Foreign key linking to partner.mvno_profile. Business justification: Network outages affecting MVNO subscribers require MVNO profile linkage for regulatory reporting obligations, SLA breach calculation, and subscriber impact assessment per MVNO capacity and subscriber ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MvnoProfile .

ind:plannedOutageId rdf:type rdf:Property ;
    rdfs:label 'Planned Outage Id' ;
    rdfs:comment 'Foreign key linking to network.planned_outage. Business justification: Unplanned outages often require retrospective linkage to planned maintenance windows to determine if outage occurred during approved change window. Critical for regulatory reporting, root cause analys' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOutage .

ind:problemRecordId rdf:type rdf:Property ;
    rdfs:label 'Problem Record Id' ;
    rdfs:comment 'Foreign key linking to assurance.problem_record. Business justification: Outage records can be linked to problem records for root cause analysis. This is N:1 (many outages can be associated with one underlying problem). The FK column does not currently exist and will be cr' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProblemRecord .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Outages meeting regulatory thresholds (duration, customer impact) must be reported via formal filings to FCC, OFCOM, EU regulators. Links outage data to submitted filing for audit trail and compliance' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:responseCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Response Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Network outage response costs (emergency repairs, overtime, vendor callouts) are allocated to network operations cost centers. Required for outage cost tracking, MTTR cost analysis, and operational bu' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:affectedCellSiteIds rdf:type rdf:Property ;
    rdfs:label 'Affected Cell Site Ids' ;
    rdfs:comment 'Comma-separated list of cell site identifiers impacted by the outage for RAN-related events.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegion rdf:type rdf:Property ;
    rdfs:label 'Affected Region' ;
    rdfs:comment 'Regional classification of the outage footprint for operational and regulatory segmentation.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Sign Off Timestamp' ;
    rdfs:comment 'Timestamp when the compliance officer approved and signed off on the regulatory notification submission.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Timestamp when the first customer notification was sent regarding the outage event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactedBusinessCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Business Customer Count' ;
    rdfs:comment 'Number of business or enterprise customers affected by the outage, tracked separately for priority restoration and regulatory reporting.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Subscriber Count' ;
    rdfs:comment 'Total number of unique subscribers affected by the outage event. Key metric for regulatory threshold determination.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Due Timestamp' ;
    rdfs:comment 'Regulatory deadline timestamp by which the outage notification must be submitted to avoid compliance penalties.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Submission Timestamp' ;
    rdfs:comment 'Timestamp when the regulatory notification was officially submitted to the governing body.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Outage Cause Category' ;
    rdfs:comment 'Root cause classification for the outage event: hardware failure, software defect, power loss, fiber cut, weather event, or human error.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Outage Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause and contributing factors for the outage event.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Outage Duration Minutes' ;
    rdfs:comment 'Total duration of the outage event in minutes, calculated from start to end timestamp. Critical for SLA compliance and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage End Timestamp' ;
    rdfs:comment 'Timestamp when service was fully restored and the outage event was closed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageNumber rdf:type rdf:Property ;
    rdfs:label 'Outage Number' ;
    rdfs:comment 'Business-facing unique identifier for the outage event, used for external communication and regulatory reporting.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageSeverity rdf:type rdf:Property ;
    rdfs:label 'Outage Severity' ;
    rdfs:comment 'Severity classification of the outage event based on service impact, subscriber count, and business criticality.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outage Start Timestamp' ;
    rdfs:comment 'Timestamp when the outage event was first detected or when service disruption began.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageStatus rdf:type rdf:Property ;
    rdfs:label 'Outage Status' ;
    rdfs:comment 'Current lifecycle status of the outage record: detected, under investigation, restoration in progress, service restored, or record closed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageType rdf:type rdf:Property ;
    rdfs:label 'Outage Type' ;
    rdfs:comment 'Classification of the outage as planned maintenance or unplanned service disruption.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postOutageReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Outage Review Completed Flag' ;
    rdfs:comment 'Indicates whether the post-outage review and root cause analysis have been completed and documented.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postOutageReviewReference rdf:type rdf:Property ;
    rdfs:label 'Post Outage Review Reference' ;
    rdfs:comment 'Reference identifier or document link to the post-outage review report, root cause analysis, and preventive action plan.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Current status of the regulatory notification workflow: not required, draft in preparation, submitted to regulator, acknowledged by regulator, or closed.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number or case identifier assigned by the regulatory body upon submission of the outage notification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether the outage event meets regulatory reporting thresholds and must be reported to governing bodies.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportableThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Reportable Threshold Met' ;
    rdfs:comment 'Description of which regulatory threshold criteria were met: subscriber count threshold, duration threshold, service type threshold, or geographic scope threshold.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationMethod rdf:type rdf:Property ;
    rdfs:label 'Restoration Method' ;
    rdfs:comment 'Method used to restore service: automatic recovery, manual intervention, network failover, traffic bypass, equipment replacement, or on-site repair.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationPriority rdf:type rdf:Property ;
    rdfs:label 'Restoration Priority' ;
    rdfs:comment 'Priority level assigned to the restoration effort based on service impact, customer segment, and regulatory obligations.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationTeam rdf:type rdf:Property ;
    rdfs:label 'Restoration Team' ;
    rdfs:comment 'Name or identifier of the NOC team, field operations team, or vendor team responsible for service restoration.' ;
    rdfs:domain ind:OutageRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'Number of distinct SLA contracts breached as a result of this outage event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Performance Measurement Id' ;
    rdfs:comment 'Unique identifier for the performance measurement record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceMeasurement .

ind:measurementObjectNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Measurement Object Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: When measurement_object_type=\'EQUIPMENT\', links KPI data (port utilization, CPU, temperature) to specific routers/switches for capacity planning, fault correlation, and predictive maintenance in netwo' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:measurementObjectOltAssetId rdf:type rdf:Property ;
    rdfs:label 'Measurement Object Olt Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.olt_asset. Business justification: When measurement_object_type=\'OLT\', monitors PON port utilization, ONT count per port, and uplink bandwidth for fiber access network capacity management and OLT expansion planning.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OltAsset .

ind:measurementObjectOntAssetId rdf:type rdf:Property ;
    rdfs:label 'Measurement Object Ont Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.ont_asset. Business justification: When measurement_object_type=\'ONT\', tracks optical power levels, distance, and bandwidth utilization per ONT for GPON network quality assurance and proactive maintenance of fiber access infrastructure' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:monitoringCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Network performance monitoring infrastructure costs (probes, analytics platforms, OSS licenses) are allocated to network operations or assurance cost centers. Required for monitoring infrastructure co' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:spectrumLicenseId rdf:type rdf:Property ;
    rdfs:label 'Spectrum License Id' ;
    rdfs:comment 'Foreign key linking to compliance.spectrum_license. Business justification: Performance measurements validate spectrum license compliance: utilization thresholds (build-out requirements), interference limits, coverage obligations. Regulators audit spectrum usage; measurements' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpectrumLicense .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Computed availability percentage for the measurement object during the measurement interval. Derived from uptime and downtime measurements. Used for SLA compliance reporting.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Timestamp when the measurement record was collected and ingested into the data platform from the source OSS/EMS/NMS system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'Percentage deviation of the measurement value from the baseline value. Positive indicates above baseline; negative indicates below baseline. Used for trend analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement End Timestamp' ;
    rdfs:comment 'End timestamp of the measurement interval window. Defines the conclusion of the period over which the KPI was computed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementIntervalType rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Type' ;
    rdfs:comment 'Time granularity at which the measurement was aggregated: 15-minute, 1-hour, 24-hour, or real-time. Aligns with standard OSS collection intervals.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementObjectReference rdf:type rdf:Property ;
    rdfs:label 'Measurement Object Reference' ;
    rdfs:comment 'Unique identifier of the network element being measured (cell, link, node, shelf, port, or other infrastructure component). Maps to the physical or logical resource in the network inventory.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementObjectType rdf:type rdf:Property ;
    rdfs:label 'Measurement Object Type' ;
    rdfs:comment 'Type of network element being measured. Categorizes the infrastructure layer at which the KPI was collected.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReliabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Reliability Flag' ;
    rdfs:comment 'Boolean indicator of whether the measurement is considered reliable for reporting and analytics. False indicates the measurement should be excluded from SLA calculations.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'Name of the source system from which the measurement was collected (e.g., Nokia NetAct, Ericsson Network Manager, generic NMS/EMS/OSS).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System Code' ;
    rdfs:comment 'Unique identifier or instance ID of the source system. Enables traceability back to the originating OSS/EMS/NMS instance.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Timestamp' ;
    rdfs:comment 'Start timestamp of the measurement interval window. Defines the beginning of the period over which the KPI was computed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the measurement value (e.g., dBm, Mbps, ms, percent, count, ratio). Essential for correct interpretation and threshold comparison.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'Raw numeric value of the performance measurement as collected from the network element. Unit of measure is specified in measurement_unit.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdBreachSeverity rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Severity' ;
    rdfs:comment 'Severity level of the threshold breach if threshold_breach_flag is True. Aligns with alarm severity classifications in fault management systems.' ;
    rdfs:domain ind:PerformanceMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Recurring problems identified in compliance audits as control weaknesses (e.g., repeated outages due to inadequate change management). Links problem record to audit finding for remediation tracking an' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Estimated number of customers impacted by incidents related to this problem. Quantifies business impact and supports prioritization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedNetworkDomain rdf:type rdf:Property ;
    rdfs:label 'Affected Network Domain' ;
    rdfs:comment 'Network domain or technology layer impacted by the problem (e.g., RAN, Core, Transport, BSS, OSS). Enables domain-specific problem analysis and MTBF tracking.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Affected Technology Type' ;
    rdfs:comment 'Specific technology or platform affected by the problem (e.g., 5G NR, LTE, FTTH, GPON, IMS, VoLTE). Supports technology-specific root cause analysis.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedProblemManager rdf:type rdf:Property ;
    rdfs:label 'Assigned Problem Manager' ;
    rdfs:comment 'Name or identifier of the problem manager responsible for investigating and resolving this problem. Establishes accountability for problem resolution.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identified Timestamp' ;
    rdfs:comment 'Date and time when the problem was first identified and the problem record was created. Marks the start of the problem investigation lifecycle.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impact rdf:type rdf:Property ;
    rdfs:label 'Impact' ;
    rdfs:comment 'Assessment of the business impact scope of the problem. Measures the extent of service degradation or customer affect.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Investigation Duration Hours' ;
    rdfs:comment 'Total time in hours spent investigating the problem from identification to root cause determination. Used for problem management efficiency KPIs.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kedbArticleReference rdf:type rdf:Property ;
    rdfs:label 'Kedb Article Reference' ;
    rdfs:comment 'Reference identifier or URL to the KEDB article documenting this known error. Provides link to detailed knowledge base entry.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownErrorFlag rdf:type rdf:Property ;
    rdfs:label 'Known Error Flag' ;
    rdfs:comment 'Indicates whether this problem has been documented in the Known Error Database. True when root cause is identified and workaround is available.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedAlarmIds rdf:type rdf:Property ;
    rdfs:label 'Linked Alarm Ids' ;
    rdfs:comment 'Comma-separated list of alarm event IDs associated with this problem. Connects network alarms to problem investigation for correlation analysis.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedIncidentIds rdf:type rdf:Property ;
    rdfs:label 'Linked Incident Ids' ;
    rdfs:comment 'Comma-separated list of incident IDs or trouble ticket IDs that are related to this problem. Establishes traceability between recurring incidents and their root cause.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanentFixDescription rdf:type rdf:Property ;
    rdfs:label 'Permanent Fix Description' ;
    rdfs:comment 'Description of the permanent solution implemented to eliminate the root cause. Documents the change or remediation that resolves the problem.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemCategory rdf:type rdf:Property ;
    rdfs:label 'Problem Category' ;
    rdfs:comment 'High-level categorization of the problem type. Used for classification and routing to appropriate problem management teams.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Detailed description of the problem, including symptoms, impact, and context. Provides comprehensive understanding of the issue under investigation.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemNumber rdf:type rdf:Property ;
    rdfs:label 'Problem Number' ;
    rdfs:comment 'Human-readable business identifier for the problem record, typically following ServiceNow PRB format (e.g., PRB0001234). Used for external communication and tracking.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemStatus rdf:type rdf:Property ;
    rdfs:label 'Problem Status' ;
    rdfs:comment 'Current lifecycle state of the problem record. Tracks progression from identification through resolution and closure. [ENUM-REF-CANDIDATE: new|open|in_progress|known_error|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemSubcategory rdf:type rdf:Property ;
    rdfs:label 'Problem Subcategory' ;
    rdfs:comment 'Detailed subcategory providing granular classification within the problem category. Enables precise problem taxonomy and trend analysis.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemTitle rdf:type rdf:Property ;
    rdfs:label 'Problem Title' ;
    rdfs:comment 'Short descriptive title summarizing the problem being investigated. Provides quick identification of the problem nature.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedChangeRequestIds rdf:type rdf:Property ;
    rdfs:label 'Related Change Request Ids' ;
    rdfs:comment 'Comma-separated list of change request IDs associated with implementing the permanent fix. Links problem resolution to change management process.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Hours' ;
    rdfs:comment 'Total time in hours from problem identification to permanent fix implementation. Measures end-to-end problem resolution efficiency.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified Timestamp' ;
    rdfs:comment 'Date and time when the root cause was successfully identified. Marks transition to known error status and enables MTTR calculation.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteIds rdf:type rdf:Property ;
    rdfs:label 'Site Ids' ;
    rdfs:comment 'Comma-separated list of network site IDs affected by this problem. Links problem to specific physical infrastructure locations.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgency rdf:type rdf:Property ;
    rdfs:label 'Urgency' ;
    rdfs:comment 'Time sensitivity of the problem resolution. Indicates how quickly the problem must be addressed to prevent further incidents.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Temporary solution or procedure to mitigate the problem impact while permanent fix is being developed. Enables incident teams to reduce service disruption.' ;
    rdfs:domain ind:ProblemRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Qos Measurement Id' ;
    rdfs:comment 'Unique identifier for the QoS measurement record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QosMeasurement .

ind:cellId rdf:type rdf:Property ;
    rdfs:label 'Cell Id' ;
    rdfs:comment 'The identifier of the radio cell serving the subscriber at the time of measurement, applicable to mobile services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RanCell .

ind:measuredCpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Measured Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: Links QoS measurements (throughput, latency, packet loss, MOS) to specific customer equipment for device performance analysis, WiFi 6 upgrade targeting, and correlation of service quality with device ' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:slaProfileId rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Id' ;
    rdfs:comment 'Foreign key linking to service.sla_profile. Business justification: QoS measurements validate compliance against contracted SLA performance thresholds. Essential for proactive breach detection, customer reporting, and demonstrating service level achievement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaProfile .

ind:applicationCategory rdf:type rdf:Property ;
    rdfs:label 'Application Category' ;
    rdfs:comment 'The category of application or service being used during this measurement, as identified by DPI or traffic analysis (e.g., video_streaming, web_browsing, gaming, voip, social_media).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bearerType rdf:type rdf:Property ;
    rdfs:label 'Bearer Type' ;
    rdfs:comment 'The type of service bearer being measured: voice (circuit-switched), data (packet-switched), video (streaming), VoLTE (Voice over LTE), IMS (IP Multimedia Subsystem), or 5G network slice.' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity level of the SLA breach if one occurred: minor (slight deviation), major (significant impact), or critical (severe service degradation).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer segment to which the subscriber belongs: consumer (residential), SOHO (Small Office/Home Office), SME (Small/Medium Enterprise), enterprise (large business), wholesale (carrier/MVNO), or government.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downlinkThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Downlink Throughput Mbps' ;
    rdfs:comment 'Measured downlink (network to subscriber) data throughput in megabits per second (Mbps).' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dscpMarking rdf:type rdf:Property ;
    rdfs:label 'Dscp Marking' ;
    rdfs:comment 'The DSCP value applied to IP packets for QoS prioritization in the transport network (e.g., EF, AF41, BE).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jitterMs rdf:type rdf:Property ;
    rdfs:label 'Jitter Ms' ;
    rdfs:comment 'Measured packet delay variation (jitter) in milliseconds (ms), indicating consistency of packet arrival times.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Measured round-trip latency in milliseconds (ms) for packet transmission, representing delay experienced by the subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Seconds' ;
    rdfs:comment 'The duration in seconds over which this QoS measurement was aggregated or sampled (e.g., 60 for 1-minute interval, 300 for 5-minute interval).' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The system or method that captured this QoS measurement: DPI (Deep Packet Inspection), network probe, PCRF (Policy and Charging Rules Function), active testing system, RAN (Radio Access Network) analytics, or OSS (Operations Support Systems).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mosScore rdf:type rdf:Property ;
    rdfs:label 'Mos Score' ;
    rdfs:comment 'Mean Opinion Score for voice quality, ranging from 1.0 (poor) to 5.0 (excellent). Applicable to voice and VoLTE bearer types.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTechnology rdf:type rdf:Property ;
    rdfs:label 'Network Technology' ;
    rdfs:comment 'The underlying network technology delivering the service: 2G, 3G, 4G LTE, 5G NR (New Radio), FTTH (Fiber to the Home), GPON (Gigabit Passive Optical Network), DSL, cable, or satellite. [ENUM-REF-CANDIDATE: 2g|3g|4g_lte|5g_nr|ftth|gpon|dsl|cable|satellite — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetLossPercent rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Percent' ;
    rdfs:comment 'Percentage of packets lost during transmission, a key indicator of network congestion or quality degradation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qci5qiValue rdf:type rdf:Property ;
    rdfs:label 'Qci 5qi Value' ;
    rdfs:comment 'The QoS Class Identifier (QCI) for LTE or 5G QoS Identifier (5QI) for 5G networks, defining the bearer-level QoS treatment (e.g., 1=conversational voice, 5=IMS signaling, 9=default bearer).' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qosPolicyApplied rdf:type rdf:Property ;
    rdfs:label 'Qos Policy Applied' ;
    rdfs:comment 'The name or identifier of the QoS policy rule applied to this service instance at the time of measurement (e.g., premium_data_policy, video_optimization_policy).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this QoS measurement must be included in regulatory QoS reporting to governing bodies (e.g., FCC, Ofcom).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalQualityDb rdf:type rdf:Property ;
    rdfs:label 'Signal Quality Db' ;
    rdfs:comment 'Measured signal-to-noise ratio or signal quality in decibels (dB), indicating the clarity of the radio signal for wireless services.' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Measured radio signal strength in decibels relative to one milliwatt (dBm) at the subscriber device, applicable to wireless services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputMbps rdf:type rdf:Property ;
    rdfs:label 'Throughput Mbps' ;
    rdfs:comment 'Measured data throughput in megabits per second (Mbps) experienced by the subscriber during this measurement interval.' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uplinkThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Uplink Throughput Mbps' ;
    rdfs:comment 'Measured uplink (subscriber to network) data throughput in megabits per second (Mbps).' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoResolutionAchieved rdf:type rdf:Property ;
    rdfs:label 'Video Resolution Achieved' ;
    rdfs:comment 'The actual video resolution delivered to the subscriber: SD (Standard Definition), HD (720p), Full HD (1080p), 4K (2160p), or 8K (4320p).' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoStallRatePercent rdf:type rdf:Property ;
    rdfs:label 'Video Stall Rate Percent' ;
    rdfs:comment 'Percentage of video playback time affected by buffering or stalling events. Applicable to video and IPTV services.' ;
    rdfs:domain ind:QosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationRunId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Run Id' ;
    rdfs:comment 'Unique identifier for the revenue assurance reconciliation execution run. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReconciliationRun .

ind:affectedIpAddressPoolId rdf:type rdf:Property ;
    rdfs:label 'Affected Ip Address Pool Id' ;
    rdfs:comment 'Foreign key linking to inventory.ip_address_pool. Business justification: When control_type=\'IP_ALLOCATION\', reconciles IP address assignments between IPAM and service activation systems to detect IP exhaustion, prevent conflicts, and ensure accurate CGNAT pool utilization ' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:affectedMsisdnRangeId rdf:type rdf:Property ;
    rdfs:label 'Affected Msisdn Range Id' ;
    rdfs:comment 'Foreign key linking to inventory.msisdn_range. Business justification: When control_type=\'NUMBER_INVENTORY\', validates MSISDN allocation records against billing/HLR systems for revenue assurance, identifies ghost numbers, and ensures regulatory number utilization reporti' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsisdnRange .

ind:primaryReconciliationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reconciliation Employee Id' ;
    rdfs:comment 'Identifier of the revenue assurance analyst assigned to review and resolve discrepancies from this reconciliation run.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourcePipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Source Pipeline Run Id' ;
    rdfs:comment 'Foreign key linking to analytics.pipeline_run. Business justification: Reconciliation runs ARE data pipeline executions. Real-world revenue assurance systems track which ETL pipeline run produced reconciliation results for data lineage, troubleshooting, and SLA complianc' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRun .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this reconciliation run requires management approval before resolution actions can be executed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the reconciliation run results were formally approved by authorized personnel.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdrFileReferences rdf:type rdf:Property ;
    rdfs:label 'Cdr File References' ;
    rdfs:comment 'Comma-separated list or reference identifiers of CDR files processed during this reconciliation run.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCategory rdf:type rdf:Property ;
    rdfs:label 'Control Category' ;
    rdfs:comment 'Category of the revenue assurance control defining the type of reconciliation being performed.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Name of the revenue assurance control being executed in this reconciliation run (e.g., CDR Completeness Check, Rating Accuracy Validation).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Type of control execution indicating whether the reconciliation is fully automated, manual, or a hybrid approach requiring both system and human intervention.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Description' ;
    rdfs:comment 'Detailed description of the detection rule or logic applied during this reconciliation run to identify discrepancies, mismatches, or anomalies.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total discrepancy amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'Total number of individual discrepancies identified during this reconciliation run, representing line-level mismatches or anomalies.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:duplicateRecordCount rdf:type rdf:Property ;
    rdfs:label 'Duplicate Record Count' ;
    rdfs:comment 'Number of duplicate records identified during reconciliation, which may indicate data quality issues or system errors.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Matched Record Count' ;
    rdfs:comment 'Number of records that successfully matched between source and target systems with no discrepancies detected.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediationSystemReference rdf:type rdf:Property ;
    rdfs:label 'Mediation System Reference' ;
    rdfs:comment 'Reference identifier or batch ID from the mediation system that processed the CDRs being reconciled.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingRecordCount rdf:type rdf:Property ;
    rdfs:label 'Missing Record Count' ;
    rdfs:comment 'Number of records expected but not found in either source or target system, indicating potential data loss or completeness issues.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Overcharge Amount' ;
    rdfs:comment 'Total monetary value of discrepancies where customers were overcharged, requiring potential refunds or credits.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End Date' ;
    rdfs:comment 'End date of the business period being reconciled (e.g., billing cycle end, CDR collection period end).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start Date' ;
    rdfs:comment 'Start date of the business period being reconciled (e.g., billing cycle start, CDR collection period start).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'Specific type of reconciliation being performed, defining the source-to-target comparison scope (e.g., CDR-to-bill matching, inventory-to-provisioning alignment, TAP file reconciliation).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Record Count' ;
    rdfs:comment 'Number of records rejected during reconciliation processing due to validation failures, format errors, or business rule violations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionSummary rdf:type rdf:Property ;
    rdfs:label 'Resolution Summary' ;
    rdfs:comment 'Summary description of resolution actions taken for discrepancies identified in this reconciliation run.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the reconciliation run, used for tracking and reporting purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned timestamp when the reconciliation run was scheduled to begin execution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceRecordCount rdf:type rdf:Property ;
    rdfs:label 'Source Record Count' ;
    rdfs:comment 'Total number of records extracted from the source system for reconciliation.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Technical identifier or instance ID of the source system from which reconciliation data is extracted.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRecordCount rdf:type rdf:Property ;
    rdfs:label 'Target Record Count' ;
    rdfs:comment 'Total number of records extracted from the target system for comparison.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSystem rdf:type rdf:Property ;
    rdfs:label 'Target System' ;
    rdfs:comment 'Name of the target system being compared against the source (e.g., Amdocs Revenue Management, Oracle Communications OSM, billing system).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemCode rdf:type rdf:Property ;
    rdfs:label 'Target System Code' ;
    rdfs:comment 'Technical identifier or instance ID of the target system against which reconciliation data is compared.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDiscrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Discrepancy Amount' ;
    rdfs:comment 'Aggregate monetary value of all discrepancies identified in this reconciliation run, representing potential revenue leakage or over-billing.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRecordsProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Records Processed' ;
    rdfs:comment 'Total number of records processed during this reconciliation run across both source and target systems.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerMethod rdf:type rdf:Property ;
    rdfs:label 'Trigger Method' ;
    rdfs:comment 'Method by which this reconciliation run was initiated (e.g., scheduled job, manual trigger by analyst, event-driven, threshold breach alert).' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbilledAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Amount' ;
    rdfs:comment 'Total monetary value of usage or services that were not billed to customers, representing direct revenue leakage.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Undercharge Amount' ;
    rdfs:comment 'Total monetary value of discrepancies where customers were undercharged, representing revenue leakage to the business.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Record Count' ;
    rdfs:comment 'Number of records that failed to match between source and target systems, indicating potential discrepancies or data quality issues.' ;
    rdfs:domain ind:ReconciliationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueLeakageCaseId rdf:type rdf:Property ;
    rdfs:label 'Revenue Leakage Case Id' ;
    rdfs:comment 'Unique identifier for the revenue leakage case record. Primary key for the revenue leakage case entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueLeakageCase .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_audit. Business justification: Revenue assurance findings (billing errors, unbilled usage, rating failures) often surface during SOX, financial, or operational audits. Links leakage case to audit that identified it for audit trail ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to content.content_package. Business justification: Unbilled content access, entitlement provisioning errors, and package-level billing mismatches are tracked at package level for revenue assurance teams to quantify leakage and implement corrective bil' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:pricePlanId rdf:type rdf:Property ;
    rdfs:label 'Price Plan Id' ;
    rdfs:comment 'Foreign key linking to product.price_plan. Business justification: Leakage cases often involve incorrect price plan application or missing charges; direct link enables automated validation of billing accuracy against contracted rates and detection of plan migration e' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricePlan .

ind:primaryRevenueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Employee Id' ;
    rdfs:comment 'Identifier of the Revenue Assurance analyst or team member responsible for investigating and resolving this leakage case. Links to workforce management system.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rootCauseDqIssueId rdf:type rdf:Property ;
    rdfs:label 'Root Cause Dq Issue Id' ;
    rdfs:comment 'Foreign key linking to analytics.dq_issue. Business justification: Revenue leakage is often caused by data quality failures (missing CDRs, incorrect rating, provisioning mismatches). Leakage investigations link to upstream DQ issues for systemic remediation and contr' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqIssue .

ind:affectedCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Segment' ;
    rdfs:comment 'Customer segment impacted by the revenue leakage: consumer postpaid, consumer prepaid, enterprise (business customers), wholesale (carrier partners), MVNO (Mobile Virtual Network Operator), or government accounts.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Affected Subscriber Count' ;
    rdfs:comment 'Number of individual subscribers or customer accounts impacted by this revenue leakage event. Used to assess the scope and scale of the issue.' ;
    rdfs:domain ind:Assurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedLeakageAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Leakage Amount' ;
    rdfs:comment 'Final validated monetary value of the revenue leakage after investigation completion and root cause confirmation. Represents the actual revenue loss or at-risk amount. Expressed in the billing currency.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Detailed description of the remediation actions implemented to stop the revenue leakage and prevent recurrence. Includes system changes, process updates, policy revisions, and control enhancements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this case was escalated to senior management, executive leadership, or cross-functional steering committee due to high financial impact, regulatory risk, or resolution complexity. True if escalated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the case was escalated to higher authority. Null if no escalation occurred.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedLeakageAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Leakage Amount' ;
    rdfs:comment 'Initial estimated monetary value of the revenue leakage based on preliminary analysis and detection algorithms. Expressed in the billing currency. May be revised as investigation progresses.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Category' ;
    rdfs:comment 'Classification of the financial materiality of the revenue leakage based on confirmed amount and percentage of total revenue: material (executive reporting required), significant (senior management attention), moderate (standard process), or minor (routine handling).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Flag' ;
    rdfs:comment 'Indicates whether the revenue leakage shows characteristics of intentional fraud or abuse (e.g., SIM box fraud, subscription fraud, interconnect bypass). True if fraud is suspected or confirmed.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakageEndDate rdf:type rdf:Property ;
    rdfs:label 'Leakage End Date' ;
    rdfs:comment 'Date when the revenue leakage was stopped or mitigated. Null if the leakage is ongoing. Used to calculate the total duration of revenue loss.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakageStartDate rdf:type rdf:Property ;
    rdfs:label 'Leakage Start Date' ;
    rdfs:comment 'Estimated or confirmed date when the revenue leakage first began occurring. Used to calculate the total exposure period and historical impact.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakageType rdf:type rdf:Property ;
    rdfs:label 'Leakage Type' ;
    rdfs:comment 'Classification of the revenue leakage root cause category: unbilled usage (services consumed but not billed), rating error (incorrect tariff application), provisioning mismatch (service active but not in billing system), fraud (deliberate revenue theft), interconnect discrepancy (wholesale settlement errors), or discount abuse (unauthorized promotional application).' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveControlImplemented rdf:type rdf:Property ;
    rdfs:label 'Preventive Control Implemented' ;
    rdfs:comment 'Description of new preventive controls, automated checks, or monitoring mechanisms implemented to detect similar leakage patterns in the future. Part of continuous improvement process.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recovery Timestamp' ;
    rdfs:comment 'Date and time when the revenue recovery was completed and funds were successfully collected or credited. Null if no recovery has occurred.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recurrenceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk Level' ;
    rdfs:comment 'Assessment of the likelihood that this type of revenue leakage could recur based on the effectiveness of corrective actions and preventive controls. High risk requires ongoing monitoring.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the revenue leakage case was reported to the relevant regulatory authority. Null if no regulatory reporting was required or has not yet occurred.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the BSS, OSS, or Revenue Assurance system where the leakage was detected or originated. Examples: Amdocs Revenue Management, Comverse ONE, Oracle Communications OSM.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Reference Code' ;
    rdfs:comment 'External reference identifier or case number from the originating system (e.g., Amdocs case ID, ServiceNow incident number). Used for cross-system traceability.' ;
    rdfs:domain ind:RevenueLeakageCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachEventId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Event Id' ;
    rdfs:comment 'Unique identifier for each SLA breach event instance. Primary key for the SLA breach event record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaBreachEvent .

ind:breachedKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Breached Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: SLA breaches are measured against specific KPI definitions (availability, MTTR, latency). Regulatory and customer breach reporting requires linking to the violated KPI definition for compliance docume' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: SLA penalty amounts post to specific GL accounts (revenue deductions, customer credits, liability accruals). Required for accurate revenue recognition, penalty accrual accounting, and financial statem' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:regulatoryPenaltyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_penalty. Business justification: SLA breaches (especially consumer protection SLAs like broadband speed guarantees) can result in regulatory fines from consumer protection agencies. Links breach events to resulting penalties for fina' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryPenalty .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to partner.sla_definition. Business justification: SLA breach events must reference the specific SLA definition violated for accurate penalty calculation using the defined penalty formula, credit calculation, and compliance reporting per partner agree' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:actualMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Actual Measured Value' ;
    rdfs:comment 'The actual performance metric value measured during the breach period. Used to calculate the severity of the breach deviation.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachDeviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Deviation Percentage' ;
    rdfs:comment 'Percentage deviation of the actual measured value from the contracted threshold. Quantifies the magnitude of the SLA violation.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'Total duration of the SLA breach measured in minutes. Calculated from breach start to breach end timestamp. Used for penalty calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach End Timestamp' ;
    rdfs:comment 'Precise date and time when the service metric returned to acceptable levels, marking the end of the breach period. Null if breach is ongoing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachEventNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Event Number' ;
    rdfs:comment 'Human-readable business identifier for the SLA breach event. Used for external communication and reporting.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Start Timestamp' ;
    rdfs:comment 'Precise date and time when the service metric first fell below the SLA threshold, marking the beginning of the breach period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the SLA breach event. Tracks the breach from detection through resolution and penalty application.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachType rdf:type rdf:Property ;
    rdfs:label 'Breach Type' ;
    rdfs:comment 'Category of SLA metric that was breached. Defines which Key Performance Indicator (KPI) failed to meet the contracted threshold.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Threshold Value' ;
    rdfs:comment 'The SLA threshold value defined in the contract that was breached. Represents the minimum acceptable performance level agreed upon.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Level' ;
    rdfs:comment 'Assessment of the business impact on the customer due to the SLA breach. Considers service criticality and customer segment.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Channel' ;
    rdfs:comment 'Communication channel used to notify the customer about the SLA breach. Tracks notification method for audit and compliance purposes.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Detection Delay Minutes' ;
    rdfs:comment 'Time difference between breach start and detection timestamps. Measures monitoring system responsiveness and Mean Time to Detect (MTTD).' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Indicates whether the customer or internal team has disputed the SLA breach determination or penalty calculation. Triggers dispute resolution workflow.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'Current status of the dispute resolution process for the SLA breach. Tracks dispute lifecycle from initiation to final decision.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the breach requires escalation to senior management or specialized teams based on severity and duration thresholds.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Calculated financial penalty or service credit amount owed to the customer due to the SLA breach. Used for revenue assurance and billing adjustments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Indicates whether a financial penalty or service credit is applicable for this breach according to the SLA contract terms.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount. Ensures accurate financial processing across multi-currency operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Recommended' ;
    rdfs:comment 'Recommended preventive measures to avoid similar SLA breaches in the future. Used for continuous improvement and network optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report was submitted to the governing authority. Used for compliance audit trail.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'Indicates whether the required regulatory report has been submitted for this breach event. Tracks compliance with regulatory obligations.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Description of the corrective actions taken to resolve the SLA breach and restore service to acceptable levels. Documents remediation steps.' ;
    rdfs:domain ind:SlaBreachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_agreement. Business justification: SLA contracts are defined within partner agreements and must reference the governing agreement for compliance verification, penalty cap enforcement, and dispute resolution per contract terms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:corporateHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Corporate Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to customer.corporate_hierarchy. Business justification: Enterprise hierarchy nodes have specific SLA contracts for multi-site deployments. Essential for tiered service agreements, consolidated billing, and hierarchy-level SLA reporting. Real business proce' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateHierarchy .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: SLA contracts in telecommunications require designated employee ownership for contract governance, escalation handling, customer negotiations, renewal management, and breach resolution. The existing o' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentSlaContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Sla Contract Id' ;
    rdfs:comment 'Reference to a parent or master SLA contract when this SLA is a specialized or subsidiary agreement (e.g., service-specific SLA under an enterprise master agreement). Nullable for top-level SLAs.' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaContract .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: SLA contracts for MVNOs, roaming partners, and wholesale customers require partner attribution for SLA monitoring, breach tracking, and penalty calculation in partner settlement processes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'The role or individual who has authority to approve, modify, or terminate this SLA contract (e.g., \'VP Network Operations\', \'Chief Technology Officer\', \'Regulatory Affairs Director\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percent' ;
    rdfs:comment 'The committed service availability target expressed as a percentage (e.g., 99.95% uptime). Used for SLA breach detection and penalty calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Required' ;
    rdfs:comment 'Indicates whether automatic notification to customers or stakeholders is required when an SLA breach occurs (True) or not (False).' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Count' ;
    rdfs:comment 'The number of allowable SLA breaches within the measurement window before penalties are triggered or escalation occurs. Provides tolerance for minor incidents.' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the SLA contract: draft (being defined), active (in force), suspended (temporarily inactive), expired (past expiry date), terminated (cancelled before expiry), or under review (being renegotiated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process and contact hierarchy when SLA targets are breached or at risk. May reference external documentation or runbooks.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or events that are excluded from SLA calculations (e.g., \'Planned maintenance windows\', \'Force majeure events\', \'Customer-caused outages\', \'Third-party network failures\').' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic region or coverage area to which this SLA applies (e.g., \'National\', \'Regional\', \'Metro Area\', \'International\'). Critical for multi-region operators.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Governing Regulatory Body' ;
    rdfs:comment 'The regulatory authority or standards body that mandates or oversees this SLA (e.g., \'FCC\', \'Ofcom\', \'BEREC\', \'ITU\'). Applicable for regulatory QoS compliance SLAs.' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jitterTargetMs rdf:type rdf:Property ;
    rdfs:label 'Jitter Target Ms' ;
    rdfs:comment 'The maximum allowable jitter (variation in packet delay) in milliseconds. Essential for voice and video quality assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Latency Target Ms' ;
    rdfs:comment 'The maximum allowable network latency (round-trip time) in milliseconds. Applicable to real-time services such as VoLTE, VoIP, and gaming.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWindow rdf:type rdf:Property ;
    rdfs:label 'Measurement Window' ;
    rdfs:comment 'The time period over which SLA performance is measured and evaluated (e.g., monthly, quarterly, annual, rolling 30-day window).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttrTargetHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Target Hours' ;
    rdfs:comment 'The maximum allowable mean time to repair (MTTR) for service faults, measured in hours. Critical for NOC/SOC incident management and penalty assessment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'The internal business unit or department responsible for managing and enforcing this SLA (e.g., \'Network Operations Center\', \'Customer Care\', \'Enterprise Services\', \'Wholesale Operations\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetLossTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Target Percent' ;
    rdfs:comment 'The maximum allowable packet loss rate expressed as a percentage. Critical for QoS monitoring in IP-based services.' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'The method used to calculate financial penalties or service credits when SLA targets are breached: fixed amount per incident, percentage of monthly recurring revenue (MRR), tiered based on severity, prorated by downtime duration, or service credit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'The maximum total penalty or credit amount that can be assessed within a single measurement window. Protects both provider and customer from unlimited liability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether this SLA contract includes financial penalty clauses for breach events (True) or is informational only (False).' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Code' ;
    rdfs:comment 'The specific regulation, directive, or standard code that this SLA implements (e.g., \'FCC 17-287\', \'Ofcom GC22\', \'ITU-T E.800\'). Used for compliance reporting and audit trails.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceClass rdf:type rdf:Property ;
    rdfs:label 'Service Class' ;
    rdfs:comment 'The product or service category to which this SLA applies (e.g., \'Fiber Broadband\', \'5G Mobile\', \'IPTV\', \'Enterprise MPLS\', \'VoLTE\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Externally-known unique business identifier or code for the SLA contract used in operational systems and customer communications.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name or title of the SLA contract (e.g., \'Gold Business SLA\', \'Enterprise Uptime Guarantee\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA contract by its application scope: customer-facing (B2C/B2B service commitments), internal (inter-department operational agreements), wholesale (MVNO/carrier interconnect), partner (third-party service provider), or regulatory (mandated QoS compliance).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputTargetMbps rdf:type rdf:Property ;
    rdfs:label 'Throughput Target Mbps' ;
    rdfs:comment 'The minimum guaranteed throughput or bandwidth in megabits per second (Mbps). Applicable to broadband, fiber, and enterprise connectivity services.' ;
    rdfs:domain ind:SlaContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedOntAssetId rdf:type rdf:Property ;
    rdfs:label 'Affected Ont Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.ont_asset. Business justification: Links fiber access trouble tickets to specific ONT assets for technician dispatch with correct replacement inventory, optical power troubleshooting, and ONT failure rate tracking by vendor/model.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Reference to the customer service case in CRM system if the ticket was initiated from a customer complaint or inquiry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:ottPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to content.ott_platform. Business justification: OTT platform integration issues (SSO failures, catalog sync errors, API authentication problems) require platform-specific troubleshooting by integration teams to resolve partner platform connectivity' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_request. Business justification: Tickets fulfill GDPR/CCPA data subject requests (access, deletion, portability). Privacy teams create tickets for IT/operations to execute requests within regulatory SLA deadlines. Essential for priva' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Service-affecting tickets impact specific profit centers (enterprise, consumer, wholesale). Required for P&L impact analysis, service quality cost tracking, and profit center performance reporting in ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the field service work order dispatched to resolve the ticket if on-site intervention was required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:affectedServiceName rdf:type rdf:Property ;
    rdfs:label 'Affected Service Name' ;
    rdfs:comment 'Human-readable name of the service affected by the fault (e.g., Broadband Internet, VoLTE, IPTV, Enterprise MPLS).' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedGroup rdf:type rdf:Property ;
    rdfs:label 'Assigned Group' ;
    rdfs:comment 'Name of the NOC, SOC, or field operations team assigned to investigate and resolve the ticket (e.g., NOC Tier 2, RAN Operations, Field Dispatch).' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Full name of the engineer or technician assigned to the ticket.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correlatedAlarmIds rdf:type rdf:Property ;
    rdfs:label 'Correlated Alarm Ids' ;
    rdfs:comment 'Comma-separated list of related alarm IDs that were correlated and consolidated into this single trouble ticket. Supports alarm correlation and root cause analysis.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Reported Flag' ;
    rdfs:comment 'Indicates whether the fault was first reported by a customer (reactive) or proactively detected by network monitoring systems.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'The support tier or level to which the ticket was escalated (Tier 1 = frontline NOC, Tier 2 = specialist engineers, Tier 3 = vendor support, Management = executive escalation).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScope rdf:type rdf:Property ;
    rdfs:label 'Impact Scope' ;
    rdfs:comment 'Geographic or customer scope of the fault impact (single customer, multiple customers, entire site, regional, network-wide outage).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the trouble ticket was first created in the fault management system. Represents the start of the fault lifecycle.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code representing the resolution action taken. Used for trend analysis and knowledge base categorization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the actions taken to resolve the fault (e.g., equipment replacement, configuration change, software patch, service restart).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Technical severity level indicating the scope and impact of the fault. Sev1 = service down, Sev2 = major degradation, Sev3 = minor impact, Sev4 = cosmetic/informational.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The contractual or policy-defined target resolution time in minutes for this ticket priority level.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketCategory rdf:type rdf:Property ;
    rdfs:label 'Ticket Category' ;
    rdfs:comment 'High-level classification of the trouble ticket indicating the domain of the fault (network infrastructure, service delivery, customer equipment, security incident, performance degradation).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Externally visible unique ticket number assigned by the fault management system. Used for customer and NOC communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketType rdf:type rdf:Property ;
    rdfs:label 'Ticket Type' ;
    rdfs:comment 'Specific type of trouble ticket aligned with ITIL/ITSM classification: incident (unplanned interruption), problem (root cause investigation), change request, service request, or planned maintenance.' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:troubleTicketStatus rdf:type rdf:Property ;
    rdfs:label 'Trouble Ticket Status' ;
    rdfs:comment 'Current lifecycle status of the trouble ticket in the fault management workflow. [ENUM-REF-CANDIDATE: new|open|assigned|in_progress|pending|resolved|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TroubleTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Ticket Number' ;
    rdfs:comment 'External ticket number assigned by equipment vendor or third-party support provider if the issue was escalated to vendor technical support.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique system-generated identifier for the billing adjustment record. Primary key for the adjustment data product in the Amdocs Revenue Management adjustments module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:billingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Id' ;
    rdfs:comment 'Identifier of the customer dispute or trouble ticket that triggered this adjustment. Supports dispute resolution tracking and SLA breach compensation workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Foreign key linking to enterprise.corporate_account. Business justification: Enterprise billing adjustments (retroactive discounts, contract amendments, goodwill credits) require corporate account context for approval threshold enforcement, audit trail compliance, and corporat' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Billing adjustments (credits, debits, waivers) trigger GL postings. Finance teams must trace journal entries to source adjustments for audit, revenue assurance, and SOX compliance. Standard telco mont' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:salesContractId rdf:type rdf:Property ;
    rdfs:label 'Sales Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: Contract-related adjustments for SLA violations, pricing corrections, and service level failures require contract reference for audit trails, revenue recognition adjustments, legal compliance, and con' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesContract .

ind:settlementDisputeId rdf:type rdf:Property ;
    rdfs:label 'Settlement Dispute Id' ;
    rdfs:comment 'Foreign key linking to interconnect.settlement_dispute. Business justification: Billing adjustments for roaming charges must reference wholesale settlement disputes that justified the credit—required for audit trail, revenue assurance, and proving adjustments were based on valida' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementDispute .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'Business category classifying the nature of the adjustment for reporting, revenue assurance, and analytics purposes. Supports MRR/ARPU impact analysis and churn management reporting. [ENUM-REF-CANDIDATE: goodwill|sla_compensation|dispute_resolution|overbilling_correction|equipment_return|service_outage|promotional|other — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for the adjustment. Used in customer communications, dispute correspondence, and financial reconciliation. Format: ADJ- followed by 10 digits.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment. Pending: awaiting approval. Approved: authorized but not yet applied to the account. Applied: posted to the billing account. Reversed: previously applied adjustment that has been undone. Expired: approved adjustment that was not applied within the validity window.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Indicates whether the adjustment increases (credit) or decreases (debit) the customer\'s account balance. A credit reduces the amount owed; a debit increases it.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the adjustment was posted and applied to the billing account balance. Populated when adjustment_status transitions to \'applied\'.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalThresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Breached' ;
    rdfs:comment 'Indicates whether the adjustment amount exceeded the standard agent approval threshold, requiring escalated authorization. Supports revenue assurance controls and fraud prevention.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing period to which this adjustment relates. Used alongside billing_period_start for period-accurate revenue recognition and financial reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing period to which this adjustment relates. Used for period-accurate revenue recognition, MRR reporting, and financial close processes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP cost center code associated with this adjustment for internal financial allocation and OPEX reporting purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteIssueDate rdf:type rdf:Property ;
    rdfs:label 'Credit Note Issue Date' ;
    rdfs:comment 'Date on which the credit note was formally issued to the customer. Populated only when document_type is \'credit_note\'. Determines the financial period for revenue recognition and regulatory reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Note Number' ;
    rdfs:comment 'Formal reference number of the customer-facing credit note document. Populated only when document_type is \'credit_note\'. Used in customer communications, accounts receivable reconciliation, and regulatory financial reporting. Format: CN- followed by 10 digits.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditedOnetimeAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Onetime Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to one-time charges such as activation fees, equipment charges, or installation fees.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedRecurringAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Recurring Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to recurring subscription or plan charges (e.g., monthly plan fees, MRR components). Supports MRR impact analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedUsageAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Usage Amount' ;
    rdfs:comment 'Portion of the net adjustment amount attributable to usage charges (e.g., voice, data, SMS). Supports breakdown of credited amounts by charge type for revenue assurance reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classifies the adjustment as either an internal account balance correction (internal_adjustment) or a formal customer-facing financial document (credit_note). When document_type is credit_note, the credit_note_number and credit_note_issue_date fields are populated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General Ledger account code to which this adjustment is posted for financial accounting purposes. Supports SAP S/4HANA integration and revenue recognition journal entries.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The pre-tax gross amount of the adjustment before tax impact is applied. Positive value for credits; negative value for debits. Used in revenue recognition and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCustomerVisible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Visible' ;
    rdfs:comment 'Indicates whether this adjustment is visible to the customer on their invoice or self-service portal. Internal adjustments may not be customer-facing.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Total net amount of the adjustment including gross amount, tax amount, and tax reversal. Represents the actual financial impact posted to the billing account. Used for revenue assurance and ARPU impact reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for the adjustment. Examples include: GOODWILL, SLA_BREACH, OVERBILLING, DISPUTE_RESOLUTION, EQUIPMENT_RETURN, SERVICE_OUTAGE, BILLING_ERROR. [ENUM-REF-CANDIDATE: GOODWILL|SLA_BREACH|OVERBILLING|DISPUTE_RESOLUTION|EQUIPMENT_RETURN|SERVICE_OUTAGE|BILLING_ERROR — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for the adjustment, supplementing the reason_code with contextual details such as the nature of the SLA breach, outage duration, or billing discrepancy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManagerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Manager Approval' ;
    rdfs:comment 'Indicates whether this adjustment requires manager-level approval due to amount thresholds, category sensitivity, or policy rules. Drives approval workflow routing in Amdocs Revenue Management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which the adjustment amount was recognized in the financial statements under IFRS 15. Populated when revenue_recognition_flag is true.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether this adjustment has been recognized in the financial revenue recognition process under IFRS 15. Supports financial close and revenue assurance reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which a previously applied adjustment was reversed. Populated when adjustment_status transitions to \'reversed\'. Used for revenue assurance and audit trail purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text description of the reason why a previously applied adjustment was reversed. Populated when adjustment_status is \'reversed\'. Supports revenue assurance and audit compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'The native identifier of this adjustment record in the originating source system (e.g., Amdocs internal adjustment ID, Comverse ONE transaction reference). Supports cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The tax component of the adjustment, representing the tax impact associated with the gross adjustment amount. May be positive (credit) or negative (debit) depending on adjustment_type.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether this adjustment is exempt from tax calculation. Applicable for certain goodwill credits or adjustments on tax-exempt accounts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReversalAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Reversal Amount' ;
    rdfs:comment 'Amount of tax reversed as part of this adjustment, applicable when the original invoice tax must be partially or fully reversed. Distinct from tax_amount which represents new tax applied to the adjustment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Enterprise/B2B billing accounts are assigned account managers for relationship management, escalation routing, and commission tracking. Standard telco practice for high-value accounts. No existing col' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAccountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Billing Account Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent billing account in a hierarchical account structure. Used for enterprise split billing where a master account consolidates charges from multiple child accounts. Null for standalone accounts.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Descriptive name assigned to the billing account, typically the customer legal name or a business unit label for corporate accounts. Displayed on invoices and used in collections correspondence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible, human-readable account number assigned by Amdocs Revenue Management and printed on invoices and statements. Used by customers and agents to reference the account in all billing interactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the billing account as managed in Amdocs Revenue Management. Controls whether new charges can be applied, invoices generated, and services provisioned. [ENUM-REF-CANDIDATE: active|suspended|closed|pending|delinquent|write_off — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account by customer segment. Drives applicable rate plans, credit policies, dunning rules, and regulatory treatment. [ENUM-REF-CANDIDATE: residential|small_business|enterprise|wholesale|mvno|government — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpuSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Arpu Segment Code' ;
    rdfs:comment 'Segment classification of the billing account based on Average Revenue Per User (ARPU) banding (e.g., HIGH_VALUE, MID_VALUE, LOW_VALUE). Used for targeted retention campaigns, churn management, and revenue analytics.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment is configured for this billing account. When true, the system initiates payment collection on the due date using the stored payment instrument without manual customer action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Bill Delivery Method' ;
    rdfs:comment 'Preferred channel through which invoices are delivered to the customer. Drives the bill production and distribution workflow in Amdocs Revenue Management. Suppressed is used for internal or wholesale accounts billed via EDI.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Bill Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag specifying the language in which invoices and billing communications are generated for this account (e.g., en-US, es-MX, fr-CA). Supports multilingual billing for diverse customer bases.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Code' ;
    rdfs:comment 'Code identifying the billing cycle assigned to this account in Amdocs Revenue Management (e.g., MONTHLY-01, MONTHLY-15, QUARTERLY). Determines the invoice generation schedule and the period over which charges are accumulated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedBilling rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing' ;
    rdfs:comment 'Indicates whether this billing account is configured to receive a consolidated invoice aggregating charges from multiple sub-accounts or service lines. Common for enterprise customers with split billing arrangements.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditClassCode rdf:type rdf:Property ;
    rdfs:label 'Credit Class Code' ;
    rdfs:comment 'Credit risk classification assigned to the billing account by the credit management system (e.g., GOLD, SILVER, BRONZE, HIGH_RISK). Drives credit limit assignment, deposit requirements, and dunning profile selection in Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding balance permitted on this billing account before service suspension is triggered. Set based on credit class and customer risk profile. Monitored in real time by Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Outstanding monetary balance on the billing account as of the last billing run or payment posting. Positive value indicates amount owed by the customer; negative value indicates a credit balance. Used for collections prioritization and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Monetary deposit held by the carrier against this billing account as a credit risk mitigation measure. Applied to high-risk credit classes. Refundable upon account closure in good standing per FCC deposit rules.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'Date on which the security deposit was collected from the customer. Used to calculate deposit holding period and determine refund eligibility under FCC regulations.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeInProgress rdf:type rdf:Property ;
    rdfs:label 'Dispute In Progress' ;
    rdfs:comment 'Indicates whether there is an active billing dispute on this account. When true, dunning escalation may be paused per dispute resolution policy. Linked to the dispute management workflow in Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningProfileCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Profile Code' ;
    rdfs:comment 'Code referencing the dunning workflow profile assigned to this billing account in Amdocs Revenue Management. Defines the sequence, timing, and escalation steps (reminder, warning, suspension, collections referral) applied when payment is overdue.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Status' ;
    rdfs:comment 'Current step in the dunning escalation workflow for this billing account. Tracks the collections lifecycle from initial reminder through suspension and potential write-off. Updated by Amdocs Revenue Management collections engine.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date on which the billing account became active and eligible to receive charges. Marks the start of the billing relationship and is used for revenue recognition and contract term calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which the billing account is scheduled to close or was closed. Null for open-ended accounts. Used for contract expiry tracking, churn analysis, and revenue recognition cutoff.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level of this billing account within the enterprise account hierarchy (1 = top-level master account, 2 = sub-account, 3 = sub-sub-account). Supports multi-tier corporate billing structures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceFormatCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Format Code' ;
    rdfs:comment 'Specifies the invoice presentation format assigned to this billing account. Itemized includes per-call detail; summary shows charge categories only; consolidated merges multiple sub-accounts into a single invoice.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date on which the most recent invoice was generated for this billing account. Used to track billing cycle adherence, identify accounts that have not been billed, and support collections workflows.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Monetary value of the most recent payment posted to this billing account. Used alongside last_payment_date to assess partial vs. full payment behavior and inform collections strategy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date on which the most recent payment was posted to this billing account. Used by collections agents to assess payment recency, calculate days since last payment, and prioritize dunning actions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrrAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Amount' ;
    rdfs:comment 'The contracted Monthly Recurring Revenue (MRR) value of this billing account, representing the predictable monthly charge for subscribed services excluding one-time and usage-based charges. Used for revenue forecasting and EBITDA reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Amount' ;
    rdfs:comment 'Total monetary amount past the payment due date on this billing account. Drives dunning escalation, credit limit monitoring, and collections referral decisions in Amdocs Revenue Management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Instrument used to settle invoices on this billing account. Determines auto-pay eligibility and dunning escalation paths. [ENUM-REF-CANDIDATE: auto_pay_card|auto_pay_ach|manual_card|manual_ach|check|wire|cash|voucher — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due (e.g., 14, 21, 30). Governs the due date calculation on each invoice and triggers dunning escalation if payment is not received within this window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prepaidPostpaidIndicator rdf:type rdf:Property ;
    rdfs:label 'Prepaid Postpaid Indicator' ;
    rdfs:comment 'Indicates whether this billing account operates on a prepaid (advance payment, Comverse ONE), postpaid (invoice-based, Amdocs Revenue Management), or hybrid charging model. Determines the rating engine and balance management system used.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Code' ;
    rdfs:comment 'Code identifying the revenue recognition treatment applied to charges on this billing account per IFRS 15 / ASC 606 (e.g., STRAIGHT_LINE, USAGE_BASED, MILESTONE). Used by the finance team for accurate revenue reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelCode rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Code' ;
    rdfs:comment 'Channel through which the billing account was originally acquired. Used for ARPU and revenue attribution analysis by channel, commission calculations, and churn analysis by acquisition source. [ENUM-REF-CANDIDATE: direct|retail|online|dealer|telesales|mvno|wholesale — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendLimit rdf:type rdf:Property ;
    rdfs:label 'Spend Limit' ;
    rdfs:comment 'Maximum total spend threshold configured on this billing account for real-time usage control. When the accumulated charges approach this limit, alerts are triggered or services are throttled. Distinct from credit_limit which governs outstanding balance.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptionCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate' ;
    rdfs:comment 'Reference number of the tax exemption certificate provided by the customer. Required for audit and regulatory compliance when tax_exempt is true. Stored for verification by the finance and compliance teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingChargeId rdf:type rdf:Property ;
    rdfs:label 'Billing Charge Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual monetary charge record within the billing domain. Serves as the primary key for the charge entity in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCharge .

ind:addonId rdf:type rdf:Property ;
    rdfs:label 'Addon Id' ;
    rdfs:comment 'Foreign key linking to product.addon. Business justification: Addon charges (recurring, one-time, usage-based) must link to addon definition for billing validation, addon revenue attribution, dispute resolution, and addon product performance measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Addon .

ind:billingApprovedByAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Billing Approved By Agent Employee Id' ;
    rdfs:comment 'Reference to the supervisor or authorized agent who approved this charge when approval_status is \'approved\'. Null for system-generated or not_required charges. Supports SOX compliance and internal audit requirements.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Reference to the billing cycle in which this charge was generated and processed. Links the charge to the specific monthly or periodic billing run in Amdocs Revenue Management for cycle-level reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:billingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Billing Employee Id' ;
    rdfs:comment 'Reference to the customer service agent or system user who manually applied this charge. Populated for manual and adjustment charge types. Null for system-generated charges. Used for audit and accountability tracking.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Reference to the originating order that triggered this charge, such as a new activation, upgrade, or equipment purchase order managed in Oracle Communications Order and Service Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:managedServiceId rdf:type rdf:Property ;
    rdfs:label 'Managed Service Id' ;
    rdfs:comment 'Foreign key linking to enterprise.managed_service. Business justification: Recurring and one-time charges must trace to specific managed service instances (MPLS circuits, SD-WAN nodes, UCaaS seats) for service-level revenue recognition, contract compliance validation, disput' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedService .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: Charges stem from offerings purchased by customers. Required for offer performance analysis, revenue forecasting by offering, promotional offer ROI measurement, and channel effectiveness reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:ratePlanId rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_plan. Business justification: Charges (especially recurring and usage-based charges) are priced according to a rate plan definition. The charge table currently has charge_type and charge_category but no direct FK to the rate_plan ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatePlan .

ind:reversalChargeBillingChargeId rdf:type rdf:Property ;
    rdfs:label 'Reversal Charge Billing Charge Id' ;
    rdfs:comment 'Reference to the original charge that this record reverses or credits. Populated only for reversal/credit adjustment charges. Enables audit trail linking of original charge to its reversal for revenue assurance.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCharge .

ind:specId rdf:type rdf:Property ;
    rdfs:label 'Spec Id' ;
    rdfs:comment 'Reference to the charge specification or charge template in the Netcracker Product/Service Catalog that defines the rules, rates, and conditions for this type of charge. Enables catalog-driven charge validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Spec .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'High-level business category grouping charges for revenue reporting and GL account mapping: service (subscription/plan fees), equipment (CPE/device), penalty (late fees, breach), tax (regulatory levies), discount (promotional credits), surcharge (regulatory recovery fees), interconnect (IOT/wholesale). [ENUM-REF-CANDIDATE: service|equipment|penalty|tax|discount|surcharge|interconnect — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Human-readable description of the charge as it appears on the customer\'s bill and in customer service interactions. Examples: \'Monthly Unlimited Plan Fee\', \'iPhone 15 Equipment Charge\', \'Late Payment Penalty\'. Sourced from Amdocs charge specification.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeNumber rdf:type rdf:Property ;
    rdfs:label 'Charge Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the charge as displayed on customer bills and used in dispute resolution and customer service interactions within Amdocs Revenue Management.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeSource rdf:type rdf:Property ;
    rdfs:label 'Charge Source' ;
    rdfs:comment 'Originating system that generated or triggered this charge: amdocs (Amdocs Revenue Management automated billing), comverse (Comverse ONE prepaid/real-time charging), manual (agent-applied via CRM), order_management (Oracle OSM order fulfillment), product_catalog (Netcracker catalog-driven), crm (Salesforce CRM agent action).' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle state of the charge within the billing workflow: pending (created, not yet billed), active (approved for billing), invoiced (included on an invoice), disputed (under customer dispute), waived (forgiven without reversal), cancelled (voided before invoicing), reversed (credited back after invoicing). [ENUM-REF-CANDIDATE: pending|active|invoiced|disputed|waived|cancelled|reversed — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the charge by its billing nature: recurring (monthly service fee), one_time (single occurrence), activation (service provisioning fee), equipment (CPE/device charge), late_payment (penalty fee), adjustment (credit or debit correction), or manual (agent-applied charge). [ENUM-REF-CANDIDATE: recurring|one_time|activation|equipment|late_payment|adjustment|manual — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Monetary value of any promotional, loyalty, or contractual discount applied to reduce the gross charge amount. Negative value reduces the net charge. Sourced from Amdocs Revenue Management discount engine.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level for unpaid charges, ranging from 0 (no dunning) to the maximum configured level (e.g., 4 = final notice before collections). Managed by the Amdocs Revenue Management dunning engine for collections workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dunning Timestamp' ;
    rdfs:comment 'Date and time of the most recent dunning action taken on this charge (e.g., reminder notice sent, suspension warning issued). Null if dunning_level is 0. Used to track collections escalation timeline.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External or cross-system reference identifier for this charge, such as a partner billing reference, wholesale interconnect settlement reference (TAP/IOT), or regulatory reporting reference number. Supports reconciliation with partner and regulatory systems.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates whether this charge has been prorated to reflect a partial billing period (e.g., mid-cycle activation or cancellation). True when the charge amount has been adjusted proportionally to the number of days in the service period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrrContribution rdf:type rdf:Property ;
    rdfs:label 'Mrr Contribution' ;
    rdfs:comment 'The portion of this charge that contributes to Monthly Recurring Revenue (MRR) calculations. For recurring charges, this equals the normalized monthly gross amount. Zero for one-time charges. Used in MRR/ARPU reporting and revenue forecasting.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment for this charge must be received to avoid late payment penalties and dunning escalation. Derived from the billing cycle due date and any applicable grace period configured in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End date of the billing period covered by this charge. Together with charge_period_start, defines the service period for which the recurring or prorated charge applies. Null for one-time charges with no period.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start date of the billing period covered by this charge. Applicable for recurring charges (e.g., monthly plan fee covering 2024-01-01 to 2024-01-31). Used for proration and revenue period matching.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationFactor rdf:type rdf:Property ;
    rdfs:label 'Proration Factor' ;
    rdfs:comment 'Decimal factor applied to the full-period charge to derive the prorated amount (e.g., 0.516129 for 16 days out of 31). Null when is_prorated is False. Used for revenue assurance validation of prorated charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemChargeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Charge Code' ;
    rdfs:comment 'The native charge identifier as recorded in the originating operational system (Amdocs Revenue Management or Comverse ONE). Preserved for cross-system reconciliation, data lineage tracing, and support of revenue assurance processes.' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClass rdf:type rdf:Property ;
    rdfs:label 'Tax Class' ;
    rdfs:comment 'Tax classification of the charge that determines the applicable tax treatment and rate. Drives the Amdocs tax engine calculation: taxable (standard rate), exempt (no tax), zero_rated (0% VAT/GST), reduced_rate (preferential rate), regulatory_surcharge (FCC/NTIA mandated levies).' ;
    rdfs:domain ind:BillingCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Effective tax rate percentage applied to this charge at the time of billing, expressed as a decimal (e.g., 0.0875 for 8.75%). Captured for audit and revenue assurance purposes as rates may change over time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why this charge was waived (charge_status = \'waived\'). Examples: \'Customer goodwill gesture\', \'Service outage credit\', \'Regulatory compliance\'. Required for revenue assurance audit when charges are forgiven.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteId rdf:type rdf:Property ;
    rdfs:label 'Credit Note Id' ;
    rdfs:comment 'Unique surrogate identifier for the credit note record in the billing system. Primary key for the credit_note data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditNote .

ind:issuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issued By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Credit notes impact revenue recognition and require employee accountability for audit and performance tracking. Real business process: dispute resolution metrics, regulatory compliance. Replaces denor' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the total credit amount that has been applied against invoices or account balances to date. Enables tracking of partial credit consumption and remaining credit balance for aged credit analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross pre-tax credit amount to be applied to the customer\'s account, expressed in the billing currency. Represents the principal financial value of the credit note before tax reversal. Core component of the MONETARY_TRIPLET for revenue reversal reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'The billing charge category being credited. Identifies whether the credit relates to recurring service charges, usage-based charges (CDR-level), equipment fees, tax adjustments, interconnect/wholesale charges, or roaming charges. Supports revenue assurance and MRR impact analysis.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Note Status' ;
    rdfs:comment 'Current lifecycle state of the credit note. \'issued\' = generated and sent to customer; \'applied\' = fully offset against an invoice or balance; \'partially_applied\' = partially consumed; \'expired\' = validity period lapsed without full application; \'cancelled\' = withdrawn before application; \'voided\' = reversed post-issuance for error correction. [ENUM-REF-CANDIDATE: issued|applied|partially_applied|expired|cancelled|voided — promote to reference product]' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteType rdf:type rdf:Property ;
    rdfs:label 'Credit Note Type' ;
    rdfs:comment 'Classification of the credit note by its business nature. \'financial\' = billing error correction; \'commercial\' = commercial dispute resolution; \'regulatory\' = mandated by FCC/Ofcom/BEREC regulatory ruling; \'goodwill\' = customer retention gesture; \'equipment_return\' = CPE/ONT/OLT equipment return credit.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The channel through which the credit note document was delivered to the customer. Supports omnichannel customer communication tracking and digital delivery compliance requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The timestamp when the credit note document was delivered to the customer via the specified delivery channel. Used for customer communication audit trails and regulatory compliance with billing notification requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Indicates whether this credit note was issued as a result of a regulatory mandate from FCC, Ofcom, BEREC, or other governing body. True = regulatory-mandated credit; False = commercially or operationally initiated. Used for regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The calendar date on which the credit note was formally issued to the customer. This is the principal business event date printed on the credit note document and used for revenue recognition reversal under IFRS 15.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Credit Amount' ;
    rdfs:comment 'The unapplied balance of the credit note (total_credit_amount minus applied_amount). Represents the credit still available for future application. Used for credit liability reporting and customer account balance management.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'The accounting period (YYYY-MM format) in which the revenue reversal from this credit note is recognized under IFRS 15 / ASC 606. Used by SAP S/4HANA Finance for general ledger posting and period-close reporting.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'The native identifier of this credit note in the originating source system (e.g., Amdocs internal credit note ID, Comverse ONE transaction reference). Enables cross-system traceability and reconciliation between the lakehouse Silver Layer and operational BSS/CRM systems.' ;
    rdfs:domain ind:CreditNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction or tax type code applied to the credit note for tax reversal calculation. Aligns with the tax code on the original invoice. Used for tax authority reporting and VAT/GST compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The geographic tax jurisdiction (e.g., state, country, municipality) applicable to the tax reversal on this credit note. Required for multi-jurisdiction tax compliance reporting to federal, state, and local tax authorities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total credit amount inclusive of tax reversal (credit_amount + tax_reversal_amount). This is the net financial value credited to the customer\'s account and the figure printed on the customer-facing credit note document.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Disputes are raised by specific authorized contacts (account holders, authorized users, corporate account managers). Tracking who raised dispute is critical for authorization validation, communication' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContact .

ind:previousDisputeBillingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Previous Dispute Billing Dispute Id' ;
    rdfs:comment 'Reference to the earlier dispute record if this is a repeat or re-opened dispute. Enables dispute lineage tracking and repeat-dispute root-cause analysis. Nullable for first-time disputes.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:approvedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Amount' ;
    rdfs:comment 'The monetary credit amount approved and issued to the customer as the resolution outcome. May be less than, equal to, or zero relative to the disputed amount depending on the resolution decision (upheld, partially upheld, rejected).' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdrReference rdf:type rdf:Property ;
    rdfs:label 'Cdr Reference' ;
    rdfs:comment 'Reference to the specific Call Detail Record (CDR) or usage event record that is the subject of the dispute. Enables direct linkage between the dispute and the rated usage event in the mediation/rating system.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to the dispute at creation. Used in customer communications, agent workflows, and regulatory correspondence. Format: DSP- followed by 10 digits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the billing dispute. Drives workflow routing in Amdocs and Salesforce CRM. Valid states: open (newly raised), under_review (agent investigating), escalated (referred to senior team or regulator), resolved (outcome determined), closed (credit/adjustment applied and confirmed), withdrawn (customer retracted the dispute).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the nature of the billing dispute. Drives routing rules and SLA targets. [ENUM-REF-CANDIDATE: charge_error|service_not_received|unauthorized_charge|roaming_dispute|early_termination_fee|late_payment_fee|promotional_credit_missing|other — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The gross monetary amount the customer is disputing, expressed in the billing currency. Represents the full value under contention before any partial resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Narrative or coded reason explaining why the dispute was escalated. Populated only when escalation_flag is True. Examples: SLA breach, high-value dispute, regulatory complaint, repeat dispute.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to supporting evidence documents (e.g., CDR extracts, call recordings, usage reports, screenshots) stored in the document management system. Supports dispute investigation and audit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDate rdf:type rdf:Property ;
    rdfs:label 'Raised Date' ;
    rdfs:comment 'Calendar date on which the customer formally raised the billing dispute. Used for SLA measurement, regulatory reporting, and aging analysis. Distinct from the system record creation timestamp.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raised Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the dispute was formally submitted by the customer. Used for exact SLA clock-start calculations and audit trail.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complaint Flag' ;
    rdfs:comment 'Indicates whether the dispute has been formally lodged with or referred to a regulatory body (e.g., FCC, Ofcom, BEREC). True = regulatory complaint filed. Triggers mandatory regulatory reporting workflows.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Dispute Flag' ;
    rdfs:comment 'Indicates whether this dispute is a repeat submission by the same customer for the same or similar charge within a defined lookback window. True = repeat dispute. Used for churn risk analysis and root-cause remediation.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Calendar date on which the dispute was formally resolved and an outcome was communicated to the customer. Used for SLA compliance reporting and regulatory submissions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final decision on the billing dispute. upheld: full credit issued; partially_upheld: partial credit issued; rejected: no credit, charge stands; withdrawn: customer retracted before resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise date and time at which the dispute resolution was finalized in the system. Used for exact SLA elapsed-time calculations and audit trail integrity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the SLA due date without resolution. True = SLA was breached. Used for regulatory compliance reporting and agent performance management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Target date by which the dispute must be resolved per the applicable SLA or regulatory requirement (e.g., FCC mandates, Ofcom billing dispute resolution timelines). Calculated from raised_date plus the applicable SLA window.' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningEventId rdf:type rdf:Property ;
    rdfs:label 'Dunning Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each dunning action record within the Amdocs Collections dunning engine. Primary key for the dunning_event data product in the billing domain Silver layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DunningEvent .

ind:dunningProfileId rdf:type rdf:Property ;
    rdfs:label 'Dunning Profile Id' ;
    rdfs:comment 'Reference to the dunning policy/profile configuration that governs the escalation rules, timing intervals, and communication templates applied to this account segment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DunningProfile .

ind:paymentArrangementId rdf:type rdf:Property ;
    rdfs:label 'Payment Arrangement Id' ;
    rdfs:comment 'Reference to a formal payment arrangement or instalment plan agreed with the customer as an outcome of this dunning action. Links to the payment arrangement entity in Amdocs Revenue Management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentArrangement .

ind:previousDunningEventId rdf:type rdf:Property ;
    rdfs:label 'Previous Dunning Event Id' ;
    rdfs:comment 'Reference to the immediately preceding dunning event on the same billing account in the current collections cycle. Enables traversal of the dunning escalation chain for audit and analytics purposes.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DunningEvent .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'The precise date and time at which this dunning action was executed by the Amdocs Collections dunning engine. This is the principal real-world event time for the dunning event, distinct from record audit timestamps.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agentNotes rdf:type rdf:Property ;
    rdfs:label 'Agent Notes' ;
    rdfs:comment 'Free-text notes entered by the collections agent during or after the dunning interaction. Captures context not covered by structured fields, such as customer circumstances or negotiation details.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionsCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Collections Cycle Number' ;
    rdfs:comment 'Sequential number identifying which collections cycle this dunning event belongs to for the billing account. Resets to 1 at the start of each new collections cycle following account resolution. Enables multi-cycle delinquency pattern analysis.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionsQueue rdf:type rdf:Property ;
    rdfs:label 'Collections Queue' ;
    rdfs:comment 'Name of the collections work queue within the Amdocs Collections dunning engine to which this dunning event was assigned for processing. Used for workload management and agent performance reporting.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The delivery channel used to communicate this dunning action to the customer. [ENUM-REF-CANDIDATE: SMS|EMAIL|LETTER|IVR|PUSH_NOTIFICATION|AGENT_CALL — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Communication Template Code' ;
    rdfs:comment 'Code identifying the specific message template used for the dunning communication, as configured in the Amdocs Collections template library. Enables audit of messaging content applied at each dunning level.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseCode rdf:type rdf:Property ;
    rdfs:label 'Customer Response Code' ;
    rdfs:comment 'Coded response received from the customer following this dunning action. PAYMENT_PROMISE indicates a commitment to pay by a specified date; DISPUTE_RAISED triggers a billing dispute workflow; HARDSHIP_CLAIM routes to a customer retention or hardship program. [ENUM-REF-CANDIDATE: PAYMENT_PROMISE|PAYMENT_MADE|DISPUTE_RAISED|NO_RESPONSE|CONTACT_REQUESTED|HARDSHIP_CLAIM — promote to reference product]' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Response Timestamp' ;
    rdfs:comment 'Date and time at which the customer response to this dunning action was recorded in the collections system. Null if no response was received.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the oldest unpaid invoice on the billing account has been past its due date at the time this dunning action was executed. Key metric for collections aging analysis and dunning level eligibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Outcome of the dunning communication delivery attempt via the selected channel. BOUNCED applies to email; OPTED_OUT indicates the customer has unsubscribed from the channel; UNDELIVERED covers SMS/IVR failures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningSegment rdf:type rdf:Property ;
    rdfs:label 'Dunning Segment' ;
    rdfs:comment 'Customer segment classification applied to this dunning event, determining which dunning profile and escalation rules are applicable. MVNO refers to Mobile Virtual Network Operator wholesale customers.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason Code' ;
    rdfs:comment 'Coded reason explaining why this dunning event was escalated to the current dunning level (e.g., PROMISE_BROKEN, NO_PAYMENT, PARTIAL_PAYMENT, REPEATED_DELINQUENCY). Sourced from Amdocs Collections dunning engine. [ENUM-REF-CANDIDATE: PROMISE_BROKEN|NO_PAYMENT|PARTIAL_PAYMENT|REPEATED_DELINQUENCY|FIRST_DELINQUENCY|RETURNED_PAYMENT — promote to reference product]' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardshipProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Hardship Program Flag' ;
    rdfs:comment 'Indicates whether the customer has been enrolled in a financial hardship assistance program as a result of this dunning interaction. True when enrolled; False otherwise. Triggers modified dunning rules and retention workflows.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrrAtRiskAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr At Risk Amount' ;
    rdfs:comment 'The Monthly Recurring Revenue (MRR) value of the services on the billing account at the time of this dunning action. Quantifies the revenue at risk of churn if the account is terminated, enabling prioritisation of high-value collections efforts.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'The calendar date on which the next dunning escalation action is scheduled to execute if the outstanding balance remains unpaid. Null if the account has been resolved or terminated.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDunningLevel rdf:type rdf:Property ;
    rdfs:label 'Next Dunning Level' ;
    rdfs:comment 'The dunning escalation level that will be applied if the current delinquency is not resolved. NONE indicates this is the final dunning step (termination executed or account resolved). Sourced from the dunning profile escalation rules.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalanceAmt rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amt' ;
    rdfs:comment 'Total overdue balance on the billing account at the time this dunning action was executed, expressed in the account currency. Represents the gross amount subject to collections at this dunning level.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promiseToPayAmount rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Amount' ;
    rdfs:comment 'The monetary amount the customer has committed to pay by the promise_to_pay_date. May be a partial payment arrangement. Null if no payment promise was made.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promiseToPayDate rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Date' ;
    rdfs:comment 'The date by which the customer has committed to settle the outstanding balance, as captured during a PAYMENT_PROMISE response. Used to defer further dunning escalation and monitor promise fulfilment.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ref rdf:type rdf:Property ;
    rdfs:label 'Ref' ;
    rdfs:comment 'Externally-known business reference number assigned by the Amdocs Collections dunning engine to uniquely identify this dunning action across BSS systems. Used in customer communications and dispute resolution.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether this dunning action has been placed on hold due to a regulatory restriction (e.g., FCC emergency relief orders, Ofcom consumer protection rules, or BEREC guidelines prohibiting disconnection during declared emergencies). True when a regulatory hold is active.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledActionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Action Date' ;
    rdfs:comment 'The calendar date on which this dunning action was originally scheduled to execute per the dunning profile rules. Used for SLA tracking and collections workflow planning.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the customer\'s services were suspended as a result of this dunning action. Populated only when dunning_level is SUSPENSION. Null for all other dunning levels.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which the customer\'s services were terminated as a result of this dunning action. Populated only when dunning_level is TERMINATION. Null for all other dunning levels.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The monetary value of the outstanding balance that was written off as bad debt following this dunning event. Null if write_off_flag is False. Used for revenue assurance, bad debt provisioning, and IFRS 9 impairment reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the bad debt write-off was approved and posted in the financial system. Null if write_off_flag is False. Aligns with SAP S/4HANA finance posting date for revenue recognition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether the outstanding balance associated with this dunning event has been written off as a bad debt following failed collections. True when the balance has been written off; False otherwise. Feeds revenue assurance and bad debt reporting.' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Generated By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Manual invoices, corrections, and off-cycle bills require audit trail of generating employee for dispute resolution and regulatory compliance. Critical for billing operations accountability and SOX co' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Net total of all billing adjustments, credits, and discounts applied to the invoice. Can be negative (credit to customer) or positive (additional charge). Includes dispute resolutions, goodwill credits, and promotional adjustments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billDate rdf:type rdf:Property ;
    rdfs:label 'Bill Date' ;
    rdfs:comment 'The date on which the invoice was generated and issued to the customer. Represents the principal business event timestamp for the invoice. Used as the reference date for payment due date calculation and revenue recognition.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billFormat rdf:type rdf:Property ;
    rdfs:label 'Bill Format' ;
    rdfs:comment 'The level of detail included in the customer-facing billing statement. Detailed includes full CDR (Call Detail Record) itemization; Summary shows charge categories only; Itemized shows line-item charges without full CDR detail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The last day of the billing cycle period covered by this invoice. Defines the end boundary for all charges, usage, and credits included in the invoice.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The first day of the billing cycle period covered by this invoice. Defines the start boundary for all charges, usage, and credits included in the invoice.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingSegment rdf:type rdf:Property ;
    rdfs:label 'Billing Segment' ;
    rdfs:comment 'Customer segment classification for this invoice, used for segmented revenue reporting, ARPU (Average Revenue Per User) analysis, and MRR (Monthly Recurring Revenue) tracking. MVNO (Mobile Virtual Network Operator) segment covers reseller billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Current Charges Amount' ;
    rdfs:comment 'Total of all new charges incurred during the current billing period before taxes and fees. Includes recurring subscription charges, usage charges, and one-time charges rated by Amdocs Revenue Management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which the customer must settle the invoice to avoid late payment charges or dunning actions. Calculated from bill_date plus the payment terms defined on the billing account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feesAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Amount' ;
    rdfs:comment 'Total regulatory fees, administrative fees, and surcharges applied to the invoice that are distinct from taxes. Includes items such as regulatory recovery fees, network access fees, and late payment fees.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice reference number issued to the customer. Printed on the billing statement and used for customer service inquiries and payment references. Sourced from Amdocs Revenue Management invoicing module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Drives collections workflows, dunning processes, and revenue recognition in Amdocs Revenue Management. Valid states: draft (being prepared), issued (sent to customer), paid (fully settled), disputed (customer raised dispute), written_off (deemed uncollectable), cancelled (voided before issuance).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice by its business purpose. Standard: regular periodic billing; Final: issued upon account closure; Interim: mid-cycle billing; Credit Note: net credit to customer; Debit Note: additional charge; Pro Forma: estimate before final billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this invoice is currently under a customer billing dispute. True when a dispute has been raised and is pending resolution. Used to flag invoices for collections hold and dispute management workflows.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaperless rdf:type rdf:Property ;
    rdfs:label 'Is Paperless' ;
    rdfs:comment 'Indicates whether the customer has opted into paperless billing for this invoice. True when delivery_channel is email or portal. Used for sustainability reporting and paper bill fee waiver logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The precise timestamp when the invoice was dispatched to the customer via the configured delivery channel. Distinct from bill_date (the billing date) and created_timestamp (record creation). Used for SLA (Service Level Agreement) compliance on bill delivery timeliness.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latePaymentFee rdf:type rdf:Property ;
    rdfs:label 'Late Payment Fee' ;
    rdfs:comment 'Fee assessed on this invoice for late payment of a prior invoice, per the terms and conditions of the customer\'s service agreement. Included in fees_amount but tracked separately for fee revenue reporting and customer dispute management.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on this invoice, calculated as total_amount_due minus paid_amount. Used for accounts receivable aging, collections prioritization, and MRR (Monthly Recurring Revenue) reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount paid by the customer against this specific invoice to date. Used to calculate the outstanding balance and determine if the invoice is fully or partially settled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'The timestamp when the invoice was fully settled and transitioned to paid status. Null for unpaid or partially paid invoices. Used for days-sales-outstanding (DSO) calculation and payment behavior analytics.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paperBillFee rdf:type rdf:Property ;
    rdfs:label 'Paper Bill Fee' ;
    rdfs:comment 'Fee charged to the customer for receiving a paper invoice by mail, where applicable. Zero or null for customers enrolled in paperless billing. Supports paperless billing adoption tracking and fee revenue reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentsReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payments Received Amount' ;
    rdfs:comment 'Total payments and credits received from the customer since the last invoice, applied against the previous balance. Reduces the amount owed on the current statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Balance Amount' ;
    rdfs:comment 'Outstanding balance carried forward from the prior billing cycle before any new charges or payments are applied. Represents the opening balance on the current invoice statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceInvoiceRef rdf:type rdf:Property ;
    rdfs:label 'Source Invoice Ref' ;
    rdfs:comment 'The native invoice identifier from the originating source system (Amdocs or Comverse ONE) before transformation into the enterprise data lakehouse. Enables traceability and reconciliation between the Silver Layer and the operational billing system.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'The net total amount the customer must pay, calculated as previous_balance_amount minus payments_received_amount plus current_charges_amount plus adjustments_amount plus tax_amount plus fees_amount. This is the authoritative amount printed on the customer-facing billing statement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual invoice line item within the Amdocs Revenue Management system. Serves as the primary key for the invoice_line data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:msisdnRangeId rdf:type rdf:Property ;
    rdfs:label 'Msisdn Range Id' ;
    rdfs:comment 'Foreign key linking to inventory.msisdn_range. Business justification: Number porting fees, premium number charges, or vanity number fees must reference the MSISDN range. Required for number-related billing, regulatory fee allocation, and premium number revenue tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsisdnRange .

ind:originalLineInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line item that this adjustment, credit, or reversal line corrects or offsets. Populated only for adjustment and reversal lines to maintain the audit chain between original charges and their corrections. Enables complete billing history reconstruction.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:tapRecordId rdf:type rdf:Property ;
    rdfs:label 'Tap Record Id' ;
    rdfs:comment 'Foreign key linking to interconnect.tap_record. Business justification: Retail invoice lines for roaming services must trace to originating TAP records for customer dispute investigation and retail-to-wholesale charge reconciliation—required for proving charge validity to' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapRecord .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any billing adjustment or credit applied to this line item. Examples include billing error corrections, goodwill credits, SLA breach credits, or dispute resolutions. Populated only when charge_type is \'adjustment\' or \'credit\'. Used for revenue assurance and dispute analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Charge Period End' ;
    rdfs:comment 'The end date of the billing period covered by this charge line item. For recurring charges, this is the last day of the service period. For usage charges, this is the end of the usage aggregation window. Used alongside charge_period_start for proration and revenue recognition period allocation.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Charge Period Start' ;
    rdfs:comment 'The start date of the billing period covered by this charge line item. For recurring charges, this is the first day of the service period. For usage charges, this is the start of the usage aggregation window. Essential for proration calculations and dispute resolution.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'The promotional or contractual discount code applied to this line item. References the specific discount offer or loyalty program that generated the discount_amount. Used for discount effectiveness analysis and revenue leakage detection in revenue assurance.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this charge is a recurring Monthly Recurring Revenue (MRR) component. True for subscription-based charges that appear each billing cycle (e.g., monthly plan fees, equipment rental). Used for MRR reporting and revenue forecasting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this line item is subject to taxation. False for tax-exempt charges such as certain government or non-profit customer lines, or for line items that are themselves tax charges. Used by the Amdocs tax engine and for regulatory tax reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent invoice. Used for itemized bill presentation, dispute resolution, and maintaining consistent line ordering across billing cycles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of this invoice line item. Active lines are valid billed charges. Disputed lines are under customer dispute investigation. Adjusted lines have been corrected. Cancelled lines have been voided. Reversed lines have been credited back. Written_off lines have been deemed uncollectable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaidIndicator rdf:type rdf:Property ;
    rdfs:label 'Prepaid Indicator' ;
    rdfs:comment 'Indicates whether this charge line originated from a prepaid account managed by Comverse ONE real-time rating and balance management, as opposed to a postpaid account managed by Amdocs Revenue Management. Drives different revenue recognition and reporting treatment.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the rated_quantity field. Specifies the dimension in which consumption is expressed (e.g., minutes for voice, MB/GB for data, SMS for messaging). Essential for correct interpretation of the rated quantity in billing analytics and dispute resolution. [ENUM-REF-CANDIDATE: minutes|seconds|MB|GB|TB|SMS|units|events|days|months — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rated Quantity' ;
    rdfs:comment 'The metered or rated quantity of consumption that forms the basis for this charge. Represents units consumed such as minutes of voice calls, megabytes of data, number of SMS messages, or number of pay-per-view events. Sourced from the Amdocs rating engine after processing CDRs.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingPlanCode rdf:type rdf:Property ;
    rdfs:label 'Rating Plan Code' ;
    rdfs:comment 'The identifier of the tariff or rating plan applied by the Amdocs rating engine to compute the charge for this line item. Enables traceability of the pricing logic used and supports revenue assurance validation against the product catalog.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rating Timestamp' ;
    rdfs:comment 'The date and time when the Amdocs rating engine processed and rated this charge. Provides an audit trail for the rating event and is used to reconcile rated charges against CDR processing windows in revenue assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roamingIndicator rdf:type rdf:Property ;
    rdfs:label 'Roaming Indicator' ;
    rdfs:comment 'Indicates whether this charge was incurred while the customer was roaming on a visited network outside their home network. True for roaming charges subject to GSMA TAP/NRTRDE inter-operator settlement and IOT (Inter-Operator Tariff) pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Service Identifier' ;
    rdfs:comment 'The specific service instance identifier associated with this charge, such as the MSISDN (mobile number), IMSI, broadband circuit ID, or IPTV subscriber ID. Enables line-level traceability to the specific service that generated the charge.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineRef rdf:type rdf:Property ;
    rdfs:label 'Source System Line Ref' ;
    rdfs:comment 'The native line item identifier from the originating source system (Amdocs Revenue Management or Comverse ONE) before surrogate key assignment in the Databricks Silver Layer. Enables lineage tracing back to the operational system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The final billed amount for this line item inclusive of all taxes and after all discounts. Calculated as net_amount plus tax_amount. This is the amount that contributes to the invoice total and the customer\'s payable balance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The per-unit price applied to the rated quantity to compute the gross charge amount. Sourced from the Amdocs rating engine\'s tariff tables. For example, the per-minute rate for international calls or the per-GB rate for data overage charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitedNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Visited Network Code' ;
    rdfs:comment 'The Public Land Mobile Network (PLMN) code of the visited operator\'s network where roaming usage was consumed. Composed of MCC (Mobile Country Code) and MNC (Mobile Network Code). Required for GSMA TAP inter-operator settlement and roaming revenue reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment record in the billing system. Primary key for the payment data product. Sourced from Amdocs Collections module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:originalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Id' ;
    rdfs:comment 'Reference to the original payment record that this record reverses, refunds, or adjusts. Enables chargeback and reversal lineage tracing. Null for original (non-derived) payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Reference to an instalment or payment arrangement plan under which this payment was made. Null for standard one-off payments. Used to track compliance with payment arrangement agreements in collections.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatePlan .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross monetary amount of the payment as submitted by the customer or payment processor, before any adjustments or fees. Expressed in the billing currency. Core field for revenue reconciliation and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Alphanumeric authorization or approval code returned by the payment gateway or card network upon successful transaction authorization. Used for dispute resolution, chargeback processing, and reconciliation with payment processors.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number used for direct debit or bank transfer payments. Stored as a masked identifier for verification. Null for non-bank payment methods.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'Bank routing number (ABA/ACH in the US) or sort code (UK) or BIC/SWIFT code for international transfers, identifying the financial institution for direct debit and bank transfer payments. Null for non-bank payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company\'s functional (base) currency using the exchange_rate at the time of payment. Used for consolidated financial reporting and revenue recognition in the base currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'Last four digits of the payment card number used for the transaction. Stored as a masked identifier for customer service verification and reconciliation. Full card number is never stored per PCI DSS requirements.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Card network brand for credit or debit card payments (e.g., Visa, Mastercard, Amex). Null for non-card payment methods. Used for interchange fee analysis and payment mix reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied to convert the payment amount from the transaction currency to the billing base currency at the time of payment. Relevant for international customers and roaming settlement. 1.0 for same-currency transactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateway rdf:type rdf:Property ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Name or identifier of the external payment gateway or processor that handled the transaction (e.g., Stripe, Adyen, PayPal, WorldPay, internal BSS gateway). Used for reconciliation, gateway performance monitoring, and fee analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutoPay rdf:type rdf:Property ;
    rdfs:label 'Is Auto Pay' ;
    rdfs:comment 'Indicates whether this payment was collected automatically via a recurring auto-pay mandate (True) or was manually initiated by the customer or agent (False). Used for auto-pay adoption analytics and churn risk modelling.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialPayment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Payment' ;
    rdfs:comment 'Indicates whether this payment covers only a portion of the total outstanding balance (True) or fully settles the billed amount (False). Used in collections and dunning workflows to identify accounts with partial payment arrangements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Received Amount' ;
    rdfs:comment 'Net amount received after deducting payment processing fees from the gross payment_amount. Represents the actual funds credited to the telco\'s account. Used for cash flow reporting and revenue assurance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The calendar date on which the payment was received or initiated by the customer. This is the principal business event date used for revenue recognition, aging analysis, and MRR reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the payment transaction. \'pending\' — received but not yet confirmed; \'cleared\' — funds confirmed; \'reversed\' — payment reversed/chargeback; \'failed\' — transaction declined or errored; \'refunded\' — amount returned to customer; \'disputed\' — under dispute investigation. Drives collections and dunning workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment by its business purpose: standard (regular bill payment), advance (payment before bill issuance), deposit (security deposit), refund (return of funds to customer), reversal (cancellation of a prior payment), adjustment (billing correction). Drives accounting treatment and revenue recognition.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the payment gateway or processor for handling this transaction. Deducted from the gross payment amount to derive net received funds. Used for payment cost analysis and OPEX reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the payment transaction was received and recorded in the Amdocs Collections system. Used for real-time reconciliation and SLA tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this payment transaction. Used by customers and agents to track and reconcile payments. Sourced from Amdocs Collections module.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the payment reversal or chargeback was processed. Null for non-reversed payments. Used for collections workflow timing and dispute SLA tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the payment funds were actually settled and confirmed by the bank or payment processor. May differ from payment_date for card and bank transfer payments due to clearing cycles. Used for cash flow and revenue recognition reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the external payment gateway, bank, or payment processor. Used to cross-reference and reconcile payments with third-party payment systems and bank statements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount not yet allocated to any invoice or charge. Represents an overpayment credit or advance payment held on the billing account pending future allocation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date from which the payment is considered valid for interest and balance calculations. Used in financial accounting and bank reconciliation. May differ from payment_date and settlement_date.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Unique alphanumeric code of the prepaid voucher or gift card redeemed as payment. Applicable only when payment_method is \'voucher\'. Used for voucher reconciliation and prepaid balance management in Comverse ONE.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment allocation record in the Amdocs Collections module. Serves as the primary key for the payment_allocation data product in the billing domain Silver layer.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedAllocationPaymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Allocation Payment Allocation Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original payment_allocation_id that this record reverses. Populated only when allocation_type = \'reversal\'. Enables full reversal chain traceability in the AR ledger.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentAllocation .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that has been applied to the referenced invoice or charge in this allocation record. Core financial field for AR reconciliation and partial payment tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the payment was formally allocated to the invoice or charge. Used as the key date for AR aging buckets, financial close, and revenue recognition reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this allocation record as generated by Amdocs Collections. Used in customer correspondence, dispute resolution, and financial audit trails.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the allocation record. \'allocated\' indicates the amount has been successfully applied to the invoice; \'reversed\' indicates a prior allocation was undone; \'pending_review\' indicates the allocation is under dispute or manual review; \'partially_allocated\' indicates only a portion of the payment has been applied; \'cancelled\' indicates the allocation was voided; \'on_hold\' indicates a dispute-hold is in effect. [ENUM-REF-CANDIDATE: allocated|reversed|pending_review|partially_allocated|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the allocation transaction was processed in Amdocs Collections. Distinct from allocation_date; used for intraday reconciliation and audit trail.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classifies the nature of the allocation transaction. \'standard\' is a normal payment-to-invoice application; \'reversal\' undoes a prior allocation; \'adjustment\' applies a billing adjustment; \'dispute_settlement\' closes a disputed amount; \'write_off\' applies a bad debt write-off; \'credit_memo\' applies a credit note. [ENUM-REF-CANDIDATE: standard|reversal|adjustment|dispute_settlement|write_off|credit_memo — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance After' ;
    rdfs:comment 'The remaining outstanding balance on the invoice immediately after this allocation was applied. A zero value indicates the invoice is fully settled; a positive value indicates a partial payment.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance Before' ;
    rdfs:comment 'The outstanding balance on the invoice immediately prior to this allocation being applied. Enables audit trail of how each allocation reduced the invoice balance and supports dispute resolution.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutoAllocated rdf:type rdf:Property ;
    rdfs:label 'Is Auto Allocated' ;
    rdfs:comment 'Indicates whether this allocation was performed automatically by the Amdocs Collections engine (True) or was manually applied by a collections agent (False). Supports operational analytics on automation rates and manual intervention tracking.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'The portion of the allocated_amount that corresponds to late payment fees or penalty charges applied to the invoice. Tracked separately for fee revenue reporting and customer dispute management.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overpaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Overpayment Amount' ;
    rdfs:comment 'The amount by which the payment exceeds the total invoice balance, resulting in a credit or refund. Populated when the payment amount is greater than the invoice due amount. Zero if no overpayment exists.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overpaymentHandling rdf:type rdf:Property ;
    rdfs:label 'Overpayment Handling' ;
    rdfs:comment 'Defines how any overpayment amount is to be processed. \'credit_balance\' retains the excess as a credit on the account; \'refund\' triggers a refund transaction back to the customer; \'apply_to_next\' carries the credit forward to the next billing cycle; \'write_off\' writes off the overpayment per policy; \'pending\' indicates the handling decision is awaiting approval.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalAmount rdf:type rdf:Property ;
    rdfs:label 'Principal Amount' ;
    rdfs:comment 'The portion of the allocated_amount that corresponds to the base service charges (excluding taxes and fees). Supports revenue recognition, MRR reporting, and ARPU calculation by isolating the core service revenue component.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Source System Allocation Code' ;
    rdfs:comment 'The native allocation identifier as recorded in the originating source system (Amdocs Collections or Comverse ONE). Preserved for end-to-end traceability and reconciliation between the Silver lakehouse layer and the operational BSS system.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'The portion of the original payment that remains unallocated after this allocation record is processed. Critical for unallocated cash management and financial close reporting in Amdocs Collections.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepaidBalanceId rdf:type rdf:Property ;
    rdfs:label 'Prepaid Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for the prepaid balance record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrepaidBalance .

ind:primaryPrepaidMigrationTargetAccountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Prepaid Migration Target Account Billing Account Id' ;
    rdfs:comment 'Reference to the postpaid billing account to which this prepaid balance was migrated. Populated only when balance_status = \'migrated_to_postpaid\'. Supports prepaid-to-postpaid migration tracking and balance transfer reconciliation.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Reference to the active prepaid subscription or service plan associated with this balance record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Telecommunication .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which this prepaid balance account was first activated. Marks the start of the subscriber\'s prepaid lifecycle. Used for tenure calculation, cohort analysis, and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRechargeAmount rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Amount' ;
    rdfs:comment 'Fixed monetary amount to be automatically recharged when the auto-recharge trigger threshold is reached. Expressed in the account currency. Configured by the subscriber or defaulted by the plan.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRechargeEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Enabled' ;
    rdfs:comment 'Indicates whether the subscriber has configured automatic recharge (top-up) to trigger when the main balance falls below the auto_recharge_trigger_threshold. True = auto-recharge active; False = manual recharge only.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRechargePaymentToken rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Payment Token' ;
    rdfs:comment 'Tokenized reference to the payment instrument (e.g., credit/debit card token, bank account token) used for automatic recharge transactions. The actual card/account details are stored in the payment vault; this token is the PCI-compliant reference. Sourced from Amdocs Revenue Management payment tokenization.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRechargeTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Auto Recharge Trigger Threshold' ;
    rdfs:comment 'Monetary balance level at which the auto-recharge process is automatically triggered. When main_balance_amount falls at or below this value and auto_recharge_enabled is True, a recharge of auto_recharge_amount is initiated. Expressed in the account currency.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceFreezeReason rdf:type rdf:Property ;
    rdfs:label 'Balance Freeze Reason' ;
    rdfs:comment 'Reason code explaining why the balance is in \'frozen\' status. Populated only when balance_status = \'frozen\'. Supports compliance audit trails and operational workflows. [ENUM-REF-CANDIDATE: fraud_investigation|regulatory_hold|subscriber_request|legal_order|sim_swap_pending — promote to reference product]' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Balance Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number for this prepaid balance record, as assigned by Comverse ONE Balance Management. Used in customer-facing communications and balance inquiries.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the most recent balance snapshot captured from Comverse ONE Balance Management. Indicates the freshness of the balance data in the Silver Layer. Critical for real-time authorization latency monitoring and data quality SLA tracking.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle state of the prepaid balance account. \'active\' indicates the balance is usable; \'expired\' indicates the validity period has lapsed; \'frozen\' indicates the balance is temporarily locked (e.g., fraud hold); \'migrated_to_postpaid\' indicates the subscriber has converted to a postpaid plan; \'suspended\' indicates service suspension due to non-recharge or regulatory action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceValidityDays rdf:type rdf:Property ;
    rdfs:label 'Balance Validity Days' ;
    rdfs:comment 'Number of days the main balance remains valid from the last recharge date. Determines the main_balance_expiry_date. Defined by the subscriber\'s active prepaid plan or recharge denomination.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Balance Amount' ;
    rdfs:comment 'Monetary value of promotional or bonus credits awarded to the subscriber (e.g., recharge bonuses, loyalty rewards, campaign credits). Typically consumed after the main balance is exhausted. Expressed in the account currency.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Content Credit Balance' ;
    rdfs:comment 'Remaining balance in the subscriber\'s dedicated content credit bucket, used for OTT content, IPTV, or digital entertainment purchases. Expressed in the account currency. Sourced from Comverse ONE Balance Management.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentCreditExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Content Credit Expiry Date' ;
    rdfs:comment 'Date on which the content credit bucket expires. Unused content credits are forfeited after this date.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated mobile data bucket expires. Remaining data allowance is forfeited after this date unless renewed via a recharge or data add-on purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataBucketMb rdf:type rdf:Property ;
    rdfs:label 'Data Bucket Mb' ;
    rdfs:comment 'Remaining dedicated mobile data balance in the subscriber\'s data allowance bucket, expressed in megabytes (MB). Decremented in real-time during data sessions via Comverse ONE online charging and DPI-based usage reporting.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which this prepaid balance account was deactivated (e.g., after grace period expiry, subscriber-initiated cancellation, or regulatory action). Null if the account is still active. Used for churn analysis and MSISDN recycling workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the main balance expiry date during which the subscriber may still receive incoming calls/SMS but cannot initiate outgoing services. After the grace period, the account may be deactivated. Defined by regulatory requirements and plan configuration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period Expiry Date' ;
    rdfs:comment 'Date on which the grace period ends. After this date, the prepaid account may be deactivated and the MSISDN released for recycling if no recharge is made. Calculated as main_balance_expiry_date + grace_period_days.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iccid rdf:type rdf:Property ;
    rdfs:label 'Iccid' ;
    rdfs:comment 'Unique identifier of the physical SIM or eSIM card associated with this prepaid balance account. Used for SIM swap detection, fraud management, and device-balance association. Follows ITU-T E.118 format.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsi rdf:type rdf:Property ;
    rdfs:label 'Imsi' ;
    rdfs:comment 'Unique identifier stored on the SIM/eSIM that identifies the subscriber on the mobile network. Used by the HLR/HSS/UDM for authentication and real-time charging authorization. Classified as restricted PII as it uniquely identifies a subscriber on the network.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRechargeAmount rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Amount' ;
    rdfs:comment 'Monetary value of the most recent recharge (top-up) applied to this prepaid account, expressed in the account currency. Used for ARPU calculation, recharge pattern analysis, and revenue reporting.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRechargeChannel rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Channel' ;
    rdfs:comment 'Channel through which the most recent recharge was applied. Supports channel performance analytics and customer journey analysis. [ENUM-REF-CANDIDATE: ussd|ivr|mobile_app|web_portal|retail_store|agent|voucher|bank_transfer — promote to reference product]' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRechargeDate rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Date' ;
    rdfs:comment 'Calendar date of the most recent successful recharge (top-up) applied to this prepaid account. Used for churn analysis, recharge frequency reporting, and dormancy detection.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRechargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Recharge Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) of the most recent successful recharge event applied to this prepaid account. Provides sub-day precision for real-time authorization and fraud detection workflows.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lowBalanceNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Low Balance Notification Enabled' ;
    rdfs:comment 'Indicates whether the subscriber has opted in to receive low-balance notifications when the main balance falls below the low_balance_threshold. True = notifications enabled; False = notifications disabled.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Low Balance Threshold' ;
    rdfs:comment 'Monetary threshold below which a low-balance notification is triggered to the subscriber (e.g., via SMS, push notification, or USSD). Expressed in the account currency. Configurable per subscriber or plan.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Main Balance Amount' ;
    rdfs:comment 'Current monetary balance available in the subscriber\'s primary prepaid wallet, expressed in the account currency. This is the principal cash-equivalent balance used for general service charges, roaming, and out-of-bundle usage. Sourced from Comverse ONE real-time balance management.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainBalanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Main Balance Expiry Date' ;
    rdfs:comment 'Date on which the main monetary balance expires and becomes unavailable for use if not recharged. After this date, the balance_status transitions to \'expired\'. Critical for low-balance notification and recharge prompting workflows.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msisdn rdf:type rdf:Property ;
    rdfs:label 'Msisdn' ;
    rdfs:comment 'The subscriber\'s mobile phone number in E.164 format, uniquely identifying the prepaid SIM/eSIM on the network. Used for balance inquiries, recharge operations, and real-time authorization. Classified as PII as it directly identifies an individual subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rechargeCountCurrentMonth rdf:type rdf:Property ;
    rdfs:label 'Recharge Count Current Month' ;
    rdfs:comment 'Number of successful recharge transactions applied to this prepaid account in the current calendar month. Supports MRR calculation, monthly ARPU reporting, and recharge frequency analytics.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rechargeCountLifetime rdf:type rdf:Property ;
    rdfs:label 'Recharge Count Lifetime' ;
    rdfs:comment 'Total number of successful recharge (top-up) transactions applied to this prepaid account since activation. Used for subscriber loyalty segmentation, ARPU analysis, and churn prediction models.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this prepaid balance record was first created in the Databricks Silver Layer. Supports audit trail, data lineage, and compliance reporting requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this prepaid balance record in the Databricks Silver Layer. Used for change data capture (CDC), incremental processing, and audit trail compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Reserved Balance Amount' ;
    rdfs:comment 'Amount of the main balance currently reserved (locked) for active in-progress sessions (e.g., ongoing voice calls, active data sessions). Prevents double-spending during real-time authorization. Released upon session termination. Sourced from Comverse ONE online charging.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sms Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated SMS units bucket expires. Remaining SMS units are forfeited after this date unless renewed via a recharge or bundle purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsBucketUnits rdf:type rdf:Property ;
    rdfs:label 'Sms Bucket Units' ;
    rdfs:comment 'Remaining dedicated SMS units in the subscriber\'s SMS allowance bucket. Each unit typically represents one standard SMS message. Decremented in real-time via Comverse ONE charging.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceBucketExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Voice Bucket Expiry Date' ;
    rdfs:comment 'Date on which the dedicated voice minutes bucket expires. Remaining voice minutes are forfeited after this date unless renewed via a recharge or bundle purchase.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voiceBucketMinutes rdf:type rdf:Property ;
    rdfs:label 'Voice Bucket Minutes' ;
    rdfs:comment 'Remaining dedicated voice minutes balance in the subscriber\'s voice allowance bucket. Decremented in real-time during voice calls via Comverse ONE real-time rating. Expressed in minutes.' ;
    rdfs:domain ind:PrepaidBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Rate plan authorship required for pricing governance, regulatory tariff filing audit trail, and product management accountability. Standard telco practice for pricing change control and regulatory com' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to sales.promotion. Business justification: Rate plans are frequently tied to promotional campaigns; promotion_id tracks which promotion drove rate plan selection for campaign ROI analysis, promotional effectiveness measurement, and marketing a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:activationFee rdf:type rdf:Property ;
    rdfs:label 'Activation Fee' ;
    rdfs:comment 'One-time fee charged at the time of service activation for this rate plan. Denominated in currency_code. A value of 0 indicates no activation fee. Captured as a one-time charge in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The frequency at which the recurring charge is applied and the billing cycle is closed. Drives invoice generation scheduling in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingModel rdf:type rdf:Property ;
    rdfs:label 'Charging Model' ;
    rdfs:comment 'The pricing model applied by the rating engine to calculate charges. \'flat\' = fixed charge regardless of usage; \'tiered\' = stepped rates at volume thresholds; \'volume\' = single rate applied to total volume; \'event_based\' = per-event charge; \'time_based\' = charge per unit of time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Minimum contractual commitment period in months associated with this rate plan (e.g., 12, 24, 36 months). A value of 0 indicates a month-to-month or no-commitment plan. Drives early termination fee (ETF) calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekModifierEnabled rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Modifier Enabled' ;
    rdfs:comment 'Indicates whether this rate plan applies day-of-week pricing modifiers (e.g., weekend discount rates). When TRUE, the rating engine evaluates the CDR date against the configured weekend/weekday windows.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fixed monetary penalty charged to a subscriber who cancels the service before the contract_term_months expires. Denominated in currency_code. A value of 0 indicates no early termination fee. Used in churn management and collections workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairUseCapMb rdf:type rdf:Property ;
    rdfs:label 'Fair Use Cap Mb' ;
    rdfs:comment 'Maximum data volume in megabytes beyond which the fair-use policy is triggered, resulting in speed throttling or additional charges. Distinct from the included_data_volume_mb allowance — this is the absolute ceiling before network management actions are applied. NULL indicates no fair-use cap.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedDataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Included Data Volume Mb' ;
    rdfs:comment 'Data volume allowance included in the base recurring charge, expressed in megabytes (MB). A value of -1 or NULL indicates unlimited data. The rating engine deducts consumed data against this allowance before applying overage rates or fair-use policy throttling.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedSmsCount rdf:type rdf:Property ;
    rdfs:label 'Included Sms Count' ;
    rdfs:comment 'Number of SMS messages included in the base recurring charge before overage rates apply. A value of -1 or NULL indicates unlimited SMS. Used by the rating engine for SMS CDR allowance tracking.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:includedVoiceMinutes rdf:type rdf:Property ;
    rdfs:label 'Included Voice Minutes' ;
    rdfs:comment 'Number of voice call minutes included in the rate plan\'s base recurring charge before overage rates apply. A value of -1 or NULL indicates unlimited voice. Used by the rating engine to track allowance consumption against CDRs.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Indicates whether this rate plan is a promotional or limited-time offer. When TRUE, the plan may have an associated promotion expiry date and is tracked separately in ARPU and MRR reporting to distinguish promotional revenue from base revenue.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Commercial market segment for which this rate plan is designed. Drives eligibility rules in the product catalog and CRM. \'consumer\' = individual retail customers; \'smb\' = Small and Medium Business; \'enterprise\' = large corporate accounts; \'wholesale\' = carrier/MVNO partners; \'government\' = public sector accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offPeakRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Off Peak Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate during off-peak hours when time_of_day_modifier_enabled is TRUE. A value of 0.5 means 50% discount during off-peak. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Overage Rate Per Unit' ;
    rdfs:comment 'The per-unit charge applied to usage that exceeds the included allowance. The unit of measure is defined by overage_unit_of_measure. For data, this is typically per MB or per GB; for voice, per minute; for SMS, per message. Denominated in currency_code.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Overage Unit Of Measure' ;
    rdfs:comment 'The unit of measure against which the overage_rate_per_unit is applied. Defines the granularity of overage billing (e.g., per MB for data, per minute for voice, per message for SMS). [ENUM-REF-CANDIDATE: MB|GB|minute|second|message|event|kB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakEndTime rdf:type rdf:Property ;
    rdfs:label 'Peak End Time' ;
    rdfs:comment 'The daily end time (HH:MM, 24-hour format) of the peak pricing window. Used by the rating engine to determine whether a CDR falls within peak or off-peak hours. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peakRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate during peak hours when time_of_day_modifier_enabled is TRUE. A value of 1.0 means no adjustment; 1.5 means 50% premium during peak. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakStartTime rdf:type rdf:Property ;
    rdfs:label 'Peak Start Time' ;
    rdfs:comment 'The daily start time (HH:MM, 24-hour format) of the peak pricing window. Used by the rating engine to determine whether a CDR falls within peak or off-peak hours. NULL when time-of-day pricing is not enabled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the rate plan within the Amdocs Rating engine. Controls whether the plan is available for new subscriptions and active rating. \'draft\' = under configuration; \'active\' = live for rating; \'suspended\' = temporarily halted; \'deprecated\' = replaced by a newer plan; \'inactive\' = decommissioned.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Billing modality of the rate plan. \'postpaid\' = charges billed after consumption cycle; \'prepaid\' = charges deducted from pre-loaded balance via Comverse ONE real-time rating; \'hybrid\' = mixed prepaid/postpaid; \'wholesale\' = inter-operator or MVNO wholesale pricing; \'mvno\' = Mobile Virtual Network Operator resale pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'The date on which the promotional pricing expires and the standard rate plan pricing takes effect. Applicable only when is_promotional is TRUE. NULL for non-promotional plans.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method used to calculate partial-period charges when a subscription starts or ends mid-billing-cycle. \'daily\' = charge proportional to days active; \'full_period\' = charge full cycle regardless; \'none\' = no proration applied.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Description' ;
    rdfs:comment 'Detailed narrative description of the rate plan\'s pricing logic, applicable services, and commercial intent. Used by product managers, billing analysts, and regulatory reporting teams to understand the plan\'s scope.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePlanName rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Name' ;
    rdfs:comment 'Human-readable name of the rate plan as displayed in the Amdocs Rating engine configuration and referenced in billing statements and internal reporting (e.g., \'Unlimited 5G Consumer Postpaid\', \'SMB Data Tier 3\').' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTierCount rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Count' ;
    rdfs:comment 'Number of pricing tiers (step thresholds) defined for this rate plan. A value of 1 indicates flat-rate pricing; values greater than 1 indicate tiered/stepped pricing where different rates apply at different usage volumes. Drives the rating engine\'s tier evaluation logic.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingMethod rdf:type rdf:Property ;
    rdfs:label 'Rating Method' ;
    rdfs:comment 'Indicates whether usage events (CDRs) under this rate plan are rated in real-time (online charging via Comverse ONE for prepaid) or in batch mode (offline charging via Amdocs for postpaid), or a hybrid of both.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Recurring Charge Amount' ;
    rdfs:comment 'The fixed periodic charge applied to a subscription on this rate plan per billing cycle (e.g., monthly base fee). Represents the Monthly Recurring Revenue (MRR) component at the plan level. Denominated in the currency specified by currency_code.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingDataRatePerMb rdf:type rdf:Property ;
    rdfs:label 'Roaming Data Rate Per Mb' ;
    rdfs:comment 'Per-megabyte charge applied to data usage while roaming internationally, denominated in currency_code. Applies when roaming_enabled is TRUE and the subscriber is on a visited network. Used for IOT (Inter-Operator Tariff) reconciliation.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Roaming Enabled' ;
    rdfs:comment 'Indicates whether international roaming usage is permitted and rated under this rate plan. When FALSE, roaming CDRs are blocked or rated at a default barring rate. Relevant for NRTRDE/TAP roaming data exchange compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingVoiceRatePerMin rdf:type rdf:Property ;
    rdfs:label 'Roaming Voice Rate Per Min' ;
    rdfs:comment 'Per-minute charge applied to voice calls while roaming internationally, denominated in currency_code. Applies when roaming_enabled is TRUE. Used for IOT reconciliation and NRTRDE reporting.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxClassCode rdf:type rdf:Property ;
    rdfs:label 'Tax Class Code' ;
    rdfs:comment 'Tax classification code assigned to this rate plan, used by the Amdocs tax engine to determine applicable tax rates (e.g., USF, VAT, GST, E911 surcharges). Maps to the tax jurisdiction configuration in the billing system.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRate1 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 1' ;
    rdfs:comment 'Per-unit charge applied to usage within the first pricing tier (from 0 to tier_threshold_1_mb). Denominated in currency_code per overage_unit_of_measure.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRate2 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 2' ;
    rdfs:comment 'Per-unit charge applied to usage within the second pricing tier (from tier_threshold_1_mb to tier_threshold_2_mb). Denominated in currency_code per overage_unit_of_measure. NULL if fewer than 2 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRate3 rdf:type rdf:Property ;
    rdfs:label 'Tier Rate 3' ;
    rdfs:comment 'Per-unit charge applied to usage beyond tier_threshold_2_mb (third tier and above). Denominated in currency_code per overage_unit_of_measure. NULL if fewer than 3 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThreshold1Mb rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold 1 Mb' ;
    rdfs:comment 'Usage volume threshold in MB at which the first pricing tier ends and the second tier begins. NULL if the plan has fewer than 2 tiers. Used by the Amdocs rating engine for stepped-rate calculation.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThreshold2Mb rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold 2 Mb' ;
    rdfs:comment 'Usage volume threshold in MB at which the second pricing tier ends and the third tier begins. NULL if the plan has fewer than 3 tiers.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeOfDayModifierEnabled rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Modifier Enabled' ;
    rdfs:comment 'Indicates whether this rate plan applies time-of-day pricing modifiers (e.g., peak/off-peak rates). When TRUE, the rating engine evaluates the CDR timestamp against the defined peak/off-peak windows to apply the appropriate rate multiplier.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekendRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Weekend Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the base rate on weekend days (Saturday and Sunday) when day_of_week_modifier_enabled is TRUE. A value of 0.0 means free weekend calls/data. NULL when day-of-week pricing is not enabled.' ;
    rdfs:domain ind:RatePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedEventId rdf:type rdf:Property ;
    rdfs:label 'Rated Event Id' ;
    rdfs:comment 'Unique surrogate primary key for each rated usage event record in the billing silver layer. Generated by the Amdocs Rating engine or Comverse ONE real-time rating pipeline upon successful rating of a raw CDR, IPDR, or partner usage feed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatedEvent .

ind:cdrId rdf:type rdf:Property ;
    rdfs:label 'Cdr Id' ;
    rdfs:comment 'Reference to the originating raw CDR, IPDR, or partner usage feed record from which this rated event was produced. Bridges the CDR domain to the billing/financial domain and enables traceability back to the network event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cdr .

ind:originalRatedEventId rdf:type rdf:Property ;
    rdfs:label 'Original Rated Event Id' ;
    rdfs:comment 'Reference to the original rated event record that this record supersedes or corrects. Populated for re-rated or reversed events to maintain the audit chain. Enables before/after comparison for revenue assurance and dispute resolution.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatedEvent .

ind:servingLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Serving Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Events are served by specific cell sites; essential for site-level revenue attribution, capacity planning ROI analysis, interconnect settlement by site, and correlating billing disputes with site outa' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:accessPointName rdf:type rdf:Property ;
    rdfs:label 'Access Point Name' ;
    rdfs:comment 'The APN used by the subscriber for data sessions, identifying the packet data network gateway and service context (e.g., internet, enterprise VPN, IMS). Used for data service classification, QoS policy application, and DPI-based rating.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleConsumed rdf:type rdf:Property ;
    rdfs:label 'Bundle Consumed' ;
    rdfs:comment 'Indicates whether this rated event was charged against an included bundle allowance (True) or rated as an out-of-bundle/overage charge (False). Used to track bundle utilization, identify overage revenue, and support customer usage analytics.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calledPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Called Party Number' ;
    rdfs:comment 'The destination number (B-party) dialed or messaged by the subscriber for voice calls and SMS events. Used for inter-operator settlement, fraud analysis, and regulatory lawful intercept compliance. Classified as confidential PII.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'The gross charge amount applied to this rated event before discounts and taxes, in the billing currency. Computed by the rating engine based on the applicable rate plan tier and rated volume/duration. Core financial field for revenue recognition and invoice line generation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'The reference number of the billing dispute or inter-operator dispute case associated with this rated event, if applicable. Populated when rating_status = \'disputed\'. Links to the dispute management workflow in Amdocs or ServiceNow ITSM for resolution tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDirection rdf:type rdf:Property ;
    rdfs:label 'Event Direction' ;
    rdfs:comment 'Indicates the origination direction of the usage event. MO (Mobile Originated) = subscriber initiated the call/session; MT (Mobile Terminated) = subscriber received the call/session. Relevant for voice and SMS rating and inter-operator settlement.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'The date and time when the usage event concluded (e.g., call release time, data session termination). Used to compute event duration and for billing cycle boundary determination.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Externally-known business identifier assigned by the rating engine or source OSS/BSS system to uniquely identify this rated event within a billing cycle or batch. Used for reconciliation, dispute resolution, and inter-operator settlement references.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'The date and time when the usage event began (e.g., call answer time, data session start, SMS submission time). This is the principal real-world event time used for billing cycle allocation, time-of-day rating, and CDR correlation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the usage event by service type. Drives rating logic selection and reporting segmentation. Examples: voice (MO/MT calls), SMS, data (packet sessions), roaming (visited network), content (OTT/IPTV), IoT (machine-to-machine). [ENUM-REF-CANDIDATE: voice|sms|data|roaming|content|iot|mms|video — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePlmn rdf:type rdf:Property ;
    rdfs:label 'Home Plmn' ;
    rdfs:comment 'The MCC+MNC code identifying the subscriber\'s home network operator (HPLMN). Used to determine domestic vs. roaming status and to apply correct inter-operator tariffs (IOT) for roaming settlement via GSMA TAP/NRTRDE.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imei rdf:type rdf:Property ;
    rdfs:label 'Imei' ;
    rdfs:comment 'The IMEI of the device used during this usage event. Used for device-level analytics, fraud detection (stolen device usage), and regulatory reporting. Classified as confidential device identifier.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interOperatorCharge rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Charge' ;
    rdfs:comment 'The inter-operator tariff (IOT) charge amount payable to or receivable from the visited network operator for roaming events, in the settlement currency. Populated only for roaming events (is_roaming = true). Used for GSMA TAP/NRTRDE wholesale settlement and interconnect accounting.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRoaming rdf:type rdf:Property ;
    rdfs:label 'Is Roaming' ;
    rdfs:comment 'Flag indicating whether this usage event occurred while the subscriber was roaming on a visited network (VPLMN). True = roaming event subject to inter-operator settlement; False = domestic event. Drives roaming-specific rating rules and GSMA TAP/NRTRDE processing.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Charge Amount' ;
    rdfs:comment 'The final net charge amount for this rated event after applying discounts and taxes (charge_amount - discount_amount + tax_amount) in the billing currency. This is the amount posted to the customer invoice and used for revenue recognition and ARPU calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Rated Duration Seconds' ;
    rdfs:comment 'The billable duration of the usage event in seconds as determined by the rating engine after applying rounding rules (e.g., per-second, per-minute rounding). Applicable for voice and video call events. May differ from raw CDR duration due to rating rounding rules.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Rated Unit Count' ;
    rdfs:comment 'The number of billable units consumed in this event as determined by the rating engine. For SMS: number of message segments; for content: number of items; for IoT: number of transactions. Complements rated_duration_seconds and rated_volume_bytes for non-time/non-data event types.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Rated Volume Bytes' ;
    rdfs:comment 'The billable data volume in bytes as determined by the rating engine after applying any volume rounding or threshold rules. Applicable for data, roaming data, and IoT events. Used for bundle consumption tracking and overage charge calculation.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingEngine rdf:type rdf:Property ;
    rdfs:label 'Rating Engine' ;
    rdfs:comment 'Identifies the rating system that processed and priced this event. \'amdocs\' = Amdocs Revenue Management batch/real-time rating; \'comverse_one\' = Comverse ONE prepaid real-time rating; \'partner_feed\' = rated by a partner/MVNO; \'manual\' = manually rated adjustment. Used for data lineage and revenue assurance.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingMode rdf:type rdf:Property ;
    rdfs:label 'Rating Mode' ;
    rdfs:comment 'Indicates whether this event was rated in real-time (online charging, e.g., Comverse ONE prepaid), batch mode (Amdocs post-processing), or offline (delayed/manual). Affects revenue recognition timing and prepaid balance deduction sequencing.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle state of the rated event within the billing workflow. \'rated\' = successfully priced; \'re_rated\' = repriced after correction; \'disputed\' = under customer or inter-operator dispute; \'written_off\' = revenue written off; \'pending\' = awaiting rating completion; \'rejected\' = failed rating validation. [ENUM-REF-CANDIDATE: rated|re_rated|disputed|written_off|pending|rejected — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTier rdf:type rdf:Property ;
    rdfs:label 'Rating Tier' ;
    rdfs:comment 'The specific pricing tier or band within the rate plan applied to this event (e.g., TIER_1_BUNDLE, TIER_2_OVERAGE, PEAK, OFF_PEAK, ROAM_ZONE_A). Indicates which step of a tiered or time-of-day pricing structure was used. Critical for revenue assurance and rate plan analytics.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reRatingReason rdf:type rdf:Property ;
    rdfs:label 'Re Rating Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why this event was re-rated (e.g., rate plan correction, tariff update, CDR amendment, dispute resolution). Populated only when rating_status = \'re_rated\'. Essential for revenue assurance audit trails.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the roaming event occurred. Populated only when is_roaming = true. Used for roaming revenue reporting, IOT application, and regulatory compliance with visited country regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingPlmn rdf:type rdf:Property ;
    rdfs:label 'Serving Plmn' ;
    rdfs:comment 'The MCC+MNC code of the network that served the subscriber during this event. For domestic events equals the home PLMN; for roaming events identifies the visited network (VPLMN). Critical for inter-operator settlement and roaming IOT application.' ;
    rdfs:domain ind:RatedEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapFileReference rdf:type rdf:Property ;
    rdfs:label 'Tap File Reference' ;
    rdfs:comment 'The GSMA TAP3 file identifier referencing the inter-operator roaming data exchange file from which this roaming rated event was sourced. Used for roaming settlement reconciliation, dispute management, and NRTRDE compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rechargeId rdf:type rdf:Property ;
    rdfs:label 'Recharge Id' ;
    rdfs:comment 'Unique system-generated identifier for each prepaid recharge/top-up transaction record in Comverse ONE. Serves as the primary key for this entity.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceId rdf:type rdf:Property ;
    rdfs:label 'Balance Id' ;
    rdfs:comment 'Foreign key linking to usage.usage_balance. Business justification: Recharges can top up usage balances (data/voice bundles) in addition to monetary prepaid_balance. Link required for bundle top-up tracking, bonus allocation, and hybrid prepaid-postpaid scenarios.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Balance .

ind:originalRechargeId rdf:type rdf:Property ;
    rdfs:label 'Original Recharge Id' ;
    rdfs:comment 'Reference to the original recharge transaction that this record reverses or adjusts. Populated only when reversal_flag is True. Enables audit trail linking between original and reversal transactions.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recharge .

ind:voucherBatchId rdf:type rdf:Property ;
    rdfs:label 'Voucher Batch Id' ;
    rdfs:comment 'Identifier of the voucher production batch from which the recharge voucher was issued. Populated only for voucher-channel recharges. Supports batch-level fraud investigation and distributor reconciliation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VoucherBatch .

ind:balanceAfter rdf:type rdf:Property ;
    rdfs:label 'Balance After' ;
    rdfs:comment 'The subscriber\'s prepaid main balance immediately after this recharge was applied, as recorded by Comverse ONE. Equals balance_before plus net_credited_amount plus bonus_amount. Used for balance audit trails.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceBefore rdf:type rdf:Property ;
    rdfs:label 'Balance Before' ;
    rdfs:comment 'The subscriber\'s prepaid main balance immediately before this recharge was applied, as recorded by Comverse ONE real-time balance management. Used for balance reconciliation and fraud detection.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Balance Expiry Date' ;
    rdfs:comment 'The new expiry date of the subscriber\'s prepaid balance after this recharge was applied. Recharges typically extend the validity period of the prepaid account. Used for balance lifecycle management and subscriber retention analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Additional bonus credit amount awarded to the subscriber\'s balance as part of a promotional offer associated with this recharge. Separate from the net_credited_amount; tracked for promotional liability and revenue assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataBonusMb rdf:type rdf:Property ;
    rdfs:label 'Data Bonus Mb' ;
    rdfs:comment 'Additional data allowance in megabytes (MB) credited to the subscriber\'s data bucket as part of a promotional recharge offer. Null if no data bonus was awarded. Tracked separately from monetary bonus for usage analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized error or failure reason code returned by Comverse ONE or the payment gateway when a recharge transaction fails. Null for successful transactions. Used for failure analysis and NOC troubleshooting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the subscriber\'s home network. Used for international roaming recharge scenarios and regulatory reporting to FCC/ITU/Ofcom.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCreditedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credited Amount' ;
    rdfs:comment 'The net monetary value actually credited to the subscriber\'s prepaid main balance after tax deductions. Equals recharge_amount minus tax_amount. Used for revenue recognition and balance reconciliation.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkNodeCode rdf:type rdf:Property ;
    rdfs:label 'Network Node Code' ;
    rdfs:comment 'Identifier of the network node (e.g., HLR, HSS, or UDM) that processed the recharge authorization and balance update. Used for network-level troubleshooting and capacity planning in NOC operations.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment gateway or bank transaction reference number associated with this recharge, for non-voucher channels (online, bank transfer, mobile app). Used for payment reconciliation with Amdocs Revenue Management collections.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Ms' ;
    rdfs:comment 'Time in milliseconds taken by Comverse ONE to process and complete the recharge transaction from request receipt to balance credit confirmation. Used for SLA monitoring and real-time rating performance analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rechargeDate rdf:type rdf:Property ;
    rdfs:label 'Recharge Date' ;
    rdfs:comment 'Calendar date on which the recharge was applied, derived from recharge_timestamp. Used for daily/monthly MRR reporting, ARPU calculations, and partitioning in the Databricks Silver layer.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rechargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recharge Timestamp' ;
    rdfs:comment 'The exact date and time (in ISO 8601 format with timezone offset) when the recharge event was processed and the subscriber\'s prepaid balance was credited. This is the principal business event timestamp, distinct from record audit timestamps.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rechargeType rdf:type rdf:Property ;
    rdfs:label 'Recharge Type' ;
    rdfs:comment 'Classification of the recharge event by its business nature. Distinguishes standard top-ups from promotional, emergency credit, auto-recharge triggers, or gifted recharges from another subscriber.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this recharge transaction has been reversed or cancelled after initial processing. True = reversed; False = not reversed. Used for revenue assurance and balance reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Flag' ;
    rdfs:comment 'Indicates whether the subscriber was roaming on a visited network at the time of the recharge event. True = subscriber was roaming; False = subscriber was on home network. Relevant for NRTRDE/TAP roaming reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsBonusCount rdf:type rdf:Property ;
    rdfs:label 'Sms Bonus Count' ;
    rdfs:comment 'Additional SMS messages credited to the subscriber\'s SMS bucket as part of a promotional recharge offer. Null if no SMS bonus was awarded.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the recharge transaction as processed by Comverse ONE. \'success\' indicates balance was credited; \'failed\' indicates processing error; \'reversed\' indicates a chargeback or correction; \'partial\' indicates partial credit applied.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ussdSessionCode rdf:type rdf:Property ;
    rdfs:label 'Ussd Session Code' ;
    rdfs:comment 'The USSD session identifier from the IMS/HLR for recharges initiated via USSD short codes. Populated only when recharge_channel is \'ussd\'. Supports USSD session tracing and troubleshooting.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityDays rdf:type rdf:Property ;
    rdfs:label 'Validity Days' ;
    rdfs:comment 'Number of days of service validity granted to the subscriber by this recharge event. Determines how long the subscriber can use the credited balance before it expires.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voiceBonusMinutes rdf:type rdf:Property ;
    rdfs:label 'Voice Bonus Minutes' ;
    rdfs:comment 'Additional voice call minutes credited to the subscriber\'s voice bucket as part of a promotional recharge offer. Null if no voice bonus was awarded. Tracked for promotional liability and usage analytics.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Voucher Serial Number' ;
    rdfs:comment 'The unique serial number of the physical or electronic prepaid voucher used for this recharge. Populated only when recharge_channel is \'voucher\'. Used for voucher fraud detection and inventory reconciliation.' ;
    rdfs:domain ind:Recharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique surrogate identifier for the write-off record in the Amdocs Collections system. Primary key for the write_off data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Write-offs are material financial decisions requiring documented approval chain for bad debt management and SOX compliance. Distinct from processing employee. Replaces denormalized approving_authority' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dunningCaseId rdf:type rdf:Property ;
    rdfs:label 'Dunning Case Id' ;
    rdfs:comment 'Reference to the dunning case that was exhausted prior to initiating the write-off. Confirms that all collection attempts were made before write-off approval.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:recoveryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Recovery Agency Id' ;
    rdfs:comment 'Reference to the third-party debt recovery agency to which the written-off account has been assigned for collection. Populated when write_off_status transitions to sent_to_agency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecoveryAgency .

ind:agencyAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Agency Assignment Date' ;
    rdfs:comment 'Date on which the written-off account was formally assigned to the third-party recovery agency. Marks the start of the external collection process.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Reference Number' ;
    rdfs:comment 'External reference number assigned by the third-party recovery agency to track this write-off case within their own system. Used for reconciliation between Amdocs Collections and the agency.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Receivables aging classification of the outstanding balance at the time of write-off, indicating how long the debt has been overdue (30, 60, 90, or 120+ days). Used for bad debt provisioning and revenue assurance reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Unique reference number or ticket ID from the approval workflow (e.g., ServiceNow change/approval record) authorizing the write-off. Supports audit trail and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAttemptsCount rdf:type rdf:Property ;
    rdfs:label 'Collection Attempts Count' ;
    rdfs:comment 'Total number of collection contact attempts made against the account prior to write-off (calls, letters, emails, SMS). Evidences due diligence for regulatory and audit purposes.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the written-off balance was subject to a customer dispute at any point during the collections process. Relevant for regulatory reporting and revenue assurance investigations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningStageAtWriteoff rdf:type rdf:Property ;
    rdfs:label 'Dunning Stage At Writeoff' ;
    rdfs:comment 'The final dunning stage reached before the write-off was initiated (e.g., Final Notice, Legal Warning, Pre-Legal). Confirms exhaustion of the dunning process and supports regulatory compliance documentation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date of the original invoice that generated the uncollectable balance. Used for aging calculation, statute of limitations assessment, and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalActionFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Flag' ;
    rdfs:comment 'Indicates whether legal proceedings were initiated against the customer prior to or concurrent with the write-off. Relevant for compliance, regulatory reporting, and recovery strategy.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCaseReference rdf:type rdf:Property ;
    rdfs:label 'Legal Case Reference' ;
    rdfs:comment 'External legal case or court reference number associated with legal proceedings against the customer. Populated only when legal_action_flag is True.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalanceAtWriteoff rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance At Writeoff' ;
    rdfs:comment 'Total overdue balance on the account at the time the write-off was initiated, which may include multiple invoices, late fees, and interest charges. May differ from write_off_amount if only a partial balance is written off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionAmount rdf:type rdf:Property ;
    rdfs:label 'Provision Amount' ;
    rdfs:comment 'Amount previously provisioned for this debt under the expected credit loss (ECL) model prior to the actual write-off. Used to reconcile the provision account in SAP S/4HANA Finance and assess provisioning accuracy.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Categorized reason code explaining why the outstanding balance is deemed uncollectable and eligible for write-off. Drives regulatory reporting, bad debt provisioning, and fraud analytics. [ENUM-REF-CANDIDATE: bankruptcy|deceased|uncontactable|fraud|statute_of_limitations|other — promote to reference product if additional reason codes are required]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNotes rdf:type rdf:Property ;
    rdfs:label 'Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context or supporting detail for the write-off reason code. May include case reference numbers, legal citations, or collector observations from Amdocs Collections.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which the recovery amount was received and posted back to the account. Used for revenue recognition reversal and bad debt recovery analytics.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Native identifier of the write-off record in the originating operational system (e.g., Amdocs Collections internal write-off ID). Enables traceability and reconciliation between the lakehouse Silver Layer and the source system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statuteOfLimitationsDate rdf:type rdf:Property ;
    rdfs:label 'Statute Of Limitations Date' ;
    rdfs:comment 'Date on which the legal right to pursue collection of the debt expires under applicable jurisdiction law. Used to trigger write-off when statute_of_limitations is the write_off_reason.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxWriteBackAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Write Back Amount' ;
    rdfs:comment 'Amount of tax (e.g., VAT, GST, sales tax) reclaimed or reversed as a result of the write-off. Reported to tax authorities and reflected in SAP S/4HANA Finance for tax compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the write-off transaction as assigned by Amdocs Collections. Used in correspondence with recovery agencies, auditors, and regulatory bodies.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current lifecycle state of the write-off record within the Amdocs Collections workflow. Drives downstream actions such as agency assignment, tax write-back, and revenue assurance reporting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Write Off Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the write-off transaction was created and committed in the Amdocs Collections system. Used for audit trail and intraday reconciliation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlId rdf:type rdf:Property ;
    rdfs:label 'Control Id' ;
    rdfs:comment 'Identifier of the internal control, policy, or procedure that was found to be deficient or non-compliant (e.g., ISO 27001 A.9.2.1 User Registration, FCC CPNI Control 3.2).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Control .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous finding record if this is a recurrence. Links to the historical finding for trend analysis.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:remediationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Audit findings assigned to specific employees for remediation. Telecommunications operators track ownership for escalation, performance management, and audit closure. Essential for audit management an' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when all remediation actions were completed and evidence was submitted for verification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'The business process or operational area impacted by this finding (e.g., Customer Onboarding, Billing and Revenue Management, Network Operations and Monitoring, CALEA Compliance).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the audit activity that identified this finding was conducted. Represents the business event timestamp for finding discovery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Description of the audit scope and boundaries within which this finding was identified (e.g., Network Operations Center security controls, CALEA compliance for lawful intercept, GDPR data subject rights processes).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement type. Internal audits are conducted by the organization; external audits by third parties; regulatory audits by FCC, NTIA, Ofcom, or BEREC; certification audits for ISO/IEC 27001; surveillance audits for ongoing compliance monitoring.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the auditor or audit team member who identified and documented this finding.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'The organization or entity that the auditor represents (e.g., Internal Audit Department, External Certification Body, FCC Enforcement Bureau, ISO Registrar).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By' ;
    rdfs:comment 'Name of the individual or role who approved the closure of the finding (e.g., Chief Compliance Officer, Audit Committee Chair, ISO Management Representative).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the finding was formally closed after successful verification of corrective actions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceImpact rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact' ;
    rdfs:comment 'Description of the potential regulatory, legal, or business impact if the finding is not addressed (e.g., FCC fines, GDPR penalties, loss of ISO certification, reputational damage).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDomain rdf:type rdf:Property ;
    rdfs:label 'Control Domain' ;
    rdfs:comment 'The functional domain or category of the affected control (e.g., Access Control, Data Privacy, Network Security, Financial Reporting, Lawful Intercept, Spectrum Management).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions, remediation steps, and preventive measures planned to address the finding and prevent recurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the finding was escalated to a higher authority or management level.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceOfCompletion rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Completion' ;
    rdfs:comment 'Description or reference to the evidence provided to demonstrate that corrective actions have been implemented (e.g., updated policy documents, system logs, training records, screenshots).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including what was observed, what requirement was not met, and the specific evidence supporting the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Business-readable unique reference number assigned to the finding for tracking and communication purposes (e.g., FCC-2024-001, ISO-NC-2024-042).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding from identification through remediation to closure. Tracks the progress of corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding based on severity and nature. Non-conformity indicates a failure to meet a requirement; observation is a potential issue; opportunity for improvement suggests enhancement areas. [ENUM-REF-CANDIDATE: non-conformity|observation|opportunity_for_improvement|positive_finding|major_non-conformity|minor_non-conformity|regulatory_violation|control_deficiency — promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The specific date when this finding was formally identified and documented by the auditor or compliance team.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Description of preventive measures and systemic improvements implemented to prevent similar findings in the future.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Boolean indicator of whether this finding must be reported to a regulatory authority (FCC, NTIA, Ofcom, BEREC, data protection authority) as part of compliance obligations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Department' ;
    rdfs:comment 'The department or business unit responsible for remediation (e.g., Network Operations, Legal and Regulatory Affairs, Information Security, Customer Privacy).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk-based assessment of the potential impact if the finding is not remediated. Considers likelihood and consequence of non-compliance or control failure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed analysis of the root cause(s) that led to the finding, including contributing factors and systemic issues. Documents the why behind the finding.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or committed date by which the remediation actions are expected to be completed and the finding closed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the corrective actions were verified as complete and effective.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Additional notes or comments from the verifier regarding the adequacy and effectiveness of the corrective actions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the verification process to confirm that corrective actions have been effectively implemented and the finding can be closed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Full name of the individual who verified the completion and effectiveness of the corrective actions (typically an auditor or compliance officer).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Audited Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Physical compliance audits (safety, environmental, security) occur at specific network sites. Audit reports reference site locations, and audit findings require site-level remediation tracking for cer' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_plan. Business justification: Audit programs require annual budgets for internal resources and external auditor fees. Linking audits to budget plans enables tracking of actual vs. planned audit costs, supports multi-year audit pla' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Compliance audits are conducted at the legal entity level. Audit costs, findings, and certifications must be attributed to specific company codes for financial reporting, internal cost allocation, and' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Internal audits led by employee auditors. Telecommunications operators track lead auditor for audit planning, resource allocation, quality review, and auditor performance management. Core audit manage' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit fieldwork or on-site activities concluded.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit fieldwork or on-site activities commenced.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit engagement. Tracks progression from scheduling through completion. [ENUM-REF-CANDIDATE: SCHEDULED|IN_PROGRESS|FIELDWORK_COMPLETE|UNDER_REVIEW|COMPLETED|CANCELLED|DEFERRED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Name of the organization or regulatory authority conducting the audit (e.g., external certification body, FCC, GDPR supervisory authority, internal audit department).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Auditing Body Accreditation Number' ;
    rdfs:comment 'Official accreditation or registration number of the auditing body, if applicable (e.g., ANAB accreditation number for ISO auditors).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the issued certification expires and requires renewal or recertification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issue Date' ;
    rdfs:comment 'Date when the certification was officially issued by the certifying body.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certification was issued as a result of this audit. True if certification was granted, False otherwise.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Reference Number' ;
    rdfs:comment 'Unique certificate number or reference identifier assigned by the certifying body to the issued certification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRenewalStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Renewal Status' ;
    rdfs:comment 'Current status of the certification renewal process. Tracks whether the certification is active, approaching renewal, or has expired.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope covered by the issued certification, including business units, processes, systems, and geographic locations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification issued as a result of the audit, if applicable. Identifies the specific standard or framework for which certification was granted. [ENUM-REF-CANDIDATE: ISO_IEC_27001|SOC_2_TYPE_II|PCI_DSS|FCC_CPNI_ANNUAL|GSMA_SAS|ISO_9001|ISO_20000|ISO_22301|ISO_27017|ISO_27018|CALEA_COMPLIANCE|ETSI_CERTIFICATION — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Assessment of the compliance risk level associated with the audit scope and findings. Indicates potential regulatory, financial, or reputational impact.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Deadline date by which corrective actions for identified nonconformities must be completed and submitted for verification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionsVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Verified Date' ;
    rdfs:comment 'Date when the auditing body verified that all corrective actions have been satisfactorily implemented.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for the audit engagement, including auditor fees, travel expenses, and related costs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirmName rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm Name' ;
    rdfs:comment 'Name of the external legal counsel firm engaged to support the audit, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'External Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged to support the audit process. True if external counsel was involved, False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalAuditCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Coordinator Email' ;
    rdfs:comment 'Primary email address of the internal audit coordinator for audit logistics and communication.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Coordinator Name' ;
    rdfs:comment 'Full name of the internal employee responsible for coordinating the audit activities and serving as the primary liaison with the auditing body.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformities Count' ;
    rdfs:comment 'Number of major nonconformities identified during the audit. Major nonconformities represent significant failures to meet compliance requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformities Count' ;
    rdfs:comment 'Number of minor nonconformities identified during the audit. Minor nonconformities represent less critical deviations from compliance requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit that do not constitute nonconformities.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall result or conclusion of the audit engagement. Indicates whether the organization met the compliance requirements under review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the period under audit review. Defines the conclusion of the timeframe for which compliance is being assessed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the period under audit review. Defines the beginning of the timeframe for which compliance is being assessed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the formal audit report was issued to the organization.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleExecutiveEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Email' ;
    rdfs:comment 'Primary email address of the responsible executive officer for compliance communications.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveName rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Name' ;
    rdfs:comment 'Full name of the executive officer responsible for compliance oversight and signatory authority for the audit and certification.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleExecutiveTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Executive Title' ;
    rdfs:comment 'Job title of the responsible executive officer (e.g., Chief Compliance Officer, Chief Information Security Officer, Data Protection Officer).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date for the audit fieldwork or on-site activities to conclude.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date for the audit fieldwork or on-site activities to commence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Total number of auditors and technical experts assigned to the audit engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Unique identifier for the compliance calendar entry. Primary key for the compliance calendar master record.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enterpriseContractId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Contract Id' ;
    rdfs:comment 'Foreign key linking to enterprise.enterprise_contract. Business justification: Compliance deadlines tied to specific contracts (government contract reporting, SLA reporting deadlines, audit submission dates). Contract-level tracking enables automated reminders and ensures contra' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseContract .

ind:responsibleOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Compliance deadlines assigned to specific employees. Telecommunications operators use this for task management, reminder workflows, performance tracking, and escalation. Core compliance operations req' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backupOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Backup Officer Email' ;
    rdfs:comment 'Email address of the backup officer for redundant notification and escalation paths.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupOfficerName rdf:type rdf:Property ;
    rdfs:label 'Backup Officer Name' ;
    rdfs:comment 'Full name of the secondary or backup compliance officer who can assume responsibility if the primary officer is unavailable.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedByName rdf:type rdf:Property ;
    rdfs:label 'Completed By Name' ;
    rdfs:comment 'Full name of the individual who completed or submitted the compliance obligation.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Actual date when the compliance obligation was fulfilled and the deadline requirement was met.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of work toward meeting the deadline. Tracks progress from initiation through verification of completion.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the compliance obligation was marked as completed, including time and timezone information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Deadline Description' ;
    rdfs:comment 'Detailed description of the compliance deadline, including specific requirements, deliverables, and any special instructions or conditions.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deadline Reference Number' ;
    rdfs:comment 'Business-assigned unique reference number for the compliance deadline entry, used for tracking and communication purposes.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineStatus rdf:type rdf:Property ;
    rdfs:label 'Deadline Status' ;
    rdfs:comment 'Current lifecycle status of the compliance deadline. Tracks progression from scheduling through completion or escalation. [ENUM-REF-CANDIDATE: scheduled|pending|in_progress|completed|overdue|cancelled|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineTitle rdf:type rdf:Property ;
    rdfs:label 'Deadline Title' ;
    rdfs:comment 'Short descriptive title of the compliance deadline for quick identification and calendar display purposes.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineType rdf:type rdf:Property ;
    rdfs:label 'Deadline Type' ;
    rdfs:comment 'Classification of the compliance deadline. Indicates the nature of the obligation requiring completion by the due date. [ENUM-REF-CANDIDATE: regulatory_filing|certification_renewal|audit_submission|penalty_payment|dsr_response|license_renewal|report_submission|inspection|training_completion|policy_review — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueTime rdf:type rdf:Property ;
    rdfs:label 'Due Time' ;
    rdfs:comment 'Precise timestamp including time-of-day when the deadline expires, if a specific time is mandated. Includes timezone information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation hierarchy for overdue deadlines. Comma-separated list of roles or names to notify in sequence when deadlines are missed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Triggered Flag' ;
    rdfs:comment 'Indicates whether the escalation process has been initiated due to overdue status or high-risk non-completion.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New due date if an extension has been granted. Replaces the original due date for compliance tracking purposes.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a deadline extension has been granted by the regulatory authority or internal governance body.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification or regulatory grounds for the deadline extension. Documents the rationale for the extension request and approval.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'First Reminder Sent Date' ;
    rdfs:comment 'Date when the first automated reminder notification was sent to the responsible officer.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or jurisdiction identifier where the compliance obligation applies. Examples: USA, GBR, DEU.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Date' ;
    rdfs:comment 'Date when the most recent reminder notification was sent, tracking the latest communication to responsible parties.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'The date of the next scheduled occurrence for recurring deadlines. Automatically calculated based on recurrence pattern.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Indicates whether the deadline has passed without completion. Automatically set when current date exceeds due date and completion status is not completed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceInterval rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval' ;
    rdfs:comment 'Numeric interval for recurring deadlines when using custom recurrence patterns. For example, every 2 months or every 3 years.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency pattern for recurring compliance deadlines. Indicates whether the deadline repeats and at what interval. [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|semi_annual|annual|biennial|custom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory body or governing authority that mandates this deadline. Examples include FCC, NTIA, Ofcom, BEREC, GDPR supervisory authorities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'Total number of reminder notifications sent for this deadline. Used to track engagement and escalation needs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderTriggerDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Trigger Days' ;
    rdfs:comment 'Comma-separated list of days before the due date when automated reminders should be sent to responsible officers. Example: 30,14,7,3,1.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Business unit or department accountable for meeting this compliance deadline, such as Legal, Regulatory Affairs, or Network Operations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Severity Level' ;
    rdfs:comment 'Assessment of the risk severity if this deadline is missed, considering potential regulatory penalties, reputational damage, and operational impact.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Submission Window End Date' ;
    rdfs:comment 'The final date when submission or filing will be accepted. Typically aligns with the due date but may differ for certain regulatory processes.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Submission Window Start Date' ;
    rdfs:comment 'The earliest date when submission or filing can be accepted by the regulatory authority. Defines the opening of the submission window.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether independent verification or approval is required before the deadline can be marked as fully completed.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpniAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Cpni Authorization Id' ;
    rdfs:comment 'Unique identifier for the CPNI authorization record. Primary key for tracking individual customer CPNI consent events throughout their lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpniAuthorization .

ind:annualCertificationId rdf:type rdf:Property ;
    rdfs:label 'Annual Certification Id' ;
    rdfs:comment 'Reference to the annual CPNI compliance certification filing that includes this authorization record. Links individual authorizations to regulatory filings.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnnualCertification .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier to detailed audit trail logs for this CPNI authorization. Links to immutable event log for compliance verification and regulatory inspection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authentication Timestamp' ;
    rdfs:comment 'Date and time when customer identity was verified prior to authorization. Required for FCC compliance to prevent pretexting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizationChannel rdf:type rdf:Property ;
    rdfs:label 'Authorization Channel' ;
    rdfs:comment 'Channel through which the customer provided or modified CPNI authorization: web_portal, mobile_app, IVR (Interactive Voice Response), retail_store, written_form, email, SMS, customer_service_call. [ENUM-REF-CANDIDATE: web_portal|mobile_app|ivr|retail_store|written_form|email|sms|customer_service_call — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the CPNI authorization, used in customer communications and regulatory filings. Format: CPNI-{alphanumeric}.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of the CPNI authorization: active (consent in effect), expired (time-bound consent lapsed), revoked (customer withdrew), pending_verification (awaiting identity confirmation), superseded (replaced by newer authorization).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the customer provided or modified the CPNI authorization. Critical for regulatory compliance and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Type of CPNI authorization action: opt_in (customer grants consent), opt_out (customer denies consent), renewal (periodic reconfirmation), withdrawal (customer revokes prior consent), modification (scope change).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Certification Period Year' ;
    rdfs:comment 'Calendar year for which this authorization is included in the annual CPNI certification filing to the FCC. Format: YYYY.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Scope of CPNI usage authorized by the customer: marketing (promotional offers), service_enhancement (network optimization), third_party_sharing (partner disclosures), all_purposes (unrestricted), limited (specific use case only).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAuthenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Authentication Method' ;
    rdfs:comment 'Method used to verify customer identity before accepting CPNI authorization, as required by FCC rules: password, PIN, biometric, security_question, two_factor, account_number, ssn_last_four, none (for written/signed forms). [ENUM-REF-CANDIDATE: password|pin|biometric|security_question|two_factor|account_number|ssn_last_four|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationOfBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Of Breach Flag' ;
    rdfs:comment 'Indicates whether affected customers were notified of the CPNI breach. True if notified, False otherwise. Required for material breaches.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationOfBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Of Breach Timestamp' ;
    rdfs:comment 'Date and time when affected customers were notified of the CPNI breach. Null if not notified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device used to submit the authorization (e.g., mobile device ID, browser fingerprint). Used for security and fraud prevention.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fcc Notification Required Flag' ;
    rdfs:comment 'Indicates whether FCC notification is required for this violation (True if 5000+ customers affected or other mandatory criteria met). False if no notification required or no violation.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fcc Notification Status' ;
    rdfs:comment 'Status of FCC notification for CPNI violation: not_required (below threshold), pending (notification due), submitted (filed with FCC), acknowledged (FCC confirmed receipt), none (no violation).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fcc Notification Timestamp' ;
    rdfs:comment 'Date and time when FCC was notified of the CPNI violation. Must be within 7 business days of detection for breaches affecting 5000+ customers. Null if not applicable. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the customer submitted the CPNI authorization (for web/mobile channels). Used for fraud detection and audit trail. Supports IPv4 and IPv6.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notification Flag' ;
    rdfs:comment 'Indicates whether law enforcement (FBI, Secret Service, local authorities) was notified of the CPNI violation. True if notified, False otherwise.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notification Timestamp' ;
    rdfs:comment 'Date and time when law enforcement was notified of the CPNI violation. Null if not notified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when confirmation notification was sent to customer. Null if notification_sent_flag is False. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remediationActionDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Description' ;
    rdfs:comment 'Detailed description of remediation actions taken to address the CPNI violation and prevent recurrence. Includes technical, process, and policy changes. Null if no violation.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Timestamp' ;
    rdfs:comment 'Date and time when all remediation actions for the CPNI violation were completed and verified. Null if remediation ongoing or no violation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Name of the corporate officer responsible for CPNI compliance oversight for this authorization record. Required for annual certification attestation.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Title' ;
    rdfs:comment 'Corporate title of the officer responsible for CPNI compliance (e.g., Chief Compliance Officer, VP Legal, Chief Privacy Officer).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Store Location Code' ;
    rdfs:comment 'Code identifying the retail store location where the CPNI authorization was captured. Applicable only for retail_store channel.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Closure Status' ;
    rdfs:comment 'Current status of the CPNI violation case: open (active incident), remediated (actions complete, awaiting verification), closed (fully resolved), under_investigation (root cause analysis ongoing), none (no violation).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Violation Detection Method' ;
    rdfs:comment 'Method by which the CPNI violation was detected: internal_audit, customer_complaint, system_alert, regulatory_inspection, third_party_report, none (if no violation).' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDetectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Violation Detection Timestamp' ;
    rdfs:comment 'Date and time when the CPNI violation was first detected. Null if no violation. Critical for FCC 7-business-day notification requirement. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:violationFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Flag' ;
    rdfs:comment 'Indicates whether this authorization record is associated with a CPNI violation or breach incident. True if violation occurred, False otherwise.' ;
    rdfs:domain ind:CpniAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Type of CPNI violation if violation_flag is True: unauthorized_disclosure (CPNI shared without consent), improper_access (internal unauthorized access), pretexting (fraudulent identity theft), inadequate_safeguards (security failure), none (no violation).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachOriginLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Breach Origin Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Data breaches often originate from compromised physical sites (data centers, network operations centers). Incident response requires site identification for physical containment, forensics access, and' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:incidentResponseTeamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Response Team Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Data breach response led by designated employee. Telecommunications operators must track incident commander for GDPR/breach notification compliance, audit trails, and incident management reporting. Re' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedDataCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Data Categories' ;
    rdfs:comment 'Comma-separated list of personal data categories affected by the breach (e.g., name, email, phone, address, payment card, CPNI, location data, account credentials).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'Comma-separated list of systems, applications, or infrastructure components affected by the breach (e.g., CRM, billing system, customer portal, database server).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Breach Severity Level' ;
    rdfs:comment 'Assessed severity level of the data breach incident based on data sensitivity, volume, and potential harm (critical, high, medium, low).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the data breach incident was formally closed after all remediation, notification, and regulatory obligations were completed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedAffectedIndividualsCount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Affected Individuals Count' ;
    rdfs:comment 'Confirmed number of individuals whose personal data was compromised, based on completed forensic investigation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when the data breach incident was successfully contained and the vulnerability or exposure was closed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditMonitoringOffered rdf:type rdf:Property ;
    rdfs:label 'Credit Monitoring Offered' ;
    rdfs:comment 'Indicates whether credit monitoring or identity protection services were offered to affected individuals as part of breach remediation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataExfiltrationConfirmed rdf:type rdf:Property ;
    rdfs:label 'Data Exfiltration Confirmed' ;
    rdfs:comment 'Indicates whether forensic investigation confirmed that personal data was actually exfiltrated or accessed by unauthorized parties (true) or only exposed without confirmed access (false).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionInPlace rdf:type rdf:Property ;
    rdfs:label 'Encryption In Place' ;
    rdfs:comment 'Indicates whether the affected personal data was encrypted at the time of the breach, which may reduce notification obligations under certain regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAffectedIndividualsCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Affected Individuals Count' ;
    rdfs:comment 'Estimated number of individuals whose personal data was compromised in the breach incident.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the breach including investigation costs, notification costs, remediation costs, regulatory fines, and potential litigation costs.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalForensicsFirmEngaged rdf:type rdf:Property ;
    rdfs:label 'External Forensics Firm Engaged' ;
    rdfs:comment 'Indicates whether an external cybersecurity or forensics firm was engaged to investigate the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalForensicsFirmName rdf:type rdf:Property ;
    rdfs:label 'External Forensics Firm Name' ;
    rdfs:comment 'Name of the external cybersecurity or forensics firm engaged to investigate the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated financial impact amount.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the data breach incident for tracking and regulatory reporting purposes.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualNotificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Completion Date' ;
    rdfs:comment 'Date when direct notification to all affected individuals was completed.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:individualNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Method' ;
    rdfs:comment 'Primary method used to notify affected individuals (email, postal mail, SMS, phone, website notice, substitute notice).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Required' ;
    rdfs:comment 'Indicates whether the breach meets the threshold for mandatory direct notification to affected individuals under applicable data protection regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:individualNotificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Individual Notification Start Date' ;
    rdfs:comment 'Date when direct notification to affected individuals began (via email, postal mail, or other channels).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notification Required' ;
    rdfs:comment 'Indicates whether the breach requires notification to law enforcement agencies based on criminal activity or regulatory requirements.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselEngaged rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Engaged' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged to advise on breach notification obligations and regulatory compliance.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselFirmName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Firm Name' ;
    rdfs:comment 'Name of the external legal counsel firm engaged to advise on the breach response.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationInitiated rdf:type rdf:Property ;
    rdfs:label 'Litigation Initiated' ;
    rdfs:comment 'Indicates whether civil litigation or class action lawsuits were initiated by affected individuals or consumer advocacy groups as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Estimated date and time when the data breach incident actually occurred or began, based on forensic investigation.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date when the breach was publicly disclosed through media notification, press release, or regulatory public notice.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether the breach requires public disclosure or media notification due to the number of affected individuals or regulatory requirements.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFineAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fine Amount' ;
    rdfs:comment 'Total amount of regulatory fines or penalties imposed by supervisory authorities as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFineImposed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fine Imposed' ;
    rdfs:comment 'Indicates whether a regulatory fine or penalty was imposed by a supervisory authority as a result of the breach.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the breach meets the threshold for mandatory notification to supervisory authorities under applicable data protection regulations.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date when all remediation actions were completed and verified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Description' ;
    rdfs:comment 'Detailed description of the remediation plan implemented to address the breach, prevent recurrence, and mitigate harm to affected individuals.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityAcknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Acknowledgment Reference' ;
    rdfs:comment 'Reference number or acknowledgment identifier provided by the supervisory authority upon receipt of the breach notification.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Name' ;
    rdfs:comment 'Name of the supervisory authority or regulatory body to which the breach was notified (e.g., ICO, CNIL, FCC, state attorney general).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityNotificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Deadline' ;
    rdfs:comment 'Regulatory deadline by which the breach must be notified to the supervisory authority (e.g., GDPR 72-hour deadline from detection, FCC 30-day deadline).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisoryAuthorityNotificationOnTime rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification On Time' ;
    rdfs:comment 'Indicates whether the supervisory authority notification was submitted within the regulatory deadline (true) or was late (false).' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Notification Timestamp' ;
    rdfs:comment 'Actual date and time when the breach notification was submitted to the supervisory authority.' ;
    rdfs:domain ind:DataBreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceTestSiteLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Compliance Test Site Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: E911 compliance testing (location accuracy, call routing) is conducted at specific cell sites and PSAPs. Regulatory certifications require site-level test results and location accuracy measurements fo' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:enterpriseSiteId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.site. Business justification: E911 compliance is site-specific for enterprise voice services. Each site must have accurate dispatchable location, PSAP routing, and ALI database entries. Required for FCC compliance and emergency re' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseSite .

ind:aniAliDatabaseProvider rdf:type rdf:Property ;
    rdfs:label 'Ani Ali Database Provider' ;
    rdfs:comment 'Name of the third-party provider managing the ANI/ALI database for this service (if applicable).' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callRoutingMethod rdf:type rdf:Property ;
    rdfs:label 'Call Routing Method' ;
    rdfs:comment 'Method by which E911 calls are routed to the appropriate PSAP (legacy selective router, Next Generation 911 ESInet, IP-based, hybrid, direct PSAP connection).' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this E911 compliance record, used for regulatory filings and audit trails.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the E911 obligation for this service and coverage area.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTestDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Test Date' ;
    rdfs:comment 'Date when the most recent E911 compliance test was conducted for this service and coverage area.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:databaseUpdateFrequency rdf:type rdf:Property ;
    rdfs:label 'Database Update Frequency' ;
    rdfs:comment 'Frequency at which subscriber location information is updated in the ANI/ALI or LIS database to maintain E911 compliance.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchableLocationCapable rdf:type rdf:Property ;
    rdfs:label 'Dispatchable Location Capable' ;
    rdfs:comment 'Indicates whether the service is capable of providing dispatchable location (civic address including street address, floor, suite) to the PSAP.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:horizontalAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Horizontal Accuracy Meters' ;
    rdfs:comment 'Horizontal location accuracy in meters required or achieved for Phase II wireless E911 compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the jurisdiction where this E911 compliance obligation applies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStateProvince rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Province' ;
    rdfs:comment 'State or province within the country where this E911 compliance obligation applies (e.g., California, Ontario).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDatabaseUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Database Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the ANI/ALI or LIS database for this coverage area or service.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationAccuracySuccessRatePercent rdf:type rdf:Property ;
    rdfs:label 'Location Accuracy Success Rate Percent' ;
    rdfs:comment 'Percentage of E911 test calls that met the required location accuracy threshold (Phase I, Phase II, or dispatchable location) during the most recent compliance test.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationAccuracyTier rdf:type rdf:Property ;
    rdfs:label 'Location Accuracy Tier' ;
    rdfs:comment 'FCC-defined location accuracy tier for wireless E911 (Phase I: cell tower/sector; Phase II: lat/long within specified accuracy; Dispatchable Location: civic address; Z-Axis: vertical location for multi-story buildings).' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Date when the next E911 compliance test is required per regulatory schedule.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:psapCode rdf:type rdf:Property ;
    rdfs:label 'Psap Code' ;
    rdfs:comment 'Unique identifier for the Public Safety Answering Point (PSAP) as assigned by NENA or state authority.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psapName rdf:type rdf:Property ;
    rdfs:label 'Psap Name' ;
    rdfs:comment 'Name of the Public Safety Answering Point (PSAP) serving this coverage area.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCertificationReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certification Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory certification or attestation filed with the FCC or equivalent authority confirming E911 compliance.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Date by which E911 compliance remediation actions must be completed per regulatory requirement or internal commitment.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Number of active subscribers in this coverage area subject to this E911 compliance record.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCallSuccessRatePercent rdf:type rdf:Property ;
    rdfs:label 'Test Call Success Rate Percent' ;
    rdfs:comment 'Percentage of E911 test calls that successfully reached the correct PSAP with accurate location information during the most recent compliance test.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testFailureReason rdf:type rdf:Property ;
    rdfs:label 'Test Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the E911 compliance test failed, if applicable.' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testOutcome rdf:type rdf:Property ;
    rdfs:label 'Test Outcome' ;
    rdfs:comment 'Outcome of the most recent E911 compliance test (pass, fail, partial pass, not tested, waived).' ;
    rdfs:domain ind:E911Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Vertical Accuracy Meters' ;
    rdfs:comment 'Vertical location accuracy in meters (Z-axis) required or achieved for multi-story building E911 compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: Intercept orders may target traffic from specific carriers (roaming subscribers from foreign carrier). Required for intercept provisioning on carrier-specific traffic, surveillance scope definition, a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:handlingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handling Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: CALEA/lawful intercept orders handled by specifically authorized employees with security clearances. Telecommunications operators must maintain strict chain of custody and access logs. Required for le' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interceptSiteLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Intercept Site Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Lawful intercept equipment (mediation devices, probes) is physically provisioned at specific network sites. Court orders require documenting physical interception points for chain-of-custody and LEA a' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:targetCoverageAreaId rdf:type rdf:Property ;
    rdfs:label 'Target Coverage Area Id' ;
    rdfs:comment 'Foreign key linking to location.coverage_area. Business justification: Mobile intercept orders specify target coverage areas for surveillance (cell-level interception). LEA delivery requires coverage-area-level call detail records and location data. Essential for CALEA c' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageArea .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'The access control classification for this lawful intercept order. NEED_TO_KNOW: only authorized personnel directly involved may access; RESTRICTED_ACCESS: limited to compliance and legal teams; EXECUTIVE_ONLY: requires executive approval for access.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept was activated and data collection began. This may differ from order received timestamp due to technical provisioning lead time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodyLog rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Log' ;
    rdfs:comment 'A structured log or reference to a detailed audit trail documenting every access, handling, and transfer event for this lawful intercept order and its associated data. Ensures legal admissibility and compliance with evidence handling standards.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtOrderReference rdf:type rdf:Property ;
    rdfs:label 'Court Order Reference' ;
    rdfs:comment 'The official reference number or docket number of the court order, warrant, or legal authorization document that mandates this lawful intercept. This is the externally-known business identifier for the order.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDestination rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination' ;
    rdfs:comment 'The destination address, endpoint, or location where intercepted data is delivered. May be an FTP server URL, physical address, IP address of LEA handover interface, or API endpoint.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The primary method by which intercepted data is delivered to the LEA. Options include secure FTP, physical media (encrypted USB, DVD), ETSI LI handover interfaces (HI2 for signaling, HI3 for content), network handoff, or secure API.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'The encryption algorithm and protocol used to secure intercepted data during transmission and storage. Examples: AES-256, TLS 1.3, PGP, or LEA-specified encryption standards.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept order expires and data collection must cease. Nullable for orders without a defined expiration (subject to renewal or explicit termination).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interceptServiceScope rdf:type rdf:Property ;
    rdfs:label 'Intercept Service Scope' ;
    rdfs:comment 'Defines which services are subject to intercept: voice calls, SMS, MMS, data sessions, VoLTE, VoIP, email, or all services. May be a comma-separated list or specific service identifiers.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptStatus rdf:type rdf:Property ;
    rdfs:label 'Intercept Status' ;
    rdfs:comment 'Current lifecycle status of the lawful intercept order. PENDING: received but not yet activated; ACTIVE: currently collecting data; SUSPENDED: temporarily paused; EXPIRED: reached expiry date; TERMINATED: explicitly ended; CLOSED: all deliveries completed and order archived.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptTechnology rdf:type rdf:Property ;
    rdfs:label 'Intercept Technology' ;
    rdfs:comment 'The telecommunications technology or network type on which the intercept is provisioned. Examples: 2G/GSM, 3G/UMTS, 4G/LTE, 5G NR, VoIP/IMS, FTTH, Cable, Satellite. Determines the technical implementation approach.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptType rdf:type rdf:Property ;
    rdfs:label 'Intercept Type' ;
    rdfs:comment 'Specifies the scope of the lawful intercept: content only (voice, video, messaging payload), metadata only (CDR, signaling, session data), or both content and metadata. Determines what data must be captured and delivered.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The name of the court, judge, magistrate, or law enforcement agency that issued the lawful intercept order. Examples include Federal District Court, State Superior Court, FBI, DEA, or equivalent international bodies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (country, state, province, or district) under which the lawful intercept order was issued. Examples: USA-Federal, USA-CA, GBR, DEU-Bavaria.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Timestamp' ;
    rdfs:comment 'The date and time of the most recent renewal or extension of this lawful intercept order. Nullable if the order has never been renewed.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaAgencyName rdf:type rdf:Property ;
    rdfs:label 'Lea Agency Name' ;
    rdfs:comment 'The name of the law enforcement agency (LEA) or government authority that is the recipient of the intercepted data. Examples: FBI, DEA, Metropolitan Police, Europol.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaCaseReference rdf:type rdf:Property ;
    rdfs:label 'Lea Case Reference' ;
    rdfs:comment 'The LEA\'s internal case number or investigation reference associated with this lawful intercept order. Used for cross-referencing with law enforcement records.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaContactOfficer rdf:type rdf:Property ;
    rdfs:label 'Lea Contact Officer' ;
    rdfs:comment 'The name of the LEA officer or agent who is the primary contact for this lawful intercept order. This individual receives delivery confirmations and coordinates with the telecommunications provider.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'The status of internal legal review for this lawful intercept order. Telecommunications providers typically conduct legal compliance review before activating an intercept to ensure the order is valid and complete.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Legal Review Timestamp' ;
    rdfs:comment 'The date and time when the internal legal review of this lawful intercept order was completed and the order was approved for activation.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'The name of the legal counsel or compliance officer who reviewed and approved this lawful intercept order for activation. Part of the internal approval chain of custody.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'The priority level assigned to this lawful intercept order by the issuing authority or LEA. Determines provisioning speed and resource allocation. EMERGENCY orders require immediate activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Received Timestamp' ;
    rdfs:comment 'The date and time when the lawful intercept order was officially received by the telecommunications provider. This is the principal business event timestamp marking the start of the order lifecycle.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningSystemReference rdf:type rdf:Property ;
    rdfs:label 'Provisioning System Reference' ;
    rdfs:comment 'Reference identifier or ticket number in the telecommunications provider\'s lawful intercept provisioning system (e.g., mediation device, lawful intercept gateway, OSS module) where the technical intercept configuration is managed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number for this lawful intercept order record. Incremented with each modification to support change tracking and audit trail integrity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'The number of times this lawful intercept order has been renewed or extended by the issuing authority. Tracks the order\'s history and duration of active surveillance.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Target Identifier Type' ;
    rdfs:comment 'The type or format of the target identifier. Indicates whether the target is identified by phone number (MSISDN), subscriber identity (IMSI), device identity (IMEI), IP address, email, account number, or SIP URI. [ENUM-REF-CANDIDATE: MSISDN|IMSI|IMEI|IP_ADDRESS|EMAIL|ACCOUNT_NUMBER|SIP_URI — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationHint rdf:type rdf:Property ;
    rdfs:label 'Target Location Hint' ;
    rdfs:comment 'Optional geographic or network location information provided in the court order to assist in identifying and provisioning the intercept. May include city, region, cell tower ID, or network segment. Not always present.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Termination Timestamp' ;
    rdfs:comment 'The actual date and time when the lawful intercept was terminated, either due to expiry, court order withdrawal, or completion of investigation. Marks the end of the intercept lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDataVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Data Volume Bytes' ;
    rdfs:comment 'The cumulative volume of intercepted data (content and/or metadata) collected under this order, measured in bytes. Used for capacity planning, billing (if applicable), and compliance reporting.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Total Delivery Count' ;
    rdfs:comment 'The total number of data delivery events (transmissions, handoffs, or media shipments) that have occurred for this lawful intercept order. Each delivery is typically logged as a separate line item in a related delivery record table.' ;
    rdfs:domain ind:LawfulInterceptOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mnpComplianceId rdf:type rdf:Property ;
    rdfs:label 'Mnp Compliance Id' ;
    rdfs:comment 'Primary key for mnp_compliance' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MnpCompliance .

ind:customerMnpRequestId rdf:type rdf:Property ;
    rdfs:label 'Customer Mnp Request Id' ;
    rdfs:comment 'Reference to the originating MNP request that triggered this compliance record. Links to the customer-facing porting request.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerMnpRequest .

ind:accountNumberVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Account Number Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s account number with the donor operator was verified to prevent fraudulent porting.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Method by which customer authorization was obtained (electronic signature, verbal recording, written Letter of Authorization, online consent, in-store verification).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Address Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s billing address was verified as part of the porting authorization process.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes from compliance officers regarding special circumstances, exceptions, or regulatory considerations for this porting transaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of internal compliance review for this porting transaction, particularly for SLA breaches or rejections.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Timestamp' ;
    rdfs:comment 'Date and time when the compliance review was completed.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerAuthorizationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Authorization Verified Flag' ;
    rdfs:comment 'Indicates whether customer authorization for the port was verified according to regulatory requirements (to prevent unauthorized porting/slamming).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when this compliance record is eligible for deletion according to regulatory data retention policies (typically 2-7 years depending on jurisdiction).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Donor Operator Code' ;
    rdfs:comment 'Unique code identifying the telecommunications operator from which the number is being ported (the losing carrier).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorOperatorName rdf:type rdf:Property ;
    rdfs:label 'Donor Operator Name' ;
    rdfs:comment 'Full legal name of the donor telecommunications operator.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Status' ;
    rdfs:comment 'Status of fraud detection checks performed on this porting request to prevent unauthorized number hijacking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numerical fraud risk score assigned to this porting transaction by fraud detection systems. Higher scores indicate higher risk.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberCount rdf:type rdf:Property ;
    rdfs:label 'Number Count' ;
    rdfs:comment 'Total count of numbers included in this porting transaction. Typically 1 for simple ports, multiple for complex or corporate ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Number Range End' ;
    rdfs:comment 'Ending number in a range port (for complex or corporate porting involving multiple consecutive numbers). Null for simple single-number ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Number Range Start' ;
    rdfs:comment 'Starting number in a range port (for complex or corporate porting involving multiple consecutive numbers). Null for simple single-number ports.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Completion Timestamp' ;
    rdfs:comment 'Date and time when the number porting was successfully completed and the number became active on the recipient operator\'s network.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingDirection rdf:type rdf:Property ;
    rdfs:label 'Porting Direction' ;
    rdfs:comment 'Indicates whether this is a port-in (number coming to this operator) or port-out (number leaving this operator) transaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Porting Reference Number' ;
    rdfs:comment 'Unique regulatory reference number assigned to the porting transaction by the central porting authority or clearinghouse. Used for inter-operator coordination and regulatory tracking.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Request Timestamp' ;
    rdfs:comment 'Date and time when the porting request was officially submitted to the central porting authority or clearinghouse.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingStatus rdf:type rdf:Property ;
    rdfs:label 'Porting Status' ;
    rdfs:comment 'Current status of the porting transaction in the regulatory compliance lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingType rdf:type rdf:Property ;
    rdfs:label 'Porting Type' ;
    rdfs:comment 'Classification of the porting transaction complexity. Simple (single number), complex (multiple numbers), or corporate (enterprise account porting).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Operator Code' ;
    rdfs:comment 'Unique code identifying the telecommunications operator to which the number is being ported (the gaining carrier).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOperatorName rdf:type rdf:Property ;
    rdfs:label 'Recipient Operator Name' ;
    rdfs:comment 'Full legal name of the recipient telecommunications operator.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Status' ;
    rdfs:comment 'Status of notification to the regulatory authority regarding this porting transaction. Some jurisdictions require operators to report porting metrics to regulators.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Date and time when the regulatory authority was notified of this porting transaction or compliance event.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatorySlaDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Sla Deadline Timestamp' ;
    rdfs:comment 'The regulatory deadline by which the porting must be completed to comply with FCC, BEREC, or local regulatory authority SLA requirements (typically 1 business day in the US, varies by jurisdiction).' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rejection Flag' ;
    rdfs:comment 'Indicates whether the porting request was rejected by the donor operator or central porting authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for porting rejection (e.g., account mismatch, outstanding balance, invalid authorization).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed description of why the porting request was rejected, providing context beyond the standardized code.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachDurationHours rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Duration Hours' ;
    rdfs:comment 'Number of hours by which the porting transaction exceeded the regulatory SLA deadline. Null if no breach occurred.' ;
    rdfs:domain ind:MnpCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privacyConsentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Id' ;
    rdfs:comment 'Unique identifier for the privacy consent record. Primary key for the privacy consent entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyConsent .

ind:dpoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dpo Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Data Protection Officer is designated employee role required by GDPR/privacy laws. Telecommunications operators must track DPO involvement in consent reviews for regulatory compliance and audit eviden' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Granted' ;
    rdfs:comment 'Indicates whether the organization has the right to audit the counterparty\'s data processing activities under this agreement. True if audit rights are granted, false otherwise.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caleaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Calea Compliance Flag' ;
    rdfs:comment 'Indicates whether this consent or processing activity is subject to CALEA lawful intercept requirements. True if CALEA compliance obligations apply, false otherwise. Specific to US telecommunications regulatory compliance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'Category of data processing activity covered by this consent. Values: marketing (promotional communications), analytics (usage analytics), personalization (service personalization), third_party_sharing (data sharing with partners), location_tracking (location data processing), cpni (Customer Proprietary Network Information under FCC rules), lawful_intercept (CALEA compliance), research (research and development). [ENUM-REF-CANDIDATE: marketing|analytics|personalization|third_party_sharing|location_tracking|cpni|lawful_intercept|research — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel through which the consent was captured or agreement was executed. Values: web_portal (self-service web portal), mobile_app (mobile application), call_center (customer service call), retail_store (in-store interaction), email (email communication), sms (SMS message), paper_form (physical form), api (programmatic API). [ENUM-REF-CANDIDATE: web_portal|mobile_app|call_center|retail_store|email|sms|paper_form|api — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Document Uri' ;
    rdfs:comment 'URI or file path to the stored consent proof document, signed agreement, or privacy policy version presented to the data subject. Used for audit and regulatory compliance evidence.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the consent record, used for customer inquiries and audit trails.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Type of privacy governance instrument. Values: individual_data_consent (customer consent for data processing), dpa (Data Processing Agreement with third party), sub_processor_agreement (agreement with sub-processor), data_sharing_agreement (data sharing with partner), pia (Privacy Impact Assessment), dpia (Data Protection Impact Assessment per GDPR Article 35).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent form, privacy policy, or agreement document presented to the data subject or counterparty at the time of consent or signature. Format: vX.Y (e.g., v1.0, v2.3).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the third-party organization involved in a Data Processing Agreement, sub-processor agreement, or data sharing agreement. Null for individual data consents. Used for vendor and partner privacy governance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Type of third-party counterparty in the agreement. Values: data_processor (processes data on behalf of controller), sub_processor (sub-contracted processor), joint_controller (joint data controller), data_recipient (receives data for own purposes), mvno (Mobile Virtual Network Operator partner), roaming_partner (roaming agreement partner), content_provider (OTT or IPTV content provider). [ENUM-REF-CANDIDATE: data_processor|sub_processor|joint_controller|data_recipient|mvno|roaming_partner|content_provider — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpniProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Cpni Protection Flag' ;
    rdfs:comment 'Indicates whether this consent record involves Customer Proprietary Network Information protected under FCC CPNI rules (47 CFR 64.2007). True if CPNI protection applies, false otherwise. Specific to US telecommunications regulatory compliance.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferMechanism rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism used for cross-border transfer of personal data under GDPR Chapter V. Values: adequacy_decision (EU adequacy decision per Article 45), standard_contractual_clauses (SCCs per Article 46), binding_corporate_rules (BCRs per Article 47), certification (approved certification mechanism), derogation (specific derogation per Article 49), none (no cross-border transfer).' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategories rdf:type rdf:Property ;
    rdfs:label 'Data Categories' ;
    rdfs:comment 'Comma-separated list of personal data categories covered by this consent or agreement (e.g., contact_information, usage_data, location_data, payment_information, call_detail_records, network_performance_data). Aligns with GDPR Article 4 and CCPA definitions.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Affected Count' ;
    rdfs:comment 'Estimated number of data subjects (individuals) whose personal data is affected by the processing activity assessed in the Privacy Impact Assessment or DPIA. Used for proportionality assessment.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dpoApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Dpo Approval Status' ;
    rdfs:comment 'Status of DPO review and approval. Values: approved (DPO approved the record), rejected (DPO rejected the record), pending_review (awaiting DPO review), conditional_approval (approved with conditions or mitigation requirements).' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Date' ;
    rdfs:comment 'Date on which the Data Protection Officer reviewed and approved this consent record, agreement, or privacy impact assessment.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Timestamp' ;
    rdfs:comment 'Date and time when the consent was granted or the agreement was executed. Represents the principal business event timestamp for this record.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction under which this consent or agreement is governed (e.g., USA, GBR, DEU). Determines applicable privacy regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Description of technical and organizational measures implemented to mitigate identified privacy risks, including data minimization, pseudonymization, encryption, access controls, and privacy-by-design measures per GDPR Article 25 and Article 32.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is necessary for the stated purpose and whether less intrusive alternatives exist. Required for GDPR Article 35 DPIA necessity and proportionality evaluation.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Description' ;
    rdfs:comment 'Detailed description of the data processing activity assessed in a Privacy Impact Assessment or Data Protection Impact Assessment. Includes systems involved, data flows, and processing operations.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the specific purpose for which personal data is processed under this consent or agreement. Must align with legal basis and be specific, explicit, and legitimate per GDPR Article 5.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Assessment of whether the data processing is proportionate to the stated purpose and whether the privacy impact is justified by the benefits. Required for GDPR Article 35 DPIA.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategories rdf:type rdf:Property ;
    rdfs:label 'Risk Categories' ;
    rdfs:comment 'Comma-separated list of privacy risk categories identified in the Privacy Impact Assessment or DPIA (e.g., unauthorized_access, data_breach, profiling, automated_decision_making, cross_border_transfer, surveillance_risk). Used for risk management and mitigation planning.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityObligations rdf:type rdf:Property ;
    rdfs:label 'Security Obligations' ;
    rdfs:comment 'Description of technical and organizational security measures required under this agreement or consent, including encryption, access controls, audit logging, and incident response obligations per GDPR Article 32.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted regarding this DPIA or consent matter. Null if no consultation occurred.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required' ;
    rdfs:comment 'Indicates whether consultation with the supervisory authority (e.g., ICO, CNIL, BfDI) is required for this DPIA per GDPR Article 36. True if high residual risk remains after mitigation, false otherwise.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when the consent was withdrawn by the data subject or the agreement was terminated. Null if consent has not been withdrawn.' ;
    rdfs:domain ind:PrivacyConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Privacy requests (GDPR subject access, deletion) assigned to specific employees for processing. Telecommunications operators track handler for SLA management, workload balancing, and audit trails of d' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason for cancellation if the request was withdrawn by the data subject or cancelled by the organization. Null if not cancelled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the request was cancelled. Null if not cancelled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'Assessed complexity of the request based on scope, number of systems involved, and data volume. Used for resource allocation and prioritization.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecordsRetrievedCount rdf:type rdf:Property ;
    rdfs:label 'Data Records Retrieved Count' ;
    rdfs:comment 'Total number of data records retrieved across all systems for this request. Used for scope tracking and audit purposes.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectNotified rdf:type rdf:Property ;
    rdfs:label 'Data Subject Notified' ;
    rdfs:comment 'Indicates whether the data subject has been notified of the outcome of their request. Required for regulatory compliance.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSystemsAccessedCount rdf:type rdf:Property ;
    rdfs:label 'Data Systems Accessed Count' ;
    rdfs:comment 'Number of internal systems queried to fulfill the request. Used for complexity assessment and process improvement.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extendedSlaDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Sla Deadline' ;
    rdfs:comment 'New deadline if an extension has been granted. Null if no extension was granted.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeChargedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Charged Amount' ;
    rdfs:comment 'Fee charged to the data subject for processing the request, if applicable. GDPR permits fees for manifestly unfounded or excessive requests. CCPA generally prohibits fees. Zero or null if no fee charged.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fee charged. Null if no fee charged.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeJustification rdf:type rdf:Property ;
    rdfs:label 'Fee Justification' ;
    rdfs:comment 'Business and legal justification for charging a fee. Required if fee is charged to demonstrate compliance with manifestly unfounded or excessive criteria.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Detailed status of the fulfillment activities for the request. Tracks progress through data collection, review, packaging, and delivery stages. [ENUM-REF-CANDIDATE: not_started|data_collection_in_progress|data_review_in_progress|data_package_prepared|data_delivered|action_completed|partially_fulfilled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the data subject making the request. Ensures compliance with reasonable verification requirements.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of the identity verification process to confirm the requestor is the legitimate data subject. Critical for preventing fraudulent requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Timestamp' ;
    rdfs:comment 'Date and time when the identity of the data subject was successfully verified. Null if verification is pending or failed.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method used to notify the data subject of the request outcome. Must align with the data subjects preferred communication channel.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when active processing of the request began after identity verification. Used for processing time analytics.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the data protection authority that was notified. Examples: ICO (UK), CNIL (France), California Attorney General. Null if no notification made.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Timestamp' ;
    rdfs:comment 'Date and time when the regulatory authority was notified. Null if no notification made.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Indicates whether the relevant data protection authority was notified about this request. Required for certain high-risk or disputed requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySlaDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Sla Deadline' ;
    rdfs:comment 'Regulatory deadline by which the request must be fulfilled. GDPR: 1 month (extendable to 3 months). CCPA: 45 days (extendable to 90 days). Calculated from submission timestamp.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Rejection Legal Basis' ;
    rdfs:comment 'Specific legal article or section cited as the basis for rejection. Required for regulatory compliance and audit defense.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation if the request was rejected. Must cite specific legal grounds per GDPR Article 12(5) or CCPA exceptions. Null if request was not rejected.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to the privacy request for tracking and customer communication purposes. Format: DSR-XXXXXXXXXX.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the privacy request. Tracks progression from receipt through identity verification, processing, and closure. [ENUM-REF-CANDIDATE: received|identity_verification_pending|identity_verified|in_progress|under_review|completed|rejected|cancelled|expired — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject rights request. GDPR types: access (Article 15), erasure (Article 17), portability (Article 20), rectification (Article 16), restriction (Article 18). CCPA types: opt_out, do_not_sell, consent_withdrawal. [ENUM-REF-CANDIDATE: access|erasure|portability|rectification|restriction|opt_out|do_not_sell|consent_withdrawal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Sla Extension Granted' ;
    rdfs:comment 'Indicates whether a regulatory-permitted extension to the response deadline has been granted due to request complexity or volume.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaExtensionReason rdf:type rdf:Property ;
    rdfs:label 'Sla Extension Reason' ;
    rdfs:comment 'Business justification for granting an SLA extension. Required to be communicated to the data subject per regulatory requirements.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the data subject submitted the privacy request. Used for channel analytics and response routing. [ENUM-REF-CANDIDATE: web_portal|mobile_app|email|phone|postal_mail|in_store|chat — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the privacy request was received by the organization. Marks the start of the regulatory SLA clock.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Regulatory changes assigned to analysts for impact assessment. Telecommunications operators track analyst for workload management, expertise matching, and change implementation tracking. Essential for' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededChangeRegulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Superseded Change Regulatory Change Id' ;
    rdfs:comment 'Foreign key reference to the prior regulatory change record that this change replaces or supersedes. Null if this is a new obligation with no predecessor.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:affectedComplianceAreas rdf:type rdf:Property ;
    rdfs:label 'Affected Compliance Areas' ;
    rdfs:comment 'Comma-separated list of compliance domains or operational areas impacted by this regulatory change (e.g., spectrum licensing, lawful intercept, data privacy, universal service fund, Mobile Number Portability (MNP), Customer Proprietary Network Information (CPNI) protection, emergency services).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Service Types' ;
    rdfs:comment 'Comma-separated list of telecommunications service types impacted by this change (e.g., wireless, broadband, Fiber to the Home (FTTH), Voice over Long-Term Evolution (VoLTE), Internet Protocol Television (IPTV), Mobile Virtual Network Operator (MVNO) services).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Change Reference Number' ;
    rdfs:comment 'External reference number or docket number assigned by the regulatory authority (e.g., FCC docket number, EU directive reference, parliamentary bill number). Used for tracking and cross-referencing with official regulatory publications.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Comment Period End Date' ;
    rdfs:comment 'Date when the public comment period closes. Comments submitted after this date may not be considered by the regulatory authority.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Comment Period Start Date' ;
    rdfs:comment 'Date when the public comment period opens for proposed rulemakings, allowing stakeholders to submit feedback to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Comment Submission Date' ;
    rdfs:comment 'Date when the operator submitted its formal comments to the regulatory authority. Null if no comment was submitted.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commentSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Comment Submitted Flag' ;
    rdfs:comment 'Boolean indicator of whether the telecommunications operator submitted formal comments or feedback to the regulatory authority during the public comment period.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Web link to the official regulatory document, proposed rule, or legislative text published by the issuing authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComplianceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost Amount' ;
    rdfs:comment 'Estimated financial cost to achieve compliance with this regulatory change, including system modifications, process changes, training, and external consulting. Expressed in the operators reporting currency.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Status' ;
    rdfs:comment 'Status of the internal impact assessment process evaluating how this regulatory change affects the operators systems, processes, costs, and compliance posture.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Severity Level' ;
    rdfs:comment 'Assessed severity of the regulatory changes impact on the telecommunications operator, considering operational disruption, financial cost, and compliance risk.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'Actual date when the operator achieved full compliance with the regulatory change. Null if implementation is not yet complete.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Date by which the telecommunications operator must achieve full compliance with the new or amended regulatory obligation. May differ from effective date if a transition period is granted.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan Description' ;
    rdfs:comment 'Summary of the planned or executed actions to achieve compliance, including system changes, process updates, training programs, and policy revisions.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the operators implementation efforts to achieve compliance with this regulatory change. [ENUM-REF-CANDIDATE: not_started|planning|in_progress|testing|completed|deferred|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference number or identifier of the internal corporate policy, procedure, or compliance framework document that addresses this regulatory change.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCitation rdf:type rdf:Property ;
    rdfs:label 'Legal Citation' ;
    rdfs:comment 'Full legal citation or reference to the statute, regulation, directive, or standard document (e.g., 47 CFR Part 64, EU Directive 2018/1972, 3GPP TS 23.501).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or employee identifier of the user who last modified this regulatory change record, supporting audit trail and accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPriority rdf:type rdf:Property ;
    rdfs:label 'Monitoring Priority' ;
    rdfs:comment 'Priority level assigned for ongoing monitoring and tracking of this regulatory change through its lifecycle, based on business impact and compliance risk.' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the regulatory change, proposed rule, or legislative amendment was officially published or announced by the issuing authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedChanges rdf:type rdf:Property ;
    rdfs:label 'Related Changes' ;
    rdfs:comment 'Comma-separated list of related regulatory change IDs or reference numbers that are connected to this change (e.g., predecessor rules, companion amendments, superseded regulations).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'Name of the business unit, department, or division responsible for implementing compliance with this regulatory change (e.g., Legal, Regulatory Affairs, Network Operations, Customer Privacy).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'Name of the regulatory body, legislative body, or standards organization that issued or proposed the change (e.g., FCC, NTIA, Ofcom, BEREC, European Parliament, 3GPP, ITU).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Source Jurisdiction' ;
    rdfs:comment 'Geographic or political jurisdiction of the issuing authority using ISO 3166-1 alpha-3 country codes or regional identifiers (e.g., USA, GBR, EUR for EU-wide directives).' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Foreign key reference to the original regulatory filing if this record represents an amendment or resubmission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory authority formally acknowledged receipt of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialTreatmentRequested rdf:type rdf:Property ;
    rdfs:label 'Confidential Treatment Requested' ;
    rdfs:comment 'Indicates whether the filer requested confidential or proprietary treatment for any portion of the submission under applicable rules.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or receipt number issued by the regulatory authority upon successful submission of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the system user who created this record. Audit trail for accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of supporting documents or attachments included with this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCounselInvolved rdf:type rdf:Property ;
    rdfs:label 'External Counsel Involved' ;
    rdfs:comment 'Indicates whether external legal counsel or consultants were engaged in the preparation or review of this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed narrative description of the filing content, scope, and purpose. Provides context for the submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'Monetary fee charged by the regulatory authority for processing this filing, in the reporting currency.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee amount.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFormat rdf:type rdf:Property ;
    rdfs:label 'Filing Format' ;
    rdfs:comment 'The format or medium in which the filing was submitted to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'The ending date of the reporting period covered by this regulatory filing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'The beginning date of the reporting period covered by this regulatory filing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPriority rdf:type rdf:Property ;
    rdfs:label 'Filing Priority' ;
    rdfs:comment 'Internal priority classification for this filing based on business impact, regulatory risk, or strategic importance.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the regulatory authority or internal system for tracking this submission. Business identifier for the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks the submission through its workflow from draft to final disposition.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory submission type. Defines the nature and purpose of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this record. Audit trail for accountability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier for the payment of the filing fee.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerDepartment rdf:type rdf:Property ;
    rdfs:label 'Preparer Department' ;
    rdfs:comment 'Business unit or department responsible for preparing the filing (e.g., Regulatory Affairs, Legal, Finance).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Name of the individual or team who prepared the filing content and supporting documentation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date on which the regulatory authority issued a public notice or published the filing for public comment.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date on which the regulatory authority completed its review and issued a final determination on the filing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the internal review and approval of the filing was completed prior to submission.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual who reviewed and approved the filing for submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the filing was officially submitted to the regulatory authority. Principal business event timestamp for the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPages rdf:type rdf:Property ;
    rdfs:label 'Total Pages' ;
    rdfs:comment 'Total page count across all documents submitted as part of this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Regulatory obligations (franchise fees, build-out commitments, USO requirements) are territory-specific. Compliance tracking requires mapping obligations to service territories to monitor territory-le' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:complianceOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Every regulatory obligation requires an accountable owner for telecommunications compliance management. Used for deadline tracking, escalation workflows, performance reviews, and regulatory audit resp' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualComplianceCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Compliance Cost Estimate' ;
    rdfs:comment 'Estimated annual cost in USD to maintain compliance with this obligation, including personnel, systems, external audit fees, and filing costs. Used for compliance budgeting and cost-benefit analysis.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segments to which this obligation applies. Examples: \'consumer,soho\', \'enterprise,government\', \'wholesale\'. Null if obligation applies to all customer types.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of telecommunications service types to which this obligation applies. Examples: \'mobile_voice,mobile_data\', \'fixed_broadband,fiber\', \'iptv,ott_video\', \'wholesale_interconnect\'. Null if obligation applies to all services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required Flag' ;
    rdfs:comment 'Indicates whether this obligation requires maintenance of detailed audit trails and evidence of compliance activities. True for obligations subject to regulatory audit or certification (e.g., ISO/IEC 27001, CALEA, GDPR data processing records).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationFeasibility rdf:type rdf:Property ;
    rdfs:label 'Automation Feasibility' ;
    rdfs:comment 'Assessment of the extent to which compliance monitoring, evidence collection, and reporting for this obligation can be automated through systems integration and workflow automation. Drives compliance technology roadmap.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'Required frequency for compliance reporting, monitoring, or certification activities. Determines the cadence of compliance calendar entries and audit schedules. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annual|annual|biennial|event_driven|one_time — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAuthority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority' ;
    rdfs:comment 'Name of the regulatory body or government agency responsible for enforcing this obligation. Examples: \'Federal Communications Commission (FCC)\', \'European Data Protection Board (EDPB)\', \'Office of Communications (Ofcom)\', \'California Public Utilities Commission (CPUC)\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiry Date' ;
    rdfs:comment 'Date when a granted exemption or waiver expires and full compliance becomes mandatory. Null if no exemption is in effect or exemption is permanent.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Indicates whether the organization has been granted any exemption, waiver, or special dispensation from this obligation by the enforcement authority. Includes rationale and expiry date of exemption if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Assessment Date' ;
    rdfs:comment 'Date of the most recent compliance assessment, audit, or certification activity for this obligation. Used to track assessment currency and schedule next reviews.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Update Date' ;
    rdfs:comment 'Date when the regulatory text, requirements, or interpretation of this obligation was last amended by the enforcement authority. Triggers compliance impact assessments and process updates.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty amount for a single violation of this obligation, in the currency specified. Used for risk quantification and compliance prioritization.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Due Date' ;
    rdfs:comment 'Next scheduled date by which compliance evidence, filing, or certification must be submitted to the enforcement authority. Drives compliance calendar and alert generation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory obligation, used for external reference and reporting. Examples: CALEA-LI-001, GDPR-ART17, USF-CONTRIB-Q1.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Comprehensive description of the regulatory obligation, including specific requirements, scope, applicability conditions, and any special provisions or exemptions.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Full descriptive name of the regulatory obligation. Example: \'CALEA Lawful Intercept Capability Maintenance\', \'GDPR Right to Erasure Compliance\', \'Universal Service Fund Quarterly Contribution\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the regulatory obligation by its primary regulatory domain. Determines the compliance framework, reporting requirements, and enforcement mechanisms applicable to this obligation. [ENUM-REF-CANDIDATE: spectrum_license|calea_mandate|gdpr_requirement|ccpa_requirement|usf_contribution|cpni_protection|mnp_rule|net_neutrality|e911_requirement|roaming_regulation|universal_service|numbering_plan — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationUrl rdf:type rdf:Property ;
    rdfs:label 'Obligation Url' ;
    rdfs:comment 'URL link to the official regulatory text, guidance document, or enforcement authority webpage for this obligation. Provides direct access to authoritative source material.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyFramework rdf:type rdf:Property ;
    rdfs:label 'Penalty Framework' ;
    rdfs:comment 'Description of the penalty structure for non-compliance, including monetary fines, sanctions, license revocation, or other enforcement actions. Examples: \'Up to 4% of annual global turnover or €20M (GDPR)\', \'Daily fines up to $100,000 per violation (FCC)\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedObligations rdf:type rdf:Property ;
    rdfs:label 'Related Obligations' ;
    rdfs:comment 'Comma-separated list of obligation codes for related or dependent regulatory obligations. Used to model obligation hierarchies, prerequisite relationships, and compliance dependencies. Example: \'GDPR-ART17,GDPR-ART32\' for obligations that must be satisfied together.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Reporting Template Reference' ;
    rdfs:comment 'Reference identifier or URL to the official reporting template, form, or submission format required by the enforcement authority. Examples: \'FCC Form 477\', \'BEREC Template NN-2023-01\', \'Ofcom C5 Return\'.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which compliance evidence or filings must be submitted to the enforcement authority. Determines integration requirements and submission workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (quarter or month) in which the penalty expense was recognized in the financial statements, formatted as YYYY-QN for quarters or YYYY-MM for months.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Penalty Amount' ;
    rdfs:comment 'Final penalty amount after any reductions, settlements, or adjustments resulting from appeals, negotiations, or compliance remediation. Null if no adjustment has been made.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'Date on which the regulatory authority or court issued a final decision on the appeal. Null if appeal is still pending or no appeal was filed.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Boolean indicator of whether the telecommunications operator has filed a formal appeal or petition for reconsideration with the regulatory authority or judicial body. True if appeal filed, False otherwise.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFilingDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filing Date' ;
    rdfs:comment 'Date on which the operator filed a formal appeal, petition for reconsideration, or judicial review of the penalty. Null if no appeal has been filed.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Final result of the appeal process, indicating whether the original penalty was upheld, modified, or overturned. [ENUM-REF-CANDIDATE: Penalty Upheld|Penalty Reduced|Penalty Waived|Remanded for Further Review|Settled|Withdrawn|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of the appeal or reconsideration process, tracking progression from filing through final adjudication. [ENUM-REF-CANDIDATE: Not Filed|Pending|Under Review|Hearing Scheduled|Denied|Granted|Partially Granted|Withdrawn|Settled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Number' ;
    rdfs:comment 'Transaction reference or confirmation number provided by the regulatory authority or financial institution upon successful payment of the penalty.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Notice Date' ;
    rdfs:comment 'Date on which the regulatory authority officially issued the Notice of Apparent Liability (NAL), forfeiture order, or penalty notice to the telecommunications operator.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Penalty Reference Number' ;
    rdfs:comment 'External reference number or citation number assigned by the regulatory authority to this enforcement action. Used for official correspondence and tracking.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Status' ;
    rdfs:comment 'Current lifecycle status of the penalty enforcement action, tracking progression from issuance through resolution or appeal. [ENUM-REF-CANDIDATE: Issued|Under Appeal|Appeal Denied|Appeal Granted|Paid|Partially Paid|Overdue|Waived|Settled|Withdrawn — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the penalty must be publicly disclosed in regulatory filings, financial statements, or public notices per securities law or regulatory transparency requirements. True if disclosure required, False otherwise.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk Flag' ;
    rdfs:comment 'Boolean indicator of whether the compliance team has identified a risk of similar violations recurring due to systemic process gaps or control weaknesses. True if recurrence risk identified, False otherwise.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the regulatory authority has mandated submission of a corrective action plan, compliance improvement plan, or remediation roadmap. True if required, False otherwise.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationPlanSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Submission Date' ;
    rdfs:comment 'Date on which the operator submitted the required remediation or corrective action plan to the regulatory authority. Null if not required or not yet submitted.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Flag' ;
    rdfs:comment 'Boolean indicator of whether the penalty was resolved through a negotiated settlement or consent decree with the regulatory authority. True if settled, False otherwise.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Summary of the key terms and conditions of the settlement agreement, including any compliance commitments, remediation actions, or payment schedules agreed upon.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the specific regulatory violation, including the nature of the breach, affected services, customer impact, and any aggravating or mitigating circumstances.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationEndDate rdf:type rdf:Property ;
    rdfs:label 'Violation End Date' ;
    rdfs:comment 'Date on which the violation was remediated or ceased. Null for single-occurrence violations or if the violation is ongoing.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Violation Occurrence Date' ;
    rdfs:comment 'Date on which the regulatory violation occurred or was first detected by the regulatory authority. May represent the start date for ongoing or repeated violations.' ;
    rdfs:domain ind:RegulatoryPenalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySiteLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Site Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Spectrum licenses are issued for transmission from specific physical sites. Regulatory filings to granting authorities require site-level reporting of spectrum usage, antenna locations, and interferen' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:acquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Amount' ;
    rdfs:comment 'The total cost paid by the operator to acquire this spectrum license, including auction bids, transfer fees, and transaction costs. Expressed in the currency specified by the acquisition cost currency code.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition cost.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the operator acquired ownership or rights to this spectrum license. May differ from issue date if acquired through secondary market.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'The method by which the operator acquired this spectrum license. Indicates whether it was obtained through auction, direct assignment, purchase, or other means.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'The annual regulatory fee charged by the granting authority for holding this spectrum license. Expressed in the currency specified by the fee currency code.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthMhz rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mhz' ;
    rdfs:comment 'The total bandwidth allocated to this license in megahertz. Calculated as the difference between upper and lower frequency bounds.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementActionDescription rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Description' ;
    rdfs:comment 'Textual description of any enforcement actions taken by the regulatory authority, including the nature of the violation and remediation requirements. Null if no enforcement action exists.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether any regulatory enforcement action (warning, fine, suspension) has been taken against this license. True if enforcement action exists, False otherwise.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'The radio frequency band allocated to this license, expressed in standard band notation (e.g., 600 MHz, 3.5 GHz, 28 GHz). Identifies the spectrum range for transmission.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantingAuthority rdf:type rdf:Property ;
    rdfs:label 'Granting Authority' ;
    rdfs:comment 'The regulatory body or national authority that issued this spectrum license (e.g., FCC, Ofcom, NTIA, BEREC member regulator).' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Granting Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the granting authority operates.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interferenceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Interference Protection Flag' ;
    rdfs:comment 'Indicates whether this license includes regulatory protection from interference by other spectrum users. True if protected, False if shared or unlicensed spectrum.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'The date of the most recent regulatory compliance review or audit for this license. Used to track periodic compliance verification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseCategory rdf:type rdf:Property ;
    rdfs:label 'License Category' ;
    rdfs:comment 'Classification of the spectrum license by service type. Determines the permitted use case and operational constraints.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The official license number or call sign assigned by the regulatory authority. This is the externally-known unique identifier for the spectrum license.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the spectrum license. Indicates whether the license is operational, under review, or terminated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermYears rdf:type rdf:Property ;
    rdfs:label 'License Term Years' ;
    rdfs:comment 'The duration of the license grant in years. Defines the period for which the spectrum rights are valid before renewal is required.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowerFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Lower Frequency Mhz' ;
    rdfs:comment 'The lower bound of the licensed frequency range in megahertz. Defines the start of the spectrum allocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Percentage' ;
    rdfs:comment 'The minimum spectrum utilization percentage required by the regulatory authority to maintain the license in good standing. Failure to meet this threshold may result in penalties or revocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'The scheduled date for the next regulatory compliance review or audit. Null if no review is scheduled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the licensee submitted the renewal application to the regulatory authority. Null if no renewal has been requested.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the license renewal process. Tracks whether renewal is required, applied for, or completed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedSpectrumFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Spectrum Flag' ;
    rdfs:comment 'Indicates whether this license operates in a shared spectrum environment (e.g., CBRS, LSA) where multiple operators may use the same frequencies under coordination rules. True if shared, False if exclusive.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyStandard rdf:type rdf:Property ;
    rdfs:label 'Technology Standard' ;
    rdfs:comment 'The radio access technology or standard authorized for use under this license (e.g., LTE, 5G NR, Wi-Fi 6, satellite). May be technology-neutral or technology-specific depending on regulatory framework.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether this license may be transferred or sold to another operator subject to regulatory approval. True if transferable, False if non-transferable.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Upper Frequency Mhz' ;
    rdfs:comment 'The upper bound of the licensed frequency range in megahertz. Defines the end of the spectrum allocation.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageConditions rdf:type rdf:Property ;
    rdfs:label 'Usage Conditions' ;
    rdfs:comment 'Textual description of the regulatory conditions, restrictions, and obligations attached to this license. May include build-out requirements, interference limits, and service quality mandates.' ;
    rdfs:domain ind:SpectrumLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adInsertionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Policy Id' ;
    rdfs:comment 'Unique identifier for the ad insertion policy. Primary key.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdInsertionPolicy .

ind:policyOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Ad insertion policies require business owners (advertising operations managers) to define rules, approve changes, coordinate with sales/legal teams, and ensure compliance with advertiser contracts. Cr' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adDecisionServiceType rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Service Type' ;
    rdfs:comment 'Type of ad decisioning architecture: server-side (ad stitching at origin), client-side (ad selection at player), or hybrid (combination of both).' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'Format of the advertisement to be inserted: pre-roll (before content), mid-roll (during content), post-roll (after content), overlay (on-screen graphic), companion (adjacent banner), or bumper (short non-skippable).' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Duration Seconds' ;
    rdfs:comment 'Duration of a single ad pod (group of consecutive ads) in seconds. Defines the length of each advertising break.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adServerIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Ad Server Integration Endpoint' ;
    rdfs:comment 'URL or API endpoint of the ad server system that provides ad decisioning and creative delivery for this policy.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertiserCategoryExclusions rdf:type rdf:Property ;
    rdfs:label 'Advertiser Category Exclusions' ;
    rdfs:comment 'Comma-separated list of advertiser categories or industries that are prohibited from this ad insertion policy (e.g., alcohol, gambling, political). [ENUM-REF-CANDIDATE: alcohol|gambling|tobacco|pharmaceuticals|political|adult|firearms|cryptocurrency — promote to reference product]' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannelScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel Scope' ;
    rdfs:comment 'Comma-separated list of channel codes or identifiers to which this ad insertion policy applies. Defines the content distribution channels covered.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableContentPackageScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Content Package Scope' ;
    rdfs:comment 'Comma-separated list of content package codes to which this ad insertion policy applies. Defines the content offerings covered.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier or username of the person who approved this ad insertion policy for production use.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLoggingEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Logging Enabled' ;
    rdfs:comment 'Flag indicating whether detailed audit logs of ad insertion events and decisions are captured for compliance and analytics.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveSeparationEnabled rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Enabled' ;
    rdfs:comment 'Flag indicating whether competitive separation rules are enforced to prevent ads from competing brands appearing in the same pod.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveSeparationMinutes rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Minutes' ;
    rdfs:comment 'Minimum time separation in minutes required between advertisements from competing brands or product categories.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restrictions' ;
    rdfs:comment 'Content rating levels to which this ad insertion policy applies (e.g., G, PG, PG-13, R). Ensures age-appropriate advertising.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTypeScope rdf:type rdf:Property ;
    rdfs:label 'Device Type Scope' ;
    rdfs:comment 'Comma-separated list of device types to which this ad insertion policy applies (e.g., mobile, tablet, smart TV, set-top box, web browser).' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicAdInsertionEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Ad Insertion Enabled' ;
    rdfs:comment 'Flag indicating whether dynamic ad insertion technology is enabled, allowing personalized ad targeting and real-time ad stitching.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyCapCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Count' ;
    rdfs:comment 'Maximum number of times the same advertisement can be shown to a single viewer within the frequency cap window. Prevents ad fatigue.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapWindowHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Window Hours' ;
    rdfs:comment 'Time window in hours over which the frequency cap count is enforced. Defines the period for measuring ad repetition.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insertionTriggerType rdf:type rdf:Property ;
    rdfs:label 'Insertion Trigger Type' ;
    rdfs:comment 'Mechanism that triggers ad insertion: time-based (fixed intervals), scene-based (content analysis), chapter-based (content markers), cue-tone (audio signal), SCTE-35 (industry standard signaling), or manual override.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAdLoadPerHourMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Ad Load Per Hour Minutes' ;
    rdfs:comment 'Maximum total duration of advertising content permitted per hour of programming, measured in minutes. Ensures compliance with regulatory limits and viewer experience standards.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Ad Pod Duration Seconds' ;
    rdfs:comment 'Maximum allowable duration for an ad pod in seconds. Prevents excessively long ad breaks that degrade viewer experience.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Min Ad Pod Duration Seconds' ;
    rdfs:comment 'Minimum allowable duration for an ad pod in seconds. Ensures ad breaks meet minimum length requirements for monetization.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCpmFloor rdf:type rdf:Property ;
    rdfs:label 'Minimum Cpm Floor' ;
    rdfs:comment 'Minimum cost per thousand impressions (CPM) floor price for ad inventory under this policy. Ensures minimum monetization threshold.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ottPlatformScope rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Scope' ;
    rdfs:comment 'Comma-separated list of OTT platform codes where this ad insertion policy is enforced. Defines which streaming platforms use this policy.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Flag indicating whether ad personalization based on viewer demographics, behavior, and preferences is enabled for this policy.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the ad insertion policy, used for external reference and integration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed description of the ad insertion policy, including business rules and intended use cases.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the ad insertion policy for display and reporting purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the ad insertion policy indicating whether it is operational, under development, or retired.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Type of ad insertion policy: AVOD (Advertising Video on Demand), FAST (Free Ad-Supported Streaming TV), linear (live linear channels), VOD (Video on Demand), or live streaming.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticBuyingEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Buying Enabled' ;
    rdfs:comment 'Flag indicating whether programmatic ad buying through real-time bidding (RTB) exchanges is enabled for this policy.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of advertising revenue shared with content providers or partners under this policy. Business-confidential commercial term.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Subscriber Tier Eligibility' ;
    rdfs:comment 'Subscriber tier levels to which this ad insertion policy applies: free (ad-supported free tier), basic (entry-level paid), premium (ad-free or reduced ads), or all tiers.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerRuleDefinition rdf:type rdf:Property ;
    rdfs:label 'Trigger Rule Definition' ;
    rdfs:comment 'Detailed specification of the trigger rules including timing intervals, scene detection parameters, or cue point configurations that determine when ads are inserted.' ;
    rdfs:domain ind:AdInsertionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentChannelLineupId rdf:type rdf:Property ;
    rdfs:label 'Content Channel Lineup Id' ;
    rdfs:comment 'Unique identifier for the IPTV channel lineup package. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentChannelLineup .

ind:drmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to content.drm_policy. Business justification: Channel lineups reference DRM policies for content protection rules. The drm_policy_code STRING field should be replaced with a proper FK to drm_policy.drm_policy_id. This normalizes the reference and' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:enterpriseSegmentId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Segment Id' ;
    rdfs:comment 'Foreign key linking to enterprise.segment. Business justification: Channel lineups for enterprise customers vary by segment (retail locations get different channels than corporate offices, hospitality gets premium movie channels) for licensing compliance, pricing dif' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:blackoutRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Restrictions' ;
    rdfs:comment 'Description of geographic or temporal blackout restrictions for this lineup (e.g., \'Local sports blackouts apply\', \'No restrictions\'). Supports compliance with licensing terms.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catchupTvHours rdf:type rdf:Property ;
    rdfs:label 'Catchup Tv Hours' ;
    rdfs:comment 'Number of hours of catch-up TV (time-shifted viewing) available for channels in this lineup. Zero if catch-up is not supported.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnProfileCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Profile Code' ;
    rdfs:comment 'Code identifying the CDN delivery profile for this lineup (e.g., AKAMAI_PREMIUM, CLOUDFRONT_STD). Determines streaming quality and geographic reach.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCount rdf:type rdf:Property ;
    rdfs:label 'Channel Count' ;
    rdfs:comment 'Total number of channels included in this lineup. Updated as channels are added or removed from the composition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Maximum content rating level included in this lineup (G, PG, PG-13, TV-14, TV-MA, R, NR). Used for parental control and compliance. [ENUM-REF-CANDIDATE: G|PG|PG13|TV14|TVMA|R|NR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvrEnabled rdf:type rdf:Property ;
    rdfs:label 'Dvr Enabled' ;
    rdfs:comment 'Indicates whether cloud DVR recording is enabled for channels in this lineup (true/false).' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this lineup should be featured prominently in marketing materials and product catalogs (true/false).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdChannelCount rdf:type rdf:Property ;
    rdfs:label 'Hd Channel Count' ;
    rdfs:comment 'Number of HD (High Definition) channels included in this lineup. Subset of total channel count.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Primary language code for the lineup content (ISO 639-1/639-2 format, e.g., \'en\', \'es\', \'fr\'). Determines audio and subtitle availability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date when content licensing agreements for this lineup expire. Null if perpetual or managed at channel level. Triggers renewal or discontinuation workflows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingTerritory rdf:type rdf:Property ;
    rdfs:label 'Licensing Territory' ;
    rdfs:comment 'Geographic territory covered by content licensing agreements for this lineup (e.g., \'North America\', \'EU\', \'APAC\'). Determines where lineup can be legally offered.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupCode rdf:type rdf:Property ;
    rdfs:label 'Lineup Code' ;
    rdfs:comment 'Business identifier code for the channel lineup (e.g., BASIC_HD, PREMIUM_SPORTS, FAMILY_PLUS). Used in product catalogs and subscriber entitlements.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupDescription rdf:type rdf:Property ;
    rdfs:label 'Lineup Description' ;
    rdfs:comment 'Detailed description of the channel lineup package, including key features, target audience, and value proposition.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupName rdf:type rdf:Property ;
    rdfs:label 'Lineup Name' ;
    rdfs:comment 'Marketing name of the channel lineup package (e.g., \'Basic HD Package\', \'Premium Sports Bundle\', \'Family Entertainment Plus\').' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupStatus rdf:type rdf:Property ;
    rdfs:label 'Lineup Status' ;
    rdfs:comment 'Current lifecycle status of the lineup: draft (under development), active (available for subscription), suspended (temporarily unavailable), retired (no longer offered), discontinued (removed from catalog).' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupType rdf:type rdf:Property ;
    rdfs:label 'Lineup Type' ;
    rdfs:comment 'Technical delivery type of the lineup: IPTV (managed network), OTT (over-the-top internet), hybrid, linear channels, or VOD bundle.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed per subscriber account for this lineup. Used for entitlement enforcement.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Minimum Bandwidth Mbps' ;
    rdfs:comment 'Minimum internet bandwidth (in Mbps) required to stream this lineup at standard quality. Used for service qualification.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiscreenEnabled rdf:type rdf:Property ;
    rdfs:label 'Multiscreen Enabled' ;
    rdfs:comment 'Indicates whether subscribers can view this lineup on multiple device types (TV, mobile, tablet, web) simultaneously (true/false).' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Control Required' ;
    rdfs:comment 'Indicates whether parental controls must be enabled for this lineup due to mature content (true/false).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this lineup is part of a promotional campaign (true/false). Promotional lineups may have limited-time availability or special pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Recommended Bandwidth Mbps' ;
    rdfs:comment 'Recommended internet bandwidth (in Mbps) for optimal streaming quality (HD/UHD) for this lineup.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Display sort order for this lineup in product catalogs and subscriber portals. Lower numbers appear first.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Streaming Protocol' ;
    rdfs:comment 'Primary streaming protocol used for lineup delivery: HLS (HTTP Live Streaming), DASH (Dynamic Adaptive Streaming over HTTP), Smooth Streaming, RTSP, or multicast.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDeviceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Device Types' ;
    rdfs:comment 'Comma-separated list of device types supported for this lineup (e.g., \'STB,SmartTV,Mobile,Tablet,Web,Gaming Console\'). Determined by DRM and app availability.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Service tier classification of the lineup (basic, standard, premium, add_on, a_la_carte, promotional). Determines pricing and bundling eligibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uhd4kChannelCount rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Channel Count' ;
    rdfs:comment 'Number of UHD/4K channels included in this lineup. Subset of total channel count.' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vodEnabled rdf:type rdf:Property ;
    rdfs:label 'Vod Enabled' ;
    rdfs:comment 'Indicates whether VOD content is included with this lineup (true/false).' ;
    rdfs:domain ind:ContentChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique identifier for the content entitlement record. Primary key.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpeAssetId rdf:type rdf:Property ;
    rdfs:label 'Cpe Asset Id' ;
    rdfs:comment 'Foreign key linking to inventory.cpe_asset. Business justification: Content entitlements are provisioned to specific CPE devices (STBs, streaming boxes) for DRM enforcement, device-level access control, and concurrent stream limit enforcement. Operations track device-' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CpeAsset .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Reference to the content licensing agreement that governs the rights and terms under which this entitlement is granted. Links to the contract with the content provider or studio.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was activated and the subscriber first gained access. Nullable if entitlement is still pending activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the entitlement automatically renews upon expiry. True = subscription will auto-renew unless cancelled; False = entitlement ends at expiry date. Applicable primarily to subscription-based entitlements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code indicating the reason for entitlement cancellation. Examples: \'SUBSCRIBER_REQUEST\', \'NON_PAYMENT\', \'SERVICE_TERMINATION\', \'MIGRATION\', \'FRAUD\'. Nullable if not cancelled. Used for churn analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was cancelled by the subscriber or system. Nullable if entitlement has not been cancelled. Used for churn analysis and lifecycle tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'Maximum number of simultaneous content streams allowed under this entitlement. Enforces household or account-level concurrency rules. Nullable if no limit is enforced.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceLimit rdf:type rdf:Property ;
    rdfs:label 'Device Limit' ;
    rdfs:comment 'Maximum number of devices that can be registered or authorized to consume content under this entitlement. Nullable if no device limit is enforced.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dolbyAtmosEnabled rdf:type rdf:Property ;
    rdfs:label 'Dolby Atmos Enabled' ;
    rdfs:comment 'Indicates whether the entitlement includes access to Dolby Atmos immersive audio. True = Dolby Atmos available; False = standard audio only. Premium audio feature.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Code' ;
    rdfs:comment 'Code identifying the DRM policy governing content protection and usage rules for this entitlement. Defines encryption standards, device limits, offline viewing permissions, and geographic restrictions. Examples: \'WIDEVINE_L1\', \'FAIRPLAY_STD\', \'PLAYREADY_SL3000\'.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitledContentScope rdf:type rdf:Property ;
    rdfs:label 'Entitled Content Scope' ;
    rdfs:comment 'Describes the breadth of content covered by this entitlement. May reference a package name, catalog identifier, individual title identifier, channel lineup name, or OTT platform name. Examples: \'Premium Sports Package\', \'VOD Catalog - Movies\', \'Title ID 98765\', \'HBO Max Platform\', \'Channel Lineup - Basic\'.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the content entitlement. Active = subscriber can consume content; Suspended = temporarily disabled (e.g., payment issue); Expired = validity period ended; Cancelled = subscriber or system terminated; Pending Activation = granted but not yet effective.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the content access model. Subscription = recurring access to channel lineups or VOD catalogs; Rental = TVOD time-limited access; Purchase = EST permanent ownership; Complimentary = free promotional grant; OTT Bundle = bundled third-party OTT platform access (Netflix, Disney+, HBO Max); Promotional = campaign-driven temporary access.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Code' ;
    rdfs:comment 'Code defining geographic or territorial restrictions on content access. May reference a country code, region code, or blackout zone. Examples: \'USA\', \'EU\', \'BLACKOUT_ZONE_5\'. Nullable if no geographic restrictions apply.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Code' ;
    rdfs:comment 'External reference identifier linking this entitlement to its originating source. May be a product order ID, promotion campaign ID, migration batch ID, or manual grant ticket number. Provides traceability to the business event that created the entitlement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantSource rdf:type rdf:Property ;
    rdfs:label 'Grant Source' ;
    rdfs:comment 'Origin of the entitlement grant. Product Bundle = included in a purchased service plan; Promotion = marketing campaign grant; Manual Override = CSR or admin manual grant; Migration = transferred from legacy system; Loyalty Reward = earned through customer loyalty program; Partner Offer = granted via partner agreement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdQualityEnabled rdf:type rdf:Property ;
    rdfs:label 'Hd Quality Enabled' ;
    rdfs:comment 'Indicates whether the entitlement includes access to high-definition (HD) quality streams. True = HD available; False = standard definition only. May be tier-dependent.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp of the most recent content consumption event under this entitlement. Used to track engagement and identify dormant entitlements. Nullable if content has never been accessed.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offlineViewingAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Viewing Allowed' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to download and view content offline under this entitlement. True = offline downloads enabled; False = streaming only. Subject to DRM policy and licensing terms.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ottAccountIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ott Account Identifier' ;
    rdfs:comment 'The subscriber\'s account identifier on the third-party OTT platform. Used for account linking and entitlement verification. Populated only for OTT bundle entitlements.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottApiCredential rdf:type rdf:Property ;
    rdfs:label 'Ott Api Credential' ;
    rdfs:comment 'API credential or access key used by the telecommunications platform to manage the subscriber\'s OTT entitlement via partner API. Used for provisioning, status checks, and deprovisioning operations. Applicable only to OTT bundle entitlements.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ott Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful synchronization with the OTT platform\'s entitlement API. Used to track data freshness and detect sync failures. Applicable only to OTT bundle entitlements.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ottProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Ott Provisioning Status' ;
    rdfs:comment 'Current provisioning state of the OTT platform entitlement. Pending = provisioning request submitted; Provisioned = account created on OTT platform; Active = subscriber can access; Suspended = temporarily disabled; Deprovisioned = access removed; Failed = provisioning error. Applicable only to OTT bundle entitlements.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottSsoToken rdf:type rdf:Property ;
    rdfs:label 'Ott Sso Token' ;
    rdfs:comment 'Single sign-on authentication token used for seamless subscriber login to the OTT platform. Encrypted credential enabling passwordless access. Populated only for OTT bundle entitlements with SSO integration.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlPinRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin Required' ;
    rdfs:comment 'Indicates whether a parental control PIN is required to access the entitled content. True = PIN must be entered before viewing; False = no PIN required. Used to enforce age-appropriate content access.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspended Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was suspended. Nullable if entitlement has never been suspended. Used for lifecycle event tracking.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAccessCount rdf:type rdf:Property ;
    rdfs:label 'Total Access Count' ;
    rdfs:comment 'Cumulative count of content access events (streams, downloads, views) under this entitlement since activation. Used for engagement analytics and usage-based billing.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uhd4kQualityEnabled rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Quality Enabled' ;
    rdfs:comment 'Indicates whether the entitlement includes access to ultra-high-definition (UHD) 4K quality streams. True = 4K available; False = lower resolutions only. Premium tier feature.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Id' ;
    rdfs:comment 'Unique identifier for the content geographic restriction record. Primary key.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Restricted Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Geo-restrictions operationally enforce content availability by service territory. Streaming platforms use this for real-time access control and licensing compliance. Core operational link for content ' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:allowedCountries rdf:type rdf:Property ;
    rdfs:label 'Allowed Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content is permitted for distribution (e.g., USA,CAN,MEX). Null if restriction_type is blocklist.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedRegions rdf:type rdf:Property ;
    rdfs:label 'Allowed Regions' ;
    rdfs:comment 'Comma-separated list of sub-national region codes (states, provinces, territories) where content is permitted. Used for granular territorial licensing within countries.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Log Enabled' ;
    rdfs:comment 'Indicates whether access attempts and enforcement actions for this geographic restriction are logged for compliance auditing and rights holder reporting.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedCountries rdf:type rdf:Property ;
    rdfs:label 'Blocked Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content distribution is prohibited (e.g., CHN,RUS,IRN). Null if restriction_type is allowlist.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedRegions rdf:type rdf:Property ;
    rdfs:label 'Blocked Regions' ;
    rdfs:comment 'Comma-separated list of sub-national region codes where content distribution is prohibited. Enables blackout zones within otherwise permitted countries.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnEnforcementEnabled rdf:type rdf:Property ;
    rdfs:label 'Cdn Enforcement Enabled' ;
    rdfs:comment 'Indicates whether this geographic restriction is enforced at the CDN edge nodes. True means CDN will block requests from restricted territories.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enforcementMethod rdf:type rdf:Property ;
    rdfs:label 'Enforcement Method' ;
    rdfs:comment 'Technical method used to enforce geographic restrictions: geo-IP lookup, GPS coordinates, network-based detection, device location services, or hybrid combination.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRangeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Ip Range Restrictions' ;
    rdfs:comment 'Comma-separated list of IP address ranges (CIDR notation) subject to geographic restrictions. Used for network-level enforcement of territorial rights.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEnforcementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Enforcement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent enforcement action taken based on this geographic restriction rule. Used for monitoring and compliance reporting.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether customer service or entitlement systems can override this geographic restriction for specific subscriber accounts (e.g., for traveling customers).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Override Approval Required' ;
    rdfs:comment 'Indicates whether management approval is required before a geographic restriction override can be granted to a subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformScope rdf:type rdf:Property ;
    rdfs:label 'Platform Scope' ;
    rdfs:comment 'Defines which content delivery platforms this geographic restriction applies to: IPTV, OTT streaming, VOD catalog, live TV, or all platforms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Business identifier code for this geographic restriction rule, used for operational reference and reporting.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Restriction Notes' ;
    rdfs:comment 'Free-text notes providing additional context about this geographic restriction, including business rationale, special conditions, or licensing agreement references.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionPriority rdf:type rdf:Property ;
    rdfs:label 'Restriction Priority' ;
    rdfs:comment 'Numeric priority level for this restriction when multiple overlapping geographic rules exist for the same content. Higher values take precedence.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Current lifecycle status of the geographic restriction rule. Active rules are enforced by content delivery systems.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Type of geographic restriction enforcement: allowlist (only specified territories allowed), blocklist (specified territories blocked), or hybrid (combination of both).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationAction rdf:type rdf:Property ;
    rdfs:label 'Violation Action' ;
    rdfs:comment 'Action taken when a user attempts to access content from a restricted territory: block access entirely, log for audit, warn user, degrade stream quality, or redirect to alternative content.' ;
    rdfs:domain ind:GeoRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionJobId rdf:type rdf:Property ;
    rdfs:label 'Ingestion Job Id' ;
    rdfs:comment 'Unique identifier for the content ingestion job. Primary key for tracking the operational workflow of ingesting new content assets into the platform.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIngestionPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Ingestion Partner Id' ;
    rdfs:comment 'Reference to the studio, distributor, or content partner providing the raw media files for ingestion.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:transcodingNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Transcoding Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: Content transcoding jobs are executed on specific encoding/transcoding equipment in headend facilities. Operations track equipment-job assignments for capacity planning, load balancing, job scheduling' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:abrLadderConfiguration rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Configuration' ;
    rdfs:comment 'JSON or structured representation of the ABR ladder applied during transcoding. Defines multiple quality tiers for adaptive streaming.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'Audio channel configuration produced during transcoding. Defines surround sound capabilities of the output audio.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'Audio codec applied during transcoding. Determines audio compression and quality for the output stream.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnPublishStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Publish Status' ;
    rdfs:comment 'Current status of the CDN publishing process. Indicates whether the content has been successfully distributed to edge servers for streaming delivery.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cdn Publish Timestamp' ;
    rdfs:comment 'Date and time when the content was successfully published to the CDN. Marks the point when content becomes available for subscriber streaming.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdnUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Url' ;
    rdfs:comment 'CDN endpoint URL where the published content is accessible for streaming. Used by player applications to retrieve the content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmPackagingStatus rdf:type rdf:Property ;
    rdfs:label 'Drm Packaging Status' ;
    rdfs:comment 'Current status of the DRM encryption and packaging process. Indicates whether content protection has been successfully applied.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmPackagingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Drm Packaging Timestamp' ;
    rdfs:comment 'Date and time when DRM packaging was completed. Used for tracking content protection lifecycle and compliance.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'DRM technology applied during packaging. Determines which devices and platforms can decrypt and play the protected content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrFormat rdf:type rdf:Property ;
    rdfs:label 'Hdr Format' ;
    rdfs:comment 'HDR format applied during transcoding. Defines the color depth and dynamic range capabilities of the output video.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Request Timestamp' ;
    rdfs:comment 'Date and time when the content ingestion request was submitted. Represents the business event time when the job was initiated.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Job Completion Timestamp' ;
    rdfs:comment 'Date and time when the entire ingestion job was completed. Represents the end-to-end processing time from request to CDN publishing.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobPriority rdf:type rdf:Property ;
    rdfs:label 'Job Priority' ;
    rdfs:comment 'Priority level assigned to the ingestion job. Determines processing order and resource allocation in the ingestion pipeline.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Job Reference Number' ;
    rdfs:comment 'Externally visible business identifier for the ingestion job. Used for tracking and communication with content providers and internal teams.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the content ingestion job. Tracks progression through the ingestion workflow from receipt through publishing. [ENUM-REF-CANDIDATE: pending|in_progress|transcoding|qa_review|drm_packaging|cdn_publishing|completed|failed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentStatus rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Status' ;
    rdfs:comment 'Current status of the metadata enrichment process. Indicates whether editorial metadata, thumbnails, and descriptive information have been added.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Timestamp' ;
    rdfs:comment 'Date and time when metadata enrichment was completed. Used for tracking catalog readiness and content discoverability.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qaCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Completion Timestamp' ;
    rdfs:comment 'Date and time when the quality assurance review was completed. Used for tracking review cycle time and SLA compliance.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qaNotes rdf:type rdf:Property ;
    rdfs:label 'Qa Notes' ;
    rdfs:comment 'Free-text notes from the QA reviewer documenting findings, issues, or approval rationale. Used for quality tracking and continuous improvement.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Status' ;
    rdfs:comment 'Current status of the quality assurance review process. Indicates whether the transcoded content meets technical and editorial standards.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times the ingestion job has been retried after failure. Used for monitoring job resilience and identifying chronic issues.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Hours' ;
    rdfs:comment 'Target completion time in hours as defined by the SLA with the content provider. Used for performance tracking and breach detection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFileDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Source File Duration Seconds' ;
    rdfs:comment 'Total runtime duration of the source media content in seconds. Used for validation and catalog metadata.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFileFormat rdf:type rdf:Property ;
    rdfs:label 'Source File Format' ;
    rdfs:comment 'Container format of the source media file received for ingestion. Determines compatibility and transcoding requirements.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Original filename of the raw media file received from the content provider. Used for traceability and troubleshooting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Source File Size Mb' ;
    rdfs:comment 'Size of the source media file in megabytes. Used for storage planning and transfer time estimation.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Bitrate Kbps' ;
    rdfs:comment 'Video bitrate in kilobits per second applied during transcoding. Determines video quality and bandwidth requirements for streaming.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCodec rdf:type rdf:Property ;
    rdfs:label 'Target Codec' ;
    rdfs:comment 'Video codec applied during transcoding. Determines compression efficiency and device compatibility for streaming delivery.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolution rdf:type rdf:Property ;
    rdfs:label 'Target Resolution' ;
    rdfs:comment 'Video resolution produced during transcoding. Defines the vertical pixel count for the output video stream.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcodingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transcoding Completion Timestamp' ;
    rdfs:comment 'Date and time when the transcoding process completed. Used for calculating processing duration and throughput metrics.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transcodingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Transcoding Duration Minutes' ;
    rdfs:comment 'Total time in minutes required to complete the transcoding process. Key performance indicator for ingestion efficiency.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcodingProfileCode rdf:type rdf:Property ;
    rdfs:label 'Transcoding Profile Code' ;
    rdfs:comment 'Reference to the transcoding configuration profile applied during processing. Defines codec, resolution, bitrate, and ABR ladder specifications.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcodingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transcoding Start Timestamp' ;
    rdfs:comment 'Date and time when the transcoding process began. Used for performance monitoring and SLA tracking.' ;
    rdfs:domain ind:IngestionJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Content licensing agreements require dedicated contract managers to negotiate terms, track renewal deadlines, ensure compliance with territory/platform restrictions, and coordinate with legal/finance.' ;
    rdfs:domain ind:License ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:licensedServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Licensed Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Content licenses grant rights for specific service territories. Rights management and compliance teams enforce territorial restrictions based on service territory boundaries. Essential for licensing c' ;
    rdfs:domain ind:License ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:advertisingRights rdf:type rdf:Property ;
    rdfs:label 'Advertising Rights' ;
    rdfs:comment 'Defines whether and how advertising may be monetized with the licensed content. AVOD permits ad-supported viewing; SVOD only prohibits ads; ad insertion allows dynamic ad placement; no advertising prohibits all commercial messaging.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the content licensing agreement. Used for contract reference and legal documentation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Schedule for compliance audits if required by the license agreement. On-demand allows licensor to request audit at any time. Null if compliance audit not required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDistributionPermitted rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Permitted' ;
    rdfs:comment 'Indicates whether content may be distributed through third-party CDN infrastructure or must use licensee-owned delivery networks.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Required' ;
    rdfs:comment 'Indicates whether the license agreement mandates periodic compliance audits of content usage, subscriber counts, and revenue reporting by licensor or third-party auditor.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'High-level classification of the licensed content type. Used for content catalog organization and rights management segmentation. [ENUM-REF-CANDIDATE: movie|tv_series|sports|documentary|news|kids|music|adult — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDeliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Format' ;
    rdfs:comment 'Technical format and specifications for content delivery such as HD, 4K, HDR, Dolby Atmos. May include multiple formats as comma-separated values.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGenre rdf:type rdf:Property ;
    rdfs:label 'Content Genre' ;
    rdfs:comment 'Specific genre classification of the content such as action, drama, comedy, thriller, documentary, reality, sports event type. Multiple genres may be concatenated.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentTitle rdf:type rdf:Property ;
    rdfs:label 'Content Title' ;
    rdfs:comment 'Primary title or name of the licensed content asset. For individual titles this is the movie or episode name; for series this is the series name; for catalogs this is the catalog designation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the license agreement was executed by all parties. Establishes legal binding date and may differ from license start date.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmPolicyRequired rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Required' ;
    rdfs:comment 'Indicates whether Digital Rights Management protection is mandated by the license agreement. True requires DRM encryption for all content delivery.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmTechnology rdf:type rdf:Property ;
    rdfs:label 'Drm Technology' ;
    rdfs:comment 'Specific DRM technology or standard required for content protection such as Widevine, PlayReady, FairPlay, or multi-DRM. Null if DRM not required.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total duration of the license agreement expressed in months. Calculated from start to expiry date for reporting and renewal planning.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationPermitted rdf:type rdf:Property ;
    rdfs:label 'Early Termination Permitted' ;
    rdfs:comment 'Indicates whether either party may terminate the license agreement before the expiry date. True allows early termination subject to termination terms.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total monetary value of the license fee for the agreement period. May represent upfront payment, minimum guarantee, or total contract value depending on fee structure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the license fee amount.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructureType rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Type' ;
    rdfs:comment 'Defines the pricing model for the license agreement. Flat fee is fixed payment; per subscriber is usage-based; revenue share is percentage of content revenue; minimum guarantee combines upfront and variable; hybrid uses multiple models.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestrictions rdf:type rdf:Property ;
    rdfs:label 'Holdback Restrictions' ;
    rdfs:comment 'Temporal restrictions preventing content distribution during specified windows to protect other distribution channels such as theatrical release, physical media, or competing platforms.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRights rdf:type rdf:Property ;
    rdfs:label 'Language Rights' ;
    rdfs:comment 'Languages in which the content may be distributed, including audio tracks and subtitle languages. Stored as comma-separated ISO 639-2 language codes.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Defines the exclusivity and distribution window rights. Exclusive grants sole distribution rights in territory; non-exclusive allows multiple licensees; co-exclusive limits to specified number of licensees; first/second window defines temporal exclusivity periods.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedContentScope rdf:type rdf:Property ;
    rdfs:label 'Licensed Content Scope' ;
    rdfs:comment 'Defines the granularity of content covered by this license agreement. Individual title for single VOD assets, series for complete show franchises, season for specific seasons, catalog for content libraries, channel package for linear channel bundles, or bundle for mixed content collections.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeEntityName rdf:type rdf:Property ;
    rdfs:label 'Licensee Entity Name' ;
    rdfs:comment 'Legal name of the telecommunications entity acquiring the content rights. Typically the operator\'s legal entity or subsidiary.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Legal name of the content rights holder or content provider granting the license. May be a studio, broadcaster, production company, or content aggregator.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Maximum Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous content streams permitted under this license agreement. Critical for OTT platform capacity planning and license compliance monitoring.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'Minimum payment guaranteed to licensor regardless of actual usage or revenue. Common in minimum guarantee and hybrid fee structures.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Schedule for license fee payments to the licensor. Defines billing and payment cadence per contract terms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRestrictions rdf:type rdf:Property ;
    rdfs:label 'Platform Restrictions' ;
    rdfs:comment 'Comma-separated list of distribution platforms or delivery methods permitted or restricted under this license. May include IPTV, OTT, mobile, web, STB, smart TV, casting devices.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalRights rdf:type rdf:Property ;
    rdfs:label 'Promotional Rights' ;
    rdfs:comment 'Describes permitted use of content for marketing and promotional purposes including trailers, clips, screenshots, and promotional campaigns. May include duration and platform restrictions.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the licensee has contractual option to renew the license agreement upon expiry. True grants renewal rights subject to renewal terms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and pricing for license renewal including notice period, renewal fee adjustments, and renegotiation requirements. Null if no renewal option exists.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Detailed description of usage, revenue, and subscriber reporting obligations to the licensor including frequency, format, and data elements required.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the content rights to third parties such as MVNO partners or wholesale customers.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sublicensingTerms rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Terms' ;
    rdfs:comment 'Detailed terms and conditions governing sublicensing arrangements including revenue sharing, approval requirements, and territorial restrictions. Null if sublicensing not permitted.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for early termination of the license agreement. Null if early termination not permitted.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adSupported rdf:type rdf:Property ;
    rdfs:label 'Ad Supported' ;
    rdfs:comment 'Indicates whether this package includes advertising-supported content (True) or is ad-free (False).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this package automatically renews at the end of each billing cycle (True) or requires manual renewal (False).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityMarket rdf:type rdf:Property ;
    rdfs:label 'Availability Market' ;
    rdfs:comment 'Geographic market or region where this content package is available for sale. Comma-separated list of ISO 3166-1 alpha-3 country codes or market identifiers (e.g., \'USA,CAN,MEX\' or \'NORTH_AMERICA\').' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDeliveryProfile rdf:type rdf:Property ;
    rdfs:label 'Cdn Delivery Profile' ;
    rdfs:comment 'CDN delivery profile tier assigned to this package, determining streaming quality, bitrate, and network priority: standard (SD/HD), premium (HD/FHD), ultra_hd (4K/UHD), adaptive (dynamic quality adjustment).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelLineupIncluded rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Included' ;
    rdfs:comment 'Indicates whether this package includes a linear IPTV channel lineup (True) or not (False).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentLicensingRegion rdf:type rdf:Property ;
    rdfs:label 'Content Licensing Region' ;
    rdfs:comment 'Geographic region or territory for which content licensing rights have been secured for this package. May differ from availability_market due to licensing restrictions.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRefreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Content Refresh Frequency' ;
    rdfs:comment 'Frequency at which new content is added or refreshed in this package: daily, weekly, monthly, quarterly, on_demand (ad-hoc updates).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Textual description of the content included in the package: VOD (Video on Demand) catalog titles, OTT (Over-The-Top) platform access, IPTV (Internet Protocol Television) channel lineups, and any content genre or category inclusions (e.g., \'All Sports channels, 200+ movies, Kids content library\').' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdContentIncluded rdf:type rdf:Property ;
    rdfs:label 'Hd Content Included' ;
    rdfs:comment 'Indicates whether this package includes HD (High Definition) quality content (True) or is limited to SD (Standard Definition) (False).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Reference code linking this content package to a specific marketing campaign or promotional initiative. Null if not associated with a campaign.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Months' ;
    rdfs:comment 'Minimum subscription commitment period in months required for this package. Null if no minimum commitment applies (month-to-month).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyRecurringCharge rdf:type rdf:Property ;
    rdfs:label 'Monthly Recurring Charge' ;
    rdfs:comment 'Standard monthly recurring charge for this content package in the base currency. Null if pricing is usage-based or bundled without separate charge.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offlineDownloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Download Enabled' ;
    rdfs:comment 'Indicates whether subscribers can download content for offline viewing (True) or streaming-only access (False).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known unique business identifier for the content package used in product catalogs and billing systems (e.g., ENT_PACK_01, SPORTS_MOVIES_BUNDLE).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed business description of the content package, including value proposition, target audience, and key features for marketing and sales enablement.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable marketing name of the content package (e.g., Entertainment Pack, Sports & Movies Bundle, Kids Plus).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the content package: active (available for sale), inactive (temporarily unavailable), pending (awaiting approval), deprecated (phasing out), sunset (end-of-life), pilot (trial phase).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the content package indicating its commercial structure: base_tier (foundational offering), add_on (supplementary to base), premium_bundle (high-value curated bundle), svod_bundle (Subscription Video on Demand bundle), tvod_pack (Transactional Video on Demand pack), channel_pack (linear channel lineup).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlRating rdf:type rdf:Property ;
    rdfs:label 'Parental Control Rating' ;
    rdfs:comment 'Maximum content rating included in this package, used for parental control enforcement. Based on MPAA (Motion Picture Association of America) film ratings or TV Parental Guidelines. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierReference rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Reference' ;
    rdfs:comment 'Reference code linking this content package to a pricing tier or rate plan in the billing system (e.g., TIER_BASIC, TIER_PREMIUM, TIER_FAMILY). Used for commercial offer composition.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Subscriber Eligibility Criteria' ;
    rdfs:comment 'Textual description of eligibility requirements or restrictions for subscribing to this package (e.g., \'Requires base broadband service\', \'Available to postpaid customers only\', \'Geographic restriction applies\').' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSubscriberSegment rdf:type rdf:Property ;
    rdfs:label 'Target Subscriber Segment' ;
    rdfs:comment 'Primary customer segment or persona this package is designed for (e.g., \'Families with children\', \'Sports enthusiasts\', \'Premium entertainment seekers\', \'Budget-conscious viewers\').' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Trial Period Days' ;
    rdfs:comment 'Number of days for which a free or discounted trial is offered for this package. Null if no trial period is available.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uhd4kContentIncluded rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Content Included' ;
    rdfs:comment 'Indicates whether this package includes UHD 4K (Ultra High Definition 4K) quality content (True) or not (False).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodCatalogIncluded rdf:type rdf:Property ;
    rdfs:label 'Vod Catalog Included' ;
    rdfs:comment 'Indicates whether this package includes access to a VOD catalog (True) or not (False).' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Window Id' ;
    rdfs:comment 'Unique identifier for the content rights distribution window record.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adInsertionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Enabled' ;
    rdfs:comment 'Indicates whether dynamic ad insertion is enabled (True) or disabled (False) for this distribution window. Relevant for AVOD and FAST windows where advertising revenue is the monetization model.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adLoadMinutesPerHour rdf:type rdf:Property ;
    rdfs:label 'Ad Load Minutes Per Hour' ;
    rdfs:comment 'The maximum number of minutes of advertising allowed per hour of content playback for ad-supported windows. Defines the ad density cap per studio or regulatory requirements.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audioLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 three-letter language codes for audio tracks available during this window (e.g., \'eng,spa,fra,deu\'). Defines dubbed or original language audio options.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutTerritories rdf:type rdf:Property ;
    rdfs:label 'Blackout Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content must be blocked or blacked out during this window due to conflicting rights, regulatory restrictions, or studio holdback requirements.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this distribution window grants exclusive rights (True) or non-exclusive rights (False) for the specified platform and territory scope. Exclusive windows prevent content availability through other channels during the window period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'The exact date and time when this distribution window expired and content was removed from availability. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Nullable for active or perpetual windows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Days' ;
    rdfs:comment 'The number of days between the end of the previous distribution window and the start of this window, as mandated by studio holdback requirements. Enforces sequential windowing strategy (e.g., 90-day theatrical holdback before PVOD).' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDevicesRegistered rdf:type rdf:Property ;
    rdfs:label 'Max Devices Registered' ;
    rdfs:comment 'The maximum number of devices that can be registered or authorized for content playback under this window. Controls device proliferation per subscriber account.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlineDownloadAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Download Allowed' ;
    rdfs:comment 'Indicates whether subscribers are permitted to download content for offline viewing during this window (True) or if streaming-only access is enforced (False). Reflects studio download rights.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offlineViewingPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Offline Viewing Period Hours' ;
    rdfs:comment 'The number of hours a downloaded asset remains playable offline before requiring re-authentication or license renewal. Nullable if offline downloads are not allowed.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The pricing tier or monetization model applicable during this window: premium (highest price point), standard (regular subscription), basic (entry-level), free (ad-supported or promotional), or promotional (limited-time offer).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Amount' ;
    rdfs:comment 'The per-transaction purchase price for electronic sell-through (EST) or permanent ownership models. Nullable for rental or subscription windows. Represents the amount charged for perpetual access to the content.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityProfiles rdf:type rdf:Property ;
    rdfs:label 'Quality Profiles' ;
    rdfs:comment 'Comma-separated list of video quality profiles or resolutions available during this window (e.g., \'SD,HD,4K,HDR\'). Defines the streaming quality tiers supported by the CDN and licensed by the studio.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Price Amount' ;
    rdfs:comment 'The per-transaction rental price for TVOD or PVOD windows. Nullable for subscription-based or ad-supported windows. Represents the amount charged to the customer for a single viewing period.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtitleLanguages rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 three-letter language codes for subtitle tracks available during this window (e.g., \'eng,spa,fra,deu\'). Defines localization support for accessibility and international markets.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes defining the geographic territories where this rights window is valid (e.g., \'USA,CAN,MEX\' for North America). Defines the geographic distribution rights.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEndDate rdf:type rdf:Property ;
    rdfs:label 'Window End Date' ;
    rdfs:comment 'The date when this distribution window expires and the content is no longer available under these terms. Nullable for perpetual or open-ended windows. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Business-friendly name or label for this distribution window (e.g., \'Premium Early Access\', \'Standard Subscription Window\', \'Free Tier Window\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStartDate rdf:type rdf:Property ;
    rdfs:label 'Window Start Date' ;
    rdfs:comment 'The date when this distribution window becomes active and the content becomes available for exploitation under the defined terms. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle status of the distribution window: draft (being configured), scheduled (future activation), active (currently in effect), expired (past end date), suspended (temporarily disabled), or cancelled (terminated before expiration).' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Type of distribution window defining the exploitation period: theatrical (cinema release), PVOD (Premium Video on Demand), TVOD (Transactional Video on Demand), SVOD (Subscription Video on Demand), AVOD (Advertising-based Video on Demand), FAST (Free Ad-Supported Streaming TV), or linear (traditional broadcast TV). [ENUM-REF-CANDIDATE: theatrical|pvod|tvod|svod|avod|fast|linear — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAssetId rdf:type rdf:Property ;
    rdfs:label 'Content Asset Id' ;
    rdfs:comment 'Reference to the specific content asset to which this DRM policy is applied. Null if policy is template-level.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VodAsset .

ind:allowedTerritories rdf:type rdf:Property ;
    rdfs:label 'Allowed Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is permitted (e.g., USA,CAN,GBR). Empty if restriction_type is block-list.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogOutputAllowed rdf:type rdf:Property ;
    rdfs:label 'Analog Output Allowed' ;
    rdfs:comment 'Indicates whether analog video/audio output is permitted under this DRM policy.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedTerritories rdf:type rdf:Property ;
    rdfs:label 'Blocked Territories' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is prohibited. Empty if restriction_type is allow-list.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnConfigurationRequired rdf:type rdf:Property ;
    rdfs:label 'Cdn Configuration Required' ;
    rdfs:comment 'Specific CDN configuration requirements or restrictions for content delivery under this DRM policy (e.g., token authentication, URL signing).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoEnforcementMethod rdf:type rdf:Property ;
    rdfs:label 'Geo Enforcement Method' ;
    rdfs:comment 'Technical method used to enforce geographic restrictions: geo-IP lookup, GPS location, network-based detection, or hybrid combination.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Enabled' ;
    rdfs:comment 'Indicates whether geographic access control rules are enforced for content availability.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdcpVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Hdcp Version Required' ;
    rdfs:comment 'Minimum HDCP version required for HDMI output (e.g., 2.2 for 4K content, 1.4 for HD content).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdmiOutputAllowed rdf:type rdf:Property ;
    rdfs:label 'Hdmi Output Allowed' ;
    rdfs:comment 'Indicates whether HDMI digital output is permitted under this DRM policy.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'License Duration Seconds' ;
    rdfs:comment 'Duration in seconds that a DRM license remains valid after issuance before requiring renewal.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseRenewalAllowed rdf:type rdf:Property ;
    rdfs:label 'License Renewal Allowed' ;
    rdfs:comment 'Indicates whether DRM licenses can be automatically renewed during active playback sessions.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licensingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Licensing Agreement Reference' ;
    rdfs:comment 'Reference identifier to the content licensing agreement that mandates this DRM policy configuration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDevicesPerAccount rdf:type rdf:Property ;
    rdfs:label 'Max Devices Per Account' ;
    rdfs:comment 'Maximum number of registered devices allowed per subscriber account for content playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOsVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Os Version' ;
    rdfs:comment 'Minimum operating system version required on playback devices to support this DRM policy (e.g., Android 8.0, iOS 12.0).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPlayerVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Player Version' ;
    rdfs:comment 'Minimum version of the video player application required to support this DRM policy configuration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlinePlaybackWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Window Hours' ;
    rdfs:comment 'Number of hours after first playback that offline content remains accessible before license expiration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlineRentalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Offline Rental Duration Hours' ;
    rdfs:comment 'Maximum number of hours that downloaded content remains playable offline before expiration.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyPriority rdf:type rdf:Property ;
    rdfs:label 'Policy Priority' ;
    rdfs:comment 'Numeric priority for conflict resolution when multiple DRM policies could apply to the same content. Higher values take precedence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Level' ;
    rdfs:comment 'Security level of DRM protection: L1 (hardware-backed, highest security), L2 (software with hardware crypto), L3 (software-only, lowest security).' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenCapturePrevention rdf:type rdf:Property ;
    rdfs:label 'Screen Capture Prevention' ;
    rdfs:comment 'Indicates whether screen capture and recording prevention mechanisms are enforced during playback.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vpnProxyBlockingEnabled rdf:type rdf:Property ;
    rdfs:label 'Vpn Proxy Blocking Enabled' ;
    rdfs:comment 'Indicates whether VPN and proxy detection mechanisms are enabled to prevent geographic restriction bypass.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watermarkingRequired rdf:type rdf:Property ;
    rdfs:label 'Watermarking Required' ;
    rdfs:comment 'Indicates whether forensic watermarking must be applied to content streams for piracy tracking.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watermarkingType rdf:type rdf:Property ;
    rdfs:label 'Watermarking Type' ;
    rdfs:comment 'Type of watermarking technology applied: visible overlay, invisible embedded, forensic tracking, or session-based dynamic watermark.' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgScheduleId rdf:type rdf:Property ;
    rdfs:label 'Epg Schedule Id' ;
    rdfs:comment 'Unique identifier for the EPG schedule entry. Primary key for the EPG schedule data product.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpgSchedule .

ind:blackoutGeoBoundaryId rdf:type rdf:Property ;
    rdfs:label 'Blackout Geo Boundary Id' ;
    rdfs:comment 'Foreign key linking to location.geo_boundary. Business justification: Sports blackouts and regional programming restrictions are enforced using precise geographic boundaries. EPG systems use this for real-time content availability decisions. Essential for sports rights ' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeoBoundary .

ind:programmeId rdf:type rdf:Property ;
    rdfs:label 'Programme Id' ;
    rdfs:comment 'Reference to the programme content asset being broadcast in this schedule slot.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Programme .

ind:schedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scheduler Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: EPG scheduling is a manual curation process where content operations staff plan broadcast schedules, resolve channel conflicts, coordinate with broadcasters, and manage last-minute changes. Essential ' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:seriesId rdf:type rdf:Property ;
    rdfs:label 'Series Id' ;
    rdfs:comment 'Unique identifier for the series to which this episode belongs. Used to group all episodes of a series for catch-up TV and series recording features.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:audioFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Format' ;
    rdfs:comment 'The audio encoding format used for the programme broadcast. Indicates the audio quality and surround sound capabilities.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioLanguage rdf:type rdf:Property ;
    rdfs:label 'Audio Language' ;
    rdfs:comment 'Comma-separated list of language codes (ISO 639-1) for available audio tracks. Used for multi-language broadcast support.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast End Timestamp' ;
    rdfs:comment 'The scheduled end date and time when the programme finishes broadcasting on the linear channel. Used for EPG display and catch-up TV availability calculation.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Start Timestamp' ;
    rdfs:comment 'The scheduled start date and time when the programme begins broadcasting on the linear channel. Used for EPG display and catch-up TV availability calculation.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:castList rdf:type rdf:Property ;
    rdfs:label 'Cast List' ;
    rdfs:comment 'Comma-separated list of primary cast members appearing in the programme. Used for content search and discovery features.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catchupAvailable rdf:type rdf:Property ;
    rdfs:label 'Catchup Available' ;
    rdfs:comment 'Flag indicating whether this programme is available for catch-up TV viewing after the live broadcast. True if catch-up is enabled, false otherwise. Used to control on-demand entitlement logic.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catchupEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Catchup End Timestamp' ;
    rdfs:comment 'The date and time when the programme is no longer available for catch-up TV viewing. Determined by content licensing rights and catch-up window policies.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:catchupStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Catchup Start Timestamp' ;
    rdfs:comment 'The date and time when the programme becomes available for catch-up TV viewing. Typically set to the broadcast end timestamp or shortly thereafter.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closedCaptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available' ;
    rdfs:comment 'Flag indicating whether closed captioning is available for this programme. True if closed captions are provided, false otherwise. Required for accessibility compliance.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directorName rdf:type rdf:Property ;
    rdfs:label 'Director Name' ;
    rdfs:comment 'The name of the director of the programme. Applicable primarily to movies and scripted content.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The total duration of the programme in minutes, calculated from broadcast start to end timestamps.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeNumber rdf:type rdf:Property ;
    rdfs:label 'Episode Number' ;
    rdfs:comment 'The episode number within the season. Null for non-episodic content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeTitle rdf:type rdf:Property ;
    rdfs:label 'Episode Title' ;
    rdfs:comment 'The specific episode title for episodic content. Null for non-episodic programmes such as movies or one-off specials.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is4k rdf:type rdf:Property ;
    rdfs:label 'Is 4k' ;
    rdfs:comment 'Flag indicating whether the programme is broadcast in 4K ultra high definition (UHD) quality. True if 4K, false otherwise.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHd rdf:type rdf:Property ;
    rdfs:label 'Is Hd' ;
    rdfs:comment 'Flag indicating whether the programme is broadcast in high definition (HD) quality. True if HD, false if standard definition.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLive rdf:type rdf:Property ;
    rdfs:label 'Is Live' ;
    rdfs:comment 'Flag indicating whether this programme is broadcast live in real-time. True for live events such as sports and news, false for pre-recorded content.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeat rdf:type rdf:Property ;
    rdfs:label 'Is Repeat' ;
    rdfs:comment 'Flag indicating whether this broadcast is a repeat of previously aired content. True if repeat, false if original broadcast.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAirDate rdf:type rdf:Property ;
    rdfs:label 'Original Air Date' ;
    rdfs:comment 'The date when the programme was first broadcast or released. Used to distinguish original broadcasts from repeats.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionYear rdf:type rdf:Property ;
    rdfs:label 'Production Year' ;
    rdfs:comment 'The year in which the programme was originally produced or released.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmeGenre rdf:type rdf:Property ;
    rdfs:label 'Programme Genre' ;
    rdfs:comment 'The primary genre classification of the programme content. Used for content discovery, recommendation engines, and parental control filtering. [ENUM-REF-CANDIDATE: Drama|Comedy|News|Sports|Documentary|Reality|Children|Movies|Music|Lifestyle — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeSubgenre rdf:type rdf:Property ;
    rdfs:label 'Programme Subgenre' ;
    rdfs:comment 'The secondary or more specific genre classification providing additional content categorization granularity.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeTitle rdf:type rdf:Property ;
    rdfs:label 'Programme Title' ;
    rdfs:comment 'The display title of the programme as shown in the EPG guide on set-top boxes (STBs) and over-the-top (OTT) applications.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingAllowed rdf:type rdf:Property ;
    rdfs:label 'Recording Allowed' ;
    rdfs:comment 'Flag indicating whether subscribers are permitted to record this programme using digital video recorder (DVR) functionality. Controlled by content licensing rights and digital rights management (DRM) policies.' ;
    rdfs:domain ind:EpgSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'The current status of this EPG schedule entry in its lifecycle. Scheduled indicates future broadcast, Live indicates currently broadcasting, Completed indicates past broadcast, Cancelled indicates the broadcast was cancelled, Rescheduled indicates the broadcast time was changed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonNumber rdf:type rdf:Property ;
    rdfs:label 'Season Number' ;
    rdfs:comment 'The season number within the series. Null for non-episodic content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitleLanguage rdf:type rdf:Property ;
    rdfs:label 'Subtitle Language' ;
    rdfs:comment 'Comma-separated list of language codes (ISO 639-1) for available subtitle tracks. Used for accessibility and multi-language support.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisLong rdf:type rdf:Property ;
    rdfs:label 'Synopsis Long' ;
    rdfs:comment 'A detailed description of the programme content, typically 200-500 characters, displayed in expanded EPG views and programme detail screens.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisShort rdf:type rdf:Property ;
    rdfs:label 'Synopsis Short' ;
    rdfs:comment 'A brief summary of the programme content, typically 50-100 characters, displayed in compact EPG views on set-top boxes (STBs) and mobile applications.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Display aspect ratio of the channel video stream.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available' ;
    rdfs:comment 'Indicates whether audio description track is available for visually impaired subscribers, meeting accessibility requirements.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Broadcast availability pattern for the channel. 24x7=continuous broadcast, Scheduled=specific time windows, Event-based=live event coverage, On-demand=non-linear access.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Average streaming bitrate of the channel in kilobits per second, determining bandwidth consumption and Quality of Service (QoS) requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcasterName rdf:type rdf:Property ;
    rdfs:label 'Broadcaster Name' ;
    rdfs:comment 'Name of the network or broadcaster that owns and operates the channel (e.g., \'Warner Bros. Discovery\', \'NBCUniversal\').' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catchupRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Catchup Retention Days' ;
    rdfs:comment 'Number of days that previously aired content from this channel is retained and available for catch-up viewing.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catchupTvEnabled rdf:type rdf:Property ;
    rdfs:label 'Catchup Tv Enabled' ;
    rdfs:comment 'Indicates whether catch-up TV functionality is available, allowing subscribers to watch previously aired programs from this channel.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnDistributionCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Code' ;
    rdfs:comment 'Identifier for the Content Delivery Network (CDN) distribution configuration used to deliver this channel to edge locations.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Internal system code or abbreviation for the channel used in provisioning, billing, and operational systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel content, programming focus, and target audience for marketing and subscriber information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Channel Logo Url' ;
    rdfs:comment 'URL path to the channel logo image asset used in Electronic Program Guide (EPG) displays and user interfaces.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the IPTV channel as displayed to subscribers (e.g., \'HBO\', \'ESPN\', \'CNN\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Logical channel number displayed to subscribers in the Electronic Program Guide (EPG) and set-top box interface. Used for channel navigation and lineup ordering.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the channel. Active=available for subscriber viewing, Inactive=temporarily unavailable, Suspended=administratively disabled, Maintenance=undergoing technical work, Retired=permanently removed from catalog.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSourceCode rdf:type rdf:Property ;
    rdfs:label 'Epg Source Code' ;
    rdfs:comment 'Identifier linking this channel to its Electronic Program Guide (EPG) data source for schedule and metadata retrieval.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genre rdf:type rdf:Property ;
    rdfs:label 'Genre' ;
    rdfs:comment 'Primary content genre classification for the channel used for content categorization and subscriber filtering. [ENUM-REF-CANDIDATE: news|sports|entertainment|movies|kids|documentary|music|lifestyle|education|religious|shopping — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic or regional restrictions on channel availability due to licensing rights or regulatory requirements (e.g., \'USA only\', \'EU excluded\').' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdultContent rdf:type rdf:Property ;
    rdfs:label 'Is Adult Content' ;
    rdfs:comment 'Indicates whether this channel contains adult content requiring parental controls and age verification.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHdSimulcast rdf:type rdf:Property ;
    rdfs:label 'Is Hd Simulcast' ;
    rdfs:comment 'Indicates whether this channel has a High Definition (HD) simulcast version available with the same content but higher resolution.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPayPerView rdf:type rdf:Property ;
    rdfs:label 'Is Pay Per View' ;
    rdfs:comment 'Indicates whether this channel operates on a Pay-Per-View (PPV) model requiring per-event or per-program payment.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremium rdf:type rdf:Property ;
    rdfs:label 'Is Premium' ;
    rdfs:comment 'Indicates whether this channel is classified as a premium channel requiring additional subscription fees beyond the base package.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Primary broadcast language of the channel content (e.g., \'English\', \'Spanish\', \'French\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the channel was first made available to subscribers on the IPTV platform.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'Date when the content licensing agreement for this channel expires, after which the channel must be removed from the catalog unless renewed.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Date when the content licensing agreement for this channel becomes effective, determining when the channel can be offered to subscribers.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multicastGroupAddress rdf:type rdf:Property ;
    rdfs:label 'Multicast Group Address' ;
    rdfs:comment 'IP multicast group address used for distributing the channel stream across the IPTV network infrastructure.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalRating rdf:type rdf:Property ;
    rdfs:label 'Parental Rating' ;
    rdfs:comment 'Content rating classification for parental control and age-appropriate filtering. [ENUM-REF-CANDIDATE: G|PG|PG-13|TV-14|TV-MA|R|NC-17 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution quality of the channel stream. SD=Standard Definition, HD=High Definition (720p), FHD=Full High Definition (1080p), 4K=Ultra High Definition (2160p), 8K=8K Ultra High Definition (4320p).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the channel was permanently removed from the IPTV platform and subscriber access was terminated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subGenre rdf:type rdf:Property ;
    rdfs:label 'Sub Genre' ;
    rdfs:comment 'Secondary or more granular genre classification (e.g., \'action movies\', \'live sports\', \'breaking news\').' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeShiftEnabled rdf:type rdf:Property ;
    rdfs:label 'Time Shift Enabled' ;
    rdfs:comment 'Indicates whether time-shifting capabilities (pause, rewind, replay live TV) are enabled for this channel.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unicastStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Unicast Stream Url' ;
    rdfs:comment 'Unicast streaming URL endpoint for on-demand or adaptive bitrate streaming delivery of the channel.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'Video compression codec used for encoding the channel stream.' ;
    rdfs:domain ind:IptvChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRecordingId rdf:type rdf:Property ;
    rdfs:label 'Network Recording Id' ;
    rdfs:comment 'Primary key for network_recording' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Storage Network Equipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.network_equipment. Business justification: Network DVR recordings are stored on specific storage equipment nodes. Operations track equipment-recording assignments for storage capacity management, load balancing, data migration planning, and eq' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:audioLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Audio Language Code' ;
    rdfs:comment 'The primary audio language of the recording, represented as ISO 639-1 two-letter or ISO 639-2 three-letter language code.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status for playback: available (ready for streaming), unavailable (temporarily offline), restricted (entitlement required), or geo-blocked (geographic restriction applied).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnNodeCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Code' ;
    rdfs:comment 'Identifier of the CDN edge node or origin server hosting the recording for optimized content delivery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deletion Timestamp' ;
    rdfs:comment 'The date and time when the recording was deleted, either by subscriber action, system expiry, or storage quota enforcement.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encodingFormat rdf:type rdf:Property ;
    rdfs:label 'Encoding Format' ;
    rdfs:comment 'The video codec and encoding standard used for the recorded content (e.g., H.264, H.265/HEVC, MPEG-4, VP9, AV1).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'The size of the recorded video file in megabytes, used for storage capacity planning and quota management.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPlaybackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Playback Timestamp' ;
    rdfs:comment 'The date and time of the most recent playback session for this recording.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalBroadcastDate rdf:type rdf:Property ;
    rdfs:label 'Original Broadcast Date' ;
    rdfs:comment 'The date when the programme was originally broadcast live, used for catch-up window calculation and content metadata.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:playbackCount rdf:type rdf:Property ;
    rdfs:label 'Playback Count' ;
    rdfs:comment 'The cumulative number of times this recording has been played back by subscribers, used for content popularity analytics.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmeDescription rdf:type rdf:Property ;
    rdfs:label 'Programme Description' ;
    rdfs:comment 'A textual synopsis or description of the recorded programme content, displayed in the EPG and playback interface.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Recording Duration Seconds' ;
    rdfs:comment 'The total duration of the recorded content in seconds, representing the playback length.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recording End Timestamp' ;
    rdfs:comment 'The date and time when the recording capture ended, aligned with the programme broadcast end time.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordingErrorCode rdf:type rdf:Property ;
    rdfs:label 'Recording Error Code' ;
    rdfs:comment 'The error code or fault identifier if the recording failed, used for troubleshooting and operational monitoring.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Recording Error Message' ;
    rdfs:comment 'A human-readable description of the recording failure reason, providing diagnostic context for failed recordings.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Recording Initiated By' ;
    rdfs:comment 'Indicates the initiator of the recording: system (automatic catch-up), subscriber (manual nDVR request), or series_link (automatic series recording rule).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recording Request Timestamp' ;
    rdfs:comment 'The date and time when the recording was requested or scheduled, applicable for subscriber-initiated nDVR recordings.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recording Start Timestamp' ;
    rdfs:comment 'The date and time when the recording capture began, aligned with the programme broadcast start time.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordingStatus rdf:type rdf:Property ;
    rdfs:label 'Recording Status' ;
    rdfs:comment 'Current lifecycle status of the recording: scheduled (pending), in progress (actively recording), completed (available for playback), failed (recording error), expired (retention period ended), or deleted (removed by user or system).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingType rdf:type rdf:Property ;
    rdfs:label 'Recording Type' ;
    rdfs:comment 'Classification of the recording: catch-up TV (network-initiated for all subscribers), subscriber-initiated nDVR (on-demand cloud recording), or series-link nDVR (automatic series recording).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date when the recording will expire and be automatically deleted, based on catch-up window or nDVR storage quota policies.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seriesLinkGroupCode rdf:type rdf:Property ;
    rdfs:label 'Series Link Group Code' ;
    rdfs:comment 'Identifier grouping all recordings that belong to the same series-link subscription, enabling series-based management and navigation.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationPath rdf:type rdf:Property ;
    rdfs:label 'Storage Location Path' ;
    rdfs:comment 'The CDN origin server path or cloud storage URI where the recorded video file is stored for streaming delivery.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageQuotaConsumedMb rdf:type rdf:Property ;
    rdfs:label 'Storage Quota Consumed Mb' ;
    rdfs:comment 'The amount of subscriber nDVR storage quota consumed by this recording in megabytes, used for quota enforcement and billing.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtitleAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Subtitle Available Flag' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are available for this recording (True = available, False = not available).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thumbnailImageUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Image Url' ;
    rdfs:comment 'The URL or CDN path to the thumbnail image or poster art for the recorded programme, used in user interface display.' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoResolution rdf:type rdf:Property ;
    rdfs:label 'Video Resolution' ;
    rdfs:comment 'The video resolution quality of the recording: SD (standard definition), HD (720p), FHD (1080p full HD), or UHD_4K (2160p ultra HD).' ;
    rdfs:domain ind:NetworkRecording ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Ott Entitlement Id' ;
    rdfs:comment 'Unique identifier for the OTT platform entitlement record. Primary key for this product.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:provisioningOrderId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Order Id' ;
    rdfs:comment 'Reference to the service order or provisioning request that initiated this OTT entitlement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProvisioningOrder .

ind:accessToken rdf:type rdf:Property ;
    rdfs:label 'Access Token' ;
    rdfs:comment 'The authentication token, credential, or API key used to grant the subscriber access to the OTT platform. Highly sensitive and encrypted at rest.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Billing Integration Type' ;
    rdfs:comment 'Defines how the OTT subscription cost is integrated into the telecommunications billing system (e.g., bundled into telecom bill, pass-through billing, promotional free access).' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRegion rdf:type rdf:Property ;
    rdfs:label 'Content Region' ;
    rdfs:comment 'The geographic region or country code for which this OTT entitlement grants content access, based on licensing and geo-blocking rules (ISO 3166-1 alpha-3).' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'The business reason for deactivating or terminating this OTT entitlement (e.g., customer request, non-payment, contract expiry, service migration).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'The timestamp when this OTT entitlement was deactivated, suspended, or terminated. Null if the entitlement is still active.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementEndDate rdf:type rdf:Property ;
    rdfs:label 'Entitlement End Date' ;
    rdfs:comment 'The date on which this OTT entitlement expires or is scheduled to terminate. Null indicates an open-ended or indefinite entitlement.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entitlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Reference Number' ;
    rdfs:comment 'Business-facing unique reference number or code for this OTT entitlement, used for customer service and billing inquiries.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStartDate rdf:type rdf:Property ;
    rdfs:label 'Entitlement Start Date' ;
    rdfs:comment 'The date on which this OTT entitlement becomes effective and the subscriber gains access to the OTT platform.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalPlatformCode rdf:type rdf:Property ;
    rdfs:label 'External Platform Code' ;
    rdfs:comment 'The unique identifier assigned by the OTT platform to this entitlement or subscription. Used for reconciliation and support escalation.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The timestamp of the last successful synchronization or status check with the OTT platform API to verify entitlement status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUsageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Usage Timestamp' ;
    rdfs:comment 'The timestamp of the last recorded usage or access event for this OTT entitlement, based on platform activity logs.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled' ;
    rdfs:comment 'Indicates whether parental control or content filtering is enabled for this OTT entitlement. True if enabled, False otherwise.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'The promotional or discount code applied to this OTT entitlement, if any. Used for tracking marketing campaigns and partner offers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningErrorCode rdf:type rdf:Property ;
    rdfs:label 'Provisioning Error Code' ;
    rdfs:comment 'The error code returned by the OTT platform or provisioning system if the entitlement provisioning failed. Null if provisioning was successful.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Provisioning Error Message' ;
    rdfs:comment 'The detailed error message or description associated with the provisioning error code. Used for troubleshooting and support.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningMethod rdf:type rdf:Property ;
    rdfs:label 'Provisioning Method' ;
    rdfs:comment 'The technical method used to provision this OTT entitlement to the subscriber account (e.g., SSO token, API credential, bundled billing integration).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Provisioning Status' ;
    rdfs:comment 'Current lifecycle status of the OTT entitlement provisioning. Indicates whether the entitlement is active, pending activation, suspended, or terminated. [ENUM-REF-CANDIDATE: pending|active|suspended|expired|cancelled|failed|deprovisioned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'The tier or level of service within the OTT platform that this entitlement grants (e.g., Basic, Premium, Family, 4K Ultra HD).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Indicates the current synchronization state between the telecommunications BSS and the OTT platform. Used to detect provisioning discrepancies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Timestamp' ;
    rdfs:comment 'The timestamp at which the access token expires and must be refreshed or re-provisioned.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'The date on which the trial period for this OTT entitlement ends. Null if not applicable or if the entitlement is not a trial.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Period Flag' ;
    rdfs:comment 'Indicates whether this OTT entitlement is currently in a trial or promotional free-access period. True if in trial, False otherwise.' ;
    rdfs:domain ind:OttEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Platform Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: OTT platform partnerships require dedicated telco relationship managers to coordinate technical integration, monitor SLA compliance, resolve escalations, and manage commercial terms. Essential for par' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analyticsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Analytics Integration Enabled' ;
    rdfs:comment 'Indicates whether subscriber usage and viewing analytics from the OTT platform are integrated into the telco\'s analytics systems.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for the OTT platform\'s API endpoint used for provisioning, authentication, and entitlement management.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version number of the OTT platform API currently integrated (e.g., v2.1, 3.0.5).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioFormats rdf:type rdf:Property ;
    rdfs:label 'Audio Formats' ;
    rdfs:comment 'Comma-separated list of audio formats supported (e.g., Stereo, Dolby Digital 5.1, Dolby Atmos, DTS:X).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Authentication protocol used for API integration. OAUTH2=OAuth 2.0, SAML=Security Assertion Markup Language, JWT=JSON Web Token, API_KEY=API key authentication, BASIC_AUTH=Basic authentication, CUSTOM=Custom authentication mechanism.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Billing Integration Enabled' ;
    rdfs:comment 'Indicates whether the OTT platform subscription charges are integrated into the telco\'s billing system for bundled billing.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'Name of the Content Delivery Network provider used by the OTT platform for content streaming (e.g., Akamai, Cloudflare, AWS CloudFront, Fastly).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCatalogScope rdf:type rdf:Property ;
    rdfs:label 'Content Catalog Scope' ;
    rdfs:comment 'Description of the content catalog available on the platform (e.g., Movies and TV Series, Live Sports, News and Documentaries, Kids Content, Original Productions).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGenreCategories rdf:type rdf:Property ;
    rdfs:label 'Content Genre Categories' ;
    rdfs:comment 'Comma-separated list of primary content genres available on the platform (e.g., Action, Drama, Comedy, Documentary, Sports, Kids, Reality, Sci-Fi).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLanguageSupport rdf:type rdf:Property ;
    rdfs:label 'Content Language Support' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes for audio and subtitle support (e.g., en, es, fr, de, pt, ja, ko).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the commercial contract or partnership agreement governing the OTT platform integration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the partnership contract with the OTT platform provider.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deepLinkSupport rdf:type rdf:Property ;
    rdfs:label 'Deep Link Support' ;
    rdfs:comment 'Indicates whether the platform supports deep linking to specific content from the telco\'s portal or app.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprovisioningMode rdf:type rdf:Property ;
    rdfs:label 'Deprovisioning Mode' ;
    rdfs:comment 'Method used for deprovisioning subscriber entitlements when subscription ends. AUTOMATIC=Real-time API deprovisioning, MANUAL=Manual deactivation, SEMI_AUTOMATIC=Requires approval, BATCH=Batch file processing.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3-letter country codes where the platform is available through the telco partnership (e.g., USA, CAN, GBR, DEU, FRA).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupport rdf:type rdf:Property ;
    rdfs:label 'Hdr Support' ;
    rdfs:comment 'Indicates whether the platform supports High Dynamic Range video content (HDR10, Dolby Vision, HDR10+).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationMethod rdf:type rdf:Property ;
    rdfs:label 'Integration Method' ;
    rdfs:comment 'Technical integration approach used to connect the OTT platform with the telco\'s systems. DIRECT_API=Direct API integration, SSO_FEDERATION=Single Sign-On federation, BUNDLED_BILLING=Billing integration only, DEEP_LINK=Deep linking to platform app, WHITE_LABEL=White-labeled platform instance, SDK_INTEGRATION=Software Development Kit integration.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Marketing description of the OTT platform for use in customer-facing communications and promotional materials.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVideoQuality rdf:type rdf:Property ;
    rdfs:label 'Max Video Quality' ;
    rdfs:comment 'Highest video resolution quality supported by the platform. SD=Standard Definition (480p), HD=High Definition (720p), FULL_HD=Full HD (1080p), 4K_UHD=4K Ultra HD (2160p), 8K=8K resolution.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlAvailable rdf:type rdf:Property ;
    rdfs:label 'Parental Control Available' ;
    rdfs:comment 'Indicates whether the platform provides parental control features for content restriction.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current status of the partnership agreement between the telco and the OTT platform provider. ACTIVE=Partnership is live and operational, PENDING=Agreement signed but not yet activated, SUSPENDED=Temporarily suspended, TERMINATED=Partnership ended, NEGOTIATION=Under negotiation.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Unique business identifier code for the OTT platform (e.g., NETFLIX, DISNEY_PLUS, HBO_MAX, APPLE_TV_PLUS).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Platform Launch Date' ;
    rdfs:comment 'Date when the OTT platform was first launched in the market by the provider.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Platform Logo Url' ;
    rdfs:comment 'URL to the official logo image of the OTT platform for display in the telco\'s customer portal and marketing materials.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Full commercial name of the OTT streaming platform as presented to customers (e.g., Netflix, Disney+, HBO Max, Apple TV+, Paramount+).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Business model classification of the OTT platform. SVOD=Subscription Video on Demand, AVOD=Advertising Video on Demand, TVOD=Transactional Video on Demand, FAST=Free Ad-Supported Streaming TV, HYBRID=Multiple models, PREMIUM=Premium subscription tier.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Platform Website Url' ;
    rdfs:comment 'Official website URL of the OTT platform for customer information and support.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Legal name of the company or organization that owns and operates the OTT platform (e.g., Netflix Inc., The Walt Disney Company, Warner Bros. Discovery).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningMode rdf:type rdf:Property ;
    rdfs:label 'Provisioning Mode' ;
    rdfs:comment 'Method used for provisioning subscriber entitlements on the OTT platform. AUTOMATIC=Real-time API provisioning, MANUAL=Manual activation, SEMI_AUTOMATIC=Requires approval, BATCH=Batch file processing.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoEnabled rdf:type rdf:Property ;
    rdfs:label 'Sso Enabled' ;
    rdfs:comment 'Indicates whether Single Sign-On is enabled, allowing telco subscribers to access the OTT platform using their telco credentials.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportContactEmail rdf:type rdf:Property ;
    rdfs:label 'Support Contact Email' ;
    rdfs:comment 'Email address for technical support and operational inquiries related to the OTT platform integration.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactPhone rdf:type rdf:Property ;
    rdfs:label 'Support Contact Phone' ;
    rdfs:comment 'Phone number for technical support and operational inquiries related to the OTT platform integration.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDevices rdf:type rdf:Property ;
    rdfs:label 'Supported Devices' ;
    rdfs:comment 'Comma-separated list of device types supported by the OTT platform (e.g., Smart TV, Mobile, Tablet, STB, Web Browser, Gaming Console, Streaming Stick).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedOsVersions rdf:type rdf:Property ;
    rdfs:label 'Supported Os Versions' ;
    rdfs:comment 'Comma-separated list of operating system versions supported (e.g., iOS 14+, Android 9+, tvOS 13+, webOS 4.0+).' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telcoLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Telco Launch Date' ;
    rdfs:comment 'Date when the OTT platform was first made available to the telco\'s subscribers through the partnership.' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Externally-known unique business identifier for the VOD asset, used for catalog management and content distribution. Typically assigned by content management system or studio.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:castMembers rdf:type rdf:Property ;
    rdfs:label 'Cast Members' ;
    rdfs:comment 'Comma-separated list of principal actors and performers featured in the content. Used for search, discovery, and personalization.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProfile rdf:type rdf:Property ;
    rdfs:label 'Cdn Profile' ;
    rdfs:comment 'Identifier for the CDN configuration or edge caching profile used to deliver this asset. Impacts streaming performance and Quality of Service (QoS).' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdvisories rdf:type rdf:Property ;
    rdfs:label 'Content Advisories' ;
    rdfs:comment 'Comma-separated list of content warning descriptors (e.g., violence, language, nudity, drug use) for subscriber awareness and parental control filtering.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the VOD asset by content format and structure. Determines presentation, navigation, and entitlement rules.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'URL or path to the actual video content file or streaming manifest for playback. Confidential as it may expose CDN structure and DRM endpoints.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:director rdf:type rdf:Property ;
    rdfs:label 'Director' ;
    rdfs:comment 'Name of the primary director or creator of the content. Used for content discovery and recommendation algorithms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmPolicy rdf:type rdf:Property ;
    rdfs:label 'Drm Policy' ;
    rdfs:comment 'DRM technology applied to protect the content from unauthorized access and piracy. Determines compatible playback devices and platforms.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingProfile rdf:type rdf:Property ;
    rdfs:label 'Encoding Profile' ;
    rdfs:comment 'Video encoding format and bitrate profile (e.g., H.264, H.265/HEVC, VP9, AV1) used for content delivery. Determines bandwidth requirements and device compatibility.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRights rdf:type rdf:Property ;
    rdfs:label 'Licensing Rights' ;
    rdfs:comment 'Type of distribution rights held by the telecommunications provider for this content asset. Determines exclusivity and sublicensing permissions.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Business model for subscriber access to this content. Subscription=included in package, Transactional=pay-per-view/rental, Ad_supported=free with ads, Free=no charge.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTitle rdf:type rdf:Property ;
    rdfs:label 'Original Title' ;
    rdfs:comment 'The original title of the content in its native language, if different from the localized display title.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Platform Availability Date' ;
    rdfs:comment 'Date the asset became available on this telecommunications platform for subscriber access. May differ from original release date due to licensing windows.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posterArtUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Art Url' ;
    rdfs:comment 'URL to the primary poster or cover art image for the content. Used in user interfaces, catalogs, and promotional materials.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:producer rdf:type rdf:Property ;
    rdfs:label 'Producer' ;
    rdfs:comment 'Name of the primary producer or executive producer of the content.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Price' ;
    rdfs:comment 'Price charged for permanent purchase/download of this asset. Null for rental-only, subscription, or free content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Exact date the content was originally released to the public (theatrical, broadcast, or digital premiere).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseYear rdf:type rdf:Property ;
    rdfs:label 'Release Year' ;
    rdfs:comment 'Year the content was originally released or premiered. Used for content discovery, filtering, and catalog organization.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentalPrice rdf:type rdf:Property ;
    rdfs:label 'Rental Price' ;
    rdfs:comment 'Price charged for transactional rental access to this asset. Null for subscription or free content. Currency determined by billing system configuration.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seriesCode rdf:type rdf:Property ;
    rdfs:label 'Series Code' ;
    rdfs:comment 'Foreign key reference to the parent TV series if this asset is an episode. Null for standalone movies or non-episodic content.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioName rdf:type rdf:Property ;
    rdfs:label 'Studio Name' ;
    rdfs:comment 'Name of the production studio, distributor, or content provider that owns or licenses the content rights.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to the thumbnail image for display in content grids, carousels, and search results.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'The primary display title of the VOD content asset as presented to subscribers in the content catalog and user interface.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUrl rdf:type rdf:Property ;
    rdfs:label 'Trailer Url' ;
    rdfs:comment 'URL to the promotional trailer or preview clip for the content. Used for marketing and subscriber engagement.' ;
    rdfs:domain ind:VodAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodCatalogId rdf:type rdf:Property ;
    rdfs:label 'Vod Catalog Id' ;
    rdfs:comment 'Unique identifier for the VOD catalog. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VodCatalog .

ind:curatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Curator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: VOD catalog curation (featured content selection, promotional placement, windowing strategy, editorial merchandising) is managed by content operations staff. Critical for accountability in content dis' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:catalogCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Code' ;
    rdfs:comment 'Business identifier code for the catalog used in external systems and customer-facing interfaces.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogDescription rdf:type rdf:Property ;
    rdfs:label 'Catalog Description' ;
    rdfs:comment 'Detailed description of the catalog content, target audience, and value proposition.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogName rdf:type rdf:Property ;
    rdfs:label 'Catalog Name' ;
    rdfs:comment 'Human-readable name of the VOD catalog (e.g., Premium VOD Library, Kids Catalog, Free-to-View Catalog).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogNotes rdf:type rdf:Property ;
    rdfs:label 'Catalog Notes' ;
    rdfs:comment 'Free-form notes or comments about the catalog for internal operational use, including special handling instructions or business context.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogOwner rdf:type rdf:Property ;
    rdfs:label 'Catalog Owner' ;
    rdfs:comment 'Business unit, department, or content partner responsible for managing and curating this catalog.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogPriority rdf:type rdf:Property ;
    rdfs:label 'Catalog Priority' ;
    rdfs:comment 'Display priority or ranking of this catalog relative to other catalogs in the same package or tier. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catalogStatus rdf:type rdf:Property ;
    rdfs:label 'Catalog Status' ;
    rdfs:comment 'Current lifecycle status of the catalog: draft (under construction), active (available to subscribers), suspended (temporarily unavailable), retired (no longer offered), archived (historical record).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogType rdf:type rdf:Property ;
    rdfs:label 'Catalog Type' ;
    rdfs:comment 'Business model type of the catalog: SVOD (Subscription Video on Demand), AVOD (Advertising Video on Demand), TVOD (Transactional Video on Demand), FAST (Free Ad-Supported Streaming TV), EST (Electronic Sell-Through), FVOD (Free Video on Demand).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogVersion rdf:type rdf:Property ;
    rdfs:label 'Catalog Version' ;
    rdfs:comment 'Version identifier for the catalog configuration, incremented when significant changes are made to catalog composition or rules.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDistributionProfile rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Profile' ;
    rdfs:comment 'CDN distribution profile or configuration identifier used for delivering catalog assets to end users.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Download Enabled' ;
    rdfs:comment 'Indicates whether offline download of catalog assets is permitted for subscribers.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCatalogCode rdf:type rdf:Property ;
    rdfs:label 'External Catalog Code' ;
    rdfs:comment 'External system identifier for this catalog used in upstream content management or partner systems for integration and reconciliation.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredAssetCount rdf:type rdf:Property ;
    rdfs:label 'Featured Asset Count' ;
    rdfs:comment 'Number of assets marked as featured within this catalog for promotional display.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Enabled' ;
    rdfs:comment 'Indicates whether geographic IP-based restrictions are enforced for catalog access based on licensing rights.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether this catalog contains exclusive content not available in other catalogs or to other subscriber tiers.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketRegionCode rdf:type rdf:Property ;
    rdfs:label 'Market Region Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/region code indicating the geographic market where this catalog is available (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDownloadCount rdf:type rdf:Property ;
    rdfs:label 'Max Download Count' ;
    rdfs:comment 'Maximum number of assets that can be downloaded simultaneously per subscriber account. Nullable if download is not enabled or unlimited.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metadataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Metadata Source System' ;
    rdfs:comment 'Name of the source system or content management platform from which catalog metadata originates (e.g., Netcracker OSS/BSS Suite Product Catalog).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'End date of the promotional period if this is a promotional catalog. Nullable for non-promotional catalogs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotional Start Date' ;
    rdfs:comment 'Start date of the promotional period if this is a promotional catalog. Nullable for non-promotional catalogs.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retired Timestamp' ;
    rdfs:comment 'Timestamp when this catalog was retired from active service. Nullable for active catalogs.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriberTier rdf:type rdf:Property ;
    rdfs:label 'Subscriber Tier' ;
    rdfs:comment 'Target subscriber tier or service level that has access to this catalog (e.g., basic, standard, premium, platinum, enterprise).' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssetCount rdf:type rdf:Property ;
    rdfs:label 'Total Asset Count' ;
    rdfs:comment 'Total number of VOD assets currently included in this catalog. Updated as assets are added or removed.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowingStrategy rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy' ;
    rdfs:comment 'Content windowing strategy classification indicating the release window tier (e.g., theatrical, premium, standard, library, archive) that determines asset lifecycle movement between catalogs.' ;
    rdfs:domain ind:VodCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodRentalId rdf:type rdf:Property ;
    rdfs:label 'Vod Rental Id' ;
    rdfs:comment 'Unique identifier for the VOD rental or electronic sell-through transaction.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmLicenseId rdf:type rdf:Property ;
    rdfs:label 'Drm License Id' ;
    rdfs:comment 'Unique DRM license identifier issued for this transaction, used to authorize content decryption and playback on authorized devices.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the parent order if the VOD transaction was part of a larger service order or bundle activation. Null for standalone transactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Reference to the marketing campaign that drove the VOD transaction, used for campaign performance tracking and attribution analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentQuality rdf:type rdf:Property ;
    rdfs:label 'Content Quality' ;
    rdfs:comment 'Video quality tier purchased or rented by the subscriber (SD, HD, Full HD, 4K, 8K).' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Download Permitted Flag' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to download the VOD content for offline viewing (true) or streaming-only access (false).' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPlaybackTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Playback Timestamp' ;
    rdfs:comment 'Date and time when the subscriber first started playback of the rented or purchased VOD content. Null if content not yet viewed.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlPinVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin Verified Flag' ;
    rdfs:comment 'Indicates whether parental control PIN was successfully verified before allowing the transaction for age-restricted content (true) or not required (false).' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount refunded to the subscriber if the transaction was reversed or disputed. Null if no refund issued.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Business reason for the refund (e.g., technical issue, customer dissatisfaction, billing error). Null if no refund issued.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed. Null if no refund issued.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Hours' ;
    rdfs:comment 'Duration of the rental viewing window in hours (e.g., 24, 48, 72 hours). Null for purchase transactions.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentalWindowExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rental Window Expiry Timestamp' ;
    rdfs:comment 'Date and time when the rental viewing window expires and access to the content is revoked. Null for purchase transactions.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentalWindowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rental Window Start Timestamp' ;
    rdfs:comment 'Date and time when the rental viewing window begins, typically when the subscriber first starts playback.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the VOD transaction was initiated (web portal, mobile app, STB interface, IVR, call center, retail store, partner portal). [ENUM-REF-CANDIDATE: web|mobile_app|stb|ivr|call_center|retail_store|partner_portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlaybackCount rdf:type rdf:Property ;
    rdfs:label 'Total Playback Count' ;
    rdfs:comment 'Total number of times the subscriber has initiated playback of the VOD content during the rental window or after purchase.' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally visible unique transaction number for the VOD rental or purchase event, used for customer service and billing inquiries.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the VOD rental or purchase transaction was initiated by the subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Type of VOD transaction: rental (time-limited access), purchase (permanent ownership), or EST (electronic sell-through).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewingDeviceType rdf:type rdf:Property ;
    rdfs:label 'Viewing Device Type' ;
    rdfs:comment 'Type of device used by the subscriber to initiate the VOD rental or purchase (STB, smart TV, mobile, tablet, web browser, etc.). [ENUM-REF-CANDIDATE: stb|smart_tv|mobile|tablet|web|gaming_console|streaming_device — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VodRental ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAddressId rdf:type rdf:Property ;
    rdfs:label 'Location Address Id' ;
    rdfs:comment 'Foreign key linking to location.location_address. Business justification: Customer addresses must reference authoritative location addresses for geocoding validation, serviceability checks, coverage tier assignment, and network planning. Location.location_address is the mas' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationAddress .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this address record is currently active and in use. True if active, false if inactive or deprecated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: service address (where service is delivered), billing address (where invoices are sent), installation address (where equipment is installed), correspondence address (general mail), shipping address (equipment delivery), or legal address (registered business location).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadbandCoverageTier rdf:type rdf:Property ;
    rdfs:label 'Broadband Coverage Tier' ;
    rdfs:comment 'Highest tier of broadband technology available at this address: fiber (FTTH/GPON), cable (DOCSIS), DSL (ADSL/VDSL), fixed wireless (LTE/5G), satellite, or no coverage.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name where the address is located.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellingType rdf:type rdf:Property ;
    rdfs:label 'Dwelling Type' ;
    rdfs:comment 'Classification of the building or property type at this address: single family home, multi-family building, apartment, condominium, townhouse, commercial property, industrial facility, or mixed-use development. [ENUM-REF-CANDIDATE: single_family|multi_family|apartment|condo|townhouse|commercial|industrial|mixed_use — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Ftth Serviceable Flag' ;
    rdfs:comment 'Indicates whether this address is within the FTTH network footprint and can receive fiber-optic broadband service. True if fiber service is available, false otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gponServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Gpon Serviceable Flag' ;
    rdfs:comment 'Indicates whether this address is within the GPON network coverage area and can receive gigabit passive optical network service. True if GPON service is available, false otherwise.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash of the complete address components used for deduplication, matching, and privacy-preserving analytics without exposing actual address details.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when this address was last verified or validated for accuracy, either through automated validation service or manual confirmation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and street type (e.g., 123 Main Street).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for apartment number, suite, unit, building, floor, or other location details within the primary address.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lteCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Lte Coverage Flag' ;
    rdfs:comment 'Indicates whether this address has LTE (4G) wireless network coverage. True if LTE service is available, false otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDownloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Download Speed Mbps' ;
    rdfs:comment 'Maximum theoretical download speed in megabits per second available at this address based on network infrastructure and technology tier.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumUploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Upload Speed Mbps' ;
    rdfs:comment 'Maximum theoretical upload speed in megabits per second available at this address based on network infrastructure and technology tier.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mduFlag rdf:type rdf:Property ;
    rdfs:label 'Mdu Flag' ;
    rdfs:comment 'Indicates whether this address is part of a multi-dwelling unit property (apartment building, condo complex, etc.) requiring special provisioning considerations. True if MDU, false if single-unit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:n5gCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'N5g Coverage Flag' ;
    rdfs:comment 'Indicates whether this address has 5G New Radio wireless network coverage. True if 5G service is available, false otherwise.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal code, ZIP code, or postcode for mail delivery routing. Format varies by country (e.g., 12345, 12345-6789, A1A 1A1).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary or default address for the associated customer account. True if primary, false if secondary or alternate address.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servingCentralOffice rdf:type rdf:Property ;
    rdfs:label 'Serving Central Office' ;
    rdfs:comment 'Identifier or name of the telecommunications central office, wire center, or exchange that serves this address. Used for network planning and service provisioning.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'Fully standardized and formatted address string as returned by the validation service, following postal authority standards. Used for mail delivery and system integration.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region where the address is located. Use standard postal abbreviations (e.g., CA for California, ON for Ontario).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Number of individual units or dwellings within the property at this address. Relevant for MDU properties and bulk service opportunities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the validation service or system used to verify the address (e.g., USPS CASS, Google Maps API, Loqate, Melissa Data, internal GIS system).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address: validated (confirmed accurate by validation service), unvalidated (not yet checked), invalid (failed validation), pending (validation in progress), corrected (modified during validation), or partial (some components validated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerInteractionId rdf:type rdf:Property ;
    rdfs:label 'Customer Interaction Id' ;
    rdfs:comment 'Reference to the customer interaction record that initiated or is linked to this case.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerInteraction .

ind:deviceModelId rdf:type rdf:Property ;
    rdfs:label 'Device Model Id' ;
    rdfs:comment 'Foreign key linking to product.device_model. Business justification: Cases frequently involve specific device models (troubleshooting, warranty claims, defects). Essential for technical support, warranty processing, and device quality tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceModel .

ind:parentCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Id' ;
    rdfs:comment 'Reference to a parent case if this case is a child or related case, enabling case hierarchy tracking.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:servicePremiseId rdf:type rdf:Property ;
    rdfs:label 'Service Premise Id' ;
    rdfs:comment 'Foreign key linking to location.premise. Business justification: Cases frequently involve premise-specific issues (installation failures, coverage gaps, equipment problems) requiring premise-level tracking for root cause analysis, field service dispatch, and premis' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date and time when the case was resolved and solution was provided to the customer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Secondary classification providing additional context for the case type. [ENUM-REF-CANDIDATE: network_coverage|billing_error|service_activation|device_issue|contract_inquiry|data_usage|roaming|porting|upgrade_request|cancellation_request|loyalty_reward|win_back|contract_renewal — promote to reference product]' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Detailed description of the customer issue, complaint, or request as initially reported.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the case by business purpose: complaint (service quality issue), billing_dispute (invoice or charge dispute), technical_fault (network or service technical issue), mnp_request (Mobile Number Portability request), general_inquiry (information request), save_offer (retention intervention).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date and time when the case was officially closed and marked as complete.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the support team attempted to contact the customer regarding this case.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Extension Months' ;
    rdfs:comment 'For retention cases, the number of months the customer contract was extended as part of the retention offer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date and time when the case was first created in the system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Customer satisfaction score provided by the customer after case resolution, typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fcrFlag rdf:type rdf:Property ;
    rdfs:label 'Fcr Flag' ;
    rdfs:comment 'Indicates whether the case was resolved on the first contact without requiring follow-up. True if resolved on first contact, False otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedDate rdf:type rdf:Property ;
    rdfs:label 'Modified Date' ;
    rdfs:comment 'Date and time when the case record was last modified or updated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Flag' ;
    rdfs:comment 'For retention cases, indicates whether the customer accepted the retention offer. True if accepted, False if declined.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'For retention cases, the code or identifier of the retention offer presented to the customer (discount, upgrade, loyalty reward, contract extension).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerValue rdf:type rdf:Property ;
    rdfs:label 'Offer Value' ;
    rdfs:comment 'For retention cases, the monetary value of the retention offer presented to the customer (discount amount, credit value, waived fees).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Source or trigger that created the case: customer_initiated (customer contacted support), proactive_outreach (company reached out), system_generated (automated alert), escalation (from another case), third_party (partner or regulator).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times the case has been reopened after initial closure, indicating unresolved issues or customer dissatisfaction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionCost rdf:type rdf:Property ;
    rdfs:label 'Retention Cost' ;
    rdfs:comment 'For retention cases, the total cost to the business of the retention intervention (discount value, credits, waived fees, incentive costs).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionOutcome rdf:type rdf:Property ;
    rdfs:label 'Retention Outcome' ;
    rdfs:comment 'For retention cases, the final outcome of the retention intervention: retained (customer stayed), churned (customer left), pending (decision not yet made), no_action (customer did not require intervention).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Reason' ;
    rdfs:comment 'For retention cases, the business reason that triggered the save intervention: churn_intent (customer expressed intent to leave), contract_expiry (contract ending soon), competitor_offer (customer received competitive offer), high_risk_score (predictive churn model), usage_decline (significant usage drop), payment_issue (payment problems).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the issue after investigation and resolution. [ENUM-REF-CANDIDATE: network_outage|billing_system_error|provisioning_failure|user_error|device_defect|third_party_issue|process_gap|system_bug|configuration_error|capacity_issue — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saveDeskQueue rdf:type rdf:Property ;
    rdfs:label 'Save Desk Queue' ;
    rdfs:comment 'For retention cases, the specific save desk queue or team that handled the retention intervention (high_value, standard, win_back, contract_renewal).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Date' ;
    rdfs:comment 'Target date and time by which the case must be resolved according to the applicable SLA policy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary or title of the case describing the primary issue or request.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Resolution Hours' ;
    rdfs:comment 'Total elapsed time in hours from case creation to resolution, used for SLA tracking and performance measurement.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique identifier for the consent record. Primary key.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Id' ;
    rdfs:comment 'Reference to a previous consent record that this record supersedes or amends. Used to track consent history and version chains. Null for initial consent records.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained: explicit (affirmative action required), implicit (inferred from behavior), opt_in (customer actively chose to consent), opt_out (customer must actively decline), pre_checked (checkbox pre-selected), or unchecked (checkbox not pre-selected). Critical for GDPR compliance as pre-checked boxes do not constitute valid consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentText rdf:type rdf:Property ;
    rdfs:label 'Consent Text' ;
    rdfs:comment 'The exact text of the consent statement or privacy notice that was presented to the customer at the time of consent capture. Stored for audit and compliance verification. Required to demonstrate informed consent under GDPR Article 13.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategory rdf:type rdf:Property ;
    rdfs:label 'Data Category' ;
    rdfs:comment 'The specific category or categories of personal data covered by this consent (e.g., contact information, usage data, location data, payment information, call detail records). Free-text field to accommodate diverse data classification schemes across jurisdictions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'The unique identifier of the device (e.g., mobile device ID, browser fingerprint, IMEI) from which the consent was captured. Used for audit trails and fraud prevention. Considered PII under GDPR and CCPA.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotDisturbSchedule rdf:type rdf:Property ;
    rdfs:label 'Do Not Disturb Schedule' ;
    rdfs:comment 'Specific times or days when the customer does not wish to be contacted (e.g., weekends, evenings, holidays). Free-text to accommodate complex schedules. Supports FCC Telephone Consumer Protection Act (TCPA) compliance and customer experience optimization.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicBillOptIn rdf:type rdf:Property ;
    rdfs:label 'Electronic Bill Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive electronic bills via email or online portal. True = e-bill requested, False = paper bill only. Supports digital transformation and cost reduction initiatives.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocation rdf:type rdf:Property ;
    rdfs:label 'Geolocation' ;
    rdfs:comment 'The geographic coordinates (latitude, longitude) or general location from which the consent was captured. Used to verify jurisdiction and support location-based consent requirements. May be considered PII under GDPR.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The customer\'s preferred language for communications, using ISO 639-2 three-letter language codes: ENG (English), SPA (Spanish), FRA (French), GER (German), CHI (Chinese), JPN (Japanese), POR (Portuguese), ARA (Arabic). Supports multilingual customer experience and regulatory requirements for language access. [ENUM-REF-CANDIDATE: ENG|SPA|FRA|GER|CHI|JPN|POR|ARA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEmailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via email. True = opted in, False = opted out. Required for CAN-SPAM Act and GDPR compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Mail Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via postal mail. True = opted in, False = opted out.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPhoneOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Phone Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via phone call. True = opted in, False = opted out. Required for TCPA and FCC telemarketing rules compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSmsOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Sms Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via SMS text message. True = opted in, False = opted out. Required for TCPA compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paperBillOptIn rdf:type rdf:Property ;
    rdfs:label 'Paper Bill Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive paper bills via postal mail. True = paper bill requested, False = electronic bill only. Impacts billing operations and environmental sustainability initiatives.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'The customer\'s preferred channel for receiving communications: email, sms (text message), phone (voice call), mail (postal), mobile_app (push notification), or none (do not contact). Used for operational communication routing and marketing campaign targeting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTimeWindow rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time Window' ;
    rdfs:comment 'The time window during which the customer prefers to be contacted, expressed as a time range (e.g., 09:00-17:00, 18:00-21:00). Free-text to accommodate various formats. Used to honor customer communication preferences and improve Customer Satisfaction Score (CSAT).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofReference rdf:type rdf:Property ;
    rdfs:label 'Proof Reference' ;
    rdfs:comment 'Reference identifier or URL to the stored proof of consent (e.g., signed form, recorded call ID, web session ID, email confirmation ID). Required for regulatory audit trails and dispute resolution under GDPR Article 7(1) requirement to demonstrate consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Service Notification Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive service-related notifications (e.g., outage alerts, billing reminders, service updates). True = opted in, False = opted out. Distinct from marketing opt-ins; typically required for operational communications.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartySharingOptIn rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to sharing their personal data with third-party partners or affiliates. True = consented, False = not consented. Required for GDPR Article 6 lawful basis and CCPA right to opt-out of sale.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date when the customer withdrew or revoked consent. Null if consent is still active. Required for GDPR right to withdraw consent tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'The first line of the contact person\'s mailing or physical address, typically containing street number and street name.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'The second line of the contact person\'s address, typically containing apartment, suite, or unit number.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternatePhone rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone' ;
    rdfs:comment 'An alternate or secondary telephone number for the contact person (landline, office, or additional mobile).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'The level of authorization or permission this contact has to perform actions on the customer account (e.g., make changes, view bills, authorize service orders).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'The preferred language for communication with the contact person, specified as a 3-letter ISO 639-2 language code (e.g., ENG for English, SPA for Spanish).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The role or capacity in which this contact person is associated with the customer account. Defines the contact\'s authority and responsibility level.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'The current lifecycle status of the contact record. Indicates whether the contact is actively associated with the customer account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The date of birth of the contact person. Used for identity verification and age-restricted service eligibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or business unit within the organization where the contact person works. Primarily used for B2B enterprise accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether the contact person has requested not to be contacted for any purpose. True if contact is prohibited, False otherwise.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'The primary email address of the contact person used for electronic communication and correspondence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier for this contact in the source operational system. Used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The facsimile (fax) number of the contact person, if applicable. Used primarily for B2B enterprise communications.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The given name or first name of the contact person.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary or main contact for the customer account. True if primary, False otherwise. Only one contact per account should be marked as primary.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The professional job title or position of the contact person within their organization. Primarily used for Business-to-Business (B2B) enterprise accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The family name or surname of the contact person.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'The date when the contact person provided consent to receive marketing communications. Used for compliance tracking and consent management.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the contact person has explicitly opted in to receive marketing communications, promotional offers, and product updates. True if opted in, False otherwise.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'The date when the contact person withdrew consent or opted out of receiving marketing communications.' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'The middle name or initial of the contact person, if applicable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'The mobile telephone number of the contact person. Primary contact channel for SMS and voice communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'The government-issued national identification number of the contact person (e.g., Social Security Number in USA, National Insurance Number in UK). Used for identity verification and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToAccountHolder rdf:type rdf:Property ;
    rdfs:label 'Relationship To Account Holder' ;
    rdfs:comment 'Describes the personal or professional relationship of this contact to the primary account holder (e.g., spouse, parent, employee, business partner).' ;
    rdfs:domain ind:CustomerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enterpriseCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Corporate Account Id' ;
    rdfs:comment 'Foreign key linking to enterprise.corporate_account. Business justification: Large enterprise customers often have both consumer corporate hierarchy structures and enterprise managed service accounts. Telcos track which enterprise account manager owns the commercial relationsh' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:enterpriseSegmentDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Segment Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.segment_definition. Business justification: Enterprise segmentation by hierarchy_level, employee_headcount_band, annual_revenue_band, and industry_vertical_code is fundamental for B2B analytics, account planning, and enterprise sales targeting.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SegmentDefinition .

ind:headquartersLocationAddressId rdf:type rdf:Property ;
    rdfs:label 'Headquarters Location Address Id' ;
    rdfs:comment 'Foreign key linking to location.location_address. Business justification: Corporate entities require authoritative headquarters addresses for service territory assignment, enterprise account management, and regulatory jurisdiction determination. Location.location_address pr' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationAddress .

ind:parentHierarchyCorporateHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Corporate Hierarchy Id' ;
    rdfs:comment 'Reference to the parent node in the corporate hierarchy structure. Null for ultimate parent/root nodes. Enables recursive traversal of the organizational tree.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateHierarchy .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Categorical range representing the entity\'s annual revenue in USD. Used for customer segmentation, credit assessment, and strategic account classification. Bands represent millions of dollars.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1-31) when invoices are generated for this hierarchy node. Used for billing schedule management and revenue recognition timing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Company Registration Number' ;
    rdfs:comment 'Government-issued registration or incorporation number assigned by the jurisdiction of incorporation. Used for legal verification, due diligence, and regulatory reporting.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether charges for this hierarchy node and its children are consolidated into a single invoice sent to the parent entity. True enables enterprise-wide billing aggregation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for this hierarchy node in USD. Used for order approval, billing controls, and accounts receivable management. Null indicates no credit limit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned by a credit rating agency (e.g., Moody\'s, S&P, Fitch). Used for credit risk assessment, payment terms determination, and financial exposure management. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or brand name under which the entity operates commercially. May differ from the legal entity name. Used for customer-facing communications and marketing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeHeadcountBand rdf:type rdf:Property ;
    rdfs:label 'Employee Headcount Band' ;
    rdfs:comment 'Categorical range representing the total number of employees across the entity. Used for enterprise segmentation, pricing tier determination, and sales territory assignment.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'Chart of accounts code in the ERP system used for financial posting and consolidation. Links hierarchy node to the financial accounting structure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Type' ;
    rdfs:comment 'Classification of the node within the corporate structure. Ultimate parent represents the top-level legal entity, subsidiary is a controlled entity, branch is a geographic location, department is a functional unit, cost center is a budget allocation unit, and division is a business segment.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current operational status of the hierarchy node. Active indicates the node is operational, inactive indicates it has been deactivated, suspended indicates temporary hold, pending states indicate workflow transitions.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVerticalCode rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Code' ;
    rdfs:comment 'Standard Industrial Classification (SIC) or North American Industry Classification System (NAICS) code identifying the primary business sector. Used for market segmentation, competitive analysis, and product targeting.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVerticalDescription rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Description' ;
    rdfs:comment 'Human-readable description of the industry vertical corresponding to the SIC or NAICS code. Examples: Financial Services, Healthcare, Manufacturing, Retail, Technology.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'ISO 17442 compliant 20-character alphanumeric Legal Entity Identifier for global entity identification in financial transactions and regulatory reporting. Required for large enterprise accounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official registered legal name of the corporate entity as it appears on incorporation documents, contracts, and regulatory filings. Used for legal compliance, invoicing, and contract management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managedAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Managed Account Flag' ;
    rdfs:comment 'Indicates whether this hierarchy node is assigned to a dedicated account manager or strategic account team. True for high-value enterprise accounts requiring white-glove service.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership the parent entity holds in this subsidiary or controlled entity. Used for financial consolidation, regulatory reporting, and corporate structure analysis. Range 0.00 to 100.00.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Nature of the corporate relationship between parent and child nodes. Wholly owned indicates 100% ownership, majority owned indicates >50%, minority owned indicates <50%, joint venture indicates shared control, affiliate indicates associated entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'External identifier from Salesforce CRM system linking this hierarchy node to the corresponding Account object. Used for CRM integration, opportunity tracking, and customer 360 view.' ;
    rdfs:domain ind:CorporateHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identifier assigned by the tax authority in the entity\'s jurisdiction. Used for tax reporting, invoicing, and revenue recognition. May be EIN (USA), VAT number (EU), or equivalent.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatResponseId rdf:type rdf:Property ;
    rdfs:label 'Csat Response Id' ;
    rdfs:comment 'Unique identifier for the customer satisfaction survey response record.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyWaveId rdf:type rdf:Property ;
    rdfs:label 'Survey Wave Id' ;
    rdfs:comment 'Identifier for the survey campaign wave or batch in which this response was collected. Enables cohort analysis.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyWave .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Post-service CSAT surveys tied to specific field technician performance for individual performance management, coaching, incentive compensation, and quality assurance. Critical for workforce performan' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:agentRating rdf:type rdf:Property ;
    rdfs:label 'Agent Rating' ;
    rdfs:comment 'Customer rating of the service agent or representative who handled their interaction, if applicable.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedLoopActionCode rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Action Code' ;
    rdfs:comment 'Code representing the closed-loop action taken in response to this feedback (e.g., callback scheduled, credit issued, escalation created).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedLoopCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Closed Loop Completion Date' ;
    rdfs:comment 'Date when the closed-loop follow-up action was completed and the feedback loop was closed.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactPermissionFlag rdf:type rdf:Property ;
    rdfs:label 'Contact Permission Flag' ;
    rdfs:comment 'Indicates whether the customer granted permission to be contacted regarding their feedback (true/false).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:easeOfResolutionRating rdf:type rdf:Property ;
    rdfs:label 'Ease Of Resolution Rating' ;
    rdfs:comment 'Customer rating indicating how easy it was to resolve their issue or complete their request. Core component of Customer Effort Score (CES).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpActionFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Flag' ;
    rdfs:comment 'Indicates whether the response requires follow-up action from customer service or retention teams (true/false).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Indicates whether the required follow-up action has been completed (true/false).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Classification of NPS response: promoter (9-10), passive (7-8), or detractor (0-6). Null for non-NPS surveys.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the customer opted out of future surveys during or after this response (true/false).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date when the customer submitted the survey response.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Status of the survey response: completed (fully answered), partial (incomplete), abandoned (started but not finished), or invalid (failed validation).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time in seconds taken by the customer to complete the survey from start to submission.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Precise timestamp when the customer completed and submitted the survey response.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scoreScale rdf:type rdf:Property ;
    rdfs:label 'Score Scale' ;
    rdfs:comment 'The rating scale used for the survey (e.g., 0-10 for NPS, 1-5 for CSAT, 1-7 for CES).' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreValue rdf:type rdf:Property ;
    rdfs:label 'Score Value' ;
    rdfs:comment 'Numeric score value provided by the customer in response to the survey question.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated sentiment analysis score derived from verbatim comment text, ranging from -1.00 (negative) to +1.00 (positive).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'Channel through which the survey was delivered and completed: SMS, email, Interactive Voice Response (IVR), mobile app, web portal, or post-call.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyInvitationDate rdf:type rdf:Property ;
    rdfs:label 'Survey Invitation Date' ;
    rdfs:comment 'Date when the survey invitation was sent to the customer.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyLanguage rdf:type rdf:Property ;
    rdfs:label 'Survey Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language in which the survey was presented to the customer.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Type of customer feedback survey administered: Net Promoter Score (NPS), Customer Satisfaction (CSAT), or Customer Effort Score (CES).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Business event that triggered the survey: post-interaction, post-installation, periodic check-in, post-repair, post-purchase, or post-billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimComment rdf:type rdf:Property ;
    rdfs:label 'Verbatim Comment' ;
    rdfs:comment 'Free-text customer comment or feedback provided alongside the numeric score. May contain sensitive customer opinions.' ;
    rdfs:domain ind:CsatResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Customer Account Id' ;
    rdfs:comment 'Reference to parent account in hierarchical account structures. Used for enterprise customers with master account and sub-accounts, family plans with primary and secondary accounts, or wholesale relationships with reseller hierarchy. Null for standalone accounts. Enables consolidated billing and hierarchical reporting.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primarySegmentDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Segment Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.segment_definition. Business justification: Account-level attributes (account_tier, credit_class, churn_risk_score, cltv_segment) are primary segmentation criteria for B2C and B2B analytics, campaign targeting, and personalized pricing. Fundame' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SegmentDefinition .

ind:serviceLocationAddressId rdf:type rdf:Property ;
    rdfs:label 'Service Location Address Id' ;
    rdfs:comment 'Foreign key linking to location.location_address. Business justification: Accounts require authoritative geocoded service addresses for installation scheduling, coverage qualification, service provisioning, and regulatory reporting. Location.location_address is the master a' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationAddress .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Service tier or loyalty level determining priority support, special offers, and premium features. Higher tiers receive enhanced customer service, exclusive promotions, and preferential treatment. Used for customer retention and lifetime value (CLTV) optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Sales channel through which customer account was originally acquired. Retail store for physical locations; online for web/mobile signup; telesales for inbound/outbound call center; dealer for authorized resellers; partner for co-marketing channels; direct sales for field sales teams; referral for customer referral programs. Used for channel performance analysis and commission attribution. [ENUM-REF-CANDIDATE: retail_store|online|telesales|dealer|partner|direct_sales|referral — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated by this account over the trailing 12 months. Calculated as total revenue divided by number of active months. Expressed in account currency. Key metric for customer value assessment, segmentation, and churn impact analysis. Used for CLTV calculations and retention investment decisions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment is configured for this account. True means payment method is automatically charged on due date; false requires manual payment. Reduces delinquency rates and improves cash flow predictability.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether California resident has exercised right to opt out of personal information sale under CCPA. True means customer opted out; false means no opt-out request. Required for California customers. Restricts data sharing with third parties for marketing purposes.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score indicating likelihood of customer churn within next 90 days. Ranges from 0.00 (lowest risk) to 100.00 (highest risk). Generated by machine learning models analyzing usage patterns, payment behavior, support interactions, NPS scores, and competitive activity. Triggers proactive retention campaigns and win-back offers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Segmentation based on predicted customer lifetime value. High segment represents most valuable customers with strong retention and upsell potential; medium segment shows moderate value; low segment indicates limited revenue potential; new segment for recently acquired customers without history; at risk segment for high-value customers with churn indicators. Drives retention investment prioritization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditClass rdf:type rdf:Property ;
    rdfs:label 'Credit Class' ;
    rdfs:comment 'Credit risk classification based on credit bureau assessment and payment history. Determines deposit requirements, credit limits, and payment terms. Excellent and good classes receive favorable terms; fair and poor classes may require deposits; no credit check applies to prepaid; secured accounts have collateral.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the oldest unpaid invoice is overdue. Zero for accounts current on payments; positive values indicate delinquency. Used for aging analysis, dunning process triggers, and credit risk assessment. Null for prepaid accounts or accounts with no outstanding balance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotCallFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Call Flag' ;
    rdfs:comment 'Indicates whether customer is registered on Do Not Call list or has requested no telemarketing calls. True means no outbound sales calls permitted; false means calls allowed with consent. Compliance with FTC Do Not Call Registry and TCPA regulations. Does not restrict service-related or transactional calls.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether account has been flagged for suspected fraudulent activity. True means fraud investigation in progress or confirmed fraud; false means no fraud indicators. Triggers service suspension, payment holds, and security team review. Used for fraud pattern analysis and prevention.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Timestamp when GDPR consent was obtained or last updated. Required for audit trail and consent management. Null if consent not applicable or not obtained. Must be refreshed periodically per GDPR guidelines.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether customer has provided explicit consent for data processing under GDPR regulations. True means valid consent obtained; false means consent not given or withdrawn. Required for EU/EEA customers. Governs marketing communications, data sharing, and analytics usage.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current total amount owed by customer including unpaid invoices, late fees, and adjustments. Positive values indicate customer owes money; negative values indicate credit balance. Expressed in account currency. Zero for prepaid accounts. Used for collections prioritization and credit limit management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether customer has opted for electronic billing instead of paper invoices. True means customer receives invoices via email or web portal only; false means paper invoices are mailed. Supports environmental sustainability initiatives and reduces operational costs (OPEX).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Customer\'s preferred channel for receiving notifications, billing statements, promotional offers, and service updates. Email for electronic delivery; SMS for text messages; phone for voice calls; mail for postal delivery; mobile app for push notifications; web portal for self-service access.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Account status immediately before the most recent status change. Used for status transition audit trail and lifecycle analysis. Enables tracking of suspension-to-active restorations, termination reversals, and status change patterns. Null for accounts that have never changed status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full legal name of the primary account holder or authorized contact person. Used for identity verification, legal correspondence, and customer service authentication. For business accounts, this is the primary business contact. For consumer accounts, this is the account owner.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Primary Email Address' ;
    rdfs:comment 'Primary email address for account communications, billing notifications, service alerts, and password resets. Must be unique per account for authentication purposes. Used for electronic invoice delivery when paperless billing is enabled.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Number' ;
    rdfs:comment 'Primary contact telephone number in E.164 international format. Used for customer service callbacks, two-factor authentication, SMS notifications, and emergency contact. May be mobile or landline. For mobile accounts, often matches the service MSISDN (Mobile Station International Subscriber Directory Number).' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable deposit held for accounts with credit risk or new customers without credit history. Returned after satisfactory payment history period. Expressed in account currency. Zero or null for accounts not requiring deposits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAddressSameAsBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Service Address Same As Billing Flag' ;
    rdfs:comment 'Indicates whether service delivery address matches billing address. True for most residential mobile accounts; false for business accounts with separate billing and service locations, or customers with PO Box billing addresses. Determines whether separate service address fields are populated.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeDate rdf:type rdf:Property ;
    rdfs:label 'Status Change Date' ;
    rdfs:comment 'Timestamp of most recent account status change. Used for status duration analysis, SLA compliance tracking, and lifecycle event sequencing. Null for accounts that have never changed status since creation.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangeInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Status Change Initiated By' ;
    rdfs:comment 'Actor or system that triggered the most recent status change. Customer for self-service actions; system for automated processes; agent for customer service actions; billing for payment-related changes; fraud for security actions; credit for credit management; provisioning for technical changes. Used for accountability and process analysis. [ENUM-REF-CANDIDATE: customer|system|agent|billing|fraud|credit|provisioning — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'Free-text explanation for most recent status change. Examples: payment received for suspension-to-active; non-payment for active-to-suspended; customer request for termination; fraud detection for suspension. Used for root cause analysis and process improvement. Null for accounts with no status changes.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subType rdf:type rdf:Property ;
    rdfs:label 'Sub Type' ;
    rdfs:comment 'Secondary classification providing additional segmentation within account type. Individual accounts serve single consumers; family accounts serve household groups; business accounts serve commercial entities; government accounts serve public sector; nonprofit accounts serve charitable organizations; reseller accounts serve distribution partners.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether account is exempt from sales tax, value-added tax (VAT), or other telecommunications taxes. True for government entities, nonprofits, or accounts with valid tax exemption certificates; false for standard taxable accounts. Requires supporting documentation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Official certificate or registration number proving tax-exempt status. Required for audit compliance when tax exempt flag is true. Issued by relevant tax authority. Null for non-exempt accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Primary reason for account closure. Customer request for voluntary cancellation; non-payment for delinquency; fraud for security violations; relocation for move outside service area; competitor for churn to rival; service quality for dissatisfaction; price for cost concerns; deceased for customer death; duplicate for consolidation. Critical for churn root cause analysis. [ENUM-REF-CANDIDATE: customer_request|non_payment|fraud|relocation|competitor|service_quality|price|deceased|duplicate — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether account is designated as VIP requiring special handling. True for high-value customers, executives, celebrities, government officials, or strategic partners. Triggers priority support routing, dedicated account management, and enhanced service level agreements (SLA). Used for customer retention and satisfaction optimization.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Device Offering Id' ;
    rdfs:comment 'Foreign key linking to product.device_offering. Business justification: Registrations tied to device purchase/financing offerings. Essential for installment plan tracking, subsidy management, trade-in eligibility, and inventory reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceOffering .

ind:deviceSegmentDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Device Segment Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.segment_definition. Business justification: Device attributes (BYOD vs financed, 5G-capable, device_type) are common segmentation dimensions for product adoption analytics, upsell targeting (5G plan upgrades), and device financing campaign elig' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SegmentDefinition .

ind:esimProfileId rdf:type rdf:Property ;
    rdfs:label 'Esim Profile Id' ;
    rdfs:comment 'Unique identifier for the eSIM profile provisioned on the device, if applicable. Used for remote SIM provisioning and management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsimProfile .

ind:installationPremiseId rdf:type rdf:Property ;
    rdfs:label 'Installation Premise Id' ;
    rdfs:comment 'Foreign key linking to location.premise. Business justification: Device installations (CPE, ONT, fixed wireless equipment) occur at specific premises requiring premise-level tracking for inventory management, field service dispatch, and premise serviceability valid' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:replacementDeviceRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Replacement Device Registration Id' ;
    rdfs:comment 'Reference to the new device registration record if this device was replaced. Null if no replacement occurred.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceRegistration .

ind:byodFlag rdf:type rdf:Property ;
    rdfs:label 'Byod Flag' ;
    rdfs:comment 'Indicates whether the device is customer-owned (BYOD = True) or operator-provided/financed (BYOD = False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceirBlockDate rdf:type rdf:Property ;
    rdfs:label 'Ceir Block Date' ;
    rdfs:comment 'Date when the device was blocked in the CEIR. Null if device is not blocked.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceirBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Ceir Block Flag' ;
    rdfs:comment 'Indicates whether the device IMEI has been blocked in the Central Equipment Identity Register (CEIR) due to theft, loss, or fraud (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deregistrationDate rdf:type rdf:Property ;
    rdfs:label 'Deregistration Date' ;
    rdfs:comment 'Date when the device was deregistered or removed from the subscriber account. Null if device is still registered.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deregistrationReason rdf:type rdf:Property ;
    rdfs:label 'Deregistration Reason' ;
    rdfs:comment 'Reason for device deregistration: upgrade to new device, reported lost, reported stolen, damaged beyond repair, sold to another party, service termination, or other. [ENUM-REF-CANDIDATE: upgrade|lost|stolen|damaged|sold|service_termination|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Device Financing Flag' ;
    rdfs:comment 'Indicates whether the device is under an installment financing plan (True) or purchased outright (False). Links to billing installment plan records.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceStatus rdf:type rdf:Property ;
    rdfs:label 'Device Status' ;
    rdfs:comment 'Current lifecycle status of the registered device: active (in use), inactive (not in use), lost (reported lost), stolen (reported stolen and blocked via CEIR), replaced (superseded by new device), or blocked (administratively blocked).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Enrollment Flag' ;
    rdfs:comment 'Indicates whether the device is enrolled in an insurance or protection plan (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number or reference for the device insurance plan, if enrolled. Used for insurance claim validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastNetworkActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Network Activity Timestamp' ;
    rdfs:comment 'Timestamp of the last recorded network activity (data session, voice call, SMS) from this device. Used for device usage analytics and fraud detection.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware address of the device network interface, used for CPE provisioning and network access control.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapability4g rdf:type rdf:Property ;
    rdfs:label 'Network Capability 4g' ;
    rdfs:comment 'Indicates whether the device supports 4G LTE connectivity (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkCapability5g rdf:type rdf:Property ;
    rdfs:label 'Network Capability 5g' ;
    rdfs:comment 'Indicates whether the device supports 5G NR connectivity (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osType rdf:type rdf:Property ;
    rdfs:label 'Os Type' ;
    rdfs:comment 'Operating system family running on the device: Android, iOS, Windows, Linux, proprietary (for CPE/ONT), or other.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'Specific version of the operating system installed on the device (e.g., Android 13, iOS 16.5, firmware v2.1.3 for CPE).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySimIccid rdf:type rdf:Property ;
    rdfs:label 'Primary Sim Iccid' ;
    rdfs:comment 'Integrated Circuit Card ID of the primary SIM card associated with this device. 19-20 digit unique identifier for the physical or eSIM card.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date when the device was purchased by the customer, either from the operator or a third party. Used for warranty and upgrade eligibility calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'Channel through which the device was registered: retail store, online customer portal, mobile app, call center, or authorized dealer.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the device was registered against the subscriber or account in the Customer Relationship Management (CRM) system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise timestamp when the device registration was recorded in the system, including time zone information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:residualValueAmount rdf:type rdf:Property ;
    rdfs:label 'Residual Value Amount' ;
    rdfs:comment 'Current estimated residual or trade-in value of the device. Used for upgrade offers and device buyback programs.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number for non-cellular devices such as Customer Premises Equipment (CPE), Optical Network Terminals (ONT), routers, modems, and IoT devices.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simSlotType rdf:type rdf:Property ;
    rdfs:label 'Sim Slot Type' ;
    rdfs:comment 'SIM slot configuration of the device: single SIM, dual SIM (two physical slots), eSIM only (embedded SIM), hybrid (physical + eSIM), or none (for non-cellular devices).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tac rdf:type rdf:Property ;
    rdfs:label 'Tac' ;
    rdfs:comment 'First 8 digits of the IMEI, identifying the device model and manufacturer. Used for device capability lookup in GSMA TAC database.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteCapable rdf:type rdf:Property ;
    rdfs:label 'Volte Capable' ;
    rdfs:comment 'Indicates whether the device supports Voice over LTE (VoLTE) for voice calls over 4G networks (True) or not (False).' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer or operator warranty for the device expires. Null if no warranty or warranty information unavailable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wifiCapability rdf:type rdf:Property ;
    rdfs:label 'Wifi Capability' ;
    rdfs:comment 'Highest Wi-Fi standard supported by the device: WiFi 4 (802.11n), WiFi 5 (802.11ac), WiFi 6 (802.11ax), WiFi 6E (6 GHz), or none.' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique system identifier for the household grouping entity. Primary key.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:activeMemberCount rdf:type rdf:Property ;
    rdfs:label 'Active Member Count' ;
    rdfs:comment 'Number of household members with active service status. Excludes suspended or terminated member accounts.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autopayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Autopay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment is enabled for the household. True if autopay is active, False if manual payment is required.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Calculated lifetime value score for the household in monetary terms. Represents the projected total revenue from this household over the expected relationship duration.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'Segmentation tier based on projected lifetime value of the entire household. Used for retention strategy prioritization and personalized offer targeting.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Type of service contract or commitment period for the household. Determines early termination fees and upgrade eligibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Display name for the household grouping, typically the family surname or primary account holder name (e.g., \'Smith Family\', \'Johnson Household\').' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle state of the household grouping. Active households have at least one active member account; suspended households have temporary service restrictions; terminated households are closed.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household grouping structure. Determines eligibility for specific plan types and shared resource configurations.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current accumulated loyalty points balance for the household. Points can be redeemed for rewards, discounts, or service upgrades.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyProgramTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Tier' ;
    rdfs:comment 'Current tier in the telecommunications provider loyalty or rewards program. Determines eligibility for exclusive benefits, discounts, and priority support.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of individual subscriber accounts currently linked to this household grouping. Used for family plan eligibility and pricing tier determination.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrr rdf:type rdf:Property ;
    rdfs:label 'Mrr' ;
    rdfs:comment 'Total monthly recurring revenue generated by all members of the household. Sum of all subscription charges, shared plan fees, and recurring add-ons across household members.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Primary payment instrument type used for household billing. Determines payment processing workflow and collection strategy. [ENUM-REF-CANDIDATE: credit_card|debit_card|bank_transfer|direct_debit|prepaid|cash|check — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Marketing and service segmentation classification for the household. Determines product offerings, pricing strategies, and service level expectations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedDataPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Data Pool Flag' ;
    rdfs:comment 'Indicates whether the household has a shared data pool configuration where all members draw from a common data allowance. True if shared pool is active, False otherwise.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedDataPoolSizeGb rdf:type rdf:Property ;
    rdfs:label 'Shared Data Pool Size Gb' ;
    rdfs:comment 'Total size of the shared data pool in gigabytes available to all household members. Null if shared_data_pool_flag is False.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedDataPoolUsedGb rdf:type rdf:Property ;
    rdfs:label 'Shared Data Pool Used Gb' ;
    rdfs:comment 'Current month-to-date data consumption from the shared pool across all household members, measured in gigabytes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedMinutesPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Minutes Pool Flag' ;
    rdfs:comment 'Indicates whether the household has a shared voice minutes pool where all members draw from a common allowance. True if shared minutes pool is active, False otherwise.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedMinutesPoolSize rdf:type rdf:Property ;
    rdfs:label 'Shared Minutes Pool Size' ;
    rdfs:comment 'Total number of voice minutes in the shared pool available to all household members. Null if shared_minutes_pool_flag is False.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for household termination. Used for churn analysis and service improvement initiatives. Null for active households. [ENUM-REF-CANDIDATE: voluntary_churn|involuntary_churn|relocation|financial|service_quality|competitor_offer|deceased|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callbackRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Callback Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer requested a callback (True) or not (False).' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callbackScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Callback Scheduled Timestamp' ;
    rdfs:comment 'Date and time when a callback was scheduled, in format yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if no callback scheduled.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Email address used by the customer during this interaction. May differ from the primary account email.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Phone number used by the customer during this interaction. May differ from the primary account phone number.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEffortScore rdf:type rdf:Property ;
    rdfs:label 'Customer Effort Score' ;
    rdfs:comment 'Customer Effort Score measuring how easy it was for the customer to resolve their issue, typically on a scale of 1-7. Null if not captured.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of the interaction: inbound (customer-initiated) or outbound (company-initiated).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction: open, in progress, resolved, closed, escalated, or pending customer response.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction purpose: inquiry, complaint, service request, sales, technical support, or billing inquiry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Triggered Flag' ;
    rdfs:comment 'Boolean flag indicating whether a Net Promoter Score survey was triggered following this interaction (True) or not (False).' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'Name of the service queue or routing group to which the interaction was assigned (e.g., Technical Support, Billing, Sales).' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingUrl rdf:type rdf:Property ;
    rdfs:label 'Recording Url' ;
    rdfs:comment 'URL or storage path to the interaction recording (voice call recording, chat transcript, email thread). Null if recording not available or not permitted.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Status indicating whether the customer issue was resolved during the interaction: resolved, unresolved, partially resolved, escalated, or pending.' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief textual summary of the interaction content, key points discussed, and actions taken. Used for quick reference and reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicCategory rdf:type rdf:Property ;
    rdfs:label 'Topic Category' ;
    rdfs:comment 'High-level category of the interaction topic (e.g., Billing, Network Quality, Service Activation, Account Management).' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicSubcategory rdf:type rdf:Property ;
    rdfs:label 'Topic Subcategory' ;
    rdfs:comment 'Detailed subcategory of the interaction topic providing granular classification (e.g., Invoice Dispute, Data Speed Issue, SIM Activation).' ;
    rdfs:domain ind:CustomerInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationId rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Id' ;
    rdfs:comment 'Unique identifier for the KYC verification record. Primary key for the KYC verification entity.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousVerificationKycVerificationId rdf:type rdf:Property ;
    rdfs:label 'Previous Verification Kyc Verification Id' ;
    rdfs:comment 'Reference to the previous KYC verification record for this customer, enabling verification history tracking and periodic re-verification workflows. Null for first-time verification.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycVerification .

ind:addressVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Verification Status' ;
    rdfs:comment 'Status of address proof verification: fully verified against authoritative source, unverified, partially verified with some discrepancies, or not applicable for this verification type.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricMatchScore rdf:type rdf:Property ;
    rdfs:label 'Biometric Match Score' ;
    rdfs:comment 'Numerical score indicating the confidence level of biometric match, typically ranging from 0.00 to 100.00. Null if biometric verification was not performed.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biometricType rdf:type rdf:Property ;
    rdfs:label 'Biometric Type' ;
    rdfs:comment 'Type of biometric authentication used during verification: facial recognition, fingerprint scan, iris scan, voice recognition, or none if biometric verification was not performed.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Boolean flag indicating whether explicit customer consent was obtained for identity verification and data processing. True if consent obtained, False otherwise. Required for GDPR compliance.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckPerformed rdf:type rdf:Property ;
    rdfs:label 'Credit Check Performed' ;
    rdfs:comment 'Boolean flag indicating whether a credit bureau check was performed as part of the KYC verification process. True if credit check was conducted, False otherwise.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Credit score obtained from credit bureau during verification process. Null if credit check was not performed. Used for risk assessment and service eligibility determination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Date when the identity document expires and is no longer valid for verification purposes, in yyyy-MM-dd format. Null for documents without expiration.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date when the identity document was originally issued by the authority, in yyyy-MM-dd format.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Masked or tokenized document identification number from the submitted identity document. Stored in encrypted or hashed format to protect sensitive personal information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudIndicators rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicators' ;
    rdfs:comment 'Comma-separated list of fraud indicators or red flags identified during verification process (e.g., document tampering, synthetic identity, address mismatch, velocity abuse).' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country that issued the identity document (e.g., USA, GBR, DEU, FRA).' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Applicable regulatory framework or compliance standard under which the KYC verification was performed (e.g., AML/CTF, KYC, eIDAS, GDPR, USA PATRIOT Act, local telecommunications regulations).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationChannel rdf:type rdf:Property ;
    rdfs:label 'Verification Channel' ;
    rdfs:comment 'Channel through which the KYC verification was initiated and completed: web portal, mobile application, retail store, call center, or agent portal.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Verification Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to complete the verification process from initiation to final status. Used for process efficiency analysis and SLA monitoring.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Verification Expiry Date' ;
    rdfs:comment 'Date when the KYC verification expires and requires re-verification per regulatory requirements or internal policy, in yyyy-MM-dd format.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to perform the verification: fully automated using AI/ML algorithms, manual review by compliance officer, or hybrid approach combining automated screening with manual validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationProvider rdf:type rdf:Property ;
    rdfs:label 'Verification Provider' ;
    rdfs:comment 'Name of the third-party verification service provider or internal system that performed the KYC check (e.g., Jumio, Onfido, Experian, internal compliance system).' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationProviderReference rdf:type rdf:Property ;
    rdfs:label 'Verification Provider Reference' ;
    rdfs:comment 'External reference or transaction ID assigned by the verification provider for their internal tracking and support purposes.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationReason rdf:type rdf:Property ;
    rdfs:label 'Verification Reason' ;
    rdfs:comment 'Business reason triggering the KYC verification: new customer onboarding, periodic re-verification, high-value transaction threshold, regulatory mandate, fraud alert, or customer-initiated update.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Reference Number' ;
    rdfs:comment 'External reference number assigned by the verification provider or internal system for tracking and audit purposes.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationScore rdf:type rdf:Property ;
    rdfs:label 'Verification Score' ;
    rdfs:comment 'Numerical confidence score assigned by the verification system indicating the reliability of the identity verification, typically ranging from 0.00 to 100.00.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Precise timestamp when the KYC verification was completed, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationType rdf:type rdf:Property ;
    rdfs:label 'Verification Type' ;
    rdfs:comment 'Type of KYC verification performed: identity document scan, biometric authentication, credit bureau check, address proof validation, database cross-reference, or video-based identity verification.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistMatchDetails rdf:type rdf:Property ;
    rdfs:label 'Watchlist Match Details' ;
    rdfs:comment 'Details of any matches found during watchlist screening, including list name and match confidence. Null if no matches found or screening not performed.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Screening Status' ;
    rdfs:comment 'Result of screening against sanctions lists, PEP (Politically Exposed Persons) databases, and fraud watchlists: clear with no matches, match found requiring investigation, pending manual review, or not performed.' ;
    rdfs:domain ind:KycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyAccountId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Id' ;
    rdfs:comment 'Unique identifier for the loyalty program account. Primary key. _canonical_skip_reason: MASTER_AGREEMENT role inferred; this is the PK.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liabilityGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Liability General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Loyalty points represent deferred revenue liability under IFRS 15 and ASC 606. Telecommunications operators must map loyalty accounts to specific GL accounts for balance sheet reporting, liability val' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Foreign key linking to product.promo_offer. Business justification: Loyalty accounts redeem specific promo offers (bonus data, discounts). Core loyalty program mechanics for points redemption, offer eligibility validation, and campaign tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:autoRedemptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Redemption Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic points redemption is enabled for this account (e.g., auto-apply points to bill payment). True if enabled, False if manual redemption only.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason for account closure (e.g., customer request, account termination, fraud, inactivity, program discontinuation). Null if account is still open.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that can be redeemed. Reflects all earned points minus redeemed and expired points. Updated in real-time via Comverse ONE prepaid balance management.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earningRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earning Rate Multiplier' ;
    rdfs:comment 'Current points earning rate multiplier for this account based on tier level and promotions (e.g., 1.0 for base rate, 1.5 for gold tier, 2.0 for platinum). Used for real-time rating in Comverse ONE.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the customer enrolled in the loyalty program (e.g., web, mobile app, retail store, call center, partner, auto-enroll). Used for channel effectiveness analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in the loyalty program. Used for tenure analysis and anniversary rewards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent points transaction (earn, redeem, or adjustment). Used for dormancy detection and churn risk scoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date when points were last earned by the customer. Used for engagement tracking and reactivation campaigns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date when points were last redeemed by the customer. Used for redemption behavior analysis and reward catalog optimization.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total cumulative points earned since account inception, including redeemed and expired points. Used for tier qualification and Customer Lifetime Value (CLTV) segmentation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Total cumulative points that have expired due to inactivity or program rules since account inception. Used for churn risk analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total cumulative points redeemed by the customer since account inception. Used for engagement analytics and Average Revenue Per User (ARPU) uplift measurement.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyProgramCode rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Code' ;
    rdfs:comment 'Business identifier for the loyalty program this account is enrolled in (e.g., REWARDS_PLUS, PLATINUM_CLUB, BUSINESS_ADVANTAGE). Aligns with product catalog in Netcracker OSS/BSS Suite.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramName rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Name' ;
    rdfs:comment 'Human-readable name of the loyalty program (e.g., Rewards Plus, Platinum Club, Business Advantage).' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiry Date' ;
    rdfs:comment 'Date when the next batch of points is scheduled to expire. Used for proactive customer engagement and churn prevention campaigns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextExpiryPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Next Expiry Points Amount' ;
    rdfs:comment 'Number of points scheduled to expire on the next expiry date. Used for customer notification and retention campaigns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Account Number' ;
    rdfs:comment 'Customer\'s account number in the partner loyalty program. Used for cross-program point transfers and reconciliation. Null if no partner linkage.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Partner Program Code' ;
    rdfs:comment 'Code identifying any partner loyalty program this account is linked to for cross-program point transfers or earning (e.g., airline frequent flyer, hotel rewards). Null if no partner linkage.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Period Months' ;
    rdfs:comment 'Number of months after which earned points expire if not redeemed. Program rule applied at account level. Null if points never expire.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsPendingCredit rdf:type rdf:Property ;
    rdfs:label 'Points Pending Credit' ;
    rdfs:comment 'Points earned but not yet credited to the account balance, typically awaiting transaction settlement or validation period completion.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsToNextTier rdf:type rdf:Property ;
    rdfs:label 'Points To Next Tier' ;
    rdfs:comment 'Number of additional lifetime points required to qualify for the next tier level. Used for customer engagement and upsell campaigns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate' ;
    rdfs:comment 'Monetary value per point when redeeming (e.g., 0.01 means 100 points = $1). Used for redemption transaction processing and reward valuation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralBonusPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points Earned' ;
    rdfs:comment 'Total points earned through successful customer referrals. Used for referral program effectiveness measurement and Net Promoter Score (NPS) correlation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Unique referral code assigned to this loyalty account for customer acquisition campaigns. Used when this customer refers new subscribers to earn bonus points.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for account suspension (e.g., fraud investigation, customer request, policy violation, billing dispute). Null if account is not suspended.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Tier Points Threshold' ;
    rdfs:comment 'Minimum lifetime points required to maintain current tier level. Used for tier retention and upgrade eligibility calculations.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the customer qualified for their current tier level. Used for tier anniversary benefits and retention analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierReviewDate rdf:type rdf:Property ;
    rdfs:label 'Tier Review Date' ;
    rdfs:comment 'Next scheduled date for tier status review and potential upgrade or downgrade based on activity and points accumulation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorCarrierId rdf:type rdf:Property ;
    rdfs:label 'Donor Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: MNP porting requires tracking the donor carrier for settlement reconciliation, dispute resolution, regulatory reporting (NRTRDE), and SLA compliance monitoring. Telecommunications regulators mandate a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:actualCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Hours' ;
    rdfs:comment 'The actual elapsed time in hours from request submission to port completion. Used for SLA compliance monitoring and process performance analysis.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPortCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Port Completion Timestamp' ;
    rdfs:comment 'The precise date and time when the number port was successfully completed and the MSISDN became active on the recipient operator\'s network.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:centralDatabaseSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Central Database Sync Flag' ;
    rdfs:comment 'Indicates whether the MNP transaction has been synchronized with the central MNP database or number portability clearinghouse. Required for routing and billing accuracy.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centralDatabaseSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Central Database Sync Timestamp' ;
    rdfs:comment 'The date and time when the MNP transaction was synchronized with the central MNP database.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date when a dispute related to the MNP request was resolved, allowing the porting process to continue or be terminated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mnpRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Mnp Request Number' ;
    rdfs:comment 'Externally visible business identifier for the MNP request. Used for customer communication, inter-operator coordination, and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Notification Flag' ;
    rdfs:comment 'Indicates whether NRTRDE notification was sent to roaming partners about the number port. Required for maintaining accurate roaming records and billing across international networks.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberRangeHolder rdf:type rdf:Property ;
    rdfs:label 'Number Range Holder' ;
    rdfs:comment 'The original operator to which the number range was allocated by the regulatory authority. May differ from the current donor operator if the number was previously ported.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portType rdf:type rdf:Property ;
    rdfs:label 'Port Type' ;
    rdfs:comment 'Classification of the porting complexity. Simple (single number), complex (number with associated services), or bulk (multiple numbers in one request).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPortCount rdf:type rdf:Property ;
    rdfs:label 'Previous Port Count' ;
    rdfs:comment 'The number of times this MSISDN has been ported between operators. Used for tracking porting history and identifying potential fraud patterns.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date when the MNP request was initially submitted by the subscriber or receiving operator. This is the business event timestamp marking the start of the porting process.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The network routing number assigned to the MSISDN after porting. Used by all operators to correctly route calls and messages to the recipient operator\'s network.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPortDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Port Date' ;
    rdfs:comment 'The planned date for executing the number port. This is the target date agreed upon between operators for completing the MSISDN transfer.' ;
    rdfs:domain ind:CustomerMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The number of hours within which the MNP request must be completed to meet regulatory or contractual SLA requirements. Varies by jurisdiction (e.g., 24 hours in EU, 48 hours in some markets).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Subscriber Account Number' ;
    rdfs:comment 'The account number of the subscriber at the donor operator. Used for validation and account matching during the porting process.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when validation checks were completed for the MNP request.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:biometricVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Verified Flag' ;
    rdfs:comment 'Indicates whether the subscriber has completed biometric identity verification (fingerprint, facial recognition, etc.).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the subscriber has consented to sharing their data with third parties for analytics or marketing purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSpeedTier rdf:type rdf:Property ;
    rdfs:label 'Data Speed Tier' ;
    rdfs:comment 'Classification of the data speed entitlement for the subscriber based on their service plan and current usage status.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceImei rdf:type rdf:Property ;
    rdfs:label 'Device Imei' ;
    rdfs:comment 'Unique 15-digit identifier of the mobile device currently associated with the subscriber. Used for device tracking and fraud prevention.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Esim Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for eSIM provisioning based on device capability and service plan.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiveGEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Five G Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber has access to 5G network services based on device capability and service plan.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hotspotEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Hotspot Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to use mobile hotspot/tethering functionality.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Id Document Number' ;
    rdfs:comment 'Unique number of the government-issued identification document. Used for KYC and regulatory compliance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idDocumentType rdf:type rdf:Property ;
    rdfs:label 'Id Document Type' ;
    rdfs:comment 'Type of government-issued identification document provided by the subscriber during registration.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalDialingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'International Dialing Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber is permitted to make international calls from the home network.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastNpsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Nps Survey Date' ;
    rdfs:comment 'Date when the subscriber last completed an NPS survey.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSimSwapDate rdf:type rdf:Property ;
    rdfs:label 'Last Sim Swap Date' ;
    rdfs:comment 'Date of the most recent SIM card swap event for the subscriber.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date when the subscriber last used any network service (voice, data, SMS). Used for dormancy detection and churn prediction.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Country of citizenship of the subscriber, represented as ISO 3166-1 alpha-3 code. Used for roaming profile and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Flag' ;
    rdfs:comment 'Indicates whether parental control restrictions are applied to the subscriber, typically for minor dependents.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the subscriber\'s preferred language for communication and service delivery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosProfile rdf:type rdf:Property ;
    rdfs:label 'Qos Profile' ;
    rdfs:comment 'Defines the Quality of Service parameters applied to the subscriber\'s traffic, including priority, latency, and throughput guarantees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Enabled Flag' ;
    rdfs:comment 'Indicates whether roaming services are currently enabled for the subscriber. Can be toggled for fraud prevention or cost control.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roamingProfile rdf:type rdf:Property ;
    rdfs:label 'Roaming Profile' ;
    rdfs:comment 'Defines the subscriber\'s roaming permissions and geographic scope. Determines which networks the subscriber can access outside the home network.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simSwapCount rdf:type rdf:Property ;
    rdfs:label 'Sim Swap Count' ;
    rdfs:comment 'Total number of times the subscriber has performed a SIM card swap. High frequency may indicate fraud risk.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberStatus rdf:type rdf:Property ;
    rdfs:label 'Subscriber Status' ;
    rdfs:comment 'Current lifecycle status of the subscriber. Active indicates the subscriber can use services; suspended/barred indicates temporary restriction; terminated indicates permanent closure.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberType rdf:type rdf:Property ;
    rdfs:label 'Subscriber Type' ;
    rdfs:comment 'Classification of the subscriber within the account structure. Primary is the main account holder, secondary/add-on are additional lines.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Volte Enabled Flag' ;
    rdfs:comment 'Indicates whether VoLTE service is enabled for the subscriber, allowing voice calls over LTE network.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vowifiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vowifi Enabled Flag' ;
    rdfs:comment 'Indicates whether Voice over Wi-Fi calling is enabled for the subscriber.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Corporate Account Id' ;
    rdfs:comment 'Identifier of the child account in the corporate hierarchy structure. References the subordinate organizational entity in the relationship.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Identifier of the enterprise account manager or relationship owner responsible for managing this parent-child account relationship.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Account Id' ;
    rdfs:comment 'Identifier of the parent account in the corporate hierarchy structure. References the superior organizational entity in the relationship.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:billingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Flag' ;
    rdfs:comment 'Indicates whether charges from the child account should be rolled up and consolidated into the parent account invoice for unified enterprise billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division responsible for managing this hierarchy relationship within the enterprise organizational structure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representation of the complete lineage from root to current node in the account hierarchy tree. Typically formatted as slash-delimited account identifiers for efficient tree traversal queries.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Is Primary Relationship' ;
    rdfs:comment 'Indicates whether this is the primary or default parent relationship for the child account in scenarios where an account may belong to multiple hierarchies.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity under which this hierarchy relationship operates for regulatory compliance and statutory reporting requirements.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Financial profit center identifier associated with this hierarchy relationship for revenue attribution and profitability analysis in enterprise reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child account relationship. Indicates whether the hierarchical linkage is currently operational for billing consolidation and reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Consolidation Flag' ;
    rdfs:comment 'Indicates whether usage, revenue, and performance metrics from the child account should be aggregated into parent-level enterprise reporting and analytics.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bandwidthProfileId rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Profile Id' ;
    rdfs:comment 'Unique identifier for the bandwidth profile. Primary key for this entity.' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BandwidthProfile .

ind:parentProfileBandwidthProfileId rdf:type rdf:Property ;
    rdfs:label 'Parent Profile Bandwidth Profile Id' ;
    rdfs:comment 'Reference to a parent bandwidth profile for hierarchical bandwidth management. Enables envelope-based policing where multiple child profiles share a parent bandwidth constraint. Null for top-level profiles.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BandwidthProfile .

ind:applicationPriority rdf:type rdf:Property ;
    rdfs:label 'Application Priority' ;
    rdfs:comment 'Primary application type this bandwidth profile is optimized for: voice (VoIP, UC), video (conferencing, streaming), data (general business applications), management (network control), scavenger (low-priority bulk).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percentage' ;
    rdfs:comment 'Target service availability percentage for circuits using this bandwidth profile, typically expressed as uptime percentage (e.g., 99.99% = four nines).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether this bandwidth profile applies symmetrically to both ingress and egress traffic (true) or is unidirectional (false). Most enterprise services use symmetric profiles.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burstAllowancePercentage rdf:type rdf:Property ;
    rdfs:label 'Burst Allowance Percentage' ;
    rdfs:comment 'Percentage above CIR that burst traffic is allowed, calculated as ((PIR - CIR) / CIR) * 100. Represents the burst capacity as a percentage of committed rate.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cbsBytes rdf:type rdf:Property ;
    rdfs:label 'Cbs Bytes' ;
    rdfs:comment 'Committed Burst Size - the maximum amount of data in bytes that can be transmitted at line rate while remaining conformant to the CIR. Defines the token bucket depth for committed traffic.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cirMbps rdf:type rdf:Property ;
    rdfs:label 'Cir Mbps' ;
    rdfs:comment 'Committed Information Rate - the guaranteed minimum bandwidth in megabits per second that the service provider commits to deliver under normal conditions. This is the baseline bandwidth the customer can always expect.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorMode rdf:type rdf:Property ;
    rdfs:label 'Color Mode' ;
    rdfs:comment 'Indicates whether the bandwidth profile policing is color-blind (ignores existing packet color markings) or color-aware (respects pre-marked packet colors from upstream devices).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosMarking rdf:type rdf:Property ;
    rdfs:label 'Cos Marking' ;
    rdfs:comment 'IEEE 802.1p Class of Service priority value (0-7) for Layer 2 traffic marking. Used for VLAN-tagged Ethernet frames to indicate priority at the data link layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couplingFlag rdf:type rdf:Property ;
    rdfs:label 'Coupling Flag' ;
    rdfs:comment 'Indicates whether unused committed tokens can be used for excess traffic (true) or if committed and excess buckets are independent (false). Affects burst behavior.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebsBytes rdf:type rdf:Property ;
    rdfs:label 'Ebs Bytes' ;
    rdfs:comment 'Excess Burst Size - the maximum amount of excess data in bytes that can be transmitted above the CBS up to the PIR. Defines the token bucket depth for excess traffic.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:envelopeCouplingFlag rdf:type rdf:Property ;
    rdfs:label 'Envelope Coupling Flag' ;
    rdfs:comment 'For hierarchical bandwidth profiles, indicates whether unused tokens from one envelope can be shared with another envelope within the same profile hierarchy.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meteringType rdf:type rdf:Property ;
    rdfs:label 'Metering Type' ;
    rdfs:comment 'Token bucket metering algorithm used for bandwidth policing: single rate two color (srTCM), single rate three color, or two rate three color (trTCM). Determines how traffic is classified and policed.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtuBytes rdf:type rdf:Property ;
    rdfs:label 'Mtu Bytes' ;
    rdfs:comment 'Maximum Transmission Unit - the largest packet size in bytes that can be transmitted without fragmentation for this bandwidth profile. Standard Ethernet is 1500 bytes; jumbo frames can be up to 9000 bytes.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oversubscriptionRatio rdf:type rdf:Property ;
    rdfs:label 'Oversubscription Ratio' ;
    rdfs:comment 'Ratio of total subscribed bandwidth to available physical bandwidth on the network segment. A value of 1.0 means no oversubscription; higher values indicate statistical multiplexing.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packetLossTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Target Percentage' ;
    rdfs:comment 'Target maximum packet loss ratio as a percentage for traffic using this bandwidth profile. Typically expressed as a very small percentage (e.g., 0.01% = 0.0001).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pirMbps rdf:type rdf:Property ;
    rdfs:label 'Pir Mbps' ;
    rdfs:comment 'Peak Information Rate - the maximum bandwidth in megabits per second that the service can burst to when network capacity is available. Traffic above CIR up to PIR may be delivered on a best-effort basis.' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policingAction rdf:type rdf:Property ;
    rdfs:label 'Policing Action' ;
    rdfs:comment 'Action taken on traffic exceeding the bandwidth profile limits: drop (discard excess packets), remark (change DSCP/CoS to lower priority), shape (buffer and delay), pass (allow through without action).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Billing model for services using this bandwidth profile: flat rate (fixed monthly), usage based (per GB), tiered (volume discounts), burstable billing (95th percentile).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Business identifier code for the bandwidth profile, used for external reference and catalog management. Unique across all profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed description of the bandwidth profile, including use cases, target customer segments, and technical characteristics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the bandwidth profile, describing its purpose or tier (e.g., Gold Enterprise 100M, Silver SD-WAN 50M).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the bandwidth profile. Active profiles are available for provisioning; deprecated profiles are phased out; retired profiles are no longer used.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosTier rdf:type rdf:Property ;
    rdfs:label 'Qos Tier' ;
    rdfs:comment 'Quality of Service tier indicating the priority and treatment level for traffic using this bandwidth profile. Higher tiers receive better latency, jitter, and packet loss guarantees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA tier associated with this bandwidth profile, determining performance guarantees, support response times, and credit entitlements for breaches.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficClass rdf:type rdf:Property ;
    rdfs:label 'Traffic Class' ;
    rdfs:comment 'Primary traffic class mapping for this bandwidth profile using DiffServ Code Point (DSCP) classes: EF (Expedited Forwarding - real-time), AF1-AF4 (Assured Forwarding classes 1-4), BE (Best Effort).' ;
    rdfs:domain ind:BandwidthProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Corporate Account Id' ;
    rdfs:comment 'Reference to the parent corporate account if this account is part of a multi-entity corporate hierarchy or subsidiary structure.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:primaryServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Large enterprise accounts have primary service territories for account manager assignment, sales territory alignment, regional pricing model application, and coordinated service delivery across multi-' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:accountActivationDate rdf:type rdf:Property ;
    rdfs:label 'Account Activation Date' ;
    rdfs:comment 'Date when the corporate account was first activated and became operational for service delivery.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualRevenueRange rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Range' ;
    rdfs:comment 'Estimated annual revenue range of the corporate entity, used for account classification and opportunity sizing.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageRevenuePerMonth rdf:type rdf:Property ;
    rdfs:label 'Average Revenue Per Month' ;
    rdfs:comment 'Average monthly recurring revenue generated by this corporate account, calculated as total revenue divided by number of months active.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which this corporate account is billed and invoiced (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Government-issued business registration number, tax identification number, or company registration number used for legal and tax purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Next scheduled date for contract renewal negotiation or automatic renewal, used for proactive account management and retention planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerLifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Customer Lifetime Value' ;
    rdfs:comment 'Calculated total revenue value expected from this corporate account over the entire relationship lifetime, used for strategic account prioritization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Size classification of the corporate entity based on number of employees, used for segmentation and solution sizing.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the corporate headquarters street address including building number and street name.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the corporate headquarters address for suite, floor, or additional location details.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City or municipality where the corporate headquarters is located.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the corporate headquarters is located (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the corporate headquarters address.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the corporate headquarters is located.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'Primary industry sector or vertical market in which the corporate customer operates, used for segmentation and targeted offerings. [ENUM-REF-CANDIDATE: financial_services|healthcare|manufacturing|retail|government|education|technology|energy|transportation|hospitality|media|professional_services|construction|agriculture|other — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastServiceOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Order Date' ;
    rdfs:comment 'Date of the most recent service order placed by this corporate account, used for activity tracking and engagement analysis.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Most recent Net Promoter Score (-100 to +100) measuring the corporate account\'s likelihood to recommend services to other businesses.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the preferred language for communications, documentation, and support (e.g., en, es, fr).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Default payment method preferred by the corporate account for invoice settlement.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact for account-related communications, notifications, and escalations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the designated business contact at the corporate account.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Primary sales channel through which this corporate account was acquired and is managed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Tier' ;
    rdfs:comment 'Contracted SLA tier defining response times, uptime guarantees, and support levels for this corporate account.' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountSchemeId rdf:type rdf:Property ;
    rdfs:label 'Discount Scheme Id' ;
    rdfs:comment 'Primary key for discount_scheme' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'Product or service categories to which this discount scheme applies (e.g., \'SD-WAN Services\', \'MPLS Circuits\', \'Unified Communications\', \'IoT Solutions\', \'All Enterprise Services\'). [ENUM-REF-CANDIDATE: sd_wan|mpls|unified_communications|iot_solutions|managed_services|voice_services|data_services|cloud_services|security_services|all_services — promote to reference product]' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Fixed Amount' ;
    rdfs:comment 'Fixed monetary discount amount applied when discount_type is fixed_amount. Currency is defined by billing_currency_code.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied when discount_type is percentage-based. Expressed as a decimal (e.g., 15.00 for 15%).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism: percentage-based, fixed monetary amount, tiered based on usage or spend, volume-based, loyalty reward, or promotional campaign.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDiscountCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Cap' ;
    rdfs:comment 'Maximum total discount amount that can be applied under this scheme within a billing period, regardless of calculated discount. Null indicates no cap.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Threshold' ;
    rdfs:comment 'Minimum spend, usage volume, or contract value required to qualify for this discount scheme. Unit of measure defined by threshold_unit_of_measure.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationAllowed rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed' ;
    rdfs:comment 'Indicates whether the discount can be prorated for partial billing periods. True if proration is allowed, False if discount applies only to full periods.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalEligibility rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligibility' ;
    rdfs:comment 'Indicates whether the discount scheme is eligible for automatic renewal upon contract renewal. True if eligible, False if requires re-approval.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'Unique business identifier code for the discount scheme, used for external reference and integration with billing systems.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Description' ;
    rdfs:comment 'Detailed description of the discount scheme, including business rationale, eligibility criteria, and terms of application.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeName rdf:type rdf:Property ;
    rdfs:label 'Scheme Name' ;
    rdfs:comment 'Human-readable name of the discount scheme (e.g., \'Government Framework Pricing 2024\', \'Volume Discount Tier 3\', \'Strategic Account Loyalty Discount\').' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Status' ;
    rdfs:comment 'Current lifecycle status of the discount scheme: draft (under review), active (in effect), suspended (temporarily inactive), expired (past end date), or cancelled (terminated before expiry).' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingAllowed rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed' ;
    rdfs:comment 'Indicates whether this discount scheme can be combined (stacked) with other discount schemes on the same account. True if stacking is permitted, False if mutually exclusive.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackingRules rdf:type rdf:Property ;
    rdfs:label 'Stacking Rules' ;
    rdfs:comment 'Detailed rules governing how this discount scheme interacts with other discounts, including precedence, maximum combined discount caps, and exclusions.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum commitment threshold (e.g., currency amount, data volume in gigabytes, number of circuits, user seats, connected devices, or contract duration in months).' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Lower' ;
    rdfs:comment 'Lower bound of the usage or spend range for this tier. Applicable only to tiered discount schemes.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Upper' ;
    rdfs:comment 'Upper bound of the usage or spend range for this tier. Null indicates no upper limit. Applicable only to tiered discount schemes.' ;
    rdfs:domain ind:DiscountScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentContractEnterpriseContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Contract Enterprise Contract Id' ;
    rdfs:comment 'Reference to a parent or master contract when this contract is a subsidiary agreement, amendment, or task order. Enables contract hierarchy modeling.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseContract .

ind:agencyBillingCode rdf:type rdf:Property ;
    rdfs:label 'Agency Billing Code' ;
    rdfs:comment 'Government agency-specific billing or accounting code for invoice routing and payment processing. Required for government contract billing.' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of contract amendments or modifications. Zero for original contract. Increments with each formal change.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsClause rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Clause' ;
    rdfs:comment 'Full text of audit rights provisions allowing customer or regulatory inspection of service delivery, billing, and compliance records.' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingValue rdf:type rdf:Property ;
    rdfs:label 'Ceiling Value' ;
    rdfs:comment 'Maximum total contract value over the contract term. Mandatory for government contracts (GSA Schedule, G-Cloud). Nullable for commercial agreements.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level for contract terms and commercial information. Determines access controls and disclosure restrictions.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSovereigntyObligation rdf:type rdf:Property ;
    rdfs:label 'Data Sovereignty Obligation' ;
    rdfs:comment 'Contractual requirements for data residency, storage location, and cross-border data transfer restrictions. Critical for government and regulated industry contracts.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Discount Schedule Reference' ;
    rdfs:comment 'Reference to the pricing discount schedule or rate card applicable to this contract. Links to product catalog and billing rules.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed mechanism for resolving contractual disputes. Determines escalation path and legal procedures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foiaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Foia Compliance Flag' ;
    rdfs:comment 'Indicates whether contract terms and performance data are subject to FOIA disclosure requirements. Applies to US government contracts.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law for contract interpretation and dispute resolution. Critical for international agreements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentFrameworkType rdf:type rdf:Property ;
    rdfs:label 'Government Framework Type' ;
    rdfs:comment 'Specific government procurement framework or vehicle under which this contract was awarded. Null for non-government contracts.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentArr rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Arr' ;
    rdfs:comment 'Minimum annual recurring revenue commitment. Alternative or complementary to MRR for annual billing cycles.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentMrr rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Mrr' ;
    rdfs:comment 'Minimum monthly recurring revenue commitment by the enterprise customer. Used for revenue assurance and shortfall billing calculations.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mvnoHostAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Host Agreement Flag' ;
    rdfs:comment 'Indicates whether this contract is an MVNO host agreement where the telco provides wholesale network access to a virtual operator.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyClauseText rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Text' ;
    rdfs:comment 'Full text of contractual penalty clauses for service level breaches, early termination, or non-compliance. Legal reference for dispute resolution.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementVehicleCode rdf:type rdf:Property ;
    rdfs:label 'Procurement Vehicle Code' ;
    rdfs:comment 'Unique identifier for the government procurement vehicle or framework agreement. Required for government contract reporting and compliance.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days before expiry that renewal or termination notice must be provided. Contractual obligation for both parties.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Level of security clearance required for personnel servicing this contract. Mandatory for government and defense contracts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the authorized signatory who executed the contract on behalf of the enterprise customer. Legal record for contract validity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Job title or role of the signatory. Validates authority to bind the organization to contractual terms.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the contract was formally executed by all parties. Legal record for contract formation and statute of limitations.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taskOrderStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Task Order Structure Flag' ;
    rdfs:comment 'Indicates whether this contract uses a task order or call-off structure. Common in government IDIQ (Indefinite Delivery Indefinite Quantity) contracts.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wholesaleAgreementType rdf:type rdf:Property ;
    rdfs:label 'Wholesale Agreement Type' ;
    rdfs:comment 'Specific type of wholesale telecommunications agreement. Null for non-wholesale contracts.' ;
    rdfs:domain ind:EnterpriseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentContractId rdf:type rdf:Property ;
    rdfs:label 'Government Contract Id' ;
    rdfs:comment 'Unique identifier for the government contract record. Primary key for this entity.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Government contracts require dedicated program manager assignment for compliance oversight, delivery management, agency relationship management, and task order execution. Critical for federal/state co' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appropriationCode rdf:type rdf:Property ;
    rdfs:label 'Appropriation Code' ;
    rdfs:comment 'Government appropriation or budget line item code from which contract payments are funded, ensuring proper fiscal year and program alignment.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date on which the government officially awarded the contract to the service provider.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Base Period End Date' ;
    rdfs:comment 'End date of the initial base period of performance, after which option periods may be exercised at the government\'s discretion.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractBaseValue rdf:type rdf:Property ;
    rdfs:label 'Contract Base Value' ;
    rdfs:comment 'Initial contract value for the base period of performance, excluding option periods and potential modifications.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCeilingValue rdf:type rdf:Property ;
    rdfs:label 'Contract Ceiling Value' ;
    rdfs:comment 'Maximum total monetary value that can be obligated under this contract over its entire period of performance, including all options and modifications.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all financial transactions and billing under this government contract.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique contract number assigned by the government agency or procurement system. This is the business identifier used in all official correspondence and invoicing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Contracting Agency Code' ;
    rdfs:comment 'Standardized code identifying the government agency, such as Department of Defense (DOD), Department of Homeland Security (DHS), or UK Government Department codes.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Contracting Agency Name' ;
    rdfs:comment 'Full legal name of the government agency, department, or public sector entity that is the contracting party.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingOfficeName rdf:type rdf:Property ;
    rdfs:label 'Contracting Office Name' ;
    rdfs:comment 'Name of the specific contracting office or procurement unit within the agency responsible for administering this contract.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Contracting Officer Email' ;
    rdfs:comment 'Official email address of the contracting officer for contract-related communications and notifications.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Contracting Officer Name' ;
    rdfs:comment 'Full name of the government contracting officer who is the authorized representative for contract administration and modifications.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Contracting Officer Phone' ;
    rdfs:comment 'Direct phone number of the contracting officer for urgent contract matters and coordination.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Data Residency Requirements' ;
    rdfs:comment 'Detailed description of data residency, localization, and sovereignty obligations imposed by the government contract, including specific geographic restrictions and compliance mandates.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSovereigntyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Data Sovereignty Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating where contract-related data must be stored and processed to meet government data sovereignty requirements.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foiaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Foia Compliance Required' ;
    rdfs:comment 'Indicates whether contract records and communications are subject to Freedom of Information Act (FOIA) or equivalent public records disclosure requirements.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frameworkAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Framework Agreement Reference' ;
    rdfs:comment 'Reference to the overarching framework agreement under which this contract is issued, such as G-Cloud, Crown Commercial Service (CCS), General Services Administration (GSA) Schedule, or other government procurement vehicle.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent contract modification or amendment.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Total number of formal modifications or amendments issued to this contract since award.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code assigned to this contract identifying the primary industry classification for the services or products being procured.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Option Periods Count' ;
    rdfs:comment 'Total number of option periods available in the contract that the government may unilaterally exercise to extend the period of performance.' ;
    rdfs:domain ind:GovernmentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

