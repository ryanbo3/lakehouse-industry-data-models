    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether end-to-end encryption (IPsec, TLS, or proprietary) is enabled for data in transit over the managed service connection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Encryption protocol and version used to secure data transmission over the managed service connection.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv4Subnet rdf:type rdf:Property ;
    rdfs:label 'Ipv4 Subnet' ;
    rdfs:comment 'IPv4 subnet allocated to the customer for this managed service instance, in CIDR notation.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv6Subnet rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Subnet' ;
    rdfs:comment 'IPv6 subnet allocated to the customer for this managed service instance, in CIDR notation.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent planned maintenance activity performed on this managed service instance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date of the next scheduled maintenance activity for firmware updates, configuration changes, or hardware refresh.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nocMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Noc Monitoring Enabled' ;
    rdfs:comment 'Indicates whether this managed service instance is actively monitored by the Network Operations Center (NOC) for performance, availability, and fault detection.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proactiveMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Proactive Monitoring Enabled' ;
    rdfs:comment 'Indicates whether proactive monitoring and alerting is enabled, allowing the NOC to detect and remediate issues before customer impact.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redundancyType rdf:type rdf:Property ;
    rdfs:label 'Redundancy Type' ;
    rdfs:comment 'Type of redundancy configuration deployed for high availability: None, Active-Standby, Active-Active, or Geo-Redundant across multiple sites.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Next scheduled renewal date for the managed service contract, triggering renewal workflow and pricing review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingProtocol rdf:type rdf:Property ;
    rdfs:label 'Routing Protocol' ;
    rdfs:comment 'Dynamic routing protocol used between customer and provider networks: Border Gateway Protocol (BGP), Open Shortest Path First (OSPF), Enhanced Interior Gateway Routing Protocol (EIGRP), or Static routing.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceInstanceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Service Instance Identifier' ;
    rdfs:comment 'Business-facing unique identifier for the managed service instance, used in customer communications and service tickets.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Free-text field for operational notes, special instructions, escalation procedures, or customer-specific requirements related to this managed service.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle state of the managed service instance in the fulfillment and operations workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Service level tier defining the scope of management, support responsiveness, and feature set included in the managed service offering.' ;
    rdfs:domain ind:ManagedService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanTag rdf:type rdf:Property ;
    rdfs:label 'Vlan Tag' ;
    rdfs:comment 'Virtual Local Area Network (VLAN) identifier used for traffic segmentation and isolation on the managed service connection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solutionArchitectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Solution Architect Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: SD-WAN topology design requires solution architect ownership for design authority, technical governance, and architecture decisions. Critical for complex multi-site deployments, underlay/overlay desig' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backupUnderlayTransport rdf:type rdf:Property ;
    rdfs:label 'Backup Underlay Transport' ;
    rdfs:comment 'Secondary or backup physical transport technology for failover and redundancy. Common patterns include MPLS primary with broadband or LTE backup. [ENUM-REF-CANDIDATE: mpls|broadband|dedicated_internet|lte|5g|satellite|none|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cloudOnRampEnabled rdf:type rdf:Property ;
    rdfs:label 'Cloud On Ramp Enabled' ;
    rdfs:comment 'Indicates whether direct cloud connectivity (cloud on-ramp) is enabled for optimized access to public cloud providers (AWS, Azure, GCP) without backhauling through data center.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cloudProvidersIntegrated rdf:type rdf:Property ;
    rdfs:label 'Cloud Providers Integrated' ;
    rdfs:comment 'Comma-separated list of public cloud providers integrated with this topology for direct connectivity (e.g., \'AWS,Azure,GCP\'). Enables optimized cloud application performance.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current service contract for this topology expires. Triggers renewal or termination processes.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpeDeviceCount rdf:type rdf:Property ;
    rdfs:label 'Cpe Device Count' ;
    rdfs:comment 'Total number of CPE devices (physical or virtual) deployed across all sites in this topology. Each site typically has one or more CPE devices for SD-WAN edge functions.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptionKeyLength rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Length' ;
    rdfs:comment 'Length of the encryption key in bits (e.g., 128, 256). Longer keys provide stronger security but may impact performance. Common values are 128-bit (AES-128) and 256-bit (AES-256).' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Encryption Standard' ;
    rdfs:comment 'Encryption protocol used to secure overlay traffic between sites. IPsec is most common for site-to-site VPN; TLS for application-layer encryption; MACsec for layer-2 encryption; some vendors use proprietary encryption.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverMode rdf:type rdf:Property ;
    rdfs:label 'Failover Mode' ;
    rdfs:comment 'Failover behavior when primary underlay path fails. Active-active uses all paths simultaneously; active-standby keeps backup idle until primary fails; load-balanced distributes traffic across paths; manual requires operator intervention.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverThresholdLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Failover Threshold Latency Ms' ;
    rdfs:comment 'Maximum acceptable latency in milliseconds before triggering failover to backup path. Typical values range from 100ms to 500ms depending on application sensitivity.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverThresholdPacketLossPct rdf:type rdf:Property ;
    rdfs:label 'Failover Threshold Packet Loss Pct' ;
    rdfs:comment 'Maximum acceptable packet loss percentage before triggering failover to backup path. Typical values range from 1% to 5% depending on application tolerance.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firewallEnabled rdf:type rdf:Property ;
    rdfs:label 'Firewall Enabled' ;
    rdfs:comment 'Indicates whether stateful firewall inspection is enabled for traffic traversing this topology. Firewall rules control inter-site and internet-bound traffic based on source, destination, application, and user identity.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubSiteCount rdf:type rdf:Property ;
    rdfs:label 'Hub Site Count' ;
    rdfs:comment 'Number of hub sites in hub-and-spoke or hybrid topologies. Hub sites typically host centralized services (data centers, cloud on-ramps, security stacks) and aggregate traffic from spoke sites.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idsIpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Ids Ips Enabled' ;
    rdfs:comment 'Indicates whether intrusion detection and prevention capabilities are enabled. IDS/IPS inspects traffic for known attack signatures and anomalous behavior, blocking or alerting on threats.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internetBreakoutPolicy rdf:type rdf:Property ;
    rdfs:label 'Internet Breakout Policy' ;
    rdfs:comment 'Policy governing where internet-bound traffic exits to the public internet. Centralized routes all traffic through hub data center; local allows direct internet access at branch; hybrid or application-based routes by application type.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orchestrationPlatform rdf:type rdf:Property ;
    rdfs:label 'Orchestration Platform' ;
    rdfs:comment 'SD-WAN orchestration and management platform used to provision, configure, and monitor this topology. Determines available features, policy capabilities, and integration points. [ENUM-REF-CANDIDATE: cisco_viptela|vmware_velocloud|fortinet_fortimanager|silver_peak|versa_networks|citrix_sdwan|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orchestrationPlatformVersion rdf:type rdf:Property ;
    rdfs:label 'Orchestration Platform Version' ;
    rdfs:comment 'Software version of the orchestration platform managing this topology. Critical for feature compatibility, security patching, and support lifecycle management.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlayRoutingProtocol rdf:type rdf:Property ;
    rdfs:label 'Overlay Routing Protocol' ;
    rdfs:comment 'Routing protocol used within the SD-WAN overlay to exchange reachability information between sites. May be standard (BGP, OSPF) or vendor-proprietary.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryUnderlayTransport rdf:type rdf:Property ;
    rdfs:label 'Primary Underlay Transport' ;
    rdfs:comment 'Primary physical transport technology for this topology. Typically the highest-quality, lowest-latency path (e.g., MPLS for mission-critical traffic). [ENUM-REF-CANDIDATE: mpls|broadband|dedicated_internet|lte|5g|satellite|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosClassesConfigured rdf:type rdf:Property ;
    rdfs:label 'Qos Classes Configured' ;
    rdfs:comment 'Number of distinct QoS classes (traffic classes) configured in this topology. Typical enterprise deployments use 4-8 classes (e.g., real-time voice, interactive video, business-critical data, best-effort).' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qosProfileName rdf:type rdf:Property ;
    rdfs:label 'Qos Profile Name' ;
    rdfs:comment 'Name of the QoS profile applied to this topology. QoS profiles define traffic classification, prioritization, queuing, and bandwidth allocation rules to ensure service level objectives for critical applications (e.g., voice, video, ERP).' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityPolicyName rdf:type rdf:Property ;
    rdfs:label 'Security Policy Name' ;
    rdfs:comment 'Name of the security policy applied to this topology. Security policies define firewall rules, intrusion detection/prevention settings, URL filtering, malware protection, and data loss prevention controls.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCount rdf:type rdf:Property ;
    rdfs:label 'Site Count' ;
    rdfs:comment 'Total number of enterprise sites (locations) participating in this SD-WAN topology. Includes hub sites, spoke sites, and any branch or remote office locations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaJitterTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Jitter Target Ms' ;
    rdfs:comment 'Maximum acceptable latency variation (jitter) in milliseconds as defined in the SLA. Critical for real-time applications like voice and video conferencing.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Maximum acceptable round-trip latency in milliseconds as defined in the SLA. Typically measured between hub and spoke sites or between critical site pairs.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaPacketLossTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Packet Loss Target Pct' ;
    rdfs:comment 'Maximum acceptable packet loss percentage as defined in the SLA. Typical enterprise SLAs guarantee less than 0.1% to 1% packet loss.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spokeSiteCount rdf:type rdf:Property ;
    rdfs:label 'Spoke Site Count' ;
    rdfs:comment 'Number of spoke sites (branch offices, remote locations) in hub-and-spoke or hybrid topologies. Spoke sites typically connect to hub sites for centralized services and internet breakout.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:topologyDesignType rdf:type rdf:Property ;
    rdfs:label 'Topology Design Type' ;
    rdfs:comment 'Logical design pattern of the SD-WAN topology. Hub-and-spoke centralizes traffic through hub sites; full-mesh provides direct connectivity between all sites; partial-mesh selectively connects high-traffic site pairs; point-to-point connects two sites; hybrid combines multiple patterns.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topologyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Topology Identifier' ;
    rdfs:comment 'External business identifier or code for this topology, used in customer-facing documentation, service orders, and billing. May be customer-provided or system-generated.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topologyName rdf:type rdf:Property ;
    rdfs:label 'Topology Name' ;
    rdfs:comment 'Business-friendly name for this SD-WAN topology configuration, typically reflecting the customer organization or deployment scope (e.g., \'Global HQ Mesh\', \'Regional Hub-Spoke\').' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topologyStatus rdf:type rdf:Property ;
    rdfs:label 'Topology Status' ;
    rdfs:comment 'Current operational status of this SD-WAN topology. Active indicates fully operational; provisioning indicates deployment in progress; suspended indicates temporary service hold; decommissioning indicates teardown in progress.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSteeringPolicy rdf:type rdf:Property ;
    rdfs:label 'Traffic Steering Policy' ;
    rdfs:comment 'Policy governing how the SD-WAN controller steers traffic across available underlay paths. Application-aware uses deep packet inspection to route by application; latency/bandwidth/cost-based optimize for specific metrics; manual uses static rules.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlayTransportTypes rdf:type rdf:Property ;
    rdfs:label 'Underlay Transport Types' ;
    rdfs:comment 'Comma-separated list of physical transport technologies used as underlay for this SD-WAN overlay (e.g., \'MPLS,Broadband,LTE\'). Underlay diversity enables path redundancy and failover.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urlFilteringEnabled rdf:type rdf:Property ;
    rdfs:label 'Url Filtering Enabled' ;
    rdfs:comment 'Indicates whether URL filtering (web content filtering) is enabled to block access to malicious, inappropriate, or non-business websites based on category and reputation.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vcpeUcpeDeploymentModel rdf:type rdf:Property ;
    rdfs:label 'Vcpe Ucpe Deployment Model' ;
    rdfs:comment 'Deployment model for customer premises equipment. vCPE runs network functions as virtual machines on generic hardware; uCPE is a physical appliance hosting multiple virtualized functions; hybrid combines both; none indicates traditional dedicated appliances.' ;
    rdfs:domain ind:SdwanTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountManagementModel rdf:type rdf:Property ;
    rdfs:label 'Account Management Model' ;
    rdfs:comment 'Customer relationship management approach assigned to this segment. Self-service for digital-only interaction, inside sales for phone-based support, dedicated account manager for personalized service, strategic account team for multi-stakeholder engagement, partner-managed for channel-driven accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskThreshold rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Threshold' ;
    rdfs:comment 'Churn risk score threshold (0-100 scale) above which accounts in this segment trigger retention intervention workflows. Lower thresholds indicate more proactive retention strategies for high-value segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractTermMinimumMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Minimum Months' ;
    rdfs:comment 'Minimum contract commitment period in months required for accounts in this segment. Longer terms may qualify for better pricing. Null if segment has no minimum term requirement.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractTermStandardMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Standard Months' ;
    rdfs:comment 'Standard contract duration in months typically offered to accounts in this segment. Represents the most common commitment period for this customer class.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether credit verification is mandatory for new accounts in this segment during onboarding. True for segments requiring financial vetting, false for pre-approved segments such as government or established enterprise relationships.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is required for new accounts in this segment. True for higher-risk segments or those with limited credit history, false for established enterprise segments with strong credit profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountTier rdf:type rdf:Property ;
    rdfs:label 'Discount Tier' ;
    rdfs:comment 'Standard discount tier available to accounts in this segment. Higher tiers receive greater discounts on products and services. Custom tier indicates individually negotiated discount structures for strategic accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goToMarketStrategy rdf:type rdf:Property ;
    rdfs:label 'Go To Market Strategy' ;
    rdfs:comment 'Primary sales and distribution approach for acquiring and serving accounts in this segment. Direct sales uses internal sales force, channel partner leverages resellers and agents, hybrid combines both, digital-only uses web-based acquisition, strategic alliance involves co-selling with technology partners.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVerticalFilter rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical Filter' ;
    rdfs:comment 'Comma-separated list of industry vertical codes that qualify for this segment. Used for vertical-based segmentation. Examples: FINANCE, HEALTHCARE, MANUFACTURING, GOVERNMENT, EDUCATION. Null if segment is not restricted by industry vertical.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Maximum Annual Revenue' ;
    rdfs:comment 'Maximum annual revenue threshold in base currency for an enterprise account to qualify for this segment. Defines upper bound for revenue band. Null if segment has no upper revenue limit or does not use revenue criteria.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Employee Count' ;
    rdfs:comment 'Maximum number of employees for an enterprise account to qualify for this segment. Defines upper bound for size band. Null if segment has no upper employee limit or does not use employee count criteria.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Revenue' ;
    rdfs:comment 'Minimum annual revenue threshold in base currency for an enterprise account to qualify for this segment. Used for revenue-based segmentation. Null if segment does not use revenue criteria.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Employee Count' ;
    rdfs:comment 'Minimum number of employees for an enterprise account to qualify for this segment. Used for size-based segmentation. Null if segment does not use employee count criteria.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Business unit, department, or executive role responsible for strategy and performance of this segment. Examples: Enterprise Sales VP, Government Sales Director, Mid-Market Business Unit, Wholesale Operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Financial and operational reporting category for revenue and performance metrics aggregation. Used for executive dashboards, regulatory filings, and investor reporting. Examples: Enterprise, Business, Government, Wholesale.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Criteria' ;
    rdfs:comment 'Business rules defining which services and solutions are available to accounts in this segment. May include eligibility for Software-Defined Wide Area Network (SD-WAN), Multiprotocol Label Switching (MPLS), dedicated fiber, unified communications, Internet of Things (IoT) platforms, managed security services, and premium Service Level Agreement (SLA) tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportChannelAccess rdf:type rdf:Property ;
    rdfs:label 'Support Channel Access' ;
    rdfs:comment 'Comma-separated list of support channels available to accounts in this segment. May include web portal, mobile app, phone support, email, chat, dedicated hotline, on-site support, Network Operations Center (NOC) direct access, and technical account manager.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerLifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Target Customer Lifetime Value' ;
    rdfs:comment 'Expected Customer Lifetime Value in base currency for accounts in this segment over a standard planning horizon. Used for investment prioritization and customer acquisition cost justification. Null if not calculated for this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upsellPriority rdf:type rdf:Property ;
    rdfs:label 'Upsell Priority' ;
    rdfs:comment 'Priority level for proactive upsell and cross-sell campaigns targeting accounts in this segment. Critical priority segments receive dedicated sales resources and personalized offers. Low priority segments receive automated digital campaigns only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Enterprise sites require employee contact assignment for field operations, dispatch coordination, and site access management. Site contacts are typically field technicians or site managers who serve a' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Detailed instructions for field technicians to access the site, including security procedures, parking, and entry points.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthRequirementMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Requirement Mbps' ;
    rdfs:comment 'Required bandwidth capacity for the site measured in megabits per second, used for circuit provisioning and SD-WAN (Software-Defined Wide Area Network) design.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingType rdf:type rdf:Property ;
    rdfs:label 'Building Type' ;
    rdfs:comment 'Physical building classification affecting infrastructure deployment and access procedures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHours rdf:type rdf:Property ;
    rdfs:label 'Business Hours' ;
    rdfs:comment 'Standard operating hours for the site, used for scheduling maintenance and support activities.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeInventoryReference rdf:type rdf:Property ;
    rdfs:label 'Cpe Inventory Reference' ;
    rdfs:comment 'Reference identifier linking to the inventory of CPE (Customer Premises Equipment) deployed at this site, such as routers, switches, and ONT (Optical Network Terminal) devices.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disasterRecoveryTier rdf:type rdf:Property ;
    rdfs:label 'Disaster Recovery Tier' ;
    rdfs:comment 'Disaster recovery classification indicating backup and failover requirements for business continuity planning.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Specific floor or level within the building where equipment is located, used for field dispatch instructions.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when services were first installed and activated at this site.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:is24x7Operation rdf:type rdf:Property ;
    rdfs:label 'Is 24x7 Operation' ;
    rdfs:comment 'Flag indicating whether the site operates continuously around the clock, affecting maintenance window planning.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfUsers rdf:type rdf:Property ;
    rdfs:label 'Number Of Users' ;
    rdfs:comment 'Total count of end users or employees at this site, used for capacity planning and service dimensioning.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceType rdf:type rdf:Property ;
    rdfs:label 'Primary Service Type' ;
    rdfs:comment 'Primary telecommunications service delivered to this site (SD-WAN: Software-Defined Wide Area Network, MPLS: Multiprotocol Label Switching, IoT: Internet of Things).' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Externally-known unique business identifier for the site, used in service orders and field dispatch.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the site (e.g., \'Headquarters Building A\', \'Chicago Branch Office\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the site indicating its operational state.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site based on its business function and infrastructure requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaZone rdf:type rdf:Property ;
    rdfs:label 'Sla Zone' ;
    rdfs:comment 'Geographic service zone classification used for SLA (Service Level Agreement) response time calculations and field dispatch routing.' ;
    rdfs:domain ind:EnterpriseSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the site location, used for scheduling maintenance windows and SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Primary key for sla_breach' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enterpriseCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Customer Account Id' ;
    rdfs:comment 'Reference to the enterprise customer account affected by the SLA breach. Identifies the B2B customer experiencing the service degradation.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:enterpriseSlaContractId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Sla Contract Id' ;
    rdfs:comment 'Reference to the SLA contract that was breached. Links to the enterprise SLA contract defining the service level commitments.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaContract .

ind:enterpriseSlaMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Sla Measurement Id' ;
    rdfs:comment 'Foreign key linking to enterprise.sla_measurement. Business justification: SLA breaches are triggered by SLA measurements that fall below contracted thresholds. This FK links each breach event to the specific measurement that triggered it, enabling root cause analysis, measu' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseSlaMeasurement .

ind:resolutionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Resolution Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: SLA breaches require clear resolution ownership for accountability, escalation management, and root cause remediation. Distinct from ticket owner - tracks the senior engineer/manager responsible for b' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualMetricValue rdf:type rdf:Property ;
    rdfs:label 'Actual Metric Value' ;
    rdfs:comment 'The actual measured value of the SLA metric during the breach period. Represents the degraded performance level that triggered the breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedServiceComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Service Component' ;
    rdfs:comment 'Specific service component or network element that experienced the degradation leading to the SLA breach (e.g., router, circuit, application server, SD-WAN edge device).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Detected Timestamp' ;
    rdfs:comment 'Timestamp when the SLA breach was first detected by monitoring systems. Represents the real-world event time when the service metric fell below the contracted threshold.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Breach Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the SLA breach event. Used in customer communications, credit memos, and escalation workflows. Format: SLB-XXXXXXXXXX.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTerminationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Termination Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether the SLA breach (or pattern of breaches) creates a risk of contract termination by the enterprise customer. Triggers executive engagement and retention actions.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Credit Calculation Method' ;
    rdfs:comment 'Method used to calculate the SLA credit amount as defined in the enterprise SLA contract. Determines how breach duration and severity translate to monetary compensation.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the SLA credit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Enterprise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether the SLA credit has been issued to the customer account. True if credit has been applied, false if pending or waived.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Timestamp' ;
    rdfs:comment 'Timestamp when the SLA credit was issued to the customer billing account. Null if credit has not yet been issued.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Flag' ;
    rdfs:comment 'Boolean flag indicating whether the enterprise customer has acknowledged receipt of the SLA breach notification. Used for audit trail and dispute prevention.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgment Timestamp' ;
    rdfs:comment 'Timestamp when the enterprise customer acknowledged the SLA breach notification. Null if not yet acknowledged.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Status of customer notification regarding the SLA breach. Tracks whether the enterprise customer has been informed of the breach and credit eligibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Timestamp' ;
    rdfs:comment 'Timestamp when the enterprise customer was notified of the SLA breach. Used to track compliance with contractual notification requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Customer-provided reason for disputing the SLA breach. Captures customer perspective on measurement accuracy, threshold interpretation, or credit calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedLocationCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Location Count' ;
    rdfs:comment 'Number of enterprise customer locations affected by the SLA breach. Used for impact assessment and credit calculation for multi-site services.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repeatBreachCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Breach Count' ;
    rdfs:comment 'Count of previous breaches of the same SLA metric for this service instance within the current measurement period. Used for trend analysis and contract review triggers.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repeatBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Breach Flag' ;
    rdfs:comment 'Boolean flag indicating whether this is a repeat breach of the same SLA metric for the same service instance within a defined time window. Triggers enhanced escalation and remediation.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Resolution Reference Number' ;
    rdfs:comment 'Reference number for the resolution action or change request that addressed the root cause of the SLA breach. Links to change management or problem management records.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value breached (failed to meet) the target value for this measurement period. True indicates a breach occurred; False indicates target was met or exceeded.' ;
    rdfs:domain ind:EnterpriseSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditEntitlementAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Entitlement Amount' ;
    rdfs:comment 'The monetary credit amount (in contract currency) that the enterprise customer is entitled to receive as compensation for this SLA breach, calculated according to the credit schedule defined in the SLA contract.' ;
    rdfs:domain ind:EnterpriseSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Applied Flag' ;
    rdfs:comment 'Indicates whether any contractual exclusions were applied to this measurement (e.g., planned maintenance windows, force majeure events, customer-caused outages). True if exclusions were applied; False otherwise.' ;
    rdfs:domain ind:EnterpriseSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to capture the SLA metric. Options include automated network probes, synthetic transactions, passive traffic monitoring, customer-reported incidents, or manual calculation from operational data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The business reporting period to which this measurement belongs (e.g., 2024-Q1, 2024-03, Week-12-2024). Used for aggregating measurements into periodic SLA reports and dashboards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'The user ID or name of the operations staff member who validated this SLA measurement. Null for automated validations. Provides accountability and audit trail.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The date and time when this SLA measurement was validated and approved for reporting. Null if not yet validated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ticketId rdf:type rdf:Property ;
    rdfs:label 'Ticket Id' ;
    rdfs:comment 'Unique identifier for the enterprise support ticket. Primary key for the ticket entity.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitId rdf:type rdf:Property ;
    rdfs:label 'Circuit Id' ;
    rdfs:comment 'Unique identifier of the network circuit affected by the issue. Used for rapid technical troubleshooting and network operations coordination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Circuit .

ind:relatedChangeChangeRecordId rdf:type rdf:Property ;
    rdfs:label 'Related Change Change Record Id' ;
    rdfs:comment 'Reference to a change record if this ticket requires or resulted from a network or service configuration change.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeRecord .

ind:ticketEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ticket Employee Id' ;
    rdfs:comment 'Reference to the support engineer or technical account manager currently assigned to work on this ticket.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ticketTechnicalAccountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ticket Technical Account Manager Employee Id' ;
    rdfs:comment 'Reference to the dedicated Technical Account Manager assigned to this enterprise customer. TAM provides oversight and escalation management for high-priority tickets.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Response Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from ticket creation to first response by support team. Used for SLA performance measurement.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedUserCount rdf:type rdf:Property ;
    rdfs:label 'Affected User Count' ;
    rdfs:comment 'Number of end users at the enterprise customer site impacted by the issue. Used for severity assessment and resource allocation.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team' ;
    rdfs:comment 'Name of the support team or technical group currently responsible for this ticket. Used for workload distribution and escalation routing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the customer after ticket resolution. Used for service improvement and quality assurance.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Post-resolution customer satisfaction rating provided by the enterprise contact. Typically on a 1-5 scale used for service quality measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the support team provided the first substantive response to the customer. Used for SLA response time compliance measurement.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedByEmail rdf:type rdf:Property ;
    rdfs:label 'Reported By Email' ;
    rdfs:comment 'Email address of the enterprise customer contact who reported the issue. Used for ticket updates and resolution notifications.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the enterprise customer contact who reported the issue or opened the ticket.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByPhone rdf:type rdf:Property ;
    rdfs:label 'Reported By Phone' ;
    rdfs:comment 'Contact phone number of the enterprise customer contact who reported the issue for urgent escalations and callbacks.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Target Minutes' ;
    rdfs:comment 'Contracted maximum time in minutes for issue resolution based on priority and SLA tier. Used for SLA compliance tracking and breach detection.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target Minutes' ;
    rdfs:comment 'Contracted maximum time in minutes for initial response to the customer based on priority and SLA tier. Used for SLA compliance tracking.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed classification within the primary category for granular issue tracking and knowledge base routing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Tam Involved Flag' ;
    rdfs:comment 'Indicator whether the Technical Account Manager has been engaged in this ticket for escalation or customer relationship management.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ticketDescription rdf:type rdf:Property ;
    rdfs:label 'Ticket Description' ;
    rdfs:comment 'Detailed description of the issue, symptoms, and business impact as reported by the customer or documented by the support agent.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle status of the support ticket in the enterprise workflow. Tracks progression from initial submission through resolution and closure. [ENUM-REF-CANDIDATE: new|assigned|in_progress|pending_customer|pending_vendor|resolved|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundApplied rdf:type rdf:Property ;
    rdfs:label 'Workaround Applied' ;
    rdfs:comment 'Description of any temporary workaround implemented to restore service while permanent resolution is in progress.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Uc Subscription Id' ;
    rdfs:comment 'Unique identifier for the Unified Communications subscription record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UcSubscription .

ind:provisioningEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: UC platform provisioning requires specialized engineer assignment for implementation, SIP trunk configuration, DID porting, and technical delivery. Tracks technical ownership for provisioning lifecycl' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency of billing for this subscription: monthly, quarterly, annual, or custom interval.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callRecordingEnabled rdf:type rdf:Property ;
    rdfs:label 'Call Recording Enabled' ;
    rdfs:comment 'Indicates whether call recording capability is enabled for this subscription (True) or not (False). Used for compliance, quality assurance, and training.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callRecordingRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Call Recording Retention Days' ;
    rdfs:comment 'Number of days call recordings are retained before automatic deletion. Null if call recording is not enabled.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the subscription was cancelled or terminated. Null for active subscriptions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:didCount rdf:type rdf:Property ;
    rdfs:label 'Did Count' ;
    rdfs:comment 'Total number of DID numbers allocated to this subscription.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:didNumberBlockEnd rdf:type rdf:Property ;
    rdfs:label 'Did Number Block End' ;
    rdfs:comment 'Ending phone number of the DID block assigned to this UC subscription for inbound calling.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:didNumberBlockStart rdf:type rdf:Property ;
    rdfs:label 'Did Number Block Start' ;
    rdfs:comment 'Starting phone number of the DID block assigned to this UC subscription for inbound calling.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:e911Enabled rdf:type rdf:Property ;
    rdfs:label 'E911 Enabled' ;
    rdfs:comment 'Indicates whether Enhanced 911 emergency calling service is enabled for this subscription (True) or not (False). Required for VoIP services in many jurisdictions.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:e911RegisteredAddress rdf:type rdf:Property ;
    rdfs:label 'E911 Registered Address' ;
    rdfs:comment 'Full address registered with E911 services for emergency response dispatch. May differ from service address for mobile/remote workers.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featurePack rdf:type rdf:Property ;
    rdfs:label 'Feature Pack' ;
    rdfs:comment 'Service tier or feature bundle included in the subscription: basic (core calling), standard (calling + voicemail), premium (calling + collaboration), or enterprise (full suite with advanced features).' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current status of the third-party integration: active (operational), inactive (disabled), pending (configuration in progress), failed (integration error), or not applicable (standalone subscription).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Third-party platform or CRM system integrated with the UC subscription: Microsoft Teams, Cisco Webex, Zoom, Google Workspace, Salesforce, standalone (no integration), or custom integration. [ENUM-REF-CANDIDATE: microsoft_teams|cisco_webex|zoom|google_workspace|salesforce|standalone|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyRecurringRevenue rdf:type rdf:Property ;
    rdfs:label 'Monthly Recurring Revenue' ;
    rdfs:comment 'Total monthly recurring revenue for this subscription, calculated as seat count multiplied by monthly seat charge plus any fixed platform fees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlySeatCharge rdf:type rdf:Property ;
    rdfs:label 'Monthly Seat Charge' ;
    rdfs:comment 'Recurring monthly charge per user seat in the subscription currency. Does not include usage-based charges or one-time fees.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisioningCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Provisioning Completed Timestamp' ;
    rdfs:comment 'Date and time when technical provisioning was successfully completed and the service became operational.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qosClass rdf:type rdf:Property ;
    rdfs:label 'Qos Class' ;
    rdfs:comment 'Network quality of service tier assigned to this subscription for traffic prioritization and performance guarantees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatCount rdf:type rdf:Property ;
    rdfs:label 'Seat Count' ;
    rdfs:comment 'Number of licensed user seats or concurrent users provisioned under this UC subscription.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sipTrunkCapacity rdf:type rdf:Property ;
    rdfs:label 'Sip Trunk Capacity' ;
    rdfs:comment 'Maximum number of concurrent SIP trunk channels provisioned for voice calls. Null if SIP trunking is not part of the subscription.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Externally-visible business identifier for the UC subscription, used in customer communications and billing.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the UC subscription: active (in service), suspended (temporarily disabled), pending activation (ordered but not yet live), pending cancellation (termination requested), cancelled (terminated), or expired (contract ended).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucPlatformType rdf:type rdf:Property ;
    rdfs:label 'Uc Platform Type' ;
    rdfs:comment 'Type of UC platform provisioned: hosted PBX, SIP trunking, UCaaS (Unified Communications as a Service), CCaaS (Contact Center as a Service), video conferencing, or collaboration suite.' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimePercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Uptime Percentage Target' ;
    rdfs:comment 'Contractual uptime percentage target for the UC service (e.g., 99.90 for 99.9% uptime SLA).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voipCodec rdf:type rdf:Property ;
    rdfs:label 'Voip Codec' ;
    rdfs:comment 'Audio codec used for voice compression and transmission: G.711 (uncompressed), G.729 (compressed), Opus (adaptive), or G.722 (wideband).' ;
    rdfs:domain ind:UcSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable record. Primary key for the accounts receivable entity.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Reference to the payment plan agreement if this receivable is being paid in installments. Null if not on a payment plan.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:arDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Document Number' ;
    rdfs:comment 'External business identifier for the accounts receivable document. Used for reconciliation and reporting purposes.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the accounts receivable record. Indicates whether the receivable is open, paid, disputed, or written off. [ENUM-REF-CANDIDATE: open|partially_paid|paid|written_off|disputed|under_collection|credit_applied|reversed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badDebtProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Provision Amount' ;
    rdfs:comment 'Amount reserved as allowance for doubtful accounts for this receivable. Used for financial statement preparation and EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) analysis.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Reference date used to calculate the payment due date based on payment terms. Typically the invoice date or goods receipt date.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Business segment or line of business that generated this receivable. Used for segment reporting and revenue analysis by product line.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Code' ;
    rdfs:comment 'Reference to the external collection agency assigned to this receivable if escalated to third-party collections. Null if managed internally.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of collection activities for this receivable. Indicates whether the account is under active collection, on a payment plan, or in legal proceedings.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity or company code that owns this receivable. Used for financial consolidation and intercompany reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Amount' ;
    rdfs:comment 'Total amount of credit memos applied to reduce this receivable balance. Includes service credits, billing adjustments, and promotional credits.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date when the most recent dunning notice or collection communication was sent to the customer for this receivable.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'Total amount of the original invoice before any payments, credits, or adjustments. Represents the initial receivable balance.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether this receivable is part of a structured payment plan or installment agreement. True if customer is on a payment plan, false otherwise.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms applicable to this receivable (e.g., NET30, NET60, due on receipt). Determines the due date calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when this receivable was last reconciled with the billing system. Used for audit trail and revenue assurance reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of reconciliation between AR records and billing system invoices. Used for revenue assurance and financial controls.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of the revenue type that generated this receivable. Distinguishes between service charges, equipment sales, usage fees, and other revenue streams.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Code indicating the reason for writing off the receivable (e.g., bankruptcy, uncollectible, customer deceased, small balance). Used for bad debt analysis.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Asset Transaction Id' ;
    rdfs:comment 'Unique identifier for the asset transaction record. Primary key for the asset transaction entity.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset that is the subject of this transaction. Links to the master asset record in the asset register.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to finance.purchase_order. Business justification: Asset acquisition transaction may reference a purchase order for procurement tracking. N:1 relationship (many asset transactions can reference one PO). The purchase_order_id FK will link to purchase_o' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification code grouping assets with similar characteristics, depreciation methods, and useful lives. Examples include buildings, network infrastructure, vehicles, IT equipment. Determines default depreciation parameters and account assignments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'Sub-asset identifier used when a main asset is divided into multiple components for separate depreciation tracking. Enables component-based accounting for complex assets such as buildings with separately depreciable components (structure, HVAC, elevators).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValueDate rdf:type rdf:Property ;
    rdfs:label 'Asset Value Date' ;
    rdfs:comment 'The effective date from which the asset transaction impacts depreciation calculations and asset valuation. For acquisitions, this is the capitalization date when depreciation begins; for retirements, this is when depreciation ceases. Critical for accurate depreciation computation.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The organizational unit responsible for the asset and its associated costs. Used for internal cost allocation, OPEX tracking, and management reporting. Links asset transactions to operational responsibility centers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Two-digit code identifying the valuation view for the asset transaction. Area 01 typically represents book depreciation for financial reporting; area 15 represents tax depreciation; area 20 represents cost accounting depreciation. Enables parallel valuation for different reporting purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gain Loss Amount' ;
    rdfs:comment 'The calculated gain or loss on asset disposal, computed as retirement proceeds minus net book value. Positive values represent gains; negative values represent losses. Posted to income statement and impacts EBITDA calculation.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'The general ledger account number to which the asset transaction is posted. For acquisitions, typically an asset account; for depreciation, an accumulated depreciation or expense account; for retirements, a gain/loss account. Ensures proper financial statement classification.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'Internal order number used for tracking costs related to specific initiatives, maintenance activities, or short-term projects. Enables cost collection for asset-related activities before capitalization or for OPEX expense tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the company code local currency using the exchange rate effective on the transaction date. Used for statutory financial reporting and consolidation.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetAccount rdf:type rdf:Property ;
    rdfs:label 'Offset Account' ;
    rdfs:comment 'The contra general ledger account for double-entry bookkeeping. For asset acquisitions, typically accounts payable or cash; for depreciation, accumulated depreciation; for retirements, asset clearing account. Completes the accounting entry pair.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting period date when the transaction was posted to the general ledger. Used for period closing and financial statement preparation. May differ from transaction date due to timing of accounting entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'The accounting period number within the fiscal year when the transaction was posted. Typically 1-12 for monthly periods, with additional special periods (13-16) for year-end adjustments and closing entries.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The business segment or profit-responsible unit to which the asset is assigned. Used for segment reporting, EBITDA analysis, and profitability evaluation. Enables financial performance measurement by business line.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The physical quantity of assets involved in the transaction. Used for assets managed in quantity units such as vehicles, network equipment units, or infrastructure components. Enables unit-based asset tracking and partial retirement processing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference number linking the asset transaction to source documents such as purchase orders, vendor invoices, project completion reports, or disposal authorizations. Provides audit trail to supporting documentation.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey rdf:type rdf:Property ;
    rdfs:label 'Reference Key' ;
    rdfs:comment 'Three-character code classifying the type of reference document. Examples include PO for purchase order, INV for invoice, PRJ for project. Used for categorizing transaction source documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementProceeds rdf:type rdf:Property ;
    rdfs:label 'Retirement Proceeds' ;
    rdfs:comment 'The cash or fair value received from disposal of the asset. Used to calculate gain or loss on disposal by comparing to net book value. Populated for sale and trade-in retirement transactions.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Classification of why the asset was retired or disposed. Sale represents disposal with proceeds; scrap represents disposal without value; donation represents charitable transfer; theft represents involuntary loss; obsolescence represents technological replacement; transfer represents movement to another entity. Used for asset lifecycle analysis and disposal reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this transaction reverses a previous asset transaction. True when the transaction is a correction or cancellation of an earlier posting. Used for audit trail and error correction tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The original document number being reversed by this transaction. Populated when reversal_indicator is true. Provides linkage between reversal and original transaction for reconciliation and audit purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the asset transaction in the company code currency. For acquisitions, represents capitalized cost; for retirements, represents net book value disposed; for depreciation, represents periodic expense; for revaluations, represents adjustment amount. Positive values increase asset value; negative values decrease asset value.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the transaction amount is denominated. Used for foreign currency translation and multi-currency reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date on which the asset transaction occurred or became effective. This is the value date for financial reporting and represents when the economic event took place, distinct from the posting date when it was recorded in the system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionText rdf:type rdf:Property ;
    rdfs:label 'Transaction Text' ;
    rdfs:comment 'Free-form descriptive text providing additional context about the asset transaction. May include details such as asset description, reason for transaction, approval references, or special handling notes. Used for documentation and audit support.' ;
    rdfs:domain ind:AssetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project structure element identifier for CAPEX projects. Links asset acquisitions to capital investment projects for project accounting, budget tracking, and ROI analysis. Used when assets are capitalized from project activities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account master record in SAP S/4HANA treasury management. Primary key for the bank account entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:cashPoolId rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Id' ;
    rdfs:comment 'Identifier linking this bank account to a cash pooling arrangement. Cash pooling enables centralized liquidity management by consolidating balances across multiple accounts for interest optimization and overdraft protection.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashPool .

ind:houseBankId rdf:type rdf:Property ;
    rdfs:label 'House Bank Id' ;
    rdfs:comment 'Internal identifier for the house bank in SAP S/4HANA. House banks are the primary banking partners used for payment processing, cash management, and treasury operations. Links to the house bank master data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HouseBank .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'The date when the bank account was closed with the financial institution. Null for active accounts. Used for historical reporting and account lifecycle management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the native currency of the bank account. All transactions in this account are denominated in this currency. Critical for multi-currency treasury operations and foreign exchange management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the entity that holds the bank account as registered with the financial institution. Typically matches the company legal name for corporate accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountIdSap rdf:type rdf:Property ;
    rdfs:label 'Account Id Sap' ;
    rdfs:comment 'Five-character alphanumeric account identifier within the house bank structure in SAP S/4HANA. Used in payment programs, bank statement processing, and cash position reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'The date when the bank account was originally opened with the financial institution. Used for relationship tracking and historical analysis.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Free-text description of the business purpose or use case for this bank account (e.g., payroll disbursements, vendor payments, customer collections, tax payments, intercompany settlements). Used for treasury reporting and account rationalization.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatories rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatories' ;
    rdfs:comment 'Comma-separated list of employee IDs or names authorized to approve payments and transactions from this bank account. Used for dual-control enforcement and audit trail. Confidential due to internal control sensitivity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReconciliationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Reconciliation Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automated bank reconciliation is enabled for this account. When true, SAP S/4HANA automatically matches bank statement lines to open GL items using matching rules and algorithms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The balance available for immediate use after accounting for holds, pending transactions, and reserve requirements. Critical for payment processing and overdraft prevention.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The unique account number assigned by the financial institution. This is the primary account identifier used for all banking transactions, electronic bank statements, and payment processing. Restricted due to financial sensitivity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific branch or office of the financial institution where the account is domiciled. Relevant for regional banking relationships and local cash management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter ISO country code identifying the country where the bank account is domiciled. Critical for regulatory reporting, tax compliance, and cross-border payment routing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Unique identifier for the financial institution in the bank directory. In US context this is the ABA routing number; in European context this is the national bank code. Used for payment processing and bank statement reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full legal name of the financial institution where the account is held. Used for reporting, reconciliation, and correspondence.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolType rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Type' ;
    rdfs:comment 'Classification of the cash pooling structure this account participates in. Physical pooling involves actual fund transfers; notional pooling calculates interest on aggregated balances without transfers; zero-balance accounts sweep funds daily; target-balance accounts maintain specified levels.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicFormat rdf:type rdf:Property ;
    rdfs:label 'Electronic Format' ;
    rdfs:comment 'The electronic file format used for importing bank statements into SAP S/4HANA. MT940 and CAMT.053 are international standards; BAI2 is common in North America; MT942 is for interim statements; proprietary formats are bank-specific.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number used for cross-border payments and SEPA transactions. Mandatory for European banking operations and increasingly used globally for international wire transfers.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'The method used by the financial institution to calculate interest on this account. Daily balance calculates interest on end-of-day balances; average balance uses the period average; tiered applies different rates to balance ranges; none indicates non-interest-bearing accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to this bank account, expressed as a decimal (e.g., 0.0250 for 2.50%). Used for interest accrual calculations and cash flow forecasting. May be positive for deposit accounts or negative for overdraft facilities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the most recent bank reconciliation was completed for this account. Used to monitor reconciliation timeliness and compliance with internal controls.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementBalance rdf:type rdf:Property ;
    rdfs:label 'Last Statement Balance' ;
    rdfs:comment 'The closing balance reported on the most recent bank statement. Used as the reconciliation baseline to match against the general ledger balance and identify unreconciled items.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'The date of the most recent electronic bank statement (MT940 or CAMT.053 format) imported into SAP S/4HANA. Used to track reconciliation currency and identify gaps in statement processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Requirement' ;
    rdfs:comment 'The minimum balance that must be maintained in the account to avoid fees or meet contractual obligations. Used for cash positioning and liquidity planning.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The account balance at the beginning of the current reporting period or fiscal year. Used as the starting point for cash flow analysis, reconciliation, and liquidity forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum negative balance (credit line) authorized by the financial institution for this account. Used for liquidity management and to prevent payment failures. Confidential due to credit facility sensitivity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Method Enabled' ;
    rdfs:comment 'Comma-separated list of payment methods enabled for this bank account (e.g., wire_transfer, ACH, check, SEPA_credit_transfer, SEPA_direct_debit). Determines which payment formats and channels can be used for outbound payments from this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Signatory Limit Amount' ;
    rdfs:comment 'The maximum transaction amount that can be approved by a single authorized signatory. Transactions exceeding this limit require dual approval or escalation. Critical for fraud prevention and internal controls.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementImportFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Import Frequency' ;
    rdfs:comment 'The frequency at which electronic bank statements are automatically imported from the financial institution. Daily is standard for operational accounts; intraday supports real-time cash management; weekly or monthly may be used for low-activity accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'SWIFT Business Identifier Code uniquely identifying the bank and branch for international wire transfers and correspondent banking. Format: 8 or 11 characters (bank code, country code, location code, optional branch code).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this bank account record is effective and available for use in SAP S/4HANA. Supports time-dependent master data management and historical reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this bank account record is effective. After this date, the account is no longer available for new transactions. Null or far-future date indicates an open-ended validity period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankStatementId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Id' ;
    rdfs:comment 'Unique identifier for the bank statement record. Primary key for the bank statement entity.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Verification Status' ;
    rdfs:comment 'Indicates whether the opening balance matches the previous statement closing balance. Flags continuity breaks requiring investigation.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankIdentifierCode rdf:type rdf:Property ;
    rdfs:label 'Bank Identifier Code' ;
    rdfs:comment 'SWIFT BIC code of the bank that issued the statement. Uniquely identifies the financial institution in international transactions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'The account balance at the end of the statement period. Used for daily cash position reporting and liquidity forecasting.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardAvailableBalance rdf:type rdf:Property ;
    rdfs:label 'Forward Available Balance' ;
    rdfs:comment 'Projected available balance including future-dated transactions. Supports treasury cash flow forecasting and liquidity planning.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:importBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Import Batch Number' ;
    rdfs:comment 'Identifier for the batch job that imported this statement. Groups statements processed together for operational tracking.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importFileName rdf:type rdf:Property ;
    rdfs:label 'Import File Name' ;
    rdfs:comment 'Name of the source file from which this statement was imported. Provides traceability back to the original electronic banking file.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importTimestamp rdf:type rdf:Property ;
    rdfs:label 'Import Timestamp' ;
    rdfs:comment 'Date and time when the bank statement file was imported into SAP S/4HANA Cash Management. Record audit timestamp for data lineage.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousStatementClosingBalance rdf:type rdf:Property ;
    rdfs:label 'Previous Statement Closing Balance' ;
    rdfs:comment 'Closing balance from the immediately preceding statement. Used to validate continuity and detect discrepancies between statements.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledByUser rdf:type rdf:Property ;
    rdfs:label 'Reconciled By User' ;
    rdfs:comment 'User ID of the treasury analyst who completed or approved the reconciliation. Provides accountability for manual reconciliation decisions.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Reconciled Transaction Count' ;
    rdfs:comment 'Number of statement transactions that have been successfully auto-matched to open AR/AP items. Used to track reconciliation progress and efficiency.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance Amount' ;
    rdfs:comment 'Total monetary value of unreconciled transactions. Represents the outstanding variance between bank statement and internal cash ledger.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The date on which the bank statement was generated. Principal business event timestamp for the statement lifecycle.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'The electronic format in which the bank statement was received. Indicates the message standard used for import into SAP S/4HANA Cash Management.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Unique statement number assigned by the bank. External business identifier for the statement, typically sequential per account.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date covered by this statement period. Defines the end of the transaction window included in the statement.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date covered by this statement period. Defines the beginning of the transaction window included in the statement.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Sequence Number' ;
    rdfs:comment 'Sequential number of this statement within the account history. Used to detect missing statements and ensure continuity.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current processing status of the bank statement within the cash management system. Tracks the lifecycle state from import through reconciliation to archival.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Sum of all debit transactions on this statement. Represents total outflows from the account during the statement period.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of individual transaction lines included in this bank statement. Used for validation and reconciliation control.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unreconciledTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Unreconciled Transaction Count' ;
    rdfs:comment 'Number of statement transactions that remain unmatched and require manual review. Indicates exceptions requiring treasury analyst attention.' ;
    rdfs:domain ind:BankStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key for the budget line entity.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for this budget line. Establishes accountability for budget execution and variance management.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual expenditure or revenue recorded against this budget line. Used for variance analysis and budget monitoring.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Classification of the budget line as Capital Expenditure (CAPEX), Operational Expenditure (OPEX), Revenue, or Other. Critical for financial planning and EBITDA analysis in telecommunications.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlLevel rdf:type rdf:Property ;
    rdfs:label 'Budget Control Level' ;
    rdfs:comment 'Level of budget control enforcement for this line. Advisory allows overspending with notification, Warning requires justification, Blocking prevents transactions that exceed the budget.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Line Description' ;
    rdfs:comment 'Detailed textual description of the purpose and scope of this budget line item. Provides business context for the allocation.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget line. Indicates whether the line is in planning, approved for use, actively monitored, locked from changes, closed for the period, or cancelled.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget line by planning horizon or purpose. Distinguishes between regular periodic budgets and special allocations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version identifier for the budget plan. Enables tracking of multiple budget scenarios (e.g., original, revised, forecast) for comparison and planning accuracy assessment.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryforwardAmount rdf:type rdf:Property ;
    rdfs:label 'Carryforward Amount' ;
    rdfs:comment 'Amount of unused budget carried forward from the previous fiscal period. Represents budget authority transferred from prior period allocations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryforwardEligible rdf:type rdf:Property ;
    rdfs:label 'Carryforward Eligible' ;
    rdfs:comment 'Indicates whether unused budget from this line can be carried forward to the next fiscal period. True if carryforward is allowed, False if budget expires at period end.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount committed through purchase orders or contracts but not yet spent. Represents financial obligations that will impact the budget.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Code representing the functional area (e.g., Network Operations, Customer Service, Marketing) to which this budget line belongs. Supports functional cost analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Fund or grant identifier if this budget line is financed from a specific funding source. Relevant for government-funded projects or earmarked capital allocations.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The budgeted financial amount allocated for this line item. Represents the planned expenditure or revenue for the specified GL account, cost center, and fiscal period combination.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Project identifier if this budget line is allocated to a specific capital or operational project. Enables project-based budget tracking for network expansion, system implementations, etc.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionAmount rdf:type rdf:Property ;
    rdfs:label 'Reduction Amount' ;
    rdfs:comment 'Amount by which the original budget was reduced through budget cuts or reallocations. Tracks mid-period budget decreases.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplementalAmount rdf:type rdf:Property ;
    rdfs:label 'Supplemental Amount' ;
    rdfs:comment 'Additional budget amount added to the original planned amount through supplemental budget requests or adjustments. Tracks mid-period budget increases.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Target Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Budgets are set to achieve specific KPI targets (subscriber growth, churn reduction, ARPU improvement). Telecommunications planning links budget plans to strategic KPIs for goal alignment, variance tr' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:actualToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Actual To Date Amount' ;
    rdfs:comment 'Cumulative actual expenditure posted against this budget plan as of the last update. Used for budget vs. actuals variance analysis.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Available Budget Amount' ;
    rdfs:comment 'Remaining available budget calculated as total_planned_amount minus actual_to_date_amount minus committed_amount.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or identifier of the manager or executive responsible for managing and executing this budget plan.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Status' ;
    rdfs:comment 'Current lifecycle status of the budget plan: draft (in preparation), submitted (awaiting approval), under_review (being evaluated), approved (authorized for execution), rejected (not approved), active (in execution), closed (planning period ended), superseded (replaced by newer version). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|active|closed|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Commitment Tracking Enabled' ;
    rdfs:comment 'Indicates whether purchase order commitments and encumbrances are tracked against this budget plan for funds availability checking.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Level of financial consolidation for this budget plan: entity (single legal entity), business_unit (operational unit), division (multiple business units), corporate (enterprise-wide).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP controlling area for cost and profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this budget plan includes intercompany transactions requiring elimination during consolidation.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Indicates whether this version is the baseline (original approved) budget used for variance analysis. Only one version per plan should be marked as baseline.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the budget plan (e.g., \'FY2024 Network CAPEX Budget\', \'2024 Marketing OPEX Plan\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique business identifier for the budget plan, formatted as BP-YYYYNNNN where YYYY is fiscal year and NNNN is sequence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the budget planning period (typically end of fiscal year or project completion).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the budget planning period (typically beginning of fiscal year or project start).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningMethod rdf:type rdf:Property ;
    rdfs:label 'Planning Method' ;
    rdfs:comment 'Methodology used to develop the budget: top_down (executive-driven allocation), bottom_up (department-driven aggregation), zero_based (justify all expenses from zero), incremental (prior year plus adjustment), activity_based (cost driver based).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reforecastAmount rdf:type rdf:Property ;
    rdfs:label 'Reforecast Amount' ;
    rdfs:comment 'Updated forecast amount based on year-to-date actuals and revised projections. Used for mid-year budget adjustments and EBITDA reforecasting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reforecastDate rdf:type rdf:Property ;
    rdfs:label 'Reforecast Date' ;
    rdfs:comment 'Date when the reforecast amount was last updated.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPlannedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Amount' ;
    rdfs:comment 'Total budgeted amount across all line items in the plan, in the plan currency. Sum of all budget line allocations.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Percent' ;
    rdfs:comment 'Budget variance as a percentage of planned amount: (actual_to_date_amount / total_planned_amount - 1) * 100.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Absolute variance threshold in plan currency. Variances exceeding this amount trigger alerts or require explanation.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of planned amount. Variances exceeding this threshold trigger alerts or require explanation (e.g., 10.00 means ±10%).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the budget version: original (initial approved budget), revised (formal amendment), forecast (updated projection), actual (actuals loaded for comparison).' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capital Manager Employee Id' ;
    rdfs:comment 'Identifier of the project manager responsible for day-to-day execution, budget control, and milestone delivery.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:networkRolloutZoneId rdf:type rdf:Property ;
    rdfs:label 'Network Rollout Zone Id' ;
    rdfs:comment 'Foreign key linking to location.network_rollout_zone. Business justification: Major capex programs (5G rollout, fiber expansion, rural broadband) are planned and budgeted by rollout zones. Required for program financial tracking, subsidy claim validation, zone-level capex vs. a' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkRolloutZone .

ind:primaryCapitalApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capital Approved By Employee Id' ;
    rdfs:comment 'Identifier of the executive or committee member who granted final project approval. Audit trail for governance compliance.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Capital project is assigned to a responsible cost center for project management and cost tracking. N:1 relationship (many projects per cost center). The responsible_cost_center_id FK will link to cost' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs posted to the project from invoices, goods receipts, and internal activity allocations. Real-time spend tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total approved capital budget for the project, including all phases and contingency. Baseline for variance analysis and budget control.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aucAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Auc Asset Number' ;
    rdfs:comment 'Asset number for the AuC master record where project costs are capitalized during construction. Converted to fixed asset upon project completion.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the approved budget. Typically the local currency of the operating company.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Calculated variance between approved budget and actual costs (approved_budget_amount - actual_cost_amount). Positive indicates under budget.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Percentage' ;
    rdfs:comment 'Budget variance expressed as percentage of approved budget. Key performance indicator for project financial control.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when project costs are transferred from AuC to fixed assets on the balance sheet. Marks the start of depreciation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs from purchase orders, contracts, and reservations. Represents financial obligations not yet invoiced.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpactAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Required' ;
    rdfs:comment 'Indicates whether the project requires environmental impact assessment under NEPA or state environmental regulations.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastFinalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Final Cost Amount' ;
    rdfs:comment 'Projected total cost at project completion based on current actuals, commitments, and remaining work estimates. Updated monthly.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Business function or division responsible for project delivery. Used for cross-functional portfolio analysis and resource allocation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'Date when the capital asset is placed into operational service and begins generating revenue or operational benefits. Triggers depreciation start.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentCategory rdf:type rdf:Property ;
    rdfs:label 'Investment Category' ;
    rdfs:comment 'Strategic investment classification for portfolio management and CAPEX allocation analysis. Aligns with network planning and technology roadmap. [ENUM-REF-CANDIDATE: ran_expansion|core_network|transport_network|access_network|it_systems|facilities|spectrum — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrPercentage rdf:type rdf:Property ;
    rdfs:label 'Irr Percentage' ;
    rdfs:comment 'Internal rate of return calculated for the project investment. Used for comparing investment alternatives and portfolio optimization.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvAmount rdf:type rdf:Property ;
    rdfs:label 'Npv Amount' ;
    rdfs:comment 'Calculated net present value of the project investment based on discounted cash flow analysis. Key metric for capital allocation decisions.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Expected number of months to recover the capital investment through operational benefits and revenue generation.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion and final deliverable acceptance. Baseline for schedule variance analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned cost estimate for the project based on detailed engineering and procurement planning. Updated throughout project lifecycle.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDefinitionCode rdf:type rdf:Property ;
    rdfs:label 'Project Definition Code' ;
    rdfs:comment 'External business identifier for the project definition in SAP PS. Used for cross-system integration and reporting.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed business description and scope of the capital project, including objectives, deliverables, and strategic alignment.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Full descriptive name of the capital project (e.g., \'5G NR Rollout Phase 3 - Metro Region\', \'FTTH Fiber Deployment - Northeast Corridor\').' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current execution phase of the project within its lifecycle. Used for milestone tracking and phase-gate governance. [ENUM-REF-CANDIDATE: initiation|planning|design|procurement|construction|testing|commissioning|closeout — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital project. Controls budget availability, settlement processing, and asset capitalization workflow. [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by investment category. Determines capitalization rules, depreciation schedules, and financial reporting treatment.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether the project requires regulatory approval from FCC, state PUC, or other telecommunications authorities before execution.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roiTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percentage' ;
    rdfs:comment 'Target ROI percentage established during project approval. Used for investment prioritization and post-implementation review.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile' ;
    rdfs:comment 'SAP settlement profile defining rules for transferring project costs to fixed assets (AuC - Assets under Construction) or expense accounts.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDomain rdf:type rdf:Property ;
    rdfs:label 'Technology Domain' ;
    rdfs:comment 'Primary technology domain or platform that the project delivers or enhances. Critical for technology portfolio management and ROI measurement. [ENUM-REF-CANDIDATE: 5g_nr|lte|ftth_gpon|iptv|ims_volte|sdn_nfv|oss_bss|data_center|spectrum — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsRootElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Root Element' ;
    rdfs:comment 'Top-level WBS element code representing the entire project hierarchy. Parent node for all sub-WBS elements and cost collection.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Business Area Required Indicator' ;
    rdfs:comment 'Boolean flag indicating whether business area assignment is mandatory for all financial postings in this company code. Used for segment reporting under IFRS 8.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this company code. The COA defines the structure of General Ledger (GL) accounts used for financial recording and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current operational status of the company code. Active company codes can post financial transactions; inactive or closed company codes are restricted.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Full legal name of the company code entity as registered with regulatory authorities. Used for statutory reporting, invoices, and legal documentation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyNameShort rdf:type rdf:Property ;
    rdfs:label 'Company Name Short' ;
    rdfs:comment 'Abbreviated or short name of the company code for display purposes in reports and user interfaces.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyType rdf:type rdf:Property ;
    rdfs:label 'Company Type' ;
    rdfs:comment 'Classification of the legal entity type. Determines consolidation treatment, reporting requirements, and intercompany transaction handling.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Code identifying the consolidation group to which this company code belongs for group financial reporting and EBITDA analysis.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfSalesAccountingIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Of Sales Accounting Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this company code uses cost-of-sales accounting (true) or period accounting (false) for profit and loss reporting. Determines GL account assignment logic.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area assigned to this company code. Used for managing customer credit limits and credit exposure across one or more company codes.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this company code ceased operations or was closed. Null for currently active company codes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStatusVariant rdf:type rdf:Property ;
    rdfs:label 'Field Status Variant' ;
    rdfs:comment 'Four-character code defining which fields are required, optional, or suppressed during financial document posting for this company code.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'Code identifying the financial statement version used for external reporting by this company code. Defines the structure and line items of balance sheet and profit & loss statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this company code, including the number of posting periods, special periods, and fiscal year start/end dates. Determines how financial periods are structured for reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when this company code master record was last modified.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumExchangeRateDeviation rdf:type rdf:Property ;
    rdfs:label 'Maximum Exchange Rate Deviation' ;
    rdfs:comment 'Maximum allowable percentage deviation from the standard exchange rate for foreign currency transactions. Used for exchange rate validation during posting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code' ;
    rdfs:comment 'Four-character company code of the parent entity in the corporate hierarchy. Used for consolidation and intercompany transaction elimination.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Four-character code defining the posting period control rules for this company code, including open and closed periods for financial postings.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'Code identifying the standard profit center hierarchy assigned to this company code for profitability analysis and segment reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary tax jurisdiction under which this company code operates. Used for tax calculation, withholding tax, and tax reporting compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number assigned by the tax authority. Required for VAT/GST reporting and invoicing in applicable jurisdictions.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation transaction record in SAP Controlling (CO) module. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:allocationCycleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Id' ;
    rdfs:comment 'Business identifier for the periodic assessment or distribution cycle that groups related cost allocation transactions. Corresponds to SAP CO cycle run identifier.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:allocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Id' ;
    rdfs:comment 'Identifier of the predefined allocation rule or cycle segment that governs this transaction, used for recurring monthly allocations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Reference to the original cost allocation record that this transaction reverses, populated only when reversal_indicator is true.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'The cost center from which costs are being allocated. Typically represents shared infrastructure (NOC, RAN, IT platforms, corporate overhead) whose costs are distributed to beneficiaries.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'The profit center receiving the allocated costs, used for segment P&L reporting and EBITDA analysis by business line (e.g., wireless, broadband, enterprise).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:receiverWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Receiver Wbs Element Id' ;
    rdfs:comment 'The WBS element (project phase or deliverable) receiving the allocated costs, used when costs are allocated to capital projects or network expansion initiatives.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:userEmployeeId rdf:type rdf:Property ;
    rdfs:label 'User Employee Id' ;
    rdfs:comment 'The SAP user ID of the person or system account that executed the allocation cycle or posted the manual allocation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityQuantity rdf:type rdf:Property ;
    rdfs:label 'Activity Quantity' ;
    rdfs:comment 'The quantity of activity consumed by the receiver (e.g., 120 support hours, 500 monitoring hours), used with activity rate to calculate allocated amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityRate rdf:type rdf:Property ;
    rdfs:label 'Activity Rate' ;
    rdfs:comment 'The cost per unit of activity (e.g., USD per support hour, USD per monitoring hour), multiplied by activity quantity to determine allocated amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'The activity type code when using activity-based allocation (e.g., NOC monitoring hours, IT support tickets, network maintenance hours).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisType rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Type' ;
    rdfs:comment 'The method used to determine how costs are distributed: fixed percentage (pre-defined split), statistical key figure (driver-based), activity quantity (usage-based), headcount, revenue, subscriber count, or network capacity. [ENUM-REF-CANDIDATE: fixed_percentage|statistical_key_figure|activity_quantity|headcount|revenue|subscriber_count|network_capacity — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDescription rdf:type rdf:Property ;
    rdfs:label 'Allocation Description' ;
    rdfs:comment 'Free-text description of the allocation transaction, typically auto-generated from cycle definition or manually entered for ad-hoc allocations.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Document Number' ;
    rdfs:comment 'The SAP CO document number generated when the allocation is posted, used for audit trail and drill-down to source transaction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of sender costs allocated to this receiver when using fixed percentage allocation basis. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Timestamp' ;
    rdfs:comment 'The date and time when the allocation cycle was executed and this transaction was created in the system.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the allocated cost as CAPEX (capital expenditure for network build, infrastructure projects) or OPEX (operational expenditure for ongoing operations and maintenance).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalKeyFigureCode rdf:type rdf:Property ;
    rdfs:label 'Statistical Key Figure Code' ;
    rdfs:comment 'The code identifying the statistical key figure used as allocation driver (e.g., subscriber count, network port count, square footage, FTE count).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalKeyFigureValue rdf:type rdf:Property ;
    rdfs:label 'Statistical Key Figure Value' ;
    rdfs:comment 'The quantity of the statistical key figure for the receiver, used to calculate proportional allocation (e.g., 50,000 subscribers, 200 FTEs).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the cost center hierarchy. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual budget amount allocated to this cost center for the current fiscal year.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area code for cross-company code reporting and segment analysis (e.g., Wireless, Broadband, Enterprise Services).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexOpexIndicator rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Indicator' ;
    rdfs:comment 'Indicates whether costs in this cost center are primarily capital expenditures, operational expenditures, or a mix of both.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this cost center belongs. Controlling area is the highest organizational unit in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects (e.g., direct assignment, activity-based costing, percentage allocation).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by functional category. Determines how costs are allocated and reported.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended textual description of the cost center\'s purpose, scope, and responsibilities within the organization.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center (e.g., \'Network Operations Center\', \'RAN Engineering\', \'Customer Care - Tier 1\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active cost centers can accept postings; inactive and blocked cannot.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Type classification indicating whether the cost center is operational (OPEX), capital (CAPEX), shared service, overhead, or revenue-generating.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group Code' ;
    rdfs:comment 'Default cost element group for categorizing the types of costs posted to this cost center (e.g., personnel, materials, services).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department code within the organizational structure to which this cost center belongs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Code identifying the cost center group for aggregated reporting and analysis (e.g., all NOC cost centers, all engineering cost centers).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Indicates whether the cost center is locked for new cost postings (true = locked, false = open for postings).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this is a statistical cost center used for reporting purposes only, without actual cost postings (true = statistical, false = real).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningGroupCode rdf:type rdf:Property ;
    rdfs:label 'Planning Group Code' ;
    rdfs:comment 'Code identifying the planning group responsible for budget planning and forecasting for this cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialConsolidationId rdf:type rdf:Property ;
    rdfs:label 'Financial Consolidation Id' ;
    rdfs:comment 'Unique identifier for the group-level financial consolidation record. Primary key for the financial consolidation entity.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Financial consolidation is performed for a parent entity (legal entity). N:1 relationship (many consolidations for one parent company). The parent_company_code_id FK will link to company_code.company_' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:primaryFinancialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Financial Employee Id' ;
    rdfs:comment 'User identifier of the finance professional who prepared this consolidation record.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting framework applied for this consolidation: IFRS (International Financial Reporting Standards), US GAAP (Generally Accepted Accounting Principles), or local jurisdiction GAAP.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'Type of audit opinion issued: unqualified (clean), qualified (exceptions noted), adverse (material misstatement), or disclaimer (unable to form opinion).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexConsolidated rdf:type rdf:Property ;
    rdfs:label 'Capex Consolidated' ;
    rdfs:comment 'Consolidated capital expenditure for the period, including network infrastructure, equipment, and technology investments.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationCurrency rdf:type rdf:Property ;
    rdfs:label 'Consolidation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for group-level consolidated reporting (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Technical method used for consolidation: direct (single-step), step acquisition (phased control), or simultaneous (all entities at once).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationNotes rdf:type rdf:Property ;
    rdfs:label 'Consolidation Notes' ;
    rdfs:comment 'Free-text notes documenting significant consolidation adjustments, assumptions, or explanations for material variances.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Number' ;
    rdfs:comment 'Business identifier for the consolidation run. Externally-known unique document number used for audit trail and reference.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationScope rdf:type rdf:Property ;
    rdfs:label 'Consolidation Scope' ;
    rdfs:comment 'Method of consolidation applied: full (100% control), partial (significant influence), equity method (20-50% ownership), or proportionate (joint ventures).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Current lifecycle state of the consolidation process. Tracks workflow from draft through approval to final publication.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Type' ;
    rdfs:comment 'Classification of the consolidation purpose: statutory (IFRS/GAAP), management (internal reporting), regulatory (FCC/ITU filings), tax (jurisdiction-specific), or segment (business unit rollup).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyTranslationAdjustment rdf:type rdf:Property ;
    rdfs:label 'Currency Translation Adjustment' ;
    rdfs:comment 'Cumulative translation adjustment arising from converting foreign subsidiary financial statements into the consolidation currency. Recorded in other comprehensive income.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaConsolidated rdf:type rdf:Property ;
    rdfs:label 'Ebitda Consolidated' ;
    rdfs:comment 'Consolidated EBITDA calculated as operating income before depreciation, amortization, interest, and taxes. Key performance metric for telecom industry.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which this consolidation must be filed with governing authorities.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Filing Submission Date' ;
    rdfs:comment 'Actual date when the consolidation report was submitted to regulatory authorities.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodwillConsolidated rdf:type rdf:Property ;
    rdfs:label 'Goodwill Consolidated' ;
    rdfs:comment 'Consolidated goodwill arising from business combinations, representing excess of purchase price over fair value of net identifiable assets acquired.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intangibleAssetsConsolidated rdf:type rdf:Property ;
    rdfs:label 'Intangible Assets Consolidated' ;
    rdfs:comment 'Consolidated intangible assets including spectrum licenses, customer relationships, brand value, and software, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyEliminationAmount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Amount' ;
    rdfs:comment 'Total value of intercompany transactions and balances eliminated during consolidation to avoid double-counting (e.g., intercompany sales, loans, dividends).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minorityInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Amount' ;
    rdfs:comment 'Non-controlling interest (minority interest) in consolidated subsidiaries, representing equity attributable to shareholders other than the parent.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeConsolidated rdf:type rdf:Property ;
    rdfs:label 'Net Income Consolidated' ;
    rdfs:comment 'Consolidated net income (profit after tax) for the group, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfEntitiesConsolidated rdf:type rdf:Property ;
    rdfs:label 'Number Of Entities Consolidated' ;
    rdfs:comment 'Count of legal entities included in the consolidation scope for this reporting period.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opexConsolidated rdf:type rdf:Property ;
    rdfs:label 'Opex Consolidated' ;
    rdfs:comment 'Consolidated operational expenditure for the period, including network operations, customer service, and administrative costs.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityCode rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Code' ;
    rdfs:comment 'Legal entity code of the parent company at the top of the consolidation hierarchy. Typically the publicly-traded holding company.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this consolidation must be filed with regulatory authorities (FCC, SEC, ITU, national telecom regulators).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'Last day of the financial reporting period covered by this consolidation (e.g., 2024-03-31 for Q1 2024).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'First day of the financial reporting period covered by this consolidation (e.g., 2024-01-01 for Q1 2024).' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAssetsConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Assets Consolidated' ;
    rdfs:comment 'Consolidated total assets on the group balance sheet after elimination of intercompany balances, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEquityConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Equity Consolidated' ;
    rdfs:comment 'Consolidated total equity (shareholders equity) on the group balance sheet, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilitiesConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities Consolidated' ;
    rdfs:comment 'Consolidated total liabilities on the group balance sheet after elimination of intercompany balances, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpensesConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses Consolidated' ;
    rdfs:comment 'Consolidated total operating expenses (OPEX) for the group after elimination entries, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueConsolidated rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Consolidated' ;
    rdfs:comment 'Consolidated total revenue for the group after elimination of intercompany transactions, expressed in consolidation currency.' ;
    rdfs:domain ind:FinancialConsolidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record in SAP Asset Accounting (FI-AA). Primary key for the fixed asset master data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Identifier of the employee or asset custodian responsible for the asset. Used for accountability and asset tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Identifier of the supplier or vendor from whom the asset was purchased. Links to vendor master data for procurement tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized since capitalization date. Represents the cumulative reduction in asset value over time.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionValue rdf:type rdf:Property ;
    rdfs:label 'Acquisition Value' ;
    rdfs:comment 'Original cost or fair value of the fixed asset at acquisition, including purchase price, installation costs, and directly attributable costs. Recorded in functional currency.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level categorization of the asset for financial reporting. Distinguishes between tangible assets, intangible assets, and right-of-use assets under IFRS 16.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset including make, model, specifications, and purpose. Used for asset identification and inventory management.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'External business identifier for the fixed asset. Unique asset tag or serial number used for physical identification and tracking across the organization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Determines whether depreciation is active and whether the asset is available for operational use.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset identifier for components or modules within a main asset. Used for tracking individual parts of complex network equipment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to allocate the cost of the asset over its useful life. Determines the pattern of depreciation expense recognition.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalValue rdf:type rdf:Property ;
    rdfs:label 'Disposal Value' ;
    rdfs:comment 'Proceeds received from the sale or disposal of the retired asset. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Write-down amount recognized when the asset\'s recoverable amount falls below its carrying value. Reflects economic obsolescence or damage.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'Date when the impairment loss was recognized. Marks the adjustment to the asset\'s carrying value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLeased rdf:type rdf:Property ;
    rdfs:label 'Is Leased' ;
    rdfs:comment 'Indicates whether the asset is leased rather than owned. True for right-of-use assets under IFRS 16 lease accounting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Date' ;
    rdfs:comment 'Date of the most recent physical inventory verification of the asset. Used for asset reconciliation and audit compliance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseContractId rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Id' ;
    rdfs:comment 'Identifier of the lease agreement if the asset is leased. Links to lease contract master data for IFRS 16 compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the equipment manufacturer or original equipment manufacturer (OEM). Used for warranty claims and spare parts sourcing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model or part number for the asset. Used for technical specifications, compatibility, and replacement planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the fixed asset calculated as acquisition value minus accumulated depreciation. Represents the asset\'s value on the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Adjustment to the asset\'s carrying value based on fair value revaluation. Used when applying the revaluation model under IFRS.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationDate rdf:type rdf:Property ;
    rdfs:label 'Revaluation Date' ;
    rdfs:comment 'Date when the asset was revalued to fair value. Marks the adjustment to the asset\'s carrying value under the revaluation model.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected economic useful life of the asset in years. Used to calculate annual depreciation expense. Determined by asset class and regulatory guidelines.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage ends. Used for maintenance planning and extended warranty decisions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts to which this GL account belongs. Supports multi-entity consolidation and statutory reporting requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:controllingAreaId rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Id' ;
    rdfs:comment 'Reference to the controlling area for management accounting and cost center assignment. Links financial accounting to cost accounting for OPEX and CAPEX tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControllingArea .

ind:costElementId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Id' ;
    rdfs:comment 'Reference to the cost element in controlling (CO) module. Links GL account to cost accounting for CAPEX/OPEX tracking and profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostElement .

ind:functionalAreaId rdf:type rdf:Property ;
    rdfs:label 'Functional Area Id' ;
    rdfs:comment 'Reference to the functional area for segment reporting and cost-of-sales accounting. Enables classification by business function (e.g., network operations, sales, administration).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalArea .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Account group code that controls field status, number range assignment, and screen layout for the GL account. Defines account behavior and validation rules.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNameLong rdf:type rdf:Property ;
    rdfs:label 'Account Name Long' ;
    rdfs:comment 'Full descriptive name of the GL account providing complete business context and purpose of the account.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNameShort rdf:type rdf:Property ;
    rdfs:label 'Account Name Short' ;
    rdfs:comment 'Short descriptive name of the GL account, typically 20-40 characters, used in reports and user interfaces for quick identification.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Alternative or legacy account number used for mapping to external systems, prior chart of accounts, or regulatory reporting requirements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccountType rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account Type' ;
    rdfs:comment 'Sub-classification for balance sheet accounts into current vs. fixed assets, current vs. long-term liabilities, and equity for liquidity analysis and financial ratio calculation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Relevant Flag' ;
    rdfs:comment 'Indicates whether postings to this account are relevant for cash flow statement generation. True includes transactions in operating, investing, or financing cash flow categories.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Field status group code that controls which fields are required, optional, or suppressed during posting transactions to this account.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'Financial statement line item code to which this GL account maps for balance sheet and income statement reporting. Enables automated financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The unique account number in the chart of accounts. Typically 6-10 digit numeric code used as the business identifier for all financial postings and reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflationKey rdf:type rdf:Property ;
    rdfs:label 'Inflation Key' ;
    rdfs:comment 'Inflation index key used for inflation-adjusted reporting in hyperinflationary economies. Enables IAS 29 compliance for financial statement restatement.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Indicator' ;
    rdfs:comment 'Interest calculation indicator code that determines whether and how interest is calculated on balances in this account (e.g., for customer deposits, vendor payables).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line items are stored and can be displayed for this account. True enables drill-down to transaction-level detail; false stores only balances.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether open item management is active for this account. True enables tracking of open and cleared items for accounts requiring item-level reconciliation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Planning level code indicating the granularity at which budget planning and forecasting is performed for this account (e.g., cost center, profit center, segment).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Indicates whether postings to this account are blocked. True prevents any new transactions from being posted to the account.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Update Flag' ;
    rdfs:comment 'Indicates whether profit center is a mandatory field for postings to this account. True enforces profit center assignment for segment profitability reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossAccountType rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Account Type' ;
    rdfs:comment 'Classification for P&L accounts distinguishing between primary costs (direct), secondary costs (allocated), revenue, and other categories for cost accounting and profitability analysis.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account for subledgers (accounts receivable, accounts payable, asset accounting). True if subledger postings automatically update this GL account.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Account Flag' ;
    rdfs:comment 'Indicates whether this is a sample or template account used for training or testing purposes. True excludes account from production reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Flag' ;
    rdfs:comment 'Indicates whether this account is relevant for segment reporting under IFRS 8. True includes account balances in segment-level financial statements.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Default sort key code that determines the assignment number format for postings to this account (e.g., by posting date, document number, or custom logic).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax category code indicating whether the account is subject to input tax, output tax, or is tax-exempt. Controls automatic tax calculation on postings.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Tolerance group code that defines permissible payment differences, cash discount limits, and exchange rate variances for postings to this account.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationGroup rdf:type rdf:Property ;
    rdfs:label 'Valuation Group' ;
    rdfs:comment 'Valuation group code used for foreign currency valuation and mark-to-market adjustments. Determines valuation method for balance sheet accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Intercompany transaction originates from a sending legal entity. N:1 relationship (many transactions from one company). The sending_company_code_id FK will link to company_code.company_code_id. Remove' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:sendingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Intercompany transaction originates from a sending cost center. N:1 relationship (many transactions from one cost center). The sending_cost_center_id FK will link to cost_center.cost_center_id. The ex' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sendingProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Intercompany transaction originates from a sending profit center. N:1 relationship (many transactions from one profit center). The sending_profit_center_id FK will link to profit_center.profit_center_' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business segment or division within the telecom group to which the intercompany transaction is attributed for segment reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Reference to the source document or invoice that supports the intercompany transaction for audit trail purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date when the intercompany transaction was eliminated during the financial consolidation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Indicates whether the intercompany transaction has been eliminated in the consolidated financial statements to avoid double-counting group revenue and expenses.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'The three-letter ISO currency code of the corporate group reporting currency (typically USD, EUR, or GBP).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterReceiving rdf:type rdf:Property ;
    rdfs:label 'Profit Center Receiving' ;
    rdfs:comment 'The profit center within the receiving company for internal profitability analysis and segment reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterSending rdf:type rdf:Property ;
    rdfs:label 'Profit Center Sending' ;
    rdfs:comment 'The profit center within the sending company for internal profitability analysis and segment reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The legal entity code of the subsidiary or business unit that is the recipient or creditor in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Name' ;
    rdfs:comment 'The legal name of the receiving company entity for business user reference and reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Cost Center' ;
    rdfs:comment 'The cost center within the receiving company that receives the intercompany revenue or allocation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'Reference identifier linking this transaction to the corresponding reciprocal entry in the counterparty legal entity for intercompany reconciliation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'The legal entity code of the subsidiary or business unit that is the originator or debtor in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center' ;
    rdfs:comment 'The cost center within the sending company that is charged or allocated the intercompany expense.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the service, product, or cost allocation that is the subject of the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating the tax treatment applicable to the intercompany transaction for transfer pricing and tax compliance purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the intercompany transaction, used for reconciliation and audit trails across subsidiaries.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The transfer pricing methodology applied to determine the arms-length price for the intercompany transaction in compliance with tax regulations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text field used for additional reference information such as invoice numbers, purchase order numbers, or payment references. Supports reconciliation and audit trail requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the journal entry line item was cleared through payment, reconciliation, or offsetting entry. Used for accounts receivable, accounts payable, and balance sheet reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The accounting document number that cleared this journal entry line item. Links the original entry to its settlement or reconciliation document.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the journal entry line item is a debit (D) or credit (C) posting. Fundamental accounting classification for double-entry bookkeeping and trial balance generation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original business transaction or source document that triggered the journal entry. May differ from posting date for backdated or delayed entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date when the journal entry was physically entered into the SAP S/4HANA system by the user. Used for audit trail and data entry tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groupAmount rdf:type rdf:Property ;
    rdfs:label 'Group Amount' ;
    rdfs:comment 'The monetary amount of the journal entry line item translated into the corporate group\'s reporting currency. Used for consolidated financial reporting and group-wide analytics.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyPartner rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany transactions. Used for intercompany reconciliation and elimination entries in consolidated financial statements.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'The ledger classification for parallel accounting scenarios (e.g., local GAAP, IFRS, tax ledger). Supports multiple accounting principles within the Universal Journal.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'The monetary amount of the journal entry line item translated into the company code\'s local currency. Used for statutory financial statements and local GAAP reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company code\'s local currency. Used for legal entity financial statements and statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The payment terms code defining due date calculation and cash discount conditions. Used for accounts payable and accounts receivable management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls whether a line item is a debit or credit and determines the account type (GL, customer, vendor, asset). Standard SAP posting keys include 40 (debit GL), 50 (credit GL), 01 (debit customer), 11 (credit customer), 31 (debit vendor), 21 (credit vendor).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Posted indicates the entry is final and impacts the general ledger; parked indicates a draft entry pending approval; cleared indicates the entry has been reconciled; reversed indicates the entry has been reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'The SAP user ID of the person who posted the journal entry. Used for audit trail, segregation of duties monitoring, and user activity tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description of the journal entry line item providing business context and explanation. Used for audit documentation and financial statement notes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular financial transaction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of this line item converted to the local reporting currency of the legal entity. Used for statutory reporting and consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The monetary amount of this line item in the original transaction currency. Used for multi-currency operations and foreign exchange tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'Customer account number for accounts receivable line items. Links revenue postings to customer master data and ARPU analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order used for tracking specific cost collection objects such as maintenance orders, marketing campaigns, or overhead allocation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the journal entry document. Determines the ordering and position of this line in the posting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemStatus rdf:type rdf:Property ;
    rdfs:label 'Line Item Status' ;
    rdfs:comment 'Current processing status of this line item. Tracks lifecycle from initial posting through clearing or blocking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local reporting currency. Typically the functional currency of the operating entity.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Material master number for inventory and procurement postings. Links financial transactions to physical goods and CPE inventory.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Partner Profit Center Code' ;
    rdfs:comment 'Partner profit center for intercompany and internal transfer pricing postings. Enables elimination entries and internal revenue tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as vendor invoice number, customer billing document, or bank statement reference. Links financial posting to source document.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Special GL indicator for down payments, guarantees, bills of exchange, or other special ledger transactions. Enables specialized financial processing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The calculated tax amount for this line item in local currency. Supports tax reporting and reconciliation to tax authorities.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner company code for intercompany transactions. Essential for consolidation eliminations and intercompany reconciliation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction amount (e.g., USD, EUR, GBP). Enables multi-currency financial consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Vendor account number for accounts payable line items. Enables supplier spend analysis and procurement reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'The WBS element for project-related postings. Critical for CAPEX tracking, network infrastructure projects, and capital investment analysis in telecom.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in the organizational hierarchy, enabling multi-level profitability analysis and roll-up reporting. Null for top-level profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:primaryKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Profit centers own revenue and profitability KPIs (segment ARPU, EBITDA margin, subscriber growth). Telecommunications finance assigns primary KPI accountability to profit centers for business unit sc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:arpuTarget rdf:type rdf:Property ;
    rdfs:label 'Arpu Target' ;
    rdfs:comment 'Target Average Revenue Per User (ARPU) for this profit center used for performance measurement and business planning. Expressed in the profit center\'s functional currency.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexBudget rdf:type rdf:Property ;
    rdfs:label 'Capex Budget' ;
    rdfs:comment 'Annual Capital Expenditure (CAPEX) budget allocated to this profit center for infrastructure investments, network expansion, and equipment purchases. Expressed in the profit center\'s functional currency.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaTarget rdf:type rdf:Property ;
    rdfs:label 'Ebitda Target' ;
    rdfs:comment 'Target Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) for this profit center used for profitability measurement and executive reporting. Expressed in the profit center\'s functional currency.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsolidationRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Relevant' ;
    rdfs:comment 'Boolean flag indicating whether this profit center\'s financial results are included in corporate consolidation and group reporting processes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntercompanyEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this profit center participates in intercompany transactions and transfer pricing arrangements with other profit centers or legal entities.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opexBudget rdf:type rdf:Property ;
    rdfs:label 'Opex Budget' ;
    rdfs:comment 'Annual Operational Expenditure (OPEX) budget allocated to this profit center for day-to-day operations, maintenance, and recurring costs. Expressed in the profit center\'s functional currency.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed description of the profit center\'s business purpose, scope of operations, and key responsibilities. Provides context for financial analysis and reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Profit Center Group' ;
    rdfs:comment 'Grouping classification for aggregating multiple profit centers for consolidated reporting and analysis (e.g., All Consumer Services, All Enterprise Services, All Wholesale Operations).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full business name of the profit center representing the business segment or product line (e.g., Mobile Consumer, Fixed Broadband, Enterprise B2B, IPTV/Content, Wholesale/Interconnect).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center indicating whether it is operational, planned for future activation, temporarily inactive, or permanently closed.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension (e.g., Product Line, Geographic Region, Customer Segment, Service Type, Channel, Cost Center).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Method used for revenue recognition for this profit center as per IFRS 15 / ASC 606 standards (e.g., Point in Time, Over Time, Subscription, Usage-Based, Hybrid).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center used in reports and dashboards where space is limited.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveNumber rdf:type rdf:Property ;
    rdfs:label 'Collective Number' ;
    rdfs:comment 'Grouping identifier for related purchase orders processed together in a procurement campaign or bulk order scenario.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentValue rdf:type rdf:Property ;
    rdfs:label 'Commitment Value' ;
    rdfs:comment 'Encumbered budget amount for this purchase order. Used for budget control and funds management to prevent overspending.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested or scheduled date for goods receipt or service completion. Used for supply chain planning and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether goods receipt posting is required for this purchase order. True for material procurement, false for service-only orders.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grBasedInvoiceVerification rdf:type rdf:Property ;
    rdfs:label 'Gr Based Invoice Verification' ;
    rdfs:comment 'Flag indicating whether invoice verification is based on goods receipt rather than purchase order. When true, invoice must match GR quantity and value.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms defining the responsibilities of buyer and seller for shipping, insurance, and customs (e.g., FOB, CIF, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms clause (e.g., FOB Shanghai, DDP New York).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this purchase order. Used in three-way match processing (PO, GR, IR).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Net monetary value after applying discounts and before taxes. Used for vendor payment calculation and financial reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Physical location or facility where goods will be received or services will be rendered. Four-character code representing warehouse, distribution center, Network Operations Center (NOC), or field office.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued to the vendor. Principal business event timestamp for procurement commitment tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order. Ten-digit numeric code used for vendor communication and three-way match processing.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. Tracks progression from draft through approval, goods receipt, invoice verification, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_process|partially_received|fully_received|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order based on procurement scenario: standard (goods procurement), subcontracting (material provided to vendor), consignment (vendor-owned inventory), stock transfer (inter-plant), service (professional services), or framework (blanket agreement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer or procurement team responsible for this purchase order. Three-character code identifying the individual or team handling vendor negotiations and order management.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Organizational unit responsible for procurement activities. Four-character alphanumeric code representing the division or business unit authorized to negotiate and execute purchase agreements.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Reference to the vendor quotation or Request for Quotation (RFQ) that preceded this purchase order. Links to the sourcing process.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStrategy rdf:type rdf:Property ;
    rdfs:label 'Release Strategy' ;
    rdfs:comment 'Approval workflow strategy code determining the approval path based on PO value, material group, or purchasing organization. Defines the sequence of approvers and thresholds.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitioner rdf:type rdf:Property ;
    rdfs:label 'Requisitioner' ;
    rdfs:comment 'User ID or name of the person who requested the procurement. Links to the originating purchase requisition for accountability.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingInstructions rdf:type rdf:Property ;
    rdfs:label 'Shipping Instructions' ;
    rdfs:comment 'Special instructions for the vendor regarding packaging, labeling, shipping method, or delivery requirements. Free-text field for logistics coordination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before taxes and discounts. Used for Capital Expenditure (CAPEX) and Operational Expenditure (OPEX) commitment tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Effective end date for framework or blanket purchase orders. Defines the expiration of the procurement agreement period.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Effective start date for framework or blanket purchase orders. Defines the beginning of the procurement agreement period.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key for this entity.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractLineNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Line Number' ;
    rdfs:comment 'Line item number within the referenced contract. Links this purchase order line to specific contract terms and pricing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this line item has been marked for deletion. Deleted lines are excluded from further processing but retained for audit purposes.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of the line item as either capital expenditure (CAPEX) for long-term assets or operational expenditure (OPEX) for ongoing operations. Critical for financial planning and EBITDA analysis.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Flag indicating that the final invoice has been received for this line item and no further invoices are expected. Used to close procurement transactions.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Incoterms code defining the delivery terms and transfer of risk between buyer and seller (e.g., FOB, CIF, DDP). Used for international procurement.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Item Category Code' ;
    rdfs:comment 'Purchase order item category code that controls the procurement process flow and account assignment for this line (e.g., standard item, consignment, subcontracting, service).' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the purchase order. Determines the ordering and display sequence of line items.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineText rdf:type rdf:Property ;
    rdfs:label 'Line Text' ;
    rdfs:comment 'Free-form text field for additional notes, specifications, or instructions specific to this purchase order line item.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The original equipment manufacturer (OEM) part number for the material. Used for technical specifications and warranty tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Reference to the material or service being procured. Links to the master material catalog for network equipment, infrastructure components, or operational services.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Textual description of the material or service being procured on this line. Provides human-readable context for the procurement item.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Classification code grouping similar materials or services together for procurement analysis and reporting. Used for spend categorization.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value of this line item before taxes and discounts. Calculated as (quantity_ordered * unit_price / price_unit).' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received or invoiced. Calculated as quantity_ordered minus the greater of quantity_received or quantity_invoiced.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Code identifying the receiving plant or facility location for the procured material. Used for inventory management and logistics planning.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity of units to which the unit price applies. For example, if price_unit is 100, the unit_price applies to 100 units rather than 1.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseRequisitionLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Line Number' ;
    rdfs:comment 'Line item number within the originating purchase requisition. Used for end-to-end procurement tracking from requisition to order.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseRequisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Number' ;
    rdfs:comment 'Reference to the originating purchase requisition document that triggered this purchase order line. Provides procurement traceability.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Quantity Invoiced' ;
    rdfs:comment 'Cumulative quantity invoiced by the vendor against this purchase order line. Updated through invoice receipt transactions.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of material or service units ordered on this line item. Represents the total amount requested from the vendor.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Cumulative quantity of goods or services received against this purchase order line. Updated through goods receipt transactions.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or business user who requested this material or service. Used for procurement tracking and accountability.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the specific storage location within the plant where the material will be received and stored.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per single unit of the material or service. Used to calculate the total line item value before taxes and adjustments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The vendor\'s own material or part number for the procured item. Used for vendor communication and order fulfillment.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition entry. Primary key for the revenue recognition product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:originalRecognitionRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Revenue Recognition Id' ;
    rdfs:comment 'Reference to the original revenue recognition entry that this record reverses or adjusts. Maintains audit trail for revenue corrections.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier for the specific performance obligation within the contract. Telecom contracts often contain multiple performance obligations such as handset delivery, service activation, and ongoing network access.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:productOfferingId rdf:type rdf:Property ;
    rdfs:label 'Product Offering Id' ;
    rdfs:comment 'Reference to the product offering catalog entry that defines the commercial product sold. Links to product master data for pricing, features, and bundling rules.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:bundledArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Bundled Arrangement Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition entry is part of a multi-element bundled arrangement requiring transaction price allocation across multiple performance obligations.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied Flag' ;
    rdfs:comment 'Indicates whether the variable consideration constraint has been applied per IFRS 15 / ASC 606 requirements to prevent revenue reversal. True when constraint reduces variable consideration estimate.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractAssetBalance rdf:type rdf:Property ;
    rdfs:label 'Contract Asset Balance' ;
    rdfs:comment 'Contract asset position where revenue has been recognized but billing has not yet occurred. Common in telecom for handset subsidies and upfront service activations.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition entry results from a contract modification. Telecom contracts frequently undergo modifications for plan upgrades, device changes, and service additions.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total amount of revenue recognized to date for this performance obligation across all fiscal periods since contract inception.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'Remaining unearned revenue balance for this performance obligation. Represents the contract liability position where cash has been received but performance obligation is not yet satisfied.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handsetSubsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Handset Subsidy Amount' ;
    rdfs:comment 'Amount of handset subsidy embedded in the contract. Telecom-specific field capturing the device discount that must be allocated and recognized over the contract term.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Type of contract modification that triggered this revenue recognition adjustment. Critical for tracking customer behavior and revenue impact of plan changes.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Detailed description of the performance obligation being satisfied. Examples include mobile service provision, broadband connectivity, handset subsidy, or bundled entertainment content.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'Date on which the revenue was recognized in the general ledger. Represents the business event timestamp for revenue realization.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized for this performance obligation. Over time recognition applies to ongoing services like monthly subscriptions; point in time applies to discrete deliverables like handset sales.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPattern rdf:type rdf:Property ;
    rdfs:label 'Recognition Pattern' ;
    rdfs:comment 'Specific pattern used for over-time revenue recognition. Straight-line for subscription services, usage-based for metered consumption, milestone for project-based delivery.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'Amount of revenue recognized in the current fiscal period for this performance obligation. Represents the portion of transaction price that has been earned through satisfaction of the obligation.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition entry. Tracks whether revenue has been recognized, is pending approval, or has been adjusted or reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Category' ;
    rdfs:comment 'Classification of the revenue stream within the telecommunications business model. Distinguishes between recurring subscription revenue, variable usage charges, and one-time equipment sales.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date when the performance obligation period ends. For over-time recognition, this marks the completion of the revenue recognition period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date when the performance obligation period begins. For over-time recognition, this marks the start of the revenue recognition period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'Standalone selling price of the performance obligation used for transaction price allocation in bundled arrangements. Required for IFRS 15 / ASC 606 compliance in multi-element contracts.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionPriceAllocated rdf:type rdf:Property ;
    rdfs:label 'Transaction Price Allocated' ;
    rdfs:comment 'Total transaction price allocated to this performance obligation from the contract. For multi-element arrangements, this represents the standalone selling price allocation per IFRS 15 / ASC 606 requirements.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'Estimated amount of variable consideration included in the transaction price. Includes usage overages, performance bonuses, volume discounts, and other variable pricing elements subject to constraint.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting record. Primary key for the tax posting entity.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'The gross base amount on which the tax is calculated, before tax is applied. This is the taxable amount in the transaction currency.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Local Base Amount' ;
    rdfs:comment 'The tax base amount converted to the local reporting currency of the company.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Amount' ;
    rdfs:comment 'The tax amount converted to the local reporting currency of the company.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptionIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction qualifies for tax exemption under applicable regulations.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'The human-readable name of the tax jurisdiction or authority (e.g., United States IRS, UK HMRC, India GST Council).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate percentage applied to the base amount to calculate the tax amount. For example, 20.00 for 20% VAT.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'The statutory tax reporting period to which this posting belongs, formatted as YYYY-MM or YYYY-QQ for monthly or quarterly tax returns.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'The reference number of the tax return filing in which this tax posting is included. Links the posting to the statutory tax return submission.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Return Status' ;
    rdfs:comment 'The current status of the tax return associated with this posting in the tax compliance workflow.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax transaction indicating whether it is input tax (recoverable), output tax (payable), withholding tax, use tax, reverse charge, or import tax.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxCertificate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Certificate' ;
    rdfs:comment 'The certificate number issued for withholding tax deducted, required for vendor tax credit claims.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this posting represents withholding tax deducted at source.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key for the vendor invoice entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:cashDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Amount' ;
    rdfs:comment 'The discount amount taken for early payment according to the payment terms (e.g., 2% discount if paid within 10 days). Reduces the net payment amount and improves working capital efficiency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Date' ;
    rdfs:comment 'The last date on which the cash discount can be taken. Used for payment run optimization to maximize early payment discounts and reduce procurement costs.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'Classification of the invoice as capital expenditure (CAPEX) for long-term assets like network equipment and infrastructure, or operational expenditure (OPEX) for recurring costs like software licenses, interconnect settlements, and facility leases. Critical for financial planning, ROI measurement, and EBITDA calculation.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming physical receipt of materials or completion of services. Part of the three-way match process to validate invoice accuracy before payment.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services covered by the invoice. Provides business context for the invoice purpose, such as network equipment purchase, fiber installation services, software license renewal, interconnect settlement, or facility lease payment.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Flag indicating whether the invoice is blocked from payment processing. True if the invoice is on hold due to disputes, missing approvals, or compliance issues. False if the invoice is eligible for payment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'The reason code or description explaining why the invoice is blocked from payment. Common reasons include pending approval, disputed charges, missing documentation, or vendor compliance issues.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Indicates whether the invoice has been successfully matched against the purchase order and goods receipt. Matched invoices pass all validation checks, unmatched invoices have discrepancies, partial matches have some lines matched, variance within tolerance has acceptable differences, and variance exceeds tolerance requires manual review.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccount rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'The bank account number to which payment should be remitted. Used for electronic payment processing and vendor master data validation.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of tax withheld from the vendor payment as required by tax regulations. Reduces the net payment to the vendor and is remitted to tax authorities on behalf of the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPaymentId rdf:type rdf:Property ;
    rdfs:label 'Vendor Payment Id' ;
    rdfs:comment 'Unique identifier for the vendor payment transaction. Primary key for the vendor payment entity.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'User ID of the person who created the payment record. Used for audit trails and segregation of duties compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the payment record. Used for audit trails and change management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the payment run batch that processed this payment. Groups payments executed together in a single payment run for treasury operations and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net amount actually disbursed to the vendor after applying cash discounts and withholding taxes. Represents the final payment value transferred to the vendor.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount disbursed to the vendor in the payment transaction. Represents the gross payment value before any adjustments or discounts.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Approval status of the payment transaction. Indicates whether the payment is pending approval, approved, or rejected per internal controls.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Batch Number' ;
    rdfs:comment 'Batch number assigned by the payment processor for grouped payments. Used for payment reconciliation and bank statement matching.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount. Indicates the currency in which the payment was made (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-text description or memo for the payment transaction. Provides additional context about the payment purpose or special instructions.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'Externally visible payment document number assigned by the financial system. Used for payment tracking, reconciliation, and audit trails.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorName rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Name' ;
    rdfs:comment 'Name of the payment processor or bank that executed the payment. Used for payment tracking and reconciliation.' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Payment Term Code' ;
    rdfs:comment 'Payment term code that governed this payment. Indicates the agreed payment terms with the vendor (e.g., Net 30, 2/10 Net 30).' ;
    rdfs:domain ind:VendorPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Commercial Owner Employee Id' ;
    rdfs:comment 'Reference to the internal employee responsible for managing and renewing this carrier agreement. Typically the Wholesale or Interconnect Account Manager. Used for escalation and renewal workflow routing.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:counterpartyCarrierId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Carrier Id' ;
    rdfs:comment 'Reference to the domestic or international operator that is the counterparty to this agreement. Links to the carrier/partner master record in the interconnect domain.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:iotTariffId rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Id' ;
    rdfs:comment 'Reference to the Inter-Operator Tariff (IOT) rate table applicable to this agreement. The IOT table defines per-unit wholesale rates for voice (per minute), SMS (per message), and data (per MB/GB) exchanged between operators.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IotTariff .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive commercial name of the carrier agreement (e.g., \'Roaming IOT Agreement – Carrier X 2024\'). Used for display in BSS portals and settlement reports.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the carrier agreement. DRAFT = under negotiation; ACTIVE = commercially live and binding; SUSPENDED = temporarily halted by mutual or unilateral action; TERMINATED = permanently ended; EXPIRED = reached end date without renewal; PENDING_APPROVAL = awaiting regulatory or internal sign-off.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carrier agreement by commercial relationship type. IOT = Inter-Operator Tariff roaming; CAMEL = Customised Applications for Mobile networks Enhanced Logic; MVNO_HOSTING = Mobile Virtual Network Operator (MVNO) hosting arrangement; NATIONAL_ROAMING = domestic network sharing; WHOLESALE_BROADBAND = wholesale broadband resale; CAPACITY_RESALE = bandwidth/capacity resale; TRANSIT = transit traffic routing; PEERING = direct traffic exchange. [ENUM-REF-CANDIDATE: IOT|CAMEL|MVNO_HOSTING|NATIONAL_ROAMING|WHOLESALE_BROADBAND|CAPACITY_RESALE|TRANSIT|PEERING — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version number of the agreement document (e.g., \'1.0\', \'2.3\'). Incremented when amendments are executed. Enables tracking of agreement evolution and ensures the correct rate tables are applied for each version period.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments executed against this agreement since its original signing. Provides a quick indicator of agreement complexity and negotiation history.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveredServices rdf:type rdf:Property ;
    rdfs:label 'Covered Services' ;
    rdfs:comment 'Comma-separated list of telecommunication services covered under this agreement (e.g., VOICE, SMS, DATA, VOLTE, VONR, MMS, CAMEL_GPRS). Governs which service types are eligible for IOT settlement and TAP file exchange. [ENUM-REF-CANDIDATE: VOICE|SMS|DATA|VOLTE|VONR|MMS|CAMEL_GPRS|USSD — promote to reference product]' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionAddendumFlag rdf:type rdf:Property ;
    rdfs:label 'Data Protection Addendum Flag' ;
    rdfs:comment 'Indicates whether a data protection addendum (DPA) is attached to this agreement, governing the processing of subscriber personal data exchanged between operators in compliance with GDPR or equivalent regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving financial or operational disputes arising under this agreement. GSMA_MEDIATION refers to the GSMA Billing and Accounting Dispute Resolution process.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Prevention Flag' ;
    rdfs:comment 'Indicates whether this agreement includes specific fraud prevention obligations such as NRTRDE, SIM box detection cooperation, or GSMA Fraud Information Gathering System (FIGS) participation.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountryCode rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern this agreement (e.g., GBR for English law, USA for US law). Relevant for regulatory compliance and dispute resolution.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Interconnect Agreement Ref' ;
    rdfs:comment 'External reference number or document identifier for the physical signed agreement document, as stored in the document management system or SAP S/4HANA contract repository. Enables traceability to the legal instrument.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minVolumeCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Min Volume Commitment Units' ;
    rdfs:comment 'Minimum traffic volume committed by one or both parties under this agreement, expressed in the unit defined by min_volume_unit (e.g., minutes, MB, messages). Triggers true-up billing if actual volume falls below this threshold.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Min Volume Unit' ;
    rdfs:comment 'Unit of measure for the minimum volume commitment (min_volume_commitment_units). MINUTES = voice traffic; MEGABYTES/GIGABYTES = data traffic; MESSAGES = SMS/MMS; ERLANGS = traffic intensity for capacity agreements.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkGeneration rdf:type rdf:Property ;
    rdfs:label 'Network Generation' ;
    rdfs:comment 'Radio access network generation(s) covered by this agreement. 2G = GSM/GPRS/EDGE; 3G = UMTS/HSPA; 4G_LTE = Long-Term Evolution (LTE); 5G_NR = 5G New Radio (NR); ALL = all generations. Determines applicable IOT tariff tables and NRTRDE reporting scope.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement. Governs the termination workflow in contract lifecycle management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrtrdeFlag rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Flag' ;
    rdfs:comment 'Indicates whether this agreement requires Near Real-Time Roaming Data Exchange (NRTRDE) reporting per GSMA PRD FS.11. NRTRDE enables fraud detection by providing near-real-time CDR visibility to the home operator.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrtrdeTransmissionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Transmission Window Hours' ;
    rdfs:comment 'Maximum number of hours within which NRTRDE files must be transmitted to the home operator after the roaming CDR is generated. Standard GSMA requirement is 4 hours; some bilateral agreements specify tighter windows.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal cycle when auto_renewal_flag is True. Null when auto-renewal is not applicable.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roamingDirection rdf:type rdf:Property ;
    rdfs:label 'Roaming Direction' ;
    rdfs:comment 'Direction of roaming traffic covered by this agreement. INBOUND = foreign subscribers roaming on Telecommunication\'s network; OUTBOUND = Telecommunication\'s subscribers roaming on the counterparty\'s network; BILATERAL = both directions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial settlement under this agreement (e.g., USD, EUR, GBP). Governs currency conversion in Amdocs Revenue Management inter-operator billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency at which financial settlement is performed between the parties under this agreement. Governs the billing cycle in Amdocs Revenue Management inter-operator invoicing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Calendar date on which all parties executed the agreement. May precede the effective_from_date during a transition or notice period. Used for legal and audit trail purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapFileExchangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tap File Exchange Flag' ;
    rdfs:comment 'Indicates whether this agreement mandates Transferred Account Procedure (TAP) file exchange for roaming CDR settlement. True = TAP files must be exchanged per GSMA PRD TD.57 specifications.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapVersion rdf:type rdf:Property ;
    rdfs:label 'Tap Version' ;
    rdfs:comment 'Version of the GSMA Transferred Account Procedure (TAP) standard used for CDR file exchange under this agreement. Governs file format and field mapping in the TAP processing pipeline.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trueUpFrequency rdf:type rdf:Property ;
    rdfs:label 'True Up Frequency' ;
    rdfs:comment 'Frequency at which minimum volume commitment true-up calculations are performed. If actual traffic falls below min_volume_commitment_units within the period, a shortfall charge is raised in Amdocs Revenue Management.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal or trading name of the carrier, transit operator, MVNO, or wholesale partner as registered with the relevant regulatory authority. Used as the primary human-readable identifier across all interconnect domain products.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier relationship. Active indicates live traffic exchange; suspended indicates temporary halt pending dispute or non-payment; terminated indicates the relationship has ended; pending indicates onboarding in progress; inactive indicates dormant with no current traffic.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier by network ownership and service role: MNO (Mobile Network Operator), MVNO (Mobile Virtual Network Operator), transit (transit/wholesale carrier), IXC (Interexchange Carrier), LEC (Local Exchange Carrier), ISP (Internet Service Provider). Drives applicable tariff tables, settlement rules, and regulatory reporting.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Carrier Code' ;
    rdfs:comment 'Carrier identifier assigned by the clearinghouse (e.g., Syniverse or BICS carrier code) used for TAP file routing, NRTRDE submission, and financial settlement matching within the clearinghouse platform.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseName rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Name' ;
    rdfs:comment 'Name of the financial and data clearinghouse through which TAP file exchange and inter-operator financial settlement is processed for this carrier (e.g., HSCSD, Syniverse, BICS). Required for TAP file routing and settlement reconciliation.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialContactEmail rdf:type rdf:Property ;
    rdfs:label 'Commercial Contact Email' ;
    rdfs:comment 'Email address for the carrier\'s commercial or wholesale account management team. Used for agreement negotiations, invoice disputes, and settlement correspondence.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Data Roaming Enabled' ;
    rdfs:comment 'Indicates whether GPRS/LTE/5G NR data roaming is active with this carrier. When true, data CDRs from this carrier\'s subscribers are processed through the TAP/NRTRDE pipeline and rated against the applicable IOT data tariff.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc Registration Number' ;
    rdfs:comment 'Ten-digit FCC Registration Number (FRN) assigned to US-based carriers by the Federal Communications Commission. Required for FCC regulatory filings, Form 499 reporting, and USAC fund contributions tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiveGRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Five G Roaming Enabled' ;
    rdfs:comment 'Indicates whether 5G NR (New Radio) roaming is active with this carrier. Requires 5G roaming agreement, SEPP (Security Edge Protection Proxy) interconnect, and N32 interface configuration per 3GPP TS 33.501.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Level' ;
    rdfs:comment 'Fraud risk classification for this carrier based on historical NRTRDE anomalies, grey route incidents, and GSMA FASG (Fraud and Security Group) advisories. Drives real-time fraud monitoring thresholds and NRTRDE file frequency.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectAgreementType rdf:type rdf:Property ;
    rdfs:label 'Interconnect Agreement Type' ;
    rdfs:comment 'Type of interconnect arrangement with this carrier: direct (direct circuit interconnect), transit (traffic routed via a third-party transit carrier), peering (IP or voice peering arrangement), wholesale (wholesale traffic purchase/sale), none (no active interconnect).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffGroup rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Group' ;
    rdfs:comment 'IOT tariff group classification assigned to this carrier, used to look up applicable Inter-Operator Tariff (IOT) rates for roaming settlement. Aligns with GSMA IOT rate tables and bilateral agreement terms. Drives rating of inbound and outbound roaming CDRs.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ir21LastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Ir21 Last Updated Date' ;
    rdfs:comment 'Date on which the carrier\'s GSMA IR.21 roaming information profile was last updated in the GSMA RAEX (Roaming Agreement Exchange) system. Stale IR.21 data can cause roaming activation failures.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ir21ProfileVersion rdf:type rdf:Property ;
    rdfs:label 'Ir21 Profile Version' ;
    rdfs:comment 'Version identifier of the carrier\'s GSMA IR.21 roaming information document on file. IR.21 contains network configuration data required for roaming service activation including IMSI ranges, supported services, and signalling parameters.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTapFileReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Tap File Received Date' ;
    rdfs:comment 'Date of the most recently received TAP (Transferred Account Procedure) file from this carrier. Used to monitor TAP file exchange health and detect stale or missing files that may indicate a processing issue or carrier-side problem.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTapFileSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Tap File Sent Date' ;
    rdfs:comment 'Date of the most recently sent TAP file to this carrier. Used to monitor outbound TAP file exchange health and ensure timely delivery within GSMA-mandated submission windows.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lteRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Lte Roaming Enabled' ;
    rdfs:comment 'Indicates whether LTE (4G) data roaming is active with this carrier. Distinct from VoLTE; covers data-only LTE roaming sessions rated and settled via TAP3 or DIAMETER-based online charging.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mcc rdf:type rdf:Property ;
    rdfs:label 'Mcc' ;
    rdfs:comment 'Three-digit ITU-assigned Mobile Country Code (MCC) identifying the country of the carrier\'s home network. Combined with MNC to form the full PLMN identifier used in roaming and signalling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnc rdf:type rdf:Property ;
    rdfs:label 'Mnc' ;
    rdfs:comment 'Two- or three-digit ITU-assigned Mobile Network Code (MNC) identifying the carrier\'s specific network within its country. Combined with MCC to form the PLMN identifier used in HLR/HSS, roaming agreements, and CDR processing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocEmail rdf:type rdf:Property ;
    rdfs:label 'Noc Email' ;
    rdfs:comment 'Primary email address for the carrier\'s Network Operations Center (NOC) used for fault escalation, outage notifications, and interconnect incident management. Operational contact for network-layer issues.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocPhone rdf:type rdf:Property ;
    rdfs:label 'Noc Phone' ;
    rdfs:comment '24/7 phone number for the carrier\'s Network Operations Center (NOC) in E.164 international format. Used for real-time fault escalation, SLA breach notification, and interconnect outage coordination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeEnabled rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Enabled' ;
    rdfs:comment 'Indicates whether this carrier participates in NRTRDE (Near Real-Time Roaming Data Exchange) for near-real-time roaming fraud detection and usage monitoring. When true, NRTRDE files must be exchanged within the GSMA-mandated 4-hour window.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the carrier was formally onboarded into Telecommunication\'s interconnect systems including OSS/BSS provisioning, TAP file pipeline configuration, and clearinghouse registration. Distinct from relationship_start_date which may precede system activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredInterconnectRoute rdf:type rdf:Property ;
    rdfs:label 'Preferred Interconnect Route' ;
    rdfs:comment 'Preferred routing method for interconnect traffic to/from this carrier: direct (direct circuit), via_transit (through a transit carrier), via_iplc (International Private Leased Circuit), via_mpls (MPLS backbone), via_sdwan (SD-WAN overlay). Used by NOC for traffic engineering.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region grouping for the carrier (e.g., APAC, EMEA, AMER, LATAM). Used for regional traffic analysis, IOT tariff banding, and wholesale reporting. [ENUM-REF-CANDIDATE: APAC|EMEA|AMER|LATAM|MEA|CEUR — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date on which the commercial and operational relationship with this carrier was or is scheduled to be terminated. Null for active ongoing relationships. Used for agreement expiry tracking and traffic wind-down planning.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the commercial and operational relationship with this carrier was formally established. Marks the beginning of the carrier\'s lifecycle in the interconnect registry and the effective date of the first agreement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roamingAgreementType rdf:type rdf:Property ;
    rdfs:label 'Roaming Agreement Type' ;
    rdfs:comment 'Type of roaming agreement in place with this carrier: bilateral (direct two-way roaming), multilateral (via GSMA or regional body), MVNO_host (carrier hosts an MVNO), transit_only (transit traffic only, no retail roaming), none (no roaming, interconnect only).' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial settlement with this carrier (e.g., USD, EUR, GBP). Determines the currency in which TAP invoices, IOT charges, and interconnect invoices are denominated and paid.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsInterconnectEnabled rdf:type rdf:Property ;
    rdfs:label 'Sms Interconnect Enabled' ;
    rdfs:comment 'Indicates whether SMS (Short Message Service) interconnect is active with this carrier. Drives SMS CDR routing, A2P/P2P SMS settlement, and grey route detection.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spid rdf:type rdf:Property ;
    rdfs:label 'Spid' ;
    rdfs:comment 'Four-digit Service Provider Identifier (SPID) assigned by the North American Numbering Plan Administrator (NANPA) or local number portability administrator. Used for MNP (Mobile Number Portability) routing and LNP database queries.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tadigCode rdf:type rdf:Property ;
    rdfs:label 'Tadig Code' ;
    rdfs:comment 'Five-character GSMA-assigned TADIG code uniquely identifying the carrier for TAP file exchange and inter-operator roaming settlement. Mandatory for all MNO and MVNO roaming partners. Used as the primary key in TAP file headers and NRTRDE records.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceInterconnectEnabled rdf:type rdf:Property ;
    rdfs:label 'Voice Interconnect Enabled' ;
    rdfs:comment 'Indicates whether voice traffic (PSTN/VoIP/VoLTE) interconnect is active with this carrier. Drives CDR routing, rating, and settlement processing for voice traffic.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volteRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Volte Roaming Enabled' ;
    rdfs:comment 'Indicates whether VoLTE (Voice over LTE) roaming via IMS (IP Multimedia Subsystem) is active with this carrier. Requires bilateral IMS interconnect configuration and specific IR.92/IR.94 profile exchange.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poiId rdf:type rdf:Property ;
    rdfs:label 'Poi Id' ;
    rdfs:comment 'Unique surrogate identifier for the Point of Interconnect (POI) master record. Primary key for the interconnect_poi entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Poi .

ind:nmsElementId rdf:type rdf:Property ;
    rdfs:label 'Nms Element Id' ;
    rdfs:comment 'Identifier of the corresponding network element in the Network Management System (NMS) — Nokia NetAct or Ericsson Network Manager — that monitors this POI. Enables correlation between the business POI record and real-time network telemetry.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:peeringArrangementId rdf:type rdf:Property ;
    rdfs:label 'Peering Arrangement Id' ;
    rdfs:comment 'Foreign key linking to interconnect.peering_arrangement. Business justification: Point of Interconnect (POI) represents physical/logical handoff points that may be associated with specific peering arrangements. Adding FK to peering_arrangement links infrastructure to commercial ag' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeeringArrangement .

ind:redundantPoiId rdf:type rdf:Property ;
    rdfs:label 'Redundant Poi Id' ;
    rdfs:comment 'Self-referencing identifier of the backup or redundant POI that provides failover capacity for this POI. Null if no redundant POI is designated. Used in network resilience and failover planning.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Poi .

ind:responsibleTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Responsible Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Telecommunications POIs require assigned technicians for maintenance, fault resolution, capacity upgrades, and emergency response. Business process: POI maintenance scheduling, SLA compliance tracking' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:bandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mbps' ;
    rdfs:comment 'Total provisioned bandwidth capacity at this POI in megabits per second (Mbps). Applicable primarily for IP/SIP, MPLS, and Ethernet interconnect types. Used for traffic engineering and QoS planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clliCode rdf:type rdf:Property ;
    rdfs:label 'Clli Code' ;
    rdfs:comment 'Telcordia/iconectiv Common Language Location Identifier (CLLI) code for the network element or building where this POI is located. Industry-standard 11-character code used in OSS provisioning and regulatory filings.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmdbCiReference rdf:type rdf:Property ;
    rdfs:label 'Cmdb Ci Reference' ;
    rdfs:comment 'ServiceNow CMDB Configuration Item (CI) identifier for this POI. Enables linking the POI business record to ITSM incident, change, and problem management workflows.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name of the data center or colocation facility hosting the POI for IP-based or MPLS interconnects (e.g., \'Equinix NY5\', \'CyrusOne Dallas\'). Applicable for IP/SIP and MPLS interconnect types.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which this POI was or is scheduled to be permanently decommissioned and removed from service. Null if the POI is still active. Used for lifecycle management and capacity reclamation planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeName rdf:type rdf:Property ;
    rdfs:label 'Exchange Name' ;
    rdfs:comment 'Name of the telephone exchange, central office, or network exchange facility where the POI is physically housed (e.g., \'Manhattan Central Office\', \'Chicago Exchange 5\'). Used in OSS topology mapping.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectType rdf:type rdf:Property ;
    rdfs:label 'Interconnect Type' ;
    rdfs:comment 'Technology type of the interconnect at this POI. TDM = Time Division Multiplexing (legacy PSTN); IP_SIP = IP-based Session Initiation Protocol; MPLS = Multiprotocol Label Switching; ETHERNET = Layer 2 Ethernet handoff; FIBER = direct fiber interconnect.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Traffic jurisdiction classification for this POI. INTERSTATE = traffic crossing state lines (FCC jurisdiction); INTRASTATE = within-state traffic (state PUC jurisdiction); INTERNATIONAL = cross-border traffic; LOCAL = local exchange traffic. Determines applicable tariff and regulatory regime.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent physical or logical audit of this POI, verifying that the as-built configuration matches the system of record. Required for regulatory compliance and CMDB accuracy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window' ;
    rdfs:comment 'Scheduled maintenance window for this POI expressed as a cron-style or free-text schedule (e.g., \'SUN 02:00-04:00 UTC\'). Used by NOC for planned outage coordination and change management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocContact rdf:type rdf:Property ;
    rdfs:label 'Noc Contact' ;
    rdfs:comment 'Contact details (name, phone, or email) for the Network Operations Center (NOC) team responsible for monitoring and managing this POI. Used for fault escalation and incident coordination.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle state of the POI. ACTIVE = in-service and carrying traffic; PROVISIONING = being set up; SUSPENDED = temporarily halted; DECOMMISSIONED = permanently retired from service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringType rdf:type rdf:Property ;
    rdfs:label 'Peering Type' ;
    rdfs:comment 'Classification of the peering arrangement at this POI. PUBLIC = via internet exchange point (IXP); PRIVATE = direct bilateral peering; BILATERAL = two-party agreement; MULTILATERAL = multi-party peering fabric. Applicable for IP peering POIs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiCategory rdf:type rdf:Property ;
    rdfs:label 'Poi Category' ;
    rdfs:comment 'Business classification of the POI by traffic scope. DOMESTIC = national carrier interconnect; INTERNATIONAL = cross-border carrier handoff; TRANSIT = pass-through traffic routing; PEERING = bilateral traffic exchange; WHOLESALE = MVNO or reseller interconnect.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiCode rdf:type rdf:Property ;
    rdfs:label 'Poi Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the POI, used in regulatory filings, carrier agreements, and OSS/BSS systems. Unique across all interconnect points. Sourced from Netcracker OSS/BSS Resource Inventory.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poiName rdf:type rdf:Property ;
    rdfs:label 'Poi Name' ;
    rdfs:comment 'Human-readable descriptive name for the POI, typically referencing the exchange location or data center (e.g., \'NYC-Manhattan-Equinix-POI-01\'). Used in operational dashboards and carrier communications.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:popCode rdf:type rdf:Property ;
    rdfs:label 'Pop Code' ;
    rdfs:comment 'Code identifying the Point of Presence (POP) network node associated with this POI. A POP is the physical network access location; multiple POIs may share a POP. Used in network topology and routing tables.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStandard rdf:type rdf:Property ;
    rdfs:label 'Protocol Standard' ;
    rdfs:comment 'Signaling or routing protocol standard used at this POI. SIP = Session Initiation Protocol; H.323 = ITU multimedia protocol; SS7 = Signaling System 7 (PSTN); ISUP = ISDN User Part; SIGTRAN = SS7 over IP; BGP = Border Gateway Protocol; LDP = Label Distribution Protocol (MPLS).' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyFlag rdf:type rdf:Property ;
    rdfs:label 'Redundancy Flag' ;
    rdfs:comment 'Indicates whether this POI has a redundant or backup interconnect path configured (True = redundant path exists; False = single path, no redundancy). Critical for SLA risk assessment and network resilience planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Regulatory classification of the POI as determined by applicable telecommunications authority (e.g., FCC, Ofcom, BEREC). Determines whether interconnect rates are tariff-regulated or commercially negotiated. Critical for compliance reporting.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityCircuits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Circuits' ;
    rdfs:comment 'Total provisioned circuit capacity at this POI expressed as number of circuits (DS0 equivalents for TDM, or logical channels for IP). Principal quantitative measure of the POI resource. Used for capacity planning and SLA enforcement.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficDirection rdf:type rdf:Property ;
    rdfs:label 'Traffic Direction' ;
    rdfs:comment 'Permitted traffic flow direction at this POI. INBOUND = traffic received from the connected carrier; OUTBOUND = traffic sent to the connected carrier; BIDIRECTIONAL = traffic flows in both directions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trunkGroupCode rdf:type rdf:Property ;
    rdfs:label 'Trunk Group Code' ;
    rdfs:comment 'Reference to the trunk group associated with this POI. A trunk group is a logical bundle of circuits or channels provisioned at this interconnect point for traffic routing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedCapacityCircuits rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Circuits' ;
    rdfs:comment 'Number of circuits currently in active use at this POI. Used to calculate utilization percentage for capacity management, congestion alerting, and expansion planning.' ;
    rdfs:domain ind:Poi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each interconnect rate record in the wholesale rate schedule. Primary key for the interconnect_rate data product.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer rate record that replaced this one when rate_status is \'superseded\'. Enables forward navigation of the rate version chain for audit and dispute resolution purposes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'Structural basis on which the rate is calculated: flat (single rate regardless of volume), tiered (rate changes at volume thresholds), volume_discount (discounted rate applied retroactively above threshold), or distance_based (rate varies by geographic distance between interconnect points). Determines the rating algorithm applied.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code identifying the destination country for international termination or transit rates (e.g., USA, GBR, DEU). Used for international settlement and regulatory compliance reporting.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPrefix rdf:type rdf:Property ;
    rdfs:label 'Destination Prefix' ;
    rdfs:comment 'E.164 dialled number prefix or number range (e.g., \'+1202\', \'+44207\') to which this rate applies. Enables prefix-based rate lookup during CDR rating and settlement. May represent a country code, area code, or specific number block.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interconnectPointCode rdf:type rdf:Property ;
    rdfs:label 'Interconnect Point Code' ;
    rdfs:comment 'Code identifying the specific Point of Presence (POP) or interconnect gateway at which traffic is exchanged under this rate. Rates may vary by interconnect point due to transport cost differences. Aligns with network inventory records.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffClass rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Class' ;
    rdfs:comment 'IOT tariff classification code as defined by GSMA inter-operator tariff tables, applicable when this rate is used for roaming wholesale settlement. Maps to the GSMA IOT rate category (e.g., IOT-A, IOT-B, IOT-C) for NRTRDE and TAP file processing.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCallDurationSec rdf:type rdf:Property ;
    rdfs:label 'Minimum Call Duration Sec' ;
    rdfs:comment 'Minimum billable call duration in seconds applied during rating. Calls shorter than this threshold are billed at this minimum (e.g., 30-second minimum billing). Common in wholesale voice interconnect agreements to prevent micro-call gaming.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nrtrdeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Applicable Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to NRTRDE (Near Real-Time Roaming Data Exchange) reporting obligations. When true, CDRs rated under this rate must be transmitted to the counterparty within the NRTRDE transmission window for fraud prevention purposes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offPeakRate rdf:type rdf:Property ;
    rdfs:label 'Off Peak Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during off-peak hours (typically evenings and nights on weekdays). Lower than peak rate to reflect reduced network demand. Expressed in settlement currency per billing unit.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Originating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where the traffic originates. Required for international transit and termination rates to distinguish bilateral from multilateral routing scenarios and apply correct regulatory frameworks.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakRate rdf:type rdf:Property ;
    rdfs:label 'Peak Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during peak hours (typically business hours on weekdays). Expressed in the settlement currency per billing unit (e.g., per minute for voice, per event for SMS, per MB for data). This is the principal quantitative rate value for the resource.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this rate entry within the wholesale rate schedule. Used in TAP file references and inter-operator billing reconciliation.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Human-readable descriptive name for the rate entry (e.g., \'US Domestic Voice Termination Peak\', \'EU Roam-Like-At-Home SMS\'). Used in rate schedule documentation and commercial negotiations.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle state of the rate record: active (currently in force for rating), pending (approved but not yet effective), superseded (replaced by a newer rate version), expired (past effective period), or withdrawn (cancelled before activation). Controls whether the rate is used in CDR rating and settlement.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate by traffic direction and role: termination (delivering traffic to destination network), origination (collecting traffic from originating network), transit (passing traffic through an intermediate network), transit_international (cross-border transit), or access (local loop access charge). Governs regulatory framework applicability.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCapRate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Cap Rate' ;
    rdfs:comment 'Maximum rate permitted by the applicable regulatory framework for this service type and destination (e.g., EU RLAH wholesale voice cap of €0.032/min, Ofcom FAMR charge control ceiling). The actual rate must not exceed this cap. Used for compliance validation and regulatory reporting.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roundingIncrementSec rdf:type rdf:Property ;
    rdfs:label 'Rounding Increment Sec' ;
    rdfs:comment 'Duration increment in seconds to which call durations are rounded up for billing purposes (e.g., 6-second or 60-second rounding). Directly impacts settlement amounts and must align with the counterparty carrier agreement terms.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapRateCategory rdf:type rdf:Property ;
    rdfs:label 'Tap Rate Category' ;
    rdfs:comment 'TAP file rate category code as defined in the GSMA Transferred Account Procedure (TAP3) specification. Maps this rate to the correct TAP record type for inter-operator roaming settlement file generation and validation.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Unit of measure against which the rate is applied for billing purposes: per_minute or per_second for voice, per_event for SMS/MMS, per_mb/per_kb/per_gb for data. Determines how CDR volumes are multiplied by the rate to produce settlement charges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold' ;
    rdfs:comment 'Minimum traffic volume (in the rate_unit) at which a tiered or volume-discount rate becomes applicable. Null for flat-rate structures. Used by the rating engine to select the correct rate tier based on cumulative monthly traffic volumes.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weekendRate rdf:type rdf:Property ;
    rdfs:label 'Weekend Rate' ;
    rdfs:comment 'Per-unit wholesale charge applied during weekend periods (Saturday and Sunday). May differ from both peak and off-peak weekday rates. Expressed in settlement currency per billing unit.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Charging Interval Seconds' ;
    rdfs:comment 'The billing increment in seconds used for voice service IOT charge calculation. For example, a value of 60 means charges are calculated per full minute; a value of 1 means per-second billing. Applicable only for voice service types.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationZoneCode rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Code' ;
    rdfs:comment 'The GSMA-defined or operator-defined destination zone code to which this IOT rate applies. Zones group countries or network destinations for wholesale tariff banding. Used in TAP file rating to match usage records to the correct IOT rate.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationZoneName rdf:type rdf:Property ;
    rdfs:label 'Destination Zone Name' ;
    rdfs:comment 'Human-readable name of the destination zone (e.g., \'Zone 1 - EU\', \'Zone 2 - Rest of World\'). Used in settlement reports, finance dashboards, and operator billing correspondence.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveRate rdf:type rdf:Property ;
    rdfs:label 'Effective Rate' ;
    rdfs:comment 'The net IOT rate after applying any negotiated discount_percentage to the standard iot_rate. Stored as a pre-computed field to support high-volume TAP file rating performance. Expressed in the tariff currency per rate_unit.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsmaRateGroup rdf:type rdf:Property ;
    rdfs:label 'Gsma Rate Group' ;
    rdfs:comment 'The GSMA-defined rate group classification for this IOT tariff entry. Rate groups are published in the GSMA IOT rate tables and used to categorise wholesale rates for settlement and benchmarking purposes. Examples: RG1, RG2, RG3 for voice; DG1, DG2 for data.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeNetworkPlmn rdf:type rdf:Property ;
    rdfs:label 'Home Network Plmn' ;
    rdfs:comment 'The GSMA-assigned PLMN code (MCC+MNC) of the home operator network for which this IOT tariff is applicable. Enables multi-PLMN operators to maintain separate IOT rate tables per home network entity.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Initial Duration Seconds' ;
    rdfs:comment 'The initial billing period in seconds for voice calls, which may be charged at a different rate or as a flat fee before the standard per-interval rate applies. Common in IOT tariffs where the first 30 or 60 seconds are charged as a connection fee.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialRate rdf:type rdf:Property ;
    rdfs:label 'Initial Rate' ;
    rdfs:comment 'The IOT rate applied during the initial_duration_seconds period of a voice call, if different from the standard iot_rate. Null if no differentiated initial rate applies. Expressed in the tariff currency.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interOperatorTariffType rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Tariff Type' ;
    rdfs:comment 'Classification of the IOT tariff by commercial arrangement type. \'standard\' for GSMA-published rates, \'preferential\' for bilaterally negotiated lower rates, \'reciprocal\' for symmetric bilateral agreements, \'benchmark\' for reference rates used in dispute resolution.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Iot Publication Date' ;
    rdfs:comment 'The date on which this IOT tariff was officially published by the GSMA or notified by the visited operator. Used for audit trail and to verify compliance with GSMA notification lead-time requirements prior to the effective_from_date.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iotRate rdf:type rdf:Property ;
    rdfs:label 'Iot Rate' ;
    rdfs:comment 'The wholesale IOT rate charged by the visited operator to the home operator for the specified service type and destination zone. Expressed in the currency defined by currency_code. For voice: rate per minute; for SMS: rate per message; for data: rate per kilobyte or megabyte as defined by rate_unit. This is the principal quantitative fact of the IOT tariff record.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'The minimum wholesale charge applicable per usage event under this IOT tariff, expressed in the tariff currency. Ensures a floor charge is applied even for very short calls or minimal data usage. Used in TAP file rating to enforce minimum billing thresholds.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationReference rdf:type rdf:Property ;
    rdfs:label 'Notification Reference' ;
    rdfs:comment 'The reference number or identifier of the official GSMA or bilateral operator notification document that introduced or amended this IOT tariff. Provides an audit trail linking the tariff record to the formal inter-operator communication.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeEligible rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Eligible' ;
    rdfs:comment 'Indicates whether usage records rated under this IOT tariff are subject to NRTRDE near-real-time roaming data exchange reporting to the home operator. True for operators with NRTRDE obligations under GSMA PRD TD.57. Used for fraud detection and real-time roaming cost monitoring.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakIndicator rdf:type rdf:Property ;
    rdfs:label 'Peak Indicator' ;
    rdfs:comment 'Indicates whether this IOT tariff applies to peak, off-peak, or flat (time-independent) usage periods. Some bilateral roaming agreements differentiate IOT rates by time-of-day. \'flat\' indicates no time-of-day differentiation.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the IOT rate. Defines the denominator for the iot_rate value. \'per_minute\' for voice, \'per_message\' for SMS/MMS, \'per_kb\' or \'per_mb\' for data, \'per_event\' for supplementary services. Required for correct TAP file charge calculation.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for operational notes, special conditions, or exceptions associated with this IOT tariff record. Used by the interconnect team to document bilateral negotiation context, GSMA waiver references, or rate dispute notes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'The rounding method applied to calculated IOT charges during TAP file rating. Governs how fractional charge amounts are rounded to the precision defined by tap_decimal_places. Ensures consistent charge calculation between home and visited operators.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSubtype rdf:type rdf:Property ;
    rdfs:label 'Service Subtype' ;
    rdfs:comment 'Granular classification of the roaming service within the service_type. Examples: MOC (Mobile Originated Call), MTC (Mobile Terminated Call), MO-SMS, MT-SMS, GPRS, VoLTE, 5G NR data. Used for detailed IOT rate differentiation and TAP file reconciliation. [ENUM-REF-CANDIDATE: moc|mtc|mo_sms|mt_sms|gprs|volte|5g_nr|mms_mo|mms_mt|supplementary — promote to reference product]' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Tap Decimal Places' ;
    rdfs:comment 'The number of decimal places used to express the IOT rate in TAP file records, as defined by the GSMA TAP3 specification. Governs the precision of charge amounts encoded in TAP files exchanged between operators. Typically 5 for most currencies.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapFileType rdf:type rdf:Property ;
    rdfs:label 'Tap File Type' ;
    rdfs:comment 'The GSMA file exchange format type for which this IOT tariff is applicable. TAP3 for standard roaming settlement files, NRTRDE for Near Real-Time Roaming Data Exchange files used for fraud detection, RAP for Returned Account Procedure files handling billing disputes.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this IOT tariff entry within the GSMA/operator tariff catalogue. Used as the business key in TAP file references and inter-operator correspondence.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'Human-readable descriptive name for the IOT tariff entry, used in settlement reports, operator portals, and finance reconciliation dashboards.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle state of the IOT tariff record. Controls whether the tariff is eligible for use in TAP file rating and settlement invoice generation. \'superseded\' indicates a newer version has replaced this record.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffVersion rdf:type rdf:Property ;
    rdfs:label 'Tariff Version' ;
    rdfs:comment 'Version identifier for the IOT tariff record, enabling tracking of rate changes over time. Incremented each time the tariff is revised. Used to ensure TAP file rating applies the correct rate version.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Indicator' ;
    rdfs:comment 'Indicates whether the IOT rate is inclusive of applicable taxes (True) or exclusive of taxes (False). Relevant for operators in jurisdictions where VAT or GST applies to wholesale roaming charges. Impacts settlement invoice tax treatment.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Visited Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the visited network where the roaming subscriber consumed the service. Used to map usage to the correct IOT tariff zone and for regulatory reporting of international roaming charges.' ;
    rdfs:domain ind:IotTariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitedNetworkPlmn rdf:type rdf:Property ;
    rdfs:label 'Visited Network Plmn' ;
    rdfs:comment 'The GSMA-assigned Public Land Mobile Network (PLMN) code (MCC+MNC) of the visited operator network. Used to uniquely identify the roaming partner network for IOT rate lookup and TAP file routing.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnpTransactionId rdf:type rdf:Property ;
    rdfs:label 'Mnp Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each Mobile Number Portability (MNP) transaction record in the interconnect domain. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MnpTransaction .

ind:hlrNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Hlr Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Mobile number portability requires HLR/HSS updates to redirect routing. Operations must track which HLR/HSS network element processed each port for audit, troubleshooting, and regulatory compliance. R' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:recipientPartnerId rdf:type rdf:Property ;
    rdfs:label 'Recipient Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Number portability transactions often involve partner networks (MVNOs) as recipient operators. Business process: MNP coordination with partner operators, regulatory compliance reporting, partner opera' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:authorisationCode rdf:type rdf:Property ;
    rdfs:label 'Authorisation Code' ;
    rdfs:comment 'The Port Authorisation Code (PAC) or equivalent subscriber-provided authorisation token used to validate the subscriber\'s consent for the port-out. Mandatory in many regulatory frameworks (e.g., Ofcom PAC regime, FCC subscriber verification). Null for port-in transactions where PAC is consumed by the gaining operator.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchFileReference rdf:type rdf:Property ;
    rdfs:label 'Batch File Reference' ;
    rdfs:comment 'Reference to the batch file or TAP/NRTRDE file submission in which this MNP transaction was included for inter-operator exchange or regulatory reporting. Supports reconciliation with interconnect file processing workflows.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlrHssUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Hlr Hss Update Status' ;
    rdfs:comment 'Status of the HLR (2G/3G) or HSS/UDM (4G/5G) subscriber profile update triggered by the MNP transaction. \'pending\' — update not yet sent; \'completed\' — subscriber profile successfully updated; \'failed\' — update failed, requiring manual intervention.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interOperatorChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Inter Operator Charge Applicable' ;
    rdfs:comment 'Indicates whether an inter-operator charge (IOT) is applicable for this MNP transaction under the governing carrier agreement. True = charge applies and will be raised in settlement; False = no charge applicable (e.g., regulatory zero-rating or waiver).' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npacOrderReference rdf:type rdf:Property ;
    rdfs:label 'Npac Order Reference' ;
    rdfs:comment 'The order identifier assigned by the Number Portability Administration Centre (NPAC) or equivalent national clearinghouse system (e.g., Syniverse, CODA) for this porting transaction. Used for cross-system reconciliation and regulatory audit.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberRangeOwner rdf:type rdf:Property ;
    rdfs:label 'Number Range Owner' ;
    rdfs:comment 'The operator or entity that holds the ITU/national regulatory authority allocation of the number range (NXX or equivalent) containing the ported MSISDN. May differ from the donor operator in MVNO or wholesale scenarios.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderManagementRef rdf:type rdf:Property ;
    rdfs:label 'Order Management Ref' ;
    rdfs:comment 'The order reference number from Oracle Communications Order and Service Management (OSM) or Netcracker OSS/BSS that orchestrated the service fulfillment actions associated with this MNP transaction (e.g., HLR/HSS update, service deprovisioning/provisioning).' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Port Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this MNP porting request by the Number Portability Administration Centre (NPAC) or equivalent national clearinghouse. Used for cross-operator tracking and regulatory audit.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portStatus rdf:type rdf:Property ;
    rdfs:label 'Port Status' ;
    rdfs:comment 'Current lifecycle status of the MNP transaction. \'pending\' — request received and awaiting validation; \'validated\' — subscriber eligibility confirmed; \'completed\' — number successfully ported; \'rejected\' — request denied (see rejection_reason); \'cancelled\' — request withdrawn before completion.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Porting Duration Hours' ;
    rdfs:comment 'The elapsed time in hours between request_timestamp and completion_timestamp. Used for SLA compliance monitoring against regulatory maximum porting time mandates (e.g., FCC 1-business-day rule, Ofcom 1-working-day rule). Null if port not yet completed.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Porting Window End' ;
    rdfs:comment 'The scheduled end date and time of the porting window. If the port is not completed within this window, the transaction may expire or require rescheduling per regulatory requirements.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Porting Window Start' ;
    rdfs:comment 'The scheduled start date and time of the porting window during which the number transfer is authorised to execute. Regulatory frameworks (e.g., FCC, Ofcom) mandate specific porting windows.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientCarrierName rdf:type rdf:Property ;
    rdfs:label 'Recipient Carrier Name' ;
    rdfs:comment 'Human-readable commercial name of the recipient (gaining) operator. Complements recipient_tadig_code for reporting and business user readability.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTadigCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Tadig Code' ;
    rdfs:comment 'The GSMA TADIG code identifying the recipient (gaining) operator network to which the MSISDN is being ported. Complements donor_tadig_code to fully describe the inter-operator porting pair.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'The latest permissible timestamp by which the MNP transaction must be completed under applicable regulatory rules (e.g., FCC 1-business-day, Ofcom 1-working-day). Used for SLA breach detection and regulatory compliance monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The date and time when the MNP porting request was formally submitted by the subscriber or the gaining operator. This is the principal business event timestamp marking the start of the porting lifecycle.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routingNumberUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Number Update Status' ;
    rdfs:comment 'Indicates whether the routing number in the Number Portability database and HLR/HSS/UDM has been successfully updated following port completion. \'pending\' — update queued; \'updated\' — successfully propagated; \'failed\' — update error requiring intervention; \'not_required\' — no routing change needed.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The monetary amount charged or credited between Telecommunication and the counterparty operator for this MNP transaction under the applicable inter-operator tariff (IOT). Expressed in the settlement currency defined in the carrier agreement. Null if inter_operator_charge_applicable = False.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Subscriber Consent Verified' ;
    rdfs:comment 'Indicates whether the subscriber\'s explicit consent for the number port has been verified and recorded, as required by regulatory frameworks. True = consent confirmed; False = consent not yet verified or verification failed. Critical for regulatory compliance.' ;
    rdfs:domain ind:MnpTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrtrdeRecordId rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each NRTRDE event record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NrtrdeRecord .

ind:tapFileId rdf:type rdf:Property ;
    rdfs:label 'Tap File Id' ;
    rdfs:comment 'Reference to the TAP file that this NRTRDE record will ultimately reconcile against during post-event settlement. Links pre-TAP roaming visibility to the formal TAP billing cycle.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapFile .

ind:visitedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Visited Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: NRTRDE record visited carrier is denormalized via visited_tadig, visited_plmn_id, visited_country_code. Normalizing to interconnect_carrier eliminates redundancy and provides authoritative carrier mas' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:apn rdf:type rdf:Property ;
    rdfs:label 'Apn' ;
    rdfs:comment 'Access Point Name used by the roaming subscriber for the data session, identifying the packet data network gateway and service type (e.g., internet, IMS, enterprise VPN). Applicable for DATA record types. Used for data service classification and IOT tariff selection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Sequence Number' ;
    rdfs:comment 'Sequential number of the NRTRDE transmission batch (file) from the visited operator, used to detect missing batches and ensure complete data receipt. Increments with each new file transmission per GSMA BA.40 batch numbering rules.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Call Duration Seconds' ;
    rdfs:comment 'Duration of the voice call or supplementary service event in seconds, as reported by the visited network. Applicable for VOICE and SUPPLEMENTARY record types. Used for IOT charge calculation and revenue assurance validation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Charge Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the estimated IOT charge is denominated (e.g., USD, EUR, GBP). Required for multi-currency settlement reconciliation between international operators.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Variance Amount' ;
    rdfs:comment 'Monetary difference between the estimated IOT charge in this NRTRDE record and the final charge confirmed in the reconciled TAP file. Populated after TAP reconciliation. Positive value indicates NRTRDE overestimated; negative indicates underestimation. Used for revenue assurance leakage analysis.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeDownlinkKb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Downlink Kb' ;
    rdfs:comment 'Volume of data transmitted from the network to the roaming subscriber\'s device (downlink) in kilobytes during a GPRS/data session. Applicable for DATA record types. Used for IOT data charge calculation.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeUplinkKb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Uplink Kb' ;
    rdfs:comment 'Volume of data transmitted from the roaming subscriber\'s device to the network (uplink) in kilobytes during a GPRS/data session. Applicable for DATA record types. Used for IOT data charge calculation.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dialedNumber rdf:type rdf:Property ;
    rdfs:label 'Dialed Number' ;
    rdfs:comment 'The destination number dialed by the roaming subscriber for voice calls (B-party number in E.164 format). Applicable for MOC record types. Used for fraud detection (e.g., premium rate number abuse, international revenue share fraud) and traffic analysis.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Charge Amount' ;
    rdfs:comment 'Estimated wholesale charge for this roaming event calculated by the visited network using the applicable IOT tariff at time of NRTRDE transmission. This is a pre-settlement estimate; the final charge is confirmed in the TAP file. Used for early revenue assurance and cash flow forecasting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date (UTC) on which the roaming service event occurred, derived from service_start_timestamp. Used as a partition key in the Silver layer lakehouse for efficient time-range queries and daily revenue assurance reporting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudAlertIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Indicator' ;
    rdfs:comment 'Flag indicating that this NRTRDE record has triggered a fraud alert to the Revenue Assurance domain based on anomalous usage patterns (e.g., impossible travel, velocity breach, SIM cloning signatures). True = fraud alert raised; False = no alert.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highUsageIndicator rdf:type rdf:Property ;
    rdfs:label 'High Usage Indicator' ;
    rdfs:comment 'Flag set by the visited network indicating that this subscriber\'s cumulative roaming usage has exceeded a predefined high-usage threshold, triggering potential fraud alert or credit limit notification to the home operator per GSMA BA.40 high-usage detection rules.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeTadig rdf:type rdf:Property ;
    rdfs:label 'Home Tadig' ;
    rdfs:comment '5-character GSMA TADIG code identifying the subscriber\'s home network operator. Used to route NRTRDE records to the correct home PLMN for revenue assurance and fraud detection.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Location Area Code' ;
    rdfs:comment 'Location Area Code identifying the geographic area within the visited network where the roaming event occurred. Used alongside Cell ID for subscriber location tracking and fraud detection in the interconnect domain.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeVersion rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Version' ;
    rdfs:comment 'Version of the GSMA BA.40 NRTRDE standard used to generate this record (e.g., 2.0, 3.0). Required for backward-compatible processing as operators may transmit records under different standard versions during migration periods.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Specific CDR record type classifying the direction and nature of the roaming event. MOC=Mobile Originated Call, MTC=Mobile Terminated Call, GPRS=data session, SMS_MO=outbound SMS, SMS_MT=inbound SMS. Aligns with TAP3 record type taxonomy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the NRTRDE record within a transmission batch, used to detect gaps, duplicates, and ordering issues during inter-operator exchange per GSMA BA.40.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service End Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when the roaming service event concluded. For voice calls this is call release time; for data sessions this is PDP context deactivation. Used to derive call/session duration and validate against usage volume.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Start Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when the roaming service event began — the principal real-world event time. For voice calls this is call answer time; for data sessions this is PDP context activation; for SMS this is submission time. Core field for NRTRDE 4-hour transmission SLA compliance measurement per GSMA BA.40.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Indicator' ;
    rdfs:comment 'Flag indicating whether this NRTRDE record was transmitted outside the GSMA BA.40 4-hour SLA window (transmission_latency_minutes > 240). True = SLA breached; False = within SLA. Used for inter-operator SLA performance reporting and penalty calculation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Tap Reconciliation Status' ;
    rdfs:comment 'Status of reconciliation between this NRTRDE pre-TAP record and the corresponding TAP3 billing record. PENDING=TAP file not yet received; MATCHED=successfully reconciled; UNMATCHED=no corresponding TAP record found; PARTIAL=partial match with charge discrepancy. Critical for revenue assurance.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionLatencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Transmission Latency Minutes' ;
    rdfs:comment 'Elapsed time in minutes between service_start_timestamp and transmission_timestamp. Measures compliance with the GSMA BA.40 4-hour (240-minute) near-real-time transmission SLA. Records exceeding 240 minutes are flagged for SLA breach reporting.' ;
    rdfs:domain ind:NrtrdeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the NRTRDE record was transmitted by the visited network to the home network. Used to calculate transmission latency against the GSMA BA.40 4-hour SLA requirement from service delivery.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Peer Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: Peering arrangement peer is currently denormalized via peer_carrier_name. Normalizing to interconnect_carrier provides authoritative carrier master reference with full carrier attributes (TADIG, MCC/M' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:technicalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Peering arrangements require technical ownership by network engineers responsible for BGP configuration, capacity planning, and SLA monitoring—distinct from commercial ownership. This supports NOC esc' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arrangementCode rdf:type rdf:Property ;
    rdfs:label 'Arrangement Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the peering arrangement (e.g., PEER-2024-NYC-001). Used in operational communications, NOC dashboards, and inter-carrier correspondence.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Descriptive human-readable name for the peering arrangement (e.g., \'Equinix NY4 Private Peering with AS64512\'). Used in reporting and NOC tooling.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementNotes rdf:type rdf:Property ;
    rdfs:label 'Arrangement Notes' ;
    rdfs:comment 'Free-text operational notes capturing special conditions, negotiation history, technical exceptions, or contextual information about this peering arrangement not captured in structured fields.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle state of the peering arrangement. draft = under negotiation; pending_approval = awaiting internal or regulatory sign-off; active = live and carrying traffic; suspended = temporarily halted; terminated = permanently ended; expired = passed effective end date without renewal.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Availability Target Pct' ;
    rdfs:comment 'Agreed minimum uptime percentage for the peering session as specified in the SLA (e.g., 99.9900 = 99.99%). Used for SLA compliance reporting and penalty calculation.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bgpSessionType rdf:type rdf:Property ;
    rdfs:label 'Bgp Session Type' ;
    rdfs:comment 'Type of BGP session established for this peering arrangement. ebgp = External BGP (standard inter-AS peering); ibgp = Internal BGP (used in route-reflector scenarios); ebgp_multihop = eBGP session across multiple IP hops.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Committed Bandwidth Mbps' ;
    rdfs:comment 'Minimum guaranteed bandwidth in megabits per second (Mbps) committed under this peering arrangement. Used for capacity planning, SLA enforcement, and billing in paid peering scenarios.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipVersion rdf:type rdf:Property ;
    rdfs:label 'Ip Version' ;
    rdfs:comment 'IP protocol version(s) supported by this peering session. ipv4 = IPv4 only; ipv6 = IPv6 only; dual_stack = both IPv4 and IPv6 sessions active. Drives network engineering and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ixpName rdf:type rdf:Property ;
    rdfs:label 'Ixp Name' ;
    rdfs:comment 'Name of the Internet Exchange Point (IXP) where public peering occurs (e.g., Equinix IX, DE-CIX, AMS-IX, LINX). Null for private PNI arrangements. Used for peering point inventory and cost allocation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bandwidth Mbps' ;
    rdfs:comment 'Maximum allowable bandwidth in megabits per second (Mbps) for this peering arrangement before traffic shaping or penalties apply. Defines the upper capacity envelope for the interconnect port.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:md5AuthEnabled rdf:type rdf:Property ;
    rdfs:label 'Md5 Auth Enabled' ;
    rdfs:comment 'Indicates whether MD5 TCP authentication is enabled on the BGP session for this peering arrangement to prevent session hijacking. True = MD5 authentication active; False = no MD5 authentication.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nocContactEmail rdf:type rdf:Property ;
    rdfs:label 'Noc Contact Email' ;
    rdfs:comment 'Email address of the peer carrier\'s Network Operations Center (NOC) for operational escalations, fault notifications, and maintenance coordination. Classified confidential as organizational contact data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocContactPhone rdf:type rdf:Property ;
    rdfs:label 'Noc Contact Phone' ;
    rdfs:comment 'Phone number of the peer carrier\'s Network Operations Center (NOC) for 24/7 operational escalations and incident coordination. Classified confidential as organizational contact data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ourAsn rdf:type rdf:Property ;
    rdfs:label 'Our Asn' ;
    rdfs:comment 'BGP Autonomous System Number (ASN) of this carrier\'s routing domain used in this peering session. Required when the carrier operates multiple ASNs across different network segments.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ourBgpIpAddress rdf:type rdf:Property ;
    rdfs:label 'Our Bgp Ip Address' ;
    rdfs:comment 'IP address of this carrier\'s BGP router used to establish the peering session with the counterparty. May be IPv4 or IPv6. Classified confidential as it reveals internal network topology.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetLossTargetPct rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Target Pct' ;
    rdfs:comment 'Maximum agreed packet loss percentage for traffic on this peering arrangement as defined in the SLA (e.g., 0.0100 = 0.01%). Used for QoS (Quality of Service) performance monitoring.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peerAsn rdf:type rdf:Property ;
    rdfs:label 'Peer Asn' ;
    rdfs:comment 'BGP Autonomous System Number (ASN) of the peering counterparty as assigned by a Regional Internet Registry (ARIN, RIPE, APNIC). Uniquely identifies the peer\'s routing domain. Range: 1–4294967295 (32-bit ASN per RFC 6793).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peerBgpIpAddress rdf:type rdf:Property ;
    rdfs:label 'Peer Bgp Ip Address' ;
    rdfs:comment 'IP address of the counterparty\'s BGP router used to establish the peering session. May be IPv4 or IPv6. Classified confidential as it reveals network topology details.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portIdentifier rdf:type rdf:Property ;
    rdfs:label 'Port Identifier' ;
    rdfs:comment 'Unique identifier of the physical or logical interconnect port used for this peering arrangement (e.g., switch/port designation from the IXP or PNI cross-connect). Links to network inventory management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portSpeedGbps rdf:type rdf:Property ;
    rdfs:label 'Port Speed Gbps' ;
    rdfs:comment 'Physical port speed in gigabits per second (Gbps) of the interconnect port used for this peering arrangement (e.g., 1.000, 10.000, 100.000). Used for capacity planning and utilization reporting.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prefixLimit rdf:type rdf:Property ;
    rdfs:label 'Prefix Limit' ;
    rdfs:comment 'Maximum number of BGP route prefixes this carrier will accept from the peer. Exceeding this limit triggers a BGP session reset or route filtering. Critical for route table stability and security.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratioTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Ratio Tolerance Pct' ;
    rdfs:comment 'Allowable percentage deviation from the agreed traffic ratio before the arrangement is considered out of balance and subject to review or financial settlement. Expressed as a percentage (e.g., 20.00 = ±20%).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days before expiry_date that a renewal notice must be issued to the peer carrier. Used to trigger automated renewal workflow alerts in the NOC and commercial teams.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpkiValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Rpki Validation Enabled' ;
    rdfs:comment 'Indicates whether Resource Public Key Infrastructure (RPKI) route origin validation is enforced on BGP announcements received from this peer. True = RPKI validation active; False = not enforced. Supports FCC routing security mandates.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementRate rdf:type rdf:Property ;
    rdfs:label 'Settlement Rate' ;
    rdfs:comment 'Agreed per-unit financial rate applied to traffic exchange in paid peering arrangements (e.g., rate per Mbps or per GB). Expressed in the settlement_currency. Business-confidential commercial term.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRateUnit rdf:type rdf:Property ;
    rdfs:label 'Settlement Rate Unit' ;
    rdfs:comment 'Unit of measure for the settlement rate (e.g., per_mbps = per megabit per second of committed bandwidth; per_gb = per gigabyte of traffic; flat_monthly = fixed monthly fee regardless of volume).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Code' ;
    rdfs:comment 'Reference code linking this peering arrangement to the applicable Service Level Agreement (SLA) document governing latency, packet loss, availability, and jitter commitments. Used for SLA compliance reporting.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficRatioInbound rdf:type rdf:Property ;
    rdfs:label 'Traffic Ratio Inbound' ;
    rdfs:comment 'Agreed inbound traffic ratio component used to calculate the traffic balance ratio (e.g., 1.0 in a 1:1 ratio). Settlement-free peering typically requires ratios within a defined tolerance band (e.g., 1:2 or 2:1).' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficRatioOutbound rdf:type rdf:Property ;
    rdfs:label 'Traffic Ratio Outbound' ;
    rdfs:comment 'Agreed outbound traffic ratio component used to calculate the traffic balance ratio (e.g., 2.0 in a 1:2 ratio). Imbalance beyond the agreed threshold may trigger renegotiation or conversion to paid peering.' ;
    rdfs:domain ind:PeeringArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rapFileId rdf:type rdf:Property ;
    rdfs:label 'Rap File Id' ;
    rdfs:comment 'Unique surrogate identifier for the RAP file record in the interconnect settlement system. Primary key for the rap_file data product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RapFile .

ind:primaryRapResubmissionTapFileId rdf:type rdf:Property ;
    rdfs:label 'Primary Rap Resubmission Tap File Id' ;
    rdfs:comment 'Reference to the corrected TAP file resubmitted by the sender after processing this RAP rejection. Tracks the correction lifecycle and links the original rejection to its resolution.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapFile .

ind:senderCarrierId rdf:type rdf:Property ;
    rdfs:label 'Sender Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: RAP file sender is denormalized via sender_tadig. Normalizing to interconnect_carrier provides authoritative carrier master reference. The FK will be populated at RAP file creation when sender is know' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:sourceTapFileId rdf:type rdf:Property ;
    rdfs:label 'Source Tap File Id' ;
    rdfs:comment 'Reference to the originating TAP file whose records are being rejected in this RAP file. Links the RAP rejection back to the specific TAP file that contained the erroneous records.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TapFile .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the recipient operator formally acknowledged receipt and acceptance of this RAP file. Required for GSMA bilateral exchange compliance and settlement audit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingHouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearing House Code' ;
    rdfs:comment 'Identifier of the GSMA-accredited data clearing house (DCH) or billing clearing house (BCH) that processed or routed this RAP file between operators (e.g., SYNIVERSE, HROAMING). Required for multi-lateral settlement audit.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Date and time when the RAP file was generated by the sending operator\'s settlement system. Represents the principal business event timestamp for this RAP file record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileChecksum rdf:type rdf:Property ;
    rdfs:label 'File Checksum' ;
    rdfs:comment 'Cryptographic checksum (e.g., MD5 or SHA-256 hash) of the RAP file used to verify file integrity during transmission and ingestion. Supports non-repudiation and data quality assurance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Physical size of the RAP file in bytes as received from the clearing house or sender operator. Used for file integrity validation and transmission monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorNotes rdf:type rdf:Property ;
    rdfs:label 'Operator Notes' ;
    rdfs:comment 'Free-text notes entered by the settlement operations team regarding this RAP file, such as root-cause analysis findings, escalation context, or correction instructions communicated to the counterparty operator.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRejectionCode rdf:type rdf:Property ;
    rdfs:label 'Primary Rejection Code' ;
    rdfs:comment 'GSMA-standard primary rejection reason code identifying the main cause for TAP record rejection in this RAP file (e.g., \'12\' for missing mandatory field, \'15\' for invalid IMSI). Sourced from GSMA TD.32 rejection code table. [ENUM-REF-CANDIDATE: promote to reference product — GSMA TD.32 defines 50+ rejection codes]' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the RAP file was fully processed and the rejected TAP records were actioned in the settlement system. Supports audit trail and SLA measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rapFileType rdf:type rdf:Property ;
    rdfs:label 'Rap File Type' ;
    rdfs:comment 'GSMA-defined RAP file type code indicating the direction and nature of the rejection. HOMERJE = home operator rejecting visitor records; VISRJE = visited operator rejecting home records; ACK variants are acknowledgements; SYSERR = system error file. [ENUM-REF-CANDIDATE: HOMERJE|VISRJE|HOMERJE-ACK|VISRJE-ACK|SYSERR — promote to reference product]' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapReleaseVersion rdf:type rdf:Property ;
    rdfs:label 'Rap Release Version' ;
    rdfs:comment 'GSMA RAP release version within the specification version, providing finer-grained versioning of the RAP file format used for this exchange.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Rap Spec Version' ;
    rdfs:comment 'GSMA RAP specification version number used to encode this RAP file (e.g., \'04\' for RAP version 4). Governs the file structure and rejection code set applicable to this record.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapStatus rdf:type rdf:Property ;
    rdfs:label 'Rap Status' ;
    rdfs:comment 'Current lifecycle status of the RAP file within the inter-operator settlement workflow. Tracks progression from receipt through validation, processing, acknowledgement, and closure. [ENUM-REF-CANDIDATE: received|validated|processed|acknowledged|disputed|closed — promote to reference product]' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTadig rdf:type rdf:Property ;
    rdfs:label 'Recipient Tadig' ;
    rdfs:comment 'GSMA TADIG code of the operator receiving this RAP file (the operator whose TAP records are being rejected). Identifies the counterparty in the bilateral exchange.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Category' ;
    rdfs:comment 'GSMA-defined severity classification of the rejection: fatal (entire TAP file rejected), severe (significant errors requiring correction), or minor (non-critical errors). Determines the correction and resubmission workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionCodeList rdf:type rdf:Property ;
    rdfs:label 'Rejection Code List' ;
    rdfs:comment 'Pipe-delimited list of all GSMA rejection reason codes present across the rejected records in this RAP file. Provides a summary of all error types encountered, enabling root-cause analysis and TAP file correction prioritization.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Deadline Date' ;
    rdfs:comment 'Contractual or GSMA-mandated deadline by which the sender must resubmit corrected TAP records following this RAP rejection. Used for SLA monitoring and dispute escalation triggers.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Resubmission Status' ;
    rdfs:comment 'Current status of the TAP file resubmission process following this RAP rejection. Tracks whether the sender has corrected and resubmitted the rejected records, or if the rejection is under dispute or has been waived.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'End date of the billing/settlement period covered by the rejected TAP records in this RAP file. Used with settlement_period_start_date to bound the financial exposure of the rejection.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'Start date of the billing/settlement period covered by the rejected TAP records in this RAP file. Aligns the rejection to the correct inter-operator settlement cycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceTapSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Tap Sequence Number' ;
    rdfs:comment 'The GSMA sequence number of the originating TAP file being rejected, as carried within the RAP file header. Enables direct correlation to the TAP file without requiring a system join.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapReleaseVersion rdf:type rdf:Property ;
    rdfs:label 'Tap Release Version' ;
    rdfs:comment 'TAP release version of the originating TAP file being rejected, providing finer-grained versioning within the TAP specification version. Used for format validation during RAP processing.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRejectedCharge rdf:type rdf:Property ;
    rdfs:label 'Total Rejected Charge' ;
    rdfs:comment 'Aggregate monetary value of all TAP records rejected in this RAP file, expressed in the settlement currency. Represents the gross financial exposure of the rejection batch for inter-operator settlement reconciliation.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxValue rdf:type rdf:Property ;
    rdfs:label 'Total Tax Value' ;
    rdfs:comment 'Aggregate tax component of the rejected TAP records included in this RAP file. Required for accurate financial settlement reconciliation and tax reporting between operators.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferCutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Cutoff Timestamp' ;
    rdfs:comment 'GSMA-mandated cutoff timestamp by which the RAP file must be transmitted to the recipient operator. Used for SLA compliance monitoring and GSMA bilateral agreement enforcement.' ;
    rdfs:domain ind:RapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Settlement Invoice Id' ;
    rdfs:comment 'Reference to the inter-operator settlement invoice that is the subject of this dispute. Null when the dispute is raised directly against a TAP file rather than a consolidated invoice.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementInvoice .

ind:acceptedAmount rdf:type rdf:Property ;
    rdfs:label 'Accepted Amount' ;
    rdfs:comment 'Portion of the original invoice or TAP file charge that Telecommunication accepts as valid and agrees to pay. The difference between the invoiced amount and the disputed amount. Part of MONETARY_TRIPLET canonical category (adjustment component).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierResponseDate rdf:type rdf:Property ;
    rdfs:label 'Carrier Response Date' ;
    rdfs:comment 'Date on which the counterparty carrier formally responded to the dispute notification. Used to measure SLA compliance and track negotiation progress.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Carrier Response Notes' ;
    rdfs:comment 'Free-text summary of the carrier\'s formal response to the dispute, including their position, counter-evidence references, and proposed resolution.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteReference rdf:type rdf:Property ;
    rdfs:label 'Credit Note Reference' ;
    rdfs:comment 'Reference number of the credit note issued by the carrier as part of the dispute resolution. Populated when resolution_type is credit_note or partial_credit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level grouping of the dispute: financial (monetary discrepancy), technical (CDR or TAP file format/content issue), or contractual (disagreement on agreement terms or IOT applicability).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Free-text narrative describing the nature of the dispute, the specific charges contested, and the business justification for the claim. Authored by the settlement analyst at the time of dispute creation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDirection rdf:type rdf:Property ;
    rdfs:label 'Dispute Direction' ;
    rdfs:comment 'Indicates whether Telecommunication is the disputing party (outbound — Telecommunication raises dispute against carrier) or the receiving party (inbound — carrier raises dispute against Telecommunication).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to this dispute at the time of creation. Used in all carrier-to-carrier correspondence and regulatory filings. Format: DSP-YYYY-NNNNNN. Aligns with BUSINESS_IDENTIFIER canonical category.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the disputed amount (e.g., USD, EUR, GBP). Required for multi-currency inter-operator settlement environments. Part of MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedCdrCount rdf:type rdf:Property ;
    rdfs:label 'Disputed Cdr Count' ;
    rdfs:comment 'Number of individual Call Detail Records (CDRs) included in the dispute. Relevant for volume_discrepancy, duplicate_record, and missing_record dispute types.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total amount as stated on the original settlement invoice or TAP file that is the subject of this dispute. Provides the baseline for calculating the disputed and accepted portions.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSlaBreached rdf:type rdf:Property ;
    rdfs:label 'Is Sla Breached' ;
    rdfs:comment 'Indicates whether the carrier has failed to respond or resolve the dispute within the contractually agreed SLA timeframe. True when current date exceeds sla_resolution_due_date and dispute_status is not resolved or closed.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrtrdeFileReference rdf:type rdf:Property ;
    rdfs:label 'Nrtrde File Reference' ;
    rdfs:comment 'Reference identifier of the NRTRDE file associated with the disputed roaming charges. Enables near-real-time reconciliation of roaming CDRs against TAP file charges as per GSMA NRTRDE specification.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number of any regulatory filing or complaint submitted to a governing body (e.g., FCC, Ofcom, BEREC) in connection with this dispute. Null if no regulatory filing has been made.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'Final agreed monetary amount to be credited, refunded, or adjusted as the outcome of the dispute resolution. Populated only when dispute_status is resolved or closed. Part of MONETARY_TRIPLET canonical category (net total).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Classification of how the dispute was resolved: credit_note (carrier issues a credit), partial_credit (partial adjustment agreed), full_acceptance (Telecommunication accepts the original charge), withdrawal (dispute withdrawn by Telecommunication), arbitration_award (resolved via formal arbitration).' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End' ;
    rdfs:comment 'End date of the billing or settlement period covered by the disputed invoice or TAP file.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start' ;
    rdfs:comment 'Start date of the billing or settlement period covered by the disputed invoice or TAP file. Used to correlate disputes with specific traffic periods and IOT tariff versions.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResolutionDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Due Date' ;
    rdfs:comment 'Contractual deadline by which the dispute must be fully resolved as defined in the inter-operator agreement SLA terms. Used for SLA breach monitoring and escalation triggers.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Date' ;
    rdfs:comment 'Contractual deadline by which the carrier must respond to the dispute as defined in the roaming or interconnect agreement SLA terms.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemDisputeReference rdf:type rdf:Property ;
    rdfs:label 'Source System Dispute Reference' ;
    rdfs:comment 'Native identifier of this dispute record in the originating operational system (e.g., Amdocs case number, Netcracker dispute ID). Enables traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:SettlementDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tap Sequence Number' ;
    rdfs:comment 'TAP file sequence number as defined in the GSMA TAP3 specification, identifying the specific TAP batch within the carrier exchange. Used to trace disputed charges back to the originating TAP file.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficType rdf:type rdf:Property ;
    rdfs:label 'Traffic Type' ;
    rdfs:comment 'Type of telecommunications traffic associated with the disputed charges. Determines which IOT tariff schedule and settlement rules apply. [ENUM-REF-CANDIDATE: voice|data|sms|mms|roaming|transit|wholesale — promote to reference product]' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Settlement invoices in carrier billing operations require preparation by finance analysts who validate TAP/NRTRDE records, calculate amounts, and reconcile with agreements. This tracks accountability ' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:carrierCountryCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the counterparty carrier\'s home country. Used for geographic segmentation of inter-carrier settlement volumes, regulatory reporting, and IOT tariff zone determination.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Reference Number' ;
    rdfs:comment 'The invoice or settlement reference number assigned by the counterparty carrier. Used for cross-referencing and reconciliation between Telecommunication\'s internal invoice number and the carrier\'s own settlement document identifier.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTadigCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Tadig Code' ;
    rdfs:comment 'The GSMA TADIG (Transferred Account Data Interchange Group) five-character code uniquely identifying the counterparty carrier\'s network. Used in TAP file processing, NRTRDE exchange, and inter-operator settlement identification.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The net_payable_amount converted to Telecommunication\'s functional currency using the exchange_rate. Used for consolidated financial reporting, EBITDA calculation, and revenue assurance analytics.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for Telecommunication\'s functional/reporting currency into which the invoice amounts are converted using exchange_rate. Enables consolidated financial reporting across multi-currency carrier settlements.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffVersion rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Version' ;
    rdfs:comment 'The version identifier of the Inter-Operator Tariff (IOT) table applied when rating the traffic charges on this invoice. Ensures auditability of the tariff applied and supports dispute resolution when tariff versions change mid-period.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The net amount due for payment after subtracting disputed_amount and applying any approved credits or adjustments from the gross_amount plus tax_amount. This is the actionable settlement figure used for payment processing and financial ledger posting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Flag' ;
    rdfs:comment 'Indicates whether this invoice is subject to bilateral netting against a corresponding payable or receivable invoice with the same carrier for the same billing period. When True, the net_payable_amount reflects the netted position. Supports cash flow optimization in carrier settlement.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nettingInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Netting Invoice Reference' ;
    rdfs:comment 'The invoice_number of the offsetting invoice used in bilateral netting. Populated only when netting_flag is True. Enables traceability of the netting pair for audit and reconciliation purposes.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeReference rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Reference' ;
    rdfs:comment 'Reference identifier for the NRTRDE data exchange associated with this invoice. NRTRDE provides near-real-time roaming CDR data used for fraud detection and early settlement validation prior to TAP file processing. Null for non-roaming invoices.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCdrCount rdf:type rdf:Property ;
    rdfs:label 'Total Cdr Count' ;
    rdfs:comment 'The total number of Call Detail Records (CDRs) included in this settlement invoice. Used for volume reconciliation against TAP files and NRTRDE data. Discrepancies between CDR counts and billed amounts are a primary trigger for disputes.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Total Data Volume Mb' ;
    rdfs:comment 'Total data volume in megabytes (MB) covered by this settlement invoice. Used for data roaming and interconnect data charge reconciliation. Applicable to roaming TAP, interconnect_data, and wholesale invoice types.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSmsCount rdf:type rdf:Property ;
    rdfs:label 'Total Sms Count' ;
    rdfs:comment 'Total number of SMS messages included in this settlement invoice. Used for SMS interconnect charge reconciliation and IOT tariff validation. Applicable to roaming TAP and SMS termination/origination invoice types.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUsageMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Usage Minutes' ;
    rdfs:comment 'Aggregate voice usage duration in minutes covered by this settlement invoice. Used for traffic volume analysis, IOT tariff validation, and inter-carrier settlement reconciliation. Applicable primarily to voice termination, origination, and roaming invoices.' ;
    rdfs:domain ind:SettlementInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Settlement Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each settlement invoice line item within the interconnect domain. Primary key for this entity.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callEventCount rdf:type rdf:Property ;
    rdfs:label 'Call Event Count' ;
    rdfs:comment 'Number of individual Call Detail Records (CDRs) or usage events aggregated into this settlement line item. Used for reconciliation against TAP file record counts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Charge Amount' ;
    rdfs:comment 'The total gross charge for this settlement line item before any discounts, adjustments, or taxes are applied. Calculated as traffic_volume multiplied by unit_rate.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of this settlement invoice line item, providing additional context about the service, traffic type, or special billing arrangement for reconciliation and audit purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference code for this settlement invoice line, used in dispute correspondence and reconciliation with the counterpart carrier.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Partner Operator Code' ;
    rdfs:comment 'GSMA TADIG (Transferred Account Data Interchange Group) code identifying the partner/counterpart operator for this settlement line. Used for carrier identification in TAP file processing and IOT settlement.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Partner Operator Name' ;
    rdfs:comment 'Full legal or trading name of the partner operator (carrier, MVNO, or transit provider) associated with this settlement line item.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapReference rdf:type rdf:Property ;
    rdfs:label 'Rap Reference' ;
    rdfs:comment 'Reference to the Return Account Procedure (RAP) file if this settlement line was returned or rejected during TAP processing. Enables tracking of rejected CDRs and their financial impact.' ;
    rdfs:domain ind:Interconnect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the unit_rate. May differ from the settlement_currency_code when rate tables are maintained in SDR (Special Drawing Rights) or a reference currency.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAssuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Flag' ;
    rdfs:comment 'Indicates whether this settlement line item has been flagged by the revenue assurance process for further investigation (e.g., volume anomaly, rate mismatch, missing TAP records).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level classification of the telecommunications service type for this settlement line item. Drives IOT tariff selection and financial reporting by service type. [ENUM-REF-CANDIDATE: voice_termination|sms|data_roaming|transit|mms|supplementary_service|iptv|voip|content — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Service Period End' ;
    rdfs:comment 'The end date of the billing period or traffic window covered by this settlement invoice line item. Together with service_period_start, defines the chargeable period.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Service Period Start' ;
    rdfs:comment 'The start date of the billing period or traffic window covered by this settlement invoice line item. Defines the temporal scope for traffic volume and charge calculation.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trafficCategory rdf:type rdf:Property ;
    rdfs:label 'Traffic Category' ;
    rdfs:comment 'Classification of the traffic flow direction and type for this settlement line. Distinguishes inbound roaming (MVNO/visited network charges), outbound roaming, transit traffic, and wholesale termination for revenue assurance and regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficVolume rdf:type rdf:Property ;
    rdfs:label 'Traffic Volume' ;
    rdfs:comment 'Total quantity of traffic units (calls, messages, data bytes, or events) included in this settlement line item. The unit of measure is defined by traffic_volume_unit.' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Traffic Volume Unit' ;
    rdfs:comment 'Unit of measure for the traffic_volume field. Varies by service category: seconds/minutes for voice, messages for SMS/MMS, kilobytes/megabytes/gigabytes for data roaming. [ENUM-REF-CANDIDATE: seconds|minutes|messages|kilobytes|megabytes|gigabytes|events — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SettlementInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseReference rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Reference' ;
    rdfs:comment 'The unique reference number assigned by the inter-operator clearinghouse (e.g., GSMA Clearing House, Syniverse, BICS) upon receipt of this TAP file. Used for end-to-end traceability, dispute resolution, and reconciliation against clearinghouse settlement statements.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPeriodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Period End Timestamp' ;
    rdfs:comment 'The timestamp of the latest CDR event contained within this TAP file, representing the end of the usage data period covered by the batch. Used alongside data_period_start_timestamp for gap detection and completeness validation.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataPeriodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Period Start Timestamp' ;
    rdfs:comment 'The timestamp of the earliest CDR event contained within this TAP file, representing the start of the usage data period covered by the batch. Used for period-based reconciliation, billing cycle alignment, and regulatory reporting.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Creation Timestamp' ;
    rdfs:comment 'The date and time at which the TAP file was generated by the sending operator\'s mediation or billing system (Amdocs Revenue Management). Represents the principal business event time for the file batch. Used for timeliness SLA measurement per GSMA NRTRDE and TAP submission deadlines.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current lifecycle state of the TAP file within the inter-operator settlement workflow. Transitions: created → sent → acknowledged (clean acceptance) or rejected (validation failure) → disputed (commercial challenge) or resubmitted (corrected re-send). Drives settlement reconciliation and SLA monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileType rdf:type rdf:Property ;
    rdfs:label 'File Type' ;
    rdfs:comment 'Classifies the type of inter-operator data exchange file: TAP (standard Transferred Account Procedure batch), NRTRDE (Near Real-Time Roaming Data Exchange for fraud detection), RAP (Returned Account Procedure for rejected records), or STOP (Stop file halting processing). Determines processing pipeline and settlement treatment.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestFile rdf:type rdf:Property ;
    rdfs:label 'Is Test File' ;
    rdfs:comment 'Indicates whether this TAP file is a test/simulation file (True) or a live production file (False) carrying real roaming charges. Test files must be excluded from financial settlement calculations and revenue reporting.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'The predominant radio access network technology type of the CDRs contained in this TAP file (e.g., LTE, 5G NR, VoLTE). Used for technology-segmented roaming analytics, IOT tariff differentiation, and network capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Sequence Number' ;
    rdfs:comment 'For resubmitted TAP files, the sequence number of the original file that this resubmission replaces. Enables lineage tracing from corrected files back to the original rejected batch. Null for first-time submissions.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingOutcome rdf:type rdf:Property ;
    rdfs:label 'Processing Outcome' ;
    rdfs:comment 'The outcome of the TAP file processing pipeline within the operator\'s BSS/OSS systems (Amdocs Revenue Management, Netcracker OSS/BSS). Indicates whether all CDRs were successfully rated and posted to settlement accounts, partially processed, or failed. Drives exception management workflows.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The date and time at which the TAP file was received and acknowledged at the clearinghouse or by the recipient operator. Used to calculate transit latency and confirm delivery within bilateral SLA windows.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientCountryCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 country code of the recipient operator\'s home country. Used for bilateral traffic analysis, regulatory reporting, and determining applicable IOT tariff zones and settlement currency conventions.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'The number of times this TAP file has been resubmitted after rejection or dispute. A value greater than zero indicates the file has been corrected and resent. Used for operator performance monitoring and SLA compliance tracking.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementStatementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Statement Reference' ;
    rdfs:comment 'The reference number of the clearinghouse settlement statement that includes charges from this TAP file. Links the TAP file batch to the financial settlement document used for inter-operator payment and accounting entries in SAP S/4HANA.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'The gross total Inter-Operator Tariff (IOT) charge amount declared in the TAP file header, representing the sum of all roaming charges for CDRs in this batch. Expressed in the settlement currency. Used as the primary financial control total for clearinghouse reconciliation and operator settlement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'The total number of validation errors identified during TAP file parsing and structural/business rule validation. A non-zero value triggers RAP (Returned Account Procedure) generation. Used for quality monitoring and operator performance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorSummary rdf:type rdf:Property ;
    rdfs:label 'Validation Error Summary' ;
    rdfs:comment 'A structured summary of the validation errors encountered during TAP file processing, including error codes and descriptions as defined in the GSMA TAP3 specification. Supports root cause analysis, operator dispute resolution, and resubmission guidance.' ;
    rdfs:domain ind:TapFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callEventType rdf:type rdf:Property ;
    rdfs:label 'Call Event Type' ;
    rdfs:comment 'Classification of the billable roaming event captured in this TAP record. MOC=Mobile Originated Call, MTC=Mobile Terminated Call, GPRS=data session, SMS_MO/MT=Short Message Service originated/terminated, MMS_MO/MT=Multimedia Message Service. [ENUM-REF-CANDIDATE: MOC|MTC|GPRS|SMS_MO|SMS_MT|MMS_MO|MMS_MT — promote to reference product]' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calledNumber rdf:type rdf:Property ;
    rdfs:label 'Called Number' ;
    rdfs:comment 'E.164 telephone number of the called party (B-number) for MOC voice events. Used for traffic analysis, fraud detection (e.g., IRSF detection), and regulatory reporting. Null for MTC, GPRS, and messaging events.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargedAmount rdf:type rdf:Property ;
    rdfs:label 'Charged Amount' ;
    rdfs:comment 'Gross monetary amount charged to the home network operator for this individual roaming event, expressed in the settlement currency. Calculated by the visited network by applying the applicable IOT rate to the consumed duration or volume.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Flag set to True when this TAP record has been identified as potentially fraudulent by the fraud management system (e.g., IRSF, SIM cloning, abnormal roaming patterns). Triggers investigation workflow in the Revenue Assurance domain.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Home Currency Amount' ;
    rdfs:comment 'Charged amount converted to the home network operator\'s functional accounting currency using the exchange_rate. Used for financial reporting, EBITDA calculation, and MRR/revenue recognition in SAP S/4HANA.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeNetworkTadig rdf:type rdf:Property ;
    rdfs:label 'Home Network Tadig' ;
    rdfs:comment '5-character GSMA TADIG code identifying the home network operator (HPMN) to which the roaming subscriber belongs and to whom the TAP file is addressed for settlement.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotRateApplied rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Applied' ;
    rdfs:comment 'The specific IOT unit rate applied by the visited network to calculate the charged amount for this roaming event (e.g., rate per minute for voice, rate per KB for data). Sourced from the applicable IOT tariff table in effect at the time of service.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iotRateUnit rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Unit' ;
    rdfs:comment 'Unit of measure for the IOT rate applied to this roaming event (e.g., PER_MINUTE for voice calls, PER_KB or PER_MB for data sessions, PER_MESSAGE for SMS/MMS).' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAccessTechnology rdf:type rdf:Property ;
    rdfs:label 'Network Access Technology' ;
    rdfs:comment 'Radio access technology used by the visiting subscriber during this roaming event (e.g., 2G/GSM, 3G/UMTS, 4G LTE, 5G NR). Relevant for IOT tariff differentiation and network analytics.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Transmission Timestamp' ;
    rdfs:comment 'UTC timestamp when this CDR was transmitted via the NRTRDE mechanism to the home network. Null if nrtrde_flag is False. Used to verify compliance with the GSMA 4-hour NRTRDE transmission SLA.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partialRecordIndicator rdf:type rdf:Property ;
    rdfs:label 'Partial Record Indicator' ;
    rdfs:comment 'Indicates whether this TAP record represents a partial CDR (e.g., a long-duration data session split across multiple records by the visited network). True=partial record requiring reassembly; False=complete single record.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current processing and settlement lifecycle status of this TAP roaming record. ACCEPTED=validated and accepted for settlement; REJECTED=failed TAP validation; DISPUTED=under inter-operator dispute; PENDING=awaiting validation; SETTLED=financially settled.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingType rdf:type rdf:Property ;
    rdfs:label 'Roaming Type' ;
    rdfs:comment 'Indicates the direction of roaming from the perspective of the home network operator. INBOUND=a subscriber from another network is roaming on our network (we are the VPMN); OUTBOUND=our subscriber is roaming on another network (we are the HPMN).' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment '3GPP teleservice or bearer service code identifying the specific service used during this roaming event (e.g., 11=telephony, 22=SMS, 41=data circuit async). Maps to the TAP3 BasicServiceUsed element.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriod rdf:type rdf:Property ;
    rdfs:label 'Settlement Period' ;
    rdfs:comment 'Calendar month (YYYY-MM format) to which this TAP record is assigned for inter-operator financial settlement. Determines the billing cycle for IOT invoice generation between the visited and home network operators.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tap Creation Timestamp' ;
    rdfs:comment 'UTC timestamp when this TAP record was first created and written to the Databricks Silver Layer during TAP file ingestion and parsing. Audit trail for data lineage and SLA monitoring.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tapFileSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tap File Sequence Number' ;
    rdfs:comment 'Sequential file number assigned by the visited network operator to the TAP3 file containing this record. Together with visited_network_tadig and home_network_tadig, uniquely identifies the source TAP file for audit and reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Tap Spec Version' ;
    rdfs:comment 'Version of the GSMA TAP3 specification used to encode this roaming record (e.g., TAP3R12). Required for correct parsing, validation, and backward-compatibility handling during TAP file processing.' ;
    rdfs:domain ind:TapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTrafficRecordId rdf:type rdf:Property ;
    rdfs:label 'Transit Traffic Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each transit traffic record in the Telecommunications wholesale interconnect system. Primary key for the transit_traffic_record data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalRecordTransitTrafficRecordId rdf:type rdf:Property ;
    rdfs:label 'Original Record Transit Traffic Record Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original transit_traffic_record_id when this record is a correction, reversal, or reprocessed version of a prior record. Null for original records. Supports audit trail and settlement reconciliation.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransitTrafficRecord .

ind:originatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Originating Carrier Id' ;
    rdfs:comment 'Reference to the carrier entity that originated the transit traffic and handed it off to Telecommunications network for transit routing. Used for wholesale billing and IOT (Inter-Operator Tariff) application.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryTransitPopFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Transit Pop Facility Id' ;
    rdfs:comment 'Reference to the POP (Point of Presence) or network node where the transit traffic entered the Telecommunications network from the originating carrier. Critical for capacity planning and interconnect cost allocation.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopFacility .

ind:primaryTransitTerminatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Transit Terminating Carrier Id' ;
    rdfs:comment 'Reference to the carrier entity that receives the transit traffic from Telecommunications network for final delivery to the end destination. Used for wholesale settlement and capacity planning.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:callCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Call Completion Flag' ;
    rdfs:comment 'Indicates whether the transit call or session was successfully completed (True) or failed/unanswered (False). Used for answer seizure ratio (ASR) KPI calculation, QoS (Quality of Service) monitoring, and wholesale SLA compliance reporting.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'The precise date and time when the transit traffic session or call was terminated. Used in conjunction with call_start_timestamp to derive duration for voice and signaling traffic billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'The precise date and time when the transit traffic session or call began, as recorded at the ingress POP. This is the principal real-world event timestamp used for CDR (Call Detail Record) rating, IOT (Inter-Operator Tariff) application, and TAP (Transferred Account Procedure) file generation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdrSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Cdr Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this CDR (Call Detail Record) or transit traffic record was sourced. Supports data lineage, reconciliation, and audit trail requirements across OSS/BSS systems. [ENUM-REF-CANDIDATE: amdocs|netcracker|comverse|ericsson|nokia|mediation|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeKb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Kb' ;
    rdfs:comment 'Total volume of data traffic transited through the Telecommunications network in kilobytes. Used for per-KB or per-MB IOT (Inter-Operator Tariff) rate application for data and MMS transit traffic. Null for voice and SMS traffic types.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Billed Amount' ;
    rdfs:comment 'The gross wholesale amount billed for this transit traffic record before any adjustments, discounts, or credits. Computed as transit_rate_applied multiplied by the applicable volume or duration. Used in Amdocs Revenue Management for invoice generation and settlement.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateCdrFlag rdf:type rdf:Property ;
    rdfs:label 'Late Cdr Flag' ;
    rdfs:comment 'Indicates whether this CDR (Call Detail Record) was received after the standard TAP (Transferred Account Procedure) file submission deadline (True) or within the normal processing window (False). Late CDRs may require special handling in settlement and may be subject to GSMA late submission penalties.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'The final net amount payable for this transit traffic record after applying all discounts and adjustments. Equals gross_billed_amount minus discount_amount. Used as the authoritative financial figure for inter-carrier settlement and revenue assurance reconciliation.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrtrdeSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Sequence Number' ;
    rdfs:comment 'Sequence number assigned to this record within the NRTRDE (Near Real-Time Roaming Data Exchange) data stream. Enables near-real-time fraud detection and roaming usage monitoring per GSMA PRD IR.71 requirements.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingNumber rdf:type rdf:Property ;
    rdfs:label 'Originating Number' ;
    rdfs:comment 'The calling line identity (CLI) or originating MSISDN/number from which the transit traffic was generated. Stored for CDR (Call Detail Record) reconciliation, fraud detection, and regulatory lawful intercept compliance. Classified as confidential PII per GDPR Article 4 and FCC CPNI regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'The signaling protocol used to establish and manage the transit traffic session. Relevant for network operations, fault management, and interconnect compatibility assessment. [ENUM-REF-CANDIDATE: ss7|sigtran|sip|isup|h323|diameter — promote to reference product]' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rated Timestamp' ;
    rdfs:comment 'The date and time when this transit traffic record was rated by the billing/rating engine (Amdocs Revenue Management or Comverse ONE). Distinct from the call start timestamp; used for rating latency monitoring and billing cycle management.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this transit traffic record, used in inter-carrier settlement communications, dispute resolution, and wholesale billing reconciliation. Corresponds to the CDR (Call Detail Record) sequence number or transit record identifier exchanged between carriers.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCauseCode rdf:type rdf:Property ;
    rdfs:label 'Release Cause Code' ;
    rdfs:comment 'The ITU-T Q.850 or SIP response code indicating the reason for call or session termination. Used for quality analysis, failed call identification, and SLA (Service Level Agreement) compliance monitoring in wholesale transit services.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprocessedFlag rdf:type rdf:Property ;
    rdfs:label 'Reprocessed Flag' ;
    rdfs:comment 'Indicates whether this transit traffic record has been reprocessed or re-rated (True) due to a correction, dispute resolution, or system error. Used for audit trail and to prevent double-billing in wholesale settlement.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle state of the transit traffic record within the wholesale financial settlement workflow. Drives downstream billing, dispute management, and revenue assurance processes in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsCount rdf:type rdf:Property ;
    rdfs:label 'Sms Count' ;
    rdfs:comment 'Number of SMS messages included in this transit traffic record. Applicable when traffic_type is \'sms\'. Used for per-message IOT (Inter-Operator Tariff) rate application in wholesale SMS hubbing arrangements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Terminating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country to which the transit traffic was destined. Used for international settlement rate determination, IOT (Inter-Operator Tariff) zone classification, and regulatory reporting.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatingNumber rdf:type rdf:Property ;
    rdfs:label 'Terminating Number' ;
    rdfs:comment 'The called party number or terminating MSISDN/E.164 number to which the transit traffic was routed. Used for CDR (Call Detail Record) reconciliation, number portability (MNP) validation, and regulatory compliance. Classified as confidential PII per GDPR Article 4 and FCC CPNI regulations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitRateApplied rdf:type rdf:Property ;
    rdfs:label 'Transit Rate Applied' ;
    rdfs:comment 'The per-unit wholesale transit rate applied to this record at the time of rating, expressed in the settlement currency. Represents the IOT (Inter-Operator Tariff) unit price used to compute the billed amount. Classified as confidential due to commercial sensitivity of carrier pricing.' ;
    rdfs:domain ind:TransitTrafficRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the asset lifecycle event record. Primary key.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssetLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Location Site Id' ;
    rdfs:comment 'Reference to the stocking location, warehouse, or site where the asset was located before this event. Nullable if location did not change.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:spectrumAllocationId rdf:type rdf:Property ;
    rdfs:label 'Spectrum Allocation Id' ;
    rdfs:comment 'Foreign key linking to inventory.spectrum_allocation. Business justification: Spectrum licenses have lifecycle events (acquisition, renewal, expiration, regulatory changes) that should be tracked in asset_lifecycle_event. This FK allows tracking spectrum allocation lifecycle al' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpectrumAllocation .

ind:actualCount rdf:type rdf:Property ;
    rdfs:label 'Actual Count' ;
    rdfs:comment 'Actual quantity of assets found during the physical audit or cycle count. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this lifecycle event required managerial or system approval before execution (e.g., write-off events typically require approval). True if approval was required, False otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetReference rdf:type rdf:Property ;
    rdfs:label 'Asset Reference' ;
    rdfs:comment 'Reference to the physical inventory asset (CPE, ONT, OLT, network equipment, fiber plant, spare parts) that this lifecycle event pertains to.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event complies with regulatory or internal policy requirements (e.g., proper audit trail, authorized personnel, documented approval). True if compliant, False if non-compliant or flagged for review.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Financial impact of this lifecycle event in the base currency (e.g., asset acquisition cost for procurement, write-off amount for decommission, repair cost). Nullable for non-financial events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the lifecycle event (e.g., reason for swap, repair details, audit findings).' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the lifecycle event occurred in the real world (e.g., when the asset was deployed, swapped, or decommissioned). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCount rdf:type rdf:Property ;
    rdfs:label 'Expected Count' ;
    rdfs:comment 'Expected quantity of assets at the audited location or category based on system records. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The asset state immediately after this lifecycle event occurred. Captures the to state in the state transition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The asset state immediately before this lifecycle event occurred. Captures the from state in the state transition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAction rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Action' ;
    rdfs:comment 'Action taken to resolve the inventory variance (e.g., write-off for lost assets, adjustment to correct system records, investigation for unresolved discrepancies). Applicable only for reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Unique transaction or event identifier from the source system. Used for traceability and idempotency in data integration.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between expected and actual count (actual_count minus expected_count). Positive indicates surplus, negative indicates shortage. Applicable only for audit and reconciliation events.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Root cause or reason for the inventory variance identified during audit or reconciliation. Applicable only for audit and reconciliation events. [ENUM-REF-CANDIDATE: theft|damage|data-entry-error|unreported-deployment|unreported-return|obsolescence|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Installation Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: CPE installation at customer premises is performed by field technicians. Tracking installer supports customer satisfaction analysis, first-time-fix rate calculation, and technician performance evaluat' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal asset tag or barcode assigned by the company for inventory tracking and auditing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the CPE device was assigned to the current subscriber or service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware version installed on the CPE device. Critical for security patching and feature management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareVersion rdf:type rdf:Property ;
    rdfs:label 'Hardware Version' ;
    rdfs:comment 'Hardware revision or version of the CPE device as specified by the manufacturer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is5gCapable rdf:type rdf:Property ;
    rdfs:label 'Is 5g Capable' ;
    rdfs:comment 'Indicates whether the CPE device supports 5G New Radio (NR) connectivity.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWifi6Capable rdf:type rdf:Property ;
    rdfs:label 'Is Wifi6 Capable' ;
    rdfs:comment 'Indicates whether the CPE device supports Wi-Fi 6 (802.11ax) standard.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the CPE is company-owned, leased to customer, customer-owned (BYOD - Bring Your Own Device), or on trial.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCondition rdf:type rdf:Property ;
    rdfs:label 'Physical Condition' ;
    rdfs:comment 'Assessment of the physical condition of the CPE device. Used for redeployment decisions and asset valuation.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCount rdf:type rdf:Property ;
    rdfs:label 'Port Count' ;
    rdfs:comment 'Number of physical Ethernet ports available on the CPE device.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when the CPE device was procured or purchased by the telecommunications company.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number associated with the procurement of this CPE device.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the CPE device was returned by the customer to the company inventory.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Username or identifier of the user who last updated this CPE asset record.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer warranty coverage begins for the CPE device.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current status of the manufacturer warranty for the CPE device.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiPassword rdf:type rdf:Property ;
    rdfs:label 'Wifi Password' ;
    rdfs:comment 'Default or configured Wi-Fi password for CPE devices with Wi-Fi capability. Encrypted at rest.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiSsid rdf:type rdf:Property ;
    rdfs:label 'Wifi Ssid' ;
    rdfs:comment 'Default or configured SSID for CPE devices with Wi-Fi capability.' ;
    rdfs:domain ind:CpeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ductRouteId rdf:type rdf:Property ;
    rdfs:label 'Duct Route Id' ;
    rdfs:comment 'Identifier for the conduit or duct infrastructure housing this fiber cable. Null for aerial or direct-buried cables. Used for duct capacity planning and fill ratio analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DuctRoute .

ind:maintenanceOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Outside plant fiber infrastructure requires designated maintenance owner for right-of-way management, splice point inspection scheduling, and emergency repair coordination with field crews.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Identifier for the capital project or network expansion initiative under which this cable was deployed. Used for CAPEX tracking and project portfolio management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:startPopFacilityId rdf:type rdf:Property ;
    rdfs:label 'Start Pop Facility Id' ;
    rdfs:comment 'Foreign key linking to inventory.pop_facility. Business justification: Fiber cables typically terminate at POP facilities (central offices, headends, data centers). Tracking the starting facility provides critical context for cable routing and capacity planning. The star' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopFacility .

ind:terminationNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Termination Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Fiber cables terminate at network elements (OLT, ODF, DWDM terminal). Logical-to-physical mapping for circuit provisioning, port assignment, and fault isolation requires linking physical fiber to term' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:assignedFiberCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Fiber Count' ;
    rdfs:comment 'Number of fibers currently allocated to active services or reserved for planned deployments. Used for utilization tracking and capacity management.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attenuationDbPerKm rdf:type rdf:Property ;
    rdfs:label 'Attenuation Db Per Km' ;
    rdfs:comment 'Signal loss measurement in decibels per kilometer. Critical QoS metric for network planning and service quality assurance.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableFiberCount rdf:type rdf:Property ;
    rdfs:label 'Available Fiber Count' ;
    rdfs:comment 'Number of unused (dark) fibers available for new service provisioning. Calculated as total fiber count minus assigned fibers. Critical for capacity planning.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cableCode rdf:type rdf:Property ;
    rdfs:label 'Cable Code' ;
    rdfs:comment 'Externally-known unique identifier for the fiber cable segment used in field operations, engineering drawings, and OSP documentation.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cableType rdf:type rdf:Property ;
    rdfs:label 'Cable Type' ;
    rdfs:comment 'Classification of the fiber optic cable based on transmission mode and construction. Single-mode for long-haul, multi-mode for short-distance, ribbon for high-density, hybrid for mixed applications.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conduitFillRatioPercent rdf:type rdf:Property ;
    rdfs:label 'Conduit Fill Ratio Percent' ;
    rdfs:comment 'Percentage of conduit cross-sectional area occupied by cables. Industry best practice limits fill to 60-70% to allow for future expansion and cable movement. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conduitInnerDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Conduit Inner Diameter Mm' ;
    rdfs:comment 'Internal diameter of the conduit in millimeters. Used for calculating fill ratio and determining additional cable placement capacity. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conduitMaterialType rdf:type rdf:Property ;
    rdfs:label 'Conduit Material Type' ;
    rdfs:comment 'Material composition of the conduit housing the fiber cable. HDPE (High-Density Polyethylene) is standard for modern installations. Null for non-conduit deployments.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentMethod rdf:type rdf:Property ;
    rdfs:label 'Deployment Method' ;
    rdfs:comment 'Installation technique used for the fiber cable segment. Determines maintenance procedures, access requirements, and environmental exposure.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endLocationGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'End Location Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cable segment ending point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endLocationGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'End Location Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cable segment ending point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'Classification of the deployment environment affecting cable specifications and maintenance requirements. Coastal zones require corrosion-resistant materials, mountainous terrain affects accessibility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberCount rdf:type rdf:Property ;
    rdfs:label 'Fiber Count' ;
    rdfs:comment 'Total number of individual optical fibers contained within the cable. Critical for capacity planning and strand-level inventory management.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireRating rdf:type rdf:Property ;
    rdfs:label 'Fire Rating' ;
    rdfs:comment 'Fire safety classification of the cable sheath. OFNR (Optical Fiber Non-conductive Riser), OFNP (Plenum), OFCP (Conductive Plenum), LSZH (Low Smoke Zero Halogen). Required for building code compliance.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent physical or optical inspection of the cable segment. Used for preventive maintenance scheduling and compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Entity responsible for ongoing maintenance and repair of the fiber cable segment. Determines escalation procedures and cost allocation for fault resolution.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required inspection based on maintenance policies and regulatory requirements. Used for work order planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightOfWayPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Right Of Way Permit Number' ;
    rdfs:comment 'Government or municipal permit number authorizing the cable installation in public or private right-of-way. Required for regulatory compliance and audit trails.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Route Length Meters' ;
    rdfs:comment 'Physical length of the fiber cable segment measured in meters along the deployment route. Used for attenuation calculations and material inventory.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sheathType rdf:type rdf:Property ;
    rdfs:label 'Sheath Type' ;
    rdfs:comment 'Outer protective jacket material of the fiber cable. Determines environmental resistance, fire safety compliance, and installation method suitability.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splicePointCount rdf:type rdf:Property ;
    rdfs:label 'Splice Point Count' ;
    rdfs:comment 'Number of splice enclosures or splice points along this cable segment. Each splice introduces potential signal loss and maintenance access points.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startLocationGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the cable segment starting point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the cable segment starting point in decimal degrees. Used for GIS mapping and field dispatch.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRatingMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Max Celsius' ;
    rdfs:comment 'Maximum operating temperature in Celsius for the fiber cable. Critical for deployments in extreme climates to ensure signal integrity.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRatingMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Min Celsius' ;
    rdfs:comment 'Minimum operating temperature in Celsius for the fiber cable. Critical for deployments in extreme climates to ensure signal integrity.' ;
    rdfs:domain ind:FiberCable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiberSpliceId rdf:type rdf:Property ;
    rdfs:label 'Fiber Splice Id' ;
    rdfs:comment 'Unique identifier for the fiber splice point or splice closure record. Primary key for the fiber splice entity.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoPointId rdf:type rdf:Property ;
    rdfs:label 'Geo Point Id' ;
    rdfs:comment 'Foreign key linking to location.geo_point. Business justification: Fiber splices occur at precise surveyed geographic points. Essential for outside plant management, fault localization, and splice closure maintenance. Normalizes denormalized location attributes into ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeoPoint .

ind:installationWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Installation Work Order Id' ;
    rdfs:comment 'Work order number under which the splice installation was performed. Links splice records to field service management and project tracking systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryFiberCableId rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Cable Id' ;
    rdfs:comment 'Identifier of the fiber cable segment on the A-side (incoming) of the splice. Used for end-to-end fiber path tracing and fault isolation.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiberCable .

ind:spliceClosureId rdf:type rdf:Property ;
    rdfs:label 'Splice Closure Id' ;
    rdfs:comment 'Business identifier for the physical splice closure enclosure housing the fiber splice. Used for field operations and asset tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpliceClosure .

ind:aSideFiberNumber rdf:type rdf:Property ;
    rdfs:label 'A Side Fiber Number' ;
    rdfs:comment 'Fiber strand number within the A-side cable that is spliced. Used for detailed fiber pair mapping and circuit tracing.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bSideFiberNumber rdf:type rdf:Property ;
    rdfs:label 'B Side Fiber Number' ;
    rdfs:comment 'Fiber strand number within the B-side cable that is spliced. Used for detailed fiber pair mapping and circuit tracing.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureCapacity rdf:type rdf:Property ;
    rdfs:label 'Closure Capacity' ;
    rdfs:comment 'Maximum number of fiber splices that the closure enclosure can accommodate. Used for capacity planning and future expansion analysis.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalSealStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Seal Status' ;
    rdfs:comment 'Integrity status of the splice closure environmental seal. Compromised seals can allow moisture ingress and degrade splice performance.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberPairsSpliced rdf:type rdf:Property ;
    rdfs:label 'Fiber Pairs Spliced' ;
    rdfs:comment 'Number of individual fiber pairs joined at this splice point. Critical for capacity planning and network topology documentation.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insertionLossDb rdf:type rdf:Property ;
    rdfs:label 'Insertion Loss Db' ;
    rdfs:comment 'Measured optical power loss at the splice point in decibels (dB). Lower values indicate better splice quality. Typical fusion splice loss is 0.02-0.10 dB; mechanical splice loss is 0.10-0.50 dB.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the last inspection or quality test. Passed indicates splice meets performance standards; failed indicates remediation required; warning indicates degraded performance.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Type of physical location where the splice closure is installed. Critical for Outside Plant (OSP) and Inside Plant (ISP) asset management and field dispatch planning.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkSegment rdf:type rdf:Property ;
    rdfs:label 'Network Segment' ;
    rdfs:comment 'Segment of the fiber network topology where the splice is located. Feeder connects central office to distribution; distribution connects to customer drops; backbone connects major nodes.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Classification of the fiber plant environment. OSP (Outside Plant) refers to outdoor infrastructure; ISP (Inside Plant) refers to indoor infrastructure. Critical for maintenance planning and environmental specifications.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionScheme rdf:type rdf:Property ;
    rdfs:label 'Protection Scheme' ;
    rdfs:comment 'Network redundancy or protection mechanism applied to circuits passing through this splice. 1+1 indicates active backup; ring indicates self-healing topology.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system that is the authoritative source for this splice record (e.g., Oracle OSM, Netcracker). Used for data lineage and system integration management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reflectanceDb rdf:type rdf:Property ;
    rdfs:label 'Reflectance Db' ;
    rdfs:comment 'Optical return loss or back-reflection at the splice point in decibels (dB). Higher negative values indicate better performance. Typical fusion splice reflectance is -60 dB or better.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Service Impact Level' ;
    rdfs:comment 'Business criticality of the splice based on the number and type of services it supports. Critical splices affect large customer populations or high-value enterprise circuits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spliceStatus rdf:type rdf:Property ;
    rdfs:label 'Splice Status' ;
    rdfs:comment 'Current operational status of the fiber splice in the network lifecycle. Active indicates in-service; planned indicates design phase; failed indicates quality test failure.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spliceTrayPosition rdf:type rdf:Property ;
    rdfs:label 'Splice Tray Position' ;
    rdfs:comment 'Physical tray or slot position within the splice closure where this splice is located. Used for physical inventory and maintenance procedures.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spliceType rdf:type rdf:Property ;
    rdfs:label 'Splice Type' ;
    rdfs:comment 'Type of fiber splice technique used. Fusion splices use heat to fuse fibers; mechanical splices use alignment fixtures; ribbon splices join multiple fibers simultaneously.' ;
    rdfs:domain ind:FiberSplice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testWavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Test Wavelength Nm' ;
    rdfs:comment 'Optical wavelength in nanometers at which insertion loss and reflectance were measured. Common values are 1310 nm and 1550 nm for single-mode fiber.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiberStrandAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fiber Strand Assignment Id' ;
    rdfs:comment 'Unique identifier for the fiber strand assignment record. Primary key for this entity.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aEndRackSlotPortId rdf:type rdf:Property ;
    rdfs:label 'A End Rack Slot Port Id' ;
    rdfs:comment 'Foreign key linking to inventory.rack_slot_port. Business justification: Fiber strand assignments terminate at specific physical ports in racks. Currently a_end_port_number is a STRING; replacing with FK to rack_slot_port provides full port hierarchy (facility → equipment ' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RackSlotPort .

ind:backupStrandAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Backup Strand Assignment Id' ;
    rdfs:comment 'Reference to the backup fiber strand assignment providing redundancy for this primary strand. Null for unprotected strands or backup strands themselves.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:leaseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Id' ;
    rdfs:comment 'Reference to the wholesale dark fiber lease agreement or Indefeasible Right of Use (IRU) contract governing this strand assignment. Null for owned infrastructure.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primaryFiberLessorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Lessor Partner Id' ;
    rdfs:comment 'Reference to the partner organization providing the leased fiber strand. Null for owned infrastructure.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:primaryFiberLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Location Site Id' ;
    rdfs:comment 'Reference to the originating termination point facility or Point of Presence (POP) for this fiber strand.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:primaryFiberNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Fiber Network Equipment Id' ;
    rdfs:comment 'Reference to the network equipment (Optical Line Terminal, router, switch, or DWDM multiplexer) at the A-end termination point.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:fiberMode rdf:type rdf:Property ;
    rdfs:label 'Fiber Mode' ;
    rdfs:comment 'ISO/IEC 11801 fiber mode classification. OS1/OS2 for single-mode; OM1-OM5 for multi-mode with varying bandwidth capabilities. [ENUM-REF-CANDIDATE: OS1|OS2|OM1|OM2|OM3|OM4|OM5 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberType rdf:type rdf:Property ;
    rdfs:label 'Fiber Type' ;
    rdfs:comment 'Physical type of optical fiber. Single-mode for long-haul transmission; multi-mode for short-distance high-bandwidth; bend-insensitive for tight installation spaces.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date of the most recent optical performance test (OTDR or power meter test) conducted on this fiber strand.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Expiration date of the lease agreement. Null for IRU agreements (typically 20+ years) or owned infrastructure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Effective start date of the lease or IRU agreement for this fiber strand. Null for owned infrastructure used internally.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Ownership or lease arrangement for this fiber strand. Owned indicates company-owned infrastructure; leased indicates rental from third party; IRU (Indefeasible Right of Use) indicates long-term lease with ownership-like rights; swap indicates fiber exchange agreement; joint_build indicates shared construction arrangement.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredLossDb rdf:type rdf:Property ;
    rdfs:label 'Measured Loss Db' ;
    rdfs:comment 'Actual measured optical loss in decibels from the most recent Optical Time Domain Reflectometer (OTDR) test. Used to verify strand quality and detect degradation.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyLeaseCost rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Cost' ;
    rdfs:comment 'Monthly recurring cost for leasing this fiber strand from a third party. Null for owned infrastructure. Used for cost allocation and profitability analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyLeaseRevenue rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Revenue' ;
    rdfs:comment 'Monthly recurring revenue generated from leasing this fiber strand to wholesale customers. Null for internal use. Used for revenue assurance and wholesale billing.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opticalLossBudgetDb rdf:type rdf:Property ;
    rdfs:label 'Optical Loss Budget Db' ;
    rdfs:comment 'Total acceptable optical power loss in decibels (dB) for this fiber strand from A-end to Z-end, including fiber attenuation, splice losses, and connector losses. Critical for service quality assurance.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strandColorCode rdf:type rdf:Property ;
    rdfs:label 'Strand Color Code' ;
    rdfs:comment 'Industry-standard color coding of the fiber strand for physical identification during splicing and maintenance operations. [ENUM-REF-CANDIDATE: blue|orange|green|brown|slate|white|red|black|yellow|violet|rose|aqua — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandNumber rdf:type rdf:Property ;
    rdfs:label 'Strand Number' ;
    rdfs:comment 'Physical strand number within the fiber cable, typically numbered sequentially from 1 to the total fiber count in the cable.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wavelengthNm rdf:type rdf:Property ;
    rdfs:label 'Wavelength Nm' ;
    rdfs:comment 'Specific wavelength in nanometers assigned to this strand for Dense Wavelength Division Multiplexing (DWDM) systems. Null for non-DWDM dark fiber.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zEndPortNumber rdf:type rdf:Property ;
    rdfs:label 'Z End Port Number' ;
    rdfs:comment 'Physical port identifier on the Z-end equipment where this fiber strand terminates.' ;
    rdfs:domain ind:FiberStrandAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPoolIpAddressPoolId rdf:type rdf:Property ;
    rdfs:label 'Parent Pool Ip Address Pool Id' ;
    rdfs:comment 'Reference to parent pool if this is a sub-pool carved from a larger allocation. Enables hierarchical pool management and delegation.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:allocationPolicy rdf:type rdf:Property ;
    rdfs:label 'Allocation Policy' ;
    rdfs:comment 'Strategy for assigning resources from this pool. Sequential for ordered assignment, random for load distribution, least-used for utilization balancing.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Count' ;
    rdfs:comment 'Current number of resources actively assigned from this pool. Updated in near-real-time as assignments and releases occur.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentScope rdf:type rdf:Property ;
    rdfs:label 'Assignment Scope' ;
    rdfs:comment 'Type of entity that resources from this pool are assigned to. Subscriber for end-user accounts, CPE for customer equipment, network node for infrastructure.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCount rdf:type rdf:Property ;
    rdfs:label 'Available Count' ;
    rdfs:comment 'Current number of unassigned resources available for allocation. Calculated as total_capacity minus assigned_count minus reserved_count.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cgnatRatio rdf:type rdf:Property ;
    rdfs:label 'Cgnat Ratio' ;
    rdfs:comment 'Number of subscribers sharing each public IP address in CGNAT pools. Typical ratios range from 16:1 to 256:1 depending on service type and usage patterns.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cidrBlock rdf:type rdf:Property ;
    rdfs:label 'Cidr Block' ;
    rdfs:comment 'CIDR notation for IP address pools (e.g., 10.0.0.0/16 for IPv4, 2001:db8::/32 for IPv6). Null for non-IP resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLeaseDurationHours rdf:type rdf:Property ;
    rdfs:label 'Default Lease Duration Hours' ;
    rdfs:comment 'Default lease duration in hours for dynamic assignments from this pool. Applies to DHCP leases and temporary allocations. Null for static pools.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encapsulationType rdf:type rdf:Property ;
    rdfs:label 'Encapsulation Type' ;
    rdfs:comment 'Network encapsulation protocol used for this resource pool. 802.1Q for single VLAN tagging, QinQ for double tagging, VXLAN for overlay networks, EVPN for BGP-based VPN.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highWatermarkThreshold rdf:type rdf:Property ;
    rdfs:label 'High Watermark Threshold' ;
    rdfs:comment 'Utilization percentage threshold that triggers capacity alerts. Typically 80-90% to allow time for pool expansion before depletion.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCgnatEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Cgnat Enabled' ;
    rdfs:comment 'Indicates whether this pool is used for CGNAT (Carrier-Grade NAT) to share public IPs across multiple subscribers. Common for IPv4 conservation.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLawfulInterceptEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Lawful Intercept Enabled' ;
    rdfs:comment 'Indicates whether assignments from this pool are subject to lawful intercept logging and monitoring requirements per regulatory mandates.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicRoutable rdf:type rdf:Property ;
    rdfs:label 'Is Public Routable' ;
    rdfs:comment 'Indicates whether IP addresses in this pool are publicly routable on the internet (true) or private/RFC1918 addresses (false).' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Assignment Timestamp' ;
    rdfs:comment 'Timestamp of the most recent resource assignment from this pool. Used for activity tracking and idle pool identification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Release Timestamp' ;
    rdfs:comment 'Timestamp of the most recent resource release back to this pool. Used for churn analysis and capacity reclamation tracking.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lowWatermarkThreshold rdf:type rdf:Property ;
    rdfs:label 'Low Watermark Threshold' ;
    rdfs:comment 'Utilization percentage threshold below which the pool is considered underutilized. Used for resource optimization and consolidation decisions.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkZone rdf:type rdf:Property ;
    rdfs:label 'Network Zone' ;
    rdfs:comment 'Network architecture layer where this pool is deployed. Core for backbone, edge for distribution, access for last-mile, data center for cloud services. [ENUM-REF-CANDIDATE: core|edge|access|aggregation|metro|data_center|customer_premises — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Unique business identifier or code for the pool, used in operational systems and external references.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name or label for the IP address pool, used for identification and operational reference.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolOwner rdf:type rdf:Property ;
    rdfs:label 'Pool Owner' ;
    rdfs:comment 'Business unit, department, or team responsible for managing this pool. Used for accountability and operational ownership.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the pool. Active pools are available for assignment, depleted pools have no available resources, quarantined pools are temporarily blocked.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory designation for this pool. Lawful intercept pools require logging for law enforcement, emergency services pools have priority routing requirements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedCount rdf:type rdf:Property ;
    rdfs:label 'Reserved Count' ;
    rdfs:comment 'Number of resources reserved for future use or specific purposes (e.g., network infrastructure, management, emergency services).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Type of logical network resource managed by this pool. Distinguishes between IP address pools, VLAN segment pools, VXLAN pools, and CGNAT ranges.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDomain rdf:type rdf:Property ;
    rdfs:label 'Routing Domain' ;
    rdfs:comment 'Routing domain or VRF (Virtual Routing and Forwarding) instance this pool belongs to. Enables network segmentation and multi-tenancy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Capacity' ;
    rdfs:comment 'Maximum number of assignable resources in this pool. For IP pools, count of usable addresses; for VLAN pools, count of VLAN IDs.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Current utilization rate of the pool, calculated as (assigned_count / total_capacity) * 100. Used for capacity planning and threshold alerting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vlanRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Vlan Range End' ;
    rdfs:comment 'Ending VLAN ID for VLAN pool resources. Must be greater than or equal to vlan_range_start. Null for non-VLAN resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vlanRangeStart rdf:type rdf:Property ;
    rdfs:label 'Vlan Range Start' ;
    rdfs:comment 'Starting VLAN ID for VLAN pool resources. Valid range 1-4094 per IEEE 802.1Q. Null for non-VLAN resource types.' ;
    rdfs:domain ind:IpAddressPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAuthority rdf:type rdf:Property ;
    rdfs:label 'Allocation Authority' ;
    rdfs:comment 'Name of the regulatory body or numbering authority that allocated this number range to the operator.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockSize rdf:type rdf:Property ;
    rdfs:label 'Block Size' ;
    rdfs:comment 'Standard block size or increment in which numbers from this range are typically allocated or reserved for operational efficiency.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Per Number' ;
    rdfs:comment 'Regulatory fee or cost per individual number in this range charged by the numbering authority for allocation and maintenance.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endNumber rdf:type rdf:Property ;
    rdfs:label 'End Number' ;
    rdfs:comment 'The last MSISDN or DID number in the allocated range. Must comply with ITU-T E.164 international numbering format.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlrReference rdf:type rdf:Property ;
    rdfs:label 'Hlr Reference' ;
    rdfs:comment 'Identifier of the Home Location Register or Home Subscriber Server (HSS) system where subscriber records for this number range are stored.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeallocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Deallocation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent number deallocation or return transaction from a subscriber back to available inventory.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ndc rdf:type rdf:Property ;
    rdfs:label 'Ndc' ;
    rdfs:comment 'National destination code or area code portion of the number range. Used for geographic or network routing within the country.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Network Operator Code' ;
    rdfs:comment 'Code identifying the network operator or Mobile Virtual Network Operator (MVNO) to which this range is assigned.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberFormatMask rdf:type rdf:Property ;
    rdfs:label 'Number Format Mask' ;
    rdfs:comment 'Display format mask or template for presenting numbers from this range to end users in customer-facing systems and billing documents.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Porting Eligible Flag' ;
    rdfs:comment 'Indicates whether numbers in this range are eligible for mobile number portability per national MNP regulations.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantinePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Quarantine Period Days' ;
    rdfs:comment 'Mandatory cooling-off period in days that numbers from this range must remain quarantined after deallocation before becoming available for reassignment per regulatory requirements.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantinedCount rdf:type rdf:Property ;
    rdfs:label 'Quarantined Count' ;
    rdfs:comment 'Count of numbers in quarantine status awaiting release per regulatory cooling-off period after deallocation.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rangeCode rdf:type rdf:Property ;
    rdfs:label 'Range Code' ;
    rdfs:comment 'Business identifier code for the number range allocation. Used for external reference and operational tracking.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeStatus rdf:type rdf:Property ;
    rdfs:label 'Range Status' ;
    rdfs:comment 'Current lifecycle status of the number range indicating its availability and operational state.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rangeType rdf:type rdf:Property ;
    rdfs:label 'Range Type' ;
    rdfs:comment 'Classification of the number range indicating its purpose and usage category within the telecommunications network.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Allocation Reference' ;
    rdfs:comment 'Reference number or identifier from the national regulatory authority documenting the official allocation of this number range to the operator.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPrefix rdf:type rdf:Property ;
    rdfs:label 'Routing Prefix' ;
    rdfs:comment 'Network routing prefix used for call routing and signaling for numbers in this range within the telecommunications infrastructure.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text description of any special regulatory conditions, restrictions, or usage requirements imposed on this number range by the numbering authority.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startNumber rdf:type rdf:Property ;
    rdfs:label 'Start Number' ;
    rdfs:comment 'The first MSISDN or DID number in the allocated range. Must comply with ITU-T E.164 international numbering format.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCategory rdf:type rdf:Property ;
    rdfs:label 'Usage Category' ;
    rdfs:comment 'Business classification indicating the intended customer segment or usage purpose for numbers in this range.' ;
    rdfs:domain ind:MsisdnRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeId rdf:type rdf:Property ;
    rdfs:label 'Exchange Id' ;
    rdfs:comment 'Foreign key linking to location.exchange. Business justification: Network equipment deployed at telephone exchanges for PSTN, DSL, and broadband services. Essential for exchange capacity planning, technology migration tracking, and wholesale access reporting in tele' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exchange .

ind:maintenanceContractId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Id' ;
    rdfs:comment 'Reference to the active maintenance or support contract covering this equipment. Links to vendor SLA terms and support entitlements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceContract .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Core and edge network equipment requires assigned engineer for configuration management, change control approval, incident response, and vendor escalation authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'FK to location.site.site_id — Network equipment assets must be locatable at their hosting site for asset management, spare parts logistics, and maintenance dispatch.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:administrativeStatus rdf:type rdf:Property ;
    rdfs:label 'Administrative Status' ;
    rdfs:comment 'Administrative control state indicating whether the equipment is permitted to provide service. UNLOCKED (allowed to operate), LOCKED (administratively disabled), SHUTTING_DOWN (graceful shutdown in progress).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateControlRequired rdf:type rdf:Property ;
    rdfs:label 'Climate Control Required' ;
    rdfs:comment 'Indicates whether the equipment requires temperature and humidity-controlled environment. True for most indoor equipment, false for outdoor-hardened units.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Date when the equipment is planned for decommissioning and removal from the network. Drives CAPEX planning for replacements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endOfSaleDate rdf:type rdf:Property ;
    rdfs:label 'End Of Sale Date' ;
    rdfs:comment 'Date announced by the vendor when the equipment model is no longer available for purchase. Triggers lifecycle planning and migration strategies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date when the vendor discontinues technical support, software updates, and spare parts availability. Critical for technology refresh planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the physical equipment unit. Used for warranty tracking, maintenance history, and asset identification.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Equipment Subtype' ;
    rdfs:comment 'Detailed equipment classification within the type category. Examples: eNodeB, gNodeB, BNG, BRAS, MPLS_ROUTER, SD_WAN_EDGE, IMS_CSCF, HSS, UDM, PCF, DSLAM, OLT_GPON, OLT_XGS_PON, RECTIFIER, BATTERY_BANK.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'High-level classification of network equipment by functional layer: RAN (Radio Access Network - eNodeB/gNodeB), CORE (IMS/HSS/UDM/PCF), TRANSPORT (MPLS routers/SD-WAN), ACCESS (BNG/BRAS/DSLAM/OLT), POWER (rectifiers/batteries), CPE (Customer Premises Equipment).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyBands rdf:type rdf:Property ;
    rdfs:label 'Frequency Bands' ;
    rdfs:comment 'Comma-separated list of radio frequency bands supported by RAN equipment. Examples: 700MHz, 1800MHz, 2100MHz, 2600MHz, 3500MHz, 28GHz. Null for non-radio equipment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareRevision rdf:type rdf:Property ;
    rdfs:label 'Hardware Revision' ;
    rdfs:comment 'Hardware revision or version code assigned by the manufacturer. Used to track component changes and compatibility.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostname rdf:type rdf:Property ;
    rdfs:label 'Hostname' ;
    rdfs:comment 'Fully qualified domain name (FQDN) or hostname assigned to the equipment for network identification and DNS resolution.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPowerDrawWatts rdf:type rdf:Property ;
    rdfs:label 'Max Power Draw Watts' ;
    rdfs:comment 'Maximum power consumption in watts under peak load conditions. Critical for power supply sizing and cooling requirements.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtbfHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Hours' ;
    rdfs:comment 'Manufacturer-rated Mean Time Between Failures in hours. Reliability metric used for spare parts planning and network resilience design.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mttrHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Hours' ;
    rdfs:comment 'Average time in hours required to repair or replace the equipment when a failure occurs. Used for SLA planning and workforce scheduling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkFunction rdf:type rdf:Property ;
    rdfs:label 'Network Function' ;
    rdfs:comment 'Primary network function or service role performed by the equipment. Examples: PACKET_CORE, VOICE_SWITCHING, BROADBAND_AGGREGATION, RADIO_ACCESS, TRANSPORT_ROUTING, POLICY_CONTROL.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity based on vendor recommendations or organizational policy.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max Celsius' ;
    rdfs:comment 'Maximum ambient temperature in Celsius at which the equipment can operate within specifications. Used for cooling system design.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min Celsius' ;
    rdfs:comment 'Minimum ambient temperature in Celsius at which the equipment can operate within specifications. Critical for outdoor and remote site deployments.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portCapacityGbps rdf:type rdf:Property ;
    rdfs:label 'Port Capacity Gbps' ;
    rdfs:comment 'Aggregate throughput capacity across all ports in gigabits per second (Gbps). Used for capacity planning and traffic engineering.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerDrawWatts rdf:type rdf:Property ;
    rdfs:label 'Power Draw Watts' ;
    rdfs:comment 'Typical power consumption of the equipment in watts under normal operating conditions. Used for power capacity planning and OPEX calculation.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackLocation rdf:type rdf:Property ;
    rdfs:label 'Rack Location' ;
    rdfs:comment 'Physical rack identifier within the site where the equipment is mounted. Format varies by site convention (e.g., R01, RACK-A-12).' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackUnitHeight rdf:type rdf:Property ;
    rdfs:label 'Rack Unit Height' ;
    rdfs:comment 'Number of rack units (RU) occupied by the equipment. Standard values: 1U, 2U, 4U, etc.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rackUnitPosition rdf:type rdf:Property ;
    rdfs:label 'Rack Unit Position' ;
    rdfs:comment 'Starting rack unit position (1U = 1.75 inches) from the bottom of the rack where the equipment is mounted. Used for physical space planning and cable management.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyRole rdf:type rdf:Property ;
    rdfs:label 'Redundancy Role' ;
    rdfs:comment 'Role of the equipment in redundancy configuration. PRIMARY (active), SECONDARY (standby backup), STANDALONE (no redundancy), N_PLUS_1 (shared backup for multiple primaries).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Current firmware or software version running on the equipment. Format typically follows semantic versioning (e.g., 21.4.2, 5.1.0-R2A).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedStandards rdf:type rdf:Property ;
    rdfs:label 'Supported Standards' ;
    rdfs:comment 'Comma-separated list of technology standards and protocols supported by the equipment. Examples: LTE, 5G_NR, GPON, XGS_PON, DOCSIS_3.1, MPLS, SD_WAN, VoLTE, IMS.' ;
    rdfs:domain ind:NetworkEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupOltAssetId rdf:type rdf:Property ;
    rdfs:label 'Backup Olt Asset Id' ;
    rdfs:comment 'Reference to the backup or standby OLT asset configured for failover protection of this primary OLT.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OltAsset .

ind:activePonPorts rdf:type rdf:Property ;
    rdfs:label 'Active Pon Ports' ;
    rdfs:comment 'Number of PON ports currently in active operational use serving subscriber ONTs.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chassisType rdf:type rdf:Property ;
    rdfs:label 'Chassis Type' ;
    rdfs:comment 'Physical form factor classification of the OLT chassis hardware.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the OLT was activated and placed into operational service for subscriber connectivity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Regulatory and industry compliance certifications held by the OLT hardware (e.g., FCC, CE, UL, NEBS).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOntCount rdf:type rdf:Property ;
    rdfs:label 'Current Ont Count' ;
    rdfs:comment 'Current number of ONT devices actively registered and connected to this OLT in the network.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalTemperatureRatingCelsius rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature Rating Celsius' ;
    rdfs:comment 'Rated operating temperature range specification for the OLT hardware in Celsius degrees.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedLineCards rdf:type rdf:Property ;
    rdfs:label 'Installed Line Cards' ;
    rdfs:comment 'Current number of PON line cards physically installed in the OLT chassis slots.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastFirmwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Firmware Update Date' ;
    rdfs:comment 'Date when the OLT firmware was most recently upgraded or patched.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCardSlots rdf:type rdf:Property ;
    rdfs:label 'Line Card Slots' ;
    rdfs:comment 'Total number of physical slots available in the OLT chassis for installing PON line cards.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceContractCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Code' ;
    rdfs:comment 'Identifier for the active maintenance or support contract covering this OLT asset.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementIpAddress rdf:type rdf:Property ;
    rdfs:label 'Management Ip Address' ;
    rdfs:comment 'IP address assigned to the OLT for network management, monitoring, and configuration access via NMS/EMS systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOntCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Ont Capacity' ;
    rdfs:comment 'Maximum theoretical number of ONT devices that can be supported by this OLT based on hardware specifications and port capacity.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average operational time between hardware failures for this OLT, used for reliability and availability planning.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time required to restore the OLT to operational status following a failure event.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nmsSystem rdf:type rdf:Property ;
    rdfs:label 'Nms System' ;
    rdfs:comment 'Primary network management system platform used to monitor and manage this OLT asset.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Rated or measured electrical power consumption of the OLT hardware in watts under normal operating conditions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackPosition rdf:type rdf:Property ;
    rdfs:label 'Rack Position' ;
    rdfs:comment 'Physical rack identifier and unit position within the central office or POP where the OLT chassis is mounted.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyConfiguration rdf:type rdf:Property ;
    rdfs:label 'Redundancy Configuration' ;
    rdfs:comment 'High availability and redundancy architecture configured for this OLT to ensure service continuity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snmpCommunityString rdf:type rdf:Property ;
    rdfs:label 'Snmp Community String' ;
    rdfs:comment 'SNMP authentication string used for secure management access to the OLT device via network management systems.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPonPorts rdf:type rdf:Property ;
    rdfs:label 'Total Pon Ports' ;
    rdfs:comment 'Total number of PON ports available on the OLT chassis across all installed line cards for downstream fiber connectivity.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uplinkInterfaceType rdf:type rdf:Property ;
    rdfs:label 'Uplink Interface Type' ;
    rdfs:comment 'Type of network interface used for uplink connectivity from the OLT to the core aggregation or metro network.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkPortCount rdf:type rdf:Property ;
    rdfs:label 'Uplink Port Count' ;
    rdfs:comment 'Number of uplink ports available on the OLT for connectivity to upstream network infrastructure.' ;
    rdfs:domain ind:OltAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Internal equipment identifier used in OSS/BSS systems for asset tracking and service provisioning workflows.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Name of the configuration profile or template applied to this ONT for service provisioning and feature enablement.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceFromOltMeters rdf:type rdf:Property ;
    rdfs:label 'Distance From Olt Meters' ;
    rdfs:comment 'Physical fiber distance in meters between the OLT and this ONT, calculated from optical signal propagation delay.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gponPortReference rdf:type rdf:Property ;
    rdfs:label 'Gpon Port Reference' ;
    rdfs:comment 'Unique GPON identifier assigned to the ONT for authentication and provisioning in the PON network.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOnlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Online Timestamp' ;
    rdfs:comment 'Timestamp of the last successful connection and communication between the ONT and OLT.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDownstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Downstream Bandwidth Mbps' ;
    rdfs:comment 'Maximum downstream bandwidth capacity in megabits per second that this ONT device supports.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUpstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Max Upstream Bandwidth Mbps' ;
    rdfs:comment 'Maximum upstream bandwidth capacity in megabits per second that this ONT device supports.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oltPortNumber rdf:type rdf:Property ;
    rdfs:label 'Olt Port Number' ;
    rdfs:comment 'Physical port identifier on the OLT device where this ONT is connected, typically in shelf/slot/port format.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalPowerRxDbm rdf:type rdf:Property ;
    rdfs:label 'Optical Power Rx Dbm' ;
    rdfs:comment 'Received optical power level at the ONT in decibels relative to one milliwatt (dBm). Critical for signal quality monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opticalPowerTxDbm rdf:type rdf:Property ;
    rdfs:label 'Optical Power Tx Dbm' ;
    rdfs:comment 'Transmitted optical power level from the ONT in decibels relative to one milliwatt (dBm). Used for upstream signal quality assessment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebootCount rdf:type rdf:Property ;
    rdfs:label 'Reboot Count' ;
    rdfs:comment 'Total number of times the ONT device has been rebooted since installation. Used for stability analysis.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteManagementEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Management Enabled Flag' ;
    rdfs:comment 'Indicates whether remote management and configuration capabilities are enabled on this ONT device.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Current operating temperature of the ONT device in degrees Celsius, monitored for thermal management.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uptimeHours rdf:type rdf:Property ;
    rdfs:label 'Uptime Hours' ;
    rdfs:comment 'Total number of hours the ONT has been continuously operational since last reboot or power cycle.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voipCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Voip Capability Flag' ;
    rdfs:comment 'Indicates whether the ONT device supports VoIP telephony services with integrated analog telephone adapters.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Warehouse or storage facility location code where the ONT is stored when not deployed. Null if currently deployed.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Wifi Capability Flag' ;
    rdfs:comment 'Indicates whether the ONT device has integrated WiFi capability for wireless connectivity.' ;
    rdfs:domain ind:OntAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Point-of-presence facilities require assigned manager for vendor access coordination, security compliance, lease management, and site audit responsibility. Replaces denormalized name field.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentFacilityPopFacilityId rdf:type rdf:Property ;
    rdfs:label 'Parent Facility Pop Facility Id' ;
    rdfs:comment 'Reference to the parent facility in a hierarchical facility structure, used for regional or organizational grouping.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopFacility .

ind:primaryDepotId rdf:type rdf:Property ;
    rdfs:label 'Primary Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: POP facilities are serviced from a primary depot for workforce dispatch, parts logistics, and emergency response. This link supports dispatch optimization, travel time calculation, and resource alloca' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:backupPowerType rdf:type rdf:Property ;
    rdfs:label 'Backup Power Type' ;
    rdfs:comment 'Type of backup power system available at the facility to ensure continuity during outages.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateControlType rdf:type rdf:Property ;
    rdfs:label 'Climate Control Type' ;
    rdfs:comment 'Type of environmental climate control system installed at the facility for temperature and humidity management.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for facility operations and logistics coordination.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the facility operations team.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Cooling Capacity Tons' ;
    rdfs:comment 'HVAC cooling capacity available at the facility measured in refrigeration tons for equipment thermal management.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Number of days between scheduled physical inventory cycle counts at this facility.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the facility was or is scheduled to be decommissioned and removed from active operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentRackCount rdf:type rdf:Property ;
    rdfs:label 'Equipment Rack Count' ;
    rdfs:comment 'Number of equipment racks available for hosting network infrastructure and telecommunications equipment.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known unique business identifier for the facility, used in operational systems and field dispatch.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable name of the facility location.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitySubtype rdf:type rdf:Property ;
    rdfs:label 'Facility Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity for facility categorization (e.g., regional depot, field technician van, retail store, warehouse). [ENUM-REF-CANDIDATE: regional_depot|field_van|retail_store|central_warehouse|staging_area|maintenance_hub|distribution_center — promote to reference product]' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the facility based on its primary operational purpose in the telecommunications network infrastructure.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed at the facility for equipment and inventory protection.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorSpaceSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Space Sqm' ;
    rdfs:comment 'Total usable floor space of the facility measured in square meters.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent physical inventory cycle count was completed at this facility.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current lease agreement for the facility expires, applicable only for leased facilities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockLevelThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level Threshold' ;
    rdfs:comment 'Maximum inventory quantity threshold that defines the upper limit for stock positioning at this facility.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStockLevelThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level Threshold' ;
    rdfs:comment 'Minimum inventory quantity threshold that triggers replenishment orders for this facility.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Type' ;
    rdfs:comment 'Primary telecommunications network connectivity available at the facility (e.g., fiber, microwave, satellite, copper). [ENUM-REF-CANDIDATE: fiber|microwave|satellite|copper|wireless|hybrid|mpls — promote to reference product]' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Scheduled date for the next physical inventory cycle count at this facility.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operates24x7 rdf:type rdf:Property ;
    rdfs:label 'Operates 24x7' ;
    rdfs:comment 'Indicates whether the facility operates continuously 24 hours per day, 7 days per week.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily end time for facility operations in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily start time for facility operations in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Legal ownership or occupancy arrangement for the facility property.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerCapacityKw rdf:type rdf:Property ;
    rdfs:label 'Power Capacity Kw' ;
    rdfs:comment 'Maximum electrical power capacity available at the facility measured in kilowatts.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityTier rdf:type rdf:Property ;
    rdfs:label 'Security Tier' ;
    rdfs:comment 'Physical security classification level of the facility based on access controls, surveillance, and protection measures.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicM rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic M' ;
    rdfs:comment 'Total volumetric storage capacity available for inventory assets measured in cubic meters.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsHazmatStorage rdf:type rdf:Property ;
    rdfs:label 'Supports Hazmat Storage' ;
    rdfs:comment 'Indicates whether the facility is certified and equipped to store hazardous materials such as batteries and chemicals.' ;
    rdfs:domain ind:PopFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectedCableId rdf:type rdf:Property ;
    rdfs:label 'Connected Cable Id' ;
    rdfs:comment 'Reference identifier for the physical cable connected to this port. Used for cable management and tracing physical connectivity.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiberCable .

ind:remoteEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Remote Equipment Id' ;
    rdfs:comment 'Reference to the network equipment at the far end of the cable connection. Enables end-to-end circuit tracing.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:bandwidthAllocationMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Allocation Mbps' ;
    rdfs:comment 'Allocated bandwidth for the service or circuit on this port. May be less than the physical port speed due to Quality of Service (QoS) policies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitCode rdf:type rdf:Property ;
    rdfs:label 'Circuit Code' ;
    rdfs:comment 'Unique identifier for the logical circuit or service provisioned on this port. Links physical infrastructure to service layer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCableDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Max Cable Distance Meters' ;
    rdfs:comment 'Maximum supported cable length in meters for the port based on its speed, transceiver type, and fiber/copper specifications.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Indicates whether the port is currently connected to a cable or device (occupied), available for use (vacant), reserved for planned deployment, or quarantined due to issues.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poePowerBudgetWatts rdf:type rdf:Property ;
    rdfs:label 'Poe Power Budget Watts' ;
    rdfs:comment 'Maximum power in watts that can be delivered through this port via PoE. Common values are 15.4W (802.3af), 30W (802.3at), or 60-90W (802.3bt).' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portDuplexMode rdf:type rdf:Property ;
    rdfs:label 'Port Duplex Mode' ;
    rdfs:comment 'Duplex configuration of the port indicating whether it can transmit and receive simultaneously (full duplex) or must alternate (half duplex).' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portFunction rdf:type rdf:Property ;
    rdfs:label 'Port Function' ;
    rdfs:comment 'Functional role of the port in the network architecture (e.g., access port for end devices, trunk port for inter-switch links, uplink to core network). [ENUM-REF-CANDIDATE: access|trunk|uplink|downlink|management|monitoring|backup|interconnect — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portLabel rdf:type rdf:Property ;
    rdfs:label 'Port Label' ;
    rdfs:comment 'Physical label or tag affixed to the port for visual identification during field operations and cable management activities.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portNumber rdf:type rdf:Property ;
    rdfs:label 'Port Number' ;
    rdfs:comment 'Sequential port number on the line card or equipment module. Used in combination with slot number to uniquely identify the physical port.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Port Speed Mbps' ;
    rdfs:comment 'Maximum transmission speed of the port in megabits per second. Common values include 100, 1000, 10000, 25000, 40000, 100000.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerOverEthernetCapable rdf:type rdf:Property ;
    rdfs:label 'Power Over Ethernet Capable' ;
    rdfs:comment 'Indicates whether the port supports Power over Ethernet (PoE) to supply electrical power to connected devices over the data cable.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityOfServiceClass rdf:type rdf:Property ;
    rdfs:label 'Quality Of Service Class' ;
    rdfs:comment 'QoS classification applied to traffic on this port for prioritization and Service Level Agreement (SLA) enforcement (e.g., gold, silver, bronze, best-effort).' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackUnitStart rdf:type rdf:Property ;
    rdfs:label 'Rack Unit Start' ;
    rdfs:comment 'Starting rack unit position from the bottom of the rack where the equipment is mounted. Rack units are standardized 1.75-inch (44.45mm) increments.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyGroup rdf:type rdf:Property ;
    rdfs:label 'Redundancy Group' ;
    rdfs:comment 'Identifier for the redundancy or protection group this port belongs to. Used for high-availability configurations and failover planning.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remotePortIdentifier rdf:type rdf:Property ;
    rdfs:label 'Remote Port Identifier' ;
    rdfs:comment 'Identifier of the port on the remote equipment that this port connects to. Used for documenting point-to-point connections.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Number' ;
    rdfs:comment 'Slot number within the chassis or equipment frame where the line card or module is installed. Null if the equipment does not have modular slots.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snmpIndex rdf:type rdf:Property ;
    rdfs:label 'Snmp Index' ;
    rdfs:comment 'SNMP ifIndex value for this port as reported by the network element. Used for correlation with SNMP monitoring data.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transceiverSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Transceiver Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the installed optical transceiver module. Used for inventory tracking and warranty management.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transceiverType rdf:type rdf:Property ;
    rdfs:label 'Transceiver Type' ;
    rdfs:comment 'Type and model of the pluggable optical transceiver installed in the port (e.g., SFP-10G-SR, QSFP28-100G-LR4). Null for fixed electrical ports.' ;
    rdfs:domain ind:RackSlotPort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanNumber rdf:type rdf:Property ;
    rdfs:label 'Vlan Number' ;
    rdfs:comment 'VLAN identifier assigned to this port for network segmentation. Valid range is 1-4094 per IEEE 802.1Q standard.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custodian Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: SIM card inventory is high-security asset requiring designated custodian for activation code protection, IMSI range allocation authority, and regulatory audit compliance.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetDeviceModelId rdf:type rdf:Property ;
    rdfs:label 'Target Device Model Id' ;
    rdfs:comment 'Foreign key linking to product.device_model. Business justification: eSIM profiles and physical SIMs are pre-configured for specific device models (iPhone 14, Samsung Galaxy S23). Critical for activation workflows, compatibility validation, and inventory allocation in ' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceModel .

ind:activationCode rdf:type rdf:Property ;
    rdfs:label 'Activation Code' ;
    rdfs:comment 'Unique activation code or QR code string used by the end user to download and install the eSIM profile. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle status of the SIM stock unit: unallocated (in warehouse), reserved (allocated to order), activated (in service), suspended (temporarily disabled), deactivated (service terminated), or retired (end of life).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when the SIM stock unit was allocated or reserved for a specific order or subscriber. Marks the transition from unallocated to reserved status.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturing or provisioning batch identifier for grouping SIM cards or eSIM profiles. Used for quality control, recall management, and inventory tracking.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or rack location within the warehouse for physical SIM card storage. Enables precise inventory picking and cycle counting. Null for eSIM profiles.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Date and time when the SIM stock unit was deactivated and removed from service. Marks the end of the active service lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Download Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was downloaded from the SM-DP+ platform to the target device. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eid rdf:type rdf:Property ;
    rdfs:label 'Eid' ;
    rdfs:comment '32-digit unique identifier for the embedded Universal Integrated Circuit Card (eUICC). Only applicable for eSIM profiles. Null for physical SIM cards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimProfileState rdf:type rdf:Property ;
    rdfs:label 'Esim Profile State' ;
    rdfs:comment 'State of the eSIM profile on the SM-DP+ platform: available (ready for download), downloaded (transferred to device), installed (on eUICC), enabled (active), disabled (inactive), or deleted (removed). Only applicable for eSIM profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form factor of the SIM card: 2FF (Mini-SIM), 3FF (Micro-SIM), 4FF (Nano-SIM), MFF2 (M2M form factor), or embedded (eSIM). Null for eSIM profiles.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsiRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Imsi Range End' ;
    rdfs:comment 'Ending IMSI number in the range allocated to this SIM stock batch. Defines the upper boundary of the IMSI allocation for inventory management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsiRangeStart rdf:type rdf:Property ;
    rdfs:label 'Imsi Range Start' ;
    rdfs:comment 'Starting IMSI number in the range allocated to this SIM stock batch. 15-digit identifier used for subscriber authentication in mobile networks.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestSim rdf:type rdf:Property ;
    rdfs:label 'Is Test Sim' ;
    rdfs:comment 'Flag indicating whether this SIM stock unit is designated for testing, lab use, or quality assurance purposes. True for test SIMs, false for production SIMs.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kiValue rdf:type rdf:Property ;
    rdfs:label 'Ki Value' ;
    rdfs:comment '128-bit secret authentication key stored on the SIM card for network authentication. Highly sensitive cryptographic material. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Date when the physical SIM card was manufactured or the eSIM profile was generated on the SM-DP+ platform.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opcValue rdf:type rdf:Property ;
    rdfs:label 'Opc Value' ;
    rdfs:comment '128-bit operator-specific variant of the authentication algorithm configuration. Used in conjunction with Ki for LTE/5G authentication. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pin1 rdf:type rdf:Property ;
    rdfs:label 'Pin1' ;
    rdfs:comment '4-8 digit PIN code for SIM card access control. Required for device unlock and SIM operations. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Business classification of the SIM profile: consumer (handset), M2M (machine-to-machine), IoT (Internet of Things), enterprise (corporate), test (lab/QA), or bootstrap (initial provisioning).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:puk1 rdf:type rdf:Property ;
    rdfs:label 'Puk1' ;
    rdfs:comment '8-digit PIN Unblocking Key used to reset PIN1 after multiple failed attempts. Critical for customer self-service. Encrypted at rest.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckDate rdf:type rdf:Property ;
    rdfs:label 'Quality Check Date' ;
    rdfs:comment 'Date when the quality assurance check was completed. Used for compliance tracking and inventory release management.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of the quality assurance check performed on the SIM stock: pending (awaiting inspection), passed (approved for use), failed (rejected), or not_required (no QA needed).' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the SIM stock was received into the warehouse or provisioned on the SM-DP+ platform. Marks the start of inventory availability.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smdpAddress rdf:type rdf:Property ;
    rdfs:label 'Smdp Address' ;
    rdfs:comment 'Fully qualified domain name (FQDN) of the Subscription Manager Data Preparation Plus (SM-DP+) server hosting the eSIM profile. Only applicable for eSIM profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the supplier or vendor who provided the SIM stock. Used for procurement tracking and supplier performance management.' ;
    rdfs:domain ind:SimStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Per-unit cost of the SIM card or eSIM profile in the operator\'s base currency. Used for inventory valuation and CAPEX tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastIssuedTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Last Issued Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Tracking which technician received spare parts supports inventory accountability, usage pattern analysis, and parts consumption reporting—critical for inventory management and cost control in field op' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification based on consumption value and criticality. A-items are high-value/high-usage, C-items are low-value/low-usage.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualConsumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Annual Consumption Quantity' ;
    rdfs:comment 'Total quantity consumed or issued in the last 12 months. Used for demand forecasting and inventory optimization.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity available for issue or allocation, calculated as current stock minus reserved/allocated quantities.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Tracking Flag' ;
    rdfs:comment 'Indicates whether this spare part is tracked by batch or lot numbers for quality control and traceability.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibleEquipmentModels rdf:type rdf:Property ;
    rdfs:label 'Compatible Equipment Models' ;
    rdfs:comment 'Comma-separated list or description of equipment models that this spare part is compatible with (e.g., \'Nokia AirScale 5G RAN\', \'Ericsson RBS 6000\', \'Huawei OLT MA5800\').' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality classification indicating the impact of stockouts on network operations and service delivery (critical parts require higher stock levels and faster replenishment).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stock Quantity' ;
    rdfs:comment 'Current on-hand quantity of this spare part across all storage locations. Updated in real-time with receipts, issues, and transfers.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the spare part is classified as hazardous material requiring special handling, storage, or disposal procedures.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'Classification code for hazardous materials (e.g., UN number, DOT hazard class) if hazardous_material_flag is true.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date when this spare part was last issued from inventory for a work order or maintenance activity.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order or receipt for this spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Number' ;
    rdfs:comment 'Most recent purchase order number used to procure this spare part. Used for procurement history tracking.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Average number of days from purchase order placement to receipt of the spare part. Used for inventory planning and reorder calculations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or original equipment manufacturer (OEM) that produces this spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum quantity threshold for inventory control. Prevents overstocking and excess capital tied up in inventory.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum quantity threshold that triggers reorder alerts. Part of inventory optimization and replenishment planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceStatus rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Status' ;
    rdfs:comment 'Lifecycle status indicating whether the part is actively used, being phased out, or obsolete. Drives inventory reduction and replacement planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level classification of the spare part type. Categories include RAN (Radio Access Network) components, fiber infrastructure components, power units, line cards, CPE (Customer Premises Equipment) spares, and other network equipment. [ENUM-REF-CANDIDATE: ran_component|fiber_component|power_equipment|line_card|cpe_hardware|network_equipment|optical_equipment|test_equipment|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed technical description of the spare part including specifications, use case, and compatibility notes.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable name or title of the spare part (e.g., \'Fiber Optic Connector LC/UPC\', \'RAN Power Amplifier Module\').' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer-assigned unique part number or stock keeping unit (SKU) for the spare part. Used for catalog identification and procurement.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partSubcategory rdf:type rdf:Property ;
    rdfs:label 'Part Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the part category (e.g., \'LC Connector\', \'SC Connector\', \'Power Amplifier\', \'Antenna\', \'ONT\', \'OLT Module\').' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level at which a purchase requisition or order should be triggered to replenish stock before reaching minimum level.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to order when replenishing this spare part. May be based on economic order quantity (EOQ) calculations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementPartNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Part Number' ;
    rdfs:comment 'Part number of the superseding or replacement spare part if this part is obsolete or discontinued.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity reserved or allocated for specific work orders, projects, or planned maintenance activities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Tracking Flag' ;
    rdfs:comment 'Indicates whether individual units of this spare part are tracked by unique serial numbers for warranty, maintenance, and asset management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the spare part can be stored before it expires or degrades. Null for non-perishable items.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sparePartStatus rdf:type rdf:Property ;
    rdfs:label 'Spare Part Status' ;
    rdfs:comment 'Current operational status of the spare part in the inventory system. Blocked or restricted parts cannot be issued.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPartNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Part Number' ;
    rdfs:comment 'Part number used by the vendor in their catalog, which may differ from internal and manufacturer part numbers.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Standard warranty period in months provided by the manufacturer for this spare part.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Spectrum licenses require designated compliance officer for regulatory reporting, coverage obligation tracking, license renewal management, and interference coordination with regulatory authorities.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualLicenseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Annual License Fee Usd' ;
    rdfs:comment 'The recurring annual fee paid to the regulatory authority to maintain this spectrum license, measured in USD. Part of operational expenditure (OPEX) for spectrum management.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedRanNodesCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Ran Nodes Count' ;
    rdfs:comment 'The number of RAN nodes (cell sites, base stations, gNodeBs, eNodeBs) currently configured to use this spectrum allocation. Indicates the deployment scale and utilization of the spectrum asset.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Deadline Date' ;
    rdfs:comment 'The date by which the operator must meet the regulatory coverage obligations for this spectrum allocation. Failure to meet this deadline may result in penalties or license revocation.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageObligation rdf:type rdf:Property ;
    rdfs:label 'Coverage Obligation' ;
    rdfs:comment 'Description of any regulatory coverage obligations or build-out requirements attached to this spectrum license. May specify population coverage percentages, geographic milestones, or deployment timelines mandated by the licensing authority.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentPriority rdf:type rdf:Property ;
    rdfs:label 'Deployment Priority' ;
    rdfs:comment 'The strategic priority assigned to deploying network infrastructure on this spectrum allocation. Critical and high priority spectrum is targeted for immediate rollout, while low or deferred spectrum may be held for future use or strategic reserve.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplexMode rdf:type rdf:Property ;
    rdfs:label 'Duplex Mode' ;
    rdfs:comment 'The duplexing method used for this spectrum allocation. FDD (Frequency Division Duplex) uses paired spectrum for uplink and downlink, TDD (Time Division Duplex) uses unpaired spectrum, SDL (Supplemental Downlink) is downlink-only, SUL (Supplemental Uplink) is uplink-only.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionMaskDesignation rdf:type rdf:Property ;
    rdfs:label 'Emission Mask Designation' ;
    rdfs:comment 'The technical emission mask or out-of-band emission limits that apply to this spectrum allocation. Defines the allowable power spectral density outside the allocated frequency block to prevent interference.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyRangeLowerMhz rdf:type rdf:Property ;
    rdfs:label 'Frequency Range Lower Mhz' ;
    rdfs:comment 'The lower bound of the frequency range allocated, measured in megahertz. Defines the starting frequency of the spectrum block.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyRangeUpperMhz rdf:type rdf:Property ;
    rdfs:label 'Frequency Range Upper Mhz' ;
    rdfs:comment 'The upper bound of the frequency range allocated, measured in megahertz. Defines the ending frequency of the spectrum block.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLicenseArea rdf:type rdf:Property ;
    rdfs:label 'Geographic License Area' ;
    rdfs:comment 'The geographic region or administrative area covered by this spectrum license. May be national, regional, or specific market areas (e.g., Major Trading Area, Economic Area, county-level).' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interferenceCoordinationZone rdf:type rdf:Property ;
    rdfs:label 'Interference Coordination Zone' ;
    rdfs:comment 'Geographic zone or identifier for interference coordination with adjacent operators or cross-border spectrum users. Used to manage interference mitigation and comply with international coordination agreements.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'License Issue Date' ;
    rdfs:comment 'The date when the spectrum license was originally issued by the regulatory authority. Marks the beginning of the license validity period.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseRenewalStatus rdf:type rdf:Property ;
    rdfs:label 'License Renewal Status' ;
    rdfs:comment 'Current status of any license renewal application or process. Tracks whether the operator has applied for renewal, whether the renewal has been approved or denied, or if it is under regulatory review.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEirpDbm rdf:type rdf:Property ;
    rdfs:label 'Maximum Eirp Dbm' ;
    rdfs:comment 'The maximum effective isotropic radiated power permitted for transmissions on this spectrum allocation, measured in dBm. Regulatory limit to control interference and ensure spectrum coexistence.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spectrumBand rdf:type rdf:Property ;
    rdfs:label 'Spectrum Band' ;
    rdfs:comment 'The radio frequency band allocated for use. Common bands include 700MHz, 1800MHz, 2600MHz for LTE and 3.5GHz, 26GHz, 28GHz for 5G NR deployments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrumEfficiencyTarget rdf:type rdf:Property ;
    rdfs:label 'Spectrum Efficiency Target' ;
    rdfs:comment 'The target spectral efficiency for this allocation, measured in bits per second per hertz (bps/Hz). Represents the data throughput goal per unit of spectrum bandwidth, used for network planning and performance benchmarking.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spectrumSharingArrangement rdf:type rdf:Property ;
    rdfs:label 'Spectrum Sharing Arrangement' ;
    rdfs:comment 'Indicates if this spectrum is subject to sharing arrangements. CBRS (Citizens Broadband Radio Service) is a three-tier shared spectrum framework in the US, LSA (Licensed Shared Access) is used in Europe, DSS (Dynamic Spectrum Sharing) allows LTE and 5G coexistence, and roaming agreements enable spectrum sharing with other operators.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrumTradingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Spectrum Trading Allowed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this spectrum allocation is permitted to be traded, leased, or transferred to another operator under regulatory rules. True if trading is allowed, false if the license is non-transferable.' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyUse rdf:type rdf:Property ;
    rdfs:label 'Technology Use' ;
    rdfs:comment 'The radio access technology (RAT) for which this spectrum is designated or currently deployed. Includes LTE (Long-Term Evolution), 5G NR (5G New Radio), NB-IoT (Narrowband IoT), LTE-M, and DSS (Dynamic Spectrum Sharing). [ENUM-REF-CANDIDATE: LTE|5G_NR|NB_IoT|GSM|UMTS|LTE_M|mmWave|DSS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpectrumAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressAliasId rdf:type rdf:Property ;
    rdfs:label 'Address Alias Id' ;
    rdfs:comment 'Unique identifier for the address alias association record. Primary key for the address alias entity.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAddressEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Address Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that verified or approved this alias association. Used for accountability and audit purposes in manual verification workflows.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:addressFormatStandard rdf:type rdf:Property ;
    rdfs:label 'Address Format Standard' ;
    rdfs:comment 'Name of the address formatting standard or specification that the alias value conforms to. Examples: AS4590 (Australia), BS7666 (UK), USPS Publication 28 (USA), Universal Postal Union S42, proprietary legacy format names. Used for format conversion and standardization logic.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasIdentifier rdf:type rdf:Property ;
    rdfs:label 'Alias Identifier' ;
    rdfs:comment 'The alternative identifier or code used to reference the address in source systems. May be a legacy system key, external reference code, or alternate naming convention.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasType rdf:type rdf:Property ;
    rdfs:label 'Alias Type' ;
    rdfs:comment 'Classification of the alias relationship. Indicates the nature and source of the alternative address representation. Types include: legacy_system (address format from retired OSS/BSS), postal_alias (alternate postal service identifier), informal_name (colloquial or common name), building_alias (building-specific identifier), dpid (Delivery Point Identifier - Australia Post), gnaf_pid (Geocoded National Address File Persistent Identifier - Australia), uprn (Unique Property Reference Number - UK), gnaf_address_detail_pid (G-NAF Address Detail PID - Australia), exchange_code_address (telephone exchange-based address code), ntd_location_id (National Telecommunications Database Location ID), geocode_alias (geocoding service identifier), service_address_id (service provisioning system address), billing_address_id (billing system address reference), installation_address_id (field installation system address). [ENUM-REF-CANDIDATE: legacy_system|postal_alias|informal_name|building_alias|dpid|gnaf_pid|uprn|gnaf_address_detail_pid|exchange_code_address|ntd_location_id|geocode_alias|service_address_id|billing_address_id|installation_address_id — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasValue rdf:type rdf:Property ;
    rdfs:label 'Alias Value' ;
    rdfs:comment 'The actual alternative address representation, identifier, or name. This is the value used in the source system or alternate format. May be a formatted address string, a code, or a reference number.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deduplicationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Deduplication Group Code' ;
    rdfs:comment 'Identifier linking this alias to a group of related aliases that were identified as duplicates during address deduplication processes. All aliases in the same group map to the same canonical address.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAccuracyLevel rdf:type rdf:Property ;
    rdfs:label 'Geographic Accuracy Level' ;
    rdfs:comment 'Precision level of the geographic match between the alias and canonical address. Values: rooftop (exact building location), parcel (property boundary), street_segment (street address range), postal_code (postal code centroid), locality (city/suburb level), region (state/province level), country (country level), unknown (accuracy not determined). Critical for network planning and service delivery applications. [ENUM-REF-CANDIDATE: rooftop|parcel|street_segment|postal_code|locality|region|country|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryAlias rdf:type rdf:Property ;
    rdfs:label 'Is Primary Alias' ;
    rdfs:comment 'Indicates whether this is the primary or preferred alias for the canonical address. True for the most commonly used or authoritative alias representation. Used to determine default display values in user interfaces.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when this alias was last referenced in an operational transaction or system query. Used to identify dormant aliases that may be candidates for archival.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'Method or algorithm used to establish the alias-to-canonical address association. Values: exact_match (direct identifier match), fuzzy_match (probabilistic string matching), geocode_match (coordinate-based matching), manual_verification (human-reviewed match), rule_based (business rule engine), ml_model (machine learning model prediction), postal_authority (validated by postal service), third_party_service (external address validation service). [ENUM-REF-CANDIDATE: exact_match|fuzzy_match|geocode_match|manual_verification|rule_based|ml_model|postal_authority|third_party_service — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Match Timestamp' ;
    rdfs:comment 'Date and time when the alias association was established or last verified. Critical for audit trail and understanding the recency of address matching processes.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationBatchCode rdf:type rdf:Property ;
    rdfs:label 'Migration Batch Code' ;
    rdfs:comment 'Identifier of the data migration or address standardization batch that created this alias association. Used to track and manage large-scale address consolidation projects during OSS/BSS system migrations.' ;
    rdfs:domain ind:AddressAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this alias is a high-priority reference that must be maintained for critical business operations or regulatory compliance. True for aliases used in active service provisioning, billing, or regulatory reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressGeocodeId rdf:type rdf:Property ;
    rdfs:label 'Address Geocode Id' ;
    rdfs:comment 'Unique identifier for the address geocoding record. Primary key for the address geocode entity.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyLevel rdf:type rdf:Property ;
    rdfs:label 'Accuracy Level' ;
    rdfs:comment 'Classification of the geocoding precision achieved. Rooftop is the most precise (exact building location), postcode_centroid is the least precise (center of postal code area). Critical for network planning and service delivery decisions.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusBlockReference rdf:type rdf:Property ;
    rdfs:label 'Census Block Reference' ;
    rdfs:comment 'United States Census Bureau census block identifier. The smallest geographic unit used by the US Census Bureau, used for demographic analysis and regulatory reporting. Essential for FCC (Federal Communications Commission) reporting and Universal Service Fund compliance.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsCode rdf:type rdf:Property ;
    rdfs:label 'Crs Code' ;
    rdfs:comment 'EPSG code identifying the coordinate reference system used for the latitude and longitude values. Default is EPSG:4326 (WGS84). Included to support scenarios where alternative coordinate systems are used for specialized network planning or regional requirements.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifier of the source system or process that created this geocode record. Examples: address_validation_batch_20240115, salesforce_crm_integration, field_survey_team_3. Used for data lineage tracking and troubleshooting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Elevation above mean sea level in meters. Used for network planning, signal propagation modeling, and terrain analysis. Nullable if elevation data is not available from the geocoding provider.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Code identifying the telecommunications exchange serving this geocoded location. Derived from the geocoded coordinates by spatial proximity analysis. Critical for fixed-line service provisioning, FTTH planning, and wholesale access management.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Geocode Identifier' ;
    rdfs:comment 'External or provider-assigned unique identifier for this geocoding result. May be used for traceability back to the geocoding provider\'s system.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeMethod rdf:type rdf:Property ;
    rdfs:label 'Geocode Method' ;
    rdfs:comment 'The method or provider used to obtain this geocoding result. GNAF_match refers to Australian Geocoded National Address File, USPS_match refers to United States Postal Service address matching. Enables comparison of geocoding quality across providers.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Geocode Quality Flag' ;
    rdfs:comment 'Overall quality classification of the geocode result based on accuracy_level, confidence_score, and match_score. High quality geocodes are suitable for all use cases including FTTH (Fiber to the Home) planning. Low quality geocodes may require manual verification before use in service provisioning.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeStatus rdf:type rdf:Property ;
    rdfs:label 'Geocode Status' ;
    rdfs:comment 'Current lifecycle status of the geocode record. Active indicates the geocode is in use. Superseded indicates a newer geocode has replaced this one. Rejected indicates the geocode failed quality validation. Pending_review indicates the geocode is awaiting manual verification. Expired indicates the geocode is no longer valid due to address changes.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingProvider rdf:type rdf:Property ;
    rdfs:label 'Geocoding Provider' ;
    rdfs:comment 'Name of the organization or service that provided the geocoding result. Examples: Google Maps Platform, HERE Technologies, Esri ArcGIS, internal survey team. Used for quality tracking and vendor performance analysis.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Geocoding Timestamp' ;
    rdfs:comment 'Date and time when the geocoding operation was performed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Enables tracking of geocoding currency and identification of stale geocodes that may need refresh.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthoritative rdf:type rdf:Property ;
    rdfs:label 'Is Authoritative' ;
    rdfs:comment 'Boolean flag indicating whether this geocode record is the authoritative, production-approved geocode for the address. True indicates this is the official geocode used for network planning, service delivery, and customer management. False indicates this is an alternative or historical geocode retained for comparison or audit purposes.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Date and time when the geocode was last verified as accurate, either through automated validation or manual field verification. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if the geocode has never been verified. Used to identify geocodes requiring re-verification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Score indicating how well the input address matched the geocoding provider\'s reference database, typically expressed as a percentage (0.00 to 100.00). Distinct from confidence_score; match_score reflects address string similarity while confidence_score reflects coordinate accuracy. Used to identify addresses requiring manual review.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meshBlockReference rdf:type rdf:Property ;
    rdfs:label 'Mesh Block Reference' ;
    rdfs:comment 'Australian Bureau of Statistics (ABS) mesh block identifier. The smallest geographic area defined by the ABS, used for census data collection and demographic analysis. Critical for market segmentation and regulatory reporting in Australia.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCoverageAreaCode rdf:type rdf:Property ;
    rdfs:label 'Network Coverage Area Code' ;
    rdfs:comment 'Code identifying the network coverage area that contains this geocoded location. Derived from the geocoded coordinates by spatial intersection with coverage area polygons. Used to determine technology availability (LTE, 5G NR, FTTH) and QoS (Quality of Service) expectations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputAreaReference rdf:type rdf:Property ;
    rdfs:label 'Output Area Reference' ;
    rdfs:comment 'United Kingdom Office for National Statistics (ONS) output area identifier. The smallest census geography in the UK, used for demographic analysis and market research. Required for Ofcom regulatory reporting in the UK market.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plusCode rdf:type rdf:Property ;
    rdfs:label 'Plus Code' ;
    rdfs:comment 'Open Location Code (Plus Code) representation of the geocoded location. A grid-based geocoding system that provides a short, human-readable code for any location. Useful for areas without formal street addresses, common in emerging markets and rural areas.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'Code identifying the service territory that contains this geocoded location. Derived from the geocoded coordinates by spatial intersection with service territory boundaries. Used for dispatch routing, SLA (Service Level Agreement) assignment, and workforce management.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:what3wordsAddress rdf:type rdf:Property ;
    rdfs:label 'What3words Address' ;
    rdfs:comment 'What3Words three-word address representation of the geocoded location. Each 3m x 3m square in the world has been assigned a unique three-word identifier. Used by field technicians for precise location identification during CPE (Customer Premises Equipment) installation and fault management.' ;
    rdfs:domain ind:AddressGeocode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationEventId rdf:type rdf:Property ;
    rdfs:label 'Address Validation Event Id' ;
    rdfs:comment 'Unique identifier for each address validation and geocoding event. Primary key for the address validation event record.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiResponseCode rdf:type rdf:Property ;
    rdfs:label 'Api Response Code' ;
    rdfs:comment 'The HTTP or service-specific response code returned by the validation API. Captures technical success or error codes from the external geocoding service (e.g., 200 for success, 400 for bad request, 500 for service error).' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Api Response Message' ;
    rdfs:comment 'Detailed message or description returned by the validation API. Provides additional context about the validation result, including error messages, warnings, or informational notes from the geocoding service.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedCity rdf:type rdf:Property ;
    rdfs:label 'Corrected City' ;
    rdfs:comment 'The standardized city or locality name returned by the validation service. Captures any corrections made to match official postal authority city names.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedCountryCode rdf:type rdf:Property ;
    rdfs:label 'Corrected Country Code' ;
    rdfs:comment 'The standardized three-letter country code returned by the validation service. Uses ISO 3166-1 alpha-3 format (e.g., USA, GBR, AUS, CAN).' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedPostalCode rdf:type rdf:Property ;
    rdfs:label 'Corrected Postal Code' ;
    rdfs:comment 'The standardized postal code or ZIP code returned by the validation service. Captures any corrections made to match authoritative postal code format and assignment.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedStateProvince rdf:type rdf:Property ;
    rdfs:label 'Corrected State Province' ;
    rdfs:comment 'The standardized state, province, or region code returned by the validation service. Typically uses official postal abbreviations (e.g., CA for California, NSW for New South Wales).' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedStreetName rdf:type rdf:Property ;
    rdfs:label 'Corrected Street Name' ;
    rdfs:comment 'The standardized street name component returned by the validation service. Captures any corrections made to the input street name including spelling, abbreviations, and directional prefixes.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedStreetNumber rdf:type rdf:Property ;
    rdfs:label 'Corrected Street Number' ;
    rdfs:comment 'The standardized street number component returned by the validation service. Captures any corrections made to the input street number to match authoritative format.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedStreetType rdf:type rdf:Property ;
    rdfs:label 'Corrected Street Type' ;
    rdfs:comment 'The standardized street type component (e.g., Street, Avenue, Road, Boulevard) returned by the validation service. Captures any corrections made to match postal authority standards.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Corrected Unit Number' ;
    rdfs:comment 'The standardized unit, apartment, or suite number component returned by the validation service. Captures any corrections made to secondary address designators.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpvConfirmationIndicator rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation Indicator' ;
    rdfs:comment 'USPS-specific indicator confirming whether the address is a valid delivery point. Y indicates confirmed deliverable address; N indicates not confirmed; S indicates address is missing secondary (unit) number; D indicates address matched to USPS database but missing secondary information. Critical for mail deliverability assessment.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracyLevel rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy Level' ;
    rdfs:comment 'Precision level of the geocoding result. Rooftop indicates exact building location; parcel indicates property boundary; street indicates street segment; intersection indicates cross-street; postal_code indicates ZIP/postcode centroid; city, region, country indicate progressively coarser granularity. [ENUM-REF-CANDIDATE: rooftop|parcel|street|intersection|postal_code|city|region|country — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingLatitude rdf:type rdf:Property ;
    rdfs:label 'Geocoding Latitude' ;
    rdfs:comment 'Geographic latitude coordinate returned by the geocoding service, expressed in decimal degrees. Represents the north-south position of the validated address on Earth\'s surface, ranging from -90 to +90 degrees.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geocodingLongitude rdf:type rdf:Property ;
    rdfs:label 'Geocoding Longitude' ;
    rdfs:comment 'Geographic longitude coordinate returned by the geocoding service, expressed in decimal degrees. Represents the east-west position of the validated address on Earth\'s surface, ranging from -180 to +180 degrees.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputAddressString rdf:type rdf:Property ;
    rdfs:label 'Input Address String' ;
    rdfs:comment 'The raw, unvalidated address string submitted for validation. Captures the exact input as received from the user or system before any normalization or correction.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Numerical confidence score indicating the quality of the address match, ranging from 0 to 100. Higher scores indicate greater confidence in the validation result. Score of 100 represents exact match, lower scores indicate partial or interpolated matches.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Classification of the address match result. Exact indicates perfect match to authoritative database; partial indicates some components matched; interpolated indicates address was estimated based on range; no_match indicates validation failed; ambiguous indicates multiple possible matches; corrected indicates input was modified to match standard.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedAddressString rdf:type rdf:Property ;
    rdfs:label 'Matched Address String' ;
    rdfs:comment 'The standardized, validated address string returned by the validation service. Represents the best match found in the authoritative address database.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialDeliveryIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Delivery Indicator' ;
    rdfs:comment 'Classification indicating whether the validated address is a residential or commercial location. Used for service eligibility determination, pricing, and network planning decisions in telecommunications service delivery.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Validation Cost Amount' ;
    rdfs:comment 'Cost incurred for this validation event when using external paid geocoding services. Tracks per-transaction costs for services like Google Maps API or HERE Maps that charge per validation request. Used for cost allocation and vendor billing reconciliation.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Validation Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the validation cost amount. Typically USD for most geocoding API services.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDurationMs rdf:type rdf:Property ;
    rdfs:label 'Validation Duration Ms' ;
    rdfs:comment 'Time taken to complete the address validation request, measured in milliseconds. Used for performance monitoring and Service Level Agreement (SLA) tracking of validation service response times.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text field capturing additional context, observations, or special handling instructions related to the validation event. May include manual review notes, data quality observations, or business rules applied during validation.' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTriggerSource rdf:type rdf:Property ;
    rdfs:label 'Validation Trigger Source' ;
    rdfs:comment 'The business process or system component that initiated the address validation event. Identifies whether validation was triggered by user action, automated data quality process, service provisioning workflow, or other business event. [ENUM-REF-CANDIDATE: manual_user|batch_process|api_call|data_quality_job|customer_onboarding|service_order|network_planning|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AddressValidationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRegionAdministrativeRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Region Administrative Region Id' ;
    rdfs:comment 'Reference to the parent administrative region in the geographic hierarchy. Enables traversal of the region hierarchy (e.g., a county references its parent state, a suburb references its parent LGA). Null for top-level regions (countries).' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdministrativeRegion .

ind:administrativeRegionStatus rdf:type rdf:Property ;
    rdfs:label 'Administrative Region Status' ;
    rdfs:comment 'Current lifecycle status of the administrative region record (active = currently in use, inactive = no longer in use, pending = awaiting activation, deprecated = superseded by another region definition).' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateName rdf:type rdf:Property ;
    rdfs:label 'Alternate Name' ;
    rdfs:comment 'Alternative or historical name for the administrative region. Used for search, matching, and legacy system integration (e.g., \'Bombay\' as alternate for \'Mumbai\').' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSquareKm rdf:type rdf:Property ;
    rdfs:label 'Area Square Km' ;
    rdfs:comment 'Total geographic area of the administrative region measured in square kilometres. Used for coverage analysis, network planning, and service territory definition.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePriority rdf:type rdf:Property ;
    rdfs:label 'Coverage Priority' ;
    rdfs:comment 'Network coverage priority classification for this administrative region (high, medium, low). Drives CAPEX allocation, network rollout planning, and service expansion decisions.' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicIndicator rdf:type rdf:Property ;
    rdfs:label 'Economic Indicator' ;
    rdfs:comment 'Economic development classification or indicator for the administrative region (e.g., GDP per capita band, socioeconomic index, development tier). Used for market analysis, pricing strategy, and ARPU forecasting.' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localLanguageName rdf:type rdf:Property ;
    rdfs:label 'Local Language Name' ;
    rdfs:comment 'Name of the administrative region in the local or official language, using native script (e.g., \'München\' for Munich, \'東京\' for Tokyo). Supports multilingual customer interfaces and regulatory compliance.' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationEstimate rdf:type rdf:Property ;
    rdfs:label 'Population Estimate' ;
    rdfs:comment 'Estimated population count for the administrative region as of the most recent census or statistical estimate. Used for market sizing, network capacity planning, and regulatory reporting.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodePattern rdf:type rdf:Property ;
    rdfs:label 'Postal Code Pattern' ;
    rdfs:comment 'Regular expression or pattern describing the postal code format used in this administrative region (e.g., \'^[0-9]{5}$\' for US ZIP codes, \'^[A-Z]{1,2}[0-9]{1,2} [0-9][A-Z]{2}$\' for UK postcodes). Used for address validation and data quality.' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Official name of the administrative region as recognized by the governing authority (e.g., \'California\', \'New South Wales\', \'Greater London\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the administrative region within the geographic hierarchy (e.g., country, state, territory, province, region, county, district, local government area, suburb, locality, postcode, municipality). [ENUM-REF-CANDIDATE: country|state|territory|province|region|county|district|lga|suburb|locality|postcode|municipality — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Name of the telecommunications regulatory authority or jurisdiction governing this administrative region (e.g., \'FCC\', \'Ofcom\', \'ACMA\', \'CRTC\'). Used for compliance reporting, licensing, and regulatory obligation tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Service Availability Flag' ;
    rdfs:comment 'Indicates whether telecommunications services are currently available in this administrative region (True = services available, False = services not available). Used for service eligibility checks and market coverage reporting.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the administrative region (e.g., \'America/New_York\', \'Australia/Sydney\', \'Europe/London\'). Used for scheduling, service provisioning, and customer communication.' ;
    rdfs:domain ind:AdministrativeRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackSpotId rdf:type rdf:Property ;
    rdfs:label 'Black Spot Id' ;
    rdfs:comment 'Unique identifier for the telecommunications black spot location record. Primary key for the black spot master data entity.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ranCellId rdf:type rdf:Property ;
    rdfs:label 'Ran Cell Id' ;
    rdfs:comment 'Foreign key linking to network.ran_cell. Business justification: Black spot remediation requires identifying nearest serving cell for coverage extension planning, signal propagation analysis, and universal service obligation compliance. Critical for government-fund' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RanCell .

ind:affectedPopulationEstimate rdf:type rdf:Property ;
    rdfs:label 'Affected Population Estimate' ;
    rdfs:comment 'Estimated number of individuals residing or working within the black spot area who are impacted by inadequate telecommunications coverage. Used for social equity analysis, government subsidy justification, and community impact assessment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPremisesCount rdf:type rdf:Property ;
    rdfs:label 'Affected Premises Count' ;
    rdfs:comment 'Estimated number of residential and business premises within the black spot area that lack adequate telecommunications service. Used for programme prioritisation, funding allocation, and Universal Service Obligation (USO) compliance reporting.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackSpotName rdf:type rdf:Property ;
    rdfs:label 'Black Spot Name' ;
    rdfs:comment 'Human-readable name or label for the black spot location, typically referencing the geographic area, community, or landmark (e.g., \'Rural Valley Township\', \'Highway 101 Corridor\', \'Remote Island Settlement\').' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackSpotType rdf:type rdf:Property ;
    rdfs:label 'Black Spot Type' ;
    rdfs:comment 'Classification of the type of telecommunications coverage deficiency at this location. Distinguishes between mobile network gaps (no coverage, poor signal), broadband service gaps (no service, underserved with inadequate speeds), and fixed-line unavailability.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Latitude' ;
    rdfs:comment 'Latitude coordinate of the geographic centroid of the black spot area in decimal degrees (WGS84). Used for mapping, distance calculations, and proximity analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Longitude' ;
    rdfs:comment 'Longitude coordinate of the geographic centroid of the black spot area in decimal degrees (WGS84). Used for mapping, distance calculations, and proximity analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityPetitionFlag rdf:type rdf:Property ;
    rdfs:label 'Community Petition Flag' ;
    rdfs:comment 'Indicates whether this black spot was identified through a formal community petition or public consultation process. True if community-nominated, False otherwise.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionStartDate rdf:type rdf:Property ;
    rdfs:label 'Construction Start Date' ;
    rdfs:comment 'Date when physical construction or network deployment activities commenced to remediate the black spot. Used for project management, milestone tracking, and regulatory reporting.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distanceToServiceableLocationKm rdf:type rdf:Property ;
    rdfs:label 'Distance To Serviceable Location Km' ;
    rdfs:comment 'Distance in kilometers from the black spot centroid to the nearest location with adequate telecommunications service. Used for infrastructure cost estimation, technology selection (fiber vs wireless), and programme feasibility assessment.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economicZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Economic Zone Classification' ;
    rdfs:comment 'Economic classification of the black spot area (e.g., \'rural\', \'remote\', \'regional\', \'indigenous community\', \'agricultural zone\', \'tourism area\'). Used for programme eligibility, funding prioritisation, and socio-economic impact analysis.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConstraints rdf:type rdf:Property ;
    rdfs:label 'Environmental Constraints' ;
    rdfs:comment 'Description of environmental or regulatory constraints that may impact black spot remediation (e.g., \'national park restrictions\', \'heritage site limitations\', \'protected wildlife habitat\', \'indigenous land rights\'). Used for project planning and compliance management.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total funding amount allocated for remediation of this black spot location, including government subsidies, operator co-investment, and any third-party contributions. Expressed in local currency.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the funding amount (e.g., USD, GBP, AUD, EUR).' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryWkt rdf:type rdf:Property ;
    rdfs:label 'Geometry Wkt' ;
    rdfs:comment 'Spatial geometry of the black spot area represented in Well-Known Text (WKT) format. May be a POINT for a specific location or a POLYGON for a broader coverage deficiency area. Used for GIS analysis, network planning, and regulatory mapping.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'External business identifier or reference code for the black spot location, used in government programmes, regulatory reporting, and inter-agency coordination. May be assigned by FCC, BDUK, ACMA, or internal network planning systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Survey Date' ;
    rdfs:comment 'Date when the most recent coverage survey or field measurement was conducted to verify the black spot status. Used for data currency validation and re-assessment scheduling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measuredDownloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Measured Download Speed Mbps' ;
    rdfs:comment 'Measured broadband download speed at the black spot location in megabits per second (Mbps). Used to quantify the severity of broadband underservice and validate remediation outcomes.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredSignalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Measured Signal Strength Dbm' ;
    rdfs:comment 'Measured mobile network signal strength at the black spot location in dBm (decibel-milliwatts). Negative values indicate signal strength (e.g., -110 dBm is very weak, -70 dBm is strong). Used for coverage gap quantification and technology selection.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredUploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Measured Upload Speed Mbps' ;
    rdfs:comment 'Measured broadband upload speed at the black spot location in megabits per second (Mbps). Used to assess service adequacy for applications requiring upstream bandwidth (video conferencing, cloud backup, telehealth).' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Date when the black spot location was formally nominated or identified for inclusion in a coverage improvement programme. Used for programme tracking, prioritisation, and regulatory reporting timelines.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominationSource rdf:type rdf:Property ;
    rdfs:label 'Nomination Source' ;
    rdfs:comment 'Origin or source of the black spot nomination. Indicates whether the coverage deficiency was identified by community petition, government agency, telecommunications operator internal planning, regulatory body, or third-party survey.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeReference rdf:type rdf:Property ;
    rdfs:label 'Programme Reference' ;
    rdfs:comment 'Reference identifier or name of the government black spot programme, universal service obligation (USO) initiative, or subsidy scheme under which this location is registered (e.g., \'Mobile Black Spot Programme Round 5\', \'FCC Connect America Fund Phase II\', \'BDUK Gigabit Voucher Scheme\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmeStatus rdf:type rdf:Property ;
    rdfs:label 'Programme Status' ;
    rdfs:comment 'Current lifecycle status of the black spot within the government or operator remediation programme. Tracks progression from nomination through approval, funding, construction, and resolution. [ENUM-REF-CANDIDATE: nominated|under_review|approved|funded|in_build|resolved|not_funded|deferred — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvingTechnology rdf:type rdf:Property ;
    rdfs:label 'Resolving Technology' ;
    rdfs:comment 'Primary telecommunications technology deployed to remediate the black spot and provide adequate coverage (e.g., 5G New Radio (NR), Long-Term Evolution (LTE), Fiber to the Home (FTTH), fixed wireless access, satellite broadband). [ENUM-REF-CANDIDATE: 5G|LTE|FTTH|FTTC|fixed_wireless|satellite|microwave_backhaul|hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether the black spot is in a location where telecommunications coverage is critical for public safety, emergency services, or disaster response (e.g., remote highways, fire-prone areas, flood zones). True if safety-critical, False otherwise.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Method used to identify or verify the black spot coverage deficiency (e.g., drive test, walk test, crowdsourced data, RF propagation modeling, satellite imagery analysis, community reporting).' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Target Service Level' ;
    rdfs:comment 'Minimum service level or performance target that must be achieved to consider the black spot resolved (e.g., \'25 Mbps download / 3 Mbps upload\', \'-95 dBm outdoor signal strength\', \'99% availability\'). Used for Quality of Service (QoS) validation and regulatory compliance.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terrainType rdf:type rdf:Property ;
    rdfs:label 'Terrain Type' ;
    rdfs:comment 'Physical terrain classification of the black spot area. Influences technology selection, infrastructure cost, and signal propagation characteristics for remediation planning. [ENUM-REF-CANDIDATE: flat|hilly|mountainous|coastal|island|desert|forest|urban_canyon — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usoObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Uso Obligation Flag' ;
    rdfs:comment 'Indicates whether this black spot is subject to a Universal Service Obligation (USO) requirement, mandating the operator to provide service regardless of commercial viability. True if USO applies, False otherwise.' ;
    rdfs:domain ind:BlackSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cellCoverageFootprintId rdf:type rdf:Property ;
    rdfs:label 'Cell Coverage Footprint Id' ;
    rdfs:comment 'Unique identifier for the cell coverage footprint record. Primary key for this entity.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antennaGainDbi rdf:type rdf:Property ;
    rdfs:label 'Antenna Gain Dbi' ;
    rdfs:comment 'The gain of the antenna in dBi (decibels relative to an isotropic radiator). Higher gain increases coverage range in the direction of the main lobe.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antennaHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Antenna Height Meters' ;
    rdfs:comment 'The height of the antenna above ground level in meters. Key parameter for propagation modeling and coverage prediction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:azimuthDegrees rdf:type rdf:Property ;
    rdfs:label 'Azimuth Degrees' ;
    rdfs:comment 'The horizontal direction in degrees (0-360) that the antenna is pointing, measured clockwise from true north. Critical for coverage prediction and interference analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beamwidthHorizontalDegrees rdf:type rdf:Property ;
    rdfs:label 'Beamwidth Horizontal Degrees' ;
    rdfs:comment 'The horizontal beamwidth of the antenna in degrees, defining the angular coverage in the azimuth plane. Typically 65 or 90 degrees for sector antennas.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beamwidthVerticalDegrees rdf:type rdf:Property ;
    rdfs:label 'Beamwidth Vertical Degrees' ;
    rdfs:comment 'The vertical beamwidth of the antenna in degrees, defining the angular coverage in the elevation plane. Affects coverage distance and shape.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clutterType rdf:type rdf:Property ;
    rdfs:label 'Clutter Type' ;
    rdfs:comment 'The predominant terrain clutter classification within the coverage footprint. Affects propagation loss and coverage prediction accuracy.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'The statistical confidence level of the coverage prediction as a percentage (0-100). Higher values indicate greater certainty in the footprint accuracy.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:footprintCode rdf:type rdf:Property ;
    rdfs:label 'Footprint Code' ;
    rdfs:comment 'Business identifier for the coverage footprint, typically combining cell identifier, technology, and band for human-readable reference.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:footprintStatus rdf:type rdf:Property ;
    rdfs:label 'Footprint Status' ;
    rdfs:comment 'The current lifecycle status of this coverage footprint record. Active footprints are used for operational planning and customer-facing coverage maps.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'The methodology used to generate this coverage footprint: propagation_model (theoretical prediction), drive_test (field measurement), or crowdsourced_rf (aggregated device measurements).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indoorPenetrationDepthDb rdf:type rdf:Property ;
    rdfs:label 'Indoor Penetration Depth Db' ;
    rdfs:comment 'The estimated signal penetration loss in decibels for indoor environments within the coverage footprint. Used to assess indoor coverage quality.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSampleCount rdf:type rdf:Property ;
    rdfs:label 'Measurement Sample Count' ;
    rdfs:comment 'The number of RF measurement samples used to generate or validate this coverage footprint. Applicable for drive_test and crowdsourced_rf generation methods.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outdoorCoverageAreaSqKm rdf:type rdf:Property ;
    rdfs:label 'Outdoor Coverage Area Sq Km' ;
    rdfs:comment 'The total outdoor geographic area covered by this cell sector in square kilometers, calculated from the coverage polygon.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationCovered rdf:type rdf:Property ;
    rdfs:label 'Population Covered' ;
    rdfs:comment 'The estimated population count within the coverage footprint boundary. Used for network capacity planning and market analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictedRsrpDbm rdf:type rdf:Property ;
    rdfs:label 'Predicted Rsrp Dbm' ;
    rdfs:comment 'The predicted average Reference Signal Received Power at the coverage boundary in dBm. Key metric for LTE and 5G coverage quality assessment.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedSinrDb rdf:type rdf:Property ;
    rdfs:label 'Predicted Sinr Db' ;
    rdfs:comment 'The predicted Signal-to-Interference-plus-Noise Ratio at the coverage boundary in dB. Indicates expected data throughput and service quality.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propagationModelVersion rdf:type rdf:Property ;
    rdfs:label 'Propagation Model Version' ;
    rdfs:comment 'The version identifier of the propagation model or measurement methodology used to generate this footprint. Enables traceability and model comparison.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiltDegrees rdf:type rdf:Property ;
    rdfs:label 'Tilt Degrees' ;
    rdfs:comment 'The vertical tilt angle of the antenna in degrees. Negative values indicate downtilt. Affects coverage shape and interference footprint.' ;
    rdfs:domain ind:CellCoverageFootprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmitPowerDbm rdf:type rdf:Property ;
    rdfs:label 'Transmit Power Dbm' ;
    rdfs:comment 'The configured transmit power of the cell sector in dBm. Directly impacts coverage range and signal strength at the cell edge.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageAreaCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Code' ;
    rdfs:comment 'Business identifier for the coverage area, used for external reference and service qualification lookups.' ;
    rdfs:domain ind:CoverageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current lifecycle status of the coverage area. Active: currently providing service. Planned: future deployment. Decommissioned: no longer in service. Suspended: temporarily unavailable.' ;
    rdfs:domain ind:CoverageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The depth or quality tier of coverage provided: outdoor (macro cell coverage), indoor (building penetration), deep_indoor (basement/interior coverage), in_vehicle (mobile coverage inside vehicles).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedDownlinkThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Predicted Downlink Throughput Mbps' ;
    rdfs:comment 'The estimated maximum downlink data throughput in megabits per second (Mbps) achievable in this coverage area under typical load conditions.' ;
    rdfs:domain ind:CoverageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedSignalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Predicted Signal Strength Dbm' ;
    rdfs:comment 'The predicted received signal strength in decibels relative to one milliwatt (dBm) for this coverage area, derived from propagation models or drive test data. Typical range: -120 to -40 dBm.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedUplinkThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Predicted Uplink Throughput Mbps' ;
    rdfs:comment 'The estimated maximum uplink data throughput in megabits per second (Mbps) achievable in this coverage area under typical load conditions.' ;
    rdfs:domain ind:CoverageArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageAreaVersionId rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Version Id' ;
    rdfs:comment 'Unique identifier for this immutable versioned snapshot of a coverage area polygon. Primary key for the coverage area version record.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCoverageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Coverage Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that created this coverage area version. Supports audit and accountability for coverage data changes.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business or technical reason for creating this new version of the coverage area. Supports audit trails and regulatory reporting of coverage changes. Values include network expansion, cell reconfiguration, decommissioning, propagation model updates, drive test corrections, and regulatory mandates.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indoorCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Indoor Coverage Flag' ;
    rdfs:comment 'Indicates whether this coverage area version includes reliable indoor coverage. True if indoor penetration is modeled or verified; false if coverage is outdoor-only or uncertain.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilitySupportFlag rdf:type rdf:Property ;
    rdfs:label 'Mobility Support Flag' ;
    rdfs:comment 'Indicates whether this coverage area supports mobile handover and roaming. True for mobile network coverage; false for fixed wireless or stationary service areas.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Model Confidence Score' ;
    rdfs:comment 'Confidence score (0-100) representing the reliability of the coverage prediction for this version. Higher scores indicate greater certainty based on measurement density, model validation, or drive test correlation.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Predicted Throughput Mbps' ;
    rdfs:comment 'Average predicted downlink throughput in megabits per second (Mbps) achievable within this coverage area at this version. Used for service tier planning and customer expectation setting.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premisesCovered rdf:type rdf:Property ;
    rdfs:label 'Premises Covered' ;
    rdfs:comment 'Estimated number of residential and business premises within this coverage area at this version. Used for serviceable address analysis and broadband availability reporting.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'Date when this version of the coverage area became active and operationally valid. Marks the start of this version\'s validity period for regulatory and operational reporting.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Version Expiry Date' ;
    rdfs:comment 'Date when this version of the coverage area was superseded or decommissioned. Null for the current active version. Marks the end of this version\'s validity period.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionNotes rdf:type rdf:Property ;
    rdfs:label 'Version Notes' ;
    rdfs:comment 'Free-text notes or comments describing the changes, context, or special considerations for this coverage area version. Supports operational knowledge transfer and audit documentation.' ;
    rdfs:domain ind:CoverageAreaVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageGapId rdf:type rdf:Property ;
    rdfs:label 'Coverage Gap Id' ;
    rdfs:comment 'Unique identifier for the coverage gap record. Primary key.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Id' ;
    rdfs:comment 'Reference to the network planning or engineering team responsible for analyzing and remediating this coverage gap.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:customerComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Count' ;
    rdfs:comment 'Number of customer complaints or trouble tickets associated with poor coverage in this geographic area, used as supporting evidence for gap identification.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedRemediationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost Usd' ;
    rdfs:comment 'Estimated capital expenditure required to remediate the coverage gap, expressed in USD.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'The source of funding for gap remediation (e.g., internal CAPEX, government subsidy, Universal Service Fund, public-private partnership).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapIdentifier rdf:type rdf:Property ;
    rdfs:label 'Gap Identifier' ;
    rdfs:comment 'Business-facing unique identifier or code for the coverage gap, used for external reference and reporting to regulatory bodies.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapName rdf:type rdf:Property ;
    rdfs:label 'Gap Name' ;
    rdfs:comment 'Human-readable name or label for the coverage gap, typically referencing the geographic area or community affected.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapSeverity rdf:type rdf:Property ;
    rdfs:label 'Gap Severity' ;
    rdfs:comment 'Business priority classification of the coverage gap based on impact to service delivery, regulatory compliance, and customer experience.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Status' ;
    rdfs:comment 'Current lifecycle status of the coverage gap record in the remediation workflow. [ENUM-REF-CANDIDATE: identified|validated|prioritized|assigned|in_remediation|resolved|closed|deferred — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapType rdf:type rdf:Property ;
    rdfs:label 'Gap Type' ;
    rdfs:comment 'Classification of the coverage gap based on the type of service deficiency: no 4G coverage, no 5G coverage, no broadband, below minimum speed threshold, poor indoor coverage, or no emergency coverage.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'The date on which the coverage gap was first identified and recorded in the system.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identification Method' ;
    rdfs:comment 'The methodology or data source used to identify and validate the existence of the coverage gap.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Measured Throughput Mbps' ;
    rdfs:comment 'The actual measured data throughput in Mbps within the gap area, as determined by speed testing or network performance monitoring.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSignalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Minimum Signal Strength Dbm' ;
    rdfs:comment 'The minimum acceptable signal strength threshold in dBm that defines adequate coverage; values below this threshold constitute a gap.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Minimum Throughput Mbps' ;
    rdfs:comment 'The minimum acceptable data throughput in Mbps that defines adequate service quality; throughput below this threshold constitutes a gap.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Numerical priority score assigned to the coverage gap for investment planning, based on factors such as population impact, regulatory requirements, and business case.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationMethod rdf:type rdf:Property ;
    rdfs:label 'Remediation Method' ;
    rdfs:comment 'The planned or implemented technical solution for closing the coverage gap (e.g., new macro site, small cell deployment, FTTH extension, capacity upgrade).' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Status' ;
    rdfs:comment 'Current status of the remediation plan for closing this coverage gap, tracking progression from identification through resolution.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Verification Method' ;
    rdfs:comment 'The method used to verify that the coverage gap has been successfully closed (e.g., post-deployment drive test, customer feedback analysis, network KPI monitoring).' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'The planned or committed date by which the coverage gap is expected to be resolved and service restored to acceptable levels.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:universalServiceObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Universal Service Obligation Flag' ;
    rdfs:comment 'Indicates whether this coverage gap falls within an area subject to Universal Service Obligations requiring mandatory service provision.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'The date on which the coverage gap was validated through field testing or additional analysis to confirm the deficiency.' ;
    rdfs:domain ind:CoverageGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageQualificationId rdf:type rdf:Property ;
    rdfs:label 'Coverage Qualification Id' ;
    rdfs:comment 'Unique identifier for the coverage qualification check record. Primary key for the coverage qualification entity.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nearestExchangeId rdf:type rdf:Property ;
    rdfs:label 'Nearest Exchange Id' ;
    rdfs:comment 'Reference to the nearest central office or exchange facility serving the qualified location.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exchange .

ind:businessServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Business Service Flag' ;
    rdfs:comment 'Indicates whether the qualified location is eligible for business-grade service offerings with enhanced SLA commitments.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Construction Required Flag' ;
    rdfs:comment 'Indicates whether new infrastructure construction or network extension is required to serve the qualified location.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason Code' ;
    rdfs:comment 'Standardized code indicating why the location was not qualified for service, if applicable. Null if location is serviceable.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason Description' ;
    rdfs:comment 'Detailed explanation of why the location was not qualified for service, providing context for the disqualification reason code.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceToCellSiteKm rdf:type rdf:Property ;
    rdfs:label 'Distance To Cell Site Km' ;
    rdfs:comment 'Physical distance in kilometers from the qualified location to the nearest cell site, relevant for wireless coverage prediction.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceToExchangeKm rdf:type rdf:Property ;
    rdfs:label 'Distance To Exchange Km' ;
    rdfs:comment 'Physical distance in kilometers from the qualified location to the nearest exchange, relevant for copper-based services.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleProductCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Codes' ;
    rdfs:comment 'Comma-separated list of product codes or SKUs that are available for purchase at the qualified location based on technology and speed capabilities.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedConstructionCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Construction Cost' ;
    rdfs:comment 'Estimated cost in local currency for required construction or network extension work, if applicable.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedConstructionDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Construction Days' ;
    rdfs:comment 'Estimated number of calendar days required to complete construction or network extension work, if applicable.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipv6SupportFlag rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Support Flag' ;
    rdfs:comment 'Indicates whether IPv6 connectivity is supported at the qualified location.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Network Availability Percentage' ;
    rdfs:comment 'Predicted network uptime percentage for the qualified location based on historical performance data.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedDownlinkSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Predicted Downlink Speed Mbps' ;
    rdfs:comment 'Estimated maximum download speed in megabits per second that can be delivered to the location based on network modeling.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Predicted Latency Ms' ;
    rdfs:comment 'Estimated network latency in milliseconds for the qualified location, representing round-trip time for data packets.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedUplinkSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Predicted Uplink Speed Mbps' ;
    rdfs:comment 'Estimated maximum upload speed in megabits per second that can be delivered to the location based on network modeling.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTechnologyAvailable rdf:type rdf:Property ;
    rdfs:label 'Primary Technology Available' ;
    rdfs:comment 'The best or recommended network technology available at the qualified location based on performance and reliability. [ENUM-REF-CANDIDATE: ftth|5g_nr|lte|dsl|cable|fixed_wireless|satellite|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosClassAvailable rdf:type rdf:Property ;
    rdfs:label 'Qos Class Available' ;
    rdfs:comment 'Highest Quality of Service class that can be delivered at the qualified location based on network capabilities.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Timestamp' ;
    rdfs:comment 'Date and time when the coverage qualification check was completed and results were returned.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Confidence Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the reliability of the qualification result based on data quality and network modeling accuracy.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Timestamp' ;
    rdfs:comment 'Date and time when the qualification result expires and should be re-validated before service provisioning.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'Method used to perform the coverage qualification check, indicating the source and reliability of the qualification data.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes providing additional context, conditions, or special instructions related to the qualification result.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business-facing unique qualification reference number used for tracking and customer communication. Format: CQ followed by 10 digits.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Request Timestamp' ;
    rdfs:comment 'Date and time when the coverage qualification check was requested by the user or system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationResult rdf:type rdf:Property ;
    rdfs:label 'Qualification Result' ;
    rdfs:comment 'Overall outcome of the coverage qualification check indicating whether service can be delivered to the location.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current processing status of the qualification request in its lifecycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingSystem rdf:type rdf:Property ;
    rdfs:label 'Requesting System' ;
    rdfs:comment 'Source system or channel that initiated the coverage qualification request. [ENUM-REF-CANDIDATE: order_management|self_service_portal|dealer_portal|api|crm|field_sales|call_center|partner_portal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staticIpAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Static Ip Available Flag' ;
    rdfs:comment 'Indicates whether static IP address assignment is available as an option at the qualified location.' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologiesChecked rdf:type rdf:Property ;
    rdfs:label 'Technologies Checked' ;
    rdfs:comment 'Comma-separated list of network technologies evaluated during qualification (e.g., FTTH, 5G, LTE, DSL, Cable, Fixed Wireless).' ;
    rdfs:domain ind:CoverageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveTestRecordId rdf:type rdf:Property ;
    rdfs:label 'Drive Test Record Id' ;
    rdfs:comment 'Unique identifier for the drive test measurement record.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCampaignId rdf:type rdf:Property ;
    rdfs:label 'Test Campaign Id' ;
    rdfs:comment 'Reference to the parent drive test campaign under which this measurement was collected.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCampaign .

ind:testRouteId rdf:type rdf:Property ;
    rdfs:label 'Test Route Id' ;
    rdfs:comment 'Reference to the predefined route or path followed during the drive test campaign, enabling route-based analysis and repeatability.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestRoute .

ind:altitudeMeters rdf:type rdf:Property ;
    rdfs:label 'Altitude Meters' ;
    rdfs:comment 'Elevation above sea level in meters at the point of measurement, used for terrain-aware coverage modeling.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callSetupSuccessFlag rdf:type rdf:Property ;
    rdfs:label 'Call Setup Success Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether a voice call setup attempt was successful at this measurement point, used for voice service quality assessment.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cqi rdf:type rdf:Property ;
    rdfs:label 'Cqi' ;
    rdfs:comment 'A value from 0 to 15 reported by the device indicating the quality of the downlink channel, used by the network for adaptive modulation and coding.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSessionActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Data Session Active Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether an active data session was established at the time of measurement, affecting throughput and latency readings.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earfcn rdf:type rdf:Property ;
    rdfs:label 'Earfcn' ;
    rdfs:comment 'The channel number identifying the LTE carrier frequency, used for frequency planning and interference analysis.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverEventFlag rdf:type rdf:Property ;
    rdfs:label 'Handover Event Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether a cell handover event occurred at this measurement point, used to assess mobility performance.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pci rdf:type rdf:Property ;
    rdfs:label 'Pci' ;
    rdfs:comment 'The physical cell identity of the serving cell, a unique identifier within the local area used for cell identification and handover decisions.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rsrpDbm rdf:type rdf:Property ;
    rdfs:label 'Rsrp Dbm' ;
    rdfs:comment 'The average power of the reference signal received from the serving cell, measured in decibels relative to one milliwatt (dBm). Key indicator of signal strength.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rsrqDb rdf:type rdf:Property ;
    rdfs:label 'Rsrq Db' ;
    rdfs:comment 'The quality of the received reference signal measured in decibels, indicating signal quality relative to interference and noise.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rssiDbm rdf:type rdf:Property ;
    rdfs:label 'Rssi Dbm' ;
    rdfs:comment 'The total received wideband power measured in dBm, including signal, interference, and noise across the channel bandwidth.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sinrDb rdf:type rdf:Property ;
    rdfs:label 'Sinr Db' ;
    rdfs:comment 'The ratio of signal power to interference and noise power measured in decibels, critical for assessing channel quality and throughput potential.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'Vehicle or pedestrian speed in kilometers per hour at the time of measurement, used to distinguish stationary vs mobile testing conditions.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Type' ;
    rdfs:comment 'The make and model of the drive test equipment or scanner used to collect the measurement (e.g., Rohde & Schwarz ROMES, Keysight Nemo).' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputDownlinkMbps rdf:type rdf:Property ;
    rdfs:label 'Throughput Downlink Mbps' ;
    rdfs:comment 'The measured data transfer rate from the network to the test device in megabits per second, indicating actual user experience for download speeds.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputUplinkMbps rdf:type rdf:Property ;
    rdfs:label 'Throughput Uplink Mbps' ;
    rdfs:comment 'The measured data transfer rate from the test device to the network in megabits per second, indicating actual user experience for upload speeds.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'The prevailing weather conditions at the time of measurement, as weather can impact radio propagation characteristics.' ;
    rdfs:domain ind:DriveTestRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDuctStartGeoPointId rdf:type rdf:Property ;
    rdfs:label 'Primary Duct Start Geo Point Id' ;
    rdfs:comment 'Reference to the geographic point entity representing the starting endpoint of the duct route.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeoPoint .

ind:assetCondition rdf:type rdf:Property ;
    rdfs:label 'Asset Condition' ;
    rdfs:comment 'Current physical condition assessment of the duct route infrastructure based on inspection findings, used for maintenance prioritization and capital planning.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableSubductCount rdf:type rdf:Property ;
    rdfs:label 'Available Subduct Count' ;
    rdfs:comment 'Number of sub-ducts currently available for future cable installations, critical for capacity planning and network expansion.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of total duct capacity currently in use, calculated from occupied versus total sub-ducts, used for capacity planning and investment decisions.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionMethod rdf:type rdf:Property ;
    rdfs:label 'Construction Method' ;
    rdfs:comment 'Installation technique used to construct the duct route, affecting cost, disruption, and suitability for different terrain types.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthMetres rdf:type rdf:Property ;
    rdfs:label 'Depth Metres' ;
    rdfs:comment 'Average burial depth of the underground duct route measured in metres from ground surface, relevant for excavation safety and damage prevention.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ductDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Duct Diameter Mm' ;
    rdfs:comment 'Internal diameter of the primary duct measured in millimetres, determining cable capacity and pull tension limits.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ductMaterial rdf:type rdf:Property ;
    rdfs:label 'Duct Material' ;
    rdfs:comment 'Primary construction material of the duct or conduit, affecting durability, installation method, and maintenance requirements.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier used for this duct route in external systems such as network management systems (NMS), element management systems (EMS), or outside plant management systems.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisLayerReference rdf:type rdf:Property ;
    rdfs:label 'Gis Layer Reference' ;
    rdfs:comment 'Reference to the GIS layer or feature class where this duct route is represented in the enterprise spatial data system.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfSubducts rdf:type rdf:Property ;
    rdfs:label 'Number Of Subducts' ;
    rdfs:comment 'Total count of individual sub-ducts or inner ducts within the primary duct structure, each capable of housing separate cable runs.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:occupiedSubductCount rdf:type rdf:Property ;
    rdfs:label 'Occupied Subduct Count' ;
    rdfs:comment 'Number of sub-ducts currently occupied by installed cables or other telecommunications infrastructure.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitReference rdf:type rdf:Property ;
    rdfs:label 'Permit Reference' ;
    rdfs:comment 'Reference number or identifier of the construction permit, excavation permit, or right-of-way permit authorizing the installation and maintenance of the duct route.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Estimate' ;
    rdfs:comment 'Estimated cost to replace the entire duct route with equivalent infrastructure, used for asset valuation and insurance purposes.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roadAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Road Authority Reference' ;
    rdfs:comment 'Identifier or name of the governmental road authority or public works department with jurisdiction over the right-of-way where the duct route is installed.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Externally-known unique business identifier for the duct route, used in network planning documentation, permit applications, and field operations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or designation of the duct route, typically referencing street names, landmarks, or geographic endpoints (e.g., \'Main St to Oak Ave Underground\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePriority rdf:type rdf:Property ;
    rdfs:label 'Route Priority' ;
    rdfs:comment 'Business priority classification of the duct route based on the criticality of services it supports, used for maintenance scheduling and emergency response.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle state of the duct route in the outside plant infrastructure network.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the physical pathway method used for the telecommunications infrastructure route.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLengthMetres rdf:type rdf:Property ;
    rdfs:label 'Total Length Metres' ;
    rdfs:comment 'Total physical length of the duct route measured in metres, used for capacity planning, cost estimation, and network design.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Traffic Impact Level' ;
    rdfs:comment 'Assessment of the impact on vehicular or pedestrian traffic if maintenance or repair work is required on this route, used for work scheduling and permit coordination.' ;
    rdfs:domain ind:DuctRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualOpex rdf:type rdf:Property ;
    rdfs:label 'Annual Opex' ;
    rdfs:comment 'Estimated annual Operational Expenditure (OPEX) for maintaining and operating this exchange facility, including power, maintenance, and support costs. Used for profitability analysis and budget planning.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availablePorts rdf:type rdf:Property ;
    rdfs:label 'Available Ports' ;
    rdfs:comment 'Number of ports currently available for new customer connections. Calculated as port_capacity minus currently allocated ports. Used for real-time service qualification.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backboneConnectionType rdf:type rdf:Property ;
    rdfs:label 'Backbone Connection Type' ;
    rdfs:comment 'Type of backhaul or backbone connectivity linking this exchange to the core network. Determines reliability, latency, and bandwidth capabilities.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Coverage Radius Km' ;
    rdfs:comment 'Approximate service coverage radius from the exchange facility in kilometers. Represents the maximum distance at which acceptable service quality can be maintained for the primary technology served.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentConnectedPremises rdf:type rdf:Property ;
    rdfs:label 'Current Connected Premises' ;
    rdfs:comment 'Number of premises currently connected and receiving active service from this exchange. Used to calculate utilization rate and available capacity.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Model number or designation of the primary exchange equipment installed at this facility. Used for technical support, firmware updates, and capacity planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Status' ;
    rdfs:comment 'Current operational lifecycle status of the exchange facility. Determines service availability and eligibility for new customer connections.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the exchange facility based on its function in the network topology. Determines the service delivery model and technology capabilities.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'Total Capital Expenditure (CAPEX) incurred for the initial installation and commissioning of the exchange facility. Used for Return on Investment (ROI) analysis and asset valuation.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxServiceablePremises rdf:type rdf:Property ;
    rdfs:label 'Max Serviceable Premises' ;
    rdfs:comment 'Total number of residential and business premises that can theoretically be served from this exchange based on its capacity and coverage footprint. Used for network capacity planning and market sizing.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nbnRolloutFlag rdf:type rdf:Property ;
    rdfs:label 'Nbn Rollout Flag' ;
    rdfs:comment 'Indicates whether this exchange is part of a national broadband network rollout program (e.g., NBN in Australia, FTTP in UK). True if the exchange is designated for fiber upgrade or replacement under a government-mandated program.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the telecommunications operator or service provider that owns and operates this exchange facility.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCapacity rdf:type rdf:Property ;
    rdfs:label 'Port Capacity' ;
    rdfs:comment 'Total number of physical or logical ports available at this exchange for customer connections. Represents the hard capacity limit for simultaneous active services.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerBackupType rdf:type rdf:Property ;
    rdfs:label 'Power Backup Type' ;
    rdfs:comment 'Type of backup power system installed at the exchange facility to ensure service continuity during power outages. Critical for Service Level Agreement (SLA) compliance and disaster recovery planning.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyServed rdf:type rdf:Property ;
    rdfs:label 'Technology Served' ;
    rdfs:comment 'Primary broadband access technology delivered from this exchange facility. Determines service speed capabilities and customer eligibility for specific product offerings.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesaleAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Wholesale Access Flag' ;
    rdfs:comment 'Indicates whether this exchange facility is available for wholesale access by Mobile Virtual Network Operators (MVNOs) or other service providers. True if the exchange supports unbundled local loop or bitstream access.' ;
    rdfs:domain ind:Exchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoBoundaryId rdf:type rdf:Property ;
    rdfs:label 'Geo Boundary Id' ;
    rdfs:comment 'Unique identifier for the geographic boundary record. Primary key.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentBoundaryGeoBoundaryId rdf:type rdf:Property ;
    rdfs:label 'Parent Boundary Geo Boundary Id' ;
    rdfs:comment 'Reference to the parent boundary in a hierarchical boundary structure (e.g., SA2 parent of SA1, state parent of LGA). Null for top-level boundaries. Enables hierarchical rollup for reporting and aggregation.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeoBoundary .

ind:areaSqKm rdf:type rdf:Property ;
    rdfs:label 'Area Sq Km' ;
    rdfs:comment 'Total area of the boundary in square kilometers. Used for density calculations, coverage planning, and capacity modeling.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Boundary Identifier' ;
    rdfs:comment 'External business identifier for the boundary as assigned by the source authority (e.g., ABS region code, census tract FIPS code, postcode, LGA code). Used for cross-system integration and regulatory reporting.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryName rdf:type rdf:Property ;
    rdfs:label 'Boundary Name' ;
    rdfs:comment 'Human-readable name of the geographic boundary (e.g., \'Sydney Central Exchange\', \'New South Wales\', \'Greater London\', \'Harris County\').' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryStatus rdf:type rdf:Property ;
    rdfs:label 'Boundary Status' ;
    rdfs:comment 'Current lifecycle status of the boundary. Active: currently in use for planning and operations; inactive: temporarily not in use; proposed: planned but not yet effective; deprecated: scheduled for retirement; superseded: replaced by a newer boundary version.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryType rdf:type rdf:Property ;
    rdfs:label 'Boundary Type' ;
    rdfs:comment 'Classification of the boundary type. Exchange: telecommunications exchange boundary; LGA: Local Government Area; SA1/SA2/SA3/SA4: Australian Statistical Geography Standard levels; census_tract: US Census tract; state/territory: administrative region; country: national boundary; planning_zone: operator-defined planning area; coverage_zone: network coverage footprint; service_area: service delivery territory. [ENUM-REF-CANDIDATE: exchange|lga|postcode|sa1|sa2|sa3|sa4|census_tract|state|territory|country|planning_zone|coverage_zone|service_area — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCount rdf:type rdf:Property ;
    rdfs:label 'Business Count' ;
    rdfs:comment 'Estimated number of business establishments within the boundary. Used for enterprise sales targeting, B2B service planning, and commercial market analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coordinateReferenceSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate Reference System' ;
    rdfs:comment 'Spatial reference system used for the boundary geometry (e.g., \'EPSG:4326\' for WGS84, \'EPSG:3857\' for Web Mercator). Critical for accurate spatial operations and coordinate transformations.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageQualityScore rdf:type rdf:Property ;
    rdfs:label 'Coverage Quality Score' ;
    rdfs:comment 'Aggregate quality score for network coverage within the boundary (0-100 scale). Derived from signal strength measurements, QoS metrics, and customer experience data. Used for network investment prioritization and SLA reporting.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Type of network coverage within the boundary (e.g., \'5G NR\', \'LTE\', \'FTTH\', \'GPON\', \'HFC\', \'Fixed Wireless\'). Pipe-separated list if multiple technologies are deployed. Used for coverage mapping and service eligibility determination. [ENUM-REF-CANDIDATE: 5g_nr|lte|3g|ftth|fttc|fttb|gpon|hfc|dsl|fixed_wireless|satellite|no_coverage — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryGeojson rdf:type rdf:Property ;
    rdfs:label 'Geometry Geojson' ;
    rdfs:comment 'Spatial geometry of the boundary represented in GeoJSON format. Provides interoperability with web mapping applications and modern geospatial APIs.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Estimated or census-based number of households within the boundary. Used for FTTH rollout planning, broadband penetration analysis, and market opportunity assessment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perimeterKm rdf:type rdf:Property ;
    rdfs:label 'Perimeter Km' ;
    rdfs:comment 'Total perimeter length of the boundary in kilometers. Used for edge analysis and boundary adjacency calculations.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationCount rdf:type rdf:Property ;
    rdfs:label 'Population Count' ;
    rdfs:comment 'Estimated or census-based population within the boundary. Used for market sizing, capacity planning, and ARPU calculations. Sourced from census data or third-party demographics.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryZone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Zone' ;
    rdfs:comment 'Regulatory or licensing zone designation applicable to this boundary (e.g., \'FCC License Area 23\', \'Ofcom Geographic Market 4\', \'ACMA Spectrum Zone Sydney\'). Used for compliance reporting and spectrum management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDataset rdf:type rdf:Property ;
    rdfs:label 'Source Dataset' ;
    rdfs:comment 'Name and version of the source dataset from which this boundary was derived (e.g., \'ASGS 2021\', \'TIGER/Line 2023\', \'Operator Network Planning Zones v3.2\'). Used for data lineage and quality assessment.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'State, province, or territory code within the country (e.g., \'NSW\', \'CA\', \'ON\'). Used for regional reporting and state-level regulatory compliance.' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanRuralClassification rdf:type rdf:Property ;
    rdfs:label 'Urban Rural Classification' ;
    rdfs:comment 'Classification of the boundary as urban, suburban, rural, or remote. Used for network planning, service differentiation, and regulatory compliance (e.g., universal service obligations).' ;
    rdfs:domain ind:GeoBoundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkSegmentId rdf:type rdf:Property ;
    rdfs:label 'Network Segment Id' ;
    rdfs:comment 'Foreign key reference to the logical network segment or topology element that this geographic point belongs to. Supports network planning, routing, and topology management use cases.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:captureDate rdf:type rdf:Property ;
    rdfs:label 'Capture Date' ;
    rdfs:comment 'Date when the geographic coordinates were captured or surveyed. Provides temporal context for the spatial data and supports data currency assessments for network planning and maintenance activities.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Method or technique used to capture the geographic coordinates of the point. Indicates the data collection approach and influences the expected accuracy and reliability of the spatial data. [ENUM-REF-CANDIDATE: gps_survey|aerial_photogrammetry|digitized|interpolated|lidar|total_station|mobile_mapping — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Classification of natural hazard risks associated with the geographic point location. Used for risk assessment, business continuity planning, and infrastructure resilience design.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointDescription rdf:type rdf:Property ;
    rdfs:label 'Point Description' ;
    rdfs:comment 'Detailed textual description of the geographic point, including contextual information about its location, surroundings, access instructions, or special characteristics relevant to field operations and network planning.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointIdentifier rdf:type rdf:Property ;
    rdfs:label 'Point Identifier' ;
    rdfs:comment 'Human-readable business identifier for the geographic point, used for external reference and operational communication (e.g., TOWER-001, CAB-NW-045, MH-CENTRAL-12).' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointName rdf:type rdf:Property ;
    rdfs:label 'Point Name' ;
    rdfs:comment 'Descriptive name or label for the geographic point, used for human-readable identification in operational systems and field documentation (e.g., \'Main Street Cabinet\', \'Downtown Tower Base\', \'Customer Entry Point - Building A\').' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointStatus rdf:type rdf:Property ;
    rdfs:label 'Point Status' ;
    rdfs:comment 'Current lifecycle status of the geographic point within network planning and operations. Indicates whether the point is operational, planned for future deployment, or retired from service.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointType rdf:type rdf:Property ;
    rdfs:label 'Point Type' ;
    rdfs:comment 'Classification of the geographic point based on its telecommunications infrastructure role. Defines the functional purpose of the spatial location within the network topology. [ENUM-REF-CANDIDATE: tower_base|cabinet|manhole|pit|antenna|premise_entry|splice_point|ont_drop|olt_location|bng_site — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorReference rdf:type rdf:Property ;
    rdfs:label 'Surveyor Reference' ;
    rdfs:comment 'Reference identifier for the surveyor, survey crew, or survey organization that captured the geographic coordinates. Enables traceability and quality assurance for spatial data collection activities.' ;
    rdfs:domain ind:GeoPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Local government zoning or land use classification for the geographic point location. Impacts permitting requirements, construction restrictions, and regulatory compliance for telecommunications infrastructure deployment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentZoneGeographicZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Zone Geographic Zone Id' ;
    rdfs:comment 'Foreign key reference to the parent geographic zone in a hierarchical zone structure. Enables multi-level zone aggregation (e.g., sub-zones rolling up to regional zones). Nullable for top-level zones.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicZone .

ind:applicableProductTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Types' ;
    rdfs:comment 'Comma-separated list of product or service types to which this zone applies (e.g., broadband, mobile, IPTV, VoIP). Used by product catalog and pricing engines to determine zone-based eligibility and tariff application.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageIncomeLevel rdf:type rdf:Property ;
    rdfs:label 'Average Income Level' ;
    rdfs:comment 'Socioeconomic classification of the geographic zone based on average household income. Used for market segmentation, product targeting, Customer Lifetime Value (CLTV) modeling, and affordability-based pricing strategies.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackSpotProgrammeFlag rdf:type rdf:Property ;
    rdfs:label 'Black Spot Programme Flag' ;
    rdfs:comment 'Indicates whether this geographic zone is designated as a mobile coverage black spot eligible for government-funded infrastructure programmes. True if the zone qualifies for black spot funding; false otherwise. Used for Capital Expenditure (CAPEX) planning and regulatory reporting.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessPremisesCount rdf:type rdf:Property ;
    rdfs:label 'Business Premises Count' ;
    rdfs:comment 'Estimated number of commercial and business premises within the geographic zone. Used for enterprise service planning, Business-to-Business (B2B) market sizing, and Software-Defined Wide Area Network (SD-WAN) opportunity assessment.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure within this geographic zone. High-intensity zones have multiple operators and aggressive pricing; monopoly zones have single-provider dominance. Used for churn risk modeling, pricing strategy, and market share analysis.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Dispatch Radius Km' ;
    rdfs:comment 'Maximum distance in kilometers from the nearest service depot or Point of Presence (POP) for field technician dispatch to this geographic zone. Used by Workforce Management (WFM) systems for route optimization and Mean Time to Repair (MTTR) estimation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyServicesRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Routing Code' ;
    rdfs:comment 'Code used to route emergency calls (E911/E112) to the appropriate Public Safety Answering Point (PSAP) for this geographic zone. Critical for Voice over Long-Term Evolution (VoLTE) and IP Multimedia Subsystem (IMS) emergency call handling.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Reference' ;
    rdfs:comment 'Reference identifier for the franchise or operating license agreement that grants the operator rights to provide services within this geographic zone. Used for regulatory compliance tracking and contract management.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCoverageType rdf:type rdf:Property ;
    rdfs:label 'Network Coverage Type' ;
    rdfs:comment 'Predominant network technology available within this geographic zone. Used for service eligibility determination, product catalog filtering, and network modernization planning. 5G = 5G New Radio; LTE = Long-Term Evolution; FTTH = Fiber to the Home; FTTC = Fiber to the Cabinet; DSL = Digital Subscriber Line. [ENUM-REF-CANDIDATE: 5G|LTE|3G|2G|FTTH|FTTC|DSL|satellite|no_coverage — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Reference' ;
    rdfs:comment 'Identifier or name of the regulatory authority that governs this zone (e.g., FCC, Ofcom, BEREC). Used for compliance reporting, spectrum licensing, and Universal Service Obligation (USO) tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrumLicenseReference rdf:type rdf:Property ;
    rdfs:label 'Spectrum License Reference' ;
    rdfs:comment 'Reference identifier for the spectrum license or frequency allocation applicable to this geographic zone. Used for Radio Access Network (RAN) planning, 5G New Radio (5G NR) deployment, and regulatory compliance tracking.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Uso Eligible Flag' ;
    rdfs:comment 'Indicates whether this geographic zone qualifies for Universal Service Obligation (USO) funding or subsidies. True for underserved rural or remote areas; false for commercially viable zones. Used for regulatory reporting and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Unique business identifier code for the geographic zone used in operational systems, pricing engines, and regulatory reporting. Typically alphanumeric with operator-specific format.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the geographic zone for display in customer-facing applications, billing systems, and operational dashboards.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the geographic zone. Active zones are in operational use; pending zones are approved but not yet effective; planned zones are under design; deprecated zones are phased out but retained for historical reference; suspended zones are temporarily disabled; inactive zones are permanently retired.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneTier rdf:type rdf:Property ;
    rdfs:label 'Zone Tier' ;
    rdfs:comment 'Hierarchical classification of the zone for pricing differentiation and service level stratification. Metro zones typically have premium pricing and highest service levels; remote zones may qualify for Universal Service Obligation (USO) subsidies and have extended SLA (Service Level Agreement) response times.' ;
    rdfs:domain ind:GeographicZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the geographic zone by its primary business purpose. Pricing zones drive differential tariffs; regulatory zones align with compliance boundaries; roaming zones define partner network areas; emergency services zones map to E911/E112 routing; disaster recovery zones support business continuity; spectrum zones track licensed frequency allocations. [ENUM-REF-CANDIDATE: pricing_zone|regulatory_zone|roaming_zone|emergency_services_zone|disaster_recovery_zone|spectrum_zone|universal_service_zone|black_spot_zone — promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureCorridorId rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Corridor Id' ;
    rdfs:comment 'Unique identifier for the telecommunications infrastructure corridor. Primary key for the infrastructure corridor master record.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualOpexUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Usd' ;
    rdfs:comment 'Estimated annual operational expenditure for maintaining and operating the corridor, measured in United States Dollars. Includes maintenance, inspections, lease payments, and regulatory compliance costs.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupRouteAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Route Available Flag' ;
    rdfs:comment 'Indicates whether an alternative backup route exists that can carry traffic if this corridor fails. True for corridors with diverse route protection; false for single-path corridors. Critical for network resilience assessment.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityBandwidthGbps rdf:type rdf:Property ;
    rdfs:label 'Capacity Bandwidth Gbps' ;
    rdfs:comment 'Total designed bandwidth capacity of the corridor measured in Gigabits per second, applicable to microwave and other non-fiber corridors. Represents aggregate throughput capability. Null for fiber corridors where capacity is measured in fiber count.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityFiberCount rdf:type rdf:Property ;
    rdfs:label 'Capacity Fiber Count' ;
    rdfs:comment 'Total number of fiber strands available in the corridor for fiber-based corridors (long_haul_fiber, submarine_cable). Null for non-fiber corridors. Represents total capacity for wavelength provisioning and service delivery.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corridorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Corridor Identifier' ;
    rdfs:comment 'Externally-known unique business identifier or code for the corridor, used for operational reference and inter-system communication.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorName rdf:type rdf:Property ;
    rdfs:label 'Corridor Name' ;
    rdfs:comment 'Human-readable name of the infrastructure corridor, typically reflecting geographic endpoints or route designation (e.g., \'New York-Boston Fiber Route\', \'Trans-Pacific Cable Landing Corridor\').' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorOwner rdf:type rdf:Property ;
    rdfs:label 'Corridor Owner' ;
    rdfs:comment 'Legal entity or organization that owns the physical infrastructure corridor. May be the telecommunications operator, a third-party infrastructure provider, utility company, or government entity.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorStatus rdf:type rdf:Property ;
    rdfs:label 'Corridor Status' ;
    rdfs:comment 'Current operational status of the corridor in its lifecycle. Active corridors are in service; planned corridors are approved but not yet built; under_construction corridors are being deployed; decommissioned corridors are retired; suspended corridors are temporarily out of service; maintenance corridors are undergoing scheduled work.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorType rdf:type rdf:Property ;
    rdfs:label 'Corridor Type' ;
    rdfs:comment 'Classification of the infrastructure corridor based on the primary transport medium and deployment method. Determines planning, permitting, and operational considerations.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endLocationReference rdf:type rdf:Property ;
    rdfs:label 'End Location Reference' ;
    rdfs:comment 'Reference identifier or name for the ending point of the corridor, typically a major network node, Point of Presence (POP), cable landing station, or exchange location.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Installation Cost Usd' ;
    rdfs:comment 'Total capital expenditure (CAPEX) for constructing and commissioning the corridor, measured in United States Dollars. Includes materials, labor, permitting, and right-of-way acquisition costs. Used for ROI analysis and asset valuation.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interconnectPointsCount rdf:type rdf:Property ;
    rdfs:label 'Interconnect Points Count' ;
    rdfs:comment 'Number of intermediate interconnection points, splice points, or access nodes along the corridor where other network segments can connect. Indicates flexibility for network expansion and service delivery.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iruHolder rdf:type rdf:Property ;
    rdfs:label 'Iru Holder' ;
    rdfs:comment 'Entity holding the Indefeasible Right of Use for the corridor, granting long-term exclusive usage rights without ownership. Common in submarine cable and long-haul fiber arrangements. Null if corridor is fully owned and operated.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitAuthority rdf:type rdf:Property ;
    rdfs:label 'Permit Authority' ;
    rdfs:comment 'Government agency, regulatory body, or authority responsible for issuing construction and operational permits for the corridor. Critical for compliance tracking and regulatory reporting.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Date when the current construction or operational permit for the corridor expires. Null for corridors with perpetual permits. Used for compliance tracking and renewal planning.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protectionType rdf:type rdf:Property ;
    rdfs:label 'Protection Type' ;
    rdfs:comment 'Network protection and redundancy strategy for the corridor. Unprotected corridors have no backup; ring_protected corridors are part of a self-healing ring topology; diverse_route corridors have physically separate backup paths; mesh_protected corridors have multiple redundant paths; dual_homing corridors connect to multiple network nodes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightOfWayType rdf:type rdf:Property ;
    rdfs:label 'Right Of Way Type' ;
    rdfs:comment 'Legal arrangement governing the right to construct and maintain infrastructure along the corridor path. Owned indicates full property ownership; leased indicates rental agreement; easement indicates legal right to use another\'s property; shared_utility indicates co-location with utility infrastructure; public_right_of_way indicates use of public land; licensed indicates regulatory permission.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDiversityGroup rdf:type rdf:Property ;
    rdfs:label 'Route Diversity Group' ;
    rdfs:comment 'Identifier for the route diversity group or bundle to which this corridor belongs. Corridors in the same group serve similar endpoints and are evaluated together for diversity analysis and risk assessment.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seismicRiskZone rdf:type rdf:Property ;
    rdfs:label 'Seismic Risk Zone' ;
    rdfs:comment 'Seismic activity risk classification for the corridor route. High-risk zones require enhanced structural design and more frequent inspections. Critical for submarine cables and long-haul fiber in geologically active regions.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocationReference rdf:type rdf:Property ;
    rdfs:label 'Start Location Reference' ;
    rdfs:comment 'Reference identifier or name for the starting point of the corridor, typically a major network node, Point of Presence (POP), cable landing station, or exchange location.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportanceFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Flag' ;
    rdfs:comment 'Indicates whether this corridor is designated as strategically important for the network backbone, critical infrastructure, or national security. True for corridors that are essential for network resilience and business continuity.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalLengthKm rdf:type rdf:Property ;
    rdfs:label 'Total Length Km' ;
    rdfs:comment 'Total physical length of the infrastructure corridor measured in kilometers, representing the end-to-end distance along the route. Critical for capacity planning, cost estimation, and network design.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherExposureLevel rdf:type rdf:Property ;
    rdfs:label 'Weather Exposure Level' ;
    rdfs:comment 'Classification of the corridor\'s exposure to severe weather events (hurricanes, floods, ice storms, extreme temperatures). Influences design specifications, maintenance frequency, and disaster recovery planning.' ;
    rdfs:domain ind:InfrastructureCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current validation and operational status of the address record (e.g., verified, unverified, invalid, pending validation, deprecated).' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Official or common name of the building, tower, or complex where the address is located.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpid rdf:type rdf:Property ;
    rdfs:label 'Dpid' ;
    rdfs:comment 'Australia Post Delivery Point Identifier - unique 8-digit identifier assigned to each delivery point in Australia. Used for precise mail delivery routing.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiveGCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Five G Coverage Flag' ;
    rdfs:comment 'Boolean indicator of whether 5G New Radio (NR) wireless coverage is available at this address. Used for next-generation mobile service qualification.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor or level number within a multi-story building. May include basement (B), ground (G), mezzanine (M), or penthouse (PH) designations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingStatus rdf:type rdf:Property ;
    rdfs:label 'Geocoding Status' ;
    rdfs:comment 'Status of geocoding process indicating whether latitude and longitude coordinates have been successfully assigned and the precision level achieved.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gnafPid rdf:type rdf:Property ;
    rdfs:label 'Gnaf Pid' ;
    rdfs:comment 'Persistent identifier from Australia\'s Geocoded National Address File (GNAF). Provides stable reference to address records across systems. Applicable to Australian addresses.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Validation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent address validation or verification process. Used to track data freshness and trigger re-validation workflows.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locality rdf:type rdf:Property ;
    rdfs:label 'Locality' ;
    rdfs:comment 'Suburb, neighborhood, district, or locality name. Represents the local area within a larger city or municipality.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizationMethod rdf:type rdf:Property ;
    rdfs:label 'Standardization Method' ;
    rdfs:comment 'Method or service used to standardize and validate the address (e.g., manual entry, USPS API, Google Maps API, Australia Post, Royal Mail). Used for data quality tracking.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetDirection rdf:type rdf:Property ;
    rdfs:label 'Street Direction' ;
    rdfs:comment 'Directional prefix or suffix for the street name (e.g., North, South, East, West, Northeast, Northwest, Southeast, Southwest). [ENUM-REF-CANDIDATE: N|S|E|W|NE|NW|SE|SW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetName rdf:type rdf:Property ;
    rdfs:label 'Street Name' ;
    rdfs:comment 'Name of the street, road, avenue, or thoroughfare where the address is located.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetNumber rdf:type rdf:Property ;
    rdfs:label 'Street Number' ;
    rdfs:comment 'Numeric or alphanumeric identifier for the building or property on the street. May include suffixes like 123A or 45-47.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetType rdf:type rdf:Property ;
    rdfs:label 'Street Type' ;
    rdfs:comment 'Classification of the thoroughfare type (e.g., Street, Avenue, Road, Boulevard, Lane, Drive, Court, Place). [ENUM-REF-CANDIDATE: Street|Avenue|Road|Boulevard|Lane|Drive|Court|Place|Way|Terrace|Circle|Crescent|Highway|Parkway — promote to reference product]' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Specific unit, apartment, suite, or office number within a multi-tenant building or complex.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uprn rdf:type rdf:Property ;
    rdfs:label 'Uprn' ;
    rdfs:comment 'Unique Property Reference Number assigned by Ordnance Survey in the United Kingdom. Provides unique identifier for every addressable location in the UK.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Business purpose classification for the address within telecommunications operations (e.g., customer service address, installation address, billing address, network infrastructure site, office location).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uspsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Usps Validation Status' ;
    rdfs:comment 'Validation status from USPS address verification service indicating whether the address matches USPS delivery records. Applicable to USA addresses only.' ;
    rdfs:domain ind:LocationAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeEventId rdf:type rdf:Property ;
    rdfs:label 'Change Event Id' ;
    rdfs:comment 'Unique identifier for each location master data change event. Primary key for the location change event audit trail.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'The user identifier of the data steward or authorized personnel who approved or rejected the location data change. Null for pending or auto-approved changes. Required for governance and compliance audit trails.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryChangeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Employee Id' ;
    rdfs:comment 'The user identifier or system account that executed the location data change. Captures human operator for manual changes or system service account for automated changes. Required for audit trail and accountability.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rollbackReferenceEventId rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference Event Id' ;
    rdfs:comment 'The location_change_event_id of the original change event that is being rolled back or reversed by this change. Null for non-rollback changes. Enables traceability of correction chains.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeEvent .

ind:changeNotes rdf:type rdf:Property ;
    rdfs:label 'Change Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the operator or system regarding the location data change. Captures additional context, justification, or special handling instructions not covered by structured fields.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason or trigger for the location data change. Examples include address correction, coverage expansion, site decommission, regulatory boundary update, or data quality remediation.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSource rdf:type rdf:Property ;
    rdfs:label 'Change Source' ;
    rdfs:comment 'The origin or mechanism that initiated the location data change. Distinguishes between automated system processes, manual operator corrections, field survey updates, authoritative source updates, and bulk data imports.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'The precise date and time when the location data change was committed to the master data repository. Represents the business event time of the modification in ISO 8601 format with timezone.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changedFieldName rdf:type rdf:Property ;
    rdfs:label 'Changed Field Name' ;
    rdfs:comment 'The specific attribute or field name within the location entity that was modified. Captures the column-level granularity of the change for precise audit trail tracking.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingConfidence rdf:type rdf:Property ;
    rdfs:label 'Geocoding Confidence' ;
    rdfs:comment 'Confidence level percentage for geocoded location coordinates when the change involves address or geographic data. Ranges from 0.00 to 100.00. Null for non-geographic changes. Indicates reliability of latitude/longitude assignments.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationEntityReference rdf:type rdf:Property ;
    rdfs:label 'Location Entity Reference' ;
    rdfs:comment 'The unique identifier of the specific location entity record that was modified. References the primary key of the corresponding location master table based on location_entity_type.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationEntityType rdf:type rdf:Property ;
    rdfs:label 'Location Entity Type' ;
    rdfs:comment 'The type of location entity that was changed. Categorizes the master data record type within the location domain hierarchy.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The updated value of the changed field after the modification was applied. Stored as string representation to accommodate all data types. Null for decommission operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oldValue rdf:type rdf:Property ;
    rdfs:label 'Old Value' ;
    rdfs:comment 'The previous value of the changed field before the modification was applied. Stored as string representation to accommodate all data types. Null for create operations.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this change event represents a rollback or reversal of a previous location data modification. True when the change undoes a prior change due to error correction or business decision reversal.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The unique transaction or batch identifier from the source system that generated this change event. Enables correlation of multiple related changes within a single business transaction or bulk update operation.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Detailed error or warning message generated by data quality validation rules when the location data change failed validation checks. Provides diagnostic information for data stewards to remediate quality issues.' ;
    rdfs:domain ind:ChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the location hierarchy relationship record. Primary key for the location hierarchy association entity.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAdministrativeRegionId rdf:type rdf:Property ;
    rdfs:label 'Parent Administrative Region Id' ;
    rdfs:comment 'Foreign key linking to location.administrative_region. Business justification: Administrative regions are inherently hierarchical (country → state → city). Administrative_region already has parent_region_id for same-type hierarchies. Location_hierarchy enables cross-type hierarc' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdministrativeRegion .

ind:parentGeoBoundaryId rdf:type rdf:Property ;
    rdfs:label 'Parent Geo Boundary Id' ;
    rdfs:comment 'Foreign key linking to location.geo_boundary. Business justification: Geo boundaries have hierarchical relationships (geo_boundary already has parent_boundary_id for same-type hierarchies). Location_hierarchy enables cross-type hierarchies (e.g., administrative_region →' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeoBoundary .

ind:parentGeographicZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Geographic Zone Id' ;
    rdfs:comment 'Foreign key linking to location.geographic_zone. Business justification: Geographic zones have parent-child relationships (geographic_zone already has parent_zone_id for same-type hierarchies). Location_hierarchy enables cross-type hierarchies (e.g., service_territory → ge' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeographicZone .

ind:parentLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Site Id' ;
    rdfs:comment 'Foreign key linking to location.location_site. Business justification: Location hierarchy is a polymorphic association product that links various location entities in parent-child relationships. When parent_location_type = \'site\', the parent_location_id references a loca' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:parentPremiseId rdf:type rdf:Property ;
    rdfs:label 'Parent Premise Id' ;
    rdfs:comment 'Foreign key linking to location.premise. Business justification: Premises can be hierarchical (building → unit). Premise already has mdu_parent_premise_id for MDU-specific hierarchies. Location_hierarchy enables broader cross-type hierarchies (e.g., mdu_building → ' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:parentServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Territory Id' ;
    rdfs:comment 'Foreign key linking to location.service_territory. Business justification: Service territories have explicit hierarchical relationships (service_territory already has parent_territory_id for same-type hierarchies). Location_hierarchy enables CROSS-TYPE hierarchies (e.g., adm' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:childLocationType rdf:type rdf:Property ;
    rdfs:label 'Child Location Type' ;
    rdfs:comment 'Classification of the child location entity in the hierarchy. Defines the geographic or operational category of the child node. [ENUM-REF-CANDIDATE: administrative_region|geo_boundary|service_territory|exchange|site|premise|coverage_area — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageOverlapFlag rdf:type rdf:Property ;
    rdfs:label 'Coverage Overlap Flag' ;
    rdfs:comment 'Boolean indicator identifying whether the child location coverage area overlaps with sibling locations under the same parent. Used for network planning and coverage analysis to identify areas with redundant or overlapping service territories.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depthLevel rdf:type rdf:Property ;
    rdfs:label 'Depth Level' ;
    rdfs:comment 'Numeric indicator of the depth position in the location hierarchy tree. Level 0 represents the root (typically country), with each subsequent level representing a deeper geographic granularity. Used for roll-up queries and traversal optimization.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distanceFromParentKm rdf:type rdf:Property ;
    rdfs:label 'Distance From Parent Km' ;
    rdfs:comment 'Geographic distance in kilometers between the centroid of the child location and the centroid of the parent location. Used for network latency estimation, fiber route planning, and Operational Expenditure (OPEX) modeling for field service dispatch.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Boolean indicator identifying whether this relationship represents the primary or canonical hierarchical path for the child location. A location may participate in multiple hierarchies but typically has one primary path for default reporting and navigation.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkPlanningFlag rdf:type rdf:Property ;
    rdfs:label 'Network Planning Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this hierarchical relationship is used for network infrastructure planning, Radio Access Network (RAN) design, capacity forecasting, and Capital Expenditure (CAPEX) allocation decisions.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentLocationType rdf:type rdf:Property ;
    rdfs:label 'Parent Location Type' ;
    rdfs:comment 'Classification of the parent location entity in the hierarchy. Defines the geographic or operational category of the parent node. [ENUM-REF-CANDIDATE: country|administrative_region|geo_boundary|service_territory|exchange|site|premise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:path rdf:type rdf:Property ;
    rdfs:label 'Path' ;
    rdfs:comment 'Materialized path representation of the full hierarchical lineage from root to child location. Stored as a delimited string of location identifiers enabling efficient ancestor and descendant queries without recursive joins. Format example: /1/45/892/3421.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNotes rdf:type rdf:Property ;
    rdfs:label 'Relationship Notes' ;
    rdfs:comment 'Free-text field capturing additional context, exceptions, or special conditions related to this hierarchical relationship. Used to document boundary disputes, temporary reassignments, or operational constraints affecting the parent-child association.' ;
    rdfs:domain ind:Hierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this hierarchical relationship is used for service provisioning, activation workflows, Order Management and Fulfillment processes, and Customer Premises Equipment (CPE) deployment planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceCodeId rdf:type rdf:Property ;
    rdfs:label 'Reference Code Id' ;
    rdfs:comment 'Unique identifier for the location reference code record. Primary key for the location reference code master table.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReferenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reference Employee Id' ;
    rdfs:comment 'The identifier of the user or system account that last modified this reference code record. Supports accountability and audit trail for reference data governance. May reference an enterprise identity management system or data stewardship platform.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alternateCodeValue rdf:type rdf:Property ;
    rdfs:label 'Alternate Code Value' ;
    rdfs:comment 'An alternative identifier or legacy code value used in external systems, partner interfaces, or historical data. Supports cross-system mapping and data migration scenarios where multiple code schemes must be reconciled (e.g., legacy BSS system codes, partner MVNO codes, regulatory reporting codes).' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeDescription rdf:type rdf:Property ;
    rdfs:label 'Code Description' ;
    rdfs:comment 'Detailed business definition and usage guidance for this reference code. Explains the semantic meaning, business rules for assignment, and any special considerations or constraints. Provides context for data stewards and business users to ensure consistent application across the enterprise.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeLabel rdf:type rdf:Property ;
    rdfs:label 'Code Label' ;
    rdfs:comment 'The human-readable display label for this reference code. Used in user interfaces, reports, and business communications (e.g., \'Residential\' for code value \'RES\', \'Multi-Dwelling Unit\' for \'MDU\', \'Cell Tower Site\' for \'CELL_TOWER\').' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeSetName rdf:type rdf:Property ;
    rdfs:label 'Code Set Name' ;
    rdfs:comment 'The classification category or taxonomy to which this reference code belongs. Identifies the domain of location classification (e.g., address_type for residential/commercial/PO Box, premise_type for MDU/SDU/business, site_type for cell tower/exchange/data center, zone_type for urban/suburban/rural, region_type for state/county/municipality, coverage_tier for tier-1/tier-2/tier-3). [ENUM-REF-CANDIDATE: address_type|premise_type|site_type|zone_type|region_type|coverage_tier|geocode_accuracy_level|rollout_zone_type — promote to reference product]' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeValue rdf:type rdf:Property ;
    rdfs:label 'Code Value' ;
    rdfs:comment 'The unique identifier or key value for this reference code within its code set. Used as the canonical value stored in operational systems and data products (e.g., \'RES\' for residential address type, \'MDU\' for multi-dwelling unit premise type, \'CELL_TOWER\' for cell site type).' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this reference code is visible to customers in self-service portals, mobile apps, or customer communications. True means the code label and description must be customer-friendly and comply with brand guidelines; False means the code is for internal operational use only.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'The sort order or sequence number for displaying this code within its code set in user interfaces, dropdown lists, and reports. Lower numbers appear first. Enables business-driven ordering rather than alphabetical sorting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingStandard rdf:type rdf:Property ;
    rdfs:label 'Governing Standard' ;
    rdfs:comment 'The authoritative standard, specification, or framework that defines this reference code. Identifies whether the code is based on an international standard (e.g., ISO 19112, TM Forum SID), industry standard (e.g., GSMA, 3GPP), regulatory requirement (e.g., FCC, BEREC), or is operator-defined for internal business needs. Ensures traceability to source authority and supports compliance validation.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCodeValue rdf:type rdf:Property ;
    rdfs:label 'Parent Code Value' ;
    rdfs:comment 'The code value of the parent reference code in a hierarchical code set structure. Enables multi-level taxonomies where codes have parent-child relationships (e.g., \'URBAN\' zone type as parent of \'DOWNTOWN\' and \'SUBURBAN\' sub-zones). Null for top-level codes.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCodeValue rdf:type rdf:Property ;
    rdfs:label 'Replacement Code Value' ;
    rdfs:comment 'The code value of the reference code that should be used instead of this deprecated code. Supports data migration and remediation when codes are consolidated or replaced. Null if no direct replacement exists or if the code is still active.' ;
    rdfs:domain ind:ReferenceCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of physical access restrictions, security protocols, or special entry requirements for the site (e.g., escort required, biometric access, advance notice). Used for Workforce Management (WFM) and field dispatch planning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerCapacityKwh rdf:type rdf:Property ;
    rdfs:label 'Backup Power Capacity Kwh' ;
    rdfs:comment 'Total backup power capacity available at the site in kilowatt-hours, critical for Service Level Agreement (SLA) compliance and network resilience during outages.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Capacity classification of the site based on equipment density, power capacity, and network throughput: small (micro-site), medium (standard site), large (macro-site), enterprise (enterprise-grade facility), carrier_grade (tier-1 carrier facility).' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingType rdf:type rdf:Property ;
    rdfs:label 'Cooling Type' ;
    rdfs:comment 'Climate control system type deployed at the site: hvac (heating, ventilation, air conditioning), passive (natural ventilation), liquid (liquid cooling), evaporative (evaporative cooling), none (no cooling system).' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberConnectivity rdf:type rdf:Property ;
    rdfs:label 'Fiber Connectivity' ;
    rdfs:comment 'Indicates whether the site has fiber optic backhaul connectivity (True) or relies on alternative transport such as microwave or satellite (False). Critical for Fiber to the Home (FTTH) and 5G New Radio (5G NR) deployment planning.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatorAvailable rdf:type rdf:Property ;
    rdfs:label 'Generator Available' ;
    rdfs:comment 'Indicates whether the site has an on-site backup generator (True) or not (False). Critical for Service Level Agreement (SLA) compliance and network resilience.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterials rdf:type rdf:Property ;
    rdfs:label 'Hazardous Materials' ;
    rdfs:comment 'Indicates whether the site stores or uses hazardous materials such as diesel fuel, batteries, or refrigerants (True) or not (False). Used for environmental compliance and safety planning.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Land Area Sqm' ;
    rdfs:comment 'Total land area of the site property in square meters, used for Capital Expenditure (CAPEX) planning, lease cost allocation, and expansion feasibility analysis.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Expiration date of the site lease agreement for leased or co-located sites. Null for owned sites. Critical for contract renewal planning and Operational Expenditure (OPEX) forecasting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:microwaveBackhaul rdf:type rdf:Property ;
    rdfs:label 'Microwave Backhaul' ;
    rdfs:comment 'Indicates whether the site uses microwave radio backhaul for transport connectivity (True) or not (False). Common for remote tower sites without fiber access.' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerSupplyType rdf:type rdf:Property ;
    rdfs:label 'Power Supply Type' ;
    rdfs:comment 'Primary electrical power source for the site: grid (utility power), solar (photovoltaic), hybrid (multiple sources), generator (diesel/gas generator), battery (battery-only for remote sites).' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralType rdf:type rdf:Property ;
    rdfs:label 'Structural Type' ;
    rdfs:comment 'Physical structure classification of the site: building (permanent structure), tower (freestanding tower), pole (utility pole mount), rooftop (building rooftop installation), underground (below-grade facility), container (modular container unit).' ;
    rdfs:domain ind:LocationSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mduBuildingId rdf:type rdf:Property ;
    rdfs:label 'Mdu Building Id' ;
    rdfs:comment 'Unique system identifier for the MDU or multi-tenanted building record. Primary key for the mdu_building product.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'Date when the current MDU access agreement or infrastructure deployment agreement with the building owner expires. Triggers renewal or renegotiation activities.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bodyCorporateReference rdf:type rdf:Property ;
    rdfs:label 'Body Corporate Reference' ;
    rdfs:comment 'Reference identifier for the body corporate, owners corporation, or homeowners association governing the MDU building. Required for infrastructure installation approvals.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Externally-known unique business identifier for the MDU building, used across network planning, service provisioning, and field operations. Typically assigned by network planning or property management systems.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Building Commissioning Date' ;
    rdfs:comment 'Date when the MDU building telecommunications infrastructure was commissioned and made available for service provisioning. Marks the transition from construction to operational status.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buildingHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Building Height Meters' ;
    rdfs:comment 'Total height of the MDU building structure in meters from ground level to roof. Used for radio frequency propagation modeling and small cell placement planning.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingManagerContact rdf:type rdf:Property ;
    rdfs:label 'Building Manager Contact' ;
    rdfs:comment 'Primary contact information (phone or email) for the building manager or property management company. Used for coordinating site access and installation activities.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingOwnerName rdf:type rdf:Property ;
    rdfs:label 'Building Owner Name' ;
    rdfs:comment 'Name of the legal entity or individual that owns the MDU building. Critical for access negotiations and infrastructure agreement discussions.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingStatus rdf:type rdf:Property ;
    rdfs:label 'Building Status' ;
    rdfs:comment 'Current lifecycle status of the MDU building in the network planning and service delivery context. Determines whether the building is available for service provisioning.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Connected Unit Count' ;
    rdfs:comment 'Number of dwelling units or premises within the MDU building that currently have active telecommunications service connections. Used for penetration rate and take-up analysis.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'Year when the physical MDU building structure was originally constructed. Influences infrastructure retrofit requirements and access constraints.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiberEntryPoint rdf:type rdf:Property ;
    rdfs:label 'Fiber Entry Point' ;
    rdfs:comment 'Description of the physical location where external fiber optic cables enter the MDU building (e.g., \'South wall basement conduit\', \'Underground vault access\'). Critical for outside plant to inside plant handoff.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiveGSmallCellInstalled rdf:type rdf:Property ;
    rdfs:label 'Five G Small Cell Installed' ;
    rdfs:comment 'Indicates whether 5G small cell equipment has been deployed within or on the MDU building to provide enhanced indoor mobile coverage. Relevant for 5G New Radio (5G NR) network planning.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:footprintAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Footprint Area Sqm' ;
    rdfs:comment 'Ground-level footprint area of the MDU building in square meters. Used for site planning and infrastructure density calculations.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idfCount rdf:type rdf:Property ;
    rdfs:label 'Idf Count' ;
    rdfs:comment 'Number of intermediate distribution frames or floor-level distribution points installed within the MDU building. Indicates the granularity of in-building network distribution.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inBuildingNetworkType rdf:type rdf:Property ;
    rdfs:label 'In Building Network Type' ;
    rdfs:comment 'Type of telecommunications infrastructure deployed or planned within the MDU building. Determines service capabilities and technology limitations for end-user provisioning.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSiteSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Site Survey Date' ;
    rdfs:comment 'Date when the most recent physical site survey or infrastructure audit was conducted for the MDU building. Used to assess data currency and plan re-survey activities.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mdfLocation rdf:type rdf:Property ;
    rdfs:label 'Mdf Location' ;
    rdfs:comment 'Physical location description of the main distribution frame or primary telecommunications room within the MDU building (e.g., \'Basement Level 1, Room B-12\'). Critical for field technician access.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mduAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Mdu Agreement Status' ;
    rdfs:comment 'Current status of the access agreement or infrastructure deployment agreement with the building owner or body corporate. Determines whether service provisioning is authorized.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailability rdf:type rdf:Property ;
    rdfs:label 'Parking Availability' ;
    rdfs:comment 'Availability of parking facilities for field technician vehicles during installation and maintenance activities. Impacts field dispatch planning and service appointment scheduling.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerBackupAvailable rdf:type rdf:Property ;
    rdfs:label 'Power Backup Available' ;
    rdfs:comment 'Indicates whether backup power (UPS or generator) is available for telecommunications equipment within the MDU building. Impacts service reliability and SLA commitments.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riserAvailableCapacity rdf:type rdf:Property ;
    rdfs:label 'Riser Available Capacity' ;
    rdfs:comment 'Number of unused fiber or cable pairs currently available in the vertical riser infrastructure. Used for capacity planning and service provisioning feasibility checks.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riserCapacity rdf:type rdf:Property ;
    rdfs:label 'Riser Capacity' ;
    rdfs:comment 'Maximum number of fiber or cable pairs available in the vertical riser infrastructure within the MDU building. Determines the maximum serviceable unit count.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceableUnitCount rdf:type rdf:Property ;
    rdfs:label 'Serviceable Unit Count' ;
    rdfs:comment 'Number of dwelling units or premises within the MDU building that are technically serviceable with telecommunications infrastructure. May be less than total units due to infrastructure limitations.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloors rdf:type rdf:Property ;
    rdfs:label 'Total Floors' ;
    rdfs:comment 'Total number of floors or levels in the MDU building, including basement and ground levels. Critical for vertical infrastructure planning and riser design.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTenancies rdf:type rdf:Property ;
    rdfs:label 'Total Tenancies' ;
    rdfs:comment 'Total number of commercial tenancies, office suites, or business premises within the MDU building. Relevant for mixed-use and commercial buildings.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of individual dwelling units, apartments, or residential premises within the MDU building. Used for capacity planning and penetration rate calculations.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wifiCoverageAvailable rdf:type rdf:Property ;
    rdfs:label 'Wifi Coverage Available' ;
    rdfs:comment 'Indicates whether managed WiFi coverage is available within common areas or individual units of the MDU building. Relevant for converged fixed-mobile service offerings.' ;
    rdfs:domain ind:MduBuilding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedContractorId rdf:type rdf:Property ;
    rdfs:label 'Assigned Contractor Id' ;
    rdfs:comment 'Identifier of the primary construction contractor or vendor responsible for physical build activities in this zone. Used for vendor performance tracking and contract management.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:actualCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Capex Amount' ;
    rdfs:comment 'Actual capital expenditure incurred to date for the rollout zone in local currency. Updated as costs are recorded. Used for variance analysis and cost control.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPremisesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Actual Premises Passed Count' ;
    rdfs:comment 'Actual number of premises passed as of the current date. Updated as construction progresses. Used for variance analysis against planned targets and regulatory reporting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessLocationCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Business Location Count Estimate' ;
    rdfs:comment 'Estimated number of commercial and business locations within the rollout zone. Used for enterprise market opportunity assessment.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Status' ;
    rdfs:comment 'Status of environmental impact assessment and regulatory clearance for the rollout zone. Not_required: no assessment needed; Pending: under review; Approved: cleared for construction; Conditional: approved with mitigation requirements; Denied: clearance refused.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex Amount' ;
    rdfs:comment 'Estimated total capital expenditure for the rollout zone in local currency. Includes materials, labor, permits, and indirect costs. Used for budget planning and financial forecasting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Household Count Estimate' ;
    rdfs:comment 'Estimated number of residential households within the rollout zone. Used for addressable market analysis and service penetration modeling.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income for the rollout zone area in local currency. Used for market segmentation, product mix planning, and affordability analysis.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkActivationDate rdf:type rdf:Property ;
    rdfs:label 'Network Activation Date' ;
    rdfs:comment 'Date when the network infrastructure in this zone was activated and made available for service provisioning. Null if not yet activated. Used for service readiness and revenue forecasting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Permit Approval Date' ;
    rdfs:comment 'Date when all required construction permits and right-of-way approvals were obtained for the rollout zone. Null if permits not yet approved. Used for schedule tracking and regulatory compliance.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedPremisesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Planned Premises Passed Count' ;
    rdfs:comment 'Target number of residential and business premises that will have network infrastructure available upon completion of the rollout zone. Key metric for CAPEX planning and regulatory subsidy compliance.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmeName rdf:type rdf:Property ;
    rdfs:label 'Programme Name' ;
    rdfs:comment 'Name of the broader infrastructure programme or initiative this zone belongs to (e.g., \'NBN Co National Broadband Network\', \'RDOF Rural Digital Opportunity Fund\', \'BEAD Broadband Equity Access and Deployment\', \'Project Gigabit UK\'). Used for portfolio management and regulatory reporting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutPhase rdf:type rdf:Property ;
    rdfs:label 'Rollout Phase' ;
    rdfs:comment 'Current phase of the rollout project lifecycle. Design: engineering and planning; Permitting: regulatory approvals; Procurement: material and contractor acquisition; Construction: physical build; Testing: network commissioning; Activation: service turn-up; Closeout: final documentation and handover. [ENUM-REF-CANDIDATE: design|permitting|procurement|construction|testing|activation|closeout — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidyAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Subsidy Award Amount' ;
    rdfs:comment 'Total government subsidy or grant amount awarded for this rollout zone in local currency. Null if no subsidy awarded. Used for financial tracking and regulatory reporting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subsidyEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Subsidy Eligible Flag' ;
    rdfs:comment 'Indicates whether this rollout zone qualifies for government subsidy or universal service funding. True if eligible; False otherwise. Used for funding application and compliance reporting.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetTechnology rdf:type rdf:Property ;
    rdfs:label 'Target Technology' ;
    rdfs:comment 'Primary network technology being deployed in this rollout zone. GPON: Gigabit Passive Optical Network; XGS_PON: 10 Gigabit Symmetric PON; NG_PON2: Next-Generation PON 2; 5G_NR: 5G New Radio; LTE_Advanced: 4G LTE-A; DOCSIS_3_1/4_0: Data Over Cable Service Interface Specification; FWA: Fixed Wireless Access. [ENUM-REF-CANDIDATE: GPON|XGS_PON|NG_PON2|5G_NR|LTE_Advanced|DOCSIS_3_1|DOCSIS_4_0|FWA_5G|FWA_LTE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underservedPremisesCount rdf:type rdf:Property ;
    rdfs:label 'Underserved Premises Count' ;
    rdfs:comment 'Number of premises within the zone that have broadband service below target speed thresholds (typically below 100/20 Mbps or jurisdiction-specific standard). Used for subsidy eligibility and upgrade prioritization.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unservedPremisesCount rdf:type rdf:Property ;
    rdfs:label 'Unserved Premises Count' ;
    rdfs:comment 'Number of premises within the zone that currently have no broadband service meeting minimum speed thresholds (typically 25/3 Mbps or jurisdiction-specific standard). Used for subsidy eligibility and digital divide reporting.' ;
    rdfs:domain ind:NetworkRolloutZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadbandServiceableLocationPremiseId rdf:type rdf:Property ;
    rdfs:label 'Broadband Serviceable Location Premise Id' ;
    rdfs:comment 'Federal Communications Commission (FCC) Broadband Serviceable Location (BSL) identifier for regulatory reporting under the Broadband Data Collection (BDC) program.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:dslamElementId rdf:type rdf:Property ;
    rdfs:label 'Dslam Element Id' ;
    rdfs:comment 'Reference to the Digital Subscriber Line Access Multiplexer (DSLAM) equipment that serves this premise for DSL broadband services. Null if premise is not DSL-served.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:mduParentPremiseId rdf:type rdf:Property ;
    rdfs:label 'Mdu Parent Premise Id' ;
    rdfs:comment 'Reference to the parent premise record for individual units within a Multi-Dwelling Unit (MDU). Null for standalone premises or the MDU parent record itself. Enables hierarchical premise relationships.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:cadastralReference rdf:type rdf:Property ;
    rdfs:label 'Cadastral Reference' ;
    rdfs:comment 'Official cadastral or land registry reference number linking the premise to government property records and land title systems.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusBlockCode rdf:type rdf:Property ;
    rdfs:label 'Census Block Code' ;
    rdfs:comment '15-digit Federal Information Processing Standards (FIPS) census block code identifying the smallest geographic unit for which census data is collected. Used for regulatory reporting and demographic analysis.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellingCount rdf:type rdf:Property ;
    rdfs:label 'Dwelling Count' ;
    rdfs:comment 'Number of individual dwelling units or serviceable endpoints within this premise. For Multi-Dwelling Units (MDU), represents the total unit count. For single-family homes, typically 1.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fttnServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Fttn Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is serviceable via Fiber to the Node (FTTN) technology with copper last-mile. True if FTTN infrastructure serves the premise area, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fttpServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Fttp Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is serviceable via Fiber to the Premise (FTTP) technology. True if fiber infrastructure reaches the premise, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fwaServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Fwa Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is serviceable via Fixed Wireless Access (FWA) technology. True if wireless coverage and capacity are available, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the latitude and longitude coordinates. Rooftop is most precise (building-level), parcel is property boundary, street is street segment, postal code is ZIP/postal area, city is municipality level, unknown indicates unverified coordinates.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Hazard Zone Flag' ;
    rdfs:comment 'Indicates whether the premise is located in a designated hazard zone (flood plain, earthquake zone, wildfire risk area, etc.). True if in hazard zone, false otherwise. Used for risk assessment and infrastructure planning.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hfcServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Hfc Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is serviceable via Hybrid Fiber-Coaxial (HFC) cable network technology. True if HFC infrastructure reaches the premise, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastServiceabilityUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Serviceability Update Date' ;
    rdfs:comment 'Date when the technology serviceability flags (FTTP, HFC, FTTN, FWA, 5G, LTE) were last updated based on network infrastructure changes or coverage analysis.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Legal lot or parcel number assigned by local government for property identification and taxation purposes.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lteServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'Lte Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is within Long-Term Evolution (LTE) coverage area and can receive 4G mobile services. True if LTE coverage exists, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:n5gServiceableFlag rdf:type rdf:Property ;
    rdfs:label 'N5g Serviceable Flag' ;
    rdfs:comment 'Indicates whether the premise is within 5G New Radio (5G NR) coverage area and can receive 5G mobile services. True if 5G coverage exists, false otherwise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiseCode rdf:type rdf:Property ;
    rdfs:label 'Premise Code' ;
    rdfs:comment 'Externally-known unique business identifier for the premise, used across systems and customer communications.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiseStatus rdf:type rdf:Property ;
    rdfs:label 'Premise Status' ;
    rdfs:comment 'Current lifecycle status of the premise. Active premises are serviceable, demolished premises no longer exist, under construction premises are being built, planned premises are future sites, inactive premises exist but are not currently serviceable, condemned premises are marked for demolition.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiseType rdf:type rdf:Property ;
    rdfs:label 'Premise Type' ;
    rdfs:comment 'Classification of the premise based on its primary use and structure. Residential single-family, residential apartment, small commercial, large commercial, Multi-Dwelling Unit (MDU), government facility, or industrial site. [ENUM-REF-CANDIDATE: residential_single|residential_apartment|commercial_small|commercial_large|mdu|government|industrial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruralFlag rdf:type rdf:Property ;
    rdfs:label 'Rural Flag' ;
    rdfs:comment 'Indicates whether the premise is classified as rural based on population density and distance from urban centers. True if rural, false if urban or suburban. Used for regulatory reporting and subsidy program eligibility.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tribalLandFlag rdf:type rdf:Property ;
    rdfs:label 'Tribal Land Flag' ;
    rdfs:comment 'Indicates whether the premise is located on federally-recognized tribal land. True if on tribal land, false otherwise. Used for regulatory compliance and special program eligibility.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premisesPassedId rdf:type rdf:Property ;
    rdfs:label 'Premises Passed Id' ;
    rdfs:comment 'Unique identifier for the premises passed event record. Primary key for this transactional record capturing when a specific premise was made serviceable by network infrastructure rollout.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Id' ;
    rdfs:comment 'Reference to the construction contractor or deployment partner responsible for passing this premise. Used for performance tracking, quality assurance, and payment reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:fieldSurveyId rdf:type rdf:Property ;
    rdfs:label 'Field Survey Id' ;
    rdfs:comment 'Reference to the field survey or site assessment record that validated this premises passed event. Links to the engineering survey that confirmed infrastructure readiness.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldSurvey .

ind:primaryPremisesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Premises Employee Id' ;
    rdfs:comment 'Reference to the user or system account that verified and approved this premises passed record. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Readiness Status' ;
    rdfs:comment 'Current status of the premises readiness for service activation. Ready to connect (can be activated immediately), pending construction (infrastructure work in progress), awaiting permit (regulatory approval needed), blocked (physical or legal impediment), or under review (assessment in progress).' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPremiseFlag rdf:type rdf:Property ;
    rdfs:label 'Business Premise Flag' ;
    rdfs:comment 'Boolean indicator of whether this premise is classified as a business or commercial location rather than residential. True indicates business premise; affects product eligibility, SLA requirements, and pricing.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveOverlapFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Overlap Flag' ;
    rdfs:comment 'Boolean indicator of whether this premise is also served by competing network infrastructure from other telecommunications providers. True indicates competitive overlap; used for market analysis and strategic planning.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionCostTier rdf:type rdf:Property ;
    rdfs:label 'Connection Cost Tier' ;
    rdfs:comment 'Categorical classification of the connection cost complexity. Standard (normal installation), medium (minor additional work), high (significant construction required), or custom (requires individual assessment and quote).' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Completion Date' ;
    rdfs:comment 'The date on which physical construction or infrastructure deployment was completed for this premise. May differ from pass_date if there is a lag between construction completion and formal service readiness declaration.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distanceToNetworkMetres rdf:type rdf:Property ;
    rdfs:label 'Distance To Network Metres' ;
    rdfs:comment 'The physical distance in metres from the premise to the nearest network access point or serving network element. Used for estimating connection feasibility, signal quality, and installation cost.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedConnectionCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Connection Cost' ;
    rdfs:comment 'The estimated cost in local currency to activate service at this premise, based on distance, pass type, and required infrastructure work. Used for customer quoting and financial planning.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseAreaCode rdf:type rdf:Property ;
    rdfs:label 'Franchise Area Code' ;
    rdfs:comment 'The franchise or license area code within which this premise is located. Used for regulatory compliance, franchise fee calculation, and territorial rights management.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumServiceSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Service Speed Mbps' ;
    rdfs:comment 'The maximum downstream service speed in megabits per second (Mbps) that can be delivered to this premise based on the technology type, distance, and network element capacity. Used for product catalog eligibility and customer expectation setting.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passDate rdf:type rdf:Property ;
    rdfs:label 'Pass Date' ;
    rdfs:comment 'The date on which the premise was formally passed or made serviceable by the network infrastructure. This is the official date the premise became reachable by the network, critical for regulatory premises-passed reporting and NBN Co compliance.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pass Reference Number' ;
    rdfs:comment 'External business identifier for this premises passed event, typically assigned by the field deployment team or contractor. Used for tracking and reconciliation with field survey reports.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passType rdf:type rdf:Property ;
    rdfs:label 'Pass Type' ;
    rdfs:comment 'Classification of the pass readiness level indicating the type of infrastructure available at the premise. Aerial drop available (overhead cable ready), underground duct available (conduit in place), active port available (live connection point ready), or on-demand only (requires additional construction).' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCapacityAvailable rdf:type rdf:Property ;
    rdfs:label 'Port Capacity Available' ;
    rdfs:comment 'The number of available service ports on the serving network element that can be allocated to this premise. Critical for capacity management and preventing oversubscription in GPON and FTTH deployments.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roamingZone rdf:type rdf:Property ;
    rdfs:label 'Roaming Zone' ;
    rdfs:comment 'The roaming zone classification for this premise location, relevant for mobile and fixed wireless access services. Used for billing, service availability, and interconnect agreements.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceableFlag rdf:type rdf:Property ;
    rdfs:label 'Serviceable Flag' ;
    rdfs:comment 'Boolean indicator of whether the premise is currently serviceable and ready for customer activation. True indicates the premise can be connected without additional infrastructure work; false indicates further construction or engineering is required.' ;
    rdfs:domain ind:PremisesPassed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentTerritoryServiceTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Service Territory Id' ;
    rdfs:comment 'Reference to the parent service territory in a hierarchical territory structure, enabling nested regional, divisional, and national territory rollups.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTerritory .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Total number of active customers or subscriber accounts currently assigned to this service territory, used for workload balancing and capacity planning.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Code' ;
    rdfs:comment 'Reference to the franchise or license agreement governing the right to provide telecommunications services within this territory, applicable for franchise_area territory types.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceTerritoryDescription rdf:type rdf:Property ;
    rdfs:label 'Service Territory Description' ;
    rdfs:comment 'Detailed textual description of the service territory, including geographic landmarks, boundary definitions, operational notes, and any special characteristics or constraints.' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Externally-known unique business identifier for the service territory, used across operational systems for territory reference and assignment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the service territory, typically reflecting geographic or organizational designation (e.g., \'Northeast Metro Region\', \'Downtown Dispatch Zone\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the service territory: active (in operational use), inactive (temporarily not in use), proposed (planned but not yet activated), suspended (temporarily disabled), retired (permanently decommissioned).' ;
    rdfs:domain ind:ServiceTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the service territory by operational purpose: field_ops (field operations coverage), sales_region (sales team assignment), noc_zone (Network Operations Center monitoring zone), dispatch_zone (workforce dispatch area), franchise_area (licensed service area), regulatory_zone (compliance jurisdiction).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmId rdf:type rdf:Property ;
    rdfs:label 'Alarm Id' ;
    rdfs:comment 'Primary key for alarm' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_account. Business justification: Network alarms affecting specific enterprise customer accounts drive proactive notifications, SLA credit calculations, escalation workflows. Real process: customer-impacting incident management for de' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:affectedEnterpriseSiteId rdf:type rdf:Property ;
    rdfs:label 'Affected Enterprise Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.site. Business justification: Alarms affecting enterprise sites drive customer impact assessment and notification. Business process: enterprise customer notification, site-level fault correlation, and proactive outage communicatio' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseSite .

ind:assignedTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Assigned Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Network alarms require technician assignment for investigation and resolution in NOC/field operations. Critical for alarm lifecycle management, SLA tracking, and workforce utilization reporting in tel' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:acknowledgedBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By' ;
    rdfs:comment 'The username or identifier of the NOC operator or engineer who acknowledged the alarm. Used for accountability and audit trail.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Indicates whether the alarm has been acknowledged by NOC operations staff. Acknowledged alarms are under active investigation or remediation.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedNetworkElementType rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element Type' ;
    rdfs:comment 'Type or category of the affected network element (e.g., eNodeB, OLT, BNG, MPLS router, optical switch, DSLAM). Used for alarm categorization and routing to specialized support teams.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmCount rdf:type rdf:Property ;
    rdfs:label 'Alarm Count' ;
    rdfs:comment 'The number of times this specific alarm condition has been raised (for recurring alarms). A count greater than 1 indicates a flapping or intermittent fault condition.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmDescription rdf:type rdf:Property ;
    rdfs:label 'Alarm Description' ;
    rdfs:comment 'Detailed textual description of the alarm condition, including context, affected components, and potential impact. Sourced from the network element or enriched by the NMS.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmStatus rdf:type rdf:Property ;
    rdfs:label 'Alarm Status' ;
    rdfs:comment 'Current lifecycle status of the alarm indicating whether it is active, has been acknowledged by NOC staff, cleared by the network element, or administratively closed.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clear Timestamp' ;
    rdfs:comment 'The date and time when the alarm condition was resolved and the alarm was cleared by the network element or management system. Null if the alarm is still active.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correlationKey rdf:type rdf:Property ;
    rdfs:label 'Correlation Key' ;
    rdfs:comment 'Identifier used to group related alarms that stem from the same root cause. Alarm correlation reduces alarm noise and helps NOC staff focus on the primary fault.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'The geographic location or site identifier of the affected network element. Used for dispatch routing and regional impact analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Notification Identifier' ;
    rdfs:comment 'Unique identifier for the alarm notification message as assigned by the originating system. Used for message tracking and deduplication.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raise Timestamp' ;
    rdfs:comment 'The date and time when the alarm condition was first detected and raised by the network element or management system. Used as the start point for alarm duration and MTTR calculations.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAlarmFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Alarm Flag' ;
    rdfs:comment 'Boolean flag indicating whether this alarm has been identified as the root cause alarm in a correlated alarm set. True if this is the root cause; false if it is a secondary or consequential alarm.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachType rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Type' ;
    rdfs:comment 'The type of SLA breach associated with this alarm (e.g., availability breach, MTTR breach, performance degradation). Null if no SLA breach occurred.' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceInterface rdf:type rdf:Property ;
    rdfs:label 'Source Interface' ;
    rdfs:comment 'The specific interface, protocol, or API through which the alarm was received (e.g., SNMP v2c, SNMP v3, Netconf, REST API, proprietary northbound interface).' ;
    rdfs:domain ind:Alarm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Id' ;
    rdfs:comment 'Primary key for capacity' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCapacity rdf:type rdf:Property ;
    rdfs:label 'Available Capacity' ;
    rdfs:comment 'Remaining capacity available for new service provisioning. Calculated as total capacity minus committed capacity and any reserved buffers.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Average Utilization Percentage' ;
    rdfs:comment 'Mean utilization percentage across the measurement period. Used for trend analysis and capacity planning forecasting.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:busyHourIndicator rdf:type rdf:Property ;
    rdfs:label 'Busy Hour Indicator' ;
    rdfs:comment 'Flag indicating whether this measurement represents the busy hour period. Busy hour metrics are critical for capacity dimensioning and network planning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current operational status of the resource capacity relative to defined thresholds. Drives capacity augmentation and network planning decisions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCapacity rdf:type rdf:Property ;
    rdfs:label 'Committed Capacity' ;
    rdfs:comment 'Capacity already allocated or reserved for active services and customer commitments. Represents the portion of total capacity currently in use or reserved.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:congestionThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Congestion Threshold Percentage' ;
    rdfs:comment 'Utilization percentage threshold at which the resource is considered congested and requires capacity augmentation. Typically set based on QoS requirements and SLA commitments.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Percentage' ;
    rdfs:comment 'Utilization percentage threshold indicating critical capacity exhaustion requiring immediate intervention. Triggers urgent capacity expansion or traffic engineering actions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Projected date when capacity will reach congestion threshold based on current growth trends. Drives capital planning and network expansion timelines.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:growthRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Growth Rate Percentage' ;
    rdfs:comment 'Observed or projected capacity growth rate percentage per period. Used for trend-based capacity forecasting and investment planning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Minutes' ;
    rdfs:comment 'Duration of the measurement period in minutes. Common intervals include 15, 30, 60 minutes for operational monitoring and daily/weekly for planning.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkLayer rdf:type rdf:Property ;
    rdfs:label 'Network Layer' ;
    rdfs:comment 'Hierarchical network layer classification of the resource. Aligns with network architecture topology and capacity planning domains.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Peak Utilization Percentage' ;
    rdfs:comment 'Maximum utilization percentage observed during the measurement period. Critical metric for identifying capacity bottlenecks and congestion events.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Planned Upgrade Date' ;
    rdfs:comment 'Scheduled date for capacity augmentation or upgrade activity. Links capacity monitoring to capital project execution.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservationPercentage rdf:type rdf:Property ;
    rdfs:label 'Reservation Percentage' ;
    rdfs:comment 'Percentage of total capacity reserved for network resilience, traffic bursts, and emergency services. Not available for normal service provisioning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Resource Identifier' ;
    rdfs:comment 'Business identifier or name of the specific resource (cell ID, link name, tunnel ID, port designation). Human-readable reference used in network operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Availability Percentage' ;
    rdfs:comment 'Target availability percentage defined in SLA commitments. Capacity planning must ensure sufficient redundancy to meet availability targets.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCapacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Network Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the network capacity plan record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCapacityPlan .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Capacity plans require assigned network planners for demand analysis, forecasting, and recommendation development. Business process: capacity planning workload distribution and accountability tracking' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforceCapacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Workforce Capacity Plan Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_capacity_plan. Business justification: Network capacity expansion plans drive workforce capacity planning for installation, commissioning, and maintenance. Strategic planning process requires linking network buildout plans to hiring/traini' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceCapacityPlan .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the recommended capacity augmentation action, including technical approach, scope, and expected outcomes.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityGap rdf:type rdf:Property ;
    rdfs:label 'Capacity Gap' ;
    rdfs:comment 'Calculated or assessed capacity shortfall (projected_demand minus current_capacity_baseline), indicating the magnitude of capacity augmentation required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for capacity metrics (e.g., Gbps, Mbps, Erlang, subscribers, sites, ports, wavelengths, MHz spectrum, cells). [ENUM-REF-CANDIDATE: gbps|mbps|erlang|subscribers|sites|ports|wavelengths|mhz|cells — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityBaseline rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Baseline' ;
    rdfs:comment 'Current capacity baseline measurement for the target network domain, expressed in the unit specified by capacity_unit (e.g., Gbps, Erlang, number of subscribers, number of sites).' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCapex rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex' ;
    rdfs:comment 'Estimated capital expenditure required to implement the capacity plan, in the currency specified by currency_code.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOpexAnnual rdf:type rdf:Property ;
    rdfs:label 'Estimated Opex Annual' ;
    rdfs:comment 'Estimated incremental annual operational expenditure resulting from the capacity augmentation (e.g., maintenance, power, lease costs).' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberRouteKm rdf:type rdf:Property ;
    rdfs:label 'Fiber Route Km' ;
    rdfs:comment 'Total length of new fiber route to be deployed (in kilometers) as part of the capacity plan. Applicable for FTTH, transport, and backhaul expansion plans.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfSites rdf:type rdf:Property ;
    rdfs:label 'Number Of Sites' ;
    rdfs:comment 'Number of new cell sites, POPs, or network nodes to be deployed as part of the capacity plan. Applicable for site expansion plans.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Percentage completion of the capacity plan implementation, ranging from 0.00 to 100.00.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier or reference code for the capacity plan, used for tracking and reporting (e.g., \'CAP-2024-RAN-037\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned or scheduled start date for implementation of the capacity augmentation activities, in yyyy-MM-dd format.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time horizon for the capacity planning activity: short_term (0-12 months), medium_term (1-3 years), long_term (3+ years).' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedDemand rdf:type rdf:Property ;
    rdfs:label 'Projected Demand' ;
    rdfs:comment 'Forecasted demand or capacity requirement at the end of the planning horizon, expressed in the same unit as current_capacity_baseline.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Primary recommended action to address the capacity gap: new_site (build new cell site or POP), spectrum_addition (acquire or refarm spectrum), equipment_upgrade (add cards/modules), fiber_deployment (extend FTTH/transport), capacity_swap (technology migration), decommission (retire legacy), optimization (software/configuration tuning). [ENUM-REF-CANDIDATE: new_site|spectrum_addition|equipment_upgrade|fiber_deployment|capacity_swap|decommission|optimization — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Description of key risks, dependencies, or constraints associated with the capacity plan (e.g., site acquisition delays, vendor supply chain issues, regulatory approval dependencies).' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiMonths rdf:type rdf:Property ;
    rdfs:label 'Roi Months' ;
    rdfs:comment 'Expected return on investment period in months, representing the time to recover the CAPEX investment through incremental revenue or cost savings.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Availability Percent' ;
    rdfs:comment 'Target network availability percentage (e.g., 99.95%) that the augmented capacity is designed to support, per SLA commitments.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spectrumBandwidthMhz rdf:type rdf:Property ;
    rdfs:label 'Spectrum Bandwidth Mhz' ;
    rdfs:comment 'Amount of spectrum bandwidth (in MHz) to be added or refarmed as part of the capacity plan. Applicable for RAN capacity plans.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNetworkDomain rdf:type rdf:Property ;
    rdfs:label 'Target Network Domain' ;
    rdfs:comment 'The network domain or layer targeted by this capacity plan: RAN (Radio Access Network), transport (MPLS/SD-WAN), core (EPC/5GC), access (FTTH/GPON/DSLAM), edge (MEC), backhaul.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSubscriberCapacity rdf:type rdf:Property ;
    rdfs:label 'Target Subscriber Capacity' ;
    rdfs:comment 'Target number of subscribers or connections that the augmented capacity will support. Applicable for access and core network capacity plans.' ;
    rdfs:domain ind:NetworkCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configChangeId rdf:type rdf:Property ;
    rdfs:label 'Config Change Id' ;
    rdfs:comment 'Unique identifier for the configuration change record. Primary key for the configuration change transaction.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineElementConfigId rdf:type rdf:Property ;
    rdfs:label 'Baseline Element Config Id' ;
    rdfs:comment 'Foreign key linking to network.element_config. Business justification: Configuration changes are applied against a baseline configuration. This FK links each config_change transaction to the element_config baseline it modifies, enabling change impact analysis, rollback p' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ElementConfig .

ind:executedByTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Executed By Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Configuration changes executed by technicians (field or NOC) require audit trail linking change to executor. Regulatory compliance (SOX, telecom audits) and change management processes mandate trackin' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:affectedCustomersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customers Count' ;
    rdfs:comment 'Estimated or actual number of customers whose services were impacted by this configuration change.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServices rdf:type rdf:Property ;
    rdfs:label 'Affected Services' ;
    rdfs:comment 'Comma-separated list of service identifiers or service names that were potentially impacted by this configuration change (e.g., \'VoLTE\', \'IPTV\', \'Broadband\').' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterValue rdf:type rdf:Property ;
    rdfs:label 'After Value' ;
    rdfs:comment 'Configuration parameter value(s) after the change was applied. Supports verification and compliance validation.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupCreated rdf:type rdf:Property ;
    rdfs:label 'Backup Created' ;
    rdfs:comment 'Indicates whether a configuration backup was created before applying this change to enable rollback (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupReference rdf:type rdf:Property ;
    rdfs:label 'Backup Reference' ;
    rdfs:comment 'Identifier or file path of the configuration backup created before this change. Null if no backup was created.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beforeValue rdf:type rdf:Property ;
    rdfs:label 'Before Value' ;
    rdfs:comment 'Configuration parameter value(s) before the change was applied. Supports audit trail and rollback scenarios.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceValidated rdf:type rdf:Property ;
    rdfs:label 'Compliance Validated' ;
    rdfs:comment 'Indicates whether the configuration change has been validated against compliance policies and regulatory requirements (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes of service downtime caused by this configuration change. Zero if no downtime occurred.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executedBySystem rdf:type rdf:Property ;
    rdfs:label 'Executed By System' ;
    rdfs:comment 'Name or identifier of the automation system or orchestration platform that executed the change (e.g., \'Nokia NetAct\', \'Ericsson Network Manager\', \'Ansible Tower\', \'NSO\').' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the configuration change failed or was rolled back. Null if change was successful.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReference rdf:type rdf:Property ;
    rdfs:label 'Incident Reference' ;
    rdfs:comment 'Reference to the incident ticket (from ServiceNow ITSM or fault management system) that triggered this emergency configuration change. Null for planned changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Noc Notification Sent' ;
    rdfs:comment 'Indicates whether the Network Operations Center was notified about this configuration change (True/False).' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parametersModified rdf:type rdf:Property ;
    rdfs:label 'Parameters Modified' ;
    rdfs:comment 'Comma-separated or structured list of configuration parameters that were modified during this change (e.g., \'txPower, antennaAzimuth, vlanId\').' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackReference rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference' ;
    rdfs:comment 'Reference identifier to the rollback change request or transaction that reverted this configuration change. Null if no rollback occurred.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the configuration change was scheduled to complete.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:softwareVersionAfter rdf:type rdf:Property ;
    rdfs:label 'Software Version After' ;
    rdfs:comment 'Software or firmware version of the network element after the configuration change. Relevant for software upgrade changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersionBefore rdf:type rdf:Property ;
    rdfs:label 'Software Version Before' ;
    rdfs:comment 'Software or firmware version of the network element before the configuration change. Relevant for software upgrade changes.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResult rdf:type rdf:Property ;
    rdfs:label 'Validation Result' ;
    rdfs:comment 'Result of post-change validation tests: passed (all tests successful), failed (validation detected issues), partial (some tests passed), or not_performed.' ;
    rdfs:domain ind:ConfigChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementId rdf:type rdf:Property ;
    rdfs:label 'Element Id' ;
    rdfs:comment 'Primary key for element' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:owningOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owning Org Unit Id' ;
    rdfs:comment 'Foreign key linking to people.org_unit. Business justification: Network elements are owned and managed by specific organizational units (regional NOCs, core network operations, etc.). Business process: budget allocation, headcount planning, operational responsibil' ;
    rdfs:domain ind:Element ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:administrativeState rdf:type rdf:Property ;
    rdfs:label 'Administrative State' ;
    rdfs:comment 'Administrative control state of the network element indicating whether it is locked (prevented from use), unlocked (available for use), or in the process of shutting down.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Numeric capacity rating of the network element representing its maximum throughput, bandwidth, or processing capability.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elementName rdf:type rdf:Property ;
    rdfs:label 'Element Name' ;
    rdfs:comment 'Human-readable name or label assigned to the network element for identification and operational reference.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementType rdf:type rdf:Property ;
    rdfs:label 'Element Type' ;
    rdfs:comment 'High-level classification of the network element indicating its functional category within the telecommunications infrastructure.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emsSystem rdf:type rdf:Property ;
    rdfs:label 'Ems System' ;
    rdfs:comment 'Name of the Element Management System platform responsible for element-level configuration and fault management.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleState rdf:type rdf:Property ;
    rdfs:label 'Lifecycle State' ;
    rdfs:comment 'Current lifecycle stage of the network element from initial planning through active operation to eventual retirement.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manoOrchestrator rdf:type rdf:Property ;
    rdfs:label 'Mano Orchestrator' ;
    rdfs:comment 'Name or identifier of the NFV MANO platform responsible for orchestrating the lifecycle of this virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfvIndicator rdf:type rdf:Property ;
    rdfs:label 'Nfv Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this network element is a virtualized network function (VNF) running on NFV infrastructure rather than dedicated physical hardware.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalState rdf:type rdf:Property ;
    rdfs:label 'Operational State' ;
    rdfs:comment 'Current operational state of the network element indicating whether it is actively processing traffic, disabled, or in testing mode.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyMode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Mode' ;
    rdfs:comment 'Redundancy configuration mode for the network element indicating how failover and high availability are implemented.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPosition rdf:type rdf:Property ;
    rdfs:label 'Slot Position' ;
    rdfs:comment 'Specific slot or bay position within the rack or chassis where the network element card or module is installed.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed classification of the network element specifying the exact node type (e.g., eNodeB, gNodeB, MME, AMF, SMF, UPF, P-CSCF, S-CSCF, I-CSCF, HSS, MPLS router, OTN switch, DSLAM, BNG, BRAS, OLT, ONT, ONU, vMME, vSGW, vPGW, vBNG, vFirewall).' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContact rdf:type rdf:Property ;
    rdfs:label 'Support Contact' ;
    rdfs:comment 'Primary technical support contact information (email or phone) for vendor support escalation related to this network element.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRatingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Celsius' ;
    rdfs:comment 'Maximum operating temperature rating in degrees Celsius for the network element hardware.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vcpuCount rdf:type rdf:Property ;
    rdfs:label 'Vcpu Count' ;
    rdfs:comment 'Number of virtual CPU cores allocated to the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vnfdIdentifier rdf:type rdf:Property ;
    rdfs:label 'Vnfd Identifier' ;
    rdfs:comment 'Unique identifier for the VNF Descriptor that defines the deployment and operational behavior of the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vramGb rdf:type rdf:Property ;
    rdfs:label 'Vram Gb' ;
    rdfs:comment 'Amount of virtual memory in gigabytes allocated to the virtualized network function. Applicable only when NFV indicator is true.' ;
    rdfs:domain ind:Element ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elementConfigId rdf:type rdf:Property ;
    rdfs:label 'Element Config Id' ;
    rdfs:comment 'Unique identifier for the network element configuration record. Primary key for configuration management tracking across Nokia NetAct and Ericsson Network Manager platforms.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configTemplateId rdf:type rdf:Property ;
    rdfs:label 'Config Template Id' ;
    rdfs:comment 'Reference to the standardized configuration template or golden config that this configuration is based on. Enables consistency across similar network elements and simplifies mass configuration deployment.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfigTemplate .

ind:primaryElementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Element Employee Id' ;
    rdfs:comment 'Identifier of the network operations engineer or administrator who initiated or approved this configuration change. Used for accountability, audit trail, and access control compliance. May be human operator or automation system identifier.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rollbackReferenceElementConfigId rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference Element Config Id' ;
    rdfs:comment 'Reference to the previous configuration version that was restored during a rollback operation. Enables tracking of configuration reversion history and supports automated rollback procedures.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ElementConfig .

ind:affectedSubscribersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Subscribers Count' ;
    rdfs:comment 'Estimated or actual number of subscribers impacted by this configuration change. Used for impact assessment, prioritization, and customer communication during planned maintenance or incident response.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Date and time when this configuration was moved to archived status. Used for retention policy enforcement and historical analysis. Null for active or staged configurations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationSystem rdf:type rdf:Property ;
    rdfs:label 'Automation System' ;
    rdfs:comment 'Name of the automation platform or orchestration system that executed this configuration change (e.g., Nokia NetAct, Ericsson Network Manager, Ansible, Terraform, NSO). Null if manually executed by operator.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupLocation rdf:type rdf:Property ;
    rdfs:label 'Backup Location' ;
    rdfs:comment 'Storage path or URI where the full configuration backup file is stored. Supports disaster recovery, audit compliance, and rapid restoration. May reference network file system, object storage, or configuration management database.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256) of the configuration file to ensure integrity and detect unauthorized modifications. Used for security audit and tamper detection in compliance with security frameworks.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Version' ;
    rdfs:comment 'Version of the compliance policy framework used to validate this configuration. Ensures audit trail of which standards were applied at the time of configuration deployment.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Human-readable description of the configuration change purpose, scope, and expected outcome. Includes business justification such as capacity expansion, performance optimization, security hardening, or bug fix.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Additional operational notes, lessons learned, or special considerations related to this configuration. Used for knowledge management and to inform future similar changes.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configParameters rdf:type rdf:Property ;
    rdfs:label 'Config Parameters' ;
    rdfs:comment 'Structured representation of configuration parameters including neighbor cell lists, handover thresholds, QoS (Quality of Service) policies, routing tables, VLAN assignments, MPLS labels, BGP peers, OSPF areas, and vendor-specific settings. Stored as JSON or XML for structured querying.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Config Source System' ;
    rdfs:comment 'Name of the source system or NMS (Network Management System) / EMS (Element Management System) that generated or captured this configuration record (e.g., Nokia NetAct, Ericsson Network Manager, Netcracker OSS).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of this configuration record. Active indicates currently deployed; staged indicates pending activation; archived indicates historical record; superseded indicates replaced by newer version; failed indicates deployment failure.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configType rdf:type rdf:Property ;
    rdfs:label 'Config Type' ;
    rdfs:comment 'Type of configuration record: running (active operational config), startup (boot config), candidate (staged for activation), baseline (approved reference), golden (vendor-certified template).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version identifier for this configuration snapshot. Follows semantic versioning or vendor-specific versioning scheme (e.g., 2.4.1, R15B). Used for configuration baseline tracking and rollback operations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driftDetails rdf:type rdf:Property ;
    rdfs:label 'Drift Details' ;
    rdfs:comment 'Detailed description of configuration drift including specific parameters that differ from baseline, magnitude of deviation, and potential impact on network performance or security. Used for root cause analysis.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionOutcome rdf:type rdf:Property ;
    rdfs:label 'Execution Outcome' ;
    rdfs:comment 'Result of the configuration deployment attempt: success (fully applied), partial (some parameters applied), failed (deployment unsuccessful), rolled_back (reverted to previous config due to validation failure or service impact).' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nocSiteCode rdf:type rdf:Property ;
    rdfs:label 'Noc Site Code' ;
    rdfs:comment 'Code identifying the NOC (Network Operations Center) or regional operations center responsible for managing this network element configuration. Used for operational accountability and escalation routing.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Service Impact Flag' ;
    rdfs:comment 'Boolean indicator that this configuration change caused or is expected to cause service disruption, degradation, or customer impact. Used for SLA tracking, root cause analysis, and change management process improvement.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'List of validation errors or warnings identified during configuration validation. Includes syntax errors, policy violations, resource conflicts, or dependency issues. Used to prevent service-impacting misconfigurations.' ;
    rdfs:domain ind:ElementConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ims Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: IMS nodes require assigned engineers for configuration, capacity management, and service troubleshooting. Business process: IMS registration failures and session capacity issues route to responsible a' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:redundancyPairNodeId rdf:type rdf:Property ;
    rdfs:label 'Redundancy Pair Node Id' ;
    rdfs:comment 'Reference to the paired IMS node that provides redundancy or failover capability for this node.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImsNode .

ind:actualAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Availability Percentage' ;
    rdfs:comment 'Measured actual availability percentage of the IMS node over a defined reporting period, used for SLA compliance tracking.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Current Registration Count' ;
    rdfs:comment 'Current number of active subscriber registrations maintained by the node at the time of measurement.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentSessionCount rdf:type rdf:Property ;
    rdfs:label 'Current Session Count' ;
    rdfs:comment 'Current number of active IMS sessions being processed by the node at the time of measurement.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imsDomainName rdf:type rdf:Property ;
    rdfs:label 'Ims Domain Name' ;
    rdfs:comment 'Fully qualified domain name (FQDN) of the IMS domain that this node serves, used for SIP routing and service identification.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failure or outage event experienced by the IMS node.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nmsObjectReference rdf:type rdf:Property ;
    rdfs:label 'Nms Object Reference' ;
    rdfs:comment 'Unique object identifier assigned to this IMS node within the network management system for tracking and correlation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Node Identifier' ;
    rdfs:comment 'Externally-known unique identifier or name for the IMS node, used in network management systems and operational documentation.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name assigned to the IMS node for identification in network operations and management interfaces.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the IMS node function: P-CSCF (Proxy Call Session Control Function), S-CSCF (Serving CSCF), I-CSCF (Interrogating CSCF), PCRF (Policy and Charging Rules Function), HSS (Home Subscriber Server), AS (Application Server), BGCF (Breakout Gateway Control Function), MGCF (Media Gateway Control Function). [ENUM-REF-CANDIDATE: P-CSCF|S-CSCF|I-CSCF|PCRF|HSS|AS|BGCF|MGCF — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Business unit, department, or organizational entity responsible for the ownership and operational management of this IMS node.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCapacity rdf:type rdf:Property ;
    rdfs:label 'Registration Capacity' ;
    rdfs:comment 'Maximum number of concurrent subscriber registrations that the node can maintain, applicable primarily to S-CSCF and HSS nodes.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryIpAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Ip Address' ;
    rdfs:comment 'Secondary or backup IP address for redundancy and failover scenarios.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityZone rdf:type rdf:Property ;
    rdfs:label 'Security Zone' ;
    rdfs:comment 'Network security zone or segment in which the IMS node is deployed, defining firewall rules and access control policies.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionCapacity rdf:type rdf:Property ;
    rdfs:label 'Session Capacity' ;
    rdfs:comment 'Maximum number of concurrent IMS sessions (calls, video sessions, messaging sessions) that the node can handle simultaneously.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedCodecs rdf:type rdf:Property ;
    rdfs:label 'Supported Codecs' ;
    rdfs:comment 'Comma-separated list of voice and video codecs supported by this IMS node (e.g., AMR-NB, AMR-WB, EVS, H.264, H.265) for multimedia session negotiation.' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedServices rdf:type rdf:Property ;
    rdfs:label 'Supported Services' ;
    rdfs:comment 'Comma-separated list of IMS-based services enabled on this node (e.g., VoLTE, VoNR, RCS, video calling, SMS over IP, emergency calling).' ;
    rdfs:domain ind:ImsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressPlanId rdf:type rdf:Property ;
    rdfs:label 'Ip Address Plan Id' ;
    rdfs:comment 'Unique identifier for the IP address plan record. Primary key for IP address space management (IPAM) entries.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressSpaceType rdf:type rdf:Property ;
    rdfs:label 'Address Space Type' ;
    rdfs:comment 'Classification of the IP address space: public (globally routable), private (RFC 1918 for IPv4 or ULA for IPv6), reserved (special-use addresses), or carrier_grade_nat (CGN/LSN address pool per RFC 6598).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPurpose rdf:type rdf:Property ;
    rdfs:label 'Allocation Purpose' ;
    rdfs:comment 'Business purpose for which this IP address block is allocated: management (network device management), subscriber (customer-facing services), loopback (routing protocol loopbacks), transit (inter-AS routing), peering (interconnect with other carriers), or infrastructure (internal network services).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAddressesCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Addresses Count' ;
    rdfs:comment 'Number of IP addresses from this block that are currently assigned to devices or services.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autonomousSystemNumber rdf:type rdf:Property ;
    rdfs:label 'Autonomous System Number' ;
    rdfs:comment 'Autonomous System Number (ASN) associated with this IP address block for BGP routing. Identifies the carrier or network operator.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableAddressesCount rdf:type rdf:Property ;
    rdfs:label 'Available Addresses Count' ;
    rdfs:comment 'Number of IP addresses in this block that remain available for assignment.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastAddress rdf:type rdf:Property ;
    rdfs:label 'Broadcast Address' ;
    rdfs:comment 'Broadcast address for this IPv4 subnet, typically the last address in the block. Not applicable for IPv6.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhcpPoolFlag rdf:type rdf:Property ;
    rdfs:label 'Dhcp Pool Flag' ;
    rdfs:comment 'Indicates whether this IP address block is configured as a DHCP pool for dynamic address assignment (True) or used for static assignment (False).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dnsZone rdf:type rdf:Property ;
    rdfs:label 'Dns Zone' ;
    rdfs:comment 'DNS zone or domain name associated with this IP address block for reverse DNS lookups (e.g., in-addr.arpa for IPv4, ip6.arpa for IPv6).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayAddress rdf:type rdf:Property ;
    rdfs:label 'Gateway Address' ;
    rdfs:comment 'Default gateway IP address for this subnet, typically the first usable address in the block.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipPrefix rdf:type rdf:Property ;
    rdfs:label 'Ip Prefix' ;
    rdfs:comment 'IP address block in CIDR notation (e.g., 10.0.0.0/24 for IPv4 or 2001:db8::/32 for IPv6). Represents the network prefix and subnet mask.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipamSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Ipam Source System' ;
    rdfs:comment 'Name of the IPAM or Network Management System (NMS/EMS) that is the authoritative source for this IP address plan record (e.g., Nokia NetAct, Ericsson Network Manager, Infoblox).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkFunctionType rdf:type rdf:Property ;
    rdfs:label 'Network Function Type' ;
    rdfs:comment 'Type of network function or service supported by this IP address block (e.g., RAN, Core, IMS, NFV, SDN, GPON, MPLS, SD-WAN).' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPrefix rdf:type rdf:Property ;
    rdfs:label 'Parent Prefix' ;
    rdfs:comment 'Parent or supernet IP prefix from which this block was subdivided. Supports hierarchical IP address planning and aggregation.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name of the Network Operations Center (NOC) team or organizational unit responsible for managing this IP address block.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subnetMask rdf:type rdf:Property ;
    rdfs:label 'Subnet Mask' ;
    rdfs:comment 'Subnet mask in dotted-decimal notation (e.g., 255.255.255.0) for IPv4 address blocks. Defines the network and host portions of the address.' ;
    rdfs:domain ind:IpAddressPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMplsNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Primary Mpls Network Element Id' ;
    rdfs:comment 'Identifier of the network element serving as the Label Edge Router (LER) where traffic enters the MPLS tunnel.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:tunnelAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tunnel Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: MPLS tunnels require network engineers for configuration, path optimization, and troubleshooting. Business process: tunnel performance issues and reoptimization tasks escalate to assigned administrato' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affinityBits rdf:type rdf:Property ;
    rdfs:label 'Affinity Bits' ;
    rdfs:comment 'Administrative group or color constraints (32-bit mask) used to include or exclude specific links during path computation for traffic engineering.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoBandwidthEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Bandwidth Enabled' ;
    rdfs:comment 'Indicates whether automatic bandwidth adjustment is enabled, allowing the tunnel to dynamically resize based on traffic patterns.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoBandwidthMaxMbps rdf:type rdf:Property ;
    rdfs:label 'Auto Bandwidth Max Mbps' ;
    rdfs:comment 'Maximum bandwidth limit in megabits per second that auto-bandwidth can adjust to, preventing over-allocation.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoBandwidthMinMbps rdf:type rdf:Property ;
    rdfs:label 'Auto Bandwidth Min Mbps' ;
    rdfs:comment 'Minimum bandwidth limit in megabits per second that auto-bandwidth can adjust to, ensuring baseline capacity.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthReservedMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Reserved Mbps' ;
    rdfs:comment 'Amount of bandwidth reserved for this tunnel in megabits per second, used for traffic engineering and capacity planning.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthUtilizedMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Utilized Mbps' ;
    rdfs:comment 'Current bandwidth utilization of the tunnel in megabits per second, measured from traffic statistics.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bytesReceived rdf:type rdf:Property ;
    rdfs:label 'Bytes Received' ;
    rdfs:comment 'Total number of bytes received through the tunnel since establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bytesTransmitted rdf:type rdf:Property ;
    rdfs:label 'Bytes Transmitted' ;
    rdfs:comment 'Total number of bytes transmitted through the tunnel since establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:explicitRoutePath rdf:type rdf:Property ;
    rdfs:label 'Explicit Route Path' ;
    rdfs:comment 'Ordered list of network nodes or links defining the explicit route object (ERO) that the LSP must traverse, used for traffic engineering.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverCount rdf:type rdf:Property ;
    rdfs:label 'Failover Count' ;
    rdfs:comment 'Number of times the tunnel has failed over to a protection path since establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdingPriority rdf:type rdf:Property ;
    rdfs:label 'Holding Priority' ;
    rdfs:comment 'Priority level (0-7, where 0 is highest) used to determine whether an established LSP can be preempted by a new LSP with higher setup priority.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastFailoverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failover Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failover event to a protection path.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReoptimizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reoptimization Timestamp' ;
    rdfs:comment 'Timestamp of the most recent path reoptimization event for this tunnel.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lspIdentifier rdf:type rdf:Property ;
    rdfs:label 'Lsp Identifier' ;
    rdfs:comment 'Numeric identifier for the specific Label Switched Path instance within the tunnel, used for multi-path or protection scenarios.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Type of metric used for path computation. IGP = Interior Gateway Protocol metric, TE = Traffic Engineering metric, delay = latency-based, hop-count = number of hops.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'Numeric metric value associated with the tunnel path, used for routing decisions and path selection.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetLossCount rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Count' ;
    rdfs:comment 'Total number of packets lost in transit through the tunnel, indicating quality degradation.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetsReceived rdf:type rdf:Property ;
    rdfs:label 'Packets Received' ;
    rdfs:comment 'Total number of packets received through the tunnel since establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetsTransmitted rdf:type rdf:Property ;
    rdfs:label 'Packets Transmitted' ;
    rdfs:comment 'Total number of packets transmitted through the tunnel since establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pathComputationMethod rdf:type rdf:Property ;
    rdfs:label 'Path Computation Method' ;
    rdfs:comment 'Method used to compute the tunnel path. CSPF = Constrained Shortest Path First (local computation), PCE = Path Computation Element (centralized), manual = operator-defined.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pceAddress rdf:type rdf:Property ;
    rdfs:label 'Pce Address' ;
    rdfs:comment 'IP address of the Path Computation Element server used for centralized path computation when PCE method is enabled.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionPath rdf:type rdf:Property ;
    rdfs:label 'Protection Path' ;
    rdfs:comment 'Ordered list of network nodes or links defining the backup or protection LSP route used when the primary path fails.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reoptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Reoptimization Enabled' ;
    rdfs:comment 'Indicates whether periodic path reoptimization is enabled to find more optimal routes as network conditions change.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reoptimizationIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Reoptimization Interval Seconds' ;
    rdfs:comment 'Time interval in seconds between automatic path reoptimization attempts.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupPriority rdf:type rdf:Property ;
    rdfs:label 'Setup Priority' ;
    rdfs:comment 'Priority level (0-7, where 0 is highest) used during LSP setup to determine which tunnels can preempt others when resources are constrained.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalingProtocol rdf:type rdf:Property ;
    rdfs:label 'Signaling Protocol' ;
    rdfs:comment 'Protocol used to signal and establish the MPLS tunnel. RSVP-TE = Resource Reservation Protocol Traffic Engineering, LDP = Label Distribution Protocol, BGP = Border Gateway Protocol, SR = Segment Routing.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tunnelIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tunnel Id Number' ;
    rdfs:comment 'Numeric tunnel identifier used in RSVP-TE signaling to uniquely identify the tunnel on the ingress node.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tunnelName rdf:type rdf:Property ;
    rdfs:label 'Tunnel Name' ;
    rdfs:comment 'Human-readable name or label assigned to the MPLS tunnel for identification and operational reference.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tunnelType rdf:type rdf:Property ;
    rdfs:label 'Tunnel Type' ;
    rdfs:comment 'The signaling protocol or method used to establish the Label Switched Path (LSP). LDP = Label Distribution Protocol, RSVP-TE = Resource Reservation Protocol - Traffic Engineering, SR-MPLS = Segment Routing MPLS, MPLS-TP = MPLS Transport Profile, BGP-LU = BGP Labeled Unicast, Static = manually configured.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Uptime Seconds' ;
    rdfs:comment 'Total time in seconds that the tunnel has been in operational up state since last establishment.' ;
    rdfs:domain ind:MplsTunnel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:administratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: 5G network slices require assigned engineers for orchestration, SLA monitoring, and lifecycle management. Business process: slice instantiation, modification, and SLA breach resolution require enginee' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargingRatePlanId rdf:type rdf:Property ;
    rdfs:label 'Charging Rate Plan Id' ;
    rdfs:comment 'Reference to the rate plan defining pricing rules, tariffs, and charging parameters for usage of this network slice.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatePlan .

ind:tenantCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Tenant Corporate Account Id' ;
    rdfs:comment 'Foreign key linking to enterprise.corporate_account. Business justification: 5G network slices provide tenant-isolated connectivity per enterprise account. Business process: enterprise 5G service delivery, slice lifecycle management, and account-level SLA enforcement for dedic' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:tenantPartnerId rdf:type rdf:Property ;
    rdfs:label 'Tenant Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: 5G network slicing commonly serves enterprise partners or MVNOs as tenants with dedicated slice instances. Slice billing, SLA enforcement, resource allocation, and usage settlement require linking the' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:coreSliceConfig rdf:type rdf:Property ;
    rdfs:label 'Core Slice Config' ;
    rdfs:comment 'JSON or XML configuration parameters defining 5G core network slice behavior including network function selection, policy rules, and charging parameters.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaTacList rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Tac List' ;
    rdfs:comment 'Comma-separated list of Tracking Area Codes where this slice is available. Defines the geographic scope of slice coverage.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUeCount rdf:type rdf:Property ;
    rdfs:label 'Current Ue Count' ;
    rdfs:comment 'Current number of active User Equipment (devices) connected to this network slice. Used for real-time capacity monitoring and utilization tracking.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommission Timestamp' ;
    rdfs:comment 'Date and time when the network slice was decommissioned and resources were released. Marks the end of the slice lifecycle.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentModel rdf:type rdf:Property ;
    rdfs:label 'Deployment Model' ;
    rdfs:comment 'Resource allocation model: dedicated (isolated resources per slice), shared (resources shared across slices), or hybrid (mix of dedicated and shared components).' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instantiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instantiation Timestamp' ;
    rdfs:comment 'Date and time when the network slice was instantiated and provisioned by the orchestrator. Marks the beginning of the slice lifecycle.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isolationLevel rdf:type rdf:Property ;
    rdfs:label 'Isolation Level' ;
    rdfs:comment 'Degree of resource isolation between this slice and others: physical (dedicated hardware), logical (virtualized separation), or none (best-effort shared resources).' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxUeCount rdf:type rdf:Property ;
    rdfs:label 'Max Ue Count' ;
    rdfs:comment 'Maximum number of concurrent User Equipment (devices) that can be served by this network slice. Critical capacity planning parameter for mMTC slices.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nsiIdentifier rdf:type rdf:Property ;
    rdfs:label 'Nsi Identifier' ;
    rdfs:comment 'The globally unique Network Slice Instance identifier assigned by the MANO orchestrator. Used for lifecycle management and cross-domain coordination.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nssfInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Nssf Instance Reference' ;
    rdfs:comment 'The NSSF network function instance identifier responsible for slice selection for this slice. NSSF selects the appropriate network slice instance for UE registration.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nstIdentifier rdf:type rdf:Property ;
    rdfs:label 'Nst Identifier' ;
    rdfs:comment 'Reference to the Network Slice Template used to instantiate this slice. Templates define reusable slice blueprints with predefined configurations.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orchestratorSystem rdf:type rdf:Property ;
    rdfs:label 'Orchestrator System' ;
    rdfs:comment 'Name of the NFV MANO or SDN orchestrator system responsible for lifecycle management of this slice (e.g., ONAP, OSM, vendor-specific NFVO).' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmnIdList rdf:type rdf:Property ;
    rdfs:label 'Plmn Id List' ;
    rdfs:comment 'Comma-separated list of PLMN IDs (MCC-MNC combinations) where this slice is deployed. Supports multi-operator and roaming scenarios.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ranSliceConfig rdf:type rdf:Property ;
    rdfs:label 'Ran Slice Config' ;
    rdfs:comment 'JSON or XML configuration parameters defining RAN-level slice behavior including radio resource allocation, scheduling policies, and QoS parameters.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdValue rdf:type rdf:Property ;
    rdfs:label 'Sd Value' ;
    rdfs:comment 'The 24-bit Slice Differentiator component of S-NSSAI, used to differentiate multiple slices of the same SST. Hexadecimal format. Optional field per 3GPP specification.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Security Policy Reference' ;
    rdfs:comment 'Reference to the security policy governing authentication, encryption, firewall rules, and access control for this slice.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sliceName rdf:type rdf:Property ;
    rdfs:label 'Slice Name' ;
    rdfs:comment 'Human-readable business name assigned to the network slice for operational identification and reporting purposes.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sliceType rdf:type rdf:Property ;
    rdfs:label 'Slice Type' ;
    rdfs:comment 'The service category this slice is optimized for: eMBB (enhanced Mobile Broadband), URLLC (Ultra-Reliable Low-Latency Communications), mMTC (massive Machine-Type Communications), V2X (Vehicle-to-Everything), or custom for enterprise-specific configurations.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sstValue rdf:type rdf:Property ;
    rdfs:label 'Sst Value' ;
    rdfs:comment 'The 8-bit Slice/Service Type component of S-NSSAI. Standardized values: 1=eMBB, 2=URLLC, 3=mMTC, 4=V2X. Range 128-255 reserved for operator-specific slice types.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenantCode rdf:type rdf:Property ;
    rdfs:label 'Tenant Code' ;
    rdfs:comment 'Identifier of the enterprise customer or business unit that owns or leases this network slice. Used for multi-tenancy and slice-as-a-service offerings.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportSliceConfig rdf:type rdf:Property ;
    rdfs:label 'Transport Slice Config' ;
    rdfs:comment 'JSON or XML configuration parameters defining transport network slice behavior including MPLS tunnels, SD-WAN policies, and QoS class mappings.' ;
    rdfs:domain ind:Slice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfvVnfId rdf:type rdf:Property ;
    rdfs:label 'Nfv Vnf Id' ;
    rdfs:comment 'Unique identifier for the Virtual Network Function instance deployed on the NFV Infrastructure.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NfvVnf .

ind:deploymentWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Deployment Work Order Id' ;
    rdfs:comment 'Foreign key linking to workforce.work_order. Business justification: VNF deployment and troubleshooting generates work orders for NOC/datacenter technicians. Tracks labor for NFV lifecycle management, enables cost allocation for virtualized network functions, and suppo' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:vnfAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Vnf Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Virtual network functions require assigned engineers for lifecycle management, scaling operations, and troubleshooting. Business process: VNF instantiation, scaling, and termination require engineer a' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affinityRule rdf:type rdf:Property ;
    rdfs:label 'Affinity Rule' ;
    rdfs:comment 'Placement rule indicating whether this VNF instance should be co-located (affinity) or separated (anti-affinity) from other VNF instances for performance or resilience.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoHealingEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Healing Enabled' ;
    rdfs:comment 'Indicates whether automatic fault detection and recovery (auto-healing) is enabled for this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Status of the VNF instance configuration, indicating whether initial configuration has been successfully applied or if configuration errors exist.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentScaleLevel rdf:type rdf:Property ;
    rdfs:label 'Current Scale Level' ;
    rdfs:comment 'Current number of active VNF instances deployed for this VNF type, reflecting the current scaling state.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPlaneIpAddress rdf:type rdf:Property ;
    rdfs:label 'Data Plane Ip Address' ;
    rdfs:comment 'IP address assigned to the data plane interface of this VNF instance for processing user traffic and signaling.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentFlavor rdf:type rdf:Property ;
    rdfs:label 'Deployment Flavor' ;
    rdfs:comment 'Deployment flavor identifier specifying the resource profile (CPU, memory, storage) and configuration variant for this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultStatus rdf:type rdf:Property ;
    rdfs:label 'Fault Status' ;
    rdfs:comment 'Current fault severity level for this VNF instance based on active alarms and fault management system inputs.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highAvailabilityMode rdf:type rdf:Property ;
    rdfs:label 'High Availability Mode' ;
    rdfs:comment 'High availability configuration mode for this VNF instance, indicating whether it operates in active-active, active-standby, or no redundancy mode.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instantiationLevel rdf:type rdf:Property ;
    rdfs:label 'Instantiation Level' ;
    rdfs:comment 'Instantiation level identifier indicating the scale and capacity configuration at which this VNF instance was deployed.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instantiationState rdf:type rdf:Property ;
    rdfs:label 'Instantiation State' ;
    rdfs:comment 'Current lifecycle state of the VNF instance indicating whether it is instantiated and operational, failed, or in a transitional state.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseKey rdf:type rdf:Property ;
    rdfs:label 'License Key' ;
    rdfs:comment 'Software license key or token required to activate and operate this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxScaleLevel rdf:type rdf:Property ;
    rdfs:label 'Max Scale Level' ;
    rdfs:comment 'Maximum number of VNF instances that can be deployed for this VNF type based on capacity planning and resource constraints.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minScaleLevel rdf:type rdf:Property ;
    rdfs:label 'Min Scale Level' ;
    rdfs:comment 'Minimum number of VNF instances that must be maintained for this VNF type to meet service availability and performance requirements.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkServiceReference rdf:type rdf:Property ;
    rdfs:label 'Network Service Reference' ;
    rdfs:comment 'Identifier of the parent network service that this VNF instance is part of, enabling end-to-end service tracking and orchestration.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfviHostReference rdf:type rdf:Property ;
    rdfs:label 'Nfvi Host Reference' ;
    rdfs:comment 'Identifier of the physical or virtual host within the NFV Infrastructure where this VNF instance is deployed and running.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfvoReference rdf:type rdf:Property ;
    rdfs:label 'Nfvo Reference' ;
    rdfs:comment 'Identifier of the NFV Orchestrator responsible for network service orchestration and resource orchestration across the NFV Infrastructure.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance tier classification for this VNF instance indicating the level of service quality, throughput capacity, and resource allocation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyModel rdf:type rdf:Property ;
    rdfs:label 'Redundancy Model' ;
    rdfs:comment 'Redundancy architecture model applied to this VNF instance for fault tolerance and service continuity.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scalingPolicy rdf:type rdf:Property ;
    rdfs:label 'Scaling Policy' ;
    rdfs:comment 'Defines the scaling behavior for this VNF instance, indicating whether scaling is manual, automatic (scale-out, scale-in, or both), or not applicable.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaProfile rdf:type rdf:Property ;
    rdfs:label 'Sla Profile' ;
    rdfs:comment 'Identifier of the SLA profile defining the performance, availability, and quality of service commitments for this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageState rdf:type rdf:Property ;
    rdfs:label 'Usage State' ;
    rdfs:comment 'Current usage state of the VNF instance indicating whether it is idle, actively processing traffic, or operating at capacity.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vcpuAllocation rdf:type rdf:Property ;
    rdfs:label 'Vcpu Allocation' ;
    rdfs:comment 'Number of virtual CPU cores allocated to this VNF instance for compute processing.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vimReference rdf:type rdf:Property ;
    rdfs:label 'Vim Reference' ;
    rdfs:comment 'Identifier of the VIM (e.g., OpenStack, VMware vCenter) managing the compute, storage, and network resources for this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfInstanceName rdf:type rdf:Property ;
    rdfs:label 'Vnf Instance Name' ;
    rdfs:comment 'Human-readable name assigned to this VNF instance for operational identification and management purposes.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Vnf Software Version' ;
    rdfs:comment 'Version identifier of the VNF software package currently deployed, used for lifecycle management, patching, and upgrade planning.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfType rdf:type rdf:Property ;
    rdfs:label 'Vnf Type' ;
    rdfs:comment 'Classification of the virtualized network function indicating its role in the network architecture (e.g., virtual Evolved Packet Core components, IP Multimedia Subsystem elements, virtual Broadband Network Gateway, virtual Customer Premises Equipment). [ENUM-REF-CANDIDATE: vEPC|vMME|vSGW|vPGW|vIMS|vP-CSCF|vS-CSCF|vI-CSCF|vBNG|vFirewall|vRouter|vCPE|vSD-WAN|vDPI|vPCRF|vHSS|vUDM|vPCF|vSMF|vUPF|vAMF — 21 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfdReference rdf:type rdf:Property ;
    rdfs:label 'Vnfd Reference' ;
    rdfs:comment 'Reference to the VNF Descriptor that defines the deployment template, configuration parameters, and lifecycle management operations for this VNF type.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfmReference rdf:type rdf:Property ;
    rdfs:label 'Vnfm Reference' ;
    rdfs:comment 'Identifier of the VNF Manager component within the MANO (Management and Orchestration) framework responsible for lifecycle management of this VNF instance.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vramAllocationGb rdf:type rdf:Property ;
    rdfs:label 'Vram Allocation Gb' ;
    rdfs:comment 'Amount of virtual memory in gigabytes allocated to this VNF instance for runtime operations.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vstorageAllocationGb rdf:type rdf:Property ;
    rdfs:label 'Vstorage Allocation Gb' ;
    rdfs:comment 'Amount of virtual disk storage in gigabytes allocated to this VNF instance for persistent data and configuration storage.' ;
    rdfs:domain ind:NfvVnf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peeringAgreementId rdf:type rdf:Property ;
    rdfs:label 'Peering Agreement Id' ;
    rdfs:comment 'Unique identifier for the network peering or transit agreement record. Primary key for the peering agreement entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PeeringAgreement .

ind:peeringCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Peering Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Peering agreements require assigned engineers for technical negotiation, BGP session management, and ongoing coordination. Business process: peering session failures and traffic ratio violations escal' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:peeringPartnerId rdf:type rdf:Property ;
    rdfs:label 'Peering Partner Id' ;
    rdfs:comment 'Reference to the partner or carrier entity in the partner domain representing the peering counterparty.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:agreedBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Agreed Bandwidth Mbps' ;
    rdfs:comment 'The committed or agreed bandwidth capacity for the peering interconnection, measured in megabits per second.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'The expiration or termination date of the peering agreement. Null for open-ended agreements.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'The effective start date when the peering agreement becomes active and traffic exchange begins.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bgpAsnLocal rdf:type rdf:Property ;
    rdfs:label 'Bgp Asn Local' ;
    rdfs:comment 'The local Autonomous System Number used in the BGP peering session for this agreement.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bgpAsnRemote rdf:type rdf:Property ;
    rdfs:label 'Bgp Asn Remote' ;
    rdfs:comment 'The remote peering partner\'s Autonomous System Number used in the BGP peering session.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bgpSessionState rdf:type rdf:Property ;
    rdfs:label 'Bgp Session State' ;
    rdfs:comment 'Current operational state of the BGP peering session: idle, connect, active, opensent, openconfirm, or established (per BGP finite state machine).' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialTermsReference rdf:type rdf:Property ;
    rdfs:label 'Commercial Terms Reference' ;
    rdfs:comment 'Reference to the commercial contract document or terms governing pricing, service levels, and obligations for the peering arrangement.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSessionDownTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Session Down Timestamp' ;
    rdfs:comment 'Timestamp when the BGP peering session last transitioned out of the established state (went down).' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSessionUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Session Up Timestamp' ;
    rdfs:comment 'Timestamp when the BGP peering session last transitioned to the established state.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxPrefixLimitIpv4 rdf:type rdf:Property ;
    rdfs:label 'Max Prefix Limit Ipv4' ;
    rdfs:comment 'Maximum number of IPv4 prefixes that can be advertised or accepted over the BGP peering session before the session is torn down.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPrefixLimitIpv6 rdf:type rdf:Property ;
    rdfs:label 'Max Prefix Limit Ipv6' ;
    rdfs:comment 'Maximum number of IPv6 prefixes that can be advertised or accepted over the BGP peering session before the session is torn down.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nocContactName rdf:type rdf:Property ;
    rdfs:label 'Noc Contact Name' ;
    rdfs:comment 'Name of the primary technical contact at the peering partner\'s Network Operations Center for operational coordination and incident escalation.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringIpv4AddressLocal rdf:type rdf:Property ;
    rdfs:label 'Peering Ipv4 Address Local' ;
    rdfs:comment 'The local IPv4 address assigned to the peering interface on the local side of the BGP session.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringIpv4AddressRemote rdf:type rdf:Property ;
    rdfs:label 'Peering Ipv4 Address Remote' ;
    rdfs:comment 'The remote IPv4 address assigned to the peering partner\'s interface on the remote side of the BGP session.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringIpv6AddressLocal rdf:type rdf:Property ;
    rdfs:label 'Peering Ipv6 Address Local' ;
    rdfs:comment 'The local IPv6 address assigned to the peering interface on the local side of the BGP session, if IPv6 peering is enabled.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringIpv6AddressRemote rdf:type rdf:Property ;
    rdfs:label 'Peering Ipv6 Address Remote' ;
    rdfs:comment 'The remote IPv6 address assigned to the peering partner\'s interface on the remote side of the BGP session, if IPv6 peering is enabled.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peeringLocation rdf:type rdf:Property ;
    rdfs:label 'Peering Location' ;
    rdfs:comment 'Physical location or Point of Presence (POP) site where the peering interconnection is established, including city and facility name.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeFilterPolicy rdf:type rdf:Property ;
    rdfs:label 'Route Filter Policy' ;
    rdfs:comment 'Description of BGP route filtering policies applied to the peering session, including prefix limits and route acceptance criteria.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionUptimeHours rdf:type rdf:Property ;
    rdfs:label 'Session Uptime Hours' ;
    rdfs:comment 'Total uptime of the current BGP session since the last establishment, measured in hours.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Availability Percent' ;
    rdfs:comment 'Contractual uptime availability target for the peering interconnection, expressed as a percentage (e.g., 99.95%).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Ms' ;
    rdfs:comment 'Maximum acceptable round-trip latency for the peering connection, measured in milliseconds, as specified in the SLA.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPacketLossPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Packet Loss Percent' ;
    rdfs:comment 'Maximum acceptable packet loss rate for the peering connection, expressed as a percentage, as specified in the SLA.' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficExchangePolicy rdf:type rdf:Property ;
    rdfs:label 'Traffic Exchange Policy' ;
    rdfs:comment 'Commercial policy governing traffic exchange: settlement-free (no charges), paid transit (upstream provider), paid peering (per-Mbps charges), balanced (equal traffic), or unbalanced (asymmetric traffic).' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficRatioPolicy rdf:type rdf:Property ;
    rdfs:label 'Traffic Ratio Policy' ;
    rdfs:comment 'Policy governing acceptable inbound-to-outbound traffic ratios, if specified in the agreement (e.g., 2:1, balanced).' ;
    rdfs:domain ind:PeeringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceCounterId rdf:type rdf:Property ;
    rdfs:label 'Performance Counter Id' ;
    rdfs:comment 'Primary key for performance_counter' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterValue rdf:type rdf:Property ;
    rdfs:label 'Counter Value' ;
    rdfs:comment 'The raw numeric value of the performance counter as collected from the network element. This is the unprocessed measurement before any KPI calculation or normalization.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Indicates whether the measured performance level (especially if threshold-breaching) has direct impact on customer-facing service quality. Used to prioritize network optimization and remediation efforts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Nms System Name' ;
    rdfs:comment 'The name of the Network Management System or Element Management System that collected and reported this performance measurement. Source system for data lineage and reconciliation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Limit' ;
    rdfs:comment 'The minimum acceptable value for this KPI as defined in the network performance SLA or operational policy. Values below this threshold trigger performance degradation alerts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Limit' ;
    rdfs:comment 'The maximum acceptable value for this KPI (applicable to metrics where higher values indicate problems, such as packet loss or latency). Values above this threshold trigger performance degradation alerts.' ;
    rdfs:domain ind:PerformanceCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Lead Technician Id' ;
    rdfs:comment 'Foreign key linking to workforce.technician. Business justification: Planned outages require lead technician assignment for execution oversight beyond general employee_id. Field operations need to identify skilled technician responsible for outage execution, rollback d' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:maintenanceWindowId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Id' ;
    rdfs:comment 'Foreign key linking to network.maintenance_window. Business justification: A planned outage is scheduled within a maintenance window; adding planned_outage.maintenance_window_id links the two and removes the maintenance_window silo.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceWindow .

ind:primaryPlannedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Planned Employee Id' ;
    rdfs:comment 'Identifier of the lead engineer or technician accountable for the planned outage execution and outcome.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPlannedLastUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Planned Last Updated By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified the planned outage record, used for audit trail and change tracking.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual duration of the planned outage in minutes, calculated from actual start to actual end, used for performance analysis.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServiceIds rdf:type rdf:Property ;
    rdfs:label 'Affected Service Ids' ;
    rdfs:comment 'Comma-separated list of service identifiers that will experience degradation or interruption during the planned outage window.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Backup Verification Status' ;
    rdfs:comment 'Status of pre-outage configuration and data backup verification: verified (backups confirmed), not_verified (pending), not_required (no backup needed), failed (backup verification unsuccessful).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Status' ;
    rdfs:comment 'Status of Change Advisory Board review and approval for the planned outage: pending (awaiting review), approved (authorized to proceed), rejected (denied), not_required (low-risk standard change).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cab Approval Timestamp' ;
    rdfs:comment 'Date and time when the Change Advisory Board approved the planned outage, establishing authorization to proceed.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Business impact classification of the planned outage based on customer count, service criticality, and revenue exposure: critical (major service disruption), high (significant impact), medium (moderate impact), low (minor impact), minimal (negligible impact).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Type' ;
    rdfs:comment 'Classification of the maintenance window: standard (regular scheduled window), emergency (urgent unplanned but scheduled), extended (longer than standard duration), recurring (repeating pattern).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageName rdf:type rdf:Property ;
    rdfs:label 'Outage Name' ;
    rdfs:comment 'Descriptive name or title of the planned outage for identification and reporting purposes.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageOutcome rdf:type rdf:Property ;
    rdfs:label 'Outage Outcome' ;
    rdfs:comment 'Final result of the planned outage execution: successful (all objectives met), partially_successful (some objectives met), failed (objectives not achieved), rolled_back (changes reverted), cancelled (aborted before execution).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageOutcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outage Outcome Notes' ;
    rdfs:comment 'Detailed notes documenting the planned outage execution results, issues encountered, lessons learned, and post-implementation observations.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReason rdf:type rdf:Property ;
    rdfs:label 'Outage Reason' ;
    rdfs:comment 'Detailed business justification and technical rationale for the planned outage, including objectives and expected outcomes.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Outage Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the planned outage, used for NOC coordination and customer communication.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'Expected duration of the planned outage maintenance window in minutes, calculated from planned start to planned end.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postOutageValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Post Outage Validation Status' ;
    rdfs:comment 'Status of post-outage testing and validation to confirm services are restored and functioning correctly: passed (validation successful), failed (issues detected), in_progress (testing underway), not_started (pending).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Level' ;
    rdfs:comment 'Pre-outage risk assessment classification based on complexity, customer impact, and technical risk: low (routine), medium (moderate risk), high (significant risk), critical (high-risk requiring executive approval).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackPlanReference rdf:type rdf:Property ;
    rdfs:label 'Rollback Plan Reference' ;
    rdfs:comment 'Reference identifier or document location for the rollback procedure to be executed if the planned outage encounters critical issues requiring service restoration to previous state.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNotificationLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Notification Lead Time Hours' ;
    rdfs:comment 'Number of hours advance notice provided to customers before the planned outage, used to verify compliance with SLA notification requirements.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorEngineerName rdf:type rdf:Property ;
    rdfs:label 'Vendor Engineer Name' ;
    rdfs:comment 'Name of the vendor engineer or technician supporting the planned outage execution, if vendor support is required.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableNetworkDomain rdf:type rdf:Property ;
    rdfs:label 'Applicable Network Domain' ;
    rdfs:comment 'Network domain where this QoS profile is enforced. RAN for radio access network, Core for packet core (EPC/5GC), Transport for IP/MPLS backhaul, All for end-to-end enforcement.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTechnology rdf:type rdf:Property ;
    rdfs:label 'Applicable Technology' ;
    rdfs:comment 'Network technology or service platform where this QoS profile is applicable. Supports LTE, 5G NR, VoLTE, IMS, MPLS, SD-WAN and other technology-specific QoS implementations.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Arp Priority Level' ;
    rdfs:comment 'Allocation and Retention Priority level (1-15) used for admission control decisions. Lower values indicate higher priority for resource allocation and retention.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averagingWindowMs rdf:type rdf:Property ;
    rdfs:label 'Averaging Window Ms' ;
    rdfs:comment 'Time window in milliseconds over which bit rate guarantees and measurements are averaged for GBR bearers. Used for traffic policing and shaping calculations.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burstSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Burst Size Bytes' ;
    rdfs:comment 'Maximum burst size in bytes allowed for traffic shaping token bucket algorithm. Defines how much traffic can exceed the sustained rate in short bursts.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargingImpact rdf:type rdf:Property ;
    rdfs:label 'Charging Impact' ;
    rdfs:comment 'Indicates how this QoS profile impacts subscriber charging. Premium for higher-tier billing, Standard for normal rates, Zero-rated for excluded from data caps, Sponsored for third-party paid.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationTemplate rdf:type rdf:Property ;
    rdfs:label 'Configuration Template' ;
    rdfs:comment 'Reference to the network configuration template or policy map used to implement this QoS profile across network elements (NMS/EMS template identifier).' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congestionNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Congestion Notification Enabled' ;
    rdfs:comment 'Indicates whether Explicit Congestion Notification is enabled for this QoS profile to signal network congestion without dropping packets.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dscpValue rdf:type rdf:Property ;
    rdfs:label 'Dscp Value' ;
    rdfs:comment '6-bit DSCP marking value (0-63) used in IP packet headers for traffic classification and priority treatment in IP transport and MPLS networks.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiveQiValue rdf:type rdf:Property ;
    rdfs:label 'Five Qi Value' ;
    rdfs:comment '5G QoS Identifier scalar value (1-85 standardized, 128-254 operator-specific) that defines QoS characteristics for 5G NR bearers including resource type, priority level, packet delay budget, and packet error rate.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedBitRateDownlinkKbps rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Bit Rate Downlink Kbps' ;
    rdfs:comment 'Minimum downlink bit rate in kbps that the network guarantees to provide for GBR bearers. Null for non-GBR profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedBitRateUplinkKbps rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Bit Rate Uplink Kbps' ;
    rdfs:comment 'Minimum uplink bit rate in kbps that the network guarantees to provide for GBR bearers. Null for non-GBR profiles.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBitRateDownlinkKbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Bit Rate Downlink Kbps' ;
    rdfs:comment 'Maximum downlink bit rate in kbps that the bearer is allowed to utilize. Used for traffic shaping and policing to prevent bandwidth oversubscription.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBitRateUplinkKbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Bit Rate Uplink Kbps' ;
    rdfs:comment 'Maximum uplink bit rate in kbps that the bearer is allowed to utilize. Used for traffic shaping and policing to prevent bandwidth oversubscription.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkQosProfileDescription rdf:type rdf:Property ;
    rdfs:label 'Network Qos Profile Description' ;
    rdfs:comment 'Detailed description of the QoS profile including its intended use cases, traffic characteristics, and configuration rationale.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packetDelayBudgetMs rdf:type rdf:Property ;
    rdfs:label 'Packet Delay Budget Ms' ;
    rdfs:comment 'Maximum allowable one-way packet delay in milliseconds from UE to gateway for this QoS profile. Critical for real-time services like VoLTE and video conferencing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetErrorRate rdf:type rdf:Property ;
    rdfs:label 'Packet Error Rate' ;
    rdfs:comment 'Maximum acceptable packet error rate expressed as a decimal fraction (e.g., 0.000001 for 10^-6). Defines the upper bound for packet loss tolerance for this QoS class.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionCapability rdf:type rdf:Property ;
    rdfs:label 'Preemption Capability' ;
    rdfs:comment 'Indicates whether this QoS profile can trigger preemption of lower-priority bearers during resource congestion to establish or maintain its own bearer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionVulnerability rdf:type rdf:Property ;
    rdfs:label 'Preemption Vulnerability' ;
    rdfs:comment 'Indicates whether bearers using this QoS profile can be preempted by higher-priority bearers during resource congestion.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qciValue rdf:type rdf:Property ;
    rdfs:label 'Qci Value' ;
    rdfs:comment 'QoS Class Identifier for LTE networks, a scalar value (1-9 standardized, 128-254 operator-specific) that defines bearer-level QoS characteristics including priority, packet delay budget, and packet error loss rate.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficShapingEnabled rdf:type rdf:Property ;
    rdfs:label 'Traffic Shaping Enabled' ;
    rdfs:comment 'Indicates whether traffic shaping is enabled for this QoS profile to smooth traffic bursts and enforce maximum bit rate limits.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorSpecificParameters rdf:type rdf:Property ;
    rdfs:label 'Vendor Specific Parameters' ;
    rdfs:comment 'JSON or key-value string containing vendor-specific QoS parameters for Nokia, Ericsson, or other equipment vendors that extend standard 3GPP QoS attributes.' ;
    rdfs:domain ind:NetworkQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rf Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: RAN cells require assigned RF engineers for optimization, troubleshooting, and performance management. Business process: cell performance degradation triggers work assignment to responsible engineer f' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:servingSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Serving Subscriber Id' ;
    rdfs:comment 'Foreign key linking to customer.subscriber. Business justification: RAN cells track currently-served or last-served subscriber for handover decisions, radio resource management, coverage analysis. Core mobile network operation: cell-to-subscriber association drives re' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:beamformingEnabled rdf:type rdf:Property ;
    rdfs:label 'Beamforming Enabled' ;
    rdfs:comment 'Indicates whether advanced beamforming techniques are enabled. Beamforming directs radio signals toward specific users, improving signal quality and capacity.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierAggregationEnabled rdf:type rdf:Property ;
    rdfs:label 'Carrier Aggregation Enabled' ;
    rdfs:comment 'Indicates whether carrier aggregation is enabled for this cell. CA combines multiple frequency bands to increase throughput in LTE and 5G networks.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Carrier Frequency Mhz' ;
    rdfs:comment 'Center frequency of the carrier in megahertz. The primary operating frequency for the cell\'s radio transmission.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellActivationDate rdf:type rdf:Property ;
    rdfs:label 'Cell Activation Date' ;
    rdfs:comment 'Date when the cell was first activated and began serving traffic. Used for lifecycle tracking and network evolution analysis.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cellCapacityUsers rdf:type rdf:Property ;
    rdfs:label 'Cell Capacity Users' ;
    rdfs:comment 'Maximum number of concurrent users the cell is designed to support. Based on spectrum allocation, technology, and configuration.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Cell Deactivation Date' ;
    rdfs:comment 'Date when the cell was deactivated or decommissioned. Null for active cells. Used for historical analysis and asset lifecycle management.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cellGlobalIdentity rdf:type rdf:Property ;
    rdfs:label 'Cell Global Identity' ;
    rdfs:comment 'Globally unique cell identifier combining MCC, MNC, LAC/TAC, and Cell ID. Format varies by technology: CGI for 2G/3G, ECGI for LTE, NCI for 5G NR. Used for cell identification in handovers and network operations.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellName rdf:type rdf:Property ;
    rdfs:label 'Cell Name' ;
    rdfs:comment 'Human-readable name assigned to the cell for operational identification and network management purposes. Typically includes site identifier and sector information.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellOperationalState rdf:type rdf:Property ;
    rdfs:label 'Cell Operational State' ;
    rdfs:comment 'Current operational status of the cell. Indicates whether the cell is serving traffic, under maintenance, or planned for deployment.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentScenario rdf:type rdf:Property ;
    rdfs:label 'Deployment Scenario' ;
    rdfs:comment 'The deployment environment scenario for the cell. Influences planning parameters, capacity expectations, and performance benchmarks.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricalTiltDegrees rdf:type rdf:Property ;
    rdfs:label 'Electrical Tilt Degrees' ;
    rdfs:comment 'Electronic beam steering tilt angle in degrees, adjustable via Remote Electrical Tilt (RET) systems. Enables dynamic coverage optimization.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energySavingMode rdf:type rdf:Property ;
    rdfs:label 'Energy Saving Mode' ;
    rdfs:comment 'Energy saving configuration for the cell. Adaptive mode dynamically adjusts power based on traffic load to reduce operational expenditure.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverHysteresisDb rdf:type rdf:Property ;
    rdfs:label 'Handover Hysteresis Db' ;
    rdfs:comment 'Hysteresis value in decibels to prevent ping-pong handovers between cells. Stabilizes mobility decisions in border areas.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverMarginDb rdf:type rdf:Property ;
    rdfs:label 'Handover Margin Db' ;
    rdfs:comment 'Signal strength margin in decibels required to trigger handover to neighboring cells. Critical parameter for mobility management and call continuity.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastConfigurationChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Configuration Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent configuration change applied to the cell. Critical for change management and troubleshooting.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadBalancingEnabled rdf:type rdf:Property ;
    rdfs:label 'Load Balancing Enabled' ;
    rdfs:comment 'Indicates whether automatic load balancing is enabled to distribute traffic across neighboring cells during congestion.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumCellRangeMeters rdf:type rdf:Property ;
    rdfs:label 'Maximum Cell Range Meters' ;
    rdfs:comment 'Maximum designed coverage radius of the cell in meters. Used for network planning and capacity dimensioning.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mechanicalTiltDegrees rdf:type rdf:Property ;
    rdfs:label 'Mechanical Tilt Degrees' ;
    rdfs:comment 'Physical downward tilt angle of the antenna in degrees. Used to control vertical coverage and reduce interference.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mimoConfiguration rdf:type rdf:Property ;
    rdfs:label 'Mimo Configuration' ;
    rdfs:comment 'MIMO antenna configuration indicating the number of transmit and receive antenna paths. Higher configurations enable greater spectral efficiency and throughput.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCellIdentifier rdf:type rdf:Property ;
    rdfs:label 'Physical Cell Identifier' ;
    rdfs:comment 'Physical layer cell identity used for cell identification during initial access and handover. Range 0-503 for LTE, 0-1007 for 5G NR.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:radioAccessTechnology rdf:type rdf:Property ;
    rdfs:label 'Radio Access Technology' ;
    rdfs:comment 'Specific radio access technology standard implemented by the cell. More granular than technology generation, specifying the exact air interface protocol.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorNumber rdf:type rdf:Property ;
    rdfs:label 'Sector Number' ;
    rdfs:comment 'Identifier for the sector within the base station site. Typically indicates the directional coverage area (e.g., Alpha, Beta, Gamma or 1, 2, 3).' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToTriggerMs rdf:type rdf:Property ;
    rdfs:label 'Time To Trigger Ms' ;
    rdfs:comment 'Duration in milliseconds that handover conditions must be met before triggering handover. Prevents unnecessary handovers due to temporary signal fluctuations.' ;
    rdfs:domain ind:RanCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Area Code' ;
    rdfs:comment 'Tracking Area Code for LTE/5G or Location Area Code for 2G/3G. Groups cells for mobility management and paging optimization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdwanPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sdwan Policy Id' ;
    rdfs:comment 'Unique identifier for the SD-WAN policy configuration record. Primary key for the SD-WAN policy entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdwanPolicy .

ind:policyAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Policy Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: SD-WAN policies require network engineers for creation, modification, and troubleshooting. Business process: policy changes require engineer approval, implementation tracking, and issue resolution ass' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationClassificationRules rdf:type rdf:Property ;
    rdfs:label 'Application Classification Rules' ;
    rdfs:comment 'Encoded rules defining how network traffic is classified by application type, protocol, port, or Deep Packet Inspection (DPI) signatures to enable application-aware routing decisions.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerVpnReference rdf:type rdf:Property ;
    rdfs:label 'Customer Vpn Reference' ;
    rdfs:comment 'Reference to the enterprise customer VPN overlay to which this SD-WAN policy is associated, enabling multi-tenant policy isolation.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationNetworkSegment rdf:type rdf:Property ;
    rdfs:label 'Destination Network Segment' ;
    rdfs:comment 'Destination network segment, subnet, or VLAN identifier to which this policy applies, enabling granular traffic control based on target.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Encryption algorithm applied to traffic matching this policy when encryption is required: AES-256, AES-128, IPsec, TLS 1.3, or none.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether traffic matching this policy must be encrypted, enforcing security requirements for sensitive data transmission over SD-WAN overlays.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverRevertDelaySeconds rdf:type rdf:Property ;
    rdfs:label 'Failover Revert Delay Seconds' ;
    rdfs:comment 'Time delay in seconds before reverting traffic back to the primary path after the primary path recovers from a failure, preventing flapping during intermittent issues.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverTriggerCondition rdf:type rdf:Property ;
    rdfs:label 'Failover Trigger Condition' ;
    rdfs:comment 'Conditions that automatically trigger failover to backup path, such as link down, SLA threshold breach, or manual override. May include complex boolean logic combining multiple metrics.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firewallPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Firewall Policy Reference' ;
    rdfs:comment 'Reference to the associated firewall policy applied in conjunction with this SD-WAN policy for integrated security enforcement.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoLocationFilter rdf:type rdf:Property ;
    rdfs:label 'Geo Location Filter' ;
    rdfs:comment 'Geographic location or region filter defining where this policy applies, enabling location-aware routing for distributed enterprise networks.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadBalancingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Load Balancing Algorithm' ;
    rdfs:comment 'Algorithm used for distributing traffic across multiple paths when load balancing is enabled: round-robin, weighted distribution, least latency, least packet loss, or session-based persistence.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nmsSystemSource rdf:type rdf:Property ;
    rdfs:label 'Nms System Source' ;
    rdfs:comment 'Name or identifier of the Network Management System (NMS) or Element Management System (EMS) that is the authoritative source for this policy configuration, such as Nokia NetAct or Ericsson Network Manager.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathPreference rdf:type rdf:Property ;
    rdfs:label 'Path Preference' ;
    rdfs:comment 'Preferred transport path selection strategy for traffic routing: MPLS primary (prioritize MPLS links), broadband primary (prioritize internet broadband), LTE primary (prioritize cellular), load balanced (distribute across paths), or dynamic (real-time selection based on conditions).' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Policy Identifier' ;
    rdfs:comment 'Externally-known unique code or reference number for the SD-WAN policy used in network management systems and customer communications.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of this policy configuration, incremented with each modification to support version control and rollback capabilities.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portRangeFilter rdf:type rdf:Property ;
    rdfs:label 'Port Range Filter' ;
    rdfs:comment 'TCP/UDP port or port range filter specification defining which application ports are subject to this policy, enabling port-based traffic classification.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolFilter rdf:type rdf:Property ;
    rdfs:label 'Protocol Filter' ;
    rdfs:comment 'Network protocol filter specification (TCP, UDP, ICMP, etc.) defining which protocols are subject to this policy, enabling protocol-specific routing decisions.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBandwidthThresholdMbps rdf:type rdf:Property ;
    rdfs:label 'Sla Bandwidth Threshold Mbps' ;
    rdfs:comment 'Minimum guaranteed bandwidth in megabits per second defined in the SLA for this policy to ensure adequate capacity for business-critical applications.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaJitterThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Sla Jitter Threshold Ms' ;
    rdfs:comment 'Maximum acceptable network jitter (latency variation) in milliseconds defined in the SLA for this policy. Critical for real-time applications like VoIP and video conferencing.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaLatencyThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Threshold Ms' ;
    rdfs:comment 'Maximum acceptable network latency in milliseconds defined in the SLA for this policy. Exceeding this threshold may trigger failover or path re-selection.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaPacketLossThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Packet Loss Threshold Percent' ;
    rdfs:comment 'Maximum acceptable packet loss percentage defined in the SLA for this policy. Exceeding this threshold indicates degraded network quality requiring remediation.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceNetworkSegment rdf:type rdf:Property ;
    rdfs:label 'Source Network Segment' ;
    rdfs:comment 'Source network segment, subnet, or VLAN identifier to which this policy applies, enabling granular traffic control based on origin.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBasedActivation rdf:type rdf:Property ;
    rdfs:label 'Time Based Activation' ;
    rdfs:comment 'Time-based schedule defining when this policy is active, supporting business-hours routing, maintenance windows, or time-of-day traffic optimization.' ;
    rdfs:domain ind:SdwanPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topologyId rdf:type rdf:Property ;
    rdfs:label 'Topology Id' ;
    rdfs:comment 'Primary key for topology' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupLinkId rdf:type rdf:Property ;
    rdfs:label 'Backup Link Id' ;
    rdfs:comment 'Reference to the backup or protection link used for failover when this primary link fails. Part of the protection scheme topology.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionLink .

ind:destinationNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Destination Network Element Id' ;
    rdfs:comment 'Reference to the terminating network element (node) of this topology link. Represents the Z-end of the connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:sourceNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Source Network Element Id' ;
    rdfs:comment 'Reference to the originating network element (node) of this topology link. Represents the A-end of the connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:destinationInterfaceName rdf:type rdf:Property ;
    rdfs:label 'Destination Interface Name' ;
    rdfs:comment 'Name or identifier of the physical or logical interface on the destination network element where the link terminates. Used for detailed topology mapping and troubleshooting.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBidirectional rdf:type rdf:Property ;
    rdfs:label 'Is Bidirectional' ;
    rdfs:comment 'Indicates whether the link supports bidirectional traffic flow or is unidirectional. Affects path computation and traffic engineering algorithms.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProtected rdf:type rdf:Property ;
    rdfs:label 'Is Protected' ;
    rdfs:comment 'Indicates whether the link has an active protection scheme configured for redundancy and failover. Critical for Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Indicates whether the link is a virtual or logical connection (e.g., Software-Defined Networking (SDN) or Network Functions Virtualization (NFV) overlay) rather than a physical connection.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Link Capacity Mbps' ;
    rdfs:comment 'Maximum bandwidth capacity of the link measured in megabits per second. Critical for capacity planning, traffic engineering, and Quality of Service (QoS) management.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkCost rdf:type rdf:Property ;
    rdfs:label 'Link Cost' ;
    rdfs:comment 'Routing protocol cost or metric assigned to the link for path computation algorithms. Used in Open Shortest Path First (OSPF), Intermediate System to Intermediate System (IS-IS), and other routing protocols.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Link Distance Km' ;
    rdfs:comment 'Physical or logical distance of the link in kilometers. Used for latency calculations, signal degradation analysis, and network planning.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkIdentifier rdf:type rdf:Property ;
    rdfs:label 'Link Identifier' ;
    rdfs:comment 'Externally-known unique identifier for the network link, used in network management systems and topology diagrams. Typically follows naming conventions from Nokia NetAct or Ericsson Network Manager.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Link Latency Ms' ;
    rdfs:comment 'Measured or calculated propagation delay across the link in milliseconds. Critical for Service Level Agreement (SLA) compliance and Quality of Service (QoS) assurance.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkName rdf:type rdf:Property ;
    rdfs:label 'Link Name' ;
    rdfs:comment 'Human-readable name or label for the network link, used for identification in network operations and documentation.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkType rdf:type rdf:Property ;
    rdfs:label 'Link Type' ;
    rdfs:comment 'Classification of the physical or logical medium used for the network link. Determines transmission characteristics and capacity planning parameters.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mplsLabel rdf:type rdf:Property ;
    rdfs:label 'Mpls Label' ;
    rdfs:comment 'MPLS label assigned to the Label Switched Path (LSP) for this link. Used for traffic engineering and Quality of Service (QoS) in MPLS networks.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceInterfaceName rdf:type rdf:Property ;
    rdfs:label 'Source Interface Name' ;
    rdfs:comment 'Name or identifier of the physical or logical interface on the source network element where the link originates. Used for detailed topology mapping and troubleshooting.' ;
    rdfs:domain ind:Topology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEnterpriseSiteId rdf:type rdf:Property ;
    rdfs:label 'Customer Enterprise Site Id' ;
    rdfs:comment 'Foreign key linking to enterprise.site. Business justification: Transmission links terminate at enterprise customer sites for dedicated WAN/MPLS connectivity. Core business process: enterprise circuit provisioning and inventory management for point-to-point and MP' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseSite .

ind:fiberLeaseId rdf:type rdf:Property ;
    rdfs:label 'Fiber Lease Id' ;
    rdfs:comment 'Circuit identifier provided by the leasing carrier for leased line links. Null for owned infrastructure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiberLease .

ind:leaseProviderPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lease Provider Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: Transmission links are frequently leased from infrastructure partners (fiber providers, dark fiber lessors). Settlement reconciliation, invoice validation, SLA tracking, and dispute resolution require' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:primaryTransmissionLocationSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Transmission Location Site Id' ;
    rdfs:comment 'Identifier of the network site or Point of Presence (POP) at the A-end (originating end) of the transmission link.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationSite .

ind:primaryTransmissionNetworkEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Transmission Network Equipment Id' ;
    rdfs:comment 'Identifier of the network element or equipment at the A-end of the transmission link (e.g., OLT, DSLAM, BNG, router).' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkEquipment .

ind:aEndPort rdf:type rdf:Property ;
    rdfs:label 'A End Port' ;
    rdfs:comment 'Port or interface designation on the A-end equipment where the transmission link terminates.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmSeverityThreshold rdf:type rdf:Property ;
    rdfs:label 'Alarm Severity Threshold' ;
    rdfs:comment 'Minimum alarm severity level configured for fault management notifications for this transmission link.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attenuationDb rdf:type rdf:Property ;
    rdfs:label 'Attenuation Db' ;
    rdfs:comment 'Signal attenuation or loss measured in decibels for the transmission link, applicable to fiber and microwave links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberPairCount rdf:type rdf:Property ;
    rdfs:label 'Fiber Pair Count' ;
    rdfs:comment 'Number of fiber pairs (transmit/receive pairs) available in the fiber cable for this link. Null for non-fiber links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Route Description' ;
    rdfs:comment 'Textual description of the geographic route or path taken by the transmission link, including key waypoints or conduit paths.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseContractEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease Contract End Date' ;
    rdfs:comment 'End date of the lease contract for leased line circuits. Null for owned infrastructure.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseMonthlyCost rdf:type rdf:Property ;
    rdfs:label 'Lease Monthly Cost' ;
    rdfs:comment 'Monthly recurring cost for leased transmission links. Null for owned infrastructure. Business-confidential financial data.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current operational state of the transmission link in its lifecycle.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyGroupCode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Group Code' ;
    rdfs:comment 'Identifier of the redundancy or protection group to which this transmission link belongs, used for coordinated protection switching.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Route Distance Km' ;
    rdfs:comment 'Physical distance of the transmission link route measured in kilometers.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Percent' ;
    rdfs:comment 'Current utilization percentage of the transmission link capacity, calculated from performance monitoring data.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendor rdf:type rdf:Property ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Manufacturer or vendor of the transmission equipment and infrastructure for this link.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wavelengthCount rdf:type rdf:Property ;
    rdfs:label 'Wavelength Count' ;
    rdfs:comment 'Number of optical wavelengths (lambdas) supported on the fiber link for Dense Wavelength Division Multiplexing (DWDM) systems. Null for non-DWDM links.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zEndPort rdf:type rdf:Property ;
    rdfs:label 'Z End Port' ;
    rdfs:comment 'Port or interface designation on the Z-end equipment where the transmission link terminates.' ;
    rdfs:domain ind:TransmissionLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentId rdf:type rdf:Property ;
    rdfs:label 'Appointment Id' ;
    rdfs:comment 'Unique surrogate identifier for the field technician appointment record within the order fulfillment domain. Primary key for the appointment data product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:depotId rdf:type rdf:Property ;
    rdfs:label 'Depot Id' ;
    rdfs:comment 'Foreign key linking to workforce.depot. Business justification: Appointments are scheduled from depots managing technician territories and service zones. Essential for capacity planning, technician assignment optimization, and tracking which facility supports cust' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual date and time the field technician arrived at the customer premises. Compared against scheduled_start_time to measure on-time arrival performance and SLA adherence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'Actual date and time the field technician completed the on-site work and closed the appointment. Used to calculate job duration, MTTR (Mean Time to Repair), and workforce productivity metrics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Externally visible, human-readable appointment reference number communicated to the customer and field technician. Follows the format APT-NNNNNNNNNN. Used in customer notifications, WFM dispatch sheets, and trouble ticket references.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle state of the appointment. Drives downstream workflow actions: SCHEDULED (created, not yet confirmed), CONFIRMED (customer acknowledged), COMPLETED (work done), MISSED (technician or customer no-show), RESCHEDULED (new slot assigned), CANCELLED (appointment voided).' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the on-site work to be performed. Drives technician skill matching, equipment pre-staging, and estimated duration in WFM. [ENUM-REF-CANDIDATE: FTTH_INSTALLATION|GPON_INSTALLATION|CPE_SWAP|ONT_REPLACEMENT|ENTERPRISE_CIRCUIT_COMMISSIONING|FAULT_REPAIR|UPGRADE|DOWNGRADE|DISCONNECTION — promote to reference product]' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes entered by the field technician upon appointment completion. Captures work performed, issues encountered, materials used, and any follow-up actions required. Populated when appointment_status is COMPLETED.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationChannel rdf:type rdf:Property ;
    rdfs:label 'Confirmation Channel' ;
    rdfs:comment 'Channel through which the customer confirmed the appointment. Supports omnichannel analytics and confirmation effectiveness reporting. Populated only when customer_confirmed is True.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the customer confirmed the appointment. Populated only when customer_confirmed is True. Used for lead-time analysis and confirmation workflow SLA measurement.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cpeModel rdf:type rdf:Property ;
    rdfs:label 'Cpe Model' ;
    rdfs:comment 'Model identifier of the Customer Premises Equipment (CPE) or Optical Network Terminal (ONT) to be installed, swapped, or replaced during the appointment. Used for pre-staging equipment and inventory reservation.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Cpe Serial Number' ;
    rdfs:comment 'Serial number of the specific CPE or ONT unit assigned for installation or replacement. Enables asset tracking, warranty management, and post-installation inventory reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConfirmed rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmed' ;
    rdfs:comment 'Indicates whether the customer has explicitly confirmed the scheduled appointment. True = confirmed by customer; False = not yet confirmed. Drives automated reminder workflows and no-show risk scoring.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Full name of the customer or on-site contact person who will be present during the appointment. Required for technician identification and access coordination.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the on-site contact person for appointment day coordination, technician arrival notification, and access instructions. Follows ITU-T E.164 format.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Work Order Number' ;
    rdfs:comment 'External work order reference number generated by Granite Telecommunications WFM upon technician dispatch. Used to cross-reference appointment records with WFM dispatch sheets and field activity logs.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete the on-site work. Derived from appointment type and technology type during WFM scheduling. Used for route optimization and technician capacity planning.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpReason rdf:type rdf:Property ;
    rdfs:label 'Follow Up Reason' ;
    rdfs:comment 'Free-text description of why a follow-up appointment or action is required. Populated only when follow_up_required is True. Used for work order creation and technician briefing.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up appointment or action is required after this appointment. True = follow-up needed (e.g., incomplete installation, pending network provisioning). Triggers creation of a new appointment or trouble ticket.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedReason rdf:type rdf:Property ;
    rdfs:label 'Missed Reason' ;
    rdfs:comment 'Reason code explaining why the appointment was missed. Populated only when appointment_status is MISSED. Used for SLA breach analysis, customer compensation workflows, and workforce accountability reporting.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osmTaskReference rdf:type rdf:Property ;
    rdfs:label 'Osm Task Reference' ;
    rdfs:comment 'Task identifier from Oracle Communications Order and Service Management (OSM) that corresponds to the appointment fulfillment step in the order orchestration workflow. Enables end-to-end order traceability.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'Number of times this appointment has been rescheduled. Tracks appointment instability, customer experience impact, and operational efficiency. High reschedule counts may trigger escalation workflows.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Reschedule Reason' ;
    rdfs:comment 'Reason code for the most recent reschedule of this appointment. Populated when appointment_status is RESCHEDULED. Used for root cause analysis and operational improvement. [ENUM-REF-CANDIDATE: CUSTOMER_REQUEST|TECHNICIAN_UNAVAILABLE|WEATHER|EQUIPMENT_NOT_READY|ACCESS_ISSUE|NETWORK_DEPENDENCY|OTHER — promote to reference product]' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Calendar date on which the field technician appointment is scheduled to occur. Used for day-level planning, route optimization, and customer communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and time at which the appointment window is scheduled to end. Defines the committed service window communicated to the customer and used for SLA compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time at which the appointment window is scheduled to begin. Used for technician dispatch, customer notification, and SLA (Service Level Agreement) measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaCommitmentMet rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Met' ;
    rdfs:comment 'Indicates whether the appointment was completed within the committed SLA (Service Level Agreement) window. True = SLA met; False = SLA breached. Drives regulatory reporting, customer compensation, and performance dashboards.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wfmJobReference rdf:type rdf:Property ;
    rdfs:label 'Wfm Job Reference' ;
    rdfs:comment 'Unique job identifier assigned by Granite Telecommunications Workforce Management system for this appointment. Enables bidirectional traceability between the order domain and the WFM dispatch system.' ;
    rdfs:domain ind:Appointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkOrderId rdf:type rdf:Property ;
    rdfs:label 'Bulk Order Id' ;
    rdfs:comment 'Unique identifier for the bulk order submission. Primary key for the bulk order entity.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when the bulk order processing was completed (all individual orders reached terminal state).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bulkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Bulk Order Number' ;
    rdfs:comment 'Externally visible business identifier for the bulk order submission, used for customer communication and tracking. Format: BLK followed by 10 digits.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkOrderType rdf:type rdf:Property ;
    rdfs:label 'Bulk Order Type' ;
    rdfs:comment 'Category of bulk order operation being requested across all individual orders within the batch. Determines decomposition strategy and fulfillment orchestration. [ENUM-REF-CANDIDATE: new_activation|upgrade|downgrade|disconnection|mnp_port_in|change_of_service|site_rollout|batch_provisioning — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the bulk order cancellation.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Committed Completion Date' ;
    rdfs:comment 'Service provider committed delivery date for bulk order completion, based on capacity planning and SLA agreements.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decompositionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decomposition Completed Timestamp' ;
    rdfs:comment 'Date and time when all individual fulfillment orders were successfully created and queued from the bulk order batch.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decompositionStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decomposition Started Timestamp' ;
    rdfs:comment 'Date and time when the bulk order began decomposition into individual fulfillment orders for orchestration.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decompositionStrategy rdf:type rdf:Property ;
    rdfs:label 'Decomposition Strategy' ;
    rdfs:comment 'Strategy used to decompose the bulk order into individual fulfillment orders (sequential processing, parallel processing, or hybrid approach).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorSummaryReportUrl rdf:type rdf:Property ;
    rdfs:label 'Error Summary Report Url' ;
    rdfs:comment 'URL or file path to the detailed error report listing all validation failures and processing errors for failed order lines.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCount rdf:type rdf:Property ;
    rdfs:label 'Failure Count' ;
    rdfs:comment 'Number of individual order lines that have failed validation, decomposition, or fulfillment within this bulk order batch. Requires remediation or manual intervention.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingCount rdf:type rdf:Property ;
    rdfs:label 'Pending Count' ;
    rdfs:comment 'Number of individual order lines still in progress or awaiting fulfillment within this bulk order batch.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Requested Completion Date' ;
    rdfs:comment 'Customer-requested target date by which all individual orders within the bulk batch should be fulfilled and activated.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Timestamp' ;
    rdfs:comment 'Date and time when the SLA breach was detected for this bulk order, triggering escalation and notification workflows.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Submission File Format' ;
    rdfs:comment 'Data format of the bulk order submission file. Determines parsing logic and validation schema applied during intake processing.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFileName rdf:type rdf:Property ;
    rdfs:label 'Submission File Name' ;
    rdfs:comment 'Original file name of the uploaded bulk order file, if submission method was file-based. Used for audit trail and troubleshooting.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the bulk order was initially submitted to the order management system. Marks the start of SLA measurement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submitterContactEmail rdf:type rdf:Property ;
    rdfs:label 'Submitter Contact Email' ;
    rdfs:comment 'Email address of the individual who submitted the bulk order, used for status notifications and error report delivery.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterContactName rdf:type rdf:Property ;
    rdfs:label 'Submitter Contact Name' ;
    rdfs:comment 'Name of the individual who submitted the bulk order on behalf of the enterprise or partner organization.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterContactPhone rdf:type rdf:Property ;
    rdfs:label 'Submitter Contact Phone' ;
    rdfs:comment 'Phone number of the individual who submitted the bulk order, used for urgent escalations and clarifications.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittingEntityType rdf:type rdf:Property ;
    rdfs:label 'Submitting Entity Type' ;
    rdfs:comment 'Classification of the organization type submitting the bulk order request. Determines routing, approval workflows, and SLA tiers.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCount rdf:type rdf:Property ;
    rdfs:label 'Success Count' ;
    rdfs:comment 'Number of individual order lines that have been successfully fulfilled and completed within this bulk order batch.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Total number of individual order lines or subscriber records included in the bulk order submission. Used for progress tracking and capacity planning.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Aggregate monetary value of all individual orders within the bulk order batch, representing total revenue opportunity.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Completed Timestamp' ;
    rdfs:comment 'Date and time when intake validation and business rule checks were completed for the bulk order submission.' ;
    rdfs:domain ind:BulkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowTemplateName rdf:type rdf:Property ;
    rdfs:label 'Workflow Template Name' ;
    rdfs:comment 'Name of the workflow template used for orchestrating this bulk order type (e.g., Enterprise_Site_Rollout, MVNO_Batch_Activation).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'The outcome of the credit assessment performed during order processing. APPROVED: customer passed credit check. DECLINED: order blocked due to credit failure. WAIVED: credit check bypassed (e.g., existing premium customer). Drives order workflow progression in Oracle Communications OSM.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalOrderReference rdf:type rdf:Property ;
    rdfs:label 'External Order Reference' ;
    rdfs:comment 'The order reference number from an external or upstream system (e.g., Salesforce CRM opportunity ID, dealer portal order number, B2B customer\'s purchase order number). Enables cross-system order tracing and reconciliation.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutCategory rdf:type rdf:Property ;
    rdfs:label 'Fallout Category' ;
    rdfs:comment 'Categorical classification of the order fallout reason, enabling structured reporting and trend analysis on order failure types. Complements fallout_reason with a standardized taxonomy for operational dashboards.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutReason rdf:type rdf:Property ;
    rdfs:label 'Fallout Reason' ;
    rdfs:comment 'Descriptive reason code or message explaining why the fulfillment order failed or was placed on hold during orchestration. Populated by Oracle Communications OSM when order_status transitions to FAILED or ON_HOLD. Critical for fallout management, root cause analysis, and process improvement.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Field Work Required' ;
    rdfs:comment 'Indicates whether this fulfillment order requires a field technician dispatch for physical installation or maintenance (e.g., FTTH CPE installation, ONT provisioning). Drives integration with Granite Telecommunications Workforce Management for scheduling and dispatch.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryOrder rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Order' ;
    rdfs:comment 'Indicates whether this fulfillment order is subject to specific regulatory mandates (e.g., FCC MNP porting deadlines, emergency service provisioning, Ofcom consumer protection rules). Regulatory orders receive elevated priority and mandatory compliance reporting.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpDonorOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Mnp Donor Operator Code' ;
    rdfs:comment 'For MNP_PORT_IN orders: the network operator code of the donor (losing) operator from whom the mobile number is being ported. Mandatory for MNP regulatory compliance reporting to FCC/Ofcom. Null for non-MNP order types.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnpRecipientOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Mnp Recipient Operator Code' ;
    rdfs:comment 'For MNP_PORT_OUT orders: the network operator code of the recipient (gaining) operator to whom the mobile number is being ported. Used for inter-operator coordination and MNP regulatory reporting. Null for non-MNP order types.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The sales or service channel through which the fulfillment order was submitted. Used for channel performance analytics, cost-to-serve analysis, and omnichannel reporting. [ENUM-REF-CANDIDATE: ONLINE|RETAIL_STORE|CALL_CENTER|DEALER|SELF_SERVICE|B2B_PORTAL|FIELD_SALES — promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the fulfillment order. Communicated to customers, field technicians, and partner systems. Sourced from Oracle Communications Order and Service Management (OSM) as the canonical order reference number.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Order Source System' ;
    rdfs:comment 'The originating system or application from which the fulfillment order was submitted. Used for channel attribution, integration troubleshooting, and data lineage tracking. [ENUM-REF-CANDIDATE: OSM|SALESFORCE_CRM|SELF_SERVICE_PORTAL|B2B_PORTAL|DEALER_PORTAL|IVR|RETAIL_POS — promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the fulfillment order within the OSS/BSS orchestration workflow. Drives jeopardy management, SLA monitoring, and customer communication triggers. Sourced from Oracle Communications OSM order state machine.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the fulfillment order by the nature of the service change being requested. Drives orchestration workflow selection, SLA type assignment, and regulatory reporting. [ENUM-REF-CANDIDATE: NEW_ACTIVATION|UPGRADE|DOWNGRADE|DISCONNECTION|MNP_PORT_IN|MNP_PORT_OUT|CHANGE_OF_SERVICE — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Porting Authorization Code' ;
    rdfs:comment 'The Porting Authorization Code provided by the donor operator to authorize the number port. Required for MNP_PORT_IN orders to validate the customer\'s right to port. Null for non-MNP order types.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingNumber rdf:type rdf:Property ;
    rdfs:label 'Porting Number' ;
    rdfs:comment 'The MSISDN (mobile phone number) being ported in MNP_PORT_IN or MNP_PORT_OUT orders. Classified as confidential PII as it directly identifies a subscriber. Null for non-MNP order types. Required for NRTRDE and TAP regulatory reporting.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Promised Completion Date' ;
    rdfs:comment 'The date committed to the customer for order fulfillment completion. Used for SLA breach detection, customer communication, and regulatory compliance reporting. Distinct from SLA target hours — this is the customer-facing commitment date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaBreachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Threshold Hours' ;
    rdfs:comment 'The number of hours elapsed from SLA measurement start at which the SLA is formally classified as BREACHED. Typically equals sla_target_hours but may differ for grace-period configurations. Triggers regulatory reporting obligations and penalty calculations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMeasurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement End Event' ;
    rdfs:comment 'The business event that stops the SLA measurement clock for this fulfillment order. Defines what constitutes successful completion for SLA purposes — e.g., SERVICE_ACTIVATED for mobile activations, CPE_INSTALLED for FTTH orders.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMeasurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Start Event' ;
    rdfs:comment 'The business event that triggers the start of SLA measurement clock for this fulfillment order. Varies by order type and SLA type — regulatory MNP orders typically start at ORDER_ACCEPTED, while commercial orders may start at PAYMENT_CONFIRMED.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMeasurementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Start Timestamp' ;
    rdfs:comment 'The precise date and time when the SLA measurement clock started for this fulfillment order, corresponding to the sla_measurement_start_event. Used as the reference point for all SLA elapsed-time calculations and regulatory compliance measurement. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current SLA compliance status of the fulfillment order based on elapsed time versus SLA thresholds. ON_TRACK: within warning threshold. AT_RISK: between warning and breach thresholds. BREACHED: exceeded breach threshold. Primary field for jeopardy detection and regulatory compliance dashboards.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaWarningThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Warning Threshold Hours' ;
    rdfs:comment 'The number of hours elapsed from SLA measurement start at which an AT_RISK warning is triggered for proactive jeopardy management. Must be less than sla_target_hours. Drives automated alerting in NOC and order management dashboards.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique surrogate identifier for each order amendment record in the Telecommunication order management system. Primary key for the order_amendment data product.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Reference to the specific order line item affected by this amendment, when the modification is scoped to a single line rather than the entire order header.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:parentAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Amendment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a prior amendment that this record supersedes or is derived from. Supports amendment chains where a rejected amendment is resubmitted with corrections.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendedFieldName rdf:type rdf:Property ;
    rdfs:label 'Amended Field Name' ;
    rdfs:comment 'The logical name of the order attribute that was changed by this amendment (e.g., appointment_date, delivery_address_id, product_offering_code, service_configuration_value). Enables fine-grained change history and audit trail per field.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment request: PENDING (submitted, awaiting review), APPROVED (authorised by agent or system), REJECTED (denied), APPLIED (successfully propagated to the fulfillment order), WITHDRAWN (retracted by the customer before decision).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Categorises the nature of the post-submission modification: APPOINTMENT_RESCHEDULE (change of installation/delivery date), PRODUCT_CHANGE (swap of selected product or offering), ADDRESS_CHANGE (new delivery or service address), SERVICE_CONFIG_CHANGE (alteration to service parameters), CONTACT_UPDATE (change of contact details), CANCELLATION_REQUEST (request to cancel the order before completion). [ENUM-REF-CANDIDATE: APPOINTMENT_RESCHEDULE|PRODUCT_CHANGE|ADDRESS_CHANGE|SERVICE_CONFIG_CHANGE|CONTACT_UPDATE|CANCELLATION_REQUEST — promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Date and time at which the approved amendment was successfully propagated and applied to the underlying fulfillment order in Oracle Communications Order and Service Management. Null until status reaches APPLIED.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Required' ;
    rdfs:comment 'Indicates whether this amendment triggers a billing adjustment in Amdocs Revenue Management (e.g., pro-rated credit, revised charge). When True, the billing team must process a corresponding adjustment record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costDelta rdf:type rdf:Property ;
    rdfs:label 'Cost Delta' ;
    rdfs:comment 'The incremental cost impact of this amendment on the order, expressed as a signed decimal. Positive values indicate an increase in order cost; negative values indicate a reduction. Used for revenue assurance and billing adjustment workflows in Amdocs Revenue Management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costDeltaCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Delta Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_delta amount (e.g., USD, GBP, EUR). Ensures multi-currency support for international operations.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been formally notified of the amendment outcome (approval, rejection, or application). Supports compliance with customer communication obligations and SLA notification requirements.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Notes' ;
    rdfs:comment 'Free-text field capturing the agent\'s or system\'s assessment of the downstream impact of this amendment on network provisioning, billing, scheduling, or third-party dependencies. Used during the approval workflow.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerInitiated rdf:type rdf:Property ;
    rdfs:label 'Is Customer Initiated' ;
    rdfs:comment 'Distinguishes amendments initiated by the customer from those initiated internally by agents or automated systems (e.g., error corrections, product availability changes). Supports root-cause analysis of amendment volumes and customer experience reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Mnp Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment affects a Mobile Number Portability (MNP) port-in or port-out request associated with the parent order. When True, the MNP coordinator must be notified to update the porting window with the donor or recipient operator.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newCommittedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'New Committed Delivery Date' ;
    rdfs:comment 'The revised committed delivery or installation date resulting from this amendment, applicable when the amendment type is APPOINTMENT_RESCHEDULE or when sla_reset_flag is True. Null if the amendment does not affect the delivery date.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCommittedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Original Committed Delivery Date' ;
    rdfs:comment 'The committed delivery or installation date that was in effect on the parent order before this amendment was applied. Preserved for SLA impact analysis and dispute resolution.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The value of the amended field as it existed on the order before this amendment was applied. Stored as a string to accommodate heterogeneous field types (dates, codes, identifiers, free text). Essential for dispute resolution and rollback.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time at which the amendment was rejected. Null if the amendment was not rejected.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The exact date and time at which the customer or agent submitted the amendment request. This is the principal business event timestamp for the amendment lifecycle and is used for SLA measurement and audit.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingChannel rdf:type rdf:Property ;
    rdfs:label 'Requesting Channel' ;
    rdfs:comment 'The customer interaction channel through which the amendment request was submitted: IVR (Interactive Voice Response), AGENT_ASSISTED (call centre), SELF_SERVICE_WEB, SELF_SERVICE_APP, RETAIL_STORE, CHAT, EMAIL. [ENUM-REF-CANDIDATE: IVR|AGENT_ASSISTED|SELF_SERVICE_WEB|SELF_SERVICE_APP|RETAIL_STORE|CHAT|EMAIL — promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresFieldVisit rdf:type rdf:Property ;
    rdfs:label 'Requires Field Visit' ;
    rdfs:comment 'Indicates whether this amendment necessitates a new or rescheduled field technician visit (e.g., address change for FTTH installation). Triggers workforce management dispatch in Granite Telecommunications Workforce Management when True.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicenowChangeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Servicenow Change Request Reference' ;
    rdfs:comment 'The ServiceNow ITSM Change Request identifier raised to govern the technical configuration changes required to fulfil this amendment. Format: CHG followed by 7 digits. Null if no ITSM change request was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Reset Flag' ;
    rdfs:comment 'Indicates whether applying this amendment resets the SLA clock on the parent order. True when the amendment materially changes the fulfillment scope (e.g., address change, product swap) and the committed delivery date must be recalculated. Critical for SLA compliance reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemAmendmentRef rdf:type rdf:Property ;
    rdfs:label 'Source System Amendment Ref' ;
    rdfs:comment 'The native amendment or change-request identifier from the originating source system (e.g., Oracle OMS internal amendment ID, Salesforce case number). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChargeId rdf:type rdf:Property ;
    rdfs:label 'Order Charge Id' ;
    rdfs:comment 'Unique identifier for the order charge record. Primary key.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceAlterationId rdf:type rdf:Property ;
    rdfs:label 'Price Alteration Id' ;
    rdfs:comment 'Foreign key linking to product.price_alteration. Business justification: Discounts and promotional adjustments applied to charges must trace to catalog price alterations for audit trail, revenue assurance, and campaign ROI analysis. Required for finance reconciliation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAlteration .

ind:billedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billed Timestamp' ;
    rdfs:comment 'Timestamp when the charge was successfully posted to a customer invoice. Null if charge has not yet been billed or was waived/cancelled.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalChargeReference rdf:type rdf:Property ;
    rdfs:label 'External Charge Reference' ;
    rdfs:comment 'Charge identifier from the source operational system. Used for cross-system reconciliation and data lineage tracking. Format varies by source system.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOfferingCode rdf:type rdf:Property ;
    rdfs:label 'Product Offering Code' ;
    rdfs:comment 'Business code identifying the commercial product offering. Used for product catalog lookup, pricing rule application, and revenue reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Marketing campaign or promotional offer code that influenced the charge amount. Used to track discount attribution and campaign effectiveness. Null if no promotion was applied.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationDays rdf:type rdf:Property ;
    rdfs:label 'Proration Days' ;
    rdfs:comment 'Number of days used to calculate prorated charge amount. Null if charge is not prorated.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalDescription rdf:type rdf:Property ;
    rdfs:label 'Reversal Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the charge reversal. Includes investigation findings, customer communication notes, or corrective action details. Null if charge was not reversed.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why a previously billed charge was reversed. BILLING_ERROR for incorrect invoicing, DUPLICATE_CHARGE for double-billing, SERVICE_NOT_DELIVERED for unfulfilled orders, CUSTOMER_DISPUTE for contested charges, SYSTEM_ERROR for technical failures, FRAUD for unauthorized charges, REGULATORY_ADJUSTMENT for compliance corrections. Null if charge was not reversed. [ENUM-REF-CANDIDATE: BILLING_ERROR|DUPLICATE_CHARGE|SERVICE_NOT_DELIVERED|CUSTOMER_DISPUTE|SYSTEM_ERROR|FRAUD|REGULATORY_ADJUSTMENT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'User ID or name of the employee who authorized the charge waiver. Used for audit trail and policy compliance verification. Null if charge was not waived.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDescription rdf:type rdf:Property ;
    rdfs:label 'Waiver Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the charge waiver. Includes customer service notes, manager approval justification, or policy reference. Null if charge was not waived.' ;
    rdfs:domain ind:OrderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Standardized code explaining why a charge was waived. CUSTOMER_RETENTION for churn prevention, SERVICE_FAILURE for quality issues, BILLING_ERROR for system mistakes, PROMOTIONAL for marketing campaigns, GOODWILL for customer satisfaction, EXECUTIVE_ESCALATION for senior management decisions, REGULATORY_COMPLIANCE for legal requirements, CONTRACT_NEGOTIATION for commercial agreements. Null if charge was not waived. [ENUM-REF-CANDIDATE: CUSTOMER_RETENTION|SERVICE_FAILURE|BILLING_ERROR|PROMOTIONAL|GOODWILL|EXECUTIVE_ESCALATION|REGULATORY_COMPLIANCE|CONTRACT_NEGOTIATION — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionId rdf:type rdf:Property ;
    rdfs:label 'Decomposition Id' ;
    rdfs:comment 'Unique identifier for the order decomposition mapping record. Primary key.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childOrderFulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Child Order Fulfillment Order Id' ;
    rdfs:comment 'Reference to the lower-level order generated during decomposition. May point to service order, resource order, or network order depending on child_order_type.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:decompositionFulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Decomposition Fulfillment Order Id' ;
    rdfs:comment 'Reference to the parent fulfillment order. Provides context for the order line being decomposed.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:decompositionPrerequisiteOrderFulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Decomposition Prerequisite Order Fulfillment Order Id' ;
    rdfs:comment 'Reference to another child order that must complete before this child order can begin execution. Null if no prerequisite exists.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:parentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Order Line Id' ;
    rdfs:comment 'Reference to the high-level fulfillment order line that was decomposed. Links to the commercial order line from which child orders were generated.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Identifier of the orchestration rule or template applied by Oracle Communications Order and Service Management (OSM) to generate the child order. Enables traceability to the decomposition logic.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DecompositionRule .

ind:childOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Child Order Number' ;
    rdfs:comment 'Business-readable identifier for the child order. Used for operational tracking and cross-system correlation.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childOrderType rdf:type rdf:Property ;
    rdfs:label 'Child Order Type' ;
    rdfs:comment 'Classification of the child order generated during decomposition. Indicates the layer of the fulfillment stack this order targets (service, resource, or network).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childSystemTarget rdf:type rdf:Property ;
    rdfs:label 'Child System Target' ;
    rdfs:comment 'Target system or domain responsible for fulfilling the child order. Examples: Netcracker Service Inventory, Nokia NetAct, Ericsson Network Manager, CPE Provisioning System.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Source system that created this decomposition mapping record. Typically Oracle Communications Order and Service Management (OSM).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decompositionLevel rdf:type rdf:Property ;
    rdfs:label 'Decomposition Level' ;
    rdfs:comment 'Hierarchical depth of this decomposition step. Level 1 indicates first-level decomposition from commercial order line; higher levels indicate nested decomposition.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decompositionStatus rdf:type rdf:Property ;
    rdfs:label 'Decomposition Status' ;
    rdfs:comment 'Current state of this decomposition mapping. Tracks whether the child order has been successfully created, dispatched, and synchronized with the target system.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Execution dependency relationship between this child order and other child orders. Sequential requires completion before next; parallel allows concurrent execution; conditional depends on outcome; blocking prevents downstream execution until resolved.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Timestamp when the child order was dispatched to the target system for fulfillment. Null if not yet dispatched.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed human-readable description of the failure reason. Provides context for troubleshooting and root cause analysis.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failure Timestamp' ;
    rdfs:comment 'Timestamp when the child order failed in the target system. Null if no failure occurred.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryCount rdf:type rdf:Property ;
    rdfs:label 'Max Retry Count' ;
    rdfs:comment 'Maximum number of retry attempts allowed for this child order before escalation or manual intervention is required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next retry attempt. Null if no retry is scheduled or max retries exceeded.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orchestrationContext rdf:type rdf:Property ;
    rdfs:label 'Orchestration Context' ;
    rdfs:comment 'Additional context or metadata passed from the orchestration engine to the target system. May include workflow variables, customer preferences, or technical parameters.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Required Flag' ;
    rdfs:comment 'Indicates whether this child order requires rollback due to parent order cancellation or downstream failure. True triggers compensating transaction.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackStatus rdf:type rdf:Property ;
    rdfs:label 'Rollback Status' ;
    rdfs:comment 'Current state of the rollback process for this child order. Tracks whether compensating actions have been successfully executed.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rollback Timestamp' ;
    rdfs:comment 'Timestamp when the rollback action was initiated for this child order. Null if no rollback occurred.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Timestamp' ;
    rdfs:comment 'Target timestamp by which this child order must be completed to meet the parent order SLA. Used for proactive breach detection.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:synchronizationStatus rdf:type rdf:Property ;
    rdfs:label 'Synchronization Status' ;
    rdfs:comment 'Indicates whether the child order state in the target system is synchronized with the orchestration layer. Critical for maintaining end-to-end order visibility.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Target System Status' ;
    rdfs:comment 'Current status of the child order as reported by the target system. May differ from decomposition_status during synchronization lag.' ;
    rdfs:domain ind:Decomposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutId rdf:type rdf:Property ;
    rdfs:label 'Fallout Id' ;
    rdfs:comment 'Unique surrogate identifier for each order fallout record in the Oracle Communications Order and Service Management (OSM) system. Primary key for the order_fallout data product.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskId rdf:type rdf:Property ;
    rdfs:label 'Task Id' ;
    rdfs:comment 'Reference to the specific orchestration task within the order workflow that triggered the fallout condition. Maps to the OSM task-level decomposition unit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:autoResolutionEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Eligible' ;
    rdfs:comment 'Indicates whether this fallout record is eligible for automated resolution without manual agent intervention, based on fallout category, retry history, and configured automation rules.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failingSystem rdf:type rdf:Property ;
    rdfs:label 'Failing System' ;
    rdfs:comment 'Name or identifier of the downstream OSS/BSS system that returned the error or failed to respond, causing the order to fall out. Examples: HLR, HSS, PROVISIONING_ENGINE, INVENTORY_MANAGER, CREDIT_SYSTEM, MNP_CLEARINGHOUSE.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failingSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Failing System Transaction Reference' ;
    rdfs:comment 'The transaction or correlation identifier returned by the failing downstream system. Enables cross-system tracing and incident correlation in ServiceNow ITSM and NOC tooling.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutStatus rdf:type rdf:Property ;
    rdfs:label 'Fallout Status' ;
    rdfs:comment 'Current lifecycle state of the fallout record within the NOC/BSS operations workqueue. Drives SLA breach prevention workflows and management dashboards.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retry Timestamp' ;
    rdfs:comment 'Date and time of the most recent automated or manual re-submission attempt for this fallout order. Used to enforce retry interval policies and prevent retry storms.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Retry Allowed' ;
    rdfs:comment 'Maximum number of automated re-submission attempts permitted for this order type before mandatory escalation to manual resolution. Configured per order type and fallout category.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mnpPortReference rdf:type rdf:Property ;
    rdfs:label 'Mnp Port Reference' ;
    rdfs:comment 'Mobile Number Portability (MNP) porting reference number applicable when the fallout is associated with a port-in or port-out order. Null for non-MNP order types. Used for MNP clearinghouse reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Free-text description of the corrective action taken by the resolution agent to address the fallout root cause. Captured at resolution time and used for knowledge base and automation training.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resubmission Outcome' ;
    rdfs:comment 'Result of the order re-submission attempt after resolution action was applied. Indicates whether the order successfully completed fulfillment, failed again, is awaiting outcome, or was cancelled.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resubmission Timestamp' ;
    rdfs:comment 'Date and time when the order was resubmitted into the orchestration engine after resolution action was applied. Null if the order has not yet been resubmitted.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subCategory rdf:type rdf:Property ;
    rdfs:label 'Sub Category' ;
    rdfs:comment 'Granular sub-classification within the fallout category providing additional specificity for root cause analysis. Examples: ADDRESS_VALIDATION_FAILED under VALIDATION_FAILURE, HLR_TIMEOUT under PROVISIONING_TIMEOUT, SIM_STOCK_DEPLETED under INVENTORY_SHORTAGE.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepName rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Name' ;
    rdfs:comment 'The name of the specific orchestration workflow step or process node within Oracle OSM that was executing when the fallout occurred. Enables precise identification of the failure point in the order decomposition graph.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepSequence rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Sequence' ;
    rdfs:comment 'Numeric sequence position of the failing workflow step within the overall order orchestration process. Used to understand how far into fulfillment the order progressed before failing.' ;
    rdfs:domain ind:Fallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderInteractionId rdf:type rdf:Property ;
    rdfs:label 'Order Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each order interaction or notification record within the order communication log. Primary key for this data product.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmCaseId rdf:type rdf:Property ;
    rdfs:label 'Crm Case Id' ;
    rdfs:comment 'Reference to the linked CRM case in Salesforce CRM Case Management, if this interaction is associated with an escalation, complaint, or service request raised during order fulfillment. Null when no case is linked.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:notificationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Notification Template Id' ;
    rdfs:comment 'Reference to the notification template used to generate outbound communications. Applicable for system-generated outbound interactions such as order confirmation, appointment reminder, and provisioning completion notices.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationTemplate .

ind:consentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Verified Flag' ;
    rdfs:comment 'Indicates whether the customer\'s consent to receive communications via the selected channel has been verified at the time of dispatch (True = consent confirmed). Supports GDPR Article 6/7, CCPA, and TCPA compliance for outbound marketing and operational notifications.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Identifies who or what originated this interaction. CUSTOMER — the customer contacted the operator; AGENT — a customer service or field agent initiated the interaction; SYSTEM — an automated BSS/OSS process (e.g., Amdocs, Oracle OSM) generated the communication.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time at which the interaction event occurred — for outbound notifications this is the dispatch time; for inbound interactions this is the time the contact was received. This is the principal business event timestamp for this record. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryLimit rdf:type rdf:Property ;
    rdfs:label 'Max Retry Limit' ;
    rdfs:comment 'The configured maximum number of delivery retry attempts permitted for this interaction before the status is set to FAILED. Enables analysis of retry policy effectiveness and notification delivery SLA compliance.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderLifecycleMilestone rdf:type rdf:Property ;
    rdfs:label 'Order Lifecycle Milestone' ;
    rdfs:comment 'The specific order fulfillment milestone that triggered or is associated with this interaction. Enables milestone-level communication analytics and SLA compliance reporting. [ENUM-REF-CANDIDATE: ORDER_CONFIRMED|APPOINTMENT_SCHEDULED|PROVISIONING_STARTED|PROVISIONING_COMPLETE|MNP_PORT_EXECUTED|ORDER_CANCELLED|ORDER_FAILED — promote to reference product]' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientDeviceToken rdf:type rdf:Property ;
    rdfs:label 'Recipient Device Token' ;
    rdfs:comment 'The mobile device push notification token (e.g., APNs or FCM token) used to deliver PUSH channel notifications to the customer\'s registered device. Classified as confidential as it is a device-level identifier. Null for non-push channels.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'The email address of the notification recipient for EMAIL channel interactions. Classified as restricted PII. Null for non-email channels.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientMsisdn rdf:type rdf:Property ;
    rdfs:label 'Recipient Msisdn' ;
    rdfs:comment 'The mobile phone number (MSISDN) of the notification recipient for SMS and IVR channel interactions. Stored in E.164 international format. Classified as restricted PII as it directly identifies an individual subscriber.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether this interaction constitutes a mandatory regulatory notification (True) as required by FCC, Ofcom, or BEREC rules — for example, MNP port execution notices or disconnection notifications. False for standard operational communications. Supports regulatory compliance reporting and audit.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Dispatch Timestamp' ;
    rdfs:comment 'The target date and time by which this outbound notification should be dispatched per the proactive customer communication SLA. Distinct from regulatory_deadline which applies only to regulatory notifications. Used to measure SLA adherence for customer experience KPIs.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemInteractionRef rdf:type rdf:Property ;
    rdfs:label 'Source System Interaction Ref' ;
    rdfs:comment 'The native interaction or message identifier assigned by the originating operational system (e.g., Salesforce Case Number, Oracle OSM interaction ID, Amdocs notification batch reference). Enables traceability back to the system of record for reconciliation and audit.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The subject line of the outbound notification, applicable to EMAIL and PUSH channels. Captures the actual subject text as dispatched (post template rendering), enabling content audit and regulatory compliance review.' ;
    rdfs:domain ind:OrderInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'The version identifier of the notification template used to generate this outbound communication (e.g., v1.0, v2.3). Enables audit of which template version was active at the time of dispatch, supporting regulatory compliance and A/B testing of communication content.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryReservationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Reservation Id' ;
    rdfs:comment 'Unique identifier for the inventory reservation record. Primary key.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourcePoolId rdf:type rdf:Property ;
    rdfs:label 'Resource Pool Id' ;
    rdfs:comment 'Reference to the inventory pool from which this resource was reserved. Enables pool-level capacity management and replenishment.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAddressPool .

ind:allocationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Code' ;
    rdfs:comment 'Reference to the business rule that governed this reservation. Enables audit of allocation logic and policy compliance.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Number of reserved units that have been consumed by fulfillment. Tracks partial consumption for bulk reservations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumed Timestamp' ;
    rdfs:comment 'Date and time when the reserved resource was consumed by fulfillment and allocated to the service. Null if not yet consumed.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAutoReleased rdf:type rdf:Property ;
    rdfs:label 'Is Auto Released' ;
    rdfs:comment 'Indicates whether the reservation was automatically released by system expiry logic (true) or manually released by an operator (false).' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseReasonCode rdf:type rdf:Property ;
    rdfs:label 'Release Reason Code' ;
    rdfs:comment 'Coded reason for reservation release. Examples: EXPIRY, ORDER_CANCELLED, MANUAL_OVERRIDE, INVENTORY_REBALANCE, FULFILLMENT_FAILURE.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Release Reason Description' ;
    rdfs:comment 'Detailed explanation of why the reservation was released. Supports operational analysis and process improvement.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the reservation was manually released back to inventory. Null if not released.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Reservation Duration Minutes' ;
    rdfs:comment 'Configured hold period in minutes before automatic expiry. Derived from order type and resource type policies.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationNotes rdf:type rdf:Property ;
    rdfs:label 'Reservation Notes' ;
    rdfs:comment 'Free-text operational notes about the reservation. Captures special handling instructions, constraints, or exceptions.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Human-readable business identifier for the reservation. Used for operational tracking and customer service reference.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationPriority rdf:type rdf:Property ;
    rdfs:label 'Reservation Priority' ;
    rdfs:comment 'Priority level for this reservation. Influences allocation sequence when inventory is constrained. Inherited from order priority.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reservation Reason Code' ;
    rdfs:comment 'Business reason for the reservation. Aligns with order action type and supports reservation analytics.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the reservation. ACTIVE=held and available, CONSUMED=used by fulfillment, EXPIRED=time limit exceeded, RELEASED=manually freed, CANCELLED=order cancelled.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'Date and time when the resource was reserved from inventory. Marks the start of the reservation hold period.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedBySystem rdf:type rdf:Property ;
    rdfs:label 'Reserved By System' ;
    rdfs:comment 'Name of the source system that initiated the reservation. Typically Oracle Communications Order and Service Management or equivalent OSS.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Resource Specification Code' ;
    rdfs:comment 'Reference to the resource catalog specification defining the characteristics and constraints of the reserved resource type.' ;
    rdfs:domain ind:InventoryReservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Service Region Code' ;
    rdfs:comment 'Geographic region code for which this resource is reserved. Ensures regional inventory alignment for MSISDN ranges and local resources.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jeopardyId rdf:type rdf:Property ;
    rdfs:label 'Jeopardy Id' ;
    rdfs:comment 'Unique surrogate identifier for the order jeopardy alert record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingTaskId rdf:type rdf:Property ;
    rdfs:label 'Blocking Task Id' ;
    rdfs:comment 'Identifier of the specific order task or workflow step within Oracle Communications OSM that is currently blocked and causing the jeopardy condition. Used for targeted remediation.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the individual currently assigned as the responsible owner for resolving this jeopardy alert. Retained for operational display on dashboards without requiring a join.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingSystem rdf:type rdf:Property ;
    rdfs:label 'Blocking System' ;
    rdfs:comment 'The Operations Support System (OSS) or Business Support System (BSS) component where the blocking condition exists. Identifies which system team must act to resolve the jeopardy. [ENUM-REF-CANDIDATE: osm|crm|network_provisioning|mnp_gateway|cpe_logistics|billing|workforce_management|external_carrier — promote to reference product]' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The monetary value of service credit or compensation to be applied to the customer account as a result of the SLA breach. Expressed in the local operating currency. Feeds billing adjustment workflows in Amdocs Revenue Management.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationEligible rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligible' ;
    rdfs:comment 'Indicates whether the customer is eligible for service credit or compensation as a result of the SLA breach associated with this jeopardy event. Drives downstream billing adjustment workflows in Amdocs Revenue Management.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpeTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Cpe Tracking Number' ;
    rdfs:comment 'Logistics shipment tracking number for the Customer Premises Equipment (CPE) associated with the order, applicable when the jeopardy type is CPE shipment delay. Used to monitor delivery status.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotified rdf:type rdf:Property ;
    rdfs:label 'Customer Notified' ;
    rdfs:comment 'Indicates whether the customer has been proactively notified about the jeopardy condition and the potential delay to their order. True if notification has been sent; False if not yet notified.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoursToBreach rdf:type rdf:Property ;
    rdfs:label 'Hours To Breach' ;
    rdfs:comment 'Calculated number of hours remaining before the order is predicted to breach its SLA threshold at the time of jeopardy detection. Drives urgency scoring and escalation routing on operations dashboards.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jeopardyNumber rdf:type rdf:Property ;
    rdfs:label 'Jeopardy Number' ;
    rdfs:comment 'Externally visible, human-readable reference number for the jeopardy alert, used by order operations managers and customer care agents when communicating about the at-risk order. Format: JEP- followed by 10 digits.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jeopardyStatus rdf:type rdf:Property ;
    rdfs:label 'Jeopardy Status' ;
    rdfs:comment 'Current lifecycle state of the jeopardy alert. Tracks progression from initial detection through resolution or closure. [ENUM-REF-CANDIDATE: open|acknowledged|in_progress|escalated|resolved|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jeopardyType rdf:type rdf:Property ;
    rdfs:label 'Jeopardy Type' ;
    rdfs:comment 'Classification of the root cause category driving the jeopardy condition. Examples include capacity constraint, field technician unavailability, Mobile Number Portability (MNP) donor delay, Customer Premises Equipment (CPE) shipment delay, network outage, or provisioning failure. [ENUM-REF-CANDIDATE: capacity_constraint|field_technician_unavailable|mnp_donor_delay|cpe_shipment_delay|network_outage|provisioning_failure|system_integration_failure|regulatory_hold — promote to reference product]' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mnpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mnp Reference Number' ;
    rdfs:comment 'The Mobile Number Portability (MNP) reference number assigned by the donor network or porting authority, applicable when the jeopardy type is MNP donor delay. Used to track and chase the porting request.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Predicted Breach Timestamp' ;
    rdfs:comment 'The predicted date and time at which the fulfillment order is expected to breach its committed completion date or Service Level Agreement (SLA) threshold if no corrective action is taken. Used for prioritisation on real-time operations dashboards.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Revised Completion Date' ;
    rdfs:comment 'The updated expected completion date for the order after the jeopardy condition has been assessed and a revised delivery commitment has been established. May differ from the original committed completion date.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardised code identifying the confirmed or suspected root cause of the jeopardy condition, aligned with the OSS/BSS fault taxonomy. Used for trend analysis and process improvement reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachOccurred rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Occurred' ;
    rdfs:comment 'Indicates whether the Service Level Agreement (SLA) was actually breached for this order. True if the committed completion date was missed; False if the order was completed within SLA despite the jeopardy alert.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Sla Threshold Hours' ;
    rdfs:comment 'The maximum number of hours allowed for order fulfillment as defined in the applicable Service Level Agreement (SLA). Jeopardy is triggered when the predicted completion time approaches or exceeds this threshold.' ;
    rdfs:domain ind:Jeopardy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Foreign key linking to product.bundle. Business justification: Bundle orders require direct catalog reference for component validation, bundle pricing enforcement, discount calculation, and eligibility verification. Critical for multi-product offer fulfillment.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'The fulfillment action to be performed for this line item. Drives order decomposition and workflow routing in Oracle Communications Order and Service Management. ADD = new activation; REMOVE = disconnection; MODIFY = change of service; SUSPEND = temporary suspension; RESUME = reactivation; PORT_IN = Mobile Number Portability (MNP) inbound; PORT_OUT = MNP outbound. [ENUM-REF-CANDIDATE: ADD|REMOVE|MODIFY|SUSPEND|RESUME|PORT_IN|PORT_OUT — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The date committed to the customer for delivery or activation of the service on this line, as agreed at order capture. Used for SLA (Service Level Agreement) compliance monitoring and breach detection in service fulfillment reporting.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decompositionState rdf:type rdf:Property ;
    rdfs:label 'Decomposition State' ;
    rdfs:comment 'Indicates the order decomposition processing state for this line within Oracle Communications Order and Service Management. Order decomposition translates a commercial product order line into technical service and resource fulfillment tasks across OSS systems. Critical for orchestration monitoring and fault management.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutDescription rdf:type rdf:Property ;
    rdfs:label 'Fallout Description' ;
    rdfs:comment 'Free-text description providing additional context for the order line fallout or failure, supplementing the fallout_reason_code. Captured by Oracle Communications Order and Service Management workflow engine for manual intervention and customer communication.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fallout Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for order line fallout or failure during fulfillment orchestration (e.g., \'CREDIT_FAIL\', \'INVENTORY_UNAVAILABLE\', \'ADDRESS_NOT_SERVICEABLE\', \'PORTING_REJECTED\'). Used for fallout management, root cause analysis, and process improvement in Oracle Communications Order and Service Management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEsim rdf:type rdf:Property ;
    rdfs:label 'Is Esim' ;
    rdfs:comment 'Indicates whether this order line involves an eSIM (Embedded SIM) provisioning rather than a physical SIM card. When TRUE, triggers eSIM profile download orchestration via GSMA SGP.22 RSP (Remote SIM Provisioning) instead of physical SIM dispatch.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMnpLine rdf:type rdf:Property ;
    rdfs:label 'Is Mnp Line' ;
    rdfs:comment 'Indicates whether this order line involves a Mobile Number Portability (MNP) port-in or port-out transaction. When TRUE, triggers MNP-specific workflow orchestration including donor operator notification and number portability clearinghouse coordination.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpDonorOperator rdf:type rdf:Property ;
    rdfs:label 'Mnp Donor Operator' ;
    rdfs:comment 'For PORT_IN action lines, the name or code of the donor (losing) network operator from whom the mobile number is being ported. Required for MNP (Mobile Number Portability) process orchestration, GSMA NRTRDE compliance, and inter-operator coordination.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net commercial price for this order line after applying discounts (unit_price × quantity − discount_amount). Represents the agreed charge basis passed to Amdocs Revenue Management for billing. Distinct from tax-inclusive total.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the product or service being ordered on this line (e.g., \'5G Unlimited Plan\', \'FTTH 1Gbps Broadband\', \'VoLTE Add-On\'). Denormalized from the product catalog for operational reporting and customer-facing order confirmations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the product or service being ordered on this line. Drives workflow routing, provisioning system selection, and reporting segmentation. [ENUM-REF-CANDIDATE: MOBILE|BROADBAND|FIXED_LINE|IPTV|VOIP|IOT|ENTERPRISE|ADD_ON — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The customer-requested date on which the product or service on this line should become active. Drives service provisioning scheduling in Oracle Communications Order and Service Management and SLA commitment tracking.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderMnpRequestId rdf:type rdf:Property ;
    rdfs:label 'Order Mnp Request Id' ;
    rdfs:comment 'Unique surrogate primary key for the MNP port-in or port-out request record within the order management system.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Flag' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent for the MNP porting request, as required by regulatory frameworks. Must be True before a porting request can be submitted to the donor operator.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Timestamp' ;
    rdfs:comment 'Timestamp when the customer provided explicit consent for the MNP porting request. Required for regulatory audit trails under GDPR and FCC consumer protection rules.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:donorAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Donor Acknowledgement Timestamp' ;
    rdfs:comment 'Timestamp when the donor operator formally acknowledged receipt of the MNP porting request. Regulatory compliance requires acknowledgement within defined windows (e.g., Ofcom 2-hour rule). Null if not yet acknowledged.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hlrUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Hlr Update Status' ;
    rdfs:comment 'Status of the HLR/HSS provisioning update on the recipient network following port execution. SUCCESS confirms the subscriber is fully provisioned; FAILED triggers a technical remediation workflow.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlrUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hlr Update Timestamp' ;
    rdfs:comment 'Timestamp when the HLR/HSS provisioning update was completed on the recipient network. Marks the point at which the subscriber\'s service is technically active on the new network.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iccNumber rdf:type rdf:Property ;
    rdfs:label 'Icc Number' ;
    rdfs:comment 'The Integrated Circuit Card Identifier (ICCID) of the SIM card associated with the MSISDN being ported. Required for network provisioning and HLR/HSS update during port execution.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Flag' ;
    rdfs:comment 'Indicates whether the donor or recipient operator involved in this MNP request is a Mobile Virtual Network Operator (MVNO). MVNO ports may require additional clearinghouse steps and host MNO coordination.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvnoHostOperatorCode rdf:type rdf:Property ;
    rdfs:label 'Mvno Host Operator Code' ;
    rdfs:comment 'Operator code of the host Mobile Network Operator (MNO) for the MVNO involved in this porting request. Populated only when mvno_flag is True. Required for routing porting requests through the correct network infrastructure.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberPortabilityDatabaseUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Number Portability Database Update Flag' ;
    rdfs:comment 'Indicates whether the national Number Portability Database (NPDB) or clearinghouse routing database has been updated to reflect the completed port. Required for correct call routing to the ported number.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pacCode rdf:type rdf:Property ;
    rdfs:label 'Pac Code' ;
    rdfs:comment 'The Porting Authorisation Code (PAC) provided by the donor operator to the subscriber, authorizing the port-out. Required for UK/Ofcom-regulated ports. Stored as confidential as it is a one-time authorization credential.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingChannel rdf:type rdf:Property ;
    rdfs:label 'Porting Channel' ;
    rdfs:comment 'The channel through which the MNP porting request was initiated by the customer (e.g., ONLINE self-service portal, retail STORE, CALL_CENTER agent, authorized DEALER, or API integration).' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingClearinghouseReference rdf:type rdf:Property ;
    rdfs:label 'Porting Clearinghouse Reference' ;
    rdfs:comment 'Reference number assigned by the national or regional MNP clearinghouse (e.g., NPAC in the US, Syniverse in Europe) to track the porting transaction through the inter-operator clearinghouse system.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Porting Execution Date' ;
    rdfs:comment 'The scheduled or actual calendar date on which the number port is executed and the MSISDN becomes active on the recipient network. Null if the port has not yet been executed.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portingExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Execution Timestamp' ;
    rdfs:comment 'Precise timestamp when the number port was technically executed at the network level, including HLR/HSS update confirmation. Provides sub-day precision for SLA measurement and NRTRDE reporting.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingRequestDate rdf:type rdf:Property ;
    rdfs:label 'Porting Request Date' ;
    rdfs:comment 'The calendar date on which the customer formally submitted the MNP porting request. Used as the anchor date for regulatory porting window compliance (e.g., FCC 1-business-day porting rule, Ofcom 1-working-day rule).' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portingRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Porting Request Number' ;
    rdfs:comment 'Externally-known business identifier for the MNP request, used in regulatory submissions and inter-operator communications. Conforms to the operator-assigned porting reference format.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Porting Window End Time' ;
    rdfs:comment 'The end of the agreed porting execution window. If the port is not completed within this window, an SLA breach may be triggered and escalation procedures initiated.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portingWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Porting Window Start Time' ;
    rdfs:comment 'The start of the agreed porting execution window during which the technical port will be performed. Agreed between donor and recipient operators to minimize service disruption.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'The latest date by which the port must be completed to comply with regulatory mandates (e.g., FCC 1-business-day rule, Ofcom 1-working-day rule). Derived from porting_request_date and applicable regulatory framework.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Timestamp' ;
    rdfs:comment 'Precise timestamp when the MNP request was formally submitted to the inter-operator porting clearinghouse or regulatory body. Marks the start of the regulatory porting window and is used for SLA compliance measurement.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stacCode rdf:type rdf:Property ;
    rdfs:label 'Stac Code' ;
    rdfs:comment 'The Service Termination Authorisation Code (STAC) used when a subscriber wishes to leave a network without porting their number. Applicable in Ofcom-regulated markets as an alternative to PAC.' ;
    rdfs:domain ind:OrderMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationId rdf:type rdf:Property ;
    rdfs:label 'Notification Id' ;
    rdfs:comment 'Unique surrogate identifier for each outbound order notification record dispatched to a customer or internal stakeholder. Primary key of the order_notification data product.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the notification template used to render the message content. Links to the notification template catalog managed in the BSS product/service catalog (Netcracker OSS/BSS).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Telecommunication .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'The scheduled field technician appointment date included in appointment reminder notifications. Populated only when notification_type is APPOINTMENT_REMINDER. Sourced from Granite Telecommunications Workforce Management scheduling.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentTimeSlot rdf:type rdf:Property ;
    rdfs:label 'Appointment Time Slot' ;
    rdfs:comment 'The scheduled appointment time window communicated to the customer in appointment reminder notifications (e.g., AM, PM, or specific time band). Sourced from Granite Telecommunications Workforce Management.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyHash rdf:type rdf:Property ;
    rdfs:label 'Body Hash' ;
    rdfs:comment 'SHA-256 hash of the rendered notification body content at the time of dispatch. Provides tamper-evident audit evidence of the exact message content sent without storing the full message body (which may contain PII).' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReference rdf:type rdf:Property ;
    rdfs:label 'Consent Reference' ;
    rdfs:comment 'Reference to the customer\'s communication consent record that authorises dispatch of this notification via the selected channel. Required for GDPR Article 6 lawful basis and TCPA compliance for SMS/IVR channels.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when delivery confirmation was received from the messaging gateway or carrier, confirming the notification reached the recipient endpoint. Null if delivery has not yet been confirmed or failed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failed Timestamp' ;
    rdfs:comment 'The date and time when a delivery failure or bounce was reported by the messaging gateway. Populated only when delivery_status is FAILED or BOUNCED. Used to trigger retry logic and escalation workflows.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Human-readable description of the delivery failure reason as returned by the messaging gateway. Complements failure_reason_code with additional context for operations and customer service teams.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackChannel rdf:type rdf:Property ;
    rdfs:label 'Fallback Channel' ;
    rdfs:comment 'The alternative delivery channel to be used if the primary delivery_channel fails after exhausting retry attempts (e.g., fall back to SMS if EMAIL bounces). Supports multi-channel notification resilience.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackTriggered rdf:type rdf:Property ;
    rdfs:label 'Fallback Triggered' ;
    rdfs:comment 'Indicates whether the fallback delivery channel was activated for this notification because the primary channel failed. True = fallback was used; False = primary channel was used.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatewayMessageReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Message Reference' ;
    rdfs:comment 'The unique message identifier assigned by the external messaging gateway or carrier (e.g., SMS aggregator message ID, email SMTP message ID, push notification token). Used for delivery receipt correlation and dispute resolution with gateway providers.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayProvider rdf:type rdf:Property ;
    rdfs:label 'Gateway Provider' ;
    rdfs:comment 'The name or identifier of the external messaging gateway or aggregator used to deliver this notification (e.g., Twilio, Syniverse, AWS SNS). Supports vendor performance monitoring and SLA management.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this notification record (e.g., NTF-0012345678). Used in customer-facing correspondence, audit trails, and regulatory evidence for MNP and disconnection notifications.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Classifies the business event that triggered this notification. Drives template selection, regulatory logging, and SLA measurement. [ENUM-REF-CANDIDATE: ORDER_CONFIRMATION|APPOINTMENT_REMINDER|PROVISIONING_COMPLETE|PORT_IN_EXECUTION|ORDER_CANCELLATION|DISCONNECTION_NOTICE — promote to reference product]' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Port Execution Date' ;
    rdfs:comment 'The date on which the MNP port-in or port-out was executed, as communicated in PORT_IN_EXECUTION notifications. Required for regulatory audit under FCC MNP Order 18-122 and GSMA PRD IR.73.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisioningCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Completion Date' ;
    rdfs:comment 'The date on which service provisioning was completed, as communicated in PROVISIONING_COMPLETE notifications. Sourced from Oracle OSM service fulfillment completion event.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Address' ;
    rdfs:comment 'The actual delivery endpoint used for this notification — phone number (E.164 format for SMS/IVR), email address, push device token, or postal address depending on delivery_channel. Stored as dispatched for audit and re-delivery purposes.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classifies whether the notification was dispatched to an external customer, an internal business stakeholder, a customer service agent, or a field technician. Governs data handling and privacy obligations.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Reference' ;
    rdfs:comment 'The specific regulatory rule, order, or article reference that mandates this notification (e.g., FCC MNP Order 18-122, Ofcom GC C7.9, BEREC Guidelines 2021). Populated only when regulatory_notification_flag is True.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Dispatch Timestamp' ;
    rdfs:comment 'The planned date and time at which the notification was scheduled to be dispatched. Compared against dispatch_timestamp to measure scheduling accuracy and identify delayed notifications.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceNumber rdf:type rdf:Property ;
    rdfs:label 'Service Number' ;
    rdfs:comment 'The MSISDN or service telephone number (E.164 format) associated with the order being notified about. Included in the notification for customer identification and MNP regulatory audit purposes.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The unique event or transaction identifier from the originating source system (OSM, Salesforce, Amdocs) that triggered this notification. Enables end-to-end traceability from the source business event to the dispatched notification.' ;
    rdfs:domain ind:Notification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Unique surrogate identifier for the order SLA commitment record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTemplateId rdf:type rdf:Property ;
    rdfs:label 'Sla Template Id' ;
    rdfs:comment 'Foreign key linking to product.sla_template. Business justification: Order SLA measurements must reference the catalog template defining targets, measurement methods, and penalty calculations for compliance reporting, penalty assessment, and service level governance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTemplate .

ind:waiverApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Regulatory SLA waivers (e.g., force majeure, customer-caused delay) require documented approval by authorized personnel in telecom. Linking to approving employee enables compliance audit trail, regula' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breachNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Sent' ;
    rdfs:comment 'Indicates whether a formal breach notification has been dispatched to the customer and/or regulatory authority (True) following a BREACHED status. Required for compliance with FCC, Ofcom, and BEREC breach reporting obligations.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Timestamp' ;
    rdfs:comment 'The date and time at which the breach notification was sent to the customer and/or regulatory authority. Null if no notification has been sent. Used to verify compliance with mandatory notification timeframes.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Hours' ;
    rdfs:comment 'The number of elapsed hours from the measurement start event at which the SLA is formally classified as BREACHED. May equal target_completion_hours or include a grace period defined in the contract or regulatory instrument.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'The exact date and time at which the SLA was formally classified as BREACHED (i.e., elapsed hours exceeded breach_threshold_hours). Null if the SLA has not been breached. Critical for regulatory penalty calculations and breach notification obligations.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Defines how elapsed time is measured for this SLA: CALENDAR_HOURS (24x7 clock), BUSINESS_HOURS (measured only during defined business operating hours), or BUSINESS_DAYS (measured in working days). Determines how target_completion_timestamp is calculated.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockSuspended rdf:type rdf:Property ;
    rdfs:label 'Clock Suspended' ;
    rdfs:comment 'Indicates whether the SLA measurement clock is currently paused (True) due to a customer hold, third-party dependency, or regulatory exclusion event. When True, elapsed_hours accumulation is halted until the clock is resumed.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elapsedHours rdf:type rdf:Property ;
    rdfs:label 'Elapsed Hours' ;
    rdfs:comment 'The number of hours elapsed since the measurement start event as of the last status evaluation. Used for real-time SLA monitoring dashboards and regulatory compliance reporting. Excludes any suspended clock periods.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement End Event' ;
    rdfs:comment 'The business event that stops the SLA clock and marks fulfillment completion. Used to calculate actual elapsed time against the SLA target. [ENUM-REF-CANDIDATE: SERVICE_ACTIVATED|ORDER_COMPLETED|PORT_COMPLETED|FAULT_RESOLVED|CPE_INSTALLED|CUSTOMER_CONFIRMED — promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Event' ;
    rdfs:comment 'The business event that triggers the start of SLA clock measurement. Defines the precise moment from which target completion hours are counted, per regulatory or contractual terms. [ENUM-REF-CANDIDATE: ORDER_SUBMITTED|ORDER_ACCEPTED|PAYMENT_CONFIRMED|SITE_SURVEY_COMPLETE|PORT_REQUEST_SUBMITTED|TECHNICIAN_DISPATCHED — promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty or service credit is contractually or regulatorily applicable upon breach of this SLA (True). Drives downstream penalty calculation and credit note generation in Amdocs Revenue Management.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Amount' ;
    rdfs:comment 'The monetary value of the service credit or penalty payable to the customer upon SLA breach, expressed in the billing currency. Null if penalty_applicable is False or if the breach has not yet been assessed. Feeds into Amdocs Revenue Management credit note generation.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryInstrumentReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Instrument Reference' ;
    rdfs:comment 'The specific regulatory rule, order, or directive citation that mandates this SLA (e.g., \'FCC 47 CFR Part 52 Section 52.35\', \'Ofcom General Conditions C5.3\', \'BEREC Guidelines on Switching 2020\'). Enables precise regulatory compliance traceability.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'Functional category of the SLA defining the business process it governs: PROVISIONING (new service activation), REPAIR (fault resolution), PORTABILITY (Mobile Number Portability / MNP), INSTALLATION (physical CPE or FTTH installation), ACTIVATION (service turn-up), or DISCONNECTION (service termination). [ENUM-REF-CANDIDATE: PROVISIONING|REPAIR|PORTABILITY|INSTALLATION|ACTIVATION|DISCONNECTION — promote to reference product if additional categories are required]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Target Completion Hours' ;
    rdfs:comment 'The contracted or regulatory maximum number of hours within which the order must be fulfilled from the measurement start event. This is the primary SLA commitment value (e.g., 24.00 hours for MNP port-in per FCC rules, 48.00 hours for residential broadband activation).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Completion Timestamp' ;
    rdfs:comment 'The calculated deadline timestamp by which the order must be fulfilled to meet the SLA commitment. Derived from measurement_start_timestamp plus target_completion_hours, adjusted for any calendar or business-hours rules. Stored for direct comparison in monitoring queries.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalSuspendedHours rdf:type rdf:Property ;
    rdfs:label 'Total Suspended Hours' ;
    rdfs:comment 'Cumulative number of hours the SLA clock has been suspended for this record due to customer holds, third-party delays, or regulatory exclusions. Subtracted from gross elapsed time to compute net elapsed hours for compliance reporting.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Hours' ;
    rdfs:comment 'The number of elapsed hours from the measurement start event at which the SLA status transitions to AT_RISK, triggering proactive escalation workflows in Oracle Communications Order and Service Management and ServiceNow ITSM. Typically set as a percentage of target_completion_hours (e.g., 75%).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningTriggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Warning Triggered Timestamp' ;
    rdfs:comment 'The date and time at which the SLA status transitioned to AT_RISK (warning threshold exceeded). Used to measure the effectiveness of proactive escalation workflows and to audit response times.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each order status history record. Primary key of the order_status_history data product. Immutable once assigned.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Actor Employee Id' ;
    rdfs:comment 'Identifier of the specific actor (system process name, agent employee ID, or customer reference) that triggered the transition or amendment. Supports audit trail requirements for FCC and BEREC regulatory reporting and dispute resolution.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceOrderId rdf:type rdf:Property ;
    rdfs:label 'Service Order Id' ;
    rdfs:comment 'Reference to the decomposed service order generated from the parent fulfillment order in Oracle Communications Order and Service Management or Netcracker OSS/BSS Suite. Supports traceability between commercial order history and service fulfillment execution.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProvisioningOrder .

ind:workflowTaskId rdf:type rdf:Property ;
    rdfs:label 'Workflow Task Id' ;
    rdfs:comment 'Identifier of the specific workflow task or orchestration step within Oracle Communications Order and Service Management that generated this history record. Enables traceability from the history record back to the originating workflow execution for technical root-cause analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Task .

ind:actorSystem rdf:type rdf:Property ;
    rdfs:label 'Actor System' ;
    rdfs:comment 'Name of the OSS/BSS system that originated the transition or amendment event (e.g., Oracle Communications Order and Service Management, Netcracker OSS/BSS Suite, Salesforce CRM, ServiceNow ITSM). Enables source-system traceability for fallout root-cause analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Categorizes the type of actor that triggered the state transition or amendment. SYSTEM indicates an automated OSS/BSS process; AGENT indicates a human CSR or field technician; CUSTOMER indicates a self-service action; SUPERVISOR indicates a management override; AUTOMATED_RULE indicates a policy engine or workflow rule.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amendment Request Timestamp' ;
    rdfs:comment 'Date and time when the amendment was formally requested by the customer or agent. Distinct from transition_timestamp (which records when the event was processed). Used to measure amendment processing lead time and SLA compliance. Null for state transition records. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durationInStateSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration In State Seconds' ;
    rdfs:comment 'Number of seconds the order spent in the previous_state before transitioning to new_state. Calculated at ingestion time as the difference between this record\'s transition_timestamp and the prior record\'s transition_timestamp for the same order. Used for SLA bottleneck analysis and process mining.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falloutResolutionCode rdf:type rdf:Property ;
    rdfs:label 'Fallout Resolution Code' ;
    rdfs:comment 'Standardized code indicating how a FALLOUT condition was resolved (e.g., AUTO_RETRY_SUCCESS, MANUAL_INTERVENTION, ORDER_CANCELLED, REROUTED_TO_ALTERNATE_RESOURCE). Populated when transitioning out of FALLOUT state. Null for non-FALLOUT records.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this history record is subject to regulatory reporting obligations (e.g., FCC order completion reporting, BEREC quality-of-service metrics, OFCOM service provisioning KPIs). True flags records that must be included in regulatory submissions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Free-text justification provided by a supervisor or authorized agent when a standard business rule or SLA policy is overridden to approve an amendment or force a state transition. Required for compliance audit trails when override_flag is True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The committed SLA completion deadline applicable at the time of this history record. If sla_reset_flag is True, this reflects the recalculated SLA target post-reset. Enables point-in-time SLA compliance measurement and regulatory reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the state transition or amendment event occurred. This is the principal business event timestamp used for SLA measurement, fallout root-cause analysis, and regulatory audit trails. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decompositionRuleId rdf:type rdf:Property ;
    rdfs:label 'Decomposition Rule Id' ;
    rdfs:comment 'Identifier of the OSM decomposition rule applied to generate this task from the parent order line. Enables audit of which orchestration logic produced the task and supports regression analysis when decomposition rules are updated.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DecompositionRule .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual date and time at which execution of this task commenced in the downstream target system. Compared against scheduled_start_time to measure scheduling adherence and identify orchestration delays.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationIndicator rdf:type rdf:Property ;
    rdfs:label 'Automation Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this task was executed automatically by the OSM orchestration engine (True) or required manual intervention by an operations team member (False). Key metric for measuring fulfillment automation rates and identifying candidates for further automation.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childSystemTaskRef rdf:type rdf:Property ;
    rdfs:label 'Child System Task Ref' ;
    rdfs:comment 'The task or work order identifier assigned by the downstream target system (e.g., Ericsson Network Manager work order ID, Netcracker service order number, ServiceNow change request number). Enables cross-system correlation and reconciliation between OSM and downstream fulfillment systems.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTime rdf:type rdf:Property ;
    rdfs:label 'Completion Time' ;
    rdfs:comment 'The date and time at which this task reached a terminal state (completed, failed, or cancelled) in the OSM orchestration engine. Used to calculate task duration, SLA compliance, and MTTR for fulfillment operations.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decompositionRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Decomposition Rule Version' ;
    rdfs:comment 'Version of the decomposition rule applied at the time this task was generated. Supports impact analysis when orchestration rules are updated and enables reproducibility of order decomposition logic for audit purposes.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyTaskIds rdf:type rdf:Property ;
    rdfs:label 'Dependency Task Ids' ;
    rdfs:comment 'Comma-separated list of order_task_id values that must reach \'completed\' status before this task can begin execution. Captures the dependency chain within the OSM orchestration workflow to enforce correct fulfillment sequencing (e.g., HLR provisioning must complete before VoLTE IMS registration).' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionSequence rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence' ;
    rdfs:comment 'Numeric ordering position of this task within the overall order fulfillment workflow. Determines the sequence in which tasks are executed relative to sibling tasks on the same order line. Lower values execute first.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falloutDetail rdf:type rdf:Property ;
    rdfs:label 'Fallout Detail' ;
    rdfs:comment 'Free-text description of the error or exception that caused this task to fall out, as returned by the downstream target system or the OSM orchestration engine. Provides diagnostic context for manual resolution by NOC or BSS operations teams.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutIndicator rdf:type rdf:Property ;
    rdfs:label 'Fallout Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this task has entered fallout status requiring manual intervention or escalation. True when the task has exceeded retry limits or encountered an unrecoverable error. Drives fallout management queues in OSM and ServiceNow ITSM.' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ontSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ont Serial Number' ;
    rdfs:comment 'Serial number of the Optical Network Terminal (ONT) / Customer Premises Equipment (CPE) being activated or configured by this task. Populated for GPON ONT activation and CPE dispatch tasks. Used for FTTH inventory reconciliation and field technician dispatch coordination.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderActionType rdf:type rdf:Property ;
    rdfs:label 'Order Action Type' ;
    rdfs:comment 'The commercial order action that triggered the creation of this task. Inherited from the parent order line and used to determine the appropriate provisioning logic in the downstream target system. MNP (Mobile Number Portability) port-in/port-out tasks require coordination with GSMA NRTRDE and TAP processes. [ENUM-REF-CANDIDATE: new_activation|upgrade|downgrade|disconnection|mnp_port_in|mnp_port_out|change_of_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this order task as assigned by the OSM orchestration engine (e.g., TSK-2024-00123456). Used in NOC dashboards, trouble tickets, and cross-system correlation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the order task within the OSM orchestration engine. Drives SLA monitoring, fallout management, and retry logic. Valid states: pending (awaiting execution), in_progress (actively executing), completed (successfully fulfilled), failed (execution error), cancelled (task voided), suspended (paused pending dependency resolution).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classifies the atomic fulfillment action this task represents within the OSM orchestration workflow. Drives routing to the appropriate downstream system and execution handler. [ENUM-REF-CANDIDATE: hlr_hss_provisioning|ip_address_assignment|cpe_dispatch|gpon_ont_activation|number_portability_submission|sim_activation|service_configuration|esim_provisioning|voip_registration|ims_registration|mpls_circuit_setup|ran_configuration — promote to reference product]' ;
    rdfs:domain ind:Task ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResultId rdf:type rdf:Property ;
    rdfs:label 'Validation Result Id' ;
    rdfs:comment 'Unique identifier for the order validation result record. Primary key.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compatibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Compatibility Rule Id' ;
    rdfs:comment 'Foreign key linking to product.compatibility_rule. Business justification: Compatibility validation outcomes must reference the catalog rule evaluated for troubleshooting order fallouts, rule tuning, and product configuration quality improvement. Critical for order success r' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompatibilityRule .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Foreign key linking to product.eligibility_rule. Business justification: Validation results must trace to the specific eligibility rule evaluated for audit trail, rule effectiveness analysis, override justification, and regulatory compliance reporting. Essential for order ' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityRule .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Result of address validation check. VALID indicates address is verified, CORRECTED indicates address was standardized, INVALID indicates address cannot be verified. Applicable only for ADDRESS validation category.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caleaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Calea Compliance Status' ;
    rdfs:comment 'Indicates whether the order complies with Communications Assistance for Law Enforcement Act (CALEA) requirements for lawful intercept capability. Applicable for regulated telecommunications services.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitApproved rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Approved' ;
    rdfs:comment 'Maximum credit limit approved for the customer based on credit check. Applicable only for CREDIT validation category. Nullable for non-credit validations.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Required Amount' ;
    rdfs:comment 'Security deposit amount required based on credit check outcome. Applicable only for CREDIT validation category. Nullable if no deposit required or for non-credit validations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Availability Status' ;
    rdfs:comment 'Availability status of required inventory items (Customer Premises Equipment (CPE), Subscriber Identity Module (SIM) cards, etc.) for order fulfillment. Applicable for orders requiring physical inventory.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverridden rdf:type rdf:Property ;
    rdfs:label 'Is Overridden' ;
    rdfs:comment 'Indicates whether a failed validation was manually overridden by an authorized agent. True if override was applied, False otherwise.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Override Allowed' ;
    rdfs:comment 'Indicates whether this validation failure can be manually overridden by an authorized agent. True if override is permitted, False if validation failure is absolute.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpCoolingPeriodCompliant rdf:type rdf:Property ;
    rdfs:label 'Mnp Cooling Period Compliant' ;
    rdfs:comment 'Indicates whether the Mobile Number Portability (MNP) request complies with regulatory cooling-off period requirements. Applicable only for MNP port-in orders. Nullable for non-MNP orders.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpCoolingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Mnp Cooling Period End Date' ;
    rdfs:comment 'Date when the Mobile Number Portability (MNP) regulatory cooling-off period expires and porting can proceed. Applicable only for MNP port-in orders. Nullable for non-MNP orders.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msisdnAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Msisdn Availability Status' ;
    rdfs:comment 'Availability status of the requested Mobile Station International Subscriber Directory Number (MSISDN). Applicable for new activation and Mobile Number Portability (MNP) orders. Nullable for non-mobile service orders.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapacityAvailable rdf:type rdf:Property ;
    rdfs:label 'Network Capacity Available' ;
    rdfs:comment 'Indicates whether sufficient network capacity exists to fulfill the service request at the specified location. Applicable for bandwidth-intensive services (Fiber to the Home (FTTH), 5G New Radio (5G NR), etc.).' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAgentName rdf:type rdf:Property ;
    rdfs:label 'Override Agent Name' ;
    rdfs:comment 'Full name of the employee or agent who authorized the validation override. Used for audit reporting. Nullable if no override was applied.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for validation override (e.g., CUST_REQUEST, EXEC_APPROVAL, SYSTEM_ERROR, BUSINESS_EXCEPTION). Nullable if no override was applied.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Override Reason Description' ;
    rdfs:comment 'Free-text description explaining why the validation failure was overridden. Required for compliance and audit purposes when override is applied.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCompatibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Product Compatibility Status' ;
    rdfs:comment 'Result of product compatibility validation checking whether requested products can coexist or if existing services require modification. Applicable for change-of-service and upgrade orders.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Status' ;
    rdfs:comment 'Outcome of service eligibility check indicating whether requested service can be provisioned at the specified location. Applicable only for ELIGIBILITY validation category.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationCategory rdf:type rdf:Property ;
    rdfs:label 'Validation Category' ;
    rdfs:comment 'High-level category of the validation check performed. Groups validation rules into functional domains for reporting and orchestration. [ENUM-REF-CANDIDATE: CREDIT|ELIGIBILITY|ADDRESS|INVENTORY|REGULATORY|COMPATIBILITY|TECHNICAL|BUSINESS_RULE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'Standardized error code for failed validations. Used for automated error handling, routing, and reporting. Nullable if validation passed.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Expiry Timestamp' ;
    rdfs:comment 'Date and time when this validation result expires and must be re-executed. Some validations (credit checks, inventory reservations) have time-limited validity.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Message' ;
    rdfs:comment 'Detailed message describing the validation result. For failures, contains specific reason and remediation guidance. For warnings, contains advisory information.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Result of the validation check execution. PASS indicates validation succeeded, FAIL indicates validation failed and order cannot proceed, WARNING indicates potential issue but order may proceed, SKIPPED indicates validation was not executed, ERROR indicates validation could not be completed due to technical issue.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResponsePayload rdf:type rdf:Property ;
    rdfs:label 'Validation Response Payload' ;
    rdfs:comment 'Raw response payload from the validation system. Stored for audit and detailed troubleshooting. May contain JSON or XML formatted data.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Code' ;
    rdfs:comment 'Unique code identifying the validation rule that was executed (e.g., CREDIT_CHECK, ADDRESS_VAL, MSISDN_AVAIL, MNP_COOLING, CALEA_COMP, PROD_COMPAT, SVC_ELIGIBILITY). Used to categorize and track validation types.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleName rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Name' ;
    rdfs:comment 'Human-readable name of the validation rule executed (e.g., Credit Check, Service Eligibility Verification, Mobile Number Portability (MNP) Cooling-Off Period Check).' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Sequence Number' ;
    rdfs:comment 'Sequential order in which this validation was executed within the overall validation workflow. Used to track validation orchestration and dependencies.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationSeverity rdf:type rdf:Property ;
    rdfs:label 'Validation Severity' ;
    rdfs:comment 'Severity level of the validation result. CRITICAL failures block order progression, HIGH failures require manual review, MEDIUM and LOW may allow conditional progression.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSystemSource rdf:type rdf:Property ;
    rdfs:label 'Validation System Source' ;
    rdfs:comment 'Name of the system or service that performed the validation check (e.g., Amdocs Credit Engine, Salesforce Address Validator, Netcracker Inventory, Internal MNP Gateway). Used for troubleshooting and system dependency tracking.' ;
    rdfs:domain ind:ValidationResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningRequestId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the provisioning request record in the Silver Layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bandwidthProfileCode rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Profile Code' ;
    rdfs:comment 'Code identifying the bandwidth profile (upstream/downstream speed tier) to be applied to the service. Maps to a predefined bandwidth template in the OLT, DSLAM, or BNG configuration. Examples: 100M_FTTH, 1G_FTTH, 50M_ADSL.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressAssigned rdf:type rdf:Property ;
    rdfs:label 'Ip Address Assigned' ;
    rdfs:comment 'The IPv4 or IPv6 address assigned to the subscriber or CPE device as part of this provisioning action. Populated by the IP Address Management (IPAM) system upon successful provisioning. Applicable for broadband, FTTH, and fixed-line services.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRollbackRequired rdf:type rdf:Property ;
    rdfs:label 'Is Rollback Required' ;
    rdfs:comment 'Indicates whether a rollback of previously applied provisioning changes is required due to a downstream failure in a multi-step orchestration workflow. When TRUE, the OSM compensation workflow is triggered to reverse partial provisioning actions.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpPortDate rdf:type rdf:Property ;
    rdfs:label 'Mnp Port Date' ;
    rdfs:comment 'The scheduled or actual date on which the Mobile Number Portability (MNP) port-in or port-out is to be executed. Applicable only when provisioning_action is PORT_IN or PORT_OUT. Governed by national MNP regulatory timelines.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkRegionCode rdf:type rdf:Property ;
    rdfs:label 'Network Region Code' ;
    rdfs:comment 'Code identifying the geographic network region or Point of Presence (POP) within which the provisioning action is being executed. Used for regional capacity planning, NOC routing, and geographic SLA analysis.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningAction rdf:type rdf:Property ;
    rdfs:label 'Provisioning Action' ;
    rdfs:comment 'The type of provisioning operation to be performed on the target OSS system. ACTIVATE: new service activation; MODIFY: change of service parameters; DEACTIVATE: service disconnection; SUSPEND: temporary service suspension; RESUME: reinstatement after suspension; PORT_IN: Mobile Number Portability (MNP) inbound port; PORT_OUT: MNP outbound port. [ENUM-REF-CANDIDATE: ACTIVATE|MODIFY|DEACTIVATE|SUSPEND|RESUME|PORT_IN|PORT_OUT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningOutcome rdf:type rdf:Property ;
    rdfs:label 'Provisioning Outcome' ;
    rdfs:comment 'Final result of the provisioning execution as reported by the target OSS system. SUCCESS: service fully activated/modified/deactivated as requested; FAILURE: provisioning could not be completed; TIMEOUT: target system did not respond within the configured timeout window; PARTIAL: some but not all service components were provisioned (e.g., multi-component service). Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category for non-monetary transactions.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosProfileCode rdf:type rdf:Property ;
    rdfs:label 'Qos Profile Code' ;
    rdfs:comment 'Code identifying the Quality of Service (QoS) profile to be applied to the service being provisioned. Maps to a predefined QoS template in the PCF/PCRF defining bandwidth limits, priority class, and traffic shaping parameters.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the provisioning request as generated by Oracle Communications OSM (e.g., PROV-2024-0001234). Used for cross-system traceability across OSS/BSS platforms. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledActivationDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Activation Date' ;
    rdfs:comment 'The date on which the service activation or modification is scheduled to take effect, as agreed with the customer or mandated by the order. May differ from dispatch_timestamp for future-dated provisioning requests.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceParametersPayload rdf:type rdf:Property ;
    rdfs:label 'Service Parameters Payload' ;
    rdfs:comment 'Serialized (JSON or XML) payload containing the service-specific configuration parameters dispatched to the target OSS system. For mobile services: MSISDN, IMSI, APN, QoS profile; for FTTH/GPON: ONT serial number, VLAN ID, bandwidth profile; for IMS: SIP URI, codec list. Stored as STRING to accommodate heterogeneous service types.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Seconds' ;
    rdfs:comment 'The contracted Service Level Agreement (SLA) target duration in seconds within which this provisioning request must be completed end-to-end. Used for SLA compliance monitoring and breach detection in NOC dashboards.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSystemInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Target System Instance Reference' ;
    rdfs:comment 'Identifier of the specific system instance or node within the target OSS system (e.g., HSS cluster node ID, OLT shelf/port identifier) to which the provisioning command is routed. Supports multi-node environments and geo-redundant deployments.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQualificationId rdf:type rdf:Property ;
    rdfs:label 'Service Qualification Id' ;
    rdfs:comment 'Unique surrogate identifier for the service qualification record. Primary key for the service_qualification data product in the order domain Silver layer.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableTechnologyOptions rdf:type rdf:Property ;
    rdfs:label 'Available Technology Options' ;
    rdfs:comment 'Pipe-delimited list of all access technologies technically available at the qualified address (e.g., \'FTTH|LTE|5G_NR\'). Enables the sales system to present all eligible product offers, not just the primary requested technology. Sourced from Netcracker Resource Inventory network coverage data.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadbandSubsidyEligible rdf:type rdf:Property ;
    rdfs:label 'Broadband Subsidy Eligible' ;
    rdfs:comment 'Indicates whether the service address qualifies for government broadband subsidy programs (e.g., FCC Affordable Connectivity Program (ACP), NTIA BEAD, UK Gigabit Voucher Scheme). Determined based on regulatory_zone_code and address-level coverage data. Relevant for compliance reporting to FCC, NTIA, and Ofcom.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Free-text description of any technical or operational constraints identified during the qualification check when the outcome is ELIGIBLE_WITH_CONSTRAINTS. Examples: \'Maximum speed limited to 100 Mbps due to copper loop length\', \'CPE upgrade required\', \'Shared GPON port — peak-hour congestion possible\'. Null when outcome is ELIGIBLE or NOT_ELIGIBLE.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpeRequired rdf:type rdf:Property ;
    rdfs:label 'Cpe Required' ;
    rdfs:comment 'Indicates whether a Customer Premises Equipment (CPE) installation or upgrade is required to deliver the requested service at the qualified address. True: CPE installation/upgrade is mandatory; False: existing CPE is compatible or no CPE is needed.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpeType rdf:type rdf:Property ;
    rdfs:label 'Cpe Type' ;
    rdfs:comment 'Type of CPE required for service delivery at the qualified address. ONT (Optical Network Terminal) for FTTH/GPON; ROUTER for broadband; MODEM for DSL; GATEWAY for combined modem/router; OUTDOOR_UNIT/INDOOR_UNIT for fixed wireless. Null when cpe_required is False.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedInstallationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Installation Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order confirmation to service activation at the qualified address. Derived from field workforce availability (Granite WFM), infrastructure readiness, and network node capacity. Displayed to customers during the ordering flow to set delivery expectations.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Estimated Latency Ms' ;
    rdfs:comment 'Estimated round-trip network latency in milliseconds at the qualified address for the requested service type. Relevant for QoS-sensitive product offers (VoLTE, gaming, enterprise SD-WAN) and SLA eligibility determination.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldSurveyRequired rdf:type rdf:Property ;
    rdfs:label 'Field Survey Required' ;
    rdfs:comment 'Indicates whether a physical field survey by a Telecommunication technician is required before service can be provisioned at this address. True when infrastructure readiness is PARTIAL or NOT_READY, or when the qualification engine cannot determine feasibility remotely. Triggers a field dispatch work order in Granite WFM.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ineligibilityReasonCode rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the address is NOT_ELIGIBLE for the requested service. NO_COVERAGE: outside network footprint; CAPACITY_EXHAUSTED: node at full capacity; INFRASTRUCTURE_NOT_BUILT: planned but not yet deployed; ADDRESS_NOT_FOUND: address could not be geocoded or matched; TECHNICAL_BARRIER: physical impediment; REGULATORY_RESTRICTION: regulatory constraint. Null when outcome is ELIGIBLE or ELIGIBLE_WITH_CONSTRAINTS.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureReadiness rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Readiness' ;
    rdfs:comment 'Indicates the physical network infrastructure readiness at or near the service address. READY: full infrastructure in place; PARTIAL: partial build-out, service possible with constraints; NOT_READY: no infrastructure present; UNDER_CONSTRUCTION: active network build in progress with a planned completion date.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDownloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Max Download Speed Mbps' ;
    rdfs:comment 'Maximum technically achievable downstream bandwidth in Megabits per second (Mbps) at the qualified address, as determined by the network qualification engine based on distance to node, line quality, and technology capability. Drives product tier eligibility in the sales flow.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxUploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Max Upload Speed Mbps' ;
    rdfs:comment 'Maximum technically achievable upstream bandwidth in Megabits per second (Mbps) at the qualified address. Critical for symmetric service offerings (FTTH/GPON) and business-grade SLA commitments.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mnpApplicable rdf:type rdf:Property ;
    rdfs:label 'Mnp Applicable' ;
    rdfs:comment 'Indicates whether Mobile Number Portability (MNP) is applicable to this service qualification, relevant for mobile service types (LTE, 5G NR) where the customer intends to port an existing number. True triggers MNP eligibility checks in the downstream order flow.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationChannel rdf:type rdf:Property ;
    rdfs:label 'Qualification Channel' ;
    rdfs:comment 'The sales or service channel through which the qualification request was initiated. ONLINE: digital self-service portal; RETAIL_STORE: in-store agent; CALL_CENTER: inbound/outbound agent via Salesforce CRM; PARTNER_API: wholesale or MVNO partner API; FIELD_AGENT: mobile field sales; SELF_SERVICE: automated IVR or chatbot.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Completed Timestamp' ;
    rdfs:comment 'The date and time when the qualification check was fully resolved and an outcome was determined. Null if the qualification is still IN_PROGRESS or was CANCELLED before completion.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'The date after which the qualification result is considered stale and must be re-evaluated before an order can be placed. Network conditions, capacity, and infrastructure status can change; this date enforces re-qualification for orders placed after a defined validity window (typically 30–90 days).' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Qualification Outcome' ;
    rdfs:comment 'Business result of the pre-order service qualification check. ELIGIBLE: the address/location can receive the requested service without restriction; NOT_ELIGIBLE: service cannot be delivered to this location; ELIGIBLE_WITH_CONSTRAINTS: service is technically feasible but subject to limitations (e.g., reduced bandwidth, extended lead time, CPE upgrade required).' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the qualification request by Oracle Communications Order and Service Management (OSM). Used by sales agents and customers to track the qualification check.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Qualification Source System' ;
    rdfs:comment 'The originating operational system that submitted the qualification request. OSM: Oracle Communications Order and Service Management; SALESFORCE: Salesforce CRM; NETCRACKER: Netcracker OSS/BSS Suite; PARTNER_PORTAL: wholesale/MVNO partner portal; SELF_SERVICE_PORTAL: customer-facing digital portal. Used for data lineage and system-of-record traceability.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryZoneCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Zone Code' ;
    rdfs:comment 'Regulatory or geographic zone code assigned to the service address, used to determine applicable regulatory obligations (e.g., FCC Universal Service Fund (USF) eligible area, NTIA BEAD-eligible zone, Ofcom Universal Service Obligation (USO) area, BEREC regulated zone). Drives compliance reporting and subsidy eligibility.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Requalification Required' ;
    rdfs:comment 'Indicates whether this qualification result has been flagged as requiring re-execution before an order can proceed. Set to True when the qualification_expiry_date has passed, when network topology changes have occurred in the serving area, or when the customer requests a different service type.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedServiceType rdf:type rdf:Property ;
    rdfs:label 'Requested Service Type' ;
    rdfs:comment 'The access technology or service type for which eligibility is being assessed. Values align with the network technologies offered by Telecommunication: FTTH (Fiber to the Home), GPON (Gigabit Passive Optical Network), LTE (Long-Term Evolution), 5G NR (5G New Radio), ADSL, VDSL, FTTB (Fiber to the Building), FTTC (Fiber to the Cabinet), FIXED_WIRELESS. [ENUM-REF-CANDIDATE: FTTH|GPON|LTE|5G_NR|ADSL|VDSL|FTTB|FTTC|FIXED_WIRELESS — promote to reference product]' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Survey Scheduled Date' ;
    rdfs:comment 'The calendar date on which the field survey is scheduled to be conducted at the customer premises, when field_survey_required is True. Populated by Granite WFM upon technician dispatch scheduling. Null when no survey is required.' ;
    rdfs:domain ind:ServiceQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterAgentDealerId rdf:type rdf:Property ;
    rdfs:label 'Master Agent Dealer Id' ;
    rdfs:comment 'Reference to the parent master agent in the channel hierarchy if this dealer operates as a sub-agent.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealer .

ind:primaryContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Dealer/retail channel management requires internal relationship owner for activation quota management, compliance audits, POS system integration, and commission settlement. Critical for indirect sales' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revenueSharePlanId rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Plan Id' ;
    rdfs:comment 'Foreign key linking to partner.revenue_share_plan. Business justification: Dealers have commission structures that should reference standardized revenue_share_plan definitions. The commission_structure_reference is a string that should be replaced with a proper FK to revenue' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueSharePlan .

ind:activationCredentialCode rdf:type rdf:Property ;
    rdfs:label 'Activation Credential Code' ;
    rdfs:comment 'Unique credential or API key identifier used by the dealer to authenticate and perform service activations in carrier systems.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedProductPortfolio rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Portfolio' ;
    rdfs:comment 'Comma-separated list or description of product categories and service offerings the dealer is authorized to sell.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTerritory rdf:type rdf:Property ;
    rdfs:label 'Authorized Territory' ;
    rdfs:comment 'Geographic region, market area, or territory where the dealer is authorized to conduct sales and service activities.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing or sort code for electronic funds transfer to the dealer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'Primary street address line for the dealer\'s principal place of business.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Secondary street address line for suite, unit, or building details of the dealer\'s business location.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City or municipality where the dealer\'s principal place of business is located.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the dealer\'s principal business location.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the dealer\'s business address.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'State, province, or administrative region where the dealer\'s business is located.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the indirect sales channel participant role within the partner ecosystem.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Status' ;
    rdfs:comment 'Current status of the dealer\'s compliance certification indicating whether they meet regulatory and carrier policy requirements.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the dealer agreement became legally effective and operational.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when the current dealer agreement expires or is scheduled for renewal.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractRenewalTerms rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Terms' ;
    rdfs:comment 'Description of the renewal terms, conditions, and notice period requirements for the dealer agreement.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Code' ;
    rdfs:comment 'Externally-known unique business identifier assigned to the dealer for operational reference and system integration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyActivationQuota rdf:type rdf:Property ;
    rdfs:label 'Monthly Activation Quota' ;
    rdfs:comment 'Target number of new service activations the dealer is expected to achieve per month as per agreement terms.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the next compliance or performance audit of the dealer.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completed Date' ;
    rdfs:comment 'Date when the dealer successfully completed all onboarding requirements and became operationally active.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Endpoint' ;
    rdfs:comment 'API endpoint URL or system integration identifier for connecting the dealer\'s POS system to carrier BSS/OSS platforms.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Type or vendor name of the point-of-sale system used by the dealer for transaction processing and inventory management.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Tier' ;
    rdfs:comment 'Current performance tier classification based on the dealer\'s adherence to contractual SLA commitments.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierGrade rdf:type rdf:Property ;
    rdfs:label 'Tier Grade' ;
    rdfs:comment 'Performance-based tier classification indicating the dealer\'s standing, sales volume, and benefit level within the channel program.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The business trading name under which the dealer operates and is publicly known.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostAgreementId rdf:type rdf:Property ;
    rdfs:label 'Host Agreement Id' ;
    rdfs:comment 'Reference to the master host agreement contract governing the MVNO relationship, terms, and commercial arrangements.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:mvnoPartnerId rdf:type rdf:Property ;
    rdfs:label 'Mvno Partner Id' ;
    rdfs:comment 'Reference to the partner entity representing this MVNO in the partner master data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:wholesaleRatePlanId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Rate Plan Id' ;
    rdfs:comment 'Reference to the wholesale rate plan applied to this MVNO for usage-based charging (voice, SMS, data).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatePlan .

ind:billingArrangementType rdf:type rdf:Property ;
    rdfs:label 'Billing Arrangement Type' ;
    rdfs:comment 'Defines the billing model between host MNO and MVNO: wholesale rated (MNO bills MVNO), retail billed (MNO bills end customers on behalf of MVNO), hybrid, or self-billed (MVNO manages own billing).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the billing and finance contact at the MVNO for invoicing and settlement matters.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Current Subscriber Count' ;
    rdfs:comment 'Current number of active subscribers provisioned under this MVNO profile.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esimSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Esim Support Enabled' ;
    rdfs:comment 'Indicates whether the MVNO supports eSIM provisioning and management for subscribers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiveGAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Five G Access Enabled' ;
    rdfs:comment 'Indicates whether MVNO subscribers have access to 5G NR network services.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlrProvisioningEnabled rdf:type rdf:Property ;
    rdfs:label 'Hlr Provisioning Enabled' ;
    rdfs:comment 'Indicates whether the MVNO has direct provisioning access to the HLR for subscriber management.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hssProvisioningEnabled rdf:type rdf:Property ;
    rdfs:label 'Hss Provisioning Enabled' ;
    rdfs:comment 'Indicates whether the MVNO has direct provisioning access to the HSS for LTE/IMS subscriber management.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'International Roaming Enabled' ;
    rdfs:comment 'Indicates whether MVNO subscribers are permitted to roam internationally on partner carrier networks.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msisdnRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Msisdn Range End' ;
    rdfs:comment 'Ending phone number in the MSISDN range allocated to this MVNO for customer-facing mobile numbers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msisdnRangeStart rdf:type rdf:Property ;
    rdfs:label 'Msisdn Range Start' ;
    rdfs:comment 'Starting phone number in the MSISDN range allocated to this MVNO for customer-facing mobile numbers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoBrandName rdf:type rdf:Property ;
    rdfs:label 'Mvno Brand Name' ;
    rdfs:comment 'The commercial brand name under which the MVNO operates and markets services to end customers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoCode rdf:type rdf:Property ;
    rdfs:label 'Mvno Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the MVNO for operational identification across network and billing systems.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoLegalName rdf:type rdf:Property ;
    rdfs:label 'Mvno Legal Name' ;
    rdfs:comment 'The legal registered business name of the MVNO entity as per incorporation documents.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoType rdf:type rdf:Property ;
    rdfs:label 'Mvno Type' ;
    rdfs:comment 'Classification of the MVNO business model: full MVNO (owns core network elements), light MVNO (limited infrastructure), branded reseller (pure resale), ESP (Enhanced Service Provider), or MVNE (MVNO Enabler).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAccessType rdf:type rdf:Property ;
    rdfs:label 'Network Access Type' ;
    rdfs:comment 'Level of network infrastructure access granted to the MVNO: full access to RAN and core, RAN sharing only, core network sharing, or pure resale arrangement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spectrumAccessRights rdf:type rdf:Property ;
    rdfs:label 'Spectrum Access Rights' ;
    rdfs:comment 'Description of spectrum bands and frequencies the MVNO is authorized to utilize (e.g., 700MHz, 1800MHz, 2600MHz, 3.5GHz 5G NR).' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCapacityLimit rdf:type rdf:Property ;
    rdfs:label 'Subscriber Capacity Limit' ;
    rdfs:comment 'Maximum number of active subscribers the MVNO is permitted to host on the network infrastructure as per contractual agreement.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the technical operations contact at the MVNO for network and provisioning issues.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteEnabled rdf:type rdf:Property ;
    rdfs:label 'Volte Enabled' ;
    rdfs:comment 'Indicates whether VoLTE voice services are enabled for MVNO subscribers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vowifiEnabled rdf:type rdf:Property ;
    rdfs:label 'Vowifi Enabled' ;
    rdfs:comment 'Indicates whether VoWiFi (Wi-Fi calling) services are enabled for MVNO subscribers.' ;
    rdfs:domain ind:MvnoProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingRequestId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Request Id' ;
    rdfs:comment 'Unique identifier for the partner onboarding request. Primary key for this entity.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiConnectivityValidated rdf:type rdf:Property ;
    rdfs:label 'Api Connectivity Validated' ;
    rdfs:comment 'Indicates whether API connectivity testing has been successfully completed and validated.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the partner submitted the initial onboarding application.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or identifier of the business user responsible for managing this onboarding request through completion.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date when the partner contract was formally executed and signed by all parties.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Assessment Status' ;
    rdfs:comment 'Status of the financial credit assessment to evaluate the partner\'s creditworthiness and financial stability.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Documentation Checklist Complete' ;
    rdfs:comment 'Indicates whether all required onboarding documentation has been received and verified as complete.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveActualDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Actual Date' ;
    rdfs:comment 'Actual date when the partner was activated and went live in production systems.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goLiveTargetDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Target Date' ;
    rdfs:comment 'Planned target date for partner activation and go-live in production systems.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationTestCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Integration Test Completion Date' ;
    rdfs:comment 'Date when all technical integration testing was successfully completed and approved.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'Date when the KYC due diligence process was completed and approved.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Status of the Know Your Customer (KYC) due diligence process for regulatory compliance and risk assessment.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle state of the onboarding request workflow. Tracks progression from initial application through approval or rejection. [ENUM-REF-CANDIDATE: Draft|Submitted|KYC In Progress|Credit Assessment|Contract Review|Technical Integration|Approved|Rejected|Cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the assigned owner for communication and notifications regarding this onboarding request.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory approval was granted by the relevant governing body.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval process with governing bodies such as Federal Communications Commission (FCC) or International Telecommunication Union (ITU) where required for partner activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the onboarding request was rejected and the process terminated.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'Type of revenue sharing arrangement agreed with the partner: Fixed Fee, Percentage-based, Tiered structure, Hybrid model, or Cost Plus.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which financial settlements and revenue sharing payments are processed with the partner.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTermsDefined rdf:type rdf:Property ;
    rdfs:label 'Sla Terms Defined' ;
    rdfs:comment 'Indicates whether Service Level Agreement (SLA) terms have been defined and agreed upon with the partner.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapFileExchangeValidated rdf:type rdf:Property ;
    rdfs:label 'Tap File Exchange Validated' ;
    rdfs:comment 'Indicates whether TAP file exchange validation for roaming data has been successfully completed. Applicable for roaming partners and Mobile Virtual Network Operator (MVNO) relationships.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Integration Status' ;
    rdfs:comment 'Status of technical integration testing including Application Programming Interface (API) connectivity, Transferred Account Procedure (TAP) file exchange validation, and system integration testing. [ENUM-REF-CANDIDATE: Not Started|Planning|API Testing|TAP Validation|System Integration|UAT|Approved|Failed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'FK to people.employee' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Id' ;
    rdfs:comment 'Reference to the parent partner in a corporate hierarchy. Null for top-level partners. Used to model subsidiary relationships and consolidated reporting.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:contractRenewalType rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Type' ;
    rdfs:comment 'Renewal mechanism for the partner agreement. Auto-renew contracts extend automatically unless terminated; manual-renew requires explicit action.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name used by the partner in commercial operations. May differ from legal name for branding purposes.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the partner organization headquarters. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'Standard industry classification code for the partner organization. Typically NAICS or SIC code. Used for market segmentation and competitive analysis.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountries rdf:type rdf:Property ;
    rdfs:label 'Operating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner has active operations. Used for roaming agreements, content licensing, and multi-jurisdiction compliance.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Externally-known unique business identifier for the partner. Used in contracts, invoices, and inter-operator communications. Typically assigned during onboarding and immutable thereafter.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Full legal name of the partner organization as registered with governing authorities. Used for contracts, regulatory filings, and legal correspondence.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship. Active partners are eligible for transactions and settlements. Suspended or terminated partners are blocked from new business.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Strategic tier or grade assigned to the partner based on revenue contribution, strategic importance, and relationship maturity. Influences SLA commitments, support priority, and commercial terms.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner based on their role in the telecommunications ecosystem. Determines applicable business processes, SLA templates, and revenue-sharing models. [ENUM-REF-CANDIDATE: MVNO|roaming_partner|content_provider|ott_platform|equipment_vendor|channel_partner|dealer|agent|wholesale_carrier|interconnect_carrier|network_vendor|system_integrator — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number for the partner entity. Used for invoicing, tax reporting, and revenue settlement. Format varies by jurisdiction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the partner organization. Used for due diligence, public information verification, and business intelligence.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Signed By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Partner contracts require internal signatory tracking for legal compliance, audit trails, and authority verification. Telecom wholesale/MVNO agreements involve significant financial commitments requir' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Partner agreements specify SLA performance metrics (uptime %, latency, throughput) that must reference formal KPI definitions for consistent measurement and reporting. Telecom operators standardize SL' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether Telecommunication retains the right to audit partner records, systems, or processes for compliance verification.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years that confidentiality obligations survive agreement termination. Governs data retention and disclosure policies.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSharingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permitted Flag' ;
    rdfs:comment 'Indicates whether customer or operational data sharing is permitted under this agreement. Critical for GDPR and privacy compliance.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'URL or file path to the secure repository location where the executed agreement and related documents are stored.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the scope of exclusivity granted, including geographic territories, product lines, or customer segments covered.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Fee Amount' ;
    rdfs:comment 'Fixed periodic payment amount for fixed-fee agreements. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Amount' ;
    rdfs:comment 'Minimum insurance coverage amount required from the partner for liability, professional indemnity, or other risk categories.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum to the agreement. Tracks contract evolution and version history.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum revenue, volume, or purchase commitment required from either party over the contract term. Confidential commercial term.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Value of performance bond or bank guarantee required to secure partner obligations. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Commercial model governing how revenue or costs are shared between Telecommunication and the partner. Determines settlement calculation methodology.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty assessed for early termination of the agreement. Confidential commercial term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Partner Certification Id' ;
    rdfs:comment 'Unique identifier for the partner certification record. Primary key.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'The required frequency (in months) at which the partner must undergo compliance audits or recertification reviews to maintain this certification. Examples: 12 (annual), 24 (biennial), 36 (triennial). Nullable if no periodic audit is required.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'The result of the most recent compliance audit or recertification review. Indicates whether the partner passed the audit, passed with minor conditions/findings, failed and requires corrective action, or audit is pending completion.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authority rdf:type rdf:Property ;
    rdfs:label 'Authority' ;
    rdfs:comment 'The name of the regulatory body, standards organization, or certifying entity that issued the certification. Examples: Federal Communications Commission (FCC), European Telecommunications Standards Institute (ETSI), International Telecommunication Union (ITU), International Organization for Standardization (ISO), GSM Association (GSMA), Office of Communications (Ofcom), national telecommunications regulatory authorities.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Authority Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction of the certifying authority (e.g., USA for FCC, GBR for Ofcom, DEU for BNetzA). Used for multi-jurisdiction compliance tracking.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'The monetary value of the performance bond or financial guarantee required from the partner. Expressed in the base currency of the business. Nullable if no bond is required.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Bond Expiry Date' ;
    rdfs:comment 'The expiration date of the partners performance bond or financial guarantee. Used to monitor bond coverage continuity. Nullable if no bond is required.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Bond Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the partner is required to post a performance bond or financial guarantee as a condition of this certification (common for dealer/agent licenses and spectrum licenses). True if bond is required, False otherwise.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The tier or grade of certification achieved by the partner, if the certification framework includes multiple levels. Examples: Gold/Silver/Bronze partner tiers, Level 1/2/3 dealer authorization, Basic/Advanced/Expert agent certification. Nullable if the certification does not have levels.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The official certificate number or registration identifier issued by the certifying authority. This is the externally-known unique identifier for the certification (e.g., FCC Equipment Authorization number, ETSI type approval certificate number, ISO 27001 certificate number, dealer license number).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Indicates whether the certification is active and valid, expired and requires renewal, suspended by the regulatory body, pending renewal workflow, revoked due to non-compliance, or under review by the certifying authority.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Certified Product Category' ;
    rdfs:comment 'The product or service category that this certification authorizes the partner to provide, sell, or operate. Examples: CPE (Customer Premises Equipment), mobile handsets, FTTH (Fiber to the Home) equipment, MVNO (Mobile Virtual Network Operator) services, IPTV (Internet Protocol Television) content, broadband services.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'The technical or quality standard that the partner must comply with under this certification. Examples: ISO 9001 (quality management), ISO 27001 (information security), SOC 2 Type II (service organization controls), PCI DSS (payment card industry data security), GDPR (data protection).' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The deadline by which the partner must complete corrective actions to address audit findings or non-compliance issues. Nullable if no corrective action is required.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of corrective actions required to address audit findings. Tracks whether corrective action is not required, open and not started, in progress, completed by partner, overdue, or verified/closed by the certifying authority.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'The geographic region or territory where this certification is valid and the partner is authorized to operate. Examples: nationwide, specific states/provinces, regional (e.g., EU, APAC), or global. Particularly relevant for spectrum licenses, dealer territories, and content broadcasting licenses.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The expiration date of the partners insurance policy. Used to monitor insurance coverage continuity and trigger renewal alerts. Nullable if insurance is not required.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the partner is required to maintain specific insurance coverage (liability, professional indemnity, errors and omissions) as a condition of this certification. True if insurance is required, False otherwise.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOwnerName rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Name' ;
    rdfs:comment 'The name of the internal employee or team responsible for managing this partner certification relationship on behalf of the telecommunications business. Used for internal accountability and workflow routing.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The date on which the certification was most recently renewed. Used to track renewal history and calculate next renewal cycle.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next compliance audit or recertification review. Calculated based on last_audit_date and audit_frequency_months. Used to trigger audit preparation workflows.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Findings Count' ;
    rdfs:comment 'The number of non-compliance findings or deficiencies identified in the most recent audit. Used to assess partner compliance risk and prioritize corrective action follow-up.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The target date by which the certification renewal process must be initiated or completed to avoid lapse. Typically set ahead of expiry_date to allow for processing time. Used to trigger renewal workflow alerts.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Workflow Status' ;
    rdfs:comment 'Current state of the certification renewal workflow process. Tracks whether renewal has been initiated, documents submitted to the authority, under review, approved, rejected, or on hold pending additional information. [ENUM-REF-CANDIDATE: not_started|in_progress|documents_submitted|under_authority_review|approved|rejected|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'The email address of the responsible party at the partner organization. Used for certification renewal notifications, audit scheduling, and compliance communications.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'The name of the individual or role within the partner organization who is responsible for maintaining this certification and ensuring ongoing compliance. Used for escalation and communication purposes.' ;
    rdfs:domain ind:PartnerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactId rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Id' ;
    rdfs:comment 'Unique identifier for the partner contact record. Primary key.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Billing Notification Enabled' ;
    rdfs:comment 'Indicates whether this contact should receive billing statements, invoices, and settlement notifications.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s role within the partner organization. Defines the functional area this contact represents.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete formatted name of the partner contact for display and communication purposes.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEscalationContact rdf:type rdf:Property ;
    rdfs:label 'Is Escalation Contact' ;
    rdfs:comment 'Indicates whether this contact should be included in escalation procedures for critical issues or Service Level Agreement (SLA) breaches.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent business interaction or communication with this partner contact.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or site identifier where the contact is based within the partner organization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business telephone number for voice communication with the partner contact.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Method' ;
    rdfs:comment 'Contact\'s preferred channel for routine business communication and coordination.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Email Address' ;
    rdfs:comment 'Alternate email address for backup communication or out-of-office scenarios.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Sla Notification Enabled' ;
    rdfs:comment 'Indicates whether this contact should receive automated notifications for Service Level Agreement (SLA) performance, breaches, or warnings.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Technical Notification Enabled' ;
    rdfs:comment 'Indicates whether this contact should receive technical integration alerts, system maintenance notifications, and operational updates.' ;
    rdfs:domain ind:PartnerContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerDisputeId rdf:type rdf:Property ;
    rdfs:label 'Partner Dispute Id' ;
    rdfs:comment 'Unique identifier for the partner dispute record. Primary key.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementRunId rdf:type rdf:Property ;
    rdfs:label 'Settlement Run Id' ;
    rdfs:comment 'Foreign key linking to partner.settlement_run. Business justification: Many partner disputes arise from specific settlement runs (disputed amounts, calculation errors, data discrepancies). This FK links the dispute to the settlement run that triggered it. The dispute rec' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementRun .

ind:acknowledgedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Date' ;
    rdfs:comment 'Date when the receiving party formally acknowledged receipt of the dispute.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreedAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Agreed Adjustment Amount' ;
    rdfs:comment 'The final monetary adjustment amount agreed upon as part of the dispute resolution (positive for credits to partner, negative for debits).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreedAdjustmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Agreed Adjustment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the agreed adjustment amount.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationBody rdf:type rdf:Property ;
    rdfs:label 'Arbitration Body' ;
    rdfs:comment 'Name of the third-party arbitration or dispute resolution body engaged to resolve the dispute (e.g., GSMA Dispute Resolution Service, ICC Arbitration).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Name of the internal department or business unit responsible for handling the dispute (e.g., Partner Finance, Roaming Operations, Legal).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Disputed Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToArbitrationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated To Arbitration Flag' ;
    rdfs:comment 'Boolean indicator of whether the dispute has been escalated to formal arbitration or third-party dispute resolution.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingParty rdf:type rdf:Property ;
    rdfs:label 'Initiating Party' ;
    rdfs:comment 'Identifies which party initiated the dispute: the partner or the internal telecommunications company.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalResponse rdf:type rdf:Property ;
    rdfs:label 'Internal Response' ;
    rdfs:comment 'Summary of the internal telecommunications company\'s formal response to the dispute, including position, evidence, and proposed resolution.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAdjustmentReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Adjustment Reference' ;
    rdfs:comment 'Reference number of any invoice adjustment or correction applied as a result of the dispute resolution.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerResponse rdf:type rdf:Property ;
    rdfs:label 'Partner Response' ;
    rdfs:comment 'Summary of the partner\'s formal response to the dispute, including their position, counter-claims, or acceptance.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Due Date' ;
    rdfs:comment 'Target date by which the dispute should be resolved, based on contractual SLA or GSMA dispute resolution timelines.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Date when the dispute was formally resolved and agreement reached between parties.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:respondingParty rdf:type rdf:Property ;
    rdfs:label 'Responding Party' ;
    rdfs:comment 'Identifies which party is responding to the dispute: the partner or the internal telecommunications company.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetricBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Breached' ;
    rdfs:comment 'Specific SLA metric or KPI that was breached and is the subject of the dispute (e.g., network availability, call completion rate, response time).' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Reference' ;
    rdfs:comment 'Reference identifier or location of supporting documentation, evidence files, CDRs, TAP files, invoices, or other materials substantiating the dispute claim.' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Roaming agreements (TAP/RAP file exchange, GSMA AA12/AA13 compliance, IoT rates) require tracking of internal negotiator for accountability, knowledge retention, and future renegotiations. Critical fo' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Secure storage location or document management system URL for the signed roaming agreement contract.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCountries rdf:type rdf:Property ;
    rdfs:label 'Coverage Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this roaming agreement provides coverage (e.g., USA,CAN,MEX).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataMbRate rdf:type rdf:Property ;
    rdfs:label 'Data Mb Rate' ;
    rdfs:comment 'Wholesale rate per megabyte of data usage in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Period Days' ;
    rdfs:comment 'Number of days within which settlement disputes must be raised after invoice receipt.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Fraud Monitoring Enabled' ;
    rdfs:comment 'Indicates whether automated fraud detection and prevention mechanisms are active for this roaming agreement.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Fraud Threshold Amount' ;
    rdfs:comment 'Maximum allowed roaming charges per subscriber per day before fraud alerts are triggered and service may be suspended.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsmaAa12Compliant rdf:type rdf:Property ;
    rdfs:label 'Gsma Aa12 Compliant' ;
    rdfs:comment 'Indicates whether the agreement adheres to GSMA AA.12 standard for roaming agreement principles and commercial frameworks.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gsmaAa13Compliant rdf:type rdf:Property ;
    rdfs:label 'Gsma Aa13 Compliant' ;
    rdfs:comment 'Indicates whether the agreement adheres to GSMA AA.13 standard for roaming financial settlement and dispute resolution.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iotRateType rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Type' ;
    rdfs:comment 'Pricing structure for wholesale roaming charges: fixed (flat rate), tiered (volume discounts), volume_based (per unit), time_based (peak/off-peak), or hybrid (combination).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrtrdeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Threshold Amount' ;
    rdfs:comment 'Financial threshold in agreement currency that triggers NRTRDE notification to home network for fraud prevention.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Partner Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the agreement on behalf of the roaming partner network operator.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Flag' ;
    rdfs:comment 'Indicates whether this partner is designated as a preferred roaming partner for network steering and priority routing.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rapVersion rdf:type rdf:Property ;
    rdfs:label 'Rap Version' ;
    rdfs:comment 'Version of the RAP file format used for dispute resolution and error correction (e.g., RAP3, RAP4).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypesCovered rdf:type rdf:Property ;
    rdfs:label 'Service Types Covered' ;
    rdfs:comment 'Comma-separated list of service types included in the roaming agreement: voice, SMS, data, MMS, VoLTE, video calling, 5G services, etc.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Days' ;
    rdfs:comment 'Number of days after period end by which settlement invoices must be issued and paid.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCallSuccessRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Call Success Rate Percent' ;
    rdfs:comment 'Minimum call setup success rate percentage guaranteed for roaming voice services.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaDataThroughputMbps rdf:type rdf:Property ;
    rdfs:label 'Sla Data Throughput Mbps' ;
    rdfs:comment 'Minimum guaranteed data throughput in megabits per second for roaming data services.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsRate rdf:type rdf:Property ;
    rdfs:label 'Sms Rate' ;
    rdfs:comment 'Wholesale rate per SMS message in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:steeringPolicy rdf:type rdf:Property ;
    rdfs:label 'Steering Policy' ;
    rdfs:comment 'Policy for directing subscribers to this partner network: automatic (default selection), manual (user choice), preferred (priority), cost_based (lowest rate), or quality_based (best QoS).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapFileFrequency rdf:type rdf:Property ;
    rdfs:label 'Tap File Frequency' ;
    rdfs:comment 'Frequency at which TAP files are exchanged between operators for settlement: daily, weekly, monthly, or real_time (near real-time).' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyStandards rdf:type rdf:Property ;
    rdfs:label 'Technology Standards' ;
    rdfs:comment 'Comma-separated list of network technology standards covered: 2G, 3G, 4G LTE, 5G NR, VoLTE, IMS, etc.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceMouRate rdf:type rdf:Property ;
    rdfs:label 'Voice Mou Rate' ;
    rdfs:comment 'Wholesale rate per minute for voice calls in the agreement currency. Used for settlement calculations.' ;
    rdfs:domain ind:RoamingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardId rdf:type rdf:Property ;
    rdfs:label 'Scorecard Id' ;
    rdfs:comment 'Unique identifier for the partner scorecard evaluation record. Primary key.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Composite Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Partner scorecards evaluate performance using standardized KPIs (revenue contribution, SLA compliance, dispute resolution rate). The composite score aggregates multiple KPI definitions. Linking enable' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target date by which the partner must submit or complete a performance improvement action plan.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal performance improvement action plan is required based on scorecard outcomes.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Performance score reflecting the partner\'s adherence to regulatory, contractual, and internal compliance requirements.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Overall weighted performance score aggregating all evaluation dimensions, typically on a 0-100 scale.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Recommendation' ;
    rdfs:comment 'Recommendation regarding contract renewal or termination based on scorecard evaluation outcomes.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTier rdf:type rdf:Property ;
    rdfs:label 'Current Tier' ;
    rdfs:comment 'Current tier classification of the partner at the time of this scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCount rdf:type rdf:Property ;
    rdfs:label 'Dispute Count' ;
    rdfs:comment 'Total number of disputes raised by or against the partner during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFrequencyScore rdf:type rdf:Property ;
    rdfs:label 'Dispute Frequency Score' ;
    rdfs:comment 'Performance score reflecting the frequency and severity of disputes raised during the evaluation period, with lower dispute counts yielding higher scores.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Rate Percentage' ;
    rdfs:comment 'Percentage of disputes successfully resolved during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period covered by this scorecard.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Evaluator Department' ;
    rdfs:comment 'Department or business unit responsible for conducting the scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the individual or team responsible for conducting the scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Improvement Areas Summary' ;
    rdfs:comment 'Narrative summary of areas requiring improvement or corrective action identified during the evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationContributionScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Contribution Score' ;
    rdfs:comment 'Performance score reflecting the partner\'s contribution to innovation, new product development, or technology advancement initiatives.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentPriority rdf:type rdf:Property ;
    rdfs:label 'Investment Priority' ;
    rdfs:comment 'Priority level for allocating partner development resources, training, and support investments based on scorecard outcomes.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next partner scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalQualityScore rdf:type rdf:Property ;
    rdfs:label 'Operational Quality Score' ;
    rdfs:comment 'Performance score reflecting operational excellence metrics such as service delivery quality, responsiveness, and process adherence.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedTier rdf:type rdf:Property ;
    rdfs:label 'Recommended Tier' ;
    rdfs:comment 'Recommended tier classification for the partner based on scorecard evaluation outcomes, which may trigger tier reclassification decisions. [ENUM-REF-CANDIDATE: platinum|gold|silver|bronze|standard|downgrade|terminate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Contribution Amount' ;
    rdfs:comment 'Total revenue generated or contributed by the partner during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueContributionScore rdf:type rdf:Property ;
    rdfs:label 'Revenue Contribution Score' ;
    rdfs:comment 'Performance score reflecting the partner\'s revenue generation and growth contribution during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueGrowthPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Growth Percentage' ;
    rdfs:comment 'Year-over-year or period-over-period revenue growth rate for this partner, expressed as a percentage.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the scorecard evaluation, typically formatted as year-quarter-partner code for traceability.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the scorecard evaluation record.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Percentage' ;
    rdfs:comment 'Percentage of SLA metrics met or exceeded by the partner during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Score' ;
    rdfs:comment 'Performance score reflecting the partner\'s adherence to contractual SLA commitments during the evaluation period.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Strategic Alignment Score' ;
    rdfs:comment 'Performance score reflecting the partner\'s alignment with strategic business objectives, innovation initiatives, and long-term roadmap.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative summary of the partner\'s key strengths and positive performance areas identified during the evaluation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Change Flag' ;
    rdfs:comment 'Indicates whether a tier reclassification is recommended based on this scorecard evaluation.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerSlaMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Partner Sla Measurement Id' ;
    rdfs:comment 'Unique identifier for the partner SLA measurement record.' ;
    rdfs:domain ind:PartnerSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditApplicable rdf:type rdf:Property ;
    rdfs:label 'Credit Applicable' ;
    rdfs:comment 'Indicates whether a service credit applies for this SLA breach.' ;
    rdfs:domain ind:PartnerSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether the SLA breach requires escalation to management or partner review.' ;
    rdfs:domain ind:PartnerSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Measurement Confidence Level' ;
    rdfs:comment 'The statistical confidence level of the measurement expressed as a percentage (e.g., 95.00 for 95% confidence).' ;
    rdfs:domain ind:PartnerSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The calculated variance between actual and target values (actual minus target).' ;
    rdfs:domain ind:PartnerSlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableProductScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Scope' ;
    rdfs:comment 'Defines the scope of products and services to which this revenue share plan applies. Determines which revenue streams are included in the calculation. [ENUM-REF-CANDIDATE: all_products|mobile_services|broadband_services|content_services|iptv_services|ott_services|voice_services|data_services|roaming_services|specific_product_list — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionProcess rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Process' ;
    rdfs:comment 'Description of the process and escalation path for resolving revenue share calculation disputes with the partner. References contract terms.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'Source of foreign exchange rates used for currency conversion in revenue share calculations (e.g., \'Reuters\', \'Bloomberg\', \'Central Bank Daily Rate\').' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Rate Amount' ;
    rdfs:comment 'The fixed monetary amount paid per unit/transaction when calculation_method is fixed-rate based. Null if calculation method is percentage-based or tiered.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Threshold Amount' ;
    rdfs:comment 'Maximum revenue or transaction volume subject to revenue sharing. Used for plans with capped commission structures. Null if no maximum threshold applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Amount' ;
    rdfs:comment 'Minimum revenue or transaction volume required before revenue sharing begins. Used for plans with minimum commitment clauses. Null if no minimum threshold applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the revenue share plan, including scope, applicable services, and commercial terms summary.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for revenue share reporting and analytics. May differ from settlement currency_code for multi-currency operations.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTermsDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms Days' ;
    rdfs:comment 'Number of days after the settlement period end date by which payment must be made to the partner. Standard payment terms (e.g., Net 30, Net 45).' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharePercentage rdf:type rdf:Property ;
    rdfs:label 'Share Percentage' ;
    rdfs:comment 'The percentage of revenue allocated to the partner when calculation_method is percentage-based. Expressed as a decimal (e.g., 15.50 for 15.5%). Null if calculation method is fixed rate or tiered.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Target Accuracy Percentage' ;
    rdfs:comment 'Target accuracy percentage for revenue share calculations as defined in the partner SLA. Used for performance monitoring and dispute resolution.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Flag' ;
    rdfs:comment 'Indicates whether this revenue share plan uses tiered thresholds for calculation. True if the plan has multiple tiers with different rates/percentages based on volume or revenue thresholds.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Percentage of revenue share payment subject to withholding tax, if applicable. Null if no withholding tax applies.' ;
    rdfs:domain ind:RevenueSharePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementLineId rdf:type rdf:Property ;
    rdfs:label 'Settlement Line Id' ;
    rdfs:comment 'Unique identifier for the settlement line item record. Primary key.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iotRateId rdf:type rdf:Property ;
    rdfs:label 'Iot Rate Id' ;
    rdfs:comment 'Reference to the specific Inter-Operator Tariff (IOT) rate agreement used for this settlement line. Applicable for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:wholesaleAgreementId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Agreement Id' ;
    rdfs:comment 'Reference to the wholesale or Mobile Virtual Network Operator (MVNO) host agreement governing the rates and terms for this settlement line.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:cdrCount rdf:type rdf:Property ;
    rdfs:label 'Cdr Count' ;
    rdfs:comment 'Number of Call Detail Records (CDRs) or usage events aggregated into this settlement line item. Provides traceability to source usage data.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date when a dispute was formally raised against this settlement line item.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originatingNetwork rdf:type rdf:Property ;
    rdfs:label 'Originating Network' ;
    rdfs:comment 'Identifier of the network where the usage or transaction originated. Relevant for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Identifier of the specific product or service offering associated with this settlement line. Maps to the product catalog entry.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapFileReference rdf:type rdf:Property ;
    rdfs:label 'Rap File Reference' ;
    rdfs:comment 'Reference to the Returned Account Procedure (RAP) file containing acknowledgments or rejections related to this settlement line.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateApplied rdf:type rdf:Property ;
    rdfs:label 'Rate Applied' ;
    rdfs:comment 'Per-unit rate applied to calculate the settlement amount. Represents the wholesale rate, Inter-Operator Tariff (IOT), or revenue share percentage.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminatingNetwork rdf:type rdf:Property ;
    rdfs:label 'Terminating Network' ;
    rdfs:comment 'Identifier of the network where the usage or transaction terminated. Relevant for roaming and interconnect settlements.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDate rdf:type rdf:Property ;
    rdfs:label 'Usage Date' ;
    rdfs:comment 'Specific date when the usage or service transaction occurred. Used for daily granularity in settlement reconciliation.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Unit' ;
    rdfs:comment 'Unit of measurement for the usage volume. Defines whether volume is measured in time, data, count, or other units. [ENUM-REF-CANDIDATE: minutes|seconds|mb|gb|messages|sessions|transactions — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageVolume rdf:type rdf:Property ;
    rdfs:label 'Usage Volume' ;
    rdfs:comment 'Quantity of service usage for this settlement line. Represents minutes, megabytes, messages, or transactions depending on service type.' ;
    rdfs:domain ind:SettlementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementAgreementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Id' ;
    rdfs:comment 'Reference to the master partner agreement governing the commercial terms, revenue share percentages, and settlement frequency for this run.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'The total number of detailed settlement line items (charges, credits, adjustments, usage records) included in this settlement run, providing a summary count for reconciliation purposes.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Payment Completion Date' ;
    rdfs:comment 'The actual date on which the payment was successfully transferred to the partner, confirming settlement closure.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Payment Instruction Reference' ;
    rdfs:comment 'External reference number or identifier linking this settlement run to the payment instruction sent to the treasury or accounts payable system (e.g., wire transfer batch ID, ACH transaction reference).' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Execution Timestamp' ;
    rdfs:comment 'The date and time when the settlement calculation engine executed this run, generating the settlement amount and line-item details.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Category of settlement run indicating the nature of the financial arrangement: MVNO wholesale billing, roaming IOT (Inter-Operator Tariff) settlement, content provider revenue share, dealer/agent commission payout, interconnect carrier settlement, or equipment vendor rebate.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settlement Amount' ;
    rdfs:comment 'The aggregate financial amount calculated for this settlement run, representing the net payable or receivable between Telecommunication and the partner. Positive values indicate amounts owed to the partner; negative values indicate amounts owed by the partner.' ;
    rdfs:domain ind:SettlementRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether this SLA is subject to regulatory compliance requirements (e.g., FCC-mandated interconnection SLAs, BEREC roaming quality standards). True if compliance reporting is mandatory.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditFormula rdf:type rdf:Property ;
    rdfs:label 'Credit Formula' ;
    rdfs:comment 'Formula or rule for calculating service credits issued to partners when SLA is breached (e.g., \'Pro-rated credit based on downtime duration\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Window Days' ;
    rdfs:comment 'Number of days within which SLA measurement disputes must be raised and resolved.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThreshold rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold' ;
    rdfs:comment 'Value at which SLA breach triggers escalation to senior management or dispute resolution process. Nullable if no escalation defined.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Conditions under which SLA measurements are excluded or suspended (e.g., \'Force majeure events\', \'Planned maintenance windows with 72-hour notice\', \'Partner-caused outages\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time window over which SLA compliance is measured and evaluated (e.g., monthly for uptime, per_incident for MTTR, quarterly for settlement processing).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDescription rdf:type rdf:Property ;
    rdfs:label 'Metric Description' ;
    rdfs:comment 'Detailed description of how the metric is measured, calculated, and interpreted for compliance evaluation.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the measurable metric governed by this SLA (e.g., \'Network Uptime Percentage\', \'Average Latency\', \'Settlement Processing Time\', \'Dispute Resolution Time\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'List of roles or contact points to be notified when SLA thresholds are breached (e.g., \'Partner NOC Manager, Account Manager, Escalation Team\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationThreshold rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold' ;
    rdfs:comment 'Value at which proactive notifications are sent to partners warning of potential SLA breach (e.g., 95% when target is 99%).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for penalty cap amount (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyFormula rdf:type rdf:Property ;
    rdfs:label 'Penalty Formula' ;
    rdfs:comment 'Formula or rule for calculating financial penalties when SLA is breached (e.g., \'1% of monthly fee per 0.1% below threshold\', \'Fixed $10,000 per incident exceeding MTTR\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'Format and delivery method for SLA performance reports (e.g., \'PDF via email\', \'API endpoint\', \'Partner portal dashboard\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Description of which services, network elements, or geographic regions this SLA applies to (e.g., \'All LTE RAN sites in Region A\', \'MVNO data services\', \'International roaming partners\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition: draft (under negotiation), active (in force), suspended (temporarily inactive), expired (past end date), terminated (cancelled before expiration).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantId rdf:type rdf:Property ;
    rdfs:label 'Applicant Id' ;
    rdfs:comment 'Unique identifier for the job applicant record. Primary key for the applicant entity.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Applicant .

ind:applicantHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the hiring manager (the manager of the position being filled) who has decision authority for this applicant.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicantInterviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Interviewer Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted the primary interview or served as the lead interviewer for this applicant.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicantRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Recruiter Employee Id' ;
    rdfs:comment 'Reference to the internal recruiter or HR business partner responsible for managing this applicant\'s recruitment process.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicantReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Referral Employee Id' ;
    rdfs:comment 'Reference to the employee who referred this applicant, if the source channel is employee referral. Used for referral bonus tracking.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Reference to the specific position record in the position master data that this application is for.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:applicantType rdf:type rdf:Property ;
    rdfs:label 'Applicant Type' ;
    rdfs:comment 'Classification of the applicant based on their relationship to the organization: internal employee applying for a different role, external candidate, contractor seeking conversion, former employee seeking rehire, employee referral, or campus recruit.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Business-facing unique application reference number assigned when the candidate submits their application. Format: APP-YYYYMMDD-sequence.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current status of the application in the recruitment workflow: applied (initial submission), screening (under review), phone screen (scheduled or completed), interview (in-person or virtual), assessment (skills or psychometric testing), offer (offer extended), hired (offer accepted and onboarded), rejected (application declined), or withdrawn (applicant withdrew). [ENUM-REF-CANDIDATE: applied|screening|phone_screen|interview|assessment|offer|hired|rejected|withdrawn — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'The date on which the background check process was completed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Current status of the background verification process for the applicant: not started, in progress, completed, cleared (passed all checks), or flagged (issues identified requiring review).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The date on which the applicant provided their GDPR/privacy consent for data processing.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the organization where the applicant is currently employed. Null if the applicant is unemployed or an internal candidate.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'The job title or role the applicant currently holds at their present employer.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'The anticipated date on which the applicant is expected to commence employment if the offer is accepted.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'The highest level of formal education attained by the applicant: high school diploma, associate degree, bachelor degree, master degree, doctorate, professional certification, or other. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional_certification|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'The date on which the applicant\'s primary or most recent interview was conducted.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL to the applicant\'s LinkedIn professional profile, if provided.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Amount' ;
    rdfs:comment 'The total annual compensation amount offered to the applicant, including base salary and guaranteed allowances.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Offer Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the offer amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'The date on which a formal job offer was extended to the applicant.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionAppliedFor rdf:type rdf:Property ;
    rdfs:label 'Position Applied For' ;
    rdfs:comment 'The job title or position name that the applicant is applying for within the telecommunications enterprise.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWorkLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Work Location' ;
    rdfs:comment 'The geographic location or office site the applicant prefers to work from, if applicable. May reference a city, office name, or remote work preference.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Resume Document Reference' ;
    rdfs:comment 'File path, URI, or document management system reference to the applicant\'s resume or curriculum vitae (CV) document.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numeric score assigned during the initial screening phase based on resume review, qualifications match, and initial assessment criteria. Scale typically 0-100.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text explanation or standardized reason code for why the applicant withdrew their application, if applicable.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years of relevant professional work experience the applicant has accumulated in their career, as declared in the application.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Unique identifier for the employee assignment record. Primary key for the assignment entity.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Approved By User Employee Id' ;
    rdfs:comment 'The user ID of the manager or HR administrator who approved this assignment. Null if assignment_approval_status is not approved.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By User Employee Id' ;
    rdfs:comment 'The user ID of the HR administrator or system user who created this assignment record. Used for audit trails and accountability.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Employee Id' ;
    rdfs:comment 'Reference to the employee who holds this assignment. Links to the employee master record in the people domain.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who is the direct manager or supervisor for this assignment. Enables reporting hierarchy reconstruction.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By User Employee Id' ;
    rdfs:comment 'The user ID of the HR administrator or system user who last modified this assignment record. Used for audit trails and change management.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the organizational unit where the employee is assigned. Links to the org_unit master record representing department, division, or business unit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business identifier for the assignment record. Follows format ASG-########. Used for operational reference and audit trails.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the assignment indicating whether it is the employee\'s primary role, a secondary/concurrent assignment, or a temporary acting/interim position.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise date and time when this assignment became or will become effective. Used for time-based queries and historical reporting hierarchy reconstruction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employmentCategory rdf:type rdf:Property ;
    rdfs:label 'Employment Category' ;
    rdfs:comment 'Classification of the employment relationship for this assignment. Distinguishes between regular employees, temporary workers, interns, contractors, and consultants.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The percentage of full-time work that this assignment represents. 100.00 indicates full-time, values below 100 indicate part-time. Used for workforce capacity planning and OPEX (Operational Expenditure) calculations.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalRole rdf:type rdf:Property ;
    rdfs:label 'Is Critical Role' ;
    rdfs:comment 'Boolean flag indicating whether this assignment is designated as a critical role for business continuity and succession planning purposes. Used for workforce risk management.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Assignment' ;
    rdfs:comment 'Boolean flag indicating whether this is the employee\'s primary assignment. An employee may have multiple concurrent assignments, but only one can be primary for reporting and benefits purposes.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'The broad occupational category or job family that this assignment belongs to, such as Engineering, Network Operations, Customer Service, Finance, or Sales. Used for workforce analytics and career pathing.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'The hierarchical level or grade of the position within the organization\'s job architecture. Examples include Individual Contributor, Team Lead, Manager, Senior Manager, Director, Vice President.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeEligibility rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligibility' ;
    rdfs:comment 'Indicates whether the employee in this assignment is eligible for overtime compensation. Exempt employees are not eligible for overtime pay under labor regulations.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The date when the probationary period for this assignment ends. Applicable for new hires or employees in new roles. Null if no probation period applies.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remoteWorkEligibility rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligibility' ;
    rdfs:comment 'Indicates whether the employee in this assignment is eligible for remote work arrangements based on role requirements, policy, and business needs.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Assignment Code' ;
    rdfs:comment 'The unique identifier for this assignment in the source system of record. Used for data reconciliation and integration traceability.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the specific labor union or collective bargaining unit that represents the employee in this assignment. Null if union_membership_flag is false.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union under this assignment. Used for compliance with collective bargaining agreements and labor relations management.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Classification of where the employee performs work under this assignment. Distinguishes between on-site office work, remote work, hybrid arrangements, field-based roles, and mobile workforce.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workSchedulePattern rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Pattern' ;
    rdfs:comment 'The standard work schedule pattern for this assignment. Defines the expected working hours arrangement such as standard 40-hour week, compressed workweek, shift rotation, or flexible schedule.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment transaction.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Reference to the specific benefit plan in which the employee is enrolling. Links to the benefit plan master record.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:beneficiaryDesignationOnFile rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation On File' ;
    rdfs:comment 'Indicates whether the employee has designated beneficiaries for this benefit plan. Applicable primarily to life insurance and retirement benefits. True indicates beneficiary forms are complete, false indicates missing or incomplete.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierAcknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Carrier Acknowledgement Received' ;
    rdfs:comment 'Indicates whether the benefit carrier has acknowledged receipt and acceptance of the enrollment. True indicates carrier confirmed enrollment, false indicates no acknowledgement or rejection.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the benefit carrier acknowledged the enrollment. Used for reconciliation and SLA (Service Level Agreement) tracking with external providers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cobraElectionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Deadline Date' ;
    rdfs:comment 'Date by which the employee must elect COBRA continuation coverage. Typically 60 days from the qualifying event or notice date, whichever is later. Populated only when COBRA eligible is true.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligible rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible for COBRA continuation coverage upon termination of this enrollment. True indicates COBRA rights apply, false indicates not eligible. Applicable primarily to health insurance enrollments.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contribution Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for contribution amounts. Typically USD for US-based telecommunications operations but supports multi-currency for global workforce.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Date when benefit coverage terminates. Nullable for active ongoing enrollments. Populated upon termination, plan change, or employment separation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'Effective date when benefit coverage begins. May differ from enrollment date due to waiting periods or plan year alignment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this enrollment. Used for coverage verification and premium calculation validation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeMonthlyContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Monthly Contribution Amount' ;
    rdfs:comment 'Monthly premium amount deducted from employee paycheck for this benefit enrollment. Represents the employee share of the benefit cost.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMonthlyContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Monthly Contribution Amount' ;
    rdfs:comment 'Monthly premium amount paid by the employer for this benefit enrollment. Represents the employer subsidy or contribution toward the benefit cost.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Approved Timestamp' ;
    rdfs:comment 'Date and time when the enrollment was approved by HR or benefits administrator. Null if approval is not required or still pending.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Number' ;
    rdfs:comment 'Unique confirmation number provided by the benefit provider upon successful enrollment. Used for tracking and verification with external benefit administrators.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'Classification of the event that triggered this enrollment. New hire indicates initial employment enrollment, open enrollment indicates annual election period, qualifying life event indicates mid-year change due to marriage/birth/etc, voluntary change indicates employee-initiated modification, annual renewal indicates automatic continuation, rehire indicates return to employment.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Channel or method through which the employee completed the enrollment. Online portal indicates self-service web enrollment, paper form indicates manual submission, phone indicates call center enrollment, benefits fair indicates in-person event, HR representative indicates assisted enrollment, mobile app indicates mobile self-service.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Record Code' ;
    rdfs:comment 'Unique identifier of this enrollment record in the source system. Used for data lineage, reconciliation, and troubleshooting integration issues.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Name of the source system or benefits administration platform from which this enrollment record originated. Examples include SAP S/4HANA HCM, Workday, ADP, or third-party benefits administration systems.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrollment. Active indicates coverage is in effect, pending indicates awaiting approval or effective date, terminated indicates coverage has ended, waived indicates employee declined coverage, suspended indicates temporary hold, cancelled indicates enrollment was reversed before taking effect.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Submitted Timestamp' ;
    rdfs:comment 'Precise date and time when the enrollment was submitted by the employee. Provides audit trail for compliance with election deadlines and regulatory windows.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentTransmittedToCarrierTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Transmitted To Carrier Timestamp' ;
    rdfs:comment 'Date and time when the enrollment was transmitted to the benefit provider or insurance carrier. Used for tracking integration SLA (Service Level Agreement) and troubleshooting transmission failures.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceOfInsurabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required' ;
    rdfs:comment 'Indicates whether the employee must provide medical evidence of insurability for this enrollment. Typically required for late enrollments or coverage amounts exceeding guaranteed issue limits. True indicates EOI is required, false indicates no medical underwriting needed.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'Current status of the evidence of insurability review process. Not required indicates no medical underwriting needed, pending indicates awaiting carrier decision, approved indicates coverage granted, denied indicates coverage declined, incomplete indicates additional information needed.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year for which this enrollment is effective. Benefit plans typically operate on annual cycles aligned with plan years.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerEnrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Provider Enrollment Code' ;
    rdfs:comment 'Unique identifier assigned by the external benefit provider or insurance carrier for this enrollment. Used for coordination with carrier systems and claims processing.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingLifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Date' ;
    rdfs:comment 'Date when the qualifying life event occurred. Used to validate enrollment timing and compliance with 30-day or 60-day election windows mandated by regulations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingLifeEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Type' ;
    rdfs:comment 'Specific type of qualifying life event that permitted mid-year enrollment change. Examples include marriage, divorce, birth, adoption, loss of other coverage, change in employment status. Populated only when enrollment event type is qualifying life event. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death_of_dependent|loss_of_coverage|employment_status_change|dependent_age_out|court_order|other — promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tobaccoUserStatus rdf:type rdf:Property ;
    rdfs:label 'Tobacco User Status' ;
    rdfs:comment 'Employee self-reported tobacco use status. Used for premium rating in health and life insurance plans. User indicates tobacco use within specified lookback period, non-user indicates no tobacco use, declined to answer indicates employee chose not to disclose.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowsDependentCoverage rdf:type rdf:Property ;
    rdfs:label 'Allows Dependent Coverage' ;
    rdfs:comment 'Indicates whether the plan allows employees to enroll eligible dependents (spouse, children, domestic partner) for coverage. True if dependent coverage is available; false if employee-only.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Annual Coverage Limit' ;
    rdfs:comment 'Maximum dollar amount the plan will pay in benefits per covered individual per year. Nullable for plans with unlimited coverage. Applicable primarily to health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCategory rdf:type rdf:Property ;
    rdfs:label 'Benefit Category' ;
    rdfs:comment 'Classification of the benefit plan by type of coverage or program. Segments benefit offerings into major categories for reporting, compliance, and employee decision-making. [ENUM-REF-CANDIDATE: medical|dental|vision|life_insurance|disability|pension|retirement|stock_purchase|wellness|telecom_discount|employee_assistance — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or contract number assigned by the insurance carrier or benefit provider. Used for claims processing, provider verification, and carrier communications.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'Percentage of covered expenses the employee pays after meeting the deductible, expressed as a decimal (e.g., 0.2000 represents 20% coinsurance). The plan pays the remaining percentage.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are made to the benefit plan. Determines payroll deduction schedule and plan funding cadence.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for specific covered services (e.g., doctor visit, prescription). Applicable to health, dental, and vision plans. May vary by service type.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Amount the employee must pay out-of-pocket before the plan begins to pay benefits. Applicable to health, dental, and vision insurance plans. Varies by coverage tier.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Textual description of requirements employees must meet to enroll in the plan, including employment type (full-time, part-time, contractor), minimum tenure, grade band, location, or other qualifying conditions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Fixed dollar amount contributed by the employee per pay period or per month, if the plan uses flat-rate contributions instead of percentage-based. Nullable if percentage-based contribution is used.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Rate' ;
    rdfs:comment 'Percentage of plan cost paid by the employee, expressed as a decimal (e.g., 0.2500 represents 25%). Used to calculate payroll deductions for benefit premiums.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Fixed dollar amount contributed by the employer per pay period or per month, if the plan uses flat-rate contributions instead of percentage-based. Nullable if percentage-based contribution is used.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Rate' ;
    rdfs:comment 'Percentage of plan cost paid by the employer, expressed as a decimal (e.g., 0.7500 represents 75%). Represents the company\'s subsidy of the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchLimit rdf:type rdf:Property ;
    rdfs:label 'Employer Match Limit' ;
    rdfs:comment 'Maximum dollar amount or percentage of salary the employer will match per year in retirement plans. Represents the cap on employer matching contributions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchRate rdf:type rdf:Property ;
    rdfs:label 'Employer Match Rate' ;
    rdfs:comment 'Percentage of employee contributions that the employer will match in retirement or savings plans, expressed as a decimal (e.g., 0.5000 represents 50% match). Applicable to 401(k), 403(b), and similar plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Employment Type Eligibility' ;
    rdfs:comment 'Employment classification required for plan eligibility. Specifies which employment types are eligible to enroll in this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date when the enrollment window closes for this benefit plan. Employees must complete enrollment actions before this date to participate in the plan for the coverage period.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'Date when the enrollment window opens for employees to enroll in or make changes to this benefit plan. Applicable for open enrollment and special enrollment periods.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentWindowType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Window Type' ;
    rdfs:comment 'Type of enrollment period during which employees can enroll in or modify this benefit plan. Open enrollment is annual; life event is triggered by qualifying events; new hire is during onboarding; special enrollment is for exceptional circumstances.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erisaPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Erisa Plan Number' ;
    rdfs:comment 'Three-digit plan number assigned for ERISA reporting purposes. Required for Form 5500 annual reporting. Each benefit plan under the same plan sponsor must have a unique ERISA plan number.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeBandEligibility rdf:type rdf:Property ;
    rdfs:label 'Grade Band Eligibility' ;
    rdfs:comment 'Organizational grade bands or job levels eligible for this plan (e.g., \'Executive\', \'Management\', \'Individual Contributor\', \'All Grades\'). Used for tiered benefit offerings.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaCompliant rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliant' ;
    rdfs:comment 'Indicates whether this benefit plan is subject to HIPAA privacy and security requirements. True for health plans that handle protected health information (PHI); false for non-health benefits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether enrollment in this benefit plan is mandatory for eligible employees (true) or voluntary (false). Certain benefits like basic life insurance may be mandatory.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Lifetime Coverage Limit' ;
    rdfs:comment 'Maximum dollar amount the plan will pay in benefits per covered individual over their lifetime. Nullable for plans with unlimited coverage. Prohibited for essential health benefits under ACA but may apply to supplemental benefits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Tenure Months' ;
    rdfs:comment 'Minimum number of months an employee must be employed before becoming eligible for this benefit plan. Zero indicates immediate eligibility upon hire.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount an employee will pay in a plan year for covered services. After reaching this limit, the plan pays 100% of covered expenses. Applicable to health insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'Web address or document management system link to the official plan document, summary plan description, or benefits guide. Provides employees access to detailed plan terms and conditions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSponsorEin rdf:type rdf:Property ;
    rdfs:label 'Plan Sponsor Ein' ;
    rdfs:comment 'Federal Employer Identification Number of the organization sponsoring the benefit plan. Used for tax reporting and regulatory filings. Format: XX-XXXXXXX.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTypeCode rdf:type rdf:Property ;
    rdfs:label 'Plan Type Code' ;
    rdfs:comment 'Standardized code representing the specific type or structure of the benefit plan (e.g., HMO, PPO for health; 401K, 403B for retirement; ESPP for stock purchase). Used for regulatory reporting and plan categorization. [ENUM-REF-CANDIDATE: HMO|PPO|EPO|POS|HDHP|FSA|HSA|401K|403B|457|ESPP|RSU|PENSION — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax status of employee contributions to the plan. Pre-tax contributions reduce taxable income; post-tax contributions are made with after-tax dollars; Roth contributions are post-tax but grow tax-free; tax-exempt applies to certain benefits.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Vesting Period Months' ;
    rdfs:comment 'Number of months an employee must participate in the plan before employer contributions become fully owned by the employee. Applicable to retirement plans, stock purchase plans, and pension plans. Zero indicates immediate vesting.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationId rdf:type rdf:Property ;
    rdfs:label 'Compensation Id' ;
    rdfs:comment 'Unique identifier for the compensation record. Primary key for the compensation entity.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Approved By Employee Id' ;
    rdfs:comment 'The employee ID of the manager or HR representative who approved this compensation plan or change.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compensationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Employee Id' ;
    rdfs:comment 'Unique identifier of the employee to whom this compensation record applies. Links to the employee master record.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualLeaveDays rdf:type rdf:Property ;
    rdfs:label 'Annual Leave Days' ;
    rdfs:comment 'The number of annual leave (vacation) days allocated to the employee per year under this compensation plan.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'The base salary or wage amount for the employee under this compensation plan, excluding allowances and bonuses.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'The commission rate percentage applied to sales or revenue for commission-based compensation plans. Applicable when plan_type is commission or hybrid.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Status' ;
    rdfs:comment 'The current lifecycle status of this compensation record (active, pending approval, approved, superseded by newer record, or terminated).' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityGrantEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for equity grants (stock options, RSUs, etc.) under this compensation plan (True = eligible, False = not eligible).' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'The FLSA classification of the employee determining overtime eligibility (exempt = not eligible for overtime, non-exempt = eligible for overtime).' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeMaximumAmount rdf:type rdf:Property ;
    rdfs:label 'Grade Maximum Amount' ;
    rdfs:comment 'The maximum salary amount defined for the employee\'s assigned pay grade.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeMinimumAmount rdf:type rdf:Property ;
    rdfs:label 'Grade Minimum Amount' ;
    rdfs:comment 'The minimum salary amount defined for the employee\'s assigned pay grade.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The hourly wage rate for employees compensated on an hourly basis. Applicable only when plan_type is hourly or hybrid.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:housingAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Housing Allowance Amount' ;
    rdfs:comment 'The monthly or periodic housing allowance provided to the employee as part of the total compensation package.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Meal Allowance Amount' ;
    rdfs:comment 'The monthly or periodic meal or food allowance provided to the employee.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Mobile Allowance Amount' ;
    rdfs:comment 'The monthly or periodic mobile phone or communication allowance provided to the employee.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible to receive overtime compensation under this plan (True = eligible, False = not eligible).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the employee is paid (monthly, bi-weekly, weekly, semi-monthly, quarterly, or annual).' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'The pay grade or band assigned to the employee, representing a hierarchical level within the organization\'s compensation structure.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payStep rdf:type rdf:Property ;
    rdfs:label 'Pay Step' ;
    rdfs:comment 'The step or increment within the assigned pay grade, typically reflecting tenure or performance progression.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftDifferentialEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for shift differential pay for non-standard working hours (True = eligible, False = not eligible).' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sickLeaveDays rdf:type rdf:Property ;
    rdfs:label 'Sick Leave Days' ;
    rdfs:comment 'The number of sick leave days allocated to the employee per year under this compensation plan.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetBonusPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Bonus Percentage' ;
    rdfs:comment 'The target annual bonus as a percentage of base salary that the employee is eligible to receive based on performance.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFixedCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fixed Compensation Amount' ;
    rdfs:comment 'The total fixed compensation amount including base salary and all fixed allowances (housing, transport, mobile, meal).' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Transport Allowance Amount' ;
    rdfs:comment 'The monthly or periodic transport or commuting allowance provided to the employee.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Union Member Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union, which may affect compensation terms and conditions (True = union member, False = not a union member).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryCaseId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Case Id' ;
    rdfs:comment 'Unique identifier for the disciplinary case record. Primary key for the disciplinary case entity.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Reference to the employee who is the subject of the disciplinary action or grievance case.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Hr Business Partner Employee Id' ;
    rdfs:comment 'Reference to the HR business partner assigned to oversee and advise on the disciplinary case, ensuring policy compliance and fair process.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'The date when the employee formally submitted an appeal against the disciplinary case outcome.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Flag' ;
    rdfs:comment 'Indicates whether the employee has filed an appeal against the disciplinary case outcome. True if appeal was lodged, false otherwise.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcomeDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome Date' ;
    rdfs:comment 'The date when the appeal outcome was formally communicated to the employee.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'The date when the disciplinary case was formally closed, including all appeals and follow-up actions completed.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseOpenDate rdf:type rdf:Property ;
    rdfs:label 'Case Open Date' ;
    rdfs:comment 'The date when the disciplinary case was formally opened and investigation commenced.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the disciplinary case, used for tracking and communication purposes.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSeverity rdf:type rdf:Property ;
    rdfs:label 'Case Severity' ;
    rdfs:comment 'Severity classification of the disciplinary action. Indicates the level of corrective action taken or recommended.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The confidentiality classification level for the disciplinary case. Determines access restrictions and handling procedures.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRepresentativePresentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Representative Present Flag' ;
    rdfs:comment 'Indicates whether the employee was accompanied by a representative, union delegate, or legal counsel during the hearing. True if representative was present, false otherwise.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Attachment Count' ;
    rdfs:comment 'The number of supporting documents, files, or evidence attachments associated with the disciplinary case.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'The date when the formal disciplinary hearing was conducted with the employee to review evidence and provide opportunity for response.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingLocation rdf:type rdf:Property ;
    rdfs:label 'Hearing Location' ;
    rdfs:comment 'The physical or virtual location where the disciplinary hearing was conducted.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementPlanEndDate rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan End Date' ;
    rdfs:comment 'The target completion date for the performance improvement plan or corrective action plan, if one was required.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Required Flag' ;
    rdfs:comment 'Indicates whether a performance improvement plan or corrective action plan is required as part of the case outcome. True if plan is required, false otherwise.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The date when the incident or behavior that triggered the disciplinary case occurred. Principal business event timestamp for the case.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the incident or behavior that triggered the disciplinary case. Contains facts, circumstances, and context of the event.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether the case required review by legal counsel due to severity, complexity, or potential litigation risk. True if legal review was required, false otherwise.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'The date when the disciplinary case outcome was formally communicated to the employee.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Detailed explanation of the disciplinary case outcome, including rationale, corrective actions, expectations, and any conditions or follow-up requirements.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeType rdf:type rdf:Property ;
    rdfs:label 'Outcome Type' ;
    rdfs:comment 'The final decision or outcome of the disciplinary case after investigation and hearing. Defines the corrective action taken or resolution reached. [ENUM-REF-CANDIDATE: warning_issued|suspension_applied|dismissal|no_action|case_dismissed|grievance_upheld|grievance_rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyReference rdf:type rdf:Property ;
    rdfs:label 'Policy Reference' ;
    rdfs:comment 'Reference to the specific company policy, code of conduct section, or regulatory requirement that was violated or is relevant to the case.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCaseCount rdf:type rdf:Property ;
    rdfs:label 'Previous Case Count' ;
    rdfs:comment 'The number of prior disciplinary cases on record for this employee at the time this case was opened. Used to assess pattern of behavior and determine appropriate severity.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date when employee suspension ended and the employee was eligible to return to work, if suspension was part of the disciplinary action.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Paid Flag' ;
    rdfs:comment 'Indicates whether the suspension period was paid or unpaid. True if paid suspension, false if unpaid.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date when employee suspension commenced, if suspension was part of the disciplinary action.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Union Notified Flag' ;
    rdfs:comment 'Indicates whether the employee\'s union or collective bargaining representative was notified of the disciplinary case, as required by labor agreements. True if union was notified, false otherwise.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warningExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warning Expiry Date' ;
    rdfs:comment 'The date when the issued warning expires and is removed from the employee\'s active disciplinary record, if applicable.' ;
    rdfs:domain ind:DisciplinaryCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'The number of witnesses interviewed or statements collected as part of the disciplinary case investigation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'The work location code of the employee at the time the disciplinary case was opened. Used for geographic and site-level analysis.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the person to contact in case of employee emergency. Used for workplace incidents, medical emergencies, and critical notifications.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Primary phone number for the designated emergency contact. Used for urgent notifications and workplace incident response.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee (e.g., spouse, parent, sibling, friend). Used to validate contact authority and prioritize notifications.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Business-facing unique employee identifier assigned by Human Resources. Used on badges, timesheets, and payroll systems. Externally-known identifier for the employee.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee within the organization. Determines access rights, payroll processing, and system permissions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employee\'s employment arrangement. Determines benefits eligibility, work schedule expectations, and contract terms.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Employee\'s self-identified gender. Used for diversity reporting, benefits administration, and compliance with equal employment opportunity regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the employee most recently joined the organization. For rehires, this is the date of the most recent hire event. Used for seniority calculations, benefits vesting, and anniversary recognition.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hrSystemSourceCode rdf:type rdf:Property ;
    rdfs:label 'Hr System Source Code' ;
    rdfs:comment 'Original identifier from the source HR system of record. Used for data lineage, system integration, and reconciliation with upstream HR platforms.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Employee\'s legal first name as it appears on government-issued identification documents. Used for payroll, tax forms, and official HR records.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Employee\'s legal last name (surname/family name) as it appears on government-issued identification documents. Used for payroll, tax forms, and official HR records.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Employee\'s legal middle name or initial as it appears on government-issued identification documents. Optional field; may be null if not applicable.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maritalStatus rdf:type rdf:Property ;
    rdfs:label 'Marital Status' ;
    rdfs:comment 'Employee\'s current marital status. Used for tax withholding calculations, benefits enrollment, and emergency contact validation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalHireDate rdf:type rdf:Property ;
    rdfs:label 'Original Hire Date' ;
    rdfs:comment 'Date the employee first joined the organization, even if they left and were rehired. Used for calculating total service time and long-term benefits eligibility.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personalEmail rdf:type rdf:Property ;
    rdfs:label 'Personal Email' ;
    rdfs:comment 'Employee\'s personal email address. Used for emergency communications, benefits notifications, and post-employment correspondence.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalMobile rdf:type rdf:Property ;
    rdfs:label 'Personal Mobile' ;
    rdfs:comment 'Employee\'s personal mobile phone number. Used for emergency contact, two-factor authentication, and urgent business communications.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in day-to-day business interactions. May differ from legal name. Used in email signatures, directory listings, and internal communications.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for rehire based on their employment history and termination circumstances. Used for recruitment screening and applicant tracking.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Employee\'s primary corporate email address. Used for business communications, system notifications, and authentication. Typically follows company email naming convention.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Employee\'s primary work phone number (desk phone or assigned mobile). Used for business contact and directory listings.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Classification of the employee\'s work schedule pattern. Used for time tracking, shift planning, and workforce management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalId rdf:type rdf:Property ;
    rdfs:label 'Goal Id' ;
    rdfs:comment 'Unique identifier for the employee performance goal record. Primary key.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Employee Id' ;
    rdfs:comment 'Reference to the employee to whom this goal is assigned. Links to the employee master record in the people domain.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Manager Employee Id' ;
    rdfs:comment 'Reference to the employee\'s direct manager who is responsible for reviewing, approving, and evaluating this goal. Links to the employee master record.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentGoalId rdf:type rdf:Property ;
    rdfs:label 'Parent Goal Id' ;
    rdfs:comment 'Reference to the parent goal from which this goal was cascaded (typically a manager\'s or organizational goal). Null if this is a top-level or self-created goal. Enables goal hierarchy and alignment tracking.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Goal .

ind:performanceCycleId rdf:type rdf:Property ;
    rdfs:label 'Performance Cycle Id' ;
    rdfs:comment 'Reference to the performance management cycle (annual, semi-annual, quarterly) within which this goal is set and evaluated.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceCycle .

ind:achievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Achievement Percentage' ;
    rdfs:comment 'The percentage of goal achievement calculated as (actual_value / target_value) * 100. Values over 100% indicate over-achievement. Used to compute weighted contribution to overall performance rating.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'General comments, notes, or additional context about the goal. May include employee self-assessment notes, manager feedback, or collaborative discussion points.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCode rdf:type rdf:Property ;
    rdfs:label 'Competency Code' ;
    rdfs:comment 'Reference code to the competency framework or skill taxonomy that this goal develops or demonstrates (e.g., \'LEAD-001\' for leadership, \'TECH-5G\' for 5G technical skills). Applicable primarily to development and behavioral goals.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the employee has formally acknowledged and accepted this goal. True means the employee has reviewed and committed to the goal; False means it is still pending employee acceptance.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the employee formally acknowledged and committed to this goal. Null if not yet acknowledged.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goalCategory rdf:type rdf:Property ;
    rdfs:label 'Goal Category' ;
    rdfs:comment 'Classification of the goal type: business_objective (tied to KPIs and business outcomes), development_goal (skill building, training, career growth), behavioral_competency (leadership, collaboration, communication), operational_excellence (process improvement, efficiency), customer_satisfaction (NPS, CSAT improvement), or innovation (new initiatives, R&D).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalDescription rdf:type rdf:Property ;
    rdfs:label 'Goal Description' ;
    rdfs:comment 'Detailed narrative description of the goal, including context, expected outcomes, success criteria, and any relevant background information.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalNumber rdf:type rdf:Property ;
    rdfs:label 'Goal Number' ;
    rdfs:comment 'Human-readable business identifier for the goal, typically formatted as cycle-employee-sequence (e.g., 2024-EMP12345-G01).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalSource rdf:type rdf:Property ;
    rdfs:label 'Goal Source' ;
    rdfs:comment 'Origin of the goal: cascaded_from_manager (manager assigned from their own goals), self_created (employee proposed), hr_assigned (HR or talent management assigned), org_objective_aligned (derived from organizational unit objectives), peer_suggested (recommended by peer or cross-functional partner).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalStatus rdf:type rdf:Property ;
    rdfs:label 'Goal Status' ;
    rdfs:comment 'Current lifecycle status of the goal: draft (being defined), committed (approved and active), in_progress (employee working on it), completed (cycle ended, achievement recorded), cancelled (goal no longer applicable), deferred (postponed to next cycle).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStretchGoal rdf:type rdf:Property ;
    rdfs:label 'Is Stretch Goal' ;
    rdfs:comment 'Indicates whether this is a stretch goal (aspirational, beyond normal expectations). True means this is a stretch goal; False means it is a standard performance goal. Stretch goals may have different evaluation criteria.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedTrainingPlanReference rdf:type rdf:Property ;
    rdfs:label 'Linked Training Plan Reference' ;
    rdfs:comment 'Reference to a training or development plan that supports achievement of this goal. Enables tracking of learning activities tied to performance goals.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the manager has formally acknowledged and approved this goal. True means the goal has been reviewed and accepted by the manager; False means it is still pending manager review.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manager Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the manager formally acknowledged and approved this goal. Null if not yet acknowledged.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:midYearProgressNote rdf:type rdf:Property ;
    rdfs:label 'Mid Year Progress Note' ;
    rdfs:comment 'Narrative assessment of progress toward the goal at the mid-year review checkpoint. Captures manager and employee observations, challenges encountered, and any adjustments to approach or target.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitObjectiveReference rdf:type rdf:Property ;
    rdfs:label 'Org Unit Objective Reference' ;
    rdfs:comment 'Reference to the organizational unit\'s strategic objective to which this goal is aligned. Enables tracking of individual goal contribution to departmental and enterprise objectives.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'The cadence at which this goal is reviewed and progress is assessed: weekly, bi_weekly, monthly, quarterly, semi_annual, annual, or ad_hoc (as needed). [ENUM-REF-CANDIDATE: weekly|bi_weekly|monthly|quarterly|semi_annual|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricName rdf:type rdf:Property ;
    rdfs:label 'Target Metric Name' ;
    rdfs:comment 'The name of the Key Performance Indicator (KPI) or metric used to measure goal achievement (e.g., \'Network Uptime Percentage\', \'Customer Churn Rate\', \'Mean Time to Repair (MTTR)\', \'Revenue Growth\', \'Training Hours Completed\').' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Target Metric Unit' ;
    rdfs:comment 'The unit of measure for the target metric (e.g., \'percentage\', \'hours\', \'count\', \'USD\', \'days\', \'incidents\'). Provides context for interpreting target and actual values.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Defines who can view this goal: private (employee and manager only), manager_only (manager and HR), team (employee\'s immediate team), department (entire department), public (all employees in the organization).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'The relative weight or importance of this goal within the employee\'s overall performance evaluation, expressed as a percentage (e.g., 25.00 means this goal accounts for 25% of the total performance score). All goals for an employee within a cycle should sum to 100%.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearEndAchievementNote rdf:type rdf:Property ;
    rdfs:label 'Year End Achievement Note' ;
    rdfs:comment 'Final narrative assessment of goal achievement at year-end evaluation. Documents actual results, impact on business outcomes, lessons learned, and manager\'s evaluation comments.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Unique identifier for the headcount planning entry. Primary key for the headcount plan record.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the job profile or job family for which headcount is being planned. Links to job profile master data.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:primaryHeadcountSubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Headcount Submitted By Employee Id' ;
    rdfs:comment 'Reference to the employee who submitted this headcount plan entry for approval. Links to the employee master data.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'The number of headcount positions that have been formally approved by management and budget authorities. May differ from planned headcount if approval is partial.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionAssumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Attrition Assumption Percentage' ;
    rdfs:comment 'The assumed attrition rate (as a percentage) used in planning calculations for this org unit and job profile. Used to forecast turnover and replacement needs.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Status' ;
    rdfs:comment 'The current approval workflow status of this headcount plan entry. Tracks the plan through the budget approval lifecycle from draft to final approval or rejection.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFilledHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Filled Headcount' ;
    rdfs:comment 'The actual number of filled positions as of the plan snapshot date. Represents current state for comparison against planned and approved levels.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentVacantHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Vacant Headcount' ;
    rdfs:comment 'The number of approved but unfilled positions as of the plan snapshot date. Calculated as approved headcount minus current filled headcount.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualCostPerHead rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Cost Per Head' ;
    rdfs:comment 'The estimated fully-loaded annual cost per headcount position, including base salary, benefits, taxes, and overhead. Used for budget planning calculations.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountType rdf:type rdf:Property ;
    rdfs:label 'Headcount Type' ;
    rdfs:comment 'The employment type category for this headcount plan entry. Distinguishes between permanent employees, fixed-term contracts, contractors, interns, and temporary workers.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netNewHeadcountRequested rdf:type rdf:Property ;
    rdfs:label 'Net New Headcount Requested' ;
    rdfs:comment 'The incremental headcount increase requested beyond current approved levels. Represents growth or expansion requests for the planning period.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'The date from which this headcount plan becomes effective. Marks the start of the planning period for this entry.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiry Date' ;
    rdfs:comment 'The date on which this headcount plan expires or is superseded. Marks the end of the planning period for this entry.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'The total number of headcount positions planned for this org unit, job profile, and period. May include fractional FTE (Full-Time Equivalent) values for part-time positions.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningCycleReference rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle Reference' ;
    rdfs:comment 'Reference to the planning cycle during which this headcount plan was created. Links to the planning cycle master data.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningNotes rdf:type rdf:Property ;
    rdfs:label 'Planning Notes' ;
    rdfs:comment 'Free-text notes and comments related to this headcount plan entry. May include justification for headcount requests, business rationale, or special considerations.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningQuarter rdf:type rdf:Property ;
    rdfs:label 'Planning Quarter' ;
    rdfs:comment 'The fiscal quarter within the planning year for which this headcount plan applies. Values: Q1, Q2, Q3, Q4.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningYear rdf:type rdf:Property ;
    rdfs:label 'Planning Year' ;
    rdfs:comment 'The fiscal year for which this headcount plan applies. Four-digit year format (e.g., 2024).' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The date on which the current filled and vacant headcount figures were captured. Used to timestamp the actual headcount data for comparison against plan.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalEstimatedAnnualCost rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Annual Cost' ;
    rdfs:comment 'The total estimated annual cost for all planned headcount in this entry. Calculated as planned headcount multiplied by estimated annual cost per head.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewEventId rdf:type rdf:Property ;
    rdfs:label 'Interview Event Id' ;
    rdfs:comment 'Unique identifier for the interview event record. Primary key for the interview event entity.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInterviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Interviewer Employee Id' ;
    rdfs:comment 'Reference to the lead interviewer conducting the interview. This is the main point of contact and decision maker for the interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryInterviewCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Interview Coordinator Employee Id' ;
    rdfs:comment 'Reference to the HR or recruitment coordinator responsible for scheduling and logistics of this interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Reference to the job requisition for which this interview is being conducted. Links the interview to the open position being filled.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:rescheduledFromInterviewEventId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Interview Event Id' ;
    rdfs:comment 'Reference to the original interview event that was rescheduled, creating this new interview event record.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterviewEvent .

ind:tertiaryInterviewer3EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Interviewer 3 Employee Id' ;
    rdfs:comment 'Reference to the third interviewer participating in the interview session, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryQuinaryInterviewer5EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quinary Interviewer 5 Employee Id' ;
    rdfs:comment 'Reference to the fifth interviewer participating in the interview session, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'The actual date and time when the interview concluded. Used to track actual interview duration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:averageInterviewerScore rdf:type rdf:Property ;
    rdfs:label 'Average Interviewer Score' ;
    rdfs:comment 'Calculated average of all interviewer scores for this interview event. Provides a consolidated quantitative assessment.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Communication Skills Rating' ;
    rdfs:comment 'Assessment of the candidates verbal and written communication abilities, presentation skills, and clarity of expression.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concernsSummary rdf:type rdf:Property ;
    rdfs:label 'Concerns Summary' ;
    rdfs:comment 'Summary of any concerns, weaknesses, or red flags identified during the interview that may impact hiring decision.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalFitRating rdf:type rdf:Property ;
    rdfs:label 'Cultural Fit Rating' ;
    rdfs:comment 'Assessment of how well the candidates values, work style, and personality align with the organizations culture and team dynamics.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feedback Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the interview feedback and scores were submitted by the interview panel. Tracks timeliness of feedback completion.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interviewLocation rdf:type rdf:Property ;
    rdfs:label 'Interview Location' ;
    rdfs:comment 'Physical location or address where the interview is conducted for on-site or off-site interviews. May include building name, floor, and room number.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewLocationType rdf:type rdf:Property ;
    rdfs:label 'Interview Location Type' ;
    rdfs:comment 'Classification of where the interview takes place. Determines logistics and technology requirements.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Interview Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the interview event, used for tracking and communication purposes.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewRoundNumber rdf:type rdf:Property ;
    rdfs:label 'Interview Round Number' ;
    rdfs:comment 'Sequential number indicating which round of interviews this represents in the recruitment process (e.g., 1 for first round, 2 for second round).' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStatus rdf:type rdf:Property ;
    rdfs:label 'Interview Status' ;
    rdfs:comment 'Current lifecycle status of the interview event. Tracks the interview from scheduling through completion or cancellation. [ENUM-REF-CANDIDATE: scheduled|confirmed|in_progress|completed|cancelled|no_show|rescheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewType rdf:type rdf:Property ;
    rdfs:label 'Interview Type' ;
    rdfs:comment 'Classification of the interview format and purpose. Determines the structure and focus of the interview session. [ENUM-REF-CANDIDATE: phone_screen|video_interview|panel_interview|technical_assessment|case_study|hr_interview|executive_interview — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewer2Score rdf:type rdf:Property ;
    rdfs:label 'Interviewer 2 Score' ;
    rdfs:comment 'Numerical score assigned by the second interviewer, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewer3Score rdf:type rdf:Property ;
    rdfs:label 'Interviewer 3 Score' ;
    rdfs:comment 'Numerical score assigned by the third interviewer, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewer4Score rdf:type rdf:Property ;
    rdfs:label 'Interviewer 4 Score' ;
    rdfs:comment 'Numerical score assigned by the fourth interviewer, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewer5Score rdf:type rdf:Property ;
    rdfs:label 'Interviewer 5 Score' ;
    rdfs:comment 'Numerical score assigned by the fifth interviewer, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextStepAction rdf:type rdf:Property ;
    rdfs:label 'Next Step Action' ;
    rdfs:comment 'Description of the next action to be taken following this interview (e.g., schedule next round, extend offer, send rejection, request additional assessment).' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowParty rdf:type rdf:Property ;
    rdfs:label 'No Show Party' ;
    rdfs:comment 'Indicates which party failed to attend the scheduled interview, if applicable.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Decision Date' ;
    rdfs:comment 'Date when the final decision on the interview outcome was made and recorded. May differ from the interview date.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRecommendation rdf:type rdf:Property ;
    rdfs:label 'Overall Recommendation' ;
    rdfs:comment 'Consolidated recommendation from the interview panel on whether to advance the candidate to the next stage. Primary decision outcome of the interview.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInterviewerScore rdf:type rdf:Property ;
    rdfs:label 'Primary Interviewer Score' ;
    rdfs:comment 'Numerical score assigned by the primary interviewer, typically on a standardized scale. Used for quantitative candidate comparison.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuredFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Structured Feedback Notes' ;
    rdfs:comment 'Detailed qualitative feedback and observations from the interview panel. Contains specific examples, strengths, weaknesses, and areas of concern.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Assessment of the candidates technical skills and domain expertise relevant to the position requirements.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoMeetingLink rdf:type rdf:Property ;
    rdfs:label 'Video Meeting Link' ;
    rdfs:comment 'URL or meeting link for the video conference session. Contains access credentials for the virtual interview room.' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoPlatform rdf:type rdf:Property ;
    rdfs:label 'Video Platform' ;
    rdfs:comment 'Name of the video conferencing platform used for remote interviews (e.g., Zoom, Microsoft Teams, Webex).' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the job profile is eligible for performance-based bonus or incentive compensation. True if eligible, False otherwise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Primary business unit or division to which the job profile is aligned. May be null for enterprise-wide job profiles applicable across multiple business units.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the job profile is eligible for sales commission or variable compensation tied to revenue generation. True if eligible, False otherwise. Typically applies to sales and business development roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coreCompetencies rdf:type rdf:Property ;
    rdfs:label 'Core Competencies' ;
    rdfs:comment 'List of essential skills, knowledge areas, and behavioral competencies required for successful performance in the role. May include technical skills (e.g., Long-Term Evolution (LTE), 5G New Radio (5G NR), Software-Defined Networking (SDN)), leadership competencies, and domain expertise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Compensation grade or pay band assigned to the job profile. Determines salary range, bonus eligibility, and benefits tier. Confidential business-sensitive data used in compensation planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Boolean flag indicating whether the job profile involves direct interaction with external customers. True if the role regularly engages with customers, False otherwise. Used for Customer Relationship Management (CRM) and training planning.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPeopleManager rdf:type rdf:Property ;
    rdfs:label 'Is People Manager' ;
    rdfs:comment 'Boolean flag indicating whether the job profile includes direct people management responsibilities (supervising, coaching, performance evaluation of subordinates). True if the role manages people, False otherwise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetySensitive rdf:type rdf:Property ;
    rdfs:label 'Is Safety Sensitive' ;
    rdfs:comment 'Boolean flag indicating whether the job profile is classified as safety-sensitive, requiring adherence to occupational health and safety regulations, drug testing, and specialized training. True for roles such as field technicians, network engineers working on infrastructure, False otherwise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Comprehensive narrative describing the purpose, responsibilities, duties, and scope of the job profile. Used in recruitment, performance management, and role clarification.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileCode rdf:type rdf:Property ;
    rdfs:label 'Job Profile Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the job profile across the enterprise. Used in Human Resources (HR) systems, payroll, and workforce planning. Business identifier for external reference.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile. Active profiles are available for use in hiring and workforce planning. Inactive or deprecated profiles are retained for historical reference but not used for new hires.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobSubfamily rdf:type rdf:Property ;
    rdfs:label 'Job Subfamily' ;
    rdfs:comment 'Secondary classification within the job family providing finer granularity. For example, within Network Engineering: Radio Access Network (RAN), Core Network, Transport, Operations Support Systems (OSS).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when the job profile was last reviewed and validated by Human Resources (HR) or the business owner. Used to ensure job profiles remain current and aligned with organizational needs.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumEducationRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Requirement' ;
    rdfs:comment 'Minimum level of formal education required for the job profile. Used in candidate screening and workforce planning. [ENUM-REF-CANDIDATE: High School Diploma|Associate Degree|Bachelor Degree|Master Degree|Doctoral Degree|Professional Certification|No Formal Requirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for the job profile. Used in recruitment and succession planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the job profile is eligible for overtime compensation. Typically aligns with Fair Labor Standards Act (FLSA) non-exempt classification. True if eligible, False otherwise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorJobProfileCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Job Profile Code' ;
    rdfs:comment 'Job profile code of the typical prior role in the career path leading to this job profile. Used for career progression planning and internal mobility analysis. May be null for entry-level roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockOptionEligible rdf:type rdf:Property ;
    rdfs:label 'Stock Option Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the job profile is eligible for equity compensation such as stock options, restricted stock units, or employee stock purchase plans. True if eligible, False otherwise.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successorJobProfileCode rdf:type rdf:Property ;
    rdfs:label 'Successor Job Profile Code' ;
    rdfs:comment 'Job profile code of the typical next role in the career path following this job profile. Used for career progression planning and succession management. May be null for terminal roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel. Expressed as an integer percentage (0-100). Used in recruitment, expense planning, and work-life balance considerations.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionEligibility rdf:type rdf:Property ;
    rdfs:label 'Union Eligibility' ;
    rdfs:comment 'Indicates whether the job profile is eligible for union membership or collective bargaining representation. Used for labor relations and compliance with collective bargaining agreements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningCourseId rdf:type rdf:Property ;
    rdfs:label 'Learning Course Id' ;
    rdfs:comment 'Unique identifier for the learning and development course. Primary key for the learning course entity.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningCourse .

ind:primaryLearningApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Learning Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the L&D manager, compliance officer, or authorized approver who approved this course for delivery. Null for courses not yet approved.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether the course is currently active and available for enrollment. True for courses in the active catalog; false for retired, suspended, or archived courses. Used to filter available courses in learning portals.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the organization or authority that issues the certification upon course completion. Examples include vendor certifications (Ericsson Certified, Nokia Certified), industry bodies (TM Forum, GSMA), or internal enterprise certifications. Null for non-certification courses.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Flag' ;
    rdfs:comment 'Indicates whether successful completion of this course results in a formal certification or credential. True for certification programs (e.g., 5G Network Specialist, OSS/BSS Administrator); false for general training.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyFramework rdf:type rdf:Property ;
    rdfs:label 'Competency Framework' ;
    rdfs:comment 'Reference to the enterprise competency model or skills framework this course supports. Maps course outcomes to organizational capability requirements (e.g., Network Operations Competency Model, Customer Experience Framework).' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Primary classification of the course content area. Categories align with telecommunications workforce development needs including technical skills (RAN, Core, OSS/BSS), leadership development, regulatory compliance (FCC, GDPR), safety training, product knowledge, and soft skills. [ENUM-REF-CANDIDATE: technical|leadership|compliance|safety|product_knowledge|soft_skills|regulatory|sales|customer_service|network_operations — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique business identifier for the course, used for catalog reference and enrollment systems. Typically alphanumeric code assigned by Learning and Development (L&D) or external training provider.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the course content, learning objectives, prerequisites, and expected outcomes. Used for course selection and enrollment decisions.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Course Fee Amount' ;
    rdfs:comment 'Cost per learner to deliver or purchase this course. Includes external vendor fees, licensing costs, or internal cost allocation. Zero for internally developed courses with no direct cost. Used for training budget management and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseLanguage rdf:type rdf:Property ;
    rdfs:label 'Course Language' ;
    rdfs:comment 'Primary language in which the course content is delivered, using ISO 639-2 three-letter language codes (e.g., ENG for English, SPA for Spanish, FRA for French). Critical for multinational telecommunications workforce.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'Full official title of the learning course as displayed in the learning management system and course catalog.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseVersion rdf:type rdf:Property ;
    rdfs:label 'Course Version' ;
    rdfs:comment 'Version number of the course content, following semantic versioning (e.g., 1.0, 2.1). Incremented when course content, assessments, or learning objectives are updated. Supports version control and learner transcript accuracy.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'Continuing education or professional development credits awarded upon successful course completion. Used for certification maintenance and professional licensing requirements.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the course content is delivered to learners. Instructor-Led Training (ILT) can be classroom or virtual, e-learning is self-paced online, blended combines multiple modes, and on-the-job is experiential learning. [ENUM-REF-CANDIDATE: instructor_led_classroom|virtual_ilt|e_learning|blended|on_the_job|self_paced|webinar — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total instructional time required to complete the course, measured in hours. Includes classroom time, virtual sessions, and estimated self-study time for e-learning modules.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastContentUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Update Date' ;
    rdfs:comment 'Date when the course content, materials, or assessments were last revised. Critical for ensuring training materials reflect current technology, regulations, and business processes in the rapidly evolving telecommunications industry.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:learningManagementSystemCode rdf:type rdf:Property ;
    rdfs:label 'Learning Management System Code' ;
    rdfs:comment 'External identifier for this course in the source Learning Management System (LMS) or Human Capital Management (HCM) platform. Used for system integration and data reconciliation with SAP SuccessFactors, Cornerstone, or other LMS platforms.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether the course is required for specific roles, job families, or all employees. True for mandatory compliance, safety, or onboarding courses; false for optional professional development.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxEnrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment Capacity' ;
    rdfs:comment 'Maximum number of learners that can be enrolled in a single course session or offering. Relevant for instructor-led and virtual courses with limited seats. Null for unlimited capacity e-learning courses.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score or percentage required to successfully complete the course and receive credit or certification. Typically expressed as percentage (e.g., 80.00 for 80%). Null for courses without formal assessment.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before enrolling in this course. Defines learning path dependencies and ensures learners have foundational knowledge. Null if no prerequisites required.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the course provider. Internal courses are developed and delivered by enterprise L&D; external vendors are third-party training companies; industry associations include GSMA, TM Forum; technology partners are equipment manufacturers offering product training.' ;
    rdfs:domain ind:LearningCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Target proficiency level for learners completing this course. Foundation courses introduce new concepts; intermediate builds on existing knowledge; advanced courses develop deep expertise; expert level is for subject matter specialists.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended learner population for this course. May specify job families (network engineers, customer service representatives), grade bands (individual contributor, manager, executive), departments, or all employees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Number of months the course completion or certification remains valid before recertification or refresher training is required. Common for compliance, safety, and technical certification courses. Null for courses with no expiration.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:learningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Learning Enrollment Id' ;
    rdfs:comment 'Unique identifier for the learning enrollment record. Primary key for the learning enrollment entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LearningEnrollment .

ind:primaryLearningEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Learning Employee Id' ;
    rdfs:comment 'Reference to the employee enrolled in the learning course. Links to the employee master record.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the employee on the course assessment or examination. Typically expressed as a percentage or points out of maximum.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of scheduled sessions or modules that the employee attended or completed. Used to track engagement and compliance with attendance requirements.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the certificate expires and recertification or renewal is required. Null for certificates with no expiration.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date when the completion certificate was issued to the employee.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a completion certificate was issued to the employee upon successful completion of the course.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique identifier or reference number of the certificate issued to the employee. Used for verification and audit purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of course content or modules completed by the employee. Tracks progress toward full course completion.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Category of compliance or regulatory requirement that the learning course fulfills. Examples include safety training, data privacy, anti-corruption, or industry-specific certifications.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdHoursCredited rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Credited' ;
    rdfs:comment 'Number of Continuing Professional Development hours credited to the employee upon completion of the course. Used for professional certification and compliance tracking.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverySessionReference rdf:type rdf:Property ;
    rdfs:label 'Delivery Session Reference' ;
    rdfs:comment 'Reference to the specific delivery session or class instance in which the employee is enrolled. Links to the learning delivery schedule.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment reference number used for tracking and reporting purposes.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Origin or trigger for the enrollment. Indicates whether the enrollment was initiated by the employee, assigned by management, required for compliance, or triggered by system rules.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the employee regarding their experience with the learning course. Used for qualitative analysis and course improvement.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Employee satisfaction rating for the learning course, typically on a scale of 1 to 5. Used to assess course quality and effectiveness.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who delivered the learning course. Applicable for instructor-led training sessions.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningHoursLogged rdf:type rdf:Property ;
    rdfs:label 'Learning Hours Logged' ;
    rdfs:comment 'Total number of hours the employee spent on the learning course, including instruction time, self-study, and assessments.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recertification Date' ;
    rdfs:comment 'Date by which the employee must complete recertification or renewal of the course. Null if recertification is not required.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Outcome of the course assessment indicating whether the employee passed or failed. Not applicable for courses without formal assessments.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the employee must retake or renew the course after a specified period to maintain certification or compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the external training provider or vendor that delivered the course. Null for internally-delivered training.' ;
    rdfs:domain ind:LearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Leave Entitlement Id' ;
    rdfs:comment 'Unique identifier for the leave entitlement record. Primary key for this entity.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or process that last modified this leave entitlement record. Used for audit trail.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual End Date' ;
    rdfs:comment 'Date on which leave accrual ends for this entitlement record. Typically the end of the leave year or the employees termination date.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualFrequency rdf:type rdf:Property ;
    rdfs:label 'Accrual Frequency' ;
    rdfs:comment 'Frequency at which leave days are accrued for this entitlement. Monthly indicates leave accrues each month; annual indicates full entitlement granted at start of year; per_pay_period indicates accrual aligned with payroll cycles; daily indicates daily accrual; quarterly indicates accrual every quarter.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Start Date' ;
    rdfs:comment 'Date from which leave accrual begins for this entitlement record. Typically the start of the leave year or the employees hire date.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accruedDays rdf:type rdf:Property ;
    rdfs:label 'Accrued Days' ;
    rdfs:comment 'Number of leave days accrued to date within the current leave year, based on the accrual frequency and the employees tenure. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'The date as of which the leave balance figures (accrued, taken, pending, remaining) are accurate. Used for point-in-time reporting and reconciliation.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carriedForwardDays rdf:type rdf:Property ;
    rdfs:label 'Carried Forward Days' ;
    rdfs:comment 'Number of unused leave days carried forward from the previous leave year, subject to company policy and regulatory limits. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryoverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Carryover Expiry Date' ;
    rdfs:comment 'Date by which carried-forward leave days must be used, after which they will be forfeited. Null indicates no expiry.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carryoverLimitDays rdf:type rdf:Property ;
    rdfs:label 'Carryover Limit Days' ;
    rdfs:comment 'Maximum number of leave days that can be carried forward to the next leave year, as per company policy or regulatory requirements. Null indicates no limit. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitlementDays rdf:type rdf:Property ;
    rdfs:label 'Entitlement Days' ;
    rdfs:comment 'Total number of leave days the employee is entitled to for this leave type in the specified leave year, as per company policy, employment contract, or statutory requirements. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forfeitedDays rdf:type rdf:Property ;
    rdfs:label 'Forfeited Days' ;
    rdfs:comment 'Number of leave days forfeited due to expiration, policy limits, or failure to use within the allowed timeframe. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether this leave type is paid (True) or unpaid (False).' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatutory rdf:type rdf:Property ;
    rdfs:label 'Is Statutory' ;
    rdfs:comment 'Indicates whether this leave entitlement is mandated by statutory or regulatory requirements (True) or is a company-provided benefit (False).' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveTypeCode rdf:type rdf:Property ;
    rdfs:label 'Leave Type Code' ;
    rdfs:comment 'Standardized code identifying the type of leave (e.g., AL for annual leave, SL for sick leave, ML for maternity leave, PL for paternity leave, PRNT for parental leave, BRV for bereavement leave, STD for study leave, UNP for unpaid leave, COMP for compensatory leave).' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveTypeName rdf:type rdf:Property ;
    rdfs:label 'Leave Type Name' ;
    rdfs:comment 'Human-readable name of the leave type (e.g., Annual Leave, Sick Leave, Maternity Leave, Paternity Leave, Parental Leave, Bereavement Leave, Study Leave, Unpaid Leave, Compensatory Leave).' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveYear rdf:type rdf:Property ;
    rdfs:label 'Leave Year' ;
    rdfs:comment 'The calendar or fiscal year for which this leave entitlement applies. Typically a four-digit year (e.g., 2024).' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Estimated financial liability for unused leave days, calculated based on the employees current salary and remaining leave balance. Used for financial reporting and accrual accounting. Measured in the companys reporting currency.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the leave liability amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pendingDays rdf:type rdf:Property ;
    rdfs:label 'Pending Days' ;
    rdfs:comment 'Number of leave days that have been approved but not yet taken (future-dated leave requests). Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBalanceDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Days' ;
    rdfs:comment 'Current remaining leave balance available for the employee to use, calculated as (entitlement_days + carried_forward_days + accrued_days - taken_days - pending_days - forfeited_days). Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'Unique identifier of this leave entitlement record in the source operational system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takenDays rdf:type rdf:Property ;
    rdfs:label 'Taken Days' ;
    rdfs:comment 'Number of leave days already taken by the employee for this leave type in the specified leave year. Measured in days and may include fractional days.' ;
    rdfs:domain ind:LeaveEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request transaction. Primary key for the leave request record.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Reference to the employee submitting the leave request. Links to the employee master record in the people domain.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveSubstituteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Substitute Employee Id' ;
    rdfs:comment 'Reference to the employee designated to cover responsibilities during the leave period. Optional field used for workforce continuity planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents attached to the leave request (e.g., medical certificates, travel documents). Used to enforce documentation requirements for certain leave types.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRequested rdf:type rdf:Property ;
    rdfs:label 'Days Requested' ;
    rdfs:comment 'Total number of leave days requested, including partial days. Calculated based on working days between start and end dates, accounting for half-day flags and organizational calendar.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the manager approved or rejected the leave request. Null for pending requests. Used for SLA (Service Level Agreement) tracking and approval turnaround metrics.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entitlementBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Entitlement Balance After' ;
    rdfs:comment 'Calculated leave entitlement balance after deducting the approved leave days. Updated when request_status changes to APPROVED and used to prevent over-allocation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitlementBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Entitlement Balance Before' ;
    rdfs:comment 'Snapshot of the employees leave entitlement balance for the applicable leave type at the time of request submission. Used for audit trail and balance reconciliation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:halfDayPeriod rdf:type rdf:Property ;
    rdfs:label 'Half Day Period' ;
    rdfs:comment 'Specifies which half of the day is requested when is_half_day is true. Used for workforce scheduling and shift coverage planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Hr Override Flag' ;
    rdfs:comment 'Indicates whether HR manually overrode the standard approval workflow or entitlement rules for this request. Used for audit and exception reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Hr Override Reason' ;
    rdfs:comment 'Explanation for why HR overrode standard rules. Required when hr_override_flag is true to maintain audit trail and compliance documentation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHalfDay rdf:type rdf:Property ;
    rdfs:label 'Is Half Day' ;
    rdfs:comment 'Flag indicating whether the leave request is for a half-day (morning or afternoon) rather than a full day. Affects leave balance deduction and workforce availability calculation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Documentation Flag' ;
    rdfs:comment 'Indicates whether the leave type or duration requires supporting documentation per organizational policy. Used to validate request completeness before approval.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Return Confirmed Flag' ;
    rdfs:comment 'Indicates whether the employees return to work has been confirmed by the manager or HR. Used to close the leave transaction and trigger final balance updates.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Actual date the employee returned to work after the leave period. Used to confirm leave completion and reconcile any discrepancies between planned and actual leave duration.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerLetterId rdf:type rdf:Property ;
    rdfs:label 'Offer Letter Id' ;
    rdfs:comment 'Unique identifier for the employment offer letter record. Primary key for the offer_letter product.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOfferHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Offer Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who will be the direct manager of the candidate upon hire. Used for approval workflow and organizational placement.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOfferApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Offer Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this offer letter (typically HR director or senior management). Required for governance and audit compliance.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'The date on which the candidate formally accepted the employment offer. Nullable if the offer has not been accepted.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Cleared Flag' ;
    rdfs:comment 'Indicates whether the candidate has successfully cleared the required background check. Nullable until background check is completed.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backgroundCheckCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completion Date' ;
    rdfs:comment 'The date on which the background check process was completed. Nullable if background check is not required or not yet completed.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Required Flag' ;
    rdfs:comment 'Indicates whether a background check is required as a condition of employment for this offer. Typically true for positions requiring security clearance or regulatory compliance.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declineDate rdf:type rdf:Property ;
    rdfs:label 'Decline Date' ;
    rdfs:comment 'The date on which the candidate formally declined the employment offer. Nullable if the offer has not been declined.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Free-text explanation provided by the candidate or recruiter for why the employment offer was declined. Used for talent acquisition analytics and process improvement.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the formal offer letter document stored in the document management system. Used for audit trail and legal compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobGrade rdf:type rdf:Property ;
    rdfs:label 'Job Grade' ;
    rdfs:comment 'The job grade or level being offered, which determines compensation band, benefits tier, and career progression path within the organization.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiry Date' ;
    rdfs:comment 'The date by which the candidate must accept or decline the offer. After this date, the offer is automatically expired and no longer valid.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerNumber rdf:type rdf:Property ;
    rdfs:label 'Offer Number' ;
    rdfs:comment 'Externally visible unique business identifier for the offer letter, typically formatted as OFR-YYYYNNNN for tracking and reference purposes.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the employment offer. Tracks the offer through its workflow from draft preparation to final disposition.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Probation Period Days' ;
    rdfs:comment 'Number of days for the probationary period during which employment may be terminated with reduced notice. Typically 90 or 180 days depending on role and jurisdiction.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'The proposed date on which the candidate is expected to commence employment if the offer is accepted. Subject to negotiation and background check clearance.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relocationAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Relocation Allowance Amount' ;
    rdfs:comment 'Relocation assistance amount offered to the candidate to cover moving expenses if the position requires geographic relocation. Nullable if not applicable.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Indicates whether the offered position is eligible for remote or hybrid work arrangements as part of the employment terms.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescindDate rdf:type rdf:Property ;
    rdfs:label 'Rescind Date' ;
    rdfs:comment 'The date on which the employer rescinded or withdrew the employment offer. Nullable if the offer has not been rescinded.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rescindReason rdf:type rdf:Property ;
    rdfs:label 'Rescind Reason' ;
    rdfs:comment 'Explanation for why the employer rescinded the employment offer (e.g., failed background check, budget freeze, position eliminated).' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the offered base salary amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOnBonusAmount rdf:type rdf:Property ;
    rdfs:label 'Sign On Bonus Amount' ;
    rdfs:comment 'One-time sign-on bonus amount offered to the candidate as an incentive to accept the employment offer. Nullable if no sign-on bonus is included.' ;
    rdfs:domain ind:OfferLetter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingTaskId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Task Id' ;
    rdfs:comment 'Unique identifier for the onboarding task record. Primary key for the onboarding task entity.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5OnboardingLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Onboarding Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that last modified this onboarding task record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:onboardingProgramId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Program Id' ;
    rdfs:comment 'Reference to the parent onboarding program or journey that this task belongs to.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingProgram .

ind:primaryOnboardingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Onboarding Employee Id' ;
    rdfs:comment 'Reference to the employee (new hire or rehire) to whom this onboarding task is assigned.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryOnboardingEscalatedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Onboarding Escalated To Employee Id' ;
    rdfs:comment 'Reference to the employee (manager or senior leader) to whom this onboarding task has been escalated for resolution.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryOnboardingCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Onboarding Created By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that created this onboarding task record.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOnboardingWaivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Onboarding Waived By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically HR manager or department head) who authorized the waiver of this onboarding task.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual time in hours spent completing this onboarding task, calculated from start to completion timestamps.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Explanation for why this onboarding task is currently blocked and cannot proceed, applicable when task_status is \'blocked\'.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Completion Evidence Reference' ;
    rdfs:comment 'Reference identifier or URI to documentation, system record, or artifact that serves as proof of task completion (e.g., training certificate ID, equipment serial number, signed acknowledgment document ID).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Expected time in hours required to complete this onboarding task, used for planning and resource allocation.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Required' ;
    rdfs:comment 'Indicates whether this onboarding task is required for regulatory compliance, legal obligations, or industry standards (e.g., safety training, data privacy acknowledgment).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReminderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Timestamp' ;
    rdfs:comment 'Date and time when the most recent reminder notification was sent for this onboarding task.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of automated reminder notifications sent to the assigned employee regarding this pending onboarding task.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'System Reference Code' ;
    rdfs:comment 'External system identifier or ticket number in the source system where this task is tracked (e.g., ServiceNow task ID, SAP SuccessFactors workflow ID).' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'Classification of the onboarding task by functional area. [ENUM-REF-CANDIDATE: it_setup|access_provisioning|equipment_issuance|policy_acknowledgment|compliance_training|benefits_enrollment|payroll_setup|buddy_assignment|orientation_session|department_induction — promote to reference product]' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the onboarding task, including instructions, requirements, and expected outcomes.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Short descriptive name of the onboarding task (e.g., \'Create Active Directory Account\', \'Issue Laptop\', \'Complete Safety Training\').' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskOwnerType rdf:type rdf:Property ;
    rdfs:label 'Task Owner Type' ;
    rdfs:comment 'The functional area or role responsible for completing or facilitating this onboarding task.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Timestamp' ;
    rdfs:comment 'Date and time when the task waiver was approved and recorded.' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity to which this organizational unit belongs, used for financial consolidation, regulatory reporting, and compliance purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy, enabling multi-level organizational structure traversal and roll-up reporting. Null for top-level units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Current actual headcount or number of employees assigned to this organizational unit, used for variance analysis against budget.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total annual operating budget allocated to this organizational unit for OPEX (Operational Expenditure) planning and financial control.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the annual budget amount, supporting multi-currency enterprise operations.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Head Employee Id' ;
    rdfs:comment 'Reference to the employee who serves as the head, manager, or leader of this organizational unit, responsible for its operations and performance.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved headcount budget or authorized number of full-time equivalent (FTE) positions allocated to this organizational unit for workforce planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether this organizational unit directly generates revenue (e.g., sales, commercial units) or is a support/cost center.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerTitle rdf:type rdf:Property ;
    rdfs:label 'Manager Title' ;
    rdfs:comment 'Official job title of the organizational unit head or manager (e.g., Vice President, Director, Manager, Team Lead).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit, used in financial systems, reporting hierarchies, and access control. Typically alphanumeric and unique across the enterprise.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, scope of work, and role within the broader enterprise structure.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Official name of the organizational unit as recognized in corporate documentation, organizational charts, and HR systems.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit indicating whether it is active, inactive, pending activation, suspended, dissolved, or merged into another unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit indicating its hierarchical level and structural role within the enterprise (e.g., division, department, team, cost center group, business unit). [ENUM-REF-CANDIDATE: division|department|team|cost_center_group|business_unit|function|region|subsidiary — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceType rdf:type rdf:Property ;
    rdfs:label 'Workforce Type' ;
    rdfs:comment 'Primary workforce composition type for this organizational unit (e.g., permanent employees, contractors, hybrid, outsourced, offshore).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique identifier for the payroll processing cycle. Primary key for the payroll run entity.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'Reference to the user or employee who executed or processed this payroll run. Links to the employee or user master data.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPayrollReversedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Payroll Reversed By User Employee Id' ;
    rdfs:comment 'Reference to the user or employee who reversed or cancelled this payroll run, if applicable. Links to the employee or user master data.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The date printed on physical checks or used as the effective date for electronic payments for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The total number of employees included in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offCycleReason rdf:type rdf:Property ;
    rdfs:label 'Off Cycle Reason' ;
    rdfs:comment 'The business reason for executing an off-cycle payroll run, if applicable (e.g., termination payment, bonus payment, correction).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'The payroll area or grouping that defines the payroll processing schedule and rules for this run (e.g., US-Salaried, US-Hourly, UK-Monthly).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollControlRecord rdf:type rdf:Property ;
    rdfs:label 'Payroll Control Record' ;
    rdfs:comment 'The payroll control record identifier that governs the processing rules and parameters for this payroll run in the source system.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollFrequency rdf:type rdf:Property ;
    rdfs:label 'Payroll Frequency' ;
    rdfs:comment 'The frequency at which payroll is processed for this run (e.g., monthly, bi-weekly, weekly, semi-monthly).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period End Date' ;
    rdfs:comment 'The last date of the payroll period covered by this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Start Date' ;
    rdfs:comment 'The first date of the payroll period covered by this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the payroll run, typically used in communications and reporting (e.g., PR-2024-001).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunType rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Type' ;
    rdfs:comment 'The type or category of payroll run being executed (e.g., regular, off-cycle, bonus, final settlement, correction, advance).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSystemReference rdf:type rdf:Property ;
    rdfs:label 'Payroll System Reference' ;
    rdfs:comment 'The unique identifier or reference number for this payroll run in the source payroll system (e.g., SAP HCM payroll run ID, SuccessFactors payroll run ID).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDateToGl rdf:type rdf:Property ;
    rdfs:label 'Posting Date To Gl' ;
    rdfs:comment 'The date on which payroll transactions from this run were posted to the general ledger in the financial system.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalEmployeeDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Employee Deductions' ;
    rdfs:comment 'The total amount of employee deductions (e.g., pension contributions, health insurance premiums, union dues) for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerContributions rdf:type rdf:Property ;
    rdfs:label 'Total Employer Contributions' ;
    rdfs:comment 'The total amount of employer contributions (e.g., pension, health insurance, social security) for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'The total gross pay amount for all employees included in this payroll run before any deductions or taxes.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'The total net pay amount for all employees included in this payroll run after all deductions, taxes, and contributions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'The total amount of taxes withheld from employee pay for this payroll run (e.g., federal, state, local income tax, social security, medicare).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique identifier for the payslip record. Primary key for the payslip transaction.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowancesTotal rdf:type rdf:Property ;
    rdfs:label 'Allowances Total' ;
    rdfs:comment 'Sum of all allowances paid in this period, including housing, transport, meal, mobile, and other allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basicSalary rdf:type rdf:Property ;
    rdfs:label 'Basic Salary' ;
    rdfs:comment 'The base salary component for the pay period, excluding any variable pay or allowances.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Sales commission or incentive earnings for the pay period.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerHealthContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Health Contribution' ;
    rdfs:comment 'Employer contribution toward employee health insurance premium. Not deducted from employee pay but shown for transparency.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerPensionContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution' ;
    rdfs:comment 'Employer matching or contribution to employee pension plan. Not deducted from employee pay but shown for transparency.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerSocialSecurity rdf:type rdf:Property ;
    rdfs:label 'Employer Social Security' ;
    rdfs:comment 'Employer portion of social security tax. Not deducted from employee pay but shown for transparency.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'Date and time when the payslip was generated by the payroll system.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total earnings before any deductions. Sum of basic salary, overtime, bonuses, allowances, and other earnings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Premium' ;
    rdfs:comment 'Employee share of health insurance premium deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total number of regular hours worked during the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeTax rdf:type rdf:Property ;
    rdfs:label 'Income Tax' ;
    rdfs:comment 'Federal, state, and local income tax withheld from gross pay for this period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Leave Days Taken' ;
    rdfs:comment 'Number of paid leave days (vacation, sick, personal) taken during this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanRepayment rdf:type rdf:Property ;
    rdfs:label 'Loan Repayment' ;
    rdfs:comment 'Installment amount deducted for employee loans (salary advance, emergency loan, etc.).' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Take-home pay after all deductions. Amount actually disbursed to the employee (gross pay minus total deductions).' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Sum of all other miscellaneous deductions not categorized above (garnishments, charitable contributions, etc.).' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total number of overtime hours worked during the pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Total overtime earnings for the pay period, including regular and premium overtime rates.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last day of the pay period covered by this payslip.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the pay period covered by this payslip.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Externally visible unique payslip reference number used for employee inquiries and audit trails.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle status of the payslip document.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionEmployeeContribution rdf:type rdf:Property ;
    rdfs:label 'Pension Employee Contribution' ;
    rdfs:comment 'Employee contribution to retirement pension plan deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferential rdf:type rdf:Property ;
    rdfs:label 'Shift Differential' ;
    rdfs:comment 'Additional compensation for working non-standard shifts (night, weekend, holiday).' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityEmployee rdf:type rdf:Property ;
    rdfs:label 'Social Security Employee' ;
    rdfs:comment 'Employee portion of social security tax deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all deductions from gross pay including taxes, insurance, pension, loans, and other withholdings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDues rdf:type rdf:Property ;
    rdfs:label 'Union Dues' ;
    rdfs:comment 'Union membership dues deducted from gross pay as per collective bargaining agreement.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdGrossPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Gross Pay' ;
    rdfs:comment 'Cumulative gross earnings from the start of the calendar or fiscal year through this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdIncomeTax rdf:type rdf:Property ;
    rdfs:label 'Ytd Income Tax' ;
    rdfs:comment 'Cumulative income tax withheld from the start of the calendar or fiscal year through this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdNetPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Net Pay' ;
    rdfs:comment 'Cumulative net pay from the start of the calendar or fiscal year through this pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cycle Owner Employee Id' ;
    rdfs:comment 'Identifier of the Human Resources (HR) business partner or administrator responsible for managing and overseeing this performance cycle.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationEndDate rdf:type rdf:Property ;
    rdfs:label 'Calibration End Date' ;
    rdfs:comment 'The deadline by which all calibration sessions must be completed and final ratings approved.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStartDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Start Date' ;
    rdfs:comment 'The date when calibration sessions begin, where leadership reviews and normalizes performance ratings across teams to ensure fairness and consistency.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Impact Flag' ;
    rdfs:comment 'Indicates whether performance ratings from this cycle directly impact compensation decisions such as merit increases, bonuses, or incentive payouts (True) or are for development purposes only (False).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the performance cycle (e.g., FY2024-ANNUAL, Q2-2024-CHECKIN). Used for external reference and reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the performance cycle, including its purpose, scope, key objectives, and any special instructions or considerations for participants.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Cycle End Date' ;
    rdfs:comment 'The date when the performance cycle officially ends. Marks the conclusion of the performance period and all review activities.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the performance cycle (e.g., 2024 Annual Performance Review, Q2 2024 Quarterly Check-In).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Start Date' ;
    rdfs:comment 'The date when the performance cycle officially begins. Marks the start of the performance period being evaluated.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the performance cycle: planned (configured but not started), active (currently running), in_progress (reviews underway), calibration (manager calibration phase), closed (completed and finalized), cancelled (terminated before completion).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Type of performance management cycle: annual appraisal (comprehensive year-end review), mid-year review (mid-cycle checkpoint), quarterly check-in (frequent touchpoint), probation review (new hire evaluation), PIP review (Performance Improvement Plan assessment), or 360-degree feedback (multi-rater assessment).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionGuideline rdf:type rdf:Property ;
    rdfs:label 'Distribution Guideline' ;
    rdfs:comment 'Textual description of the rating distribution guideline or target percentages for each rating level (e.g., Exceeds: 15-20%, Meets: 70-75%, Below: 5-10%). Applies when forced_distribution_flag is True.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePopulationCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligible Population Criteria' ;
    rdfs:comment 'Business rules defining which employees are included in this performance cycle (e.g., all full-time employees with 90+ days tenure, all managers and above, specific departments or business units). May reference employee attributes such as employment type, tenure, job level, or organizational unit.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enable360FeedbackFlag rdf:type rdf:Property ;
    rdfs:label 'Enable 360 Feedback Flag' ;
    rdfs:comment 'Indicates whether 360-degree feedback (multi-rater feedback from peers, direct reports, and other stakeholders) is enabled for this performance cycle (True) or disabled (False).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enableCalibrationFlag rdf:type rdf:Property ;
    rdfs:label 'Enable Calibration Flag' ;
    rdfs:comment 'Indicates whether calibration sessions are enabled for this performance cycle (True) or disabled (False). When enabled, leadership reviews and normalizes ratings across teams.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enableGoalSettingFlag rdf:type rdf:Property ;
    rdfs:label 'Enable Goal Setting Flag' ;
    rdfs:comment 'Indicates whether goal setting is enabled for this performance cycle (True) or disabled (False). When enabled, employees and managers must define performance objectives.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enableSelfAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Enable Self Assessment Flag' ;
    rdfs:comment 'Indicates whether employee self-assessment is enabled for this performance cycle (True) or disabled (False). When enabled, employees complete self-evaluations before manager reviews.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forcedDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Forced Distribution Flag' ;
    rdfs:comment 'Indicates whether forced (or guided) distribution of performance ratings is required for this cycle (True) or not (False). When enabled, managers must distribute ratings according to predefined percentages (e.g., 20% top performers, 70% meets expectations, 10% below expectations).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goalSettingEndDate rdf:type rdf:Property ;
    rdfs:label 'Goal Setting End Date' ;
    rdfs:comment 'The deadline by which all performance goals and objectives must be finalized and approved.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goalSettingStartDate rdf:type rdf:Property ;
    rdfs:label 'Goal Setting Start Date' ;
    rdfs:comment 'The date when employees and managers can begin setting performance goals and objectives for the cycle.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerReviewEndDate rdf:type rdf:Property ;
    rdfs:label 'Manager Review End Date' ;
    rdfs:comment 'The deadline by which managers must complete all performance reviews and submit ratings for their direct reports.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerReviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Manager Review Start Date' ;
    rdfs:comment 'The date when managers can begin conducting performance reviews and providing ratings for their direct reports.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Participation Flag' ;
    rdfs:comment 'Indicates whether participation in this performance cycle is mandatory for eligible employees (True) or optional (False). Mandatory cycles require completion for all eligible employees.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether automated email or system notifications are enabled for this performance cycle (True) to remind employees and managers of upcoming deadlines, or disabled (False).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceYear rdf:type rdf:Property ;
    rdfs:label 'Performance Year' ;
    rdfs:comment 'The fiscal or calendar year this performance cycle applies to (e.g., 2024).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligibility Flag' ;
    rdfs:comment 'Indicates whether performance ratings from this cycle are used to determine promotion eligibility (True) or not (False).' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleCode rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Code' ;
    rdfs:comment 'Reference code identifying the performance rating scale used for this cycle (e.g., SCALE_5PT, SCALE_4PT_FORCED). Links to the rating scale configuration defining rating levels and distribution guidelines.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Self Assessment End Date' ;
    rdfs:comment 'The deadline by which employees must complete and submit their self-assessment evaluations.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfAssessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Start Date' ;
    rdfs:comment 'The date when employees can begin completing their self-assessment evaluations.' ;
    rdfs:domain ind:PerformanceCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key for the performance review entity.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationSessionId rdf:type rdf:Property ;
    rdfs:label 'Calibration Session Id' ;
    rdfs:comment 'Reference to the calibration session during which this performance review was discussed and potentially adjusted. Links to the calibration session master record.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationSession .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Reference to the employee being reviewed. Links to the employee master record in the people domain.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationAdjustedRating rdf:type rdf:Property ;
    rdfs:label 'Calibration Adjusted Rating' ;
    rdfs:comment 'Performance rating after calibration session adjustments. May differ from the initial overall_rating_numeric if the calibration committee adjusted the rating for consistency across the organization.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Competency Assessment Score' ;
    rdfs:comment 'Quantitative score representing the employees demonstration of core competencies and behavioral attributes during the performance cycle. Typically expressed as a percentage or decimal.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentPlanCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Development Plan Created Flag' ;
    rdfs:comment 'Boolean indicator of whether an individual development plan was created as part of this performance review. True indicates a development plan exists.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date on which the employee acknowledged receipt and review of their performance appraisal. Indicates the employee has been informed of their rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Free-text narrative provided by the employee reflecting on their own performance, accomplishments, challenges, and development needs during the performance cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalRatingConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Final Rating Confirmed Flag' ;
    rdfs:comment 'Boolean indicator of whether the final performance rating has been confirmed and locked. True indicates the rating is final and cannot be changed without formal override.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Quantitative score representing the percentage or degree to which the employee achieved their assigned goals during the performance cycle. Typically expressed as a percentage (0-100) or decimal (0.00-1.00).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Free-text narrative comments provided by the manager summarizing the employees performance, strengths, areas for improvement, and development recommendations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseRecommendedPct rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Recommended Pct' ;
    rdfs:comment 'Recommended merit increase percentage based on the performance rating. Used as input to compensation planning and salary adjustment processes.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRatingLabel rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Label' ;
    rdfs:comment 'Textual label corresponding to the numeric performance rating. Provides human-readable interpretation of the overall rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingNumeric rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Numeric' ;
    rdfs:comment 'Numeric performance rating assigned to the employee. Typically on a scale such as 1-5 where 1=Below Expectations, 2=Meets Expectations, 3=Exceeds Expectations, 4=Outstanding, 5=Exceptional.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipEndDate rdf:type rdf:Property ;
    rdfs:label 'Pip End Date' ;
    rdfs:comment 'Scheduled end date for the Performance Improvement Plan. Represents the target date by which performance improvement is expected. Null if no PIP was triggered.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Flag' ;
    rdfs:comment 'Boolean indicator of whether a Performance Improvement Plan was triggered as a result of this review. True indicates the employee has been placed on a PIP.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Date on which the Performance Improvement Plan commenced. Null if no PIP was triggered.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether the manager recommended the employee for promotion based on this performance review. True indicates a promotion recommendation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Confirmation Date' ;
    rdfs:comment 'Date on which the final performance rating was confirmed and locked. Represents the official date the rating became final.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Target date by which the performance review should be completed and submitted. Used for tracking review completion timeliness.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Human-readable business identifier for the performance review. Typically follows a pattern such as PR-YYYY-NNNNNN where YYYY is the year and NNNNNN is a sequential number.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance period being evaluated in this review. Defines the conclusion of the timeframe for which performance is assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance period being evaluated in this review. Defines the beginning of the timeframe for which performance is assessed.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the performance review. Tracks the review through its workflow from initiation to completion and acknowledgment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Additional comments provided by secondary reviewers or HR business partners during the review process. Supplements manager comments with broader organizational perspective.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Succession Readiness Level' ;
    rdfs:comment 'Assessment of the employees readiness for succession into higher-level roles. Used for talent management and succession planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Policy Acknowledgment Id' ;
    rdfs:comment 'Unique identifier for the policy acknowledgment record. Primary key for the policy acknowledgment transaction.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPolicyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Policy Employee Id' ;
    rdfs:comment 'Reference to the employee who is acknowledging the policy. Links to the employee master record.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryPolicyRevokedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Policy Revoked By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically HR administrator or compliance officer) who revoked the policy acknowledgment.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPolicyWitnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Policy Witness Employee Id' ;
    rdfs:comment 'Reference to an employee who witnessed the policy acknowledgment. Applicable for certain high-compliance policies requiring witnessed signatures.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforcePolicyId rdf:type rdf:Property ;
    rdfs:label 'Workforce Policy Id' ;
    rdfs:comment 'Reference to the workforce policy being acknowledged. Links to the policy master record.' ;
    rdfs:domain ind:People ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforcePolicy .

ind:acknowledgmentChannel rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Channel' ;
    rdfs:comment 'The channel or method through which the employee acknowledged the policy. Examples include HR self-service portal, email confirmation, paper signature, Learning Management System (LMS) completion, mobile application, or physical kiosk.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDeviceType rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Device Type' ;
    rdfs:comment 'The type of device used by the employee to submit the acknowledgment. Useful for understanding user experience and access patterns.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Ip Address' ;
    rdfs:comment 'The Internet Protocol (IP) address from which the employee submitted the policy acknowledgment. Captured for audit trail and security purposes.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentLocation rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Location' ;
    rdfs:comment 'The physical or logical location where the acknowledgment was captured. May be office location code, remote work indicator, or geographic region.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'The specific mechanism used to capture the acknowledgment. Distinguishes between electronic signature, checkbox acceptance, biometric verification, wet signature on paper, verbal confirmation, or system-automated acknowledgment.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Number' ;
    rdfs:comment 'Human-readable unique reference number for this policy acknowledgment transaction, used for tracking and audit purposes.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current status of the policy acknowledgment in its lifecycle. Tracks whether the employee has completed, is pending, or is overdue on the acknowledgment requirement.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'The precise date and time when the employee formally acknowledged the policy. This is the primary business event timestamp for compliance and audit purposes.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attestationText rdf:type rdf:Property ;
    rdfs:label 'Attestation Text' ;
    rdfs:comment 'The specific attestation statement or declaration text that the employee agreed to when acknowledging the policy. Captured for legal and audit purposes.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Code' ;
    rdfs:comment 'Code identifying the regulatory or compliance requirement that mandates this policy acknowledgment. Examples include SOX, GDPR, HIPAA, FCC regulations, or internal audit requirements.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureHash rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Hash' ;
    rdfs:comment 'Cryptographic hash of the digital signature applied to the policy acknowledgment. Used to verify authenticity and integrity of the acknowledgment.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Count' ;
    rdfs:comment 'The number of supporting documents or attachments associated with this policy acknowledgment record. May include signed forms, certificates, or evidence files.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exemption Approval Timestamp' ;
    rdfs:comment 'The date and time when the exemption was formally approved by the authorized approver.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Indicates whether the employee has been granted an exemption from acknowledging this policy. True if exempted, False otherwise.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Detailed explanation of why the employee was exempted from the policy acknowledgment requirement. Examples include role-based exemption, geographic jurisdiction exclusion, or temporary leave status.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Timestamp' ;
    rdfs:comment 'The date and time when the most recent reminder notification was sent to the employee.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextAcknowledgmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Acknowledgment Due Date' ;
    rdfs:comment 'The date when the employee will be required to re-acknowledge this policy. Applicable for policies requiring periodic re-acknowledgment such as annual compliance training or updated code of conduct.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'The business category or classification of the policy being acknowledged. Examples include code of conduct, information security, health and safety, data privacy, anti-harassment, or regulatory compliance.' ;
    rdfs:domain ind:People ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why a previously completed acknowledgment was revoked or invalidated. Examples include policy version superseded, employee role change, or data correction.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'The date and time when the policy acknowledgment was revoked or invalidated.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completion Flag' ;
    rdfs:comment 'Indicates whether the employee completed associated training before acknowledging the policy. True if training was completed, False otherwise.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Training Duration Minutes' ;
    rdfs:comment 'The total time in minutes that the employee spent completing the policy training module before acknowledgment.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingScore rdf:type rdf:Property ;
    rdfs:label 'Training Score' ;
    rdfs:comment 'The score achieved by the employee on any assessment or quiz associated with the policy training. Expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:witnessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Timestamp' ;
    rdfs:comment 'The date and time when the witness confirmed the policy acknowledgment.' ;
    rdfs:domain ind:PolicyAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPositionId rdf:type rdf:Property ;
    rdfs:label 'Reporting Position Id' ;
    rdfs:comment 'Reference to the manager position to which this position reports. Establishes the reporting hierarchy independent of individual employees. Null for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:budgetedFlag rdf:type rdf:Property ;
    rdfs:label 'Budgeted Flag' ;
    rdfs:comment 'Indicates whether the position is included in the approved headcount budget. True if budgeted and approved for funding, False if not budgeted or pending budget approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationReason rdf:type rdf:Property ;
    rdfs:label 'Creation Reason' ;
    rdfs:comment 'Business justification or reason for creating the position. Captures whether the position was created for new business needs, as a replacement, due to restructuring, expansion, regulatory requirements, or project needs.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPositionFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Position Flag' ;
    rdfs:comment 'Indicates whether the position is designated as business-critical or key to operations. True for positions where vacancy would significantly impact business continuity or service delivery.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'Classification of the position under Fair Labor Standards Act for overtime eligibility. Exempt positions are not eligible for overtime pay, non-exempt positions are eligible.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for the position. 1.00 represents a full-time position, 0.50 represents half-time, etc. Used for headcount planning and budgeting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position, typically used in HR systems and organizational charts. Unique alphanumeric code assigned to each approved headcount slot.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position\'s responsibilities, duties, and scope. Provides comprehensive overview of what the role entails independent of the incumbent.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Indicates whether the position is active and available, currently filled, vacant and open for recruitment, frozen (temporarily unavailable), eliminated, or pending approval.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Classification of the position based on employment duration and nature. Distinguishes between permanent headcount, fixed-term roles, contractor slots, and temporary positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Required Clearance Level' ;
    rdfs:comment 'Minimum security clearance or background check level required for the position. Relevant for positions with access to sensitive network infrastructure, customer data, or classified information.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualificationsSummary rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications Summary' ;
    rdfs:comment 'Summary of minimum required qualifications, certifications, education, and experience for the position. Used for recruitment and succession planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spanOfControl rdf:type rdf:Property ;
    rdfs:label 'Span Of Control' ;
    rdfs:comment 'Number of direct report positions that report to this position. Used for organizational design and management capacity planning. Zero for non-supervisory positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successionPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Flag' ;
    rdfs:comment 'Indicates whether a formal succession plan exists for this position. True if succession planning is active, False otherwise. Typically True for critical and leadership positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Flag' ;
    rdfs:comment 'Indicates whether the position has supervisory or management responsibilities. True if the position manages direct reports, False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Union Eligible Flag' ;
    rdfs:comment 'Indicates whether the position is eligible for union membership or covered by collective bargaining agreements. Relevant for labor relations and compliance.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workArrangement rdf:type rdf:Property ;
    rdfs:label 'Work Arrangement' ;
    rdfs:comment 'Standard work arrangement or location flexibility for the position. Indicates whether the role is on-site, fully remote, hybrid, field-based, or mobile.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRecruitmentHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee record of the hiring manager who will supervise the new hire and is responsible for candidate selection decisions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRecruitmentReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Recruitment Replacement Employee Id' ;
    rdfs:comment 'Reference to the employee record being replaced, if this is a backfill or replacement requisition. Null for new headcount positions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRecruitmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee record of the manager or executive who provided final approval for this requisition. Null if not yet approved.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Reference' ;
    rdfs:comment 'Reference number or identifier for the budget approval document or Capital Expenditure (CAPEX)/Operational Expenditure (OPEX) authorization that funds this position.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityHiringInitiativeFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Hiring Initiative Flag' ;
    rdfs:comment 'Indicates whether this requisition is part of a diversity, equity, and inclusion (DEI) hiring initiative. True if special diversity sourcing applies.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalPostingOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Posting Only Flag' ;
    rdfs:comment 'Indicates whether the requisition is restricted to internal candidates only. True if external candidates are not eligible, false if open to all applicants.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business justification narrative explaining why this position is needed, including impact on operations, strategic alignment, and expected Return on Investment (ROI).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'Quantity of positions to be filled under this single requisition. Typically 1, but may be higher for bulk hiring initiatives or multiple identical roles.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingEndDate rdf:type rdf:Property ;
    rdfs:label 'Posting End Date' ;
    rdfs:comment 'Date when the job posting will be or was removed from recruitment channels. Null if posting remains open indefinitely.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStartDate rdf:type rdf:Property ;
    rdfs:label 'Posting Start Date' ;
    rdfs:comment 'Date when the job posting was or will be published to internal and external recruitment channels. Marks the beginning of active candidate sourcing.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date when the requisition was formally closed, either due to successful fill, cancellation, or other resolution. Null if still open.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNotes rdf:type rdf:Property ;
    rdfs:label 'Requisition Notes' ;
    rdfs:comment 'Free-text field for additional comments, special instructions, or context relevant to the recruitment process. Used for internal coordination.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Human-readable business identifier for the job requisition, typically formatted as REQ-YYYYNNNN where YYYY is year and NNNN is sequence number. Used for external communication and tracking.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the requisition: draft (being prepared), pending_approval (awaiting management approval), approved (ready for sourcing), sourcing (actively recruiting), interviewing (candidates in interview process), offer_stage (offer extended), filled (position filled), cancelled (requisition withdrawn), on_hold (temporarily paused), or closed (process completed). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sourcing|interviewing|offer_stage|filled|cancelled|on_hold|closed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition purpose: backfill (replacing a departing employee), new_headcount (net new position), replacement (role restructure), internal_transfer (existing employee moving), contractor_conversion (converting contractor to FTE), or reorg (organizational restructuring).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual base salary for the position in the specified currency. Defines the upper bound for offer negotiations.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual base salary for the position in the specified currency. Used for budget planning and candidate expectation management.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the position requires government or corporate security clearance. True if clearance is mandatory, false otherwise.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of recruitment channels activated for this requisition (e.g., internal_job_board, linkedin, agency, campus, employee_referral, job_fair, social_media). Tracks where candidates are being sourced from.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired date for the new hire to begin employment. Used for workforce planning and recruitment timeline management.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillTargetDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Target Days' ;
    rdfs:comment 'Target number of calendar days from requisition approval to offer acceptance. Used as a Key Performance Indicator (KPI) for recruitment efficiency and workforce planning.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:separationEventId rdf:type rdf:Property ;
    rdfs:label 'Separation Event Id' ;
    rdfs:comment 'Unique identifier for the employee separation event record. Primary key for the separation event entity.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySeparationInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Separation Initiated By Employee Id' ;
    rdfs:comment 'Reference to the employee or manager who initiated the separation process.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySeparationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Separation Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or HR leader who approved the separation.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Access Revocation Date' ;
    rdfs:comment 'The date on which all system access, credentials, and physical access rights were revoked for the separating employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Date' ;
    rdfs:comment 'The date on which all company equipment and assets were returned by the employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Status' ;
    rdfs:comment 'Status of the return of company-issued equipment and assets by the separating employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Conducted Flag' ;
    rdfs:comment 'Indicates whether an exit interview was conducted with the departing employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'The date on which the exit interview was conducted with the separating employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewKeyThemes rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Key Themes' ;
    rdfs:comment 'Summary of the primary themes and feedback points raised during the exit interview, used for organizational improvement.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewSentiment rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Sentiment' ;
    rdfs:comment 'Overall sentiment classification derived from the exit interview feedback, used for retention analytics.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Amount' ;
    rdfs:comment 'Total monetary amount paid to the employee as part of the final settlement, including unused leave, severance, and other entitlements.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalSettlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the final settlement amount.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalSettlementPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Payment Date' ;
    rdfs:comment 'The date on which the final settlement payment was processed and paid to the employee.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knowledgeTransferCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Knowledge Transfer Completed Flag' ;
    rdfs:comment 'Indicates whether the employee completed required knowledge transfer activities before separation.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastWorkingDay rdf:type rdf:Property ;
    rdfs:label 'Last Working Day' ;
    rdfs:comment 'The final date the employee is expected to perform work duties before separation becomes effective.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodServedDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Served Days' ;
    rdfs:comment 'The actual number of days the employee worked during the notice period before separation.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticePeriodWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Notice Period Waived Flag' ;
    rdfs:comment 'Indicates whether the organization waived the requirement for the employee to serve the full notice period.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Notice Waiver Reason' ;
    rdfs:comment 'Explanation for why the notice period was waived, if applicable.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingChecklistCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Offboarding Checklist Completed Flag' ;
    rdfs:comment 'Indicates whether all required offboarding tasks and checklist items have been completed.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Offboarding Completion Date' ;
    rdfs:comment 'The date on which all offboarding activities were completed and the separation case was closed.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regrettableLossFlag rdf:type rdf:Property ;
    rdfs:label 'Regrettable Loss Flag' ;
    rdfs:comment 'Indicates whether the organization considers this separation a regrettable loss of talent, used for retention strategy analysis.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility Reason' ;
    rdfs:comment 'Explanation for the rehire eligibility determination, particularly important when employee is marked as not eligible for rehire.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resignationLetterReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Resignation Letter Received Date' ;
    rdfs:comment 'The date on which the employee\'s resignation letter or notice was officially received by the organization, applicable for voluntary separations.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Separation Effective Date' ;
    rdfs:comment 'The official date when the employment relationship is terminated and the employee is no longer on the organization\'s payroll.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Initiation Date' ;
    rdfs:comment 'The date when the separation process was formally initiated, either by employee resignation submission or management termination decision.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:separationNumber rdf:type rdf:Property ;
    rdfs:label 'Separation Number' ;
    rdfs:comment 'Business-facing unique reference number for the separation event, used for tracking and communication purposes.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Separation Reason Code' ;
    rdfs:comment 'Standardized code representing the specific reason for separation, aligned with HR policy and regulatory reporting requirements. [ENUM-REF-CANDIDATE: voluntary_resignation|involuntary_performance|involuntary_misconduct|mutual_agreement|position_elimination|retirement_age|retirement_early|contract_expiration|relocation|health_reasons|career_change|better_opportunity|family_reasons|return_to_education|death|abandonment|other — promote to reference product]' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationStatus rdf:type rdf:Property ;
    rdfs:label 'Separation Status' ;
    rdfs:comment 'Current workflow status of the separation event, tracking progress through the offboarding process.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationType rdf:type rdf:Property ;
    rdfs:label 'Separation Type' ;
    rdfs:comment 'Classification of the separation event indicating the nature of the employee\'s departure from the organization.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severanceAmount rdf:type rdf:Property ;
    rdfs:label 'Severance Amount' ;
    rdfs:comment 'Monetary amount paid as severance compensation, separate from other final settlement components.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenureYears rdf:type rdf:Property ;
    rdfs:label 'Tenure Years' ;
    rdfs:comment 'Total years of service with the organization at the time of separation, used for retention and turnover analytics.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unusedLeaveDays rdf:type rdf:Property ;
    rdfs:label 'Unused Leave Days' ;
    rdfs:comment 'Number of accrued leave days that were unused at the time of separation and included in final settlement.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unusedLeavePayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Unused Leave Payout Amount' ;
    rdfs:comment 'Monetary value of accrued but unused leave entitlements paid out at separation.' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voluntaryFlag rdf:type rdf:Property ;
    rdfs:label 'Voluntary Flag' ;
    rdfs:comment 'Indicates whether the separation was initiated by the employee (voluntary) or by the organization (involuntary).' ;
    rdfs:domain ind:SeparationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryWorkforceApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the individual who formally approved this policy version for publication and enforcement.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededPolicyWorkforcePolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Workforce Policy Id' ;
    rdfs:comment 'Identifier of the previous policy version that this policy replaces, enabling policy version lineage tracking.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforcePolicy .

ind:acknowledgmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Frequency' ;
    rdfs:comment 'Frequency at which employees must re-acknowledge the policy to maintain compliance and awareness.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Unit' ;
    rdfs:comment 'Business unit or division to which this policy applies. Null indicates policy applies enterprise-wide.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableEmployeeType rdf:type rdf:Property ;
    rdfs:label 'Applicable Employee Type' ;
    rdfs:comment 'Employment category to which this policy applies, enabling targeted policy enforcement by workforce segment.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGeography rdf:type rdf:Property ;
    rdfs:label 'Applicable Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the geographic jurisdiction where this policy applies. Null indicates global applicability.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Primary method used to communicate this policy to employees, ensuring awareness and accessibility.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Process Description' ;
    rdfs:comment 'Description of the process for requesting and approving exceptions to this policy when special circumstances warrant deviation.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether employees are required to formally acknowledge receipt and understanding of this policy.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'Web address or document management system link to the full policy document for employee access and reference.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyLanguage rdf:type rdf:Property ;
    rdfs:label 'Policy Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which this policy version is published.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Department' ;
    rdfs:comment 'Department responsible for authoring, maintaining, and enforcing this policy. [ENUM-REF-CANDIDATE: hr|legal|compliance|it|finance|operations|security — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyTitle rdf:type rdf:Property ;
    rdfs:label 'Policy Title' ;
    rdfs:comment 'Official title of the workforce policy as published in the employee handbook or policy repository.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyIds rdf:type rdf:Property ;
    rdfs:label 'Related Policy Ids' ;
    rdfs:comment 'Comma-separated list of workforce policy IDs that are related or cross-referenced by this policy for comprehensive policy navigation.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Code of the training course associated with this policy, enabling linkage to learning management systems.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether formal training is required for employees to understand and comply with this policy.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationConsequence rdf:type rdf:Property ;
    rdfs:label 'Violation Consequence' ;
    rdfs:comment 'Summary of potential consequences for policy violations, ranging from verbal warning to termination, providing clarity on enforcement.' ;
    rdfs:domain ind:WorkforcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatusId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status Id' ;
    rdfs:comment 'Foreign key linking to product.lifecycle_status. Business justification: Addon lifecycle (active, deprecated, end-of-sale) must reference lifecycle_status.lifecycle_status_id for consistent status management. Current addon_status STRING should be replaced with FK.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LifecycleStatus .

ind:productManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Product managers create and manage addon offerings (international roaming packs, data boosters, content subscriptions) in telecommunications - accountable for addon portfolio performance, attach rates' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activationMethod rdf:type rdf:Property ;
    rdfs:label 'Activation Method' ;
    rdfs:comment 'Method by which the add-on is activated on the customer subscription. Instant: immediate activation; Scheduled: activation at specified date/time; Manual approval: requires CSR or system approval; Provisioning required: requires network provisioning workflow.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonCategory rdf:type rdf:Property ;
    rdfs:label 'Addon Category' ;
    rdfs:comment 'Classification of the add-on product type. Determines the functional category and business rules applicable to the add-on. [ENUM-REF-CANDIDATE: data_topup|voice_pack|sms_pack|international_calling|roaming|premium_content|cloud_storage|security|static_ip|device_insurance — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonCode rdf:type rdf:Property ;
    rdfs:label 'Addon Code' ;
    rdfs:comment 'Unique business identifier code for the add-on product used in product catalog and billing systems. Examples: DATA_5GB, INTL_CALL_100, PREMIUM_SPORTS.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonDescription rdf:type rdf:Property ;
    rdfs:label 'Addon Description' ;
    rdfs:comment 'Detailed business description of the add-on product, including features, benefits, and usage terms. Used for customer-facing documentation and sales materials.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonName rdf:type rdf:Property ;
    rdfs:label 'Addon Name' ;
    rdfs:comment 'Human-readable name of the add-on product displayed to customers and in product catalogs.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonType rdf:type rdf:Property ;
    rdfs:label 'Addon Type' ;
    rdfs:comment 'Billing model type for the add-on. One-time: single charge; Recurring: periodic subscription; Usage-based: pay-per-use; Hybrid: combination of recurring and usage.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which the add-on charge is billed to the customer. Applicable for recurring and usage-based add-ons. One-time add-ons are billed once at activation. [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|annually|usage_triggered — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Comma-separated list of sales and service channels through which the add-on can be purchased or activated. Examples: web, mobile_app, retail_store, call_center, partner_portal. [ENUM-REF-CANDIDATE: web|mobile_app|retail_store|call_center|partner_portal|self_service|agent_assisted|third_party — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationMethod rdf:type rdf:Property ;
    rdfs:label 'Deactivation Method' ;
    rdfs:comment 'Method by which the add-on is deactivated or removed from the customer subscription. Instant: immediate removal; End of period: deactivation at billing cycle end; Manual: requires CSR intervention; Grace period: deactivation after notice period.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalProductCode rdf:type rdf:Property ;
    rdfs:label 'External Product Code' ;
    rdfs:comment 'Identifier for the add-on product in external systems such as partner catalogs, wholesale platforms, or third-party marketplaces. Used for system integration and cross-reference.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQuantityPerSubscription rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Subscription' ;
    rdfs:comment 'Maximum number of instances of this add-on that can be attached to a single customer subscription. Null indicates no limit. Example: customer can purchase up to 5 data top-up add-ons per month.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minQuantityPerSubscription rdf:type rdf:Property ;
    rdfs:label 'Min Quantity Per Subscription' ;
    rdfs:comment 'Minimum number of instances of this add-on required when attached to a subscription. Typically 1 or null. Used for bundled add-ons with minimum purchase requirements.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Standard price amount for the add-on in the default currency. For recurring add-ons, this is the periodic charge amount. For one-time add-ons, this is the single purchase price.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'High-level product family or portfolio to which the add-on belongs. Examples: Mobile Services, Broadband Services, Enterprise Solutions, Digital Content, IoT Services. Used for product hierarchy and reporting.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed Flag' ;
    rdfs:comment 'Indicates whether the add-on charge is prorated when activated or deactivated mid-billing cycle. True: charge is prorated; False: full charge applies regardless of activation date.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaUnit rdf:type rdf:Property ;
    rdfs:label 'Quota Unit' ;
    rdfs:comment 'Unit of measure for the quota value. Defines what the quota_value represents. Examples: GB for data, minutes for voice, SMS for messaging, channels for IPTV. [ENUM-REF-CANDIDATE: GB|MB|minutes|SMS|channels|users|GB_storage|static_IP|incidents — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaValue rdf:type rdf:Property ;
    rdfs:label 'Quota Value' ;
    rdfs:comment 'Numeric value representing the allowance or quota provided by the add-on. Examples: 5 GB data, 100 international minutes, 500 SMS. Used in conjunction with quota_unit.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Accounting rule for revenue recognition of the add-on charges. Immediate: recognize at sale; Deferred: recognize over service period; Prorated: recognize proportionally; Usage-based: recognize as consumed.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Allowed Flag' ;
    rdfs:comment 'Indicates whether unused quota from the current period can roll over to the next period. True: unused quota carries forward; False: quota expires at period end.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Quality of Service (QoS) tier or Service Level Agreement (SLA) class associated with the add-on. Determines priority, support level, and performance guarantees.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief summary of the add-on product for display in mobile apps, web portals, and point-of-sale systems. Typically 1-2 sentences.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodUnit rdf:type rdf:Property ;
    rdfs:label 'Validity Period Unit' ;
    rdfs:comment 'Unit of time for the validity period. Examples: 30 days, 1 month, 1 year. Perpetual indicates no expiration.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Validity Period Value' ;
    rdfs:comment 'Numeric value representing the duration for which the add-on remains active after activation. Used in conjunction with validity_period_unit. Null for perpetual add-ons.' ;
    rdfs:domain ind:Addon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleCategory rdf:type rdf:Property ;
    rdfs:label 'Bundle Category' ;
    rdfs:comment 'Market segment classification for the bundle. Consumer bundles target residential customers. Business bundles serve SMB and enterprise. Wholesale bundles are for carrier-to-carrier. MVNO (Mobile Virtual Network Operator) bundles support virtual operators. IoT (Internet of Things) bundles serve connected devices. Roaming bundles provide international services.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bundle used in product catalog, ordering, and billing systems. Examples: TRIPLE_PLAY_GOLD, QUAD_PLAY_PREMIUM, MOBILE_FAMILY_PLUS.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed business description of the bundle including key features, benefits, target customer segment, and value proposition. Used for product catalog documentation and sales enablement.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable marketing name of the bundle displayed to customers and used in sales channels. Examples: Triple Play Gold, Quad Play Premium, Family Mobile Plus.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure. Fixed bundles have predefined components that cannot be changed. Flexible bundles allow customer selection from a set of options. Customizable bundles permit component substitution. Dynamic bundles adjust based on usage patterns. Promotional bundles are time-limited offers. Enterprise bundles are tailored for business customers.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Component Substitution Allowed' ;
    rdfs:comment 'Indicates whether customers can substitute bundle components with alternatives of equal or lesser value (True) or if the bundle composition is fixed (False). Used in order configuration and customization workflows.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataAllowanceGb rdf:type rdf:Property ;
    rdfs:label 'Data Allowance Gb' ;
    rdfs:comment 'Total data usage allowance included in the bundle measured in gigabytes. Applicable to mobile, broadband, and IoT bundles. Null for unlimited data bundles or bundles without data components. Used for usage tracking and overage billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Device Included Flag' ;
    rdfs:comment 'Indicates whether Customer Premises Equipment (CPE) or mobile devices are included in the bundle (True) or must be purchased separately (False). Examples: modem, router, Optical Network Terminal (ONT), smartphone, tablet.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Downgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can downgrade from this bundle to lower-tier offerings (True) or if downgrade restrictions apply (False). Used in churn prevention and customer retention strategies.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationFee rdf:type rdf:Property ;
    rdfs:label 'Installation Fee' ;
    rdfs:comment 'One-time charge for service installation, activation, and Customer Premises Equipment (CPE) setup. Null if installation is included at no charge. Used in order pricing and revenue recognition.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalRoamingIncluded rdf:type rdf:Property ;
    rdfs:label 'International Roaming Included' ;
    rdfs:comment 'Indicates whether international roaming services are included in the bundle at no additional charge (True) or require separate fees (False). Used for service provisioning and roaming partner settlement.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Component Count' ;
    rdfs:comment 'Maximum number of component products or services that can be included in the bundle. Null indicates no upper limit. Used for bundle configuration validation.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Component Count' ;
    rdfs:comment 'Minimum number of component products or services that must be included in the bundle for it to be valid. Used for bundle eligibility validation during order capture.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Quality of Service (QoS) tier and performance guarantees associated with this bundle. Standard is basic residential service. Premium offers enhanced support. Enterprise includes business-grade SLAs. Gold and Platinum are tiered service levels. Best effort has no guarantees. Defines uptime commitments, support response times, and performance thresholds.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsAllowance rdf:type rdf:Property ;
    rdfs:label 'Sms Allowance' ;
    rdfs:comment 'Total SMS text messages included in the bundle. Applicable to mobile bundles. Null for unlimited SMS bundles or bundles without SMS components. Used for usage tracking and overage billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether customers can upgrade from this bundle to higher-tier offerings without penalty (True) or if upgrade restrictions apply (False). Used in customer lifecycle management and upsell campaigns.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voiceMinutesAllowance rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes Allowance' ;
    rdfs:comment 'Total voice call minutes included in the bundle. Applicable to mobile and VoIP bundles. Null for unlimited voice bundles or bundles without voice components. Used for usage tracking and overage billing.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Catalog items must be classified within the hierarchical product taxonomy. Current STRING columns (product_category, product_subcategory) should be replaced with FK to product_category.product_categor' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:zeroRatingProgramId rdf:type rdf:Property ;
    rdfs:label 'Zero Rating Program Id' ;
    rdfs:comment 'Foreign key linking to product.zero_rating_program. Business justification: A catalog item can be associated with a zero-rating program; many catalog items may share the same program while each catalog item references at most one program. Adding catalog_item.zero_rating_progr' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ZeroRatingProgram .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard list price for the catalog item before discounts, promotions, or customer-specific adjustments. Currency is USD unless otherwise specified in enterprise configuration.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downloadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Download Speed Mbps' ;
    rdfs:comment 'Maximum or typical download throughput in Mbps for broadband and mobile data products. Key QoS parameter for customer expectations and SLA commitments.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBundled rdf:type rdf:Property ;
    rdfs:label 'Is Bundled' ;
    rdfs:comment 'Indicates whether this catalog item is a composite bundle containing multiple sub-products or services. True for triple-play, quad-play, and enterprise solution bundles.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandalone rdf:type rdf:Property ;
    rdfs:label 'Is Standalone' ;
    rdfs:comment 'Indicates whether this catalog item can be purchased independently or requires a base product. False for add-ons, value-added services, and device accessories.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the catalog item including features, benefits, and technical specifications. Used for customer-facing documentation and sales enablement.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDevice rdf:type rdf:Property ;
    rdfs:label 'Requires Device' ;
    rdfs:comment 'Indicates whether this catalog item requires customer premises equipment (CPE), SIM card, or device to function. True for mobile plans, IPTV services, and broadband requiring ONT/modem.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMttrHours rdf:type rdf:Property ;
    rdfs:label 'Sla Mttr Hours' ;
    rdfs:comment 'Maximum time in hours to restore service after a fault for enterprise products with SLA commitments. Null for consumer products. Drives NOC escalation procedures.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsEsim rdf:type rdf:Property ;
    rdfs:label 'Supports Esim' ;
    rdfs:comment 'Indicates whether mobile product supports eSIM provisioning for compatible devices. Enables remote SIM activation and multi-profile management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsMnp rdf:type rdf:Property ;
    rdfs:label 'Supports Mnp' ;
    rdfs:comment 'Indicates whether customers can port their existing phone number when subscribing to this mobile product. Drives MNP transaction workflows and regulatory compliance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRoaming rdf:type rdf:Property ;
    rdfs:label 'Supports Roaming' ;
    rdfs:comment 'Indicates whether mobile product includes international or domestic roaming capabilities. Affects CDR rating and interconnect settlement processing.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Upload Speed Mbps' ;
    rdfs:comment 'Maximum or typical upload throughput in Mbps for broadband and mobile data products. Critical for enterprise applications, video conferencing, and cloud services.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCompatibilityCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Compatibility Catalog Item Id' ;
    rdfs:comment 'Identifier of the product that is the subject of the compatibility rule. The product for which compatibility constraints are being defined.' ;
    rdfs:domain ind:CompatibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:targetProductCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Target Product Catalog Item Id' ;
    rdfs:comment 'Identifier of the product that is the object of the compatibility rule. The product that the source product has a compatibility relationship with.' ;
    rdfs:domain ind:CompatibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:technicalAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Technical analysts define product compatibility rules in telecommunications - responsible for device-plan compatibility, technology constraints (5G/4G), and bundle validation logic. Essential for orde' ;
    rdfs:domain ind:CompatibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:constraintOperator rdf:type rdf:Property ;
    rdfs:label 'Constraint Operator' ;
    rdfs:comment 'Operator used to evaluate the quantity constraint. Used in conjunction with quantity_constraint field. Example: greater_or_equal with quantity_constraint=2 means at least 2 units required.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Severity level for rule enforcement in order validation. Mandatory: order will be rejected if rule is violated. Warning: order proceeds with alert to user. Informational: rule displayed as guidance only.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Identifier of this compatibility rule in the source system of record. Used for cross-system reconciliation and integration with Netcracker Product Catalog and Oracle Communications OSM.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Category or family of products to which this rule applies. Examples: Mobile Plans, Broadband, IPTV, Devices, Enterprise Services. Used for rule filtering and catalog organization.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityConstraint rdf:type rdf:Property ;
    rdfs:label 'Quantity Constraint' ;
    rdfs:comment 'Minimum or maximum quantity constraint for the target product when the rule is applied. Example: A family plan requires at least 2 lines. Null indicates no quantity constraint.' ;
    rdfs:domain ind:CompatibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleDirection rdf:type rdf:Property ;
    rdfs:label 'Rule Direction' ;
    rdfs:comment 'Indicates whether the rule applies in one direction only (source to target) or both directions (mutual relationship). Unidirectional: A requires B does not imply B requires A. Bidirectional: A conflicts with B implies B conflicts with A.' ;
    rdfs:domain ind:CompatibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationScope rdf:type rdf:Property ;
    rdfs:label 'Validation Scope' ;
    rdfs:comment 'Scope at which the compatibility rule is evaluated. Order: rule applies within a single order. Subscription: rule applies across all products in a subscription. Account: rule applies across all subscriptions in an account. Customer: rule applies across all accounts for a customer.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryCapacityMah rdf:type rdf:Property ;
    rdfs:label 'Battery Capacity Mah' ;
    rdfs:comment 'Battery capacity in milliampere-hours (mAh) for portable devices. Null for powered CPE (Customer Premises Equipment) and network infrastructure devices.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorVariants rdf:type rdf:Property ;
    rdfs:label 'Color Variants' ;
    rdfs:comment 'Comma-separated list of available color options for the device model (e.g., Black, White, Blue, Titanium). Used for inventory management and customer selection.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCategory rdf:type rdf:Property ;
    rdfs:label 'Device Category' ;
    rdfs:comment 'Classification of the device type. CPE (Customer Premises Equipment) includes routers and modems; ONT (Optical Network Terminal) for FTTH (Fiber to the Home); OLT (Optical Line Terminal) for network infrastructure; STB (Set-Top Box) for IPTV (Internet Protocol Television) services. [ENUM-REF-CANDIDATE: smartphone|tablet|feature_phone|cpe_router|cpe_modem|ont|olt|stb|iot_device|wearable — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Device Subcategory' ;
    rdfs:comment 'Detailed subcategory within the device category for finer classification (e.g., flagship smartphone, budget smartphone, Wi-Fi 6 router, GPON ONT, 4K STB).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical dimensions of the device in millimeters, typically formatted as length x width x height (e.g., 146.7 x 71.5 x 7.8 mm). Used for packaging and display specifications.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the device model was discontinued from active sales. Null if still available. Used for inventory planning and customer migration strategies.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayResolution rdf:type rdf:Property ;
    rdfs:label 'Display Resolution' ;
    rdfs:comment 'Screen resolution in pixels (e.g., 1920x1080, 2560x1440, 3840x2160). Relevant for smartphones, tablets, and content consumption quality for IPTV and OTT services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySizeInches rdf:type rdf:Property ;
    rdfs:label 'Display Size Inches' ;
    rdfs:comment 'Screen diagonal size in inches for devices with displays (smartphones, tablets). Null for non-display devices like routers and ONT.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drmSupport rdf:type rdf:Property ;
    rdfs:label 'Drm Support' ;
    rdfs:comment 'Comma-separated list of supported DRM (Digital Rights Management) systems (e.g., Widevine, FairPlay, PlayReady). Required for premium content protection in OTT and IPTV services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualSimSupport rdf:type rdf:Property ;
    rdfs:label 'Dual Sim Support' ;
    rdfs:comment 'Indicates whether the device supports dual SIM functionality, allowing two active subscriptions simultaneously. Important for enterprise customers and international travelers.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esimCapable rdf:type rdf:Property ;
    rdfs:label 'Esim Capable' ;
    rdfs:comment 'Indicates whether the device supports eSIM (Embedded SIM) technology, enabling remote SIM provisioning without physical SIM card. Critical for digital service activation and MNP (Mobile Number Portability).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethernetPorts rdf:type rdf:Property ;
    rdfs:label 'Ethernet Ports' ;
    rdfs:comment 'Number of physical Ethernet ports available on CPE devices (routers, modems, ONT). Relevant for enterprise SD-WAN (Software-Defined Wide Area Network) and MPLS (Multiprotocol Label Switching) connectivity.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Enabled' ;
    rdfs:comment 'Indicates whether the device has GPS (Global Positioning System) or GNSS (Global Navigation Satellite System) capability. Used for location-based services and emergency services (E911).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imeiRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Imei Range End' ;
    rdfs:comment 'Ending IMEI number in the allocated range for this device model. Used with imei_range_start to validate device authenticity and prevent cloning.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imeiRangeStart rdf:type rdf:Property ;
    rdfs:label 'Imei Range Start' ;
    rdfs:comment 'Starting IMEI (International Mobile Equipment Identity) number in the allocated range for this device model. Used for device registration, activation, and fraud prevention in HLR (Home Location Register) and HSS (Home Subscriber Server).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfcEnabled rdf:type rdf:Property ;
    rdfs:label 'Nfc Enabled' ;
    rdfs:comment 'Indicates whether the device supports NFC (Near Field Communication) for contactless payments and data exchange. Relevant for mobile payment services and digital wallet integration.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system platform and version running on the device (e.g., iOS 17, Android 14, HarmonyOS, proprietary firmware). Impacts application compatibility and OTT (Over-The-Top) service delivery.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorChipset rdf:type rdf:Property ;
    rdfs:label 'Processor Chipset' ;
    rdfs:comment 'Processor or chipset model powering the device (e.g., Apple A17 Pro, Qualcomm Snapdragon 8 Gen 3, MediaTek Dimensity 9300). Indicates device performance tier.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ramCapacityGb rdf:type rdf:Property ;
    rdfs:label 'Ram Capacity Gb' ;
    rdfs:comment 'RAM memory capacity in gigabytes. Impacts device performance and ability to run advanced applications and services.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Manufacturer suggested retail price (MSRP) or standard retail price in the base currency. Used for pricing strategies, promotional offers, and revenue forecasting (ARPU - Average Revenue Per User calculations).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sarValue rdf:type rdf:Property ;
    rdfs:label 'Sar Value' ;
    rdfs:comment 'Specific Absorption Rate (SAR) value in watts per kilogram (W/kg), measuring radio frequency energy absorption. Required for regulatory compliance (FCC, ICNIRP guidelines) for mobile devices.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityGb rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Gb' ;
    rdfs:comment 'Internal storage capacity of the device in gigabytes. Relevant for smartphones, tablets, and STB (Set-Top Box) devices with local recording capability.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Internal code identifying the primary supplier or distributor for this device model. Used for procurement, inventory management, and supply chain tracking in ERP (Enterprise Resource Planning) systems.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacCode rdf:type rdf:Property ;
    rdfs:label 'Tac Code' ;
    rdfs:comment '8-digit Type Allocation Code forming the first 8 digits of the IMEI. Uniquely identifies the device model and manufacturer. Used by network systems for device identification and policy enforcement.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologySupport rdf:type rdf:Property ;
    rdfs:label 'Technology Support' ;
    rdfs:comment 'Comma-separated list of supported network technologies and standards (e.g., 4G LTE, 5G NR, VoLTE, Wi-Fi 6, Wi-Fi 6E, GPON, Bluetooth 5.2). Critical for network compatibility and service provisioning.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usbPorts rdf:type rdf:Property ;
    rdfs:label 'Usb Ports' ;
    rdfs:comment 'Number of USB ports available on the device. Used for charging, data transfer, and peripheral connectivity.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCodecSupport rdf:type rdf:Property ;
    rdfs:label 'Video Codec Support' ;
    rdfs:comment 'Comma-separated list of supported video codecs (e.g., H.264, H.265/HEVC, VP9, AV1). Essential for IPTV, OTT content delivery, and video call quality.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voipCapable rdf:type rdf:Property ;
    rdfs:label 'Voip Capable' ;
    rdfs:comment 'Indicates whether the device supports VoIP (Voice over Internet Protocol) functionality. Critical for IMS (IP Multimedia Subsystem) service delivery and VoLTE (Voice over LTE) compatibility.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterResistanceRating rdf:type rdf:Property ;
    rdfs:label 'Water Resistance Rating' ;
    rdfs:comment 'IP (Ingress Protection) rating for water and dust resistance (e.g., IP67, IP68). Indicates device durability and suitability for outdoor or harsh environments.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightGrams rdf:type rdf:Property ;
    rdfs:label 'Weight Grams' ;
    rdfs:comment 'Physical weight of the device in grams. Relevant for logistics, shipping cost calculation, and customer information.' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholesaleCost rdf:type rdf:Property ;
    rdfs:label 'Wholesale Cost' ;
    rdfs:comment 'Wholesale acquisition cost from manufacturer or distributor. Used for margin analysis, CAPEX (Capital Expenditure) planning, and profitability calculations (EBITDA - Earnings Before Interest Taxes Depreciation and Amortization).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wifiStandard rdf:type rdf:Property ;
    rdfs:label 'Wifi Standard' ;
    rdfs:comment 'Supported Wi-Fi standard (e.g., Wi-Fi 5 (802.11ac), Wi-Fi 6 (802.11ax), Wi-Fi 6E). Critical for CPE devices and home broadband service quality (QoS - Quality of Service).' ;
    rdfs:domain ind:DeviceModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessoryBundleId rdf:type rdf:Property ;
    rdfs:label 'Accessory Bundle Id' ;
    rdfs:comment 'Reference to a predefined accessory bundle (e.g., case, screen protector, charger) that can be included with this device offering. Null if no bundle defined.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:bundleEligible rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible' ;
    rdfs:comment 'Indicates whether this device offering can be bundled with other products or services (e.g., broadband, Internet Protocol Television - IPTV, accessories).' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial down payment required for installment plan or lease offerings. Null for outright purchase or fully subsidized offerings.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fullRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Full Retail Price' ;
    rdfs:comment 'Full retail price of the device without any subsidies, discounts, or installment plans. Represents the outright purchase price.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentTermMonths rdf:type rdf:Property ;
    rdfs:label 'Installment Term Months' ;
    rdfs:comment 'Duration of the Equipment Installment Plan (EIP) in months over which the device balance is financed. Common values: 12, 24, 30, 36 months. Null for non-installment offerings.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceEligible rdf:type rdf:Property ;
    rdfs:label 'Insurance Eligible' ;
    rdfs:comment 'Indicates whether device insurance or protection plans can be attached to this offering.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventorySku rdf:type rdf:Property ;
    rdfs:label 'Inventory Sku' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code used in inventory management systems to track physical device stock for this offering.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCreditScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Score' ;
    rdfs:comment 'Minimum credit score required to qualify for this device offering. Null if no credit requirement or credit check not required.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPlanArpu rdf:type rdf:Property ;
    rdfs:label 'Minimum Plan Arpu' ;
    rdfs:comment 'Minimum Average Revenue Per User (ARPU) threshold for the associated service plan required to qualify for this device offering, typically used for subsidized or promotional offerings.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyInstallmentAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Installment Amount' ;
    rdfs:comment 'Fixed monthly payment amount for installment plan offerings, calculated as (offering_price - down_payment) / installment_term_months. Null for non-installment offerings.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCompatibility rdf:type rdf:Property ;
    rdfs:label 'Network Compatibility' ;
    rdfs:comment 'Comma-separated list of network technologies supported by the device (e.g., \'5G NR,LTE,VoLTE,WiFi-6\'). Ensures device compatibility with network infrastructure.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringCode rdf:type rdf:Property ;
    rdfs:label 'Offering Code' ;
    rdfs:comment 'Unique business identifier code for the device offering used in product catalog and order management systems.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringName rdf:type rdf:Property ;
    rdfs:label 'Offering Name' ;
    rdfs:comment 'Commercial name of the device offering as presented to customers (e.g., \'iPhone 15 Pro 256GB - 24 Month Plan\').' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringPrice rdf:type rdf:Property ;
    rdfs:label 'Offering Price' ;
    rdfs:comment 'Actual price charged to the customer for this specific offering, which may differ from full retail price based on offering type (e.g., subsidized price, down payment for installment).' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringType rdf:type rdf:Property ;
    rdfs:label 'Offering Type' ;
    rdfs:comment 'Type of commercial device offering model: outright purchase (full payment upfront), installment plan (Equipment Installment Plan - EIP), subsidized with contract (device discount tied to service plan), lease (return device at end), or device-as-a-service (subscription model).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalOffering rdf:type rdf:Property ;
    rdfs:label 'Promotional Offering' ;
    rdfs:comment 'Indicates whether this is a limited-time promotional device offering with special pricing or terms.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated residual value of the device at the end of a lease term, representing the buyout price if customer chooses to purchase. Null for non-lease offerings.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee charged when a device is returned within the return period. Null if no restocking fee applies.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Return Period Days' ;
    rdfs:comment 'Number of days within which customer can return the device for a full refund, per consumer protection regulations and company policy.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Sim Type Required' ;
    rdfs:comment 'Type of Subscriber Identity Module (SIM) required or supported by this device offering: physical SIM card, embedded SIM (eSIM), dual SIM capability, or SIM-free (unlocked device).' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Subsidy Amount' ;
    rdfs:comment 'Amount of subsidy applied to reduce the device price, typically tied to a service contract commitment. Null for non-subsidized offerings.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInEligible rdf:type rdf:Property ;
    rdfs:label 'Trade In Eligible' ;
    rdfs:comment 'Indicates whether this device offering is eligible for trade-in programs where customers can exchange old devices for credit toward the new device.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unlockEligibilityDays rdf:type rdf:Property ;
    rdfs:label 'Unlock Eligibility Days' ;
    rdfs:comment 'Number of days after activation before the device becomes eligible for unlocking. Null if device is unlocked or unlock not applicable.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unlockEligible rdf:type rdf:Property ;
    rdfs:label 'Unlock Eligible' ;
    rdfs:comment 'Indicates whether the device can be unlocked for use on other carriers after contract obligations are met, per Federal Communications Commission (FCC) regulations.' ;
    rdfs:domain ind:DeviceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Business Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Business analysts define eligibility rules for product offerings in telco operations - responsible for credit class requirements, geographic restrictions, and customer segment targeting. Critical for ' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ruleGroupId rdf:type rdf:Property ;
    rdfs:label 'Rule Group Id' ;
    rdfs:comment 'Identifier for a logical grouping of related eligibility rules that are evaluated together as a unit. Enables complex nested rule logic where groups of rules can be combined with AND/OR operators at the group level. Supports advanced eligibility scenarios for enterprise Software-Defined Wide Area Network (SD-WAN), Multiprotocol Label Switching (MPLS), and wholesale offerings.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RuleGroup .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of sales and service channels where this eligibility rule applies. Examples include retail stores, online web portal, mobile app, telesales, partner channels, enterprise direct sales, Mobile Virtual Network Operator (MVNO) channels. Enables channel-specific eligibility logic for omnichannel product offerings.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverridable rdf:type rdf:Property ;
    rdfs:label 'Is Overridable' ;
    rdfs:comment 'Indicates whether authorized users (e.g., sales managers, retention specialists) can manually override this eligibility rule during order capture. Supports exception handling for high-value customers, retention scenarios, and special business cases while maintaining audit trail of overrides.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logicalOperator rdf:type rdf:Property ;
    rdfs:label 'Logical Operator' ;
    rdfs:comment 'Defines how this rule combines with other rules in the same eligibility rule set. AND requires all rules to be satisfied; OR requires at least one rule to be satisfied. Used to construct complex multi-condition eligibility expressions for bundled offerings, promotional campaigns, and segment-specific products.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authorization Level' ;
    rdfs:comment 'The minimum user role or authorization level required to override this eligibility rule. Enforces governance and controls around exception handling. Integrates with Customer Relationship Management (CRM) and Identity and Access Management (IAM) systems to validate user permissions during order capture.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleAttribute rdf:type rdf:Property ;
    rdfs:label 'Rule Attribute' ;
    rdfs:comment 'The specific customer, account, or context attribute that this rule evaluates. Examples include customer segment code, account type identifier, service address postal code, existing subscribed product identifier, credit score class, contract start date, device model identifier, network technology availability (Long-Term Evolution (LTE), 5G New Radio (5G NR)), customer age, or business employee count.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOperator rdf:type rdf:Property ;
    rdfs:label 'Rule Operator' ;
    rdfs:comment 'The logical comparison operator used to evaluate the rule condition. Determines how the rule value is compared against customer or account attributes during order capture and service provisioning workflows in Operations Support Systems (OSS) and Business Support Systems (BSS). [ENUM-REF-CANDIDATE: equals|not_equals|in|not_in|greater_than|less_than|greater_than_or_equal|less_than_or_equal|contains|not_contains|between — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSequence rdf:type rdf:Property ;
    rdfs:label 'Rule Sequence' ;
    rdfs:comment 'The execution order or priority of this rule within the eligibility rule set. Lower numbers are evaluated first. Determines the sequence in which rules are applied during product eligibility validation in order management and service activation workflows.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rule Source System' ;
    rdfs:comment 'The source system or module that originated or manages this eligibility rule. Examples include Netcracker Product Catalog, Salesforce CRM, Oracle Communications Order and Service Management (OSM), custom rule engine. Used for data lineage, troubleshooting, and system integration mapping.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleValue rdf:type rdf:Property ;
    rdfs:label 'Rule Value' ;
    rdfs:comment 'The target value or set of values against which the customer or account attribute is compared. May contain single values, comma-separated lists, numeric thresholds, geographic codes (ISO 3166-1 alpha-3), product codes, credit class identifiers, or tenure periods in months. Supports complex eligibility logic for multi-segment offerings.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByStatusLifecycleStatusId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Status Lifecycle Status Id' ;
    rdfs:comment 'Reference to the lifecycle status that replaces this status definition when it is retired. Null for active status definitions. Maintains historical lineage.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LifecycleStatus .

ind:allowedPredecessorStatuses rdf:type rdf:Property ;
    rdfs:label 'Allowed Predecessor Statuses' ;
    rdfs:comment 'Comma-separated list of lifecycle status codes from which products can transition into this status. Defines valid state transition rules in the product lifecycle state machine.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedSuccessorStatuses rdf:type rdf:Property ;
    rdfs:label 'Allowed Successor Statuses' ;
    rdfs:comment 'Comma-separated list of lifecycle status codes to which products can transition from this status. Defines valid forward state transitions in the product lifecycle state machine.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowsExistingCustomers rdf:type rdf:Property ;
    rdfs:label 'Allows Existing Customers' ;
    rdfs:comment 'Boolean flag indicating whether existing customers can continue to use and maintain products in this lifecycle status. Typically true even for end-of-sale products.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsNewCustomers rdf:type rdf:Property ;
    rdfs:label 'Allows New Customers' ;
    rdfs:comment 'Boolean flag indicating whether new customers can acquire products in this lifecycle status. False for end-of-sale statuses where only existing customers can maintain service.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Organizational level required to approve transition to this lifecycle status. Higher-risk transitions (e.g., end-of-life) require senior authority.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering value used to control the display sequence of lifecycle statuses in user interfaces, reports, and dropdown lists. Lower values appear first.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalStatusCode rdf:type rdf:Property ;
    rdfs:label 'External Status Code' ;
    rdfs:comment 'Status code used in external systems or partner integrations that maps to this internal lifecycle status. Supports cross-system status synchronization and API integration.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveStatus rdf:type rdf:Property ;
    rdfs:label 'Is Active Status' ;
    rdfs:comment 'Boolean flag indicating whether this lifecycle status represents an active, sellable state. True for statuses where products can be actively marketed and sold to customers.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDowngradeable rdf:type rdf:Property ;
    rdfs:label 'Is Downgradeable' ;
    rdfs:comment 'Boolean flag indicating whether customers can downgrade from products in this lifecycle status to lower-tier offerings. Controls product migration and retention workflows.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Boolean flag indicating whether products in this lifecycle status can be ordered by customers through sales channels. Controls order capture and fulfillment system behavior.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProvisionable rdf:type rdf:Property ;
    rdfs:label 'Is Provisionable' ;
    rdfs:comment 'Boolean flag indicating whether products in this lifecycle status can be provisioned and activated in network and service delivery systems. Controls service fulfillment workflows.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRenewable rdf:type rdf:Property ;
    rdfs:label 'Is Renewable' ;
    rdfs:comment 'Boolean flag indicating whether existing subscriptions for products in this lifecycle status can be renewed at contract expiration. Controls retention and renewal workflows.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Is System Status' ;
    rdfs:comment 'Boolean flag indicating whether this lifecycle status is system-defined and cannot be modified or deleted by users. True for core statuses required by platform logic.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUpgradeable rdf:type rdf:Property ;
    rdfs:label 'Is Upgradeable' ;
    rdfs:comment 'Boolean flag indicating whether customers with products in this lifecycle status can upgrade to newer offerings. Controls product migration and upsell workflows.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:migrationDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Migration Deadline Days' ;
    rdfs:comment 'Number of days from status transition date by which customers must migrate to alternative products. Null if no migration deadline applies. Used for end-of-life planning.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Days' ;
    rdfs:comment 'Minimum number of days advance notice required before transitioning products to this lifecycle status. Null if no notification required. Ensures regulatory compliance.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether customers must be notified when their product transitions to this lifecycle status. True for end-of-sale and end-of-life statuses.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresMigration rdf:type rdf:Property ;
    rdfs:label 'Requires Migration' ;
    rdfs:comment 'Boolean flag indicating whether customers must be migrated off products in this lifecycle status by a specific date. True for end-of-life statuses requiring mandatory customer transitions.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusCategory rdf:type rdf:Property ;
    rdfs:label 'Status Category' ;
    rdfs:comment 'High-level grouping of lifecycle statuses into major phases: pre-launch (concept, design, testing), active (available for sale), sunset (end-of-sale, end-of-life), retired (no longer supported).' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the lifecycle status within the product catalog system. Used as a business key for system integration and API references.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusDescription rdf:type rdf:Property ;
    rdfs:label 'Status Description' ;
    rdfs:comment 'Detailed explanation of what the lifecycle status represents, including business implications, operational constraints, and typical use cases within the product catalog.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusName rdf:type rdf:Property ;
    rdfs:label 'Status Name' ;
    rdfs:comment 'Human-readable name of the product lifecycle status. Displayed in user interfaces and reports to indicate the current state of a product offering in its lifecycle.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusVersion rdf:type rdf:Property ;
    rdfs:label 'Status Version' ;
    rdfs:comment 'Version number of this lifecycle status definition. Incremented when status rules, transitions, or attributes are modified. Supports change tracking and audit.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsBilling rdf:type rdf:Property ;
    rdfs:label 'Supports Billing' ;
    rdfs:comment 'Boolean flag indicating whether products in this lifecycle status continue to generate billing charges and invoices. False for retired products with no ongoing billing.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsUsageRating rdf:type rdf:Property ;
    rdfs:label 'Supports Usage Rating' ;
    rdfs:comment 'Boolean flag indicating whether usage events for products in this lifecycle status are rated and charged. Controls Call Detail Record (CDR) processing and usage-based billing.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visibleInCatalog rdf:type rdf:Property ;
    rdfs:label 'Visible In Catalog' ;
    rdfs:comment 'Boolean flag indicating whether products in this lifecycle status are visible in customer-facing product catalogs and self-service portals. False for internal-only or retired products.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visibleInChannel rdf:type rdf:Property ;
    rdfs:label 'Visible In Channel' ;
    rdfs:comment 'Comma-separated list of sales channels where products in this lifecycle status are visible and available for sale. Examples: web, mobile, retail, telesales, partner. Empty if not visible in any channel.' ;
    rdfs:domain ind:LifecycleStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Offering Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this offering for market launch. Nullable if offering is not yet approved. Used for governance and audit compliance.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:offeringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Offering Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for this offering\'s lifecycle, pricing strategy, and market performance. Used for accountability and product portfolio management.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseMonthlyPrice rdf:type rdf:Property ;
    rdfs:label 'Base Monthly Price' ;
    rdfs:comment 'Standard monthly recurring charge for this offering before discounts, promotions, or usage charges. Used for MRR forecasting and ARPU calculations. Nullable for one-time or usage-based offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Flag' ;
    rdfs:comment 'Indicates whether this offering is a bundle combining multiple catalog items or services. True = bundle offering, False = standalone offering. Bundles may include discounts vs. individual component pricing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic positioning statement describing how this offering compares to competitor products in the market. Used for sales enablement and marketing strategy. Business-confidential information.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentEntitlements rdf:type rdf:Property ;
    rdfs:label 'Content Entitlements' ;
    rdfs:comment 'Comma-separated list of included content packages, streaming services, or IPTV/OTT subscriptions bundled with this offering (e.g., premium_sports, hd_channels, streaming_music). Drives content provisioning and DRM policy application.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Credit Class Eligibility' ;
    rdfs:comment 'Minimum credit class required for customer eligibility. Drives deposit requirements, payment terms, and risk-based pricing. All = no credit restrictions.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rules Summary' ;
    rdfs:comment 'High-level summary of customer eligibility criteria for this offering (e.g., credit score requirements, existing customer status, device compatibility, service address qualification). Detailed rules managed in policy engine.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etfStructure rdf:type rdf:Property ;
    rdfs:label 'Etf Structure' ;
    rdfs:comment 'Structure of the Early Termination Fee applied when a customer cancels before contract term completion. Flat = fixed amount, Prorated = decreases over time, Tiered = varies by remaining term, None = no ETF.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoResellerFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Reseller Flag' ;
    rdfs:comment 'Indicates whether this offering is available for resale through MVNO partners. True = MVNO reseller enabled, False = direct sales only. Drives wholesale pricing and interconnect billing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsTargetScore rdf:type rdf:Property ;
    rdfs:label 'Nps Target Score' ;
    rdfs:comment 'Target Net Promoter Score for customer satisfaction tracking specific to this offering. Used for product performance monitoring and churn prediction. Nullable if no specific NPS target is set.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offeringCategory rdf:type rdf:Property ;
    rdfs:label 'Offering Category' ;
    rdfs:comment 'Market segment classification indicating the target customer base for this offering. Drives channel strategy and pricing models.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringDescription rdf:type rdf:Property ;
    rdfs:label 'Offering Description' ;
    rdfs:comment 'Detailed description of the offering including key features, benefits, and value proposition for customer-facing and internal reference.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oneTimeActivationFee rdf:type rdf:Property ;
    rdfs:label 'One Time Activation Fee' ;
    rdfs:comment 'Non-recurring charge applied at service activation or order fulfillment. Includes setup, installation, or provisioning fees. Nullable if no activation fee applies.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Included Flag' ;
    rdfs:comment 'Indicates whether international or domestic roaming is included in the offering without additional charges. True = roaming included, False = roaming charged separately. Applicable to mobile offerings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByAlterationPriceAlterationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Alteration Price Alteration Id' ;
    rdfs:comment 'Reference to the newer price alteration that replaces this one. Used to maintain version history and migration paths. Null if this is the current version.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAlteration .

ind:alterationCategory rdf:type rdf:Property ;
    rdfs:label 'Alteration Category' ;
    rdfs:comment 'Business category of the alteration defining its purpose: promotional (marketing campaigns), loyalty (customer retention rewards), volume (usage-based discounts), bundle (package discounts), regulatory (mandated charges), tax (government levies), penalty (contract breach fees), early termination (cancellation fees), late payment (overdue charges), seasonal (time-based offers). [ENUM-REF-CANDIDATE: promotional|loyalty|volume|bundle|regulatory|tax|penalty|early_termination|late_payment|seasonal — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationCode rdf:type rdf:Property ;
    rdfs:label 'Alteration Code' ;
    rdfs:comment 'Unique business identifier code for the price alteration rule, used for external reference and integration with billing systems.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationDescription rdf:type rdf:Property ;
    rdfs:label 'Alteration Description' ;
    rdfs:comment 'Detailed description of the price alteration, including business purpose, eligibility criteria, and application logic.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationName rdf:type rdf:Property ;
    rdfs:label 'Alteration Name' ;
    rdfs:comment 'Human-readable name of the price alteration rule, such as \'Holiday Promotion 2024\' or \'Volume Discount Tier 3\'.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationType rdf:type rdf:Property ;
    rdfs:label 'Alteration Type' ;
    rdfs:comment 'Classification of the price alteration indicating whether it reduces, increases, or modifies the base price. Discount reduces price, surcharge increases price, rebate provides post-payment credit, waiver eliminates a charge, adjustment modifies for specific conditions, credit applies account credit.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationValue rdf:type rdf:Property ;
    rdfs:label 'Alteration Value' ;
    rdfs:comment 'Numeric value of the price alteration. For percentage type, represents the percentage (e.g., 15.00 for 15%). For absolute type, represents the fixed amount in the currency of the price plan. For tiered and formula types, may represent a base value or multiplier.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationScope rdf:type rdf:Property ;
    rdfs:label 'Application Scope' ;
    rdfs:comment 'Defines the level at which the alteration is applied: account (entire customer account), subscription (specific subscription), service (individual service instance), usage (per usage event), invoice (entire invoice).' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSequence rdf:type rdf:Property ;
    rdfs:label 'Application Sequence' ;
    rdfs:comment 'Order in which this alteration is applied when multiple alterations exist on the same price plan. Lower numbers are applied first. Critical for calculating compound discounts and surcharges correctly.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargeTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Charge Type Filter' ;
    rdfs:comment 'Comma-separated list of charge types to which this alteration applies (e.g., \'recurring,usage,activation\'). Null means applies to all charge types. Used to restrict alterations to specific billing components.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentFilter rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Filter' ;
    rdfs:comment 'Comma-separated list of customer segments eligible for this alteration (e.g., \'enterprise,government,education\'). Null means applies to all segments. Enables segment-specific pricing strategies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAlterationAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Alteration Amount' ;
    rdfs:comment 'Maximum monetary value that the alteration can apply, capping the discount or surcharge. Null if no maximum applies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAlterationAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Alteration Amount' ;
    rdfs:comment 'Minimum monetary value that the alteration can apply, ensuring discounts or surcharges meet a floor threshold. Null if no minimum applies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Optional promotional code that customers must provide to activate this alteration. Used for targeted marketing campaigns and partner offers. Null if no code is required.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'For recurring alterations, specifies the frequency of application. Null for non-recurring alterations.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Service Type Filter' ;
    rdfs:comment 'Comma-separated list of service types to which this alteration applies (e.g., \'mobile,broadband,iptv\'). Null means applies to all service types. Enables service-specific pricing modifications.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingRule rdf:type rdf:Property ;
    rdfs:label 'Stacking Rule' ;
    rdfs:comment 'Defines whether this alteration can be combined with other alterations: stackable (can combine with others), exclusive (cannot combine, only one applies), conditional (can combine only with specific alterations based on business rules).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureRequirementMonths rdf:type rdf:Property ;
    rdfs:label 'Tenure Requirement Months' ;
    rdfs:comment 'Minimum number of months a customer must have been active to qualify for this alteration. Used for loyalty discounts. Null if no tenure requirement applies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Usage Threshold Quantity' ;
    rdfs:comment 'Minimum usage quantity required to trigger this alteration. Used for volume discounts and tiered pricing. Null if no usage threshold applies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Threshold Unit' ;
    rdfs:comment 'Unit of measure for the usage threshold quantity (e.g., minutes for voice, gigabytes for data). Null if no usage threshold applies.' ;
    rdfs:domain ind:PriceAlteration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueType rdf:type rdf:Property ;
    rdfs:label 'Value Type' ;
    rdfs:comment 'Defines how the alteration value is calculated: percentage (percent of base price), absolute (fixed amount), tiered (varies by usage/volume bands), formula (complex calculation based on multiple factors).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pricing Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Pricing analysts create and maintain price plans in telecommunications - essential for pricing governance, audit trails, and revenue assurance. Tracks who designed tiered pricing structures, overage r' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByPricePlanId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price Plan Id' ;
    rdfs:comment 'Reference to the price plan that replaces this plan when it is retired or obsoleted. Null if no replacement plan exists. Supports migration path tracking.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricePlan .

ind:advancePaymentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Required Flag' ;
    rdfs:comment 'Indicates whether payment must be collected in advance before service activation (true) or billed in arrears after service delivery (false). Common for prepaid vs postpaid models.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'The base price amount for this price plan before any discounts, surcharges, or taxes. For flat rate plans this is the fixed charge; for tiered/volume plans this is the starting tier price.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligible Flag' ;
    rdfs:comment 'Indicates whether this price plan can be included in product bundles or multi-service packages (true) or must be purchased standalone (false).' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedQuantity rdf:type rdf:Property ;
    rdfs:label 'Included Quantity' ;
    rdfs:comment 'The quantity of units included in the base price before overage charges apply. For example, 50GB of data included in a mobile plan. Null if plan does not include a bundled quantity.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum charge cap for this price plan within the billing period. Charges will not exceed this amount even if usage or events would normally result in higher charges. Null if no cap applies.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRate rdf:type rdf:Property ;
    rdfs:label 'Overage Rate' ;
    rdfs:comment 'The per-unit charge applied when usage exceeds the included quantity. For example, $0.10 per GB over the included data allowance. Null if no overage charges apply.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePlanCode rdf:type rdf:Property ;
    rdfs:label 'Price Plan Code' ;
    rdfs:comment 'External business identifier for the price plan used in product catalogs and billing systems. Unique code assigned by product management.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePlanDescription rdf:type rdf:Property ;
    rdfs:label 'Price Plan Description' ;
    rdfs:comment 'Detailed description of the price plan including what it covers, applicable services, and any special conditions or restrictions.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePlanName rdf:type rdf:Property ;
    rdfs:label 'Price Plan Name' ;
    rdfs:comment 'Human-readable name of the price plan displayed to customers and used in marketing materials.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModelType rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Type' ;
    rdfs:comment 'The pricing structure model applied to this plan. Flat rate for fixed charges, tiered for step-based pricing, volume-based for quantity discounts, usage-based for consumption charges, event-based for transaction charges, or hybrid for combinations.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationPolicy rdf:type rdf:Property ;
    rdfs:label 'Proration Policy' ;
    rdfs:comment 'Policy for prorating charges when service starts or ends mid-billing cycle. Full period charges the entire amount, daily proration calculates based on days used, no proration means no refund or partial charge, custom follows specific business rules.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingGroup rdf:type rdf:Property ;
    rdfs:label 'Rating Group' ;
    rdfs:comment 'Classification group used by the rating engine to apply appropriate charging rules and tariffs. Used in real-time charging systems for CDR (Call Detail Record) processing and usage rating.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the base price amount includes taxes (true) or taxes are added on top (false). Critical for pricing display and billing calculation.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tieredPricingStructure rdf:type rdf:Property ;
    rdfs:label 'Tiered Pricing Structure' ;
    rdfs:comment 'JSON or structured text defining the tier breakpoints and rates for tiered pricing models. Specifies quantity ranges and corresponding unit prices for each tier. Null for non-tiered plans.' ;
    rdfs:domain ind:PricePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchical taxonomy. Null for top-level categories (Mobile, Broadband, TV, Enterprise).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique business identifier code for the product category used in catalog systems and reporting. Examples: MOB_POSTPAID, BB_FIBER, IPTV_PREMIUM, ENT_SDWAN.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the product category including its purpose, scope, and the types of products it contains.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the product category displayed in catalogs and user interfaces. Examples: Mobile Postpaid, Fiber Broadband, IPTV Premium, Enterprise SD-WAN.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Market segment classification for the category indicating the target customer base.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL path to the icon or image asset representing this category in digital channels and user interfaces.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundleable rdf:type rdf:Property ;
    rdfs:label 'Is Bundleable' ;
    rdfs:comment 'Indicates whether products in this category can be included in bundle offerings with products from other categories.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingLabel rdf:type rdf:Property ;
    rdfs:label 'Marketing Label' ;
    rdfs:comment 'Customer-facing marketing label or brand name for this category used in promotional materials and campaigns.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingEligible rdf:type rdf:Property ;
    rdfs:label 'Roaming Eligible' ;
    rdfs:comment 'Indicates whether products in this category include or support international roaming capabilities.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags for search engine optimization and catalog search functionality.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDomain rdf:type rdf:Property ;
    rdfs:label 'Service Domain' ;
    rdfs:comment 'High-level service domain classification for grouping related product categories. Aligns with Operations Support Systems (OSS) and Business Support Systems (BSS) service taxonomy. [ENUM-REF-CANDIDATE: mobile|broadband|voice|video|data|messaging|iot|cloud|security|managed_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipId rdf:type rdf:Property ;
    rdfs:label 'Relationship Id' ;
    rdfs:comment 'Unique identifier for the product relationship record. Primary key.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productStrategistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Strategist Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Product strategists define cross-sell, upsell, and migration relationships between products in telco portfolio management - accountable for upgrade paths, bundle strategies, and product lifecycle tran' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relationshipSpecId rdf:type rdf:Property ;
    rdfs:label 'Relationship Spec Id' ;
    rdfs:comment 'Identifier of the originating product in the relationship. The product from which the relationship is defined.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Spec .

ind:targetProductProductSpecId rdf:type rdf:Property ;
    rdfs:label 'Target Product Product Spec Id' ;
    rdfs:comment 'Identifier of the destination product in the relationship. The product to which the relationship points.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Spec .

ind:eligibilityCondition rdf:type rdf:Property ;
    rdfs:label 'Eligibility Condition' ;
    rdfs:comment 'Business rule expression defining when this relationship applies. May reference customer segment, account type, geographic region, or other contextual attributes. Expressed in rule engine syntax.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationIncentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Migration Incentive Description' ;
    rdfs:comment 'Textual description of the migration incentive offer, including discount amount, waived fees, or promotional terms. Displayed to customer service representatives and customers during guided selling.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Migration Incentive Flag' ;
    rdfs:comment 'Indicates whether a promotional incentive or discount is available when migrating from source to target product. Used for supersession and migration path relationships to drive product lifecycle transitions.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityMax rdf:type rdf:Property ;
    rdfs:label 'Quantity Max' ;
    rdfs:comment 'Maximum quantity of the target product allowed in the relationship. Used for conflicts and exclusivity rules (e.g., only one premium plan allowed per account).' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityMin rdf:type rdf:Property ;
    rdfs:label 'Quantity Min' ;
    rdfs:comment 'Minimum quantity of the target product required to satisfy the relationship constraint. Used for requires relationships where multiple units are needed (e.g., a bundle requires at least 2 add-ons).' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalProductManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Technical product managers define product specifications including data allowances, speed tiers, QoS parameters in telco operations - responsible for technical feasibility, network capacity planning, ' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowanceQuantity rdf:type rdf:Property ;
    rdfs:label 'Allowance Quantity' ;
    rdfs:comment 'Numeric quantity of the usage allowance. Defines the included amount (e.g., 50 GB data, 1000 voice minutes, unlimited). Use -1 or special value for unlimited allowances.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Type of usage allowance for mobile and roaming products. Specifies the consumption category: data, voice minutes, SMS, roaming data, roaming voice, or international minutes. Applicable only to usage allowance specifications.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burstBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Burst Bandwidth Mbps' ;
    rdfs:comment 'Burstable bandwidth in megabits per second for enterprise circuits. Defines the maximum temporary throughput allowed above committed rate (e.g., 100 Mbps committed, 200 Mbps burst).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Name of the technical characteristic being specified. Extensible name-value pair key for product capabilities (e.g., data_allowance_gb, download_speed_mbps, channel_count, sla_uptime_percent).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicValue rdf:type rdf:Property ;
    rdfs:label 'Characteristic Value' ;
    rdfs:comment 'Value of the technical characteristic. Stores the specification parameter value as string to support numeric, boolean, and enumerated values (e.g., 50, unlimited, true, gold_tier).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous video streams allowed for IPTV and OTT services. Defines the multi-device viewing limit (e.g., 2 streams, 4 streams, unlimited).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dvrHours rdf:type rdf:Property ;
    rdfs:label 'Dvr Hours' ;
    rdfs:comment 'Cloud DVR storage capacity in hours of recording for IPTV services. Defines the network-based recording allowance (e.g., 50 hours, 200 hours, unlimited).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fairUseLimitGb rdf:type rdf:Property ;
    rdfs:label 'Fair Use Limit Gb' ;
    rdfs:comment 'Fair use policy limit in gigabytes for unlimited plans. Defines the threshold beyond which network management policies may apply (e.g., deprioritization, throttling). Regulatory compliance for unlimited offerings.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRolloverEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rollover Enabled' ;
    rdfs:comment 'Flag indicating whether unused allowance rolls over to the next billing cycle. True for rollover data plans. False for use-it-or-lose-it allowances.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShared rdf:type rdf:Property ;
    rdfs:label 'Is Shared' ;
    rdfs:comment 'Flag indicating whether the allowance is shared across multiple subscribers or devices. True for family plans and multi-device data pools. False for individual allowances.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnlimited rdf:type rdf:Property ;
    rdfs:label 'Is Unlimited' ;
    rdfs:comment 'Flag indicating whether the allowance is unlimited. True for unlimited data, voice, or SMS plans. False for metered allowances. Drives billing and network management policies.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overagePolicy rdf:type rdf:Property ;
    rdfs:label 'Overage Policy' ;
    rdfs:comment 'Policy applied when usage exceeds allowance. Defines the enforcement action: block (hard cap), throttle (reduce speed), charge (pay-per-use), rollover (carry forward unused), or unlimited (no cap).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetFrequency rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency' ;
    rdfs:comment 'Frequency at which usage allowances reset. Defines the billing cycle for allowance renewal: monthly (standard), daily (roaming fair-use), weekly, annual, one-time (non-recurring), or never (lifetime).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingDataAllowanceGb rdf:type rdf:Property ;
    rdfs:label 'Roaming Data Allowance Gb' ;
    rdfs:comment 'Data allowance in gigabytes available for roaming usage. Defines the fair-use limit for international data consumption. May differ from domestic allowance.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Guaranteed service availability percentage per SLA. Defines the contractual uptime commitment (e.g., 99.9%, 99.99%, 99.999% for carrier-grade). Applicable to enterprise SD-WAN, MPLS, and premium broadband.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specCategory rdf:type rdf:Property ;
    rdfs:label 'Spec Category' ;
    rdfs:comment 'Functional category of the specification parameter. Groups specifications by purpose: usage allowance, network capability, service feature, QoS parameter, device capability, or pricing rule.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specDescription rdf:type rdf:Property ;
    rdfs:label 'Spec Description' ;
    rdfs:comment 'Detailed description of the product specification. Provides business context and technical details for the characteristic definition. Used for product catalog documentation and customer communication.' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name of the product specification. Identifies the technical characteristic being defined (e.g., Data Allowance, Speed Tier, Channel Package).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of the product specification. Defines availability for provisioning: draft (under development), active (available), deprecated (phasing out), retired (no longer available).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specType rdf:type rdf:Property ;
    rdfs:label 'Spec Type' ;
    rdfs:comment 'Category of product specification defining the service domain. Determines which technical parameters are applicable (mobile, broadband, IPTV, VoIP, SD-WAN, MPLS, device, roaming, add-on). [ENUM-REF-CANDIDATE: mobile|broadband|iptv|voip|sdwan|mpls|device|roaming|addon — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleSpeedMbps rdf:type rdf:Property ;
    rdfs:label 'Throttle Speed Mbps' ;
    rdfs:comment 'Reduced data speed in megabits per second applied after allowance exhaustion. Applicable when overage_policy is throttle. Defines the post-allowance QoS degradation (e.g., 128 Kbps, 1 Mbps).' ;
    rdfs:domain ind:Spec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Marketing campaign managers own promotional offers in telecommunications - accountable for campaign ROI, budget management, and promotional effectiveness. Essential for tracking who designed bonus dat' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this promotional offer is automatically applied to eligible customers without requiring a promo code entry. True if auto-applied, False if customer must enter promo code.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusDataAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Data Amount' ;
    rdfs:comment 'Additional data allowance provided as part of the promotional offer, measured in the unit specified by bonus_data_unit. Applicable for mobile and broadband promotions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusDataUnit rdf:type rdf:Property ;
    rdfs:label 'Bonus Data Unit' ;
    rdfs:comment 'Unit of measure for bonus data amount: GB (gigabytes), MB (megabytes), or TB (terabytes).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for this promotional offer in the currency specified by discount_currency_code. Used to track promotional spending and prevent budget overruns.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetConsumed rdf:type rdf:Property ;
    rdfs:label 'Budget Consumed' ;
    rdfs:comment 'Amount of promotional budget consumed to date through customer redemptions. Updated as offers are redeemed. Used for budget tracking and offer performance monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Discount Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for fixed amount discounts (e.g., USD, EUR, GBP). Null for percentage-based discounts.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. For percentage discounts, represents the percentage (e.g., 25.00 for 25% off). For fixed amount discounts, represents the currency amount. Interpretation depends on discount_type.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityChannel rdf:type rdf:Property ;
    rdfs:label 'Eligibility Channel' ;
    rdfs:comment 'Sales or service channel(s) through which this offer can be redeemed (e.g., online, retail_store, telesales, partner, mobile_app). Comma-separated list if multiple channels are eligible. Null if no channel restriction.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Eligibility Customer Segment' ;
    rdfs:comment 'Specific customer segment(s) eligible for this offer (e.g., residential, small_business, enterprise, prepaid, postpaid). Comma-separated list if multiple segments are eligible. Null if no segment restriction.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCustomerType rdf:type rdf:Property ;
    rdfs:label 'Eligibility Customer Type' ;
    rdfs:comment 'Customer type eligible for this promotional offer: new (new customers only), existing (current customers only), churned (win-back for former customers), or all (no customer type restriction).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityGeographicScope rdf:type rdf:Property ;
    rdfs:label 'Eligibility Geographic Scope' ;
    rdfs:comment 'Geographic region(s) where this promotional offer is valid. Can be country codes (ISO 3166-1 alpha-3), state/province codes, or region identifiers. Comma-separated list if multiple regions. Null if no geographic restriction.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityProductCategory rdf:type rdf:Property ;
    rdfs:label 'Eligibility Product Category' ;
    rdfs:comment 'Product category or categories to which this promotional offer applies (e.g., mobile_postpaid, fiber_broadband, iptv, voip, sd_wan). Comma-separated list if applicable to multiple categories. Null if offer applies to all products.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeTrialDuration rdf:type rdf:Property ;
    rdfs:label 'Free Trial Duration' ;
    rdfs:comment 'Length of the free trial period measured in the unit specified by free_trial_unit. Applicable for free trial promotional offers.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeTrialUnit rdf:type rdf:Property ;
    rdfs:label 'Free Trial Unit' ;
    rdfs:comment 'Unit of measure for free trial duration: days, months, or billing_cycles.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingMessage rdf:type rdf:Property ;
    rdfs:label 'Marketing Message' ;
    rdfs:comment 'Short marketing message or tagline used to promote this offer in customer-facing materials, advertisements, and digital channels.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Count' ;
    rdfs:comment 'Maximum number of times this promotional offer can be redeemed across all customers. Used to cap total offer usage for budget control. Null if unlimited redemptions allowed.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Period' ;
    rdfs:comment 'Minimum contract commitment period required to qualify for this promotional offer, measured in months. Null if no commitment required.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCategory rdf:type rdf:Property ;
    rdfs:label 'Promo Category' ;
    rdfs:comment 'Category of promotional benefit provided: discount (percentage or fixed amount off), free_trial (service at no charge for period), bonus_data (additional data allowance), device_subsidy (reduced device cost), bundle (package deal), or waived_fee (activation/installation fee waived).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoDescription rdf:type rdf:Property ;
    rdfs:label 'Promo Description' ;
    rdfs:comment 'Detailed description of the promotional offer including terms, benefits, and conditions. Used in marketing materials and customer communications.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoName rdf:type rdf:Property ;
    rdfs:label 'Promo Name' ;
    rdfs:comment 'Marketing name of the promotional offer displayed to customers and used in campaign materials.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoType rdf:type rdf:Property ;
    rdfs:label 'Promo Type' ;
    rdfs:comment 'Classification of the promotional offer based on its strategic purpose: acquisition (new customer), retention (existing customer), win-back (churned customer), seasonal (holiday/event-based), loyalty (reward program), or referral (customer referral incentive).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this promotional offer. Typically 1 for most offers. Null if no per-customer limit.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this promotional offer can be combined (stacked) with other promotional offers. True if stackable, False if mutually exclusive with other offers.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpuImpact rdf:type rdf:Property ;
    rdfs:label 'Target Arpu Impact' ;
    rdfs:comment 'Projected impact on Average Revenue Per User (ARPU) from this promotional offer, expressed as a currency amount. Negative values indicate expected ARPU reduction during promo period. Used for financial planning and offer ROI analysis.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions governing the promotional offer including restrictions, disclaimers, and fine print. Used for regulatory compliance and customer disclosure.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Service delivery managers define SLA templates for enterprise and business customers in telecommunications - accountable for uptime commitments, MTTR targets, and penalty structures. Essential for ope' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bandwidthGuaranteeMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Guarantee Mbps' ;
    rdfs:comment 'Guaranteed minimum bandwidth in megabits per second. Defines the committed information rate for the service.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationMatrix rdf:type rdf:Property ;
    rdfs:label 'Escalation Matrix' ;
    rdfs:comment 'Structured escalation path defining roles and timeframes for incident escalation (e.g., L1 Support → L2 Support → Engineering → Management). May reference external escalation document.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Circumstances or events excluded from SLA calculations (e.g., scheduled maintenance, force majeure, customer-caused outages, third-party failures outside provider control).' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jitterThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Jitter Threshold Ms' ;
    rdfs:comment 'Maximum acceptable jitter (variation in packet delay) in milliseconds. Critical for voice and video quality.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyThresholdMs rdf:type rdf:Property ;
    rdfs:label 'Latency Threshold Ms' ;
    rdfs:comment 'Maximum acceptable network latency in milliseconds. Critical for real-time services like VoIP, video conferencing, and enterprise applications.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPenaltyPercent rdf:type rdf:Property ;
    rdfs:label 'Max Penalty Percent' ;
    rdfs:comment 'Maximum penalty as a percentage of monthly recurring charges that can be applied in a single measurement period. Caps the financial liability.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Hours' ;
    rdfs:comment 'Minimum advance notice in hours required for planned maintenance or service changes. Defines customer notification commitment.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packetLossThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Threshold Percent' ;
    rdfs:comment 'Maximum acceptable packet loss percentage. Defines the upper limit for packet loss before SLA breach occurs.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of penalty or remedy applied when SLA is breached (Service Credit, Refund, Rebate, None). Defines the financial consequence structure.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCompliance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance' ;
    rdfs:comment 'Regulatory frameworks or standards this SLA template complies with (e.g., FCC requirements, GDPR, HIPAA, PCI-DSS, SOC 2). May be comma-separated list.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimePriority1Hours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Priority 1 Hours' ;
    rdfs:comment 'Maximum resolution time in hours for Priority 1 (critical) incidents. Defines the time commitment to fully resolve service-affecting issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimePriority2Hours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Priority 2 Hours' ;
    rdfs:comment 'Maximum resolution time in hours for Priority 2 (high) incidents. Defines resolution commitment for high-impact but non-critical issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimePriority3Hours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Priority 3 Hours' ;
    rdfs:comment 'Maximum resolution time in hours for Priority 3 (medium) incidents. Defines resolution commitment for moderate-impact issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimePriority1Hours rdf:type rdf:Property ;
    rdfs:label 'Response Time Priority 1 Hours' ;
    rdfs:comment 'Maximum response time in hours for Priority 1 (critical) incidents. Defines how quickly support must respond to service-affecting issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimePriority2Hours rdf:type rdf:Property ;
    rdfs:label 'Response Time Priority 2 Hours' ;
    rdfs:comment 'Maximum response time in hours for Priority 2 (high) incidents. Defines response commitment for high-impact but non-critical issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimePriority3Hours rdf:type rdf:Property ;
    rdfs:label 'Response Time Priority 3 Hours' ;
    rdfs:comment 'Maximum response time in hours for Priority 3 (medium) incidents. Defines response commitment for moderate-impact issues.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTemplateDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Template Description' ;
    rdfs:comment 'Detailed description of the SLA template including its purpose, target use cases, and key differentiators from other SLA tiers.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportChannel rdf:type rdf:Property ;
    rdfs:label 'Support Channel' ;
    rdfs:comment 'Available support channels under this SLA (e.g., phone, email, portal, dedicated account manager, on-site support). May be comma-separated list.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportHours rdf:type rdf:Property ;
    rdfs:label 'Support Hours' ;
    rdfs:comment 'Hours during which support is available under this SLA (24x7, Business Hours, Extended Hours). Defines the temporal scope of support commitments.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Business identifier code for the SLA template used in product catalog and contract management systems. Externally visible unique code.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the SLA template (e.g., Gold Enterprise SLA, Silver Business Broadband SLA, Bronze MPLS SLA).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL or document reference to the full legal terms and conditions governing this SLA template.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Service tier classification indicating the level of service commitment (Platinum, Gold, Silver, Bronze, Standard, Basic). Higher tiers typically offer stricter performance guarantees and faster response times.' ;
    rdfs:domain ind:SlaTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Primary key for activity' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Reference to the sales lead this activity is associated with. Links to the prospect being qualified.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Reference to the sales opportunity this activity is associated with. Links to the opportunity being pursued.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'Date when the sales activity occurred or is scheduled to occur. Primary business event date for the interaction.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description of the sales activity. Captures notes, discussion points, customer feedback, and action items from the interaction.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current status of the sales activity in its lifecycle. Tracks whether the activity is planned, ongoing, finished, or did not occur.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Type of sales activity performed. Categorizes the interaction method used to engage with the prospect or customer.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of attendees who participated in the sales activity. Tracks the size of the meeting or presentation for engagement analysis.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorMentioned rdf:type rdf:Property ;
    rdfs:label 'Competitor Mentioned' ;
    rdfs:comment 'Name of competitor mentioned or discussed during the sales activity. Captures competitive intelligence from customer interactions.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Method or medium used to conduct the sales activity. Distinguishes the communication interface used for the interaction.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Deal Size Category' ;
    rdfs:comment 'Size category of the potential deal associated with this activity. Classifies the revenue opportunity magnitude for resource prioritization.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue' ;
    rdfs:comment 'Estimated revenue value associated with the opportunity or lead related to this activity. Represents the potential deal value in the base currency.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalActivityReference rdf:type rdf:Property ;
    rdfs:label 'External Activity Reference' ;
    rdfs:comment 'Unique identifier of the activity in the source system. Enables traceability and reconciliation with the originating CRM platform.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether the sales activity is billable to the customer or partner. Used for professional services and consulting engagements.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft delete flag indicating whether the sales activity record has been logically deleted. Supports data retention and audit requirements.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the sales activity took place. Captures the venue for in-person meetings or the platform for virtual interactions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Recommended or planned next action following this sales activity. Captures the follow-up step required to advance the opportunity or lead.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next action should be completed. Supports pipeline velocity tracking and sales cadence management.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectionRaised rdf:type rdf:Property ;
    rdfs:label 'Objection Raised' ;
    rdfs:comment 'Customer objection or concern raised during the sales activity. Documents barriers to closing the deal for coaching and strategy refinement.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productInterest rdf:type rdf:Property ;
    rdfs:label 'Product Interest' ;
    rdfs:comment 'Product or service the customer expressed interest in during this activity. Captures the specific offering being discussed or demonstrated.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:b2bAccountPlanId rdf:type rdf:Property ;
    rdfs:label 'B2b Account Plan Id' ;
    rdfs:comment 'Unique identifier for the B2B account plan. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:B2bAccountPlan .

ind:primaryB2bCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary B2b Created By User Employee Id' ;
    rdfs:comment 'Reference to the user (typically the account owner or sales manager) who created this account plan record.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetContentPackageId rdf:type rdf:Property ;
    rdfs:label 'Target Content Package Id' ;
    rdfs:comment 'Foreign key linking to content.content_package. Business justification: Enterprise account plans identify content package upsell and cross-sell opportunities as part of strategic account management. Required for whitespace analysis, revenue growth planning, and tracking c' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:tertiaryB2bApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary B2b Approved By User Employee Id' ;
    rdfs:comment 'Reference to the sales leader or manager who approved this account plan. Null if not yet approved.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountHealthStatus rdf:type rdf:Property ;
    rdfs:label 'Account Health Status' ;
    rdfs:comment 'Overall health assessment of the customer account based on satisfaction scores, service performance, payment history, and engagement level.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineArr rdf:type rdf:Property ;
    rdfs:label 'Baseline Arr' ;
    rdfs:comment 'The starting Annual Recurring Revenue (ARR) from this account at the beginning of the plan period. Used to measure growth against target.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineMrr rdf:type rdf:Property ;
    rdfs:label 'Baseline Mrr' ;
    rdfs:comment 'The starting Monthly Recurring Revenue (MRR) from this account at the beginning of the plan period. Used to measure growth against target.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnProbabilityScore rdf:type rdf:Property ;
    rdfs:label 'Churn Probability Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the likelihood of customer churn during the plan period. May be calculated by predictive models or assigned by the account team.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveThreats rdf:type rdf:Property ;
    rdfs:label 'Competitive Threats' ;
    rdfs:comment 'Analysis of competitive risks and threats from other telecommunications providers or alternative solutions (e.g., OTT services, MVNO competitors, in-house network builds). Includes competitor names and threat severity.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total contract value (TCV) of the customer\'s current agreements with the telecommunications provider. Expressed in the base currency.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossSellOpportunities rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Opportunities' ;
    rdfs:comment 'Documented list of planned cross-sell initiatives to introduce new product lines or services (e.g., adding SD-WAN to an MPLS customer, adding cloud services to a connectivity customer).' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSponsorName rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor Name' ;
    rdfs:comment 'Name of the executive sponsor or primary decision-maker at the customer organization who champions the telecommunications provider\'s solutions.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveSponsorTitle rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor Title' ;
    rdfs:comment 'Job title of the executive sponsor (e.g., CIO, CTO, VP of IT, Director of Procurement).' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyStakeholderMap rdf:type rdf:Property ;
    rdfs:label 'Key Stakeholder Map' ;
    rdfs:comment 'Structured mapping of key decision-makers, influencers, and champions within the customer organization. May include names, titles, roles, and relationship strength indicators.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The date when this account plan period concludes. Typically aligns with fiscal year end or contract renewal date.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for additional strategic notes, observations, or context about the account plan that do not fit into structured fields. May include meeting notes, customer feedback, or internal strategy discussions.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The date when this account plan becomes effective and execution begins.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCompetitor rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor' ;
    rdfs:comment 'Name of the primary competing telecommunications provider or solution vendor that poses the greatest threat to this account.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRiskFactors rdf:type rdf:Property ;
    rdfs:label 'Renewal Risk Factors' ;
    rdfs:comment 'Detailed description of factors contributing to renewal risk, such as service quality issues, pricing concerns, competitive pressure, organizational changes at the customer, or dissatisfaction with support.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Renewal Risk Level' ;
    rdfs:comment 'Assessment of the risk that the customer will not renew their contracts or services at the end of the current term. Levels: low (strong relationship, high satisfaction), medium (some concerns), high (significant issues), critical (imminent churn risk).' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePortfolioSummary rdf:type rdf:Property ;
    rdfs:label 'Service Portfolio Summary' ;
    rdfs:comment 'High-level summary of the telecommunications services currently subscribed by this customer (e.g., MPLS, SD-WAN, Internet, Voice, Mobile, Cloud Connectivity, Managed Services).' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicInitiatives rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiatives' ;
    rdfs:comment 'List of major strategic initiatives planned for this account during the plan period (e.g., 5G migration, SD-WAN deployment, IoT pilot, cloud connectivity expansion).' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArrGrowth rdf:type rdf:Property ;
    rdfs:label 'Target Arr Growth' ;
    rdfs:comment 'The target increase in Annual Recurring Revenue (ARR) for this account during the plan period. Expressed in the base currency.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMrrGrowth rdf:type rdf:Property ;
    rdfs:label 'Target Mrr Growth' ;
    rdfs:comment 'The target increase in Monthly Recurring Revenue (MRR) for this account during the plan period. Expressed in the base currency.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upsellOpportunities rdf:type rdf:Property ;
    rdfs:label 'Upsell Opportunities' ;
    rdfs:comment 'Documented list of planned upsell initiatives to increase service tier, bandwidth, or feature adoption within existing services. May include opportunity IDs or descriptions.' ;
    rdfs:domain ind:B2bAccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whitespaceAnalysis rdf:type rdf:Property ;
    rdfs:label 'Whitespace Analysis' ;
    rdfs:comment 'Detailed analysis of untapped opportunities within the customer account. Identifies products, services, or business units where the customer is not yet using the telecommunications provider\'s offerings.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTeamId rdf:type rdf:Property ;
    rdfs:label 'Sales Team Id' ;
    rdfs:comment 'Reference to the sales team assigned to manage this channel and territory.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:acceptsWalkIn rdf:type rdf:Property ;
    rdfs:label 'Accepts Walk In' ;
    rdfs:comment 'Indicates whether this channel accepts walk-in customers without appointments. Applicable to physical retail and dealer locations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Maximum number of concurrent sales opportunities or leads this channel can handle effectively, used for lead distribution and capacity planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionStructureCode rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Code' ;
    rdfs:comment 'Reference code to the commission plan and incentive structure applicable to this channel (e.g., COMM-RET-01, COMM-DEALER-TIER1).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Crm System Code' ;
    rdfs:comment 'External identifier for this channel in the Salesforce CRM system, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPlatformUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Platform Url' ;
    rdfs:comment 'Web URL or mobile app identifier for digital/online channels. Null for physical channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryChannel rdf:type rdf:Property ;
    rdfs:label 'Is Primary Channel' ;
    rdfs:comment 'Indicates whether this is the primary/preferred channel for the assigned territory. Used in lead routing tie-breaker logic.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageSupported rdf:type rdf:Property ;
    rdfs:label 'Language Supported' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes supported by this channel (e.g., en, es, fr). Used for customer routing and service delivery.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent performance evaluation and tier classification review for this channel.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAssignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Lead Assignment Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) used in automated lead distribution algorithms to route leads to channels based on performance, capacity, and segment fit.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next performance evaluation and potential tier reclassification.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the channel (e.g., Mon-Fri 9AM-6PM, 24/7, By Appointment). Used for customer expectation setting and capacity planning.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line1' ;
    rdfs:comment 'Primary street address line for physical channel locations (retail stores, dealer offices). Null for virtual channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line2' ;
    rdfs:comment 'Secondary address line (suite, floor, building) for physical channel locations. Null for virtual channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentScope rdf:type rdf:Property ;
    rdfs:label 'Segment Scope' ;
    rdfs:comment 'Customer segment(s) this channel is authorized to serve: B2C (consumer retail), B2B (business/enterprise), MVNO (Mobile Virtual Network Operator wholesale), B2C_B2B (hybrid), ALL (all segments).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsBusinessAccounts rdf:type rdf:Property ;
    rdfs:label 'Supports Business Accounts' ;
    rdfs:comment 'Indicates whether this channel is authorized and equipped to handle B2B enterprise account sales and service.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPlanId rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Id' ;
    rdfs:comment 'Unique identifier for the commission plan. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionPlan .

ind:supersededByPlanCommissionPlanId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Plan Commission Plan Id' ;
    rdfs:comment 'Identifier of the commission plan that replaces this plan when it expires or is terminated. Creates lineage chain for plan evolution. Nullable if plan is current.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionPlan .

ind:targetProductCategoryId rdf:type rdf:Property ;
    rdfs:label 'Target Product Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Commission plans often vary by product category (mobile vs broadband vs enterprise services). This link enables category-specific incentive design, sales behavior steering toward strategic products, a' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:acceleratorMultiplier rdf:type rdf:Property ;
    rdfs:label 'Accelerator Multiplier' ;
    rdfs:comment 'Multiplier applied to commission rate when accelerator threshold is exceeded (e.g., 1.50 for 150% of base rate). Nullable if plan does not include accelerator.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceleratorThreshold rdf:type rdf:Property ;
    rdfs:label 'Accelerator Threshold' ;
    rdfs:comment 'Sales quota or target that must be exceeded to trigger accelerator multiplier. Nullable if plan does not include accelerator.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Base Commission Rate' ;
    rdfs:comment 'Default commission rate expressed as a decimal percentage (e.g., 0.0500 for 5%). Applies to flat-rate plans or as the starting tier for tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clawbackPercentage rdf:type rdf:Property ;
    rdfs:label 'Clawback Percentage' ;
    rdfs:comment 'Percentage of earned commission that must be returned if clawback is triggered (e.g., 100.00 for full clawback, 50.00 for partial). Expressed as decimal percentage.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clawbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Clawback Period Days' ;
    rdfs:comment 'Number of days after sale during which customer disconnect or service cancellation triggers commission reversal. Common values: 30, 60, 90 days. Protects against churn-driven commission abuse.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRateUnit rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Unit' ;
    rdfs:comment 'Unit of measure for the commission calculation. Percentage of revenue: commission on total sale value. Percentage of MRR (Monthly Recurring Revenue): commission on subscription revenue. Flat amount per unit: fixed dollar per activation. Percentage of ARPU (Average Revenue Per User): commission based on customer lifetime value proxy.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Default Split Percentage' ;
    rdfs:comment 'Default percentage of commission allocated to primary participant when splitting is enabled. Expressed as decimal percentage (e.g., 70.00 for 70%). Nullable if splitting not allowed.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleProductCategories rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or service types that qualify for commission under this plan (e.g., \'wireless_postpaid\', \'fiber_internet\', \'enterprise_sd_wan\', \'iptv\'). Used to filter qualifying sales transactions.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdfAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Mdf Allocation Amount' ;
    rdfs:comment 'Total budget allocated for co-marketing activities with channel partners under this plan. Nullable for non-MDF plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Category of sales participant eligible for this commission plan. Internal sales rep: direct employees. Dealer: authorized retail partner. Agent: independent contractor. MVNO (Mobile Virtual Network Operator) partner: wholesale reseller. Channel partner: indirect sales organization.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDelayDays rdf:type rdf:Property ;
    rdfs:label 'Payment Delay Days' ;
    rdfs:comment 'Number of days after the end of the commission period before payment is issued. Allows time for transaction validation and clawback assessment.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaMeasurementUnit rdf:type rdf:Property ;
    rdfs:label 'Quota Measurement Unit' ;
    rdfs:comment 'Unit of measure for quota target. Revenue: total sales dollars. Unit count: number of products sold. Subscriber count: number of new activations. MRR (Monthly Recurring Revenue): recurring subscription value.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaTarget rdf:type rdf:Property ;
    rdfs:label 'Quota Target' ;
    rdfs:comment 'Sales target or quota that participants are expected to achieve under this plan. Used to calculate attainment percentage and trigger accelerators.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Residual Duration Months' ;
    rdfs:comment 'Number of months that residual commissions continue to be paid on recurring revenue from the original sale. Nullable for non-residual plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRate rdf:type rdf:Property ;
    rdfs:label 'Residual Rate' ;
    rdfs:comment 'Commission rate applied to ongoing MRR (Monthly Recurring Revenue) for residual plans. Expressed as decimal percentage. Nullable for non-residual plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spiffAmount rdf:type rdf:Property ;
    rdfs:label 'Spiff Amount' ;
    rdfs:comment 'Fixed bonus amount paid for selling specific high-priority products or services during promotional periods. Nullable for non-SPIFF plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:splitEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Split Eligible Flag' ;
    rdfs:comment 'Indicates whether commissions under this plan can be split among multiple participants (e.g., sales rep and sales manager). True: splitting allowed. False: single participant only.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier1Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate' ;
    rdfs:comment 'Commission rate applicable when sales reach tier 1 threshold. Expressed as decimal percentage. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold' ;
    rdfs:comment 'Sales volume or revenue threshold to qualify for tier 1 commission rate in tiered plans. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate' ;
    rdfs:comment 'Commission rate applicable when sales reach tier 2 threshold. Expressed as decimal percentage. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold' ;
    rdfs:comment 'Sales volume or revenue threshold to qualify for tier 2 commission rate in tiered plans. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Rate rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Rate' ;
    rdfs:comment 'Commission rate applicable when sales reach tier 3 threshold. Expressed as decimal percentage. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Threshold' ;
    rdfs:comment 'Sales volume or revenue threshold to qualify for tier 3 commission rate in tiered plans. Nullable for non-tiered plans.' ;
    rdfs:domain ind:CommissionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionTxnId rdf:type rdf:Property ;
    rdfs:label 'Commission Txn Id' ;
    rdfs:comment 'Primary key for commission_txn' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceleratorApplied rdf:type rdf:Property ;
    rdfs:label 'Accelerator Applied' ;
    rdfs:comment 'Boolean indicator of whether a commission accelerator (higher rate for exceeding quota) was applied to this transaction.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clawbackAmount rdf:type rdf:Property ;
    rdfs:label 'Clawback Amount' ;
    rdfs:comment 'The amount of commission reversed or reclaimed due to customer churn, contract cancellation, or policy violation.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clawbackReason rdf:type rdf:Property ;
    rdfs:label 'Clawback Reason' ;
    rdfs:comment 'The business reason or justification for commission clawback, such as early customer churn, contract cancellation, payment default, or policy violation.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'The percentage rate or multiplier applied to the sale value to calculate the commission amount (e.g., 0.0500 for 5%).' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Amount' ;
    rdfs:comment 'The gross commission amount earned by the sales representative before any adjustments or clawbacks.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPeriod rdf:type rdf:Property ;
    rdfs:label 'Payment Period' ;
    rdfs:comment 'The accounting period (YYYY-MM format) in which this commission is scheduled for payout.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Payout Batch Number' ;
    rdfs:comment 'Identifier of the payment batch or payroll run in which this commission was or will be paid out.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payoutDate rdf:type rdf:Property ;
    rdfs:label 'Payout Date' ;
    rdfs:comment 'The actual date when the commission payment was disbursed to the sales representative.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaAttainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Attainment Percentage' ;
    rdfs:comment 'The sales representative\'s quota attainment percentage at the time this commission was earned, which may influence commission rate or bonus eligibility.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleAmount rdf:type rdf:Property ;
    rdfs:label 'Sale Amount' ;
    rdfs:comment 'The total value of the underlying sale, activation, or contract that forms the basis for commission calculation.' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:splitPercentage rdf:type rdf:Property ;
    rdfs:label 'Split Percentage' ;
    rdfs:comment 'The percentage of the total commission allocated to this sales representative when commission is shared among multiple parties (e.g., 50.00 for 50% split).' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'The specific sales event or customer action that triggered this commission: new activation, upgrade, renewal, Mobile Number Portability (MNP) port-in, contract extension, add-on sale, device sale, or plan change. [ENUM-REF-CANDIDATE: new_activation|upgrade|renewal|mnp_port_in|contract_extension|add_on_sale|device_sale|plan_change — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommissionTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Employee Id' ;
    rdfs:comment 'Reference to the sales representative, account manager, or system user who initiated the amendment request in Salesforce CRM.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAmendmentContractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Contract Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment. Used to track amendment version chains and ensure only the latest amendment is active.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAmendment .

ind:amendedEndDate rdf:type rdf:Property ;
    rdfs:label 'Amended End Date' ;
    rdfs:comment 'The new contract expiration date after this amendment is applied. Nullable if the amendment does not affect contract end date.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendedTermMonths rdf:type rdf:Property ;
    rdfs:label 'Amended Term Months' ;
    rdfs:comment 'The new contract term length in months after this amendment is applied. Nullable if the amendment does not affect contract term.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Amendment Document Url' ;
    rdfs:comment 'Reference URL or file path to the signed amendment document stored in the document management system. Enables retrieval of the legal contract artifact.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational level required for approval based on amendment impact thresholds. Determined by revenue impact, term changes, or policy rules.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySignatoryName rdf:type rdf:Property ;
    rdfs:label 'Company Signatory Name' ;
    rdfs:comment 'Full name of the telecommunications company representative who signed the amendment on behalf of the organization.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Company Signatory Title' ;
    rdfs:comment 'Job title or role of the company representative who signed the amendment. Validates internal signing authority.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Customer Signatory Name' ;
    rdfs:comment 'Full name of the customer representative who signed the amendment. Required for legal enforceability and audit trail.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Customer Signatory Title' ;
    rdfs:comment 'Job title or role of the customer representative who signed the amendment. Validates signing authority.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Date' ;
    rdfs:comment 'Date when the customer signed the amendment. Nullable until customer signature is obtained.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Required' ;
    rdfs:comment 'Indicates whether customer signature is required for this amendment to be legally binding. Depends on amendment materiality and contract terms.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the amendment was formally executed and signed by authorized parties. Represents legal completion of the amendment process.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed' ;
    rdfs:comment 'Indicates whether required legal review has been completed and approved. Gates the amendment from moving to execution status.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether this amendment requires formal legal department review before execution. Typically true for material changes, liability modifications, or regulatory-sensitive amendments.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrrDeltaAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Delta Amount' ;
    rdfs:comment 'Net change in Monthly Recurring Revenue resulting from this amendment. Positive values indicate revenue increase, negative indicate decrease. Critical metric for sales performance and revenue forecasting.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalEndDate rdf:type rdf:Property ;
    rdfs:label 'Original End Date' ;
    rdfs:comment 'The contract expiration date before this amendment. Used to track the impact of term extension or early termination amendments.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Original Term Months' ;
    rdfs:comment 'The contract term length in months before this amendment. Used to calculate the impact of term extension amendments.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Pricing Change Description' ;
    rdfs:comment 'Detailed description of any pricing modifications including rate changes, discount adjustments, or pricing model changes. Provides transparency for revenue assurance and audit.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicesAdded rdf:type rdf:Property ;
    rdfs:label 'Services Added' ;
    rdfs:comment 'Comma-separated list or description of services, products, or features being added to the contract through this amendment. Used for service catalog impact analysis.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicesRemoved rdf:type rdf:Property ;
    rdfs:label 'Services Removed' ;
    rdfs:comment 'Comma-separated list or description of services, products, or features being removed from the contract through this amendment. Tracks service downgrades or discontinuations.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Change Description' ;
    rdfs:comment 'Description of any changes to Service Level Agreement terms, performance commitments, or penalty clauses. Critical for operations and customer success teams.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcvDeltaAmount rdf:type rdf:Property ;
    rdfs:label 'Tcv Delta Amount' ;
    rdfs:comment 'Net change in Total Contract Value over the remaining contract term resulting from this amendment. Includes all recurring and one-time charges.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique identifier for the sales forecast record. Primary key.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the manager or executive who approved this forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:forecastEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Employee Id' ;
    rdfs:comment 'Identifier of the sales representative, team lead, or manager who owns and is accountable for this forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:forecastSubmittedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Submitted By User Employee Id' ;
    rdfs:comment 'Identifier of the user who submitted this forecast for approval.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:atRiskOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'At Risk Opportunity Count' ;
    rdfs:comment 'Number of opportunities flagged as at risk of slipping to future periods or being lost.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageDealSize rdf:type rdf:Property ;
    rdfs:label 'Average Deal Size' ;
    rdfs:comment 'Average contract value per opportunity in the forecast pipeline, calculated as total_pipeline_value divided by opportunity count.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageSalesCycleDays rdf:type rdf:Property ;
    rdfs:label 'Average Sales Cycle Days' ;
    rdfs:comment 'Average number of days from opportunity creation to close for deals in this forecast scope, used for velocity analysis.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bestCaseRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Best Case Revenue Amount' ;
    rdfs:comment 'Optimistic revenue projection if all high-probability opportunities close and favorable conditions occur.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Commit Revenue Amount' ;
    rdfs:comment 'Revenue amount the forecast owner commits to delivering with high confidence, typically used for executive reporting and board commitments.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Forecast owner\'s confidence in achieving the projected numbers: high (90%+ confidence), medium (70-89%), low (<70%).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Assumption' ;
    rdfs:comment 'Assumed overall win rate percentage applied to pipeline opportunities for this forecast (e.g., 25.00 means 25% expected to close).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastName rdf:type rdf:Property ;
    rdfs:label 'Forecast Name' ;
    rdfs:comment 'Descriptive name for the forecast period or scenario (e.g., Q3 Enterprise Pipeline Review).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Human-readable business identifier for the forecast snapshot (e.g., FY24-Q3-W12).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast: draft (in progress), submitted (under review), approved (finalized), locked (immutable), archived (historical).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of forecast by periodicity: weekly, monthly, quarterly, annual, or ad hoc.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPipelineAddedAmount rdf:type rdf:Property ;
    rdfs:label 'New Pipeline Added Amount' ;
    rdfs:comment 'Total value of new opportunities created during this forecast period, indicating lead generation effectiveness.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Pipeline Coverage Ratio' ;
    rdfs:comment 'Ratio of total pipeline value to quota target, indicating pipeline health (e.g., 3.0 means 3x coverage). Calculated as total_pipeline_value / quota_target_amount.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'Product category or service type scope for this forecast (e.g., wireless, broadband, fiber, enterprise solutions, all products).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedActivationsCount rdf:type rdf:Property ;
    rdfs:label 'Projected Activations Count' ;
    rdfs:comment 'Number of new subscriber activations or service connections forecasted to complete during the period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedAttainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Attainment Percentage' ;
    rdfs:comment 'Forecasted quota attainment percentage (projected_revenue_amount / quota_target_amount × 100), indicating expected performance against target.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedMrrAmount rdf:type rdf:Property ;
    rdfs:label 'Projected Mrr Amount' ;
    rdfs:comment 'Total forecasted Monthly Recurring Revenue (MRR) expected from new activations and upsells during the forecast period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Projected Revenue Amount' ;
    rdfs:comment 'Total forecasted revenue expected to close during the forecast period, calculated as sum of weighted pipeline opportunities.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Target Amount' ;
    rdfs:comment 'Revenue quota or target assigned to the forecast owner for this period, used as baseline for attainment projections.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slippageAmount rdf:type rdf:Property ;
    rdfs:label 'Slippage Amount' ;
    rdfs:comment 'Total value of opportunities that slipped from previous forecast periods into this period, indicating pipeline health and forecasting accuracy.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Exact date and time when this forecast snapshot was captured, enabling historical trend analysis and point-in-time comparisons.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stageCommitCount rdf:type rdf:Property ;
    rdfs:label 'Stage Commit Count' ;
    rdfs:comment 'Number of opportunities in commit/verbal agreement stage at snapshot time, representing high-confidence near-term closes.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageNegotiationCount rdf:type rdf:Property ;
    rdfs:label 'Stage Negotiation Count' ;
    rdfs:comment 'Number of opportunities in negotiation/contracting stage at snapshot time.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageProposalCount rdf:type rdf:Property ;
    rdfs:label 'Stage Proposal Count' ;
    rdfs:comment 'Number of opportunities in proposal/quote stage at snapshot time.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageProspectCount rdf:type rdf:Property ;
    rdfs:label 'Stage Prospect Count' ;
    rdfs:comment 'Number of opportunities in prospect/qualification stage at snapshot time.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Total Pipeline Value' ;
    rdfs:comment 'Total unweighted value of all opportunities in the pipeline for this forecast period, regardless of probability.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upsideOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Upside Opportunity Count' ;
    rdfs:comment 'Number of opportunities identified as upside potential (not yet in commit stage but could accelerate).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceToPreviousForecast rdf:type rdf:Property ;
    rdfs:label 'Variance To Previous Forecast' ;
    rdfs:comment 'Difference in projected revenue between this forecast and the previous period\'s forecast for the same time window, enabling trend analysis.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Total pipeline value adjusted by probability of close (sum of opportunity value × probability percentage for all opportunities in scope).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:worstCaseRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Worst Case Revenue Amount' ;
    rdfs:comment 'Conservative revenue projection accounting for potential slippage, delays, and lost opportunities.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Identifier of the opportunity record created upon lead conversion. Null if not yet converted.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:interestCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Interest Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Leads capture prospect interest in specific products/services. Sales qualification and conversion tracking require knowing which catalog items prospects are interested in. Essential for lead-to-revenu' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:ageDays rdf:type rdf:Property ;
    rdfs:label 'Age Days' ;
    rdfs:comment 'Number of days since the lead was created. Used for aging analysis and pipeline velocity metrics.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalesTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Team' ;
    rdfs:comment 'Name or identifier of the sales team responsible for this lead, such as consumer sales, enterprise sales, or partner channel team.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the lead was converted to an opportunity, account, and contact in the CRM system. Null if not yet converted.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason code or description for why the lead was marked as unqualified or closed lost. Used for process improvement and lead source quality analysis.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Boolean flag indicating the lead is on the Do Not Call list and must not be contacted via phone for marketing purposes.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Estimated total contract value over the expected contract term. Relevant for B2B and enterprise leads with multi-year commitments.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlyValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Value' ;
    rdfs:comment 'Estimated monthly recurring revenue (MRR) potential from this lead if converted to customer. Used for pipeline value forecasting.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstContactDate rdf:type rdf:Property ;
    rdfs:label 'First Contact Date' ;
    rdfs:comment 'Date when the lead was first contacted by sales representative. Used for SLA compliance tracking and lead aging analysis.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpSlaHours rdf:type rdf:Property ;
    rdfs:label 'Follow Up Sla Hours' ;
    rdfs:comment 'Number of hours within which the lead must be contacted per business SLA policy. Varies by lead priority and segment.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Letter grade representing the leads demographic and firmographic fit with ideal customer profile. A is highest fit, F is lowest.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestProductCategory rdf:type rdf:Property ;
    rdfs:label 'Interest Product Category' ;
    rdfs:comment 'Primary product or service category the lead expressed interest in, such as wireless, broadband, fiber internet, IPTV, enterprise connectivity, or IoT solutions.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestServiceType rdf:type rdf:Property ;
    rdfs:label 'Interest Service Type' ;
    rdfs:comment 'Specific service type the lead is interested in, such as 5G mobile, FTTH, SD-WAN, VoIP, IPTV, or managed services.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Number' ;
    rdfs:comment 'Human-readable business identifier for the lead, typically auto-generated in format LED-XXXXXXXX. Used for external communication and tracking.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin channel through which the lead was captured. Values include web form, marketing campaign, customer referral, retail walk-in, partner channel, event, or social media. [ENUM-REF-CANDIDATE: web_form|campaign|referral|walk_in|partner|event|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle status of the lead in the sales pipeline. Values include new, contacted, qualified (SQL), unqualified, converted to opportunity, closed lost, or nurturing (MQL). [ENUM-REF-CANDIDATE: new|contacted|qualified|unqualified|converted|closed_lost|nurturing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up activity with the lead. Used for task management and pipeline hygiene.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Boolean flag indicating whether the lead has consented to receive email marketing communications. Required for CAN-SPAM and GDPR compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Boolean flag indicating whether the lead has consented to receive phone marketing calls. Required for TCPA and Do Not Call registry compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Boolean flag indicating whether the lead has consented to receive SMS marketing communications. Required for TCPA compliance.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesTerritory rdf:type rdf:Property ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or organizational sales territory to which this lead is assigned, based on address or segment rules.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score representing the leads propensity to convert, based on demographic fit, engagement behavior, and predictive analytics. Higher scores indicate higher conversion probability.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Additional detail about the lead source, such as specific campaign name, partner name, event name, or referral source identifier.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Street address of the lead contact or business location. Used for service availability checks and territory assignment.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoAgreementId rdf:type rdf:Property ;
    rdfs:label 'Mvno Agreement Id' ;
    rdfs:comment 'Unique identifier for the MVNO wholesale commercial agreement. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MvnoAgreement .

ind:allowedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Allowed Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: MVNO agreements specify which offerings the partner can resell under their brand. Essential for partner catalog management, revenue share calculation, and ensuring MVNOs only provision authorized serv' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:primaryMvnoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mvno Employee Id' ;
    rdfs:comment 'Reference to the sales or account management employee responsible for managing the MVNO partner relationship.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wholesaleRateCardId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Rate Card Id' ;
    rdfs:comment 'Reference to the wholesale pricing rate card defining per-unit charges for voice, SMS, data, and other network services provided to the MVNO.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleRateCard .

ind:billingSettlementCycleDays rdf:type rdf:Property ;
    rdfs:label 'Billing Settlement Cycle Days' ;
    rdfs:comment 'Number of days in the billing cycle for wholesale usage settlement between host operator and MVNO partner.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedSubscriberVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Subscriber Volume' ;
    rdfs:comment 'Minimum number of active subscribers the MVNO partner commits to maintain under the agreement terms, used for volume-based pricing tiers.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedTrafficVolumeGb rdf:type rdf:Property ;
    rdfs:label 'Committed Traffic Volume Gb' ;
    rdfs:comment 'Minimum monthly data traffic volume in gigabytes the MVNO partner commits to generate, used for wholesale pricing and capacity planning.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacyResponsibility rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Responsibility' ;
    rdfs:comment 'Party responsible for subscriber data privacy compliance including CPNI protection and consent management under regulatory frameworks.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:e911ServiceResponsibility rdf:type rdf:Property ;
    rdfs:label 'E911 Service Responsibility' ;
    rdfs:comment 'Party responsible for providing E911 emergency location services for MVNO subscribers under regulatory requirements.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty amount payable by the MVNO partner if the agreement is terminated before the contract term expires.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esimSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Esim Support Flag' ;
    rdfs:comment 'Indicates whether the MVNO partner is entitled to provision and manage embedded SIM profiles for subscribers under this agreement.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imsAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Ims Access Flag' ;
    rdfs:comment 'Indicates whether the MVNO partner has access to the host operators IMS core for advanced multimedia services.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawfulInterceptResponsibility rdf:type rdf:Property ;
    rdfs:label 'Lawful Intercept Responsibility' ;
    rdfs:comment 'Party responsible for implementing and managing lawful intercept capabilities for MVNO subscriber traffic under regulatory requirements.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Mvno Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the MVNO agreement indicating its operational state and enforceability.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberPortabilitySupportFlag rdf:type rdf:Property ;
    rdfs:label 'Number Portability Support Flag' ;
    rdfs:comment 'Indicates whether the MVNO partner is entitled to support mobile number portability for subscribers porting numbers in or out.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qosPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Qos Priority Level' ;
    rdfs:comment 'Network traffic prioritization level assigned to MVNO subscriber traffic relative to host operator subscribers.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceObligations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Obligations' ;
    rdfs:comment 'Description of regulatory compliance responsibilities allocated between host operator and MVNO partner, including lawful intercept, E911, and data privacy.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingCoverageZones rdf:type rdf:Property ;
    rdfs:label 'Roaming Coverage Zones' ;
    rdfs:comment 'Geographic zones or country groups where MVNO subscribers are entitled to roaming services, expressed as comma-separated zone codes.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingEntitlementFlag rdf:type rdf:Property ;
    rdfs:label 'Roaming Entitlement Flag' ;
    rdfs:comment 'Indicates whether the MVNO partner subscribers are entitled to international and domestic roaming services under this agreement.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaPacketLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Packet Loss Percentage' ;
    rdfs:comment 'Maximum acceptable packet loss percentage guaranteed under the SLA for MVNO subscriber data traffic.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Clause' ;
    rdfs:comment 'Description of financial penalties or service credits applied when the host operator fails to meet SLA commitments.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Volte Support Flag' ;
    rdfs:comment 'Indicates whether the MVNO partner subscribers are entitled to VoLTE voice services over the 4G LTE network.' ;
    rdfs:domain ind:MvnoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Opportunities represent potential sales of specific products. Linking to catalog_item enables product mix analysis, win/loss reporting by SKU, revenue forecasting by product, and sales pipeline visibi' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:primaryOfferingId rdf:type rdf:Property ;
    rdfs:label 'Primary Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: Opportunities propose specific market offerings (bundled plans, enterprise solutions). This link supports opportunity-to-offering pipeline reporting, conversion rate analysis by offering type, and sal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date when the opportunity reached a terminal closed-won or closed-lost state. Null for opportunities still in active sales stages.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveThreatLevel rdf:type rdf:Property ;
    rdfs:label 'Competitive Threat Level' ;
    rdfs:comment 'Assessment of competitive pressure and risk of losing the opportunity to a competitor. Used for resource prioritization and executive escalation.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the primary competitor being displaced or competed against in this opportunity. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedMrr rdf:type rdf:Property ;
    rdfs:label 'Estimated Mrr' ;
    rdfs:comment 'Projected monthly recurring revenue from subscription services if the opportunity closes successfully. Key metric for subscription-based business model forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOneTimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated One Time Revenue' ;
    rdfs:comment 'Projected one-time revenue from activation fees, installation charges, equipment sales, and other non-recurring charges associated with this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity is expected to reach a terminal state (closed-won or closed-lost). Used for sales forecasting and pipeline management.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast classification indicating confidence level: pipeline (early stage), best case (possible), commit (high confidence), or closed (won). Used for revenue forecasting and quota tracking.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyStakeholders rdf:type rdf:Property ;
    rdfs:label 'Key Stakeholders' ;
    rdfs:comment 'Names and roles of key decision-makers and influencers within the prospect organization. Used for relationship mapping and sales strategy in complex B2B deals.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to progress the opportunity. Used for sales activity tracking and pipeline hygiene.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfDevices rdf:type rdf:Property ;
    rdfs:label 'Number Of Devices' ;
    rdfs:comment 'Quantity of customer premises equipment, handsets, routers, or IoT devices included in the opportunity. Used for inventory allocation and logistics planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Lines' ;
    rdfs:comment 'Quantity of mobile lines, broadband connections, or service instances included in this opportunity. Used for volume-based pricing and capacity planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Human-readable name or title of the sales opportunity, typically describing the prospect and solution being pursued.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-visible business identifier for the opportunity, used in communications and reporting. Format: OPP-NNNNNNNN.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity based on the nature of the sales pursuit: new customer acquisition, upsell to existing subscriber, cross-sell of additional services, contract renewal, customer winback, or technology migration.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProductOffering rdf:type rdf:Property ;
    rdfs:label 'Primary Product Offering' ;
    rdfs:comment 'Name or description of the primary product or service offering being sold in this opportunity (e.g., 5G Unlimited Plan, Fiber 1Gbps, Enterprise SD-WAN, MVNO Wholesale Agreement).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Probability Percent' ;
    rdfs:comment 'Estimated probability of winning this opportunity, expressed as an integer percentage (0-100). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Service Start Date' ;
    rdfs:comment 'Target date for service activation and contract commencement if the opportunity is won. Used for fulfillment planning and resource allocation.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Reference to the formal price quote or proposal document associated with this opportunity. Links to quote entity in sales domain.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:salesStage rdf:type rdf:Property ;
    rdfs:label 'Sales Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline lifecycle. Tracks progression from initial prospecting through qualification, proposal, negotiation, and terminal closed-won or closed-lost states. [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether this opportunity is for a strategic or key account requiring executive sponsorship and special handling. True for enterprise strategic accounts.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winLossReason rdf:type rdf:Property ;
    rdfs:label 'Win Loss Reason' ;
    rdfs:comment 'Primary reason for winning or losing the opportunity. Captured at close for sales effectiveness analysis and process improvement. Examples: price, coverage, features, competitor, timing, budget.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Promotion Employee Id' ;
    rdfs:comment 'User ID or email of the marketing or sales operations user who created this promotion record in the system.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Promotion Last Modified By User Employee Id' ;
    rdfs:comment 'User ID or email of the user who last modified this promotion record. Used for change tracking and accountability.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Target Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Promotions often target specific catalog items (e.g., "50% off iPhone 15 with unlimited plan"). This link is essential for promotion eligibility validation, redemption tracking, and measuring promotio' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:eligibleCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Eligible Customer Segment' ;
    rdfs:comment 'Target customer segment eligible for this promotion: b2c_consumer (retail individual), b2b_smb (small/medium business), b2b_enterprise (large corporate), mvno_wholesale (Mobile Virtual Network Operator partners), all_segments (universal offer).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProductCategory rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Category' ;
    rdfs:comment 'Comma-separated list of product categories or SKU patterns eligible for this promotion (e.g., \'wireless_postpaid\', \'fiber_internet\', \'device_smartphone\', \'all_products\'). Used to constrain which products can receive the discount.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Comma-separated list of product SKUs, customer IDs, or other identifiers explicitly excluded from this promotion. Used to enforce business rules and prevent unintended redemptions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPromotionReference rdf:type rdf:Property ;
    rdfs:label 'External Promotion Reference' ;
    rdfs:comment 'Unique identifier for this promotion in the source system (e.g., Salesforce Campaign ID, Netcracker Offering ID). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicEligibility rdf:type rdf:Property ;
    rdfs:label 'Geographic Eligibility' ;
    rdfs:comment 'Comma-separated list of geographic regions, states, or countries where this promotion is valid (e.g., \'USA\', \'CAN\', \'CA,NY,TX\', \'all_regions\'). Used to enforce regional marketing campaigns and regulatory compliance.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Contract Term Months' ;
    rdfs:comment 'Minimum service contract duration in months required to qualify for this promotion. For example, a device subsidy may require a 24-month commitment. Null if no minimum term applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum order or quote value required to qualify for this promotion. For example, enterprise volume discounts may require a $10,000 minimum. Null if no minimum applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for minimum_purchase_amount (e.g., USD, EUR, GBP). Null if minimum_purchase_amount is null.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Detailed business description of the promotion, including terms and conditions, eligibility criteria, and customer-facing messaging. Used for sales rep guidance and customer communication.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable marketing name of the promotion (e.g., \'Summer Device Subsidy\', \'Port-In Bonus Q1 2024\', \'Enterprise Volume Discount Tier 3\').' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion: draft (not yet live), active (available for redemption), suspended (temporarily paused), expired (end date passed), terminated (manually closed).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotion by incentive mechanism: device_subsidy (handset discount), free_months (service waiver), bundle_discount (multi-product discount), port_in_bonus (Mobile Number Portability incentive), byod_credit (Bring Your Own Device credit), volume_discount (enterprise bulk pricing).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Current count of how many times this promotion has been redeemed. Incremented with each successful application. Used to enforce redemption_limit_total.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Total' ;
    rdfs:comment 'Maximum number of times this promotion can be redeemed across all customers and transactions. Null indicates no cap. Used for limited-time or limited-quantity offers.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed Flag' ;
    rdfs:comment 'Indicates whether this promotion can be combined (stacked) with other promotions on the same quote or order. True = stackable, False = exclusive (cannot be combined).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Redemption Id' ;
    rdfs:comment 'Unique identifier for the promotion redemption transaction. Primary key for this entity.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPromotionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Promotion Employee Id' ;
    rdfs:comment 'Reference to the sales representative or agent who applied the promotion. Nullable for self-service redemptions.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPromotionApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Promotion Approved By User Employee Id' ;
    rdfs:comment 'The system user ID of the manager or approver who authorized this promotion redemption. Nullable if no approval was required.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Benefit Duration Months' ;
    rdfs:comment 'The number of months for which the promotion benefit applies. Nullable for one-time or unlimited duration promotions.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRedemptionsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions Allowed' ;
    rdfs:comment 'The maximum number of times this promotion can be redeemed within the defined limit scope. Nullable for unlimited promotions.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Effective Date' ;
    rdfs:comment 'The date when the promotion benefit becomes active for the customer. May differ from redemption date for future-dated promotions.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Expiry Date' ;
    rdfs:comment 'The date when the promotion benefit expires or ends. Defines the duration of the promotional offer.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurringBenefitFlag rdf:type rdf:Property ;
    rdfs:label 'Recurring Benefit Flag' ;
    rdfs:comment 'Indicates whether this promotion provides a recurring benefit over multiple billing cycles. True for ongoing discounts, false for one-time discounts.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The sales channel through which the promotion was redeemed. Indicates the customer touchpoint where the promotion was applied.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'The unique alphanumeric code or voucher number entered or scanned by the customer or sales representative to activate the promotion.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'The calendar date when the promotion was redeemed. Used for day-level reporting and analytics.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitType rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Type' ;
    rdfs:comment 'The scope or level at which redemption limits are enforced for this promotion. Defines the boundary for usage tracking.' ;
    rdfs:domain ind:PromotionRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'The exact date and time when the promotion was applied to the quote, order, or contract. Represents the business event time of redemption.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date when the customer formally accepted the quote, triggering contract creation or order fulfillment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the quote received internal management approval.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimaryVersion rdf:type rdf:Property ;
    rdfs:label 'Is Primary Version' ;
    rdfs:comment 'Indicates whether this version is the primary/active version of the quote. Only one version per quote number should be primary.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oneTimeCharges rdf:type rdf:Property ;
    rdfs:label 'One Time Charges' ;
    rdfs:comment 'Total one-time charges in the quote, including activation fees, installation fees, Customer Premises Equipment (CPE) costs, and setup charges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentedDate rdf:type rdf:Property ;
    rdfs:label 'Presented Date' ;
    rdfs:comment 'Date when the quote was formally presented or sent to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteDescription rdf:type rdf:Property ;
    rdfs:label 'Quote Description' ;
    rdfs:comment 'Detailed description of the quote, including service bundle details, special terms, and customer-specific notes.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteName rdf:type rdf:Property ;
    rdfs:label 'Quote Name' ;
    rdfs:comment 'Descriptive name or title for the quote, typically reflecting the service bundle or customer segment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally visible business identifier for the quote. Format: QT-YYYYMMDD followed by sequence.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the quote: draft (being prepared), pending approval (awaiting internal sign-off), approved (ready to present), presented (sent to customer), accepted (customer agreed), rejected (customer declined), expired (validity period lapsed), or withdrawn (cancelled by sales). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|presented|accepted|rejected|expired|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quote based on the nature of the commercial transaction: new service acquisition, service upgrade, contract renewal, service modification, or service disconnect.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedDate rdf:type rdf:Property ;
    rdfs:label 'Rejected Date' ;
    rdfs:comment 'Date when the customer formally rejected or declined the quote.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceActivationDate rdf:type rdf:Property ;
    rdfs:label 'Service Activation Date' ;
    rdfs:comment 'Proposed or committed date when services will be activated for the customer if the quote is accepted.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Subtotal amount before taxes and fees, representing the sum of all line item charges after discounts.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total Contract Value (TCV): the total revenue expected over the full contract term, including all recurring and one-time charges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Total Discount Amount' ;
    rdfs:comment 'Total discount amount applied across all line items in the quote, including promotional discounts, volume discounts, and negotiated price reductions.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Total Discount Percentage' ;
    rdfs:comment 'Overall discount percentage applied to the quote, calculated as total discount divided by list price total.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntilDate rdf:type rdf:Property ;
    rdfs:label 'Valid Until Date' ;
    rdfs:comment 'End date of the quote validity period. Quote expires after this date and pricing/terms are no longer guaranteed.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winProbabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percentage' ;
    rdfs:comment 'Estimated probability of winning the deal and converting the quote to a contract, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique identifier for the quote line item. Primary key.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLineQuoteLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Quote Line Id' ;
    rdfs:comment 'Reference to another quote line if this line is a dependent or child item. Supports hierarchical quote structures for complex telecom solutions.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:primaryQuoteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Employee Id' ;
    rdfs:comment 'Reference to the sales representative responsible for this quote line. Used for quota tracking and commission attribution.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether this line item qualifies for sales commission or dealer compensation. Some promotional or subsidized offerings may be commission-exempt.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationDetails rdf:type rdf:Property ;
    rdfs:label 'Configuration Details' ;
    rdfs:comment 'Technical configuration parameters or service specifications for this line item. Captures bandwidth tiers, Quality of Service (QoS) levels, Service Level Agreement (SLA) parameters, or Customer Premises Equipment (CPE) specifications.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'Total line amount calculated as unit_price multiplied by quantity. Represents the subtotal for this line before taxes.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Standard catalog price per unit before any discounts or promotions are applied. Represents the published rate card price.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalDescription rdf:type rdf:Property ;
    rdfs:label 'Promotional Description' ;
    rdfs:comment 'Human-readable description of the promotional offer applied to this line. Displayed on customer-facing quote documents.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionInteractionId rdf:type rdf:Property ;
    rdfs:label 'Retention Interaction Id' ;
    rdfs:comment 'Unique identifier for the retention interaction record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionInteraction .

ind:primaryRetentionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Retention Employee Id' ;
    rdfs:comment 'Reference to the customer service agent or sales representative who handled the retention interaction.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agentTeam rdf:type rdf:Property ;
    rdfs:label 'Agent Team' ;
    rdfs:comment 'Name or identifier of the team to which the handling agent belongs, used for performance tracking and workforce management.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Churn Reason Code' ;
    rdfs:comment 'Standardized code representing the primary reason the customer is considering cancellation or downgrade.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Churn Reason Description' ;
    rdfs:comment 'Detailed free-text description of the customer\'s stated reason for considering cancellation or service change.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorOfferDescription rdf:type rdf:Property ;
    rdfs:label 'Competitor Offer Description' ;
    rdfs:comment 'Description of the competing offer or promotion that the customer is considering, used for competitive analysis.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which follow-up action should be completed for this retention interaction.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up action is required to complete the retention interaction or fulfill commitments made to the customer.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Hold Time Seconds' ;
    rdfs:comment 'Total time in seconds that the customer was placed on hold during the retention interaction.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionChannel rdf:type rdf:Property ;
    rdfs:label 'Interaction Channel' ;
    rdfs:comment 'Channel through which the retention interaction was conducted, indicating the customer touchpoint used for the save attempt. [ENUM-REF-CANDIDATE: inbound_call|outbound_call|web_chat|mobile_app|email|retail_store|ivr — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Interaction Duration Seconds' ;
    rdfs:comment 'Total duration of the retention interaction in seconds, from initiation to completion or abandonment.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionNotes rdf:type rdf:Property ;
    rdfs:label 'Interaction Notes' ;
    rdfs:comment 'Free-text notes captured by the agent during the retention interaction, documenting key discussion points, customer concerns, and commitments made.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Business-facing unique identifier for the retention interaction, used for tracking and reference in customer service systems.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Status' ;
    rdfs:comment 'Status indicating whether the customer accepted, rejected, or is still considering the retention offer.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the customer accepted the retention offer, if applicable.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the retention offer presented, including terms, conditions, and benefits communicated to the customer.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Offer Eligibility Criteria' ;
    rdfs:comment 'Business rules and criteria that determined the customer\'s eligibility for the presented retention offer.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Presented Flag' ;
    rdfs:comment 'Indicates whether a retention offer was presented to the customer during the interaction.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Type of retention offer presented to the customer, categorizing the incentive used to prevent churn.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Offer Validity End Date' ;
    rdfs:comment 'Date when the retention offer expires and is no longer available for customer acceptance.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Offer Validity Start Date' ;
    rdfs:comment 'Date when the retention offer becomes valid and can be accepted by the customer.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerValueAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Value Amount' ;
    rdfs:comment 'Monetary value of the retention offer presented to the customer, representing the discount, credit, or incentive amount.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postSaveContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Post Save Contract Term Months' ;
    rdfs:comment 'Duration in months of the new or extended contract term resulting from the successful retention interaction.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postSaveMrrAmount rdf:type rdf:Property ;
    rdfs:label 'Post Save Mrr Amount' ;
    rdfs:comment 'Monthly recurring revenue amount for the customer after the retention interaction, reflecting any plan changes or discounts applied.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saveMethod rdf:type rdf:Property ;
    rdfs:label 'Save Method' ;
    rdfs:comment 'Method or approach used to achieve the save outcome, indicating how the retention was accomplished.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saveOutcome rdf:type rdf:Property ;
    rdfs:label 'Save Outcome' ;
    rdfs:comment 'Final result of the retention interaction indicating whether the customer was successfully retained, lost to churn, or outcome is pending.' ;
    rdfs:domain ind:RetentionInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionOfferId rdf:type rdf:Property ;
    rdfs:label 'Retention Offer Id' ;
    rdfs:comment 'Unique identifier for the retention offer record. Primary key.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Proposed Offering Id' ;
    rdfs:comment 'Foreign key linking to product.offering. Business justification: Retention offers propose specific product/plan changes to prevent churn (e.g., upgrade to unlimited plan). This link enables save offer effectiveness analysis by product, churn prevention ROI measurem' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:proposedPricePlanId rdf:type rdf:Property ;
    rdfs:label 'Proposed Price Plan Id' ;
    rdfs:comment 'Foreign key linking to product.price_plan. Business justification: Retention offers often involve price plan changes or discounts. Linking to price_plan enables offer cost analysis, margin impact tracking, and ensuring retention offers are financially sustainable—ess' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricePlan .

ind:acceptanceOutcome rdf:type rdf:Property ;
    rdfs:label 'Acceptance Outcome' ;
    rdfs:comment 'Final outcome of the retention offer indicating whether the subscriber accepted, rejected, or did not respond.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpuImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Arpu Impact Amount' ;
    rdfs:comment 'Estimated impact on Average Revenue Per User if the retention offer is accepted, expressed as a positive or negative monetary amount.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cltv Impact Amount' ;
    rdfs:comment 'Estimated impact on Customer Lifetime Value if the retention offer is accepted and the subscriber is retained.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Discount Duration Months' ;
    rdfs:comment 'Number of months the discount or promotional pricing will remain in effect if the offer is accepted.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCostAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Cost Amount' ;
    rdfs:comment 'Internal cost to the business of providing this retention offer, including discounts, credits, and subsidies.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Human-readable name of the retention offer presented to the subscriber.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerPriority rdf:type rdf:Property ;
    rdfs:label 'Offer Priority' ;
    rdfs:comment 'Priority ranking of this retention offer when multiple offers are available for the same subscriber, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Offer Valid From Date' ;
    rdfs:comment 'Date from which the retention offer becomes valid and can be accepted by the subscriber.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerValidUntilDate rdf:type rdf:Property ;
    rdfs:label 'Offer Valid Until Date' ;
    rdfs:comment 'Date until which the retention offer remains valid for subscriber acceptance.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:presentedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Presented Timestamp' ;
    rdfs:comment 'Date and time when the retention offer was presented to the subscriber during the save interaction.' ;
    rdfs:domain ind:RetentionOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primarySalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Employee Id' ;
    rdfs:comment 'Reference to the sales representative or account executive responsible for this contract.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySalesModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sales Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this contract record.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cpniAuthorizationIncluded rdf:type rdf:Property ;
    rdfs:label 'Cpni Authorization Included' ;
    rdfs:comment 'Indicates whether the contract includes Customer Proprietary Network Information (CPNI) authorization clauses allowing use of customer network usage data for marketing purposes, as required by FCC regulations.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:e911ComplianceClause rdf:type rdf:Property ;
    rdfs:label 'E911 Compliance Clause' ;
    rdfs:comment 'Indicates whether the contract includes Enhanced 911 (E911) service disclosure and compliance clauses for VoIP or wireless services, as mandated by FCC.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etfAmount rdf:type rdf:Property ;
    rdfs:label 'Etf Amount' ;
    rdfs:comment 'Maximum Early Termination Fee (ETF) amount charged for early contract cancellation. Actual fee may vary based on schedule type and remaining term. Null if no ETF applies.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etfScheduleType rdf:type rdf:Property ;
    rdfs:label 'Etf Schedule Type' ;
    rdfs:comment 'Type of Early Termination Fee (ETF) schedule applied if customer terminates before contract end: none (no penalty), flat (fixed fee), declining (reduces over time), or prorated (proportional to remaining term).' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Percentage' ;
    rdfs:comment 'Annual percentage increase applied to recurring charges if price lock is disabled. Null if no escalation clause exists.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceLockFlag rdf:type rdf:Property ;
    rdfs:label 'Price Lock Flag' ;
    rdfs:comment 'Indicates whether pricing is locked for the contract term (True) or subject to periodic adjustments (False).' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcvAmount rdf:type rdf:Property ;
    rdfs:label 'Tcv Amount' ;
    rdfs:comment 'Total Contract Value (TCV) representing the aggregate revenue expected over the full contract term, including all recurring and one-time charges.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Duration of the contract commitment period expressed in months (e.g., 12, 24, 36). Null for month-to-month or evergreen contracts.' ;
    rdfs:domain ind:SalesContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetId rdf:type rdf:Property ;
    rdfs:label 'Target Id' ;
    rdfs:comment 'Primary key for target' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user (typically a sales manager or director) who approved the target. Null if the target has not been approved.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the sales target record.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Employee Id' ;
    rdfs:comment 'Identifier of the individual sales representative to whom this target is assigned. Null if the target is assigned to a team, dealer, or channel rather than an individual.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Target Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the sales target record.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attainmentLastCalculatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Attainment Last Calculated Timestamp' ;
    rdfs:comment 'Timestamp when the attainment value and percentage were last recalculated. Supports near-real-time performance tracking.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attainmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Attainment Percentage' ;
    rdfs:comment 'Percentage of target achieved, calculated as (attainment_value / target_value) * 100. Used for sales performance dashboards and incentive calculation.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attainmentValue rdf:type rdf:Property ;
    rdfs:label 'Attainment Value' ;
    rdfs:comment 'Actual performance value achieved against the target as of the last calculation date. Updated periodically during the measurement period.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Frequency or duration type of the target measurement period. Monthly targets reset each month; quarterly targets align with fiscal quarters; annual targets span the fiscal year; custom periods have user-defined start and end dates.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sales target, used for reference in sales performance management systems and incentive calculation workflows.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable descriptive name of the sales target (e.g., \'Q1 2024 Enterprise 5G Activations - Northeast Region\').' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Classification of the sales target by measurement type. Revenue targets measure monetary goals; activations measure new subscriber additions; ARPU (Average Revenue Per User) targets measure per-customer revenue; churn saves measure customer retention; upsell and cross-sell measure product expansion.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdAccelerator rdf:type rdf:Property ;
    rdfs:label 'Threshold Accelerator' ;
    rdfs:comment 'Performance threshold above which accelerated incentive rates apply (e.g., 120% attainment triggers 1.5x commission rate). Null if no accelerator applies.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdMinimum rdf:type rdf:Property ;
    rdfs:label 'Threshold Minimum' ;
    rdfs:comment 'Minimum performance threshold required for any incentive payout. Attainment below this value results in zero payout. Null if no minimum threshold applies.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightFactor rdf:type rdf:Property ;
    rdfs:label 'Weight Factor' ;
    rdfs:comment 'Weighting factor for this target when calculating composite performance scores across multiple targets. Expressed as a decimal (e.g., 0.30 for 30% weight). Sum of all target weights for a rep/team should equal 1.00.' ;
    rdfs:domain ind:Target ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activationEventId rdf:type rdf:Property ;
    rdfs:label 'Activation Event Id' ;
    rdfs:comment 'Unique identifier for the service activation event record. Primary key for the activation event entity.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Activation Technician Id' ;
    rdfs:comment 'Reference to the field technician who performed the activation, if applicable. Null for automated or remote activations.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:svcLocationId rdf:type rdf:Property ;
    rdfs:label 'Svc Location Id' ;
    rdfs:comment 'Reference to the physical service location or address where the service was activated. Links to the service delivery address.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcLocation .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'System or interface channel through which the activation was executed. May include Oracle OSM, Netcracker OSS, Element Management System (EMS), Network Management System (NMS), command-line interface (CLI), Application Programming Interface (API), or self-service portal. [ENUM-REF-CANDIDATE: OSM|Netcracker|EMS|NMS|CLI|API|portal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Activation Error Code' ;
    rdfs:comment 'Error code returned by the network element or provisioning system if activation failed or encountered issues. Null for successful activations.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Activation Error Message' ;
    rdfs:comment 'Detailed error message or description associated with the activation error code. Provides troubleshooting context for failed activations.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthAllocatedMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Allocated Mbps' ;
    rdfs:comment 'Bandwidth allocated to the service at activation, measured in megabits per second (Mbps). Defines the service speed tier.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esimProfileDownloadStatus rdf:type rdf:Property ;
    rdfs:label 'Esim Profile Download Status' ;
    rdfs:comment 'Status of the embedded SIM (eSIM) profile download confirmation at activation. Indicates whether the eSIM profile was successfully provisioned to the device.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimProfileIccid rdf:type rdf:Property ;
    rdfs:label 'Esim Profile Iccid' ;
    rdfs:comment 'Integrated Circuit Card Identifier (ICCID) of the eSIM profile that was activated. Uniquely identifies the eSIM profile downloaded to the device.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackActivationFlag rdf:type rdf:Property ;
    rdfs:label 'Fallback Activation Flag' ;
    rdfs:comment 'Boolean indicator of whether a fallback or alternate activation procedure was used. True if primary activation method failed and fallback was invoked.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fallbackReason rdf:type rdf:Property ;
    rdfs:label 'Fallback Reason' ;
    rdfs:comment 'Reason or error code that triggered the fallback activation procedure. Null if no fallback was required.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsRegistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ims Registration Timestamp' ;
    rdfs:comment 'Timestamp when the service successfully registered with the IP Multimedia Subsystem (IMS) core network. Null if IMS registration is not applicable or failed.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qosProfileApplied rdf:type rdf:Property ;
    rdfs:label 'Qos Profile Applied' ;
    rdfs:comment 'Quality of Service (QoS) profile identifier or name applied to the service at activation. Defines bandwidth, latency, jitter, and packet loss parameters.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Count' ;
    rdfs:comment 'Number of retry attempts made before successful activation or final failure. Zero indicates success on first attempt.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaActualActivationTime rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Activation Time' ;
    rdfs:comment 'Actual activation time in minutes from order submission to service active state. Used to calculate SLA compliance and identify breaches.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetActivationTime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Activation Time' ;
    rdfs:comment 'Target activation time in minutes as defined in the Service Level Agreement (SLA). Used to measure compliance with contractual activation commitments.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volteRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Volte Registration Status' ;
    rdfs:comment 'Voice over LTE (VoLTE) or IP Multimedia Subsystem (IMS) registration status at the moment of activation. Indicates whether the service successfully registered with the IMS core for voice services.' ;
    rdfs:domain ind:ActivationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthOntConfigId rdf:type rdf:Property ;
    rdfs:label 'Ftth Ont Config Id' ;
    rdfs:comment 'Unique identifier for the FTTH ONT configuration record. Primary key for this master resource entity representing the logical-to-physical binding between FTTH service instance and passive optical network infrastructure.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installedByTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Installed By Technician Id' ;
    rdfs:comment 'Identifier of the field technician who performed the ONT installation. Used for quality tracking and accountability.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:oltNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Olt Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: FTTH ONT configurations must reference the OLT network element for fiber service provisioning, PON port management, and fault isolation. Critical for fiber network operations, capacity planning, and s' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:ontDeviceModelId rdf:type rdf:Property ;
    rdfs:label 'Ont Device Model Id' ;
    rdfs:comment 'Foreign key linking to product.device_model. Business justification: FTTH provisioning requires ONT device model specifications (firmware, PON technology, port count) for OLT configuration. Removes denormalized ont_model and ont_vendor attributes, enforcing 3NF.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceModel .

ind:ontAssetId rdf:type rdf:Property ;
    rdfs:label 'Ont Ont Asset Id' ;
    rdfs:comment 'Logical identifier assigned to the ONT within the PON port context (0-127 for GPON). Used in PLOAM messages and bandwidth allocation.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntAsset .

ind:autoDiscoveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Discovery Enabled' ;
    rdfs:comment 'Indicates whether the ONT is configured for automatic discovery and provisioning when connected to the PON. Simplifies zero-touch deployment.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationNotes rdf:type rdf:Property ;
    rdfs:label 'Configuration Notes' ;
    rdfs:comment 'Free-text field for operational notes, special configuration requirements, or troubleshooting history related to this ONT.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvlanNumber rdf:type rdf:Property ;
    rdfs:label 'Cvlan Number' ;
    rdfs:comment 'Customer VLAN (inner VLAN tag) used in QinQ double-tagging for end-customer service identification within carrier network.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Downstream Bandwidth Mbps' ;
    rdfs:comment 'Configured downstream bandwidth limit in megabits per second. Represents the maximum download speed available to the customer.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downstreamBandwidthProfile rdf:type rdf:Property ;
    rdfs:label 'Downstream Bandwidth Profile' ;
    rdfs:comment 'Name or identifier of the bandwidth profile governing downstream traffic from OLT to ONT. Defines service tier bandwidth limits.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Fiber Distance Meters' ;
    rdfs:comment 'Physical distance in meters from OLT to ONT along the fiber path. Used for optical budget calculations and troubleshooting.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gemPortNumber rdf:type rdf:Property ;
    rdfs:label 'Gem Port Number' ;
    rdfs:comment 'GEM port identifier for traffic segmentation and QoS mapping. Multiple GEM ports can be assigned to a single ONT for service differentiation.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipv6Enabled rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Enabled' ;
    rdfs:comment 'Indicates whether IPv6 protocol support is enabled on this ONT configuration. Required for dual-stack or IPv6-only service delivery.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managedInSystem rdf:type rdf:Property ;
    rdfs:label 'Managed In System' ;
    rdfs:comment 'Source system responsible for managing this ONT configuration. Identifies the authoritative OSS/EMS platform for configuration changes.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multicastEnabled rdf:type rdf:Property ;
    rdfs:label 'Multicast Enabled' ;
    rdfs:comment 'Indicates whether IGMP multicast is enabled for IPTV service delivery to this ONT. Required for live TV channel distribution.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oltChassisSlot rdf:type rdf:Property ;
    rdfs:label 'Olt Chassis Slot' ;
    rdfs:comment 'Physical slot number in the OLT chassis where the line card serving this ONT is installed. Used for capacity planning and fault isolation.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oltPonPort rdf:type rdf:Property ;
    rdfs:label 'Olt Pon Port' ;
    rdfs:comment 'PON port number on the OLT line card to which this ONT is connected. Each PON port supports up to 128 ONTs in GPON architecture.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ontFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Ont Firmware Version' ;
    rdfs:comment 'Current firmware version running on the ONT device. Tracked for security patching, feature enablement, and troubleshooting.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Ont Location Description' ;
    rdfs:comment 'Textual description of the ONT physical installation location at customer premises (e.g., basement, garage, utility closet). Aids field technicians during service calls.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svlanNumber rdf:type rdf:Property ;
    rdfs:label 'Svlan Number' ;
    rdfs:comment 'Service VLAN (outer VLAN tag) used in QinQ double-tagging for carrier-grade service delivery and wholesale scenarios.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tcontNumber rdf:type rdf:Property ;
    rdfs:label 'Tcont Number' ;
    rdfs:comment 'T-CONT identifier for upstream bandwidth allocation in GPON. Each T-CONT represents a traffic container with specific QoS characteristics.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upstreamBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Upstream Bandwidth Mbps' ;
    rdfs:comment 'Configured upstream bandwidth limit in megabits per second. Represents the maximum upload speed available to the customer.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upstreamBandwidthProfile rdf:type rdf:Property ;
    rdfs:label 'Upstream Bandwidth Profile' ;
    rdfs:comment 'Name or identifier of the bandwidth profile governing upstream traffic from ONT to OLT. Defines assured, maximum, and fixed bandwidth allocations.' ;
    rdfs:domain ind:FtthOntConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Number Assignment Id' ;
    rdfs:comment 'Unique identifier for the number assignment record. Primary key.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'The geographic area code or national destination code portion of the number. Applicable to geographic numbers.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business reason for this number assignment. Distinguishes between new activations, replacements, and porting scenarios.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnamDisplayName rdf:type rdf:Property ;
    rdfs:label 'Cnam Display Name' ;
    rdfs:comment 'The caller ID display name associated with this number. Used for outbound call identification.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCallRegistryFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Call Registry Flag' ;
    rdfs:comment 'Indicates whether the subscriber has registered this number on the national Do Not Call registry. Restricts telemarketing calls.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Donor Carrier Code' ;
    rdfs:comment 'The carrier code of the previous service provider from which the number was ported in. Nullable if the number was not ported.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Enabled' ;
    rdfs:comment 'Indicates whether the number is enabled for emergency services (E911, E112). Critical for regulatory compliance and public safety.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlrLocation rdf:type rdf:Property ;
    rdfs:label 'Hlr Location' ;
    rdfs:comment 'The HLR or HSS node where the subscriber profile for this number is stored. Critical for routing and service provisioning.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lidbListingFlag rdf:type rdf:Property ;
    rdfs:label 'Lidb Listing Flag' ;
    rdfs:comment 'Indicates whether the number is listed in the LIDB for billing and validation purposes. Applicable primarily to North American carriers.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberCategory rdf:type rdf:Property ;
    rdfs:label 'Number Category' ;
    rdfs:comment 'Service category for which the number is assigned. Distinguishes between human-facing and machine-to-machine usage.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberType rdf:type rdf:Property ;
    rdfs:label 'Number Type' ;
    rdfs:comment 'Classification of the assigned number based on regulatory and technical categorization. Determines routing, billing, and regulatory treatment.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberUsageType rdf:type rdf:Property ;
    rdfs:label 'Number Usage Type' ;
    rdfs:comment 'Indicates the primary service type for which the number is used. Some numbers may be voice-only, SMS-only, or support all services.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Port Completion Date' ;
    rdfs:comment 'The date when the MNP port transaction was completed and the number was successfully transferred.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portRequestDate rdf:type rdf:Property ;
    rdfs:label 'Port Request Date' ;
    rdfs:comment 'The date when the MNP port request was initiated. Applicable to both port-in and port-out scenarios.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousMsisdn rdf:type rdf:Property ;
    rdfs:label 'Previous Msisdn' ;
    rdfs:comment 'The previous number assigned to this service instance, if this is a replacement assignment. Supports number change history tracking.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineEndDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine End Date' ;
    rdfs:comment 'The date when the number exits the regulatory quarantine period and becomes available for reassignment. Applicable after release to prevent customer confusion.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Carrier Code' ;
    rdfs:comment 'The carrier code of the new service provider to which the number is being ported out. Nullable if the number is not being ported out.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryOwnership rdf:type rdf:Property ;
    rdfs:label 'Regulatory Ownership' ;
    rdfs:comment 'Indicates whether the carrier owns the number range outright, leases it from the regulator, or sub-allocates it from another carrier.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Reservation Expiry Date' ;
    rdfs:comment 'The date when a reserved number assignment expires if not activated. Applicable only to reserved status assignments.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vanityNumberFlag rdf:type rdf:Property ;
    rdfs:label 'Vanity Number Flag' ;
    rdfs:comment 'Indicates whether the number is a vanity or premium number with special alphanumeric patterns or easy-to-remember sequences. May carry premium pricing.' ;
    rdfs:domain ind:NumberAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningFalloutId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Fallout Id' ;
    rdfs:comment 'Unique identifier for the provisioning fallout record. Primary key.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To User Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: Provisioning fallout resolution requires employee assignment tracking for workforce accountability, SLA compliance reporting, and performance management. Telecommunications operations mandate clear ow' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedIncidentNocIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Noc Incident Id' ;
    rdfs:comment 'Reference to any related incident ticket in ServiceNow ITSM or other incident management system that was opened for this fallout.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocIncident .

ind:customerImpact rdf:type rdf:Property ;
    rdfs:label 'Customer Impact' ;
    rdfs:comment 'Assessment of the impact on customer service availability or quality resulting from the provisioning failure.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCategory rdf:type rdf:Property ;
    rdfs:label 'Error Category' ;
    rdfs:comment 'High-level classification of the error type for reporting and trend analysis purposes. [ENUM-REF-CANDIDATE: configuration|connectivity|authentication|resource_unavailable|timeout|data_validation|system_error — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Detailed human-readable description of the error condition, including technical details and context from the source system.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalVendorInvolved rdf:type rdf:Property ;
    rdfs:label 'External Vendor Involved' ;
    rdfs:comment 'Indicates whether resolution required involvement of an external vendor or partner (equipment manufacturer, MVNO partner, interconnect carrier).' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failedSystemName rdf:type rdf:Property ;
    rdfs:label 'Failed System Name' ;
    rdfs:comment 'Name of the specific system or network element that generated the failure, such as Oracle OSM, Netcracker OSS, or a specific RAN node identifier.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureLayer rdf:type rdf:Property ;
    rdfs:label 'Failure Layer' ;
    rdfs:comment 'The architectural layer where the provisioning failure originated: network element, OSS system, BSS system, integration middleware, or external vendor system.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureStep rdf:type rdf:Property ;
    rdfs:label 'Failure Step' ;
    rdfs:comment 'The specific provisioning workflow step or task where the failure occurred, such as network element configuration, inventory update, or service activation.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutNumber rdf:type rdf:Property ;
    rdfs:label 'Fallout Number' ;
    rdfs:comment 'Human-readable business identifier for the fallout event, typically generated by the OSS fallout management module.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falloutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fallout Timestamp' ;
    rdfs:comment 'Date and time when the provisioning fallout event was first detected and recorded by the OSS system.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryReached rdf:type rdf:Property ;
    rdfs:label 'Max Retry Reached' ;
    rdfs:comment 'Indicates whether the fallout occurred because the maximum configured retry threshold was exceeded.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether automated notification was sent to relevant stakeholders (customer, operations team, management) about the provisioning delay.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of any preventive measures or process improvements implemented to avoid recurrence of similar fallout patterns.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCategory rdf:type rdf:Property ;
    rdfs:label 'Resolution Category' ;
    rdfs:comment 'Classification of the resolution approach used to clear the fallout condition.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from fallout detection to resolution, used for MTTR analysis and operational KPIs.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachRisk rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Risk' ;
    rdfs:comment 'Indicates whether the provisioning delay poses a risk of breaching committed service activation SLA targets.' ;
    rdfs:domain ind:ProvisioningFallout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Id' ;
    rdfs:comment 'Foreign key linking to interconnect.interconnect_carrier. Business justification: International or MVNO provisioning orders require tracking the partner/wholesale carrier for IoT global SIM activation, roaming profile setup, and inter-carrier provisioning coordination workflows.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:serviceInstanceId rdf:type rdf:Property ;
    rdfs:label 'Service Instance Id' ;
    rdfs:comment 'Reference to the logical service instance being provisioned, modified, or deprovisioned.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:activationTaskCount rdf:type rdf:Property ;
    rdfs:label 'Activation Task Count' ;
    rdfs:comment 'Total number of individual activation tasks or steps that comprise this provisioning order, as one order may span multiple network domains and systems.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedTaskCount rdf:type rdf:Property ;
    rdfs:label 'Completed Task Count' ;
    rdfs:comment 'Number of activation tasks that have been successfully completed, used to calculate provisioning progress percentage.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falloutFlag rdf:type rdf:Property ;
    rdfs:label 'Fallout Flag' ;
    rdfs:comment 'Indicates whether this provisioning order has entered fallout state due to execution failure requiring manual intervention or retry.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mnpPortType rdf:type rdf:Property ;
    rdfs:label 'Mnp Port Type' ;
    rdfs:comment 'Indicates whether this provisioning order involves Mobile Number Portability (MNP) porting in from another carrier or porting out to another carrier.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orchestrationState rdf:type rdf:Property ;
    rdfs:label 'Orchestration State' ;
    rdfs:comment 'Current state within the Oracle Order and Service Management (OSM) or Netcracker orchestration workflow state machine. Captures granular step-level execution state.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ossOrderReference rdf:type rdf:Property ;
    rdfs:label 'Oss Order Reference' ;
    rdfs:comment 'Native order identifier or reference number in the source Operations Support Systems (OSS) platform, used for cross-system reconciliation and troubleshooting.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ossSystem rdf:type rdf:Property ;
    rdfs:label 'Oss System' ;
    rdfs:comment 'Primary Operations Support Systems (OSS) or Business Support Systems (BSS) platform executing this provisioning order. Includes Oracle Order and Service Management (OSM), Netcracker, Nokia NetAct, Ericsson Network Manager, Amdocs, and other systems.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Porting Timestamp' ;
    rdfs:comment 'Actual timestamp when the Mobile Number Portability (MNP) porting cutover was executed and the subscriber number was transferred between carriers.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningNotes rdf:type rdf:Property ;
    rdfs:label 'Provisioning Notes' ;
    rdfs:comment 'Free-text notes capturing special instructions, customer requirements, or operational observations relevant to provisioning execution and fallout resolution.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedActivationDate rdf:type rdf:Property ;
    rdfs:label 'Requested Activation Date' ;
    rdfs:comment 'Customer-requested or business-scheduled date for service activation or provisioning completion.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Result of pre-activation service testing or qualification step, particularly for enterprise Fiber to the Home (FTTH) or Multiprotocol Label Switching (MPLS) delivery where service quality must be validated before customer handoff.' ;
    rdfs:domain ind:ProvisioningOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyId rdf:type rdf:Property ;
    rdfs:label 'Dependency Id' ;
    rdfs:comment 'Unique identifier for the service dependency relationship record. Primary key for the service dependency entity.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childServiceInstanceSvcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Child Service Instance Svc Instance Id' ;
    rdfs:comment 'Reference to the child or dependent service instance in the dependency relationship. For bundle compositions, this is a component service (e.g., broadband, VoIP, or IPTV within triple-play). For technology dependencies, this is the dependent service (e.g., VoLTE service depending on data bearer). For 5G network slices, this is the underlying connectivity service. For wholesale/MVNO scenarios, this is the virtual service layer.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:dependencySvcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Dependency Svc Instance Id' ;
    rdfs:comment 'Reference to the parent service instance in the dependency relationship. For bundle compositions, this is the container service (e.g., triple-play bundle). For technology dependencies, this is the prerequisite service (e.g., data bearer for VoLTE). For 5G network slices, this is the slice instance. For wholesale/MVNO scenarios, this is the host carrier service.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:activationSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Activation Sequence Order' ;
    rdfs:comment 'Numeric order indicating the sequence in which dependent services must be activated. Lower numbers activate first. Used by orchestration systems to ensure correct provisioning sequencing. For example, in a triple-play bundle, broadband (order 1) must activate before VoIP (order 2) and IPTV (order 3).' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingImpactType rdf:type rdf:Property ;
    rdfs:label 'Billing Impact Type' ;
    rdfs:comment 'Indicates how the dependency relationship affects billing. Bundle_discount means the dependency enables bundle pricing or discounts. Separate_billing means each service is billed independently despite the dependency. Consolidated_billing means services are billed together as a single line item. No_impact means the dependency has no billing implications.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCompositionFlag rdf:type rdf:Property ;
    rdfs:label 'Bundle Composition Flag' ;
    rdfs:comment 'Indicates whether this dependency represents a commercial bundle composition (e.g., triple-play, quad-play, family plan). True means this is a bundle relationship where parent is the bundle container and children are component services. False means this is a technical or operational dependency.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childServiceType rdf:type rdf:Property ;
    rdfs:label 'Child Service Type' ;
    rdfs:comment 'Denormalized service type of the child service instance for faster querying and reporting without joining to service instance table. Examples: voip, iptv, data_bearer, volte, connectivity_service.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Deactivation Sequence Order' ;
    rdfs:comment 'Numeric order indicating the sequence in which dependent services must be deactivated or suspended. Typically reverse of activation order. Used to ensure graceful shutdown without breaking dependencies. For example, IPTV (order 1) deactivates before VoIP (order 2) and broadband (order 3).' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dependencyCategory rdf:type rdf:Property ;
    rdfs:label 'Dependency Category' ;
    rdfs:comment 'High-level categorization of the dependency purpose. Commercial indicates bundle or pricing-driven relationships. Technical indicates technology stack or protocol dependencies. Regulatory indicates compliance-mandated relationships. Operational indicates process or workflow dependencies.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Dependency Status' ;
    rdfs:comment 'Current lifecycle status of the dependency relationship. Active indicates the dependency is currently in effect. Inactive indicates the dependency exists but is not currently enforced. Suspended indicates temporary hold. Pending indicates the dependency is being established. Terminated indicates the dependency has been permanently removed.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date and time when the service dependency relationship ended or was terminated. Null indicates the dependency is currently active. Used for historical analysis and audit trails of service relationship changes.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date and time when the service dependency relationship became active and enforceable. Used for temporal tracking of dependency lifecycle and historical analysis of service compositions.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalDependencyCode rdf:type rdf:Property ;
    rdfs:label 'External Dependency Code' ;
    rdfs:comment 'External system identifier for this dependency relationship in the source OSS/BSS system. Used for reconciliation and integration with upstream systems. Enables bidirectional traceability between lakehouse and operational systems.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureHandlingPolicy rdf:type rdf:Property ;
    rdfs:label 'Failure Handling Policy' ;
    rdfs:comment 'Defines how provisioning or lifecycle failures should be handled when they occur in the dependency chain. Rollback_all means any failure triggers rollback of all related services. Continue_partial means successful services remain active. Manual_intervention means failures require human review. Retry_automatic means system automatically retries failed operations.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactPropagationRule rdf:type rdf:Property ;
    rdfs:label 'Impact Propagation Rule' ;
    rdfs:comment 'Defines how lifecycle changes to the parent service propagate to child services. Cascade_suspend means if parent suspends, children auto-suspend. Cascade_terminate means if parent terminates, children auto-terminate. Notify_only means changes generate alerts but do not auto-propagate. Block_parent_change means parent cannot change state if children are active. Isolate means no propagation occurs.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Dependency Flag' ;
    rdfs:comment 'Indicates whether the dependency is mandatory for service operation. True means the child service cannot function without the parent, or the parent cannot exist without the child. False means the dependency is optional or advisory. Used by provisioning systems to enforce hard constraints.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvnoWholesaleFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Wholesale Flag' ;
    rdfs:comment 'Indicates whether this dependency represents a wholesale or MVNO virtual service layer relationship. True means the parent is a host carrier service and the child is a virtual service provided by an MVNO or wholesale partner. False means this is not a wholesale/MVNO relationship.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkSliceDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Network Slice Dependency Flag' ;
    rdfs:comment 'Indicates whether this dependency represents a 5G network slice composition. True means the parent is a network slice instance and the child is an underlying connectivity or transport service. False means this is not a slice-related dependency. Essential for 5G slice orchestration and lifecycle management.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orchestrationConstraint rdf:type rdf:Property ;
    rdfs:label 'Orchestration Constraint' ;
    rdfs:comment 'Free-text description of any special orchestration constraints or rules that apply to this dependency. For example, \'Parent must be fully activated before child provisioning begins\' or \'Child suspension requires 24-hour notice to parent subscriber\'. Used by OSS orchestration engines.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentServiceType rdf:type rdf:Property ;
    rdfs:label 'Parent Service Type' ;
    rdfs:comment 'Denormalized service type of the parent service instance for faster querying and reporting without joining to service instance table. Examples: broadband, mobile, bundle, network_slice, wholesale_service.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Qos Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child service inherits QoS profile settings from the parent service. True means child uses parent QoS parameters. False means child has independent QoS configuration. Important for network slice scenarios where slice QoS applies to all component services.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child service inherits SLA parameters from the parent service. True means child adopts parent SLA targets and commitments. False means child has independent SLA. Relevant for bundle compositions where all components share a single SLA tier.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'Indicates the strength or enforcement level of the dependency. Hard means the dependency is strictly enforced by provisioning systems and cannot be violated. Soft means the dependency is recommended but can be overridden with approval. Advisory means the dependency is informational only and not enforced.' ;
    rdfs:domain ind:Dependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationCode rdf:type rdf:Property ;
    rdfs:label 'Confirmation Code' ;
    rdfs:comment 'Security code used to authenticate the profile download request. Prevents unauthorized profile downloads. Part of the activation code and validated by the SM-DP+ during the download process.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was permanently deleted from the eUICC. The profile is removed from storage and cannot be recovered. The ICCID may be reused for a new profile.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceModel rdf:type rdf:Property ;
    rdfs:label 'Device Model' ;
    rdfs:comment 'Make and model of the device where this eSIM profile is installed. Used for device compatibility tracking, troubleshooting, and targeted service offerings.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disabled Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was disabled and deactivated from network access. The profile remains on the eUICC but cannot connect to the mobile network until re-enabled.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enabledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enabled Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was enabled and activated for network access. The profile is now the active profile on the eUICC and can connect to the mobile network.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:euiccFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Euicc Firmware Version' ;
    rdfs:comment 'Version of the firmware running on the eUICC chip. Determines compatibility with different profile formats, security features, and RSP specification versions.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was successfully installed on the eUICC. The profile is now stored on the chip but not yet enabled for network access.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isMnpEligible rdf:type rdf:Property ;
    rdfs:label 'Is Mnp Eligible' ;
    rdfs:comment 'Indicates whether this eSIM profile is eligible for Mobile Number Portability (MNP). True if the MSISDN can be ported to another operator, false if porting is restricted or not supported.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMultiProfileEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Multi Profile Enabled' ;
    rdfs:comment 'Indicates whether this eSIM profile is part of a multi-profile eUICC configuration. True if the eUICC can store and switch between multiple profiles, false if it supports only a single profile.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Roaming Enabled' ;
    rdfs:comment 'Indicates whether international and domestic roaming is enabled for this eSIM profile. True if the profile can connect to partner networks outside the home network, false if roaming is disabled.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastLocationUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Location Update Timestamp' ;
    rdfs:comment 'Date and time when the network last received a location update from this eSIM profile. Used for subscriber location tracking, emergency services, and roaming analytics.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastNetworkAttachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Network Attach Timestamp' ;
    rdfs:comment 'Date and time when this eSIM profile last successfully attached to the mobile network. Used for activity monitoring, fraud detection, and service usage analytics.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lpaVersion rdf:type rdf:Property ;
    rdfs:label 'Lpa Version' ;
    rdfs:comment 'Version of the Local Profile Assistant (LPA) software on the device. The LPA manages profile download, installation, enabling, disabling, and deletion on the eUICC.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingCode rdf:type rdf:Property ;
    rdfs:label 'Matching Code' ;
    rdfs:comment 'Unique identifier used by the SM-DP+ to match the eUICC with the correct profile during download. Part of the activation code and used in the secure profile download handshake.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileClass rdf:type rdf:Property ;
    rdfs:label 'Profile Class' ;
    rdfs:comment 'Business classification of the eSIM profile. Consumer profiles for handsets and tablets, M2M (Machine-to-Machine) profiles for connected devices, IoT (Internet of Things) profiles for low-power sensors and embedded systems.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNickname rdf:type rdf:Property ;
    rdfs:label 'Profile Nickname' ;
    rdfs:comment 'User-defined friendly name for the eSIM profile displayed in the device settings. Helps subscribers distinguish between multiple profiles on the same eUICC (e.g., \'Personal\', \'Work\', \'Travel\').' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileSizeKb rdf:type rdf:Property ;
    rdfs:label 'Profile Size Kb' ;
    rdfs:comment 'Size of the encrypted eSIM profile package in kilobytes. Used for eUICC storage capacity planning and download bandwidth estimation.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileState rdf:type rdf:Property ;
    rdfs:label 'Profile State' ;
    rdfs:comment 'Current lifecycle state of the eSIM profile on the eUICC. Tracks the profile from creation through download, installation, activation, and deletion. Managed by the Local Profile Assistant (LPA) on the device. [ENUM-REF-CANDIDATE: available|downloading|downloaded|installing|installed|enabled|disabled|deleted — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileVersion rdf:type rdf:Property ;
    rdfs:label 'Profile Version' ;
    rdfs:comment 'Version number of the eSIM profile format and content. Indicates the profile generation and compatibility with different eUICC firmware versions and RSP specification releases.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Provisioned Timestamp' ;
    rdfs:comment 'Date and time when the eSIM profile was created and encrypted on the SM-DP+ server. Marks the beginning of the profile lifecycle before download.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:smdsAddress rdf:type rdf:Property ;
    rdfs:label 'Smds Address' ;
    rdfs:comment 'Fully qualified domain name (FQDN) or IP address of the SM-DS server used for profile discovery. The SM-DS enables the eUICC to discover available profiles from multiple SM-DP+ servers in multi-operator scenarios.' ;
    rdfs:domain ind:EsimProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMnpRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Mnp Request Id' ;
    rdfs:comment 'Unique identifier for the mobile number portability request transaction. Primary key for the service MNP request entity.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Donor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner. Business justification: MNP requests require linking donor operator to partner entity for interconnect settlement, dispute resolution with donor, and regulatory clearinghouse reporting. Replaces denormalized donor_operator_n' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:interconnectMnpTransactionId rdf:type rdf:Property ;
    rdfs:label 'Interconnect Mnp Transaction Id' ;
    rdfs:comment 'Foreign key linking to interconnect.mnp_transaction. Business justification: Service-side MNP request directly maps to interconnect-side transaction for bilateral porting coordination between donor and recipient carriers. Critical for inter-carrier porting workflow and clearin' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MnpTransaction .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'Identifier of the user or system that submitted the MNP request (customer service representative, online portal, API).' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualPortCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Port Completion Datetime' ;
    rdfs:comment 'The actual date and time when the mobile number portability was successfully completed and the number became active on the recipient network.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualProcessingHours rdf:type rdf:Property ;
    rdfs:label 'Actual Processing Hours' ;
    rdfs:comment 'The actual elapsed time in hours from request submission to completion, used for SLA compliance measurement.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Balance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the outstanding balance amount.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Transaction Code' ;
    rdfs:comment 'Transaction identifier assigned by the national MNP clearinghouse system for inter-operator coordination and reconciliation.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorResponseCode rdf:type rdf:Property ;
    rdfs:label 'Donor Response Code' ;
    rdfs:comment 'Standardized response code provided by the donor operator in response to the port request.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee Amount' ;
    rdfs:comment 'The monetary amount of the early termination fee charged by the donor operator, if applicable.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee Applicable' ;
    rdfs:comment 'Indicates whether an early termination fee applies to this porting request due to contract obligations with the donor operator.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Any outstanding financial balance on the subscriber account with the donor operator at the time of the port request.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to the MNP request for processing queue management and SLA adherence.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recipient Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the recipient operator acknowledged receipt and acceptance of the port request.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedPortDate rdf:type rdf:Property ;
    rdfs:label 'Requested Port Date' ;
    rdfs:comment 'The date on which the subscriber has requested the mobile number portability to be completed.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledPortDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Port Datetime' ;
    rdfs:comment 'The precise date and time scheduled for the porting cutover event, coordinated between donor and recipient operators.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriberAddress rdf:type rdf:Property ;
    rdfs:label 'Subscriber Address' ;
    rdfs:comment 'Registered address of the subscriber with the donor operator, used for validation purposes during the porting process.' ;
    rdfs:domain ind:ServiceMnpRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQosProfileId rdf:type rdf:Property ;
    rdfs:label 'Service Qos Profile Id' ;
    rdfs:comment 'Unique identifier for the QoS profile. Primary key.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aggregateMaximumBitRateDownlinkKbps rdf:type rdf:Property ;
    rdfs:label 'Aggregate Maximum Bit Rate Downlink Kbps' ;
    rdfs:comment 'Aggregate maximum downlink bit rate in kbps across all non-GBR bearers for a subscriber.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aggregateMaximumBitRateUplinkKbps rdf:type rdf:Property ;
    rdfs:label 'Aggregate Maximum Bit Rate Uplink Kbps' ;
    rdfs:comment 'Aggregate maximum uplink bit rate in kbps across all non-GBR bearers for a subscriber.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargingRuleName rdf:type rdf:Property ;
    rdfs:label 'Charging Rule Name' ;
    rdfs:comment 'Name of the charging rule associated with this QoS profile. Links QoS enforcement to billing/rating policies.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:congestionHandlingPolicy rdf:type rdf:Property ;
    rdfs:label 'Congestion Handling Policy' ;
    rdfs:comment 'Policy for handling traffic during network congestion: drop packets, throttle rate, queue, or prioritize.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiPolicyClass rdf:type rdf:Property ;
    rdfs:label 'Dpi Policy Class' ;
    rdfs:comment 'DPI policy class identifier applied to traffic matching this QoS profile. Used for traffic shaping and content filtering.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcfPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Pcf Policy Code' ;
    rdfs:comment 'PCF policy identifier in 5G core network. References the policy rule enforced by the PCF.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrfPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Pcrf Policy Code' ;
    rdfs:comment 'PCRF policy identifier in LTE/4G network. References the policy rule enforced by the PCRF.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQosProfileDescription rdf:type rdf:Property ;
    rdfs:label 'Service Qos Profile Description' ;
    rdfs:comment 'Detailed description of the QoS profile purpose, use cases, and technical characteristics.' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQosProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Service Qos Profile Status' ;
    rdfs:comment 'Current lifecycle status of the QoS profile (active, inactive, deprecated, testing).' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficShapingRule rdf:type rdf:Property ;
    rdfs:label 'Traffic Shaping Rule' ;
    rdfs:comment 'Traffic shaping rule identifier or policy name applied to flows using this QoS profile (e.g., rate limiting, burst control).' ;
    rdfs:domain ind:ServiceQosProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditEligible rdf:type rdf:Property ;
    rdfs:label 'Credit Eligible' ;
    rdfs:comment 'Indicates whether SLA breaches under this profile are eligible for service credits or financial compensation.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dedicatedSupportTeam rdf:type rdf:Property ;
    rdfs:label 'Dedicated Support Team' ;
    rdfs:comment 'Indicates whether a dedicated technical account manager or support team is assigned under this SLA profile.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTier1Minutes rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 1 Minutes' ;
    rdfs:comment 'Time threshold in minutes before an unresolved incident is escalated to Tier 1 support or management.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTier2Minutes rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 2 Minutes' ;
    rdfs:comment 'Time threshold in minutes before an unresolved incident is escalated to Tier 2 engineering or senior management.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTier3Minutes rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 3 Minutes' ;
    rdfs:comment 'Time threshold in minutes before an unresolved incident is escalated to executive management or vendor escalation.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionWindowDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusion Window Description' ;
    rdfs:comment 'Description of planned maintenance windows or other exclusions that do not count against SLA uptime commitments.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindowHours rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Hours' ;
    rdfs:comment 'Time window in hours over which SLA metrics are measured and averaged (e.g., 24 hours, 720 hours for monthly).' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetLossLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Packet Loss Limit Percentage' ;
    rdfs:comment 'Maximum acceptable packet loss percentage for data transmission under this SLA. Critical for QoS enforcement and network performance monitoring.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileTier rdf:type rdf:Property ;
    rdfs:label 'Profile Tier' ;
    rdfs:comment 'Hierarchical tier level of the SLA profile indicating the quality and priority of service commitments.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on regulatory requirements or compliance obligations associated with this SLA profile (e.g., FCC service quality standards, Ofcom requirements).' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Target Minutes' ;
    rdfs:comment 'Maximum time in minutes for initial response to a service incident or trouble ticket after customer notification.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Status' ;
    rdfs:comment 'Current lifecycle status of the SLA profile in the product catalog.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svcConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Svc Configuration Id' ;
    rdfs:comment 'Unique identifier for the service configuration record. Primary key.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apnName rdf:type rdf:Property ;
    rdfs:label 'Apn Name' ;
    rdfs:comment 'Access Point Name identifying the external packet data network gateway for data sessions (LTE/3G).' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bandwidthProfileDownstreamMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Profile Downstream Mbps' ;
    rdfs:comment 'Maximum downstream (download) bandwidth in megabits per second allocated to this service instance.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthProfileUpstreamMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Profile Upstream Mbps' ;
    rdfs:comment 'Maximum upstream (upload) bandwidth in megabits per second allocated to this service instance.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationPayloadJson rdf:type rdf:Property ;
    rdfs:label 'Configuration Payload Json' ;
    rdfs:comment 'Full JSON payload containing all technology-specific configuration parameters not captured in structured columns. Supports extensibility for diverse service types.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Category of configuration parameters contained in this record (e.g., bearer settings, QoS profile, VoLTE/IMS, eSIM, FTTH ONT binding). [ENUM-REF-CANDIDATE: bearer|qos|apn|volte|ims|esim|ftth|ont|mvno|roaming|cpe|codec|bandwidth — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationVersion rdf:type rdf:Property ;
    rdfs:label 'Configuration Version' ;
    rdfs:comment 'Sequential version number tracking configuration changes over time for the same service instance.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpeWanIpAddress rdf:type rdf:Property ;
    rdfs:label 'Cpe Wan Ip Address' ;
    rdfs:comment 'Public or carrier-grade NAT IP address assigned to the WAN interface of the CPE device.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnnName rdf:type rdf:Property ;
    rdfs:label 'Dnn Name' ;
    rdfs:comment 'Data Network Name identifying the external data network for 5G standalone (5G SA) PDU sessions. Replaces APN in 5G core.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimEid rdf:type rdf:Property ;
    rdfs:label 'Esim Eid' ;
    rdfs:comment '32-digit unique identifier of the embedded Universal Integrated Circuit Card (eUICC) hardware.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimIccid rdf:type rdf:Property ;
    rdfs:label 'Esim Iccid' ;
    rdfs:comment '19 or 20-digit identifier of the eSIM profile (virtual SIM card) provisioned on the eUICC.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esimSmdpPlusAddress rdf:type rdf:Property ;
    rdfs:label 'Esim Smdp Plus Address' ;
    rdfs:comment 'Fully qualified domain name of the SM-DP+ server responsible for eSIM profile generation and download.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthGemPortNumber rdf:type rdf:Property ;
    rdfs:label 'Ftth Gem Port Number' ;
    rdfs:comment 'GEM port identifier used for traffic segmentation and QoS mapping in GPON.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftthOltIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ftth Olt Identifier' ;
    rdfs:comment 'Identifier of the OLT device in the central office serving this FTTH service instance.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthOntSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ftth Ont Serial Number' ;
    rdfs:comment 'Unique serial number of the ONT device installed at the customer premises for FTTH service delivery.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthPonPort rdf:type rdf:Property ;
    rdfs:label 'Ftth Pon Port' ;
    rdfs:comment 'PON port identifier on the OLT to which the ONT is connected.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftthTcontNumber rdf:type rdf:Property ;
    rdfs:label 'Ftth Tcont Number' ;
    rdfs:comment 'T-CONT identifier used for upstream bandwidth allocation in GPON architecture.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftthVlanNumber rdf:type rdf:Property ;
    rdfs:label 'Ftth Vlan Number' ;
    rdfs:comment 'VLAN identifier assigned for service traffic segregation on the FTTH access network.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hdVoiceEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Hd Voice Enabled Flag' ;
    rdfs:comment 'Indicates whether HD Voice (wideband audio codec) is enabled for voice calls.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imsPcscfAddress rdf:type rdf:Property ;
    rdfs:label 'Ims Pcscf Address' ;
    rdfs:comment 'IP address or FQDN of the P-CSCF node assigned for IMS session control (VoLTE/VoWiFi signaling).' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsPrivateUserIdentity rdf:type rdf:Property ;
    rdfs:label 'Ims Private User Identity' ;
    rdfs:comment 'Private user identity used for IMS authentication and registration. Typically derived from IMSI.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsPublicUserIdentity rdf:type rdf:Property ;
    rdfs:label 'Ims Public User Identity' ;
    rdfs:comment 'Public user identity (SIP URI or Tel URI) used for IMS service delivery and routing.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvnoOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Mvno Override Flag' ;
    rdfs:comment 'Indicates whether this service instance has MVNO-specific configuration overrides applied.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCodecList rdf:type rdf:Property ;
    rdfs:label 'Preferred Codec List' ;
    rdfs:comment 'Comma-separated ordered list of preferred voice codecs (e.g., AMR-WB, EVS, AMR-NB) for voice call negotiation.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningSystemSource rdf:type rdf:Property ;
    rdfs:label 'Provisioning System Source' ;
    rdfs:comment 'Name of the source system that provisioned this configuration (e.g., Netcracker OSS, Nokia NetAct, HLR/HSS, OLT EMS).' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosClassIdentifier rdf:type rdf:Property ;
    rdfs:label 'Qos Class Identifier' ;
    rdfs:comment 'QCI (LTE) or 5QI (5G NR) value defining the bearer quality of service class for packet scheduling, priority, and delay tolerance.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Zone Code' ;
    rdfs:comment 'Code identifying the roaming zone configuration for international roaming tariff and access control.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaClass rdf:type rdf:Property ;
    rdfs:label 'Sla Class' ;
    rdfs:comment 'SLA tier assigned to this service instance defining performance guarantees and support priority.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Sla Target Latency Ms' ;
    rdfs:comment 'Maximum acceptable round-trip latency in milliseconds as defined in the SLA.' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Uptime Percent' ;
    rdfs:comment 'Contractual uptime percentage target for this service instance (e.g., 99.95%).' ;
    rdfs:domain ind:SvcConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentServiceInstanceSvcInstanceId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Instance Svc Instance Id' ;
    rdfs:comment 'Reference to the parent service instance in hierarchical service scenarios (e.g., a mobile line under a family plan, or a managed service component under an enterprise contract).' ;
    rdfs:domain ind:SvcInstance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SvcInstance .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this service instance automatically renews at the end of its contract term. Controls subscription continuity and churn prevention.' ;
    rdfs:domain ind:SvcInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalServiceCode rdf:type rdf:Property ;
    rdfs:label 'External Service Code' ;
    rdfs:comment 'Service instance identifier in the upstream provisioning or network management system. Used for cross-system reconciliation and troubleshooting.' ;
    rdfs:domain ind:SvcInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsRegistered rdf:type rdf:Property ;
    rdfs:label 'Ims Registered' ;
    rdfs:comment 'Indicates whether this service instance is currently registered with the IMS core for VoLTE, VoIP, or RCS services.' ;
    rdfs:domain ind:SvcInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningSystem rdf:type rdf:Property ;
    rdfs:label 'Provisioning System' ;
    rdfs:comment 'Name of the OSS (Operations Support System) or provisioning platform that manages this service instance (e.g., Oracle OSM, Netcracker OSS, Ericsson Network Manager).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessTechnology rdf:type rdf:Property ;
    rdfs:label 'Access Technology' ;
    rdfs:comment 'Primary network access technology available at this service location. FTTH = Fiber to the Home, FTTC = Fiber to the Curb, DSL = Digital Subscriber Line.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeServiceCount rdf:type rdf:Property ;
    rdfs:label 'Active Service Count' ;
    rdfs:comment 'Number of active service instances currently provisioned at this location.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cabinet Identifier' ;
    rdfs:comment 'Identifier for the street cabinet or distribution point serving this location for FTTC deployments.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centralOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Central Office Code' ;
    rdfs:comment 'Identifier for the central office or exchange facility serving this location.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLocationCode rdf:type rdf:Property ;
    rdfs:label 'External Location Code' ;
    rdfs:comment 'Identifier for this location in external systems such as Oracle OSM, Netcracker OSS, or third-party GIS platforms.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiberAvailability rdf:type rdf:Property ;
    rdfs:label 'Fiber Availability' ;
    rdfs:comment 'Indicates whether fiber optic infrastructure is available at this location.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiveGCoverage rdf:type rdf:Property ;
    rdfs:label 'Five G Coverage' ;
    rdfs:comment 'Indicates whether 5G New Radio (NR) mobile network coverage is available at this location.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationComplexity rdf:type rdf:Property ;
    rdfs:label 'Installation Complexity' ;
    rdfs:comment 'Assessment of the complexity level for service installation at this location, used for workforce planning and scheduling.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business-assigned unique code for the service location, used for operational reference and field dispatch.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Descriptive name or label for the service location (e.g., building name, site name).' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationNotes rdf:type rdf:Property ;
    rdfs:label 'Location Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this service location for operational reference.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the service location record.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBandwidthMbps rdf:type rdf:Property ;
    rdfs:label 'Maximum Bandwidth Mbps' ;
    rdfs:comment 'Maximum bandwidth capacity available at this location in megabits per second, based on access technology and network infrastructure.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkServingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Network Serving Area Code' ;
    rdfs:comment 'Code identifying the network serving area or exchange that serves this location. Used for network planning and capacity management.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oltIdentifier rdf:type rdf:Property ;
    rdfs:label 'Olt Identifier' ;
    rdfs:comment 'Identifier for the OLT equipment serving this location for FTTH/GPON deployments.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premisesType rdf:type rdf:Property ;
    rdfs:label 'Premises Type' ;
    rdfs:comment 'Classification of the premises where service is delivered. MDU = Multi-Dwelling Unit.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Serviceability Status' ;
    rdfs:comment 'Indicates whether the location can currently be served with telecommunications services.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyedBy rdf:type rdf:Property ;
    rdfs:label 'Surveyed By' ;
    rdfs:comment 'Name or identifier of the technician or team who conducted the last survey.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universalServiceEligible rdf:type rdf:Property ;
    rdfs:label 'Universal Service Eligible' ;
    rdfs:comment 'Indicates whether this location is eligible for universal service funding or subsidies.' ;
    rdfs:domain ind:SvcLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svcStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Svc Status History Id' ;
    rdfs:comment 'Unique identifier for each service status transition event. Primary key for the service status history log.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:churnCategory rdf:type rdf:Property ;
    rdfs:label 'Churn Category' ;
    rdfs:comment 'Classification of the churn event by root cause. Distinguishes between voluntary customer-initiated churn, involuntary disconnection for non-payment, competitive loss to another provider, customer relocation, financial hardship, or service quality issues.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Churn Indicator Flag' ;
    rdfs:comment 'Indicator of whether this status transition represents a customer churn event. True when the transition to terminated status is customer-initiated and represents loss of revenue.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Eligible Flag' ;
    rdfs:comment 'Indicator of whether this status transition is eligible for customer dispute. True for transitions that can be contested through formal dispute resolution processes.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingActorName rdf:type rdf:Property ;
    rdfs:label 'Initiating Actor Name' ;
    rdfs:comment 'Human-readable name or label of the actor who initiated the transition. Provides business context for audit trails and dispute resolution.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingActorType rdf:type rdf:Property ;
    rdfs:label 'Initiating Actor Type' ;
    rdfs:comment 'Classification of the entity that triggered the status transition. Distinguishes between customer self-service actions, customer service representative interventions, automated system processes, network-driven events, billing system actions, or regulatory mandates.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The lifecycle state of the service instance after this transition. Captures the to-state in the state machine. This becomes the current status of the service instance.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notice Period Days' ;
    rdfs:comment 'The minimum number of days advance notice required by regulation before this type of status transition can occur. Applicable to disconnections and suspensions.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rollbackReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Rollback Reference Code' ;
    rdfs:comment 'Reference to the original status history record that this transition is rolling back. Links forward and reverse transitions for audit trail completeness.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flag' ;
    rdfs:comment 'Indicator of whether this status transition was scheduled in advance or occurred immediately. True for pre-planned transitions such as scheduled maintenance or future-dated disconnections.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceTechnology rdf:type rdf:Property ;
    rdfs:label 'Service Technology' ;
    rdfs:comment 'The underlying network technology delivering the service. Examples include LTE, 5G NR, GPON, FTTH, DSL, cable, or satellite. Used for technology-specific lifecycle analysis.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Minutes' ;
    rdfs:comment 'The contractual maximum time allowed for this type of status transition to complete, measured in minutes. Used to calculate SLA compliance.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Unique identifier of the status change event in the originating operational system. Enables traceability back to the source system for detailed investigation and reconciliation.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status change. Examples include customer request, non-payment, network fault, service upgrade, regulatory order, or system-initiated action.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the status transition. Captures details not conveyed by the reason code alone, such as specific customer requests or technical fault descriptions.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Eligible Flag' ;
    rdfs:comment 'Indicator of whether the customer associated with this terminated service is eligible for win-back marketing campaigns. Used to trigger retention and reacquisition workflows.' ;
    rdfs:domain ind:SvcStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svcSuspensionId rdf:type rdf:Property ;
    rdfs:label 'Svc Suspension Id' ;
    rdfs:comment 'Unique identifier for the service suspension event. Primary key.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingDealerId rdf:type rdf:Property ;
    rdfs:label 'Originating Dealer Id' ;
    rdfs:comment 'Foreign key linking to partner.dealer. Business justification: Suspensions of dealer-originated services require tracking originating dealer for fraud pattern analysis, commission clawback processing, and dealer compliance monitoring. Essential for indirect chann' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealer .

ind:actualReinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Reinstatement Date' ;
    rdfs:comment 'The actual date when the service was reinstated and became active again. Null if the service has not yet been reinstated. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReinstatementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Reinstatement Timestamp' ;
    rdfs:comment 'Precise timestamp when the service was reinstated in the network. Captured from Oracle OSM service fulfillment system. Null if not yet reinstated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoReinstatementEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Reinstatement Enabled' ;
    rdfs:comment 'Indicates whether the service will be automatically reinstated when conditions are met. True: automatic reinstatement configured (e.g., upon payment receipt). False: manual reinstatement required. Common for payment-related suspensions integrated with Amdocs Revenue Management.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAdjustmentApplied rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Applied' ;
    rdfs:comment 'Indicates whether a billing adjustment or credit was applied to the account due to the suspension. True if adjustments were made, False otherwise. Used for revenue assurance and customer account reconciliation.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Impact Flag' ;
    rdfs:comment 'Indicates whether recurring charges continue during the suspension period. True: charges continue (customer still billed). False: charges are suspended (no billing during suspension). Critical for Amdocs Revenue Management billing cycle processing and customer billing inquiries.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledgement Received' ;
    rdfs:comment 'Indicates whether the customer acknowledged receipt of the suspension notice. True: customer confirmed receipt. False: no acknowledgement received. Used for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyServicesAllowed rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Allowed' ;
    rdfs:comment 'Indicates whether emergency services (e.g., 911, E911) remain accessible during the suspension. True: emergency calls are allowed. False: all services including emergency are blocked. Regulatory compliance requirement per FCC and E911 regulations.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedReinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Reinstatement Date' ;
    rdfs:comment 'The planned or expected date when the service will be reinstated. For voluntary suspensions, this is the customer-requested end date. For involuntary suspensions, this may be calculated based on payment terms or regulatory requirements. Nullable for indefinite suspensions. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedChannel rdf:type rdf:Property ;
    rdfs:label 'Initiated Channel' ;
    rdfs:comment 'The channel through which the suspension was initiated. Web: online self-service portal. Mobile_app: mobile application. Call_center: customer service call. Retail_store: in-store request. Automated_system: system-generated. Partner_portal: partner or MVNO portal.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkSuspensionApplied rdf:type rdf:Property ;
    rdfs:label 'Network Suspension Applied' ;
    rdfs:comment 'Indicates whether the suspension was successfully applied at the network level. True: service is blocked in the network (RAN, Core, IMS). False: suspension is pending network execution or failed. Critical for operational validation.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkSuspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Network Suspension Timestamp' ;
    rdfs:comment 'Timestamp when the suspension was successfully applied in the network infrastructure (HSS, HLR, UDM, PCF). Captured from Ericsson Network Manager or Nokia NetAct. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:noticeMethod rdf:type rdf:Property ;
    rdfs:label 'Notice Method' ;
    rdfs:comment 'Method used to notify the customer of the pending suspension. Multiple: more than one method was used. Required for regulatory compliance documentation.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Notice Sent Date' ;
    rdfs:comment 'Date when the suspension notice was sent to the customer. Required for involuntary suspensions to demonstrate regulatory compliance. Null for voluntary suspensions. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proratedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Prorated Charge Amount' ;
    rdfs:comment 'The prorated charge amount applied for partial billing periods affected by the suspension. Calculated by Amdocs Revenue Management based on suspension dates and rate plan. Null if no proration applies.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinstatementCondition rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Condition' ;
    rdfs:comment 'Description of the conditions that must be met for service reinstatement. Examples: payment of outstanding balance, resolution of fraud investigation, completion of regulatory hold period, customer request. Used by collections and customer service teams.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementConditionMet rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Condition Met' ;
    rdfs:comment 'Indicates whether the reinstatement conditions have been satisfied. True: conditions met, service can be reinstated. False: conditions not yet met. Null if not applicable or not yet evaluated.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Fee Amount' ;
    rdfs:comment 'One-time fee charged to the customer for reinstating the suspended service. Common for involuntary suspensions due to non-payment. Null if no fee is charged. Amount in the billing account currency.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceBarringProfile rdf:type rdf:Property ;
    rdfs:label 'Service Barring Profile' ;
    rdfs:comment 'The network barring profile applied during suspension. Defines which services are blocked (e.g., outgoing calls only, all services, data only). Managed in Netcracker OSS service catalog and applied via IMS/PCF policy control.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Duration Days' ;
    rdfs:comment 'Calculated number of days the service was or is expected to be suspended. For active suspensions, this is calculated from start date to current date. For completed suspensions, this is the actual duration from start to reinstatement.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Suspension Fee Amount' ;
    rdfs:comment 'One-time fee charged to the customer for processing the suspension request. Typically applies to voluntary suspensions. Null if no fee is charged. Amount in the billing account currency.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Code' ;
    rdfs:comment 'Standardized code indicating the specific reason for suspension. Examples: NONPAY (non-payment), FRAUD (fraud detection), TRAVEL (customer travel hold), DISPUTE (billing dispute), REGULATORY (regulatory order), TECHNICAL (network issue). Aligns with Amdocs Revenue Management dunning codes and ServiceNow incident categories.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Description' ;
    rdfs:comment 'Detailed human-readable explanation of why the service was suspended. Provides context beyond the reason code for customer service representatives and audit purposes.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Suspension Reference Number' ;
    rdfs:comment 'Externally visible unique reference number for the suspension event. Format: SUS-XXXXXXXXXX. Used for customer communication and case tracking.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the service suspension was activated in the network. Captured from Oracle OSM service fulfillment system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspensionStatus rdf:type rdf:Property ;
    rdfs:label 'Suspension Status' ;
    rdfs:comment 'Current lifecycle status of the suspension event. Pending: suspension scheduled but not yet active. Active: service currently suspended. Reinstated: service has been restored. Expired: suspension period ended without reinstatement. Cancelled: suspension request was cancelled before activation.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionType rdf:type rdf:Property ;
    rdfs:label 'Suspension Type' ;
    rdfs:comment 'Classification of the suspension event. Voluntary: customer-initiated (e.g., travel hold, seasonal suspension). Involuntary: provider-initiated due to non-payment, policy violation, or fraud. Administrative: internal operational suspension. Regulatory: mandated by regulatory authority. Technical: network or service quality issue. Fraud: suspected fraudulent activity.' ;
    rdfs:domain ind:SvcSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteImsStateId rdf:type rdf:Property ;
    rdfs:label 'Volte Ims State Id' ;
    rdfs:comment 'Unique identifier for the VoLTE IMS state record. Primary key for tracking individual service state instances across the IMS infrastructure.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barringStatus rdf:type rdf:Property ;
    rdfs:label 'Barring Status' ;
    rdfs:comment 'Indicates any call barring restrictions applied to the VoLTE service, such as outgoing, incoming, or international call restrictions.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callForwardingStatus rdf:type rdf:Property ;
    rdfs:label 'Call Forwarding Status' ;
    rdfs:comment 'Current call forwarding configuration for the VoLTE service. Indicates if and under what conditions calls are forwarded to another number.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callWaitingEnabled rdf:type rdf:Property ;
    rdfs:label 'Call Waiting Enabled' ;
    rdfs:comment 'Boolean flag indicating whether call waiting supplementary service is enabled, allowing the subscriber to receive a second call while on an active call.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callerIdPresentation rdf:type rdf:Property ;
    rdfs:label 'Caller Id Presentation' ;
    rdfs:comment 'Configuration for outgoing caller ID presentation. Determines whether the subscribers number is displayed to called parties.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingFunctionAddress rdf:type rdf:Property ;
    rdfs:label 'Charging Function Address' ;
    rdfs:comment 'The address of the Online Charging System (OCS) or Offline Charging System (OFCS) handling billing events for this VoLTE service instance.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecPreference rdf:type rdf:Property ;
    rdfs:label 'Codec Preference' ;
    rdfs:comment 'The preferred voice codec configuration for this subscriber (e.g., EVS, AMR-WB, AMR-NB). Determines audio quality and bandwidth usage.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deregistration Timestamp' ;
    rdfs:comment 'The date and time when the subscriber was last deregistered from the IMS network, either explicitly or due to timeout/failure.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emergencyCallCapability rdf:type rdf:Property ;
    rdfs:label 'Emergency Call Capability' ;
    rdfs:comment 'Boolean flag indicating whether the subscriber can place emergency calls (E911/E112) over VoLTE. Critical for regulatory compliance with emergency services requirements.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyLocationInfo rdf:type rdf:Property ;
    rdfs:label 'Emergency Location Info' ;
    rdfs:comment 'The most recent location information (cell ID, GPS coordinates, or civic address) available for emergency call routing. Critical for E911 compliance.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esrvccCapability rdf:type rdf:Property ;
    rdfs:label 'Esrvcc Capability' ;
    rdfs:comment 'Indicates whether the subscriber and network support enhanced SRVCC for seamless handover of VoLTE calls to 3G/2G networks and emergency call continuity.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdVoiceEnabled rdf:type rdf:Property ;
    rdfs:label 'Hd Voice Enabled' ;
    rdfs:comment 'Indicates whether High Definition voice codec (EVS or AMR-WB) is enabled for this subscriber, providing enhanced audio quality over VoLTE.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hssAddress rdf:type rdf:Property ;
    rdfs:label 'Hss Address' ;
    rdfs:comment 'The address of the Home Subscriber Server storing the subscriber profile and authentication credentials for IMS services.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impi rdf:type rdf:Property ;
    rdfs:label 'Impi' ;
    rdfs:comment 'The private identity used for IMS authentication and authorization. Typically derived from IMSI and used in SIP registration.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impu rdf:type rdf:Property ;
    rdfs:label 'Impu' ;
    rdfs:comment 'The public identity (SIP URI or TEL URI) used for IMS service delivery. Visible to other users and used for call establishment.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Ims Registration Status' ;
    rdfs:comment 'Current registration state of the subscriber in the IMS core network. Indicates whether the subscriber can initiate or receive VoLTE calls.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCallTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Call Timestamp' ;
    rdfs:comment 'The date and time of the most recent VoLTE call (incoming or outgoing) made by this subscriber. Used for activity monitoring and churn prediction.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastLocationUpdate rdf:type rdf:Property ;
    rdfs:label 'Last Location Update' ;
    rdfs:comment 'The timestamp of the most recent location update received from the subscriber device. Used for emergency services location accuracy.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkAssignedUri rdf:type rdf:Property ;
    rdfs:label 'Network Assigned Uri' ;
    rdfs:comment 'The SIP URI assigned by the network for IMS service delivery. May differ from the public identity for routing purposes.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcsEnabled rdf:type rdf:Property ;
    rdfs:label 'Rcs Enabled' ;
    rdfs:comment 'Boolean flag indicating whether Rich Communication Services (advanced messaging over IMS) is enabled for this subscriber.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationExpiryTime rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Time' ;
    rdfs:comment 'The timestamp when the current IMS registration will expire if not refreshed. Determines when re-registration is required.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roamingStatus rdf:type rdf:Property ;
    rdfs:label 'Roaming Status' ;
    rdfs:comment 'Current roaming state of the subscriber for VoLTE service. Affects routing, charging, and service availability.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ueCapabilityVersion rdf:type rdf:Property ;
    rdfs:label 'Ue Capability Version' ;
    rdfs:comment 'The IMS capability version reported by the subscribers device. Indicates supported features and protocol versions.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCallingEnabled rdf:type rdf:Property ;
    rdfs:label 'Video Calling Enabled' ;
    rdfs:comment 'Indicates whether video calling over IMS (ViLTE) is enabled for this subscriber. Requires additional QoS and device capability.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volteCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Volte Capability Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber device and subscription support VoLTE service. True indicates VoLTE is enabled and available.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vowifiStatus rdf:type rdf:Property ;
    rdfs:label 'Vowifi Status' ;
    rdfs:comment 'Current status of Wi-Fi calling capability for the subscriber. Indicates whether the subscriber can make VoLTE calls over Wi-Fi networks.' ;
    rdfs:domain ind:VolteImsState ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregatedUsageId rdf:type rdf:Property ;
    rdfs:label 'Aggregated Usage Id' ;
    rdfs:comment 'Unique identifier for the aggregated usage record. Primary key for this operational summary entity.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aggregationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aggregation End Timestamp' ;
    rdfs:comment 'The end date and time of the aggregation period. Defines the close of the usage window being summarized.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aggregationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Aggregation Period Type' ;
    rdfs:comment 'The time granularity at which usage is aggregated: daily summary, weekly rollup, monthly billing cycle, or custom period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aggregation Start Timestamp' ;
    rdfs:comment 'The start date and time of the aggregation period. Defines the beginning of the usage window being summarized.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aggregationStatus rdf:type rdf:Property ;
    rdfs:label 'Aggregation Status' ;
    rdfs:comment 'Current processing status of this aggregated usage record: pending initial aggregation, completed and ready for billing, failed validation, or reprocessing.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStreamingHours rdf:type rdf:Property ;
    rdfs:label 'Content Streaming Hours' ;
    rdfs:comment 'Total hours of video/audio streaming content consumed (IPTV, OTT, VoD) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMb2g rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb 2g' ;
    rdfs:comment 'Total data consumed in megabytes over 2G Radio Access Network (RAN) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMb3g rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb 3g' ;
    rdfs:comment 'Total data consumed in megabytes over 3G Radio Access Network (RAN) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMb4gLte rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb 4g Lte' ;
    rdfs:comment 'Total data consumed in megabytes over 4G LTE Radio Access Network (RAN) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMb5g rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb 5g' ;
    rdfs:comment 'Total data consumed in megabytes over 5G NR Radio Access Network (RAN) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMbRoaming rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb Roaming' ;
    rdfs:comment 'Total data consumed in megabytes while roaming on partner networks during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataVolumeMbWifiOffload rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb Wifi Offload' ;
    rdfs:comment 'Total data consumed in megabytes via Wi-Fi offload (carrier-managed hotspots) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpiCategoryGamingMb rdf:type rdf:Property ;
    rdfs:label 'Dpi Category Gaming Mb' ;
    rdfs:comment 'Data volume attributed to gaming applications via DPI classification during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpiCategoryOtherMb rdf:type rdf:Property ;
    rdfs:label 'Dpi Category Other Mb' ;
    rdfs:comment 'Data volume attributed to other/unclassified applications via DPI classification during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpiCategorySocialMediaMb rdf:type rdf:Property ;
    rdfs:label 'Dpi Category Social Media Mb' ;
    rdfs:comment 'Data volume attributed to social media applications via DPI classification during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dpiCategoryVideoStreamingMb rdf:type rdf:Property ;
    rdfs:label 'Dpi Category Video Streaming Mb' ;
    rdfs:comment 'Data volume attributed to video streaming applications via DPI classification during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairUsePolicyThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Fair Use Policy Threshold Exceeded' ;
    rdfs:comment 'Boolean flag indicating whether the subscriber exceeded the fair use policy threshold during this aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iptvViewingHours rdf:type rdf:Property ;
    rdfs:label 'Iptv Viewing Hours' ;
    rdfs:comment 'Total hours of IPTV live and time-shifted television viewing during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediationSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Mediation Source System' ;
    rdfs:comment 'Identifier of the mediation system or collection platform that sourced the raw CDR/IPDR records for this aggregation.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offpeakUsageMb rdf:type rdf:Property ;
    rdfs:label 'Offpeak Usage Mb' ;
    rdfs:comment 'Data volume consumed during off-peak hours (nights, weekends) in megabytes.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageDataMb rdf:type rdf:Property ;
    rdfs:label 'Overage Data Mb' ;
    rdfs:comment 'Data volume consumed beyond the subscriber\'s plan allowance (overage) in megabytes during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageSmsCount rdf:type rdf:Property ;
    rdfs:label 'Overage Sms Count' ;
    rdfs:comment 'SMS messages sent beyond the subscriber\'s plan allowance (overage) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageVoiceMinutes rdf:type rdf:Property ;
    rdfs:label 'Overage Voice Minutes' ;
    rdfs:comment 'Voice minutes consumed beyond the subscriber\'s plan allowance (overage) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakUsageMb rdf:type rdf:Property ;
    rdfs:label 'Peak Usage Mb' ;
    rdfs:comment 'Data volume consumed during peak hours (as defined by network policy, typically business hours) in megabytes.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingPartnerNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Partner Network Code' ;
    rdfs:comment 'Identifier of the roaming partner network (PLMN ID or partner code) where the majority of roaming usage occurred.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsCountInternational rdf:type rdf:Property ;
    rdfs:label 'Sms Count International' ;
    rdfs:comment 'Total number of SMS messages sent to international destinations during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smsCountOffnet rdf:type rdf:Property ;
    rdfs:label 'Sms Count Offnet' ;
    rdfs:comment 'Total number of SMS messages sent to off-net destinations during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smsCountOnnet rdf:type rdf:Property ;
    rdfs:label 'Sms Count Onnet' ;
    rdfs:comment 'Total number of SMS messages sent to on-net destinations during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smsCountRoaming rdf:type rdf:Property ;
    rdfs:label 'Sms Count Roaming' ;
    rdfs:comment 'Total number of SMS messages sent while roaming during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:throttlingApplied rdf:type rdf:Property ;
    rdfs:label 'Throttling Applied' ;
    rdfs:comment 'Boolean flag indicating whether data throttling (speed reduction) was applied to the subscriber during this period due to policy enforcement.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSessionCount rdf:type rdf:Property ;
    rdfs:label 'Total Session Count' ;
    rdfs:comment 'Total number of data sessions (PDP contexts, PDN connections) initiated during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueCellTowerCount rdf:type rdf:Property ;
    rdfs:label 'Unique Cell Tower Count' ;
    rdfs:comment 'Number of unique cell towers (eNodeB, gNodeB) the subscriber connected to during the aggregation period. Indicator of mobility.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vodRentalCount rdf:type rdf:Property ;
    rdfs:label 'Vod Rental Count' ;
    rdfs:comment 'Total number of VoD rentals (pay-per-view events) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voiceMinutesInternational rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes International' ;
    rdfs:comment 'Total voice call minutes to international destinations during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceMinutesOffnet rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes Offnet' ;
    rdfs:comment 'Total voice call minutes to destinations outside the network (off-net, other carriers) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceMinutesOnnet rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes Onnet' ;
    rdfs:comment 'Total voice call minutes to destinations within the same network (on-net) during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceMinutesRoaming rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes Roaming' ;
    rdfs:comment 'Total voice call minutes made while roaming on partner networks during the aggregation period.' ;
    rdfs:domain ind:AggregatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkOperatorCarrierId rdf:type rdf:Property ;
    rdfs:label 'Network Operator Carrier Id' ;
    rdfs:comment 'Identifier of the network operator that handled the call (home or visited network).' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:originalCdrId rdf:type rdf:Property ;
    rdfs:label 'Original Cdr Id' ;
    rdfs:comment 'Reference to the original CDR identifier if this record is a correction or reprocessed version.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cdr .

ind:roamingFileId rdf:type rdf:Property ;
    rdfs:label 'Roaming File Id' ;
    rdfs:comment 'Foreign key linking to usage.roaming_file. Business justification: CDR records generated in roaming scenarios are transmitted via TAP (Transferred Account Procedure) files. The cdr table has tap_file_sequence_number (STRING) which is a denormalized reference to the f' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoamingFile .

ind:bearerServiceCode rdf:type rdf:Property ;
    rdfs:label 'Bearer Service Code' ;
    rdfs:comment 'Code identifying the bearer service type used for the call.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callCategory rdf:type rdf:Property ;
    rdfs:label 'Call Category' ;
    rdfs:comment 'Geographic classification of the call: local, national, international, or roaming.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDirection rdf:type rdf:Property ;
    rdfs:label 'Call Direction' ;
    rdfs:comment 'Direction of the call: mobile originated (MO), mobile terminated (MT), or forwarded.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Type of communication event captured in this CDR (voice, SMS, MMS, data session, video call).' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingIndicator rdf:type rdf:Property ;
    rdfs:label 'Charging Indicator' ;
    rdfs:comment 'Indicates whether the call is chargeable, non-chargeable, free, or promotional.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionIndicator rdf:type rdf:Property ;
    rdfs:label 'Correction Indicator' ;
    rdfs:comment 'Flag indicating whether this CDR is a correction or adjustment of a previously processed record.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataVolumeDownlinkBytes rdf:type rdf:Property ;
    rdfs:label 'Data Volume Downlink Bytes' ;
    rdfs:comment 'Total data volume downloaded during the session, measured in bytes.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataVolumeUplinkBytes rdf:type rdf:Property ;
    rdfs:label 'Data Volume Uplink Bytes' ;
    rdfs:comment 'Total data volume uploaded during the session, measured in bytes.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediationStatus rdf:type rdf:Property ;
    rdfs:label 'Mediation Status' ;
    rdfs:comment 'Current processing status of the CDR in the mediation layer.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mediation Timestamp' ;
    rdfs:comment 'Timestamp when the CDR was processed through the mediation layer.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nrtrdeBatchReference rdf:type rdf:Property ;
    rdfs:label 'Nrtrde Batch Reference' ;
    rdfs:comment 'Batch identifier for near real-time roaming data exchange records.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Record Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the CDR within the source system or collection batch.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueAssuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Status' ;
    rdfs:comment 'Status of revenue assurance validation for this CDR.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roamingNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Network Code' ;
    rdfs:comment 'Mobile Country Code (MCC) and Mobile Network Code (MNC) of the visited roaming network.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingMsc rdf:type rdf:Property ;
    rdfs:label 'Serving Msc' ;
    rdfs:comment 'Identifier of the Mobile Switching Center that handled the call.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplementaryServiceCodes rdf:type rdf:Property ;
    rdfs:label 'Supplementary Service Codes' ;
    rdfs:comment 'Comma-separated list of supplementary service codes active during the call (call forwarding, call waiting, etc.).' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationCauseCode rdf:type rdf:Property ;
    rdfs:label 'Termination Cause Code' ;
    rdfs:comment 'Code indicating the reason for call termination (normal, busy, no answer, network failure, etc.).' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Termination Cause Description' ;
    rdfs:comment 'Human-readable description of the call termination reason.' ;
    rdfs:domain ind:Cdr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Content Consumption Id' ;
    rdfs:comment 'Unique identifier for the content consumption event record. Primary key.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Drm Entitlement Id' ;
    rdfs:comment 'Reference to the DRM entitlement or license that authorized this content consumption. Used for rights validation and audit.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Entitlement .

ind:roamingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Roaming Partner Id' ;
    rdfs:comment 'Identifier of the roaming partner network if the subscriber was roaming. Null for non-roaming sessions.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Unique identifier for the streaming or viewing session. Used to correlate multiple events within a single consumption session.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSession .

ind:subscriptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Subscription Package Id' ;
    rdfs:comment 'Identifier of the subscription package or content entitlement that authorized this consumption. Null for pay-per-view or rental.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:bufferingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Buffering Events Count' ;
    rdfs:comment 'Number of buffering or rebuffering events during the session. Key QoS indicator for subscriber experience.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bytesConsumed rdf:type rdf:Property ;
    rdfs:label 'Bytes Consumed' ;
    rdfs:comment 'Total number of bytes transferred during the content consumption session. Used for data usage tracking and zero-rating validation.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargingReference rdf:type rdf:Property ;
    rdfs:label 'Charging Reference' ;
    rdfs:comment 'Unique identifier linking this consumption event to the real-time rating and charging system. Used for revenue assurance reconciliation.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current status of the content consumption event in the usage processing lifecycle.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedAmount rdf:type rdf:Property ;
    rdfs:label 'Rated Amount' ;
    rdfs:comment 'Monetary amount charged for this content consumption event after rating. Null if zero-rated or included in subscription.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the content consumption session in seconds. Calculated from start to end timestamp or last heartbeat.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Timestamp when the content consumption session ended. Null if session is still active or was abnormally terminated.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Timestamp when the content consumption session began. Represents the actual business event time when the subscriber initiated playback.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:streamQuality rdf:type rdf:Property ;
    rdfs:label 'Stream Quality' ;
    rdfs:comment 'Video or audio quality level of the streamed content. Impacts bandwidth consumption and QoS metrics.' ;
    rdfs:domain ind:ContentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroRatedFlag rdf:type rdf:Property ;
    rdfs:label 'Zero Rated Flag' ;
    rdfs:comment 'Indicates whether this content consumption was zero-rated (data usage not charged to subscriber). Used for zero-rating policy validation and revenue assurance.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSessionId rdf:type rdf:Property ;
    rdfs:label 'Data Session Id' ;
    rdfs:comment 'Unique identifier for the packet data session record. Primary key.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSession .

ind:chargingCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Charging Characteristics' ;
    rdfs:comment 'Hexadecimal string defining the charging behavior for this session (e.g., online/offline charging, prepaid/postpaid). Used by charging systems to determine rating rules.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downlinkBytes rdf:type rdf:Property ;
    rdfs:label 'Downlink Bytes' ;
    rdfs:comment 'Total number of bytes transmitted from the network to the subscriber device during this session. Used for usage-based billing and fair-use policy enforcement.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiveQi rdf:type rdf:Property ;
    rdfs:label 'Five Qi' ;
    rdfs:comment '5G QoS Identifier for 5G NR sessions, defining the packet forwarding treatment and service characteristics. Replaces QCI in 5G networks.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homePlmnCode rdf:type rdf:Property ;
    rdfs:label 'Home Plmn Code' ;
    rdfs:comment 'Mobile Country Code (MCC) and Mobile Network Code (MNC) of the subscriber home network. Used for subscriber identification and roaming validation.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdnType rdf:type rdf:Property ;
    rdfs:label 'Pdn Type' ;
    rdfs:comment 'The IP address type assigned to the subscriber for this session (IPv4, IPv6, or dual-stack IPv4v6). Critical for IP address management and network planning.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakDownlinkThroughputKbps rdf:type rdf:Property ;
    rdfs:label 'Peak Downlink Throughput Kbps' ;
    rdfs:comment 'Maximum downlink data transfer rate achieved during the session, measured in kilobits per second. Used for Quality of Service (QoS) analysis and network performance monitoring.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakUplinkThroughputKbps rdf:type rdf:Property ;
    rdfs:label 'Peak Uplink Throughput Kbps' ;
    rdfs:comment 'Maximum uplink data transfer rate achieved during the session, measured in kilobits per second. Used for Quality of Service (QoS) analysis and network performance monitoring.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pgwAddress rdf:type rdf:Property ;
    rdfs:label 'Pgw Address' ;
    rdfs:comment 'IP address of the PGW node that served this session in LTE networks. Gateway between the mobile network and external packet data networks.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qci rdf:type rdf:Property ;
    rdfs:label 'Qci' ;
    rdfs:comment 'QoS Class Identifier for LTE sessions, defining the packet forwarding treatment (e.g., priority, packet delay budget, packet error loss rate). Values range from 1 to 9 for standardized bearers.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratType rdf:type rdf:Property ;
    rdfs:label 'Rat Type' ;
    rdfs:comment 'The radio access technology used during the data session (e.g., 2G, 3G, HSPA, LTE, 5G NR). Critical for network performance analysis and technology migration tracking.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordClosingTime rdf:type rdf:Property ;
    rdfs:label 'Record Closing Time' ;
    rdfs:comment 'Timestamp when this charging data record was closed and finalized by the network element. Marks the record as complete for billing processing.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordOpeningTime rdf:type rdf:Property ;
    rdfs:label 'Record Opening Time' ;
    rdfs:comment 'Timestamp when this charging data record was opened by the network element. Used for CDR lifecycle tracking and mediation processing.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servingNodeType rdf:type rdf:Property ;
    rdfs:label 'Serving Node Type' ;
    rdfs:comment 'Type of core network node that served this session (SGSN for 2G/3G, PGW/SGW for LTE, UPF for 5G). Used for network architecture analysis.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTerminationCause rdf:type rdf:Property ;
    rdfs:label 'Session Termination Cause' ;
    rdfs:comment 'The reason code or description for why the data session was terminated (e.g., normal release, user disconnect, network failure, timeout). Used for troubleshooting and quality analysis.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sgsnAddress rdf:type rdf:Property ;
    rdfs:label 'Sgsn Address' ;
    rdfs:comment 'IP address of the SGSN node that served this session in 2G/3G networks. Used for network element tracking and troubleshooting.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sgwAddress rdf:type rdf:Property ;
    rdfs:label 'Sgw Address' ;
    rdfs:comment 'IP address of the SGW node that served this session in LTE networks. Routes and forwards user data packets between the RAN and PGW.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBytes rdf:type rdf:Property ;
    rdfs:label 'Total Bytes' ;
    rdfs:comment 'Combined total of uplink and downlink bytes transferred during the session. Primary metric for data usage rating and quota management.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ueIpAddress rdf:type rdf:Property ;
    rdfs:label 'Ue Ip Address' ;
    rdfs:comment 'The IP address assigned to the subscriber device during this data session. Used for session correlation and security analysis.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfAddress rdf:type rdf:Property ;
    rdfs:label 'Upf Address' ;
    rdfs:comment 'IP address of the UPF node that served this session in 5G networks. Handles user plane traffic routing and forwarding in 5G core.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkBytes rdf:type rdf:Property ;
    rdfs:label 'Uplink Bytes' ;
    rdfs:comment 'Total number of bytes transmitted from the subscriber device to the network during this session. Used for usage-based billing and fair-use policy enforcement.' ;
    rdfs:domain ind:DataSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipdrRecordId rdf:type rdf:Property ;
    rdfs:label 'Ipdr Record Id' ;
    rdfs:comment 'Unique identifier for the IPDR record. Primary key for the consolidated IP flow-level and application-layer traffic data record.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIpdrNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Primary Ipdr Network Element Id' ;
    rdfs:comment 'Identifier of the DPI probe or inline inspection node that captured and analyzed this traffic flow. Used for network topology analysis and probe performance monitoring.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:bytesDownlink rdf:type rdf:Property ;
    rdfs:label 'Bytes Downlink' ;
    rdfs:comment 'Total number of bytes transmitted from the network to the subscriber during this flow. Used for usage-based billing and fair-use policy enforcement.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bytesUplink rdf:type rdf:Property ;
    rdfs:label 'Bytes Uplink' ;
    rdfs:comment 'Total number of bytes transmitted from the subscriber to the network during this flow. Used for usage-based billing and fair-use policy enforcement.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Charging Rule Code' ;
    rdfs:comment 'Identifier of the charging rule applied to this traffic flow for real-time rating. Links to the rating engine rule set. Used for billing validation and revenue assurance.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationDomain rdf:type rdf:Property ;
    rdfs:label 'Destination Domain' ;
    rdfs:comment 'The fully qualified domain name (FQDN) of the destination server, resolved from DNS queries or extracted by DPI. Examples: www.netflix.com, api.whatsapp.net.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIpAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Ip Address' ;
    rdfs:comment 'The destination IP address of the traffic flow. Represents the remote server or service the subscriber is accessing.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedApplication rdf:type rdf:Property ;
    rdfs:label 'Detected Application' ;
    rdfs:comment 'The application or service detected by DPI analysis. Examples: Netflix, YouTube, WhatsApp, Facebook, Spotify, Zoom. Null if application could not be identified.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Flow Duration Seconds' ;
    rdfs:comment 'The total duration of the IP flow in seconds, calculated as the difference between flow_end_timestamp and flow_start_timestamp. Used for session analytics and quality of experience analysis.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flow End Timestamp' ;
    rdfs:comment 'The timestamp when this IP flow was terminated or closed. Represents the real-world event time of the last packet in the flow. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flow Start Timestamp' ;
    rdfs:comment 'The timestamp when this IP flow was initiated. Represents the real-world event time of the first packet in the flow. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lawfulInterceptFlag rdf:type rdf:Property ;
    rdfs:label 'Lawful Intercept Flag' ;
    rdfs:comment 'Indicates whether this traffic flow was subject to lawful intercept monitoring. True if the subscriber is under active lawful intercept order, False otherwise. Highly restricted access.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packetsDownlink rdf:type rdf:Property ;
    rdfs:label 'Packets Downlink' ;
    rdfs:comment 'Total number of packets transmitted from the network to the subscriber during this flow. Used for network performance analysis and anomaly detection.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packetsUplink rdf:type rdf:Property ;
    rdfs:label 'Packets Uplink' ;
    rdfs:comment 'Total number of packets transmitted from the subscriber to the network during this flow. Used for network performance analysis and anomaly detection.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyEnforcementAction rdf:type rdf:Property ;
    rdfs:label 'Policy Enforcement Action' ;
    rdfs:comment 'The policy enforcement action taken by the Policy Control Function (PCF) or policy engine for this flow. Examples: ALLOW, BLOCK, REDIRECT, RATE_LIMIT, LOG_ONLY. Used for policy compliance auditing.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyRuleCode rdf:type rdf:Property ;
    rdfs:label 'Policy Rule Code' ;
    rdfs:comment 'Identifier of the specific policy rule that triggered the policy_enforcement_action. Used for policy effectiveness analysis and troubleshooting.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocol rdf:type rdf:Property ;
    rdfs:label 'Protocol' ;
    rdfs:comment 'The network or transport layer protocol used for this traffic flow. Examples: TCP, UDP, ICMP, HTTP, HTTPS, QUIC. [ENUM-REF-CANDIDATE: TCP|UDP|ICMP|HTTP|HTTPS|QUIC|FTP|SMTP|DNS|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberIdentifier rdf:type rdf:Property ;
    rdfs:label 'Subscriber Identifier' ;
    rdfs:comment 'Alternative subscriber identifier captured from the session (e.g., MSISDN, IMSI, username, MAC address). Used when IP address alone is insufficient for subscriber correlation.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberIpAddress rdf:type rdf:Property ;
    rdfs:label 'Subscriber Ip Address' ;
    rdfs:comment 'The IP address assigned to the subscriber device at the time of this traffic flow. May be IPv4 or IPv6 format.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleActionApplied rdf:type rdf:Property ;
    rdfs:label 'Throttle Action Applied' ;
    rdfs:comment 'The throttling or traffic shaping action applied to this flow. NONE: no action, THROTTLED: bandwidth reduced, BLOCKED: traffic blocked, SHAPED: traffic shaped per policy. Used for fair-use policy enforcement evidence.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleReason rdf:type rdf:Property ;
    rdfs:label 'Throttle Reason' ;
    rdfs:comment 'The business or technical reason for applying a throttle action. Examples: FAIR_USE_EXCEEDED, CONGESTION_MANAGEMENT, POLICY_VIOLATION. Null if throttle_action_applied is NONE.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroRatingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Zero Rating Eligible Flag' ;
    rdfs:comment 'Indicates whether this traffic flow is eligible for zero-rating (excluded from data allowance charges). True if the application or destination is part of a zero-rating program, False otherwise.' ;
    rdfs:domain ind:IpdrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediationEventId rdf:type rdf:Property ;
    rdfs:label 'Mediation Event Id' ;
    rdfs:comment 'Unique identifier for the mediation event record. Primary key for tracking each raw usage event through the mediation lifecycle from collection to delivery.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawCdrId rdf:type rdf:Property ;
    rdfs:label 'Raw Cdr Id' ;
    rdfs:comment 'Reference to the original raw usage event record (CDR, IPDR, TAP, or DPI session) collected from the network element before mediation processing.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cdr .

ind:calledParty rdf:type rdf:Property ;
    rdfs:label 'Called Party' ;
    rdfs:comment 'Phone number or identifier of the party receiving the usage event (B-party). Applicable to voice, SMS, and MMS events.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callingParty rdf:type rdf:Property ;
    rdfs:label 'Calling Party' ;
    rdfs:comment 'Phone number or identifier of the party initiating the usage event (A-party). Applicable to voice, SMS, and MMS events.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Data Volume Bytes' ;
    rdfs:comment 'Total data volume transferred during the usage event in bytes (upload + download). Applicable to data sessions, IPDR, and DPI records.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Acknowledgement Flag' ;
    rdfs:comment 'Flag indicating whether the downstream system acknowledged successful receipt and processing of the mediated event. Critical for end-to-end usage processing completeness.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downloadBytes rdf:type rdf:Property ;
    rdfs:label 'Download Bytes' ;
    rdfs:comment 'Data volume downloaded by the subscriber during the usage event in bytes. Used for asymmetric rating and QoS analysis.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downstreamSystemCode rdf:type rdf:Property ;
    rdfs:label 'Downstream System Code' ;
    rdfs:comment 'Identifier of the downstream system (rating engine, billing system, revenue assurance platform) to which the mediated event was delivered.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrichment Timestamp' ;
    rdfs:comment 'Timestamp when the normalized record was enriched with subscriber, product, and network reference data. Tracks mediation processing latency.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manualReviewQueue rdf:type rdf:Property ;
    rdfs:label 'Manual Review Queue' ;
    rdfs:comment 'Identifier of the manual review queue to which this rejected event was assigned for human investigation and resolution.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediationNodeCode rdf:type rdf:Property ;
    rdfs:label 'Mediation Node Code' ;
    rdfs:comment 'Identifier of the mediation platform node that processed this event. Used for load balancing analysis and troubleshooting mediation bottlenecks.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Normalization Timestamp' ;
    rdfs:comment 'Timestamp when the raw usage record was normalized into standard mediation format. Tracks mediation processing latency.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Description' ;
    rdfs:comment 'Detailed human-readable description of why the mediation event was rejected. Provides context for manual review and resolution.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprocessingHistory rdf:type rdf:Property ;
    rdfs:label 'Reprocessing History' ;
    rdfs:comment 'Audit trail of all reprocessing attempts including timestamps, actions taken, and outcomes. Critical for regulatory audit trails and revenue assurance investigations.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Retry Eligible Flag' ;
    rdfs:comment 'Flag indicating whether the rejected event is eligible for automatic retry or requires manual intervention. Based on rejection category and business rules.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uploadBytes rdf:type rdf:Property ;
    rdfs:label 'Upload Bytes' ;
    rdfs:comment 'Data volume uploaded by the subscriber during the usage event in bytes. Used for asymmetric rating and QoS analysis.' ;
    rdfs:domain ind:MediationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processor Employee Id' ;
    rdfs:comment 'Foreign key linking to people.employee. Business justification: TAP/RAP file processing in wholesale roaming requires operator assignment for validation, dispute handling, settlement reconciliation, and audit trails. Critical for inter-carrier billing accountabili' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clearingHouseName rdf:type rdf:Property ;
    rdfs:label 'Clearing House Name' ;
    rdfs:comment 'Name of the roaming clearing house or data exchange platform used for file transmission (e.g., Syniverse, MACH, GRX) or \'Direct\' for bilateral exchange.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEventCount rdf:type rdf:Property ;
    rdfs:label 'Data Event Count' ;
    rdfs:comment 'Number of mobile data session events (GPRS/LTE/5G data usage) in the TAP file.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for dispute if dispute_flag is true. Used for inter-operator dispute resolution.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileAvailableTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Available Timestamp' ;
    rdfs:comment 'Date and time when the TAP file was made available for retrieval by the recipient operator or clearing house.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileCompressionType rdf:type rdf:Property ;
    rdfs:label 'File Compression Type' ;
    rdfs:comment 'Compression algorithm applied to the TAP file for transmission efficiency (typically gzip per GSMA standard).' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Generation Timestamp' ;
    rdfs:comment 'Date and time when the TAP file was generated by the sending operator\'s mediation system.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'File Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the TAP file for ordering and tracking purposes within the bilateral exchange relationship.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileTypeCode rdf:type rdf:Property ;
    rdfs:label 'File Type Code' ;
    rdfs:comment 'Type of roaming data exchange file. TAP3 = Transferred Account Procedure version 3 (standard roaming CDRs), RAP = Returned Account Procedure (rejections/returns), NRTRDE = Near Real-Time Roaming Data Exchange.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iotTariffApplied rdf:type rdf:Property ;
    rdfs:label 'Iot Tariff Applied' ;
    rdfs:comment 'Identifier of the inter-operator tariff agreement applied to rate the usage events in this TAP file.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text field for operational notes, special handling instructions, or comments related to TAP file processing and settlement.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapFileGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Rap File Generated Flag' ;
    rdfs:comment 'Indicates whether a RAP file (rejection/return file) was generated in response to this TAP file due to validation failures or disputes.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:senderTadigCode rdf:type rdf:Property ;
    rdfs:label 'Sender Tadig Code' ;
    rdfs:comment 'Five-character TADIG code identifying the sending mobile network operator. Format: 3-letter country code + 2-digit operator code.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsEventCount rdf:type rdf:Property ;
    rdfs:label 'Sms Event Count' ;
    rdfs:comment 'Number of SMS message events (Mobile Originated SMS and Mobile Terminated SMS) in the TAP file.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tapFileName rdf:type rdf:Property ;
    rdfs:label 'Tap File Name' ;
    rdfs:comment 'Standardized TAP file name following GSMA naming convention: sender TADIG code (5 chars), recipient TADIG code (5 chars), file type (3 chars), sequence number (5 digits).' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecordCount rdf:type rdf:Property ;
    rdfs:label 'Total Record Count' ;
    rdfs:comment 'Total number of individual roaming usage records (CDRs) contained within this TAP file.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all tax amounts applied to the usage events in the TAP file, if applicable per bilateral agreement.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationWarningCount rdf:type rdf:Property ;
    rdfs:label 'Validation Warning Count' ;
    rdfs:comment 'Number of non-fatal validation warnings detected in the TAP file that allow processing but require review.' ;
    rdfs:domain ind:RoamingFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smsRecordId rdf:type rdf:Property ;
    rdfs:label 'Sms Record Id' ;
    rdfs:comment 'Unique identifier for the SMS usage event record. Primary key for the SMS record entity.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySmsRanCellId rdf:type rdf:Property ;
    rdfs:label 'Primary Sms Ran Cell Id' ;
    rdfs:comment 'Identifier of the radio cell or base station where the originating subscriber was located when the SMS was sent. Used for network analytics and location-based services.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RanCell .

ind:cdrSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cdr Sequence Number' ;
    rdfs:comment 'Unique sequence number assigned by the mediation system to this SMS CDR for traceability and reconciliation across billing and revenue assurance systems.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClass rdf:type rdf:Property ;
    rdfs:label 'Content Class' ;
    rdfs:comment 'Classification of the message content for regulatory reporting and rating: standard (regular P2P), premium (premium-rate services), promotional (marketing A2P), transactional (account notifications), otp (one-time password), alert (emergency or service alerts).' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCodingScheme rdf:type rdf:Property ;
    rdfs:label 'Data Coding Scheme' ;
    rdfs:comment 'Code indicating the character encoding and message class of the SMS (e.g., 7-bit GSM, 8-bit data, UCS-2 Unicode). Used for message rendering and international character support.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Home Network Code' ;
    rdfs:comment 'The MCC-MNC code of the subscribers home network. Used to identify the operator responsible for billing and to distinguish home vs. roaming traffic.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReference rdf:type rdf:Property ;
    rdfs:label 'Message Reference' ;
    rdfs:comment 'Unique reference identifier assigned by the originating application or SMSC for message tracking and delivery receipt correlation. Used for A2P campaign tracking and delivery confirmation.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSegmentCount rdf:type rdf:Property ;
    rdfs:label 'Message Segment Count' ;
    rdfs:comment 'Number of SMS segments required to transmit the message. Standard SMS is 160 characters (1 segment); longer messages are split into multiple concatenated segments, each rated separately.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Message Size Bytes' ;
    rdfs:comment 'Total size of the SMS or MMS message payload in bytes. Used for rating, especially for MMS and concatenated SMS messages that span multiple segments.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Timestamp' ;
    rdfs:comment 'The exact date and time when the SMS message was originated or received by the network, captured in UTC. This is the principal business event timestamp for rating and billing purposes.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'Classification of the SMS message: MT (Mobile Terminated - incoming to subscriber), MO (Mobile Originated - outgoing from subscriber), P2P (Person-to-Person), A2P (Application-to-Person for commercial messaging), P2A (Person-to-Application), MMS (Multimedia Messaging Service).' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingMsisdn rdf:type rdf:Property ;
    rdfs:label 'Originating Msisdn' ;
    rdfs:comment 'The phone number of the subscriber or application that originated the SMS message. Personally identifiable information subject to CPNI and privacy regulations.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partitionDate rdf:type rdf:Property ;
    rdfs:label 'Partition Date' ;
    rdfs:comment 'The date used for physical partitioning of this SMS record in the lakehouse storage layer, typically derived from message_timestamp. Used for query optimization and data lifecycle management.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolIdentifier rdf:type rdf:Property ;
    rdfs:label 'Protocol Identifier' ;
    rdfs:comment 'SMS protocol identifier code indicating the type of message protocol used (e.g., standard SMS, SIM data download, email gateway). Used for technical troubleshooting and protocol-specific routing.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyPathFlag rdf:type rdf:Property ;
    rdfs:label 'Reply Path Flag' ;
    rdfs:comment 'Boolean flag indicating whether a reply path was requested for this SMS, allowing the recipient to reply via the same SMSC route. True if reply path enabled, false otherwise.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smscAddress rdf:type rdf:Property ;
    rdfs:label 'Smsc Address' ;
    rdfs:comment 'Network address of the SMSC node that processed and routed this SMS message. Used for network troubleshooting and capacity planning.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spamScore rdf:type rdf:Property ;
    rdfs:label 'Spam Score' ;
    rdfs:comment 'Numeric score (0.00 to 100.00) assigned by spam detection algorithms indicating the likelihood that this SMS is unsolicited commercial messaging or spam. Higher scores indicate higher spam probability.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminatingMsisdn rdf:type rdf:Property ;
    rdfs:label 'Terminating Msisdn' ;
    rdfs:comment 'The phone number of the subscriber or application that received the SMS message. Personally identifiable information subject to CPNI and privacy regulations.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMinutes rdf:type rdf:Property ;
    rdfs:label 'Validity Period Minutes' ;
    rdfs:comment 'The time period (in minutes) during which the SMSC will attempt to deliver the message before expiring it. Null if default validity period applies.' ;
    rdfs:domain ind:SmsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anomalyId rdf:type rdf:Property ;
    rdfs:label 'Anomaly Id' ;
    rdfs:comment 'Unique identifier for the usage anomaly record. Primary key.' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionRuleId rdf:type rdf:Property ;
    rdfs:label 'Detection Rule Id' ;
    rdfs:comment 'Identifier of the revenue assurance or mediation rule that triggered the anomaly detection.' ;
    rdfs:domain ind:Usage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DetectionRule .

ind:affectedRecordReference rdf:type rdf:Property ;
    rdfs:label 'Affected Record Reference' ;
    rdfs:comment 'External reference or identifier of the specific usage record that exhibited the anomaly (CDR sequence number, IPDR session ID, TAP file record number).' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anomalyType rdf:type rdf:Property ;
    rdfs:label 'Anomaly Type' ;
    rdfs:comment 'Classification of the detected anomaly: duplicate CDR (same record ingested multiple times), missing sequence (gap in CDR sequence numbers), volume spike (abnormal usage volume), zero duration call (call with zero or null duration), grey route indicator (suspected unauthorized routing), negative duration (invalid negative time value), invalid destination (malformed or non-existent destination number), roaming mismatch (roaming partner data inconsistency). [ENUM-REF-CANDIDATE: duplicate_cdr|missing_sequence|volume_spike|zero_duration_call|grey_route_indicator|negative_duration|invalid_destination|roaming_mismatch — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Detection Source System' ;
    rdfs:comment 'Name or identifier of the system that detected the anomaly (mediation platform, revenue assurance engine, fraud management system).' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedValue rdf:type rdf:Property ;
    rdfs:label 'Expected Value' ;
    rdfs:comment 'Expected or baseline value for the attribute that triggered the anomaly (e.g., expected sequence number, typical volume range, standard duration threshold).' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current workflow status of the anomaly investigation: new (detected, not yet assigned), assigned (assigned to analyst), in progress (under active investigation), resolved (root cause identified and corrected), closed (investigation complete), false positive (determined not to be a genuine anomaly).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAnomalyCount rdf:type rdf:Property ;
    rdfs:label 'Related Anomaly Count' ;
    rdfs:comment 'Number of related or similar anomalies detected in the same time window or for the same subscriber, indicating potential systemic or fraud patterns.' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'Estimated revenue impact (leakage or overcharge) resulting from the anomaly, in the billing currency.' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Roaming Partner Code' ;
    rdfs:comment 'Code identifying the roaming partner network involved in the usage event, applicable for roaming anomalies.' ;
    rdfs:domain ind:Anomaly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Bundle Subscription Id' ;
    rdfs:comment 'Reference to the specific bundle instance this balance tracks. Links to the bundle or rate plan instance.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BundleSubscription .

ind:lastConsumptionEventId rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Event Id' ;
    rdfs:comment 'Identifier of the most recent consumption event. Links to the detailed usage event record for audit purposes.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatedEvent .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'Type of usage balance being tracked. Categorizes the balance by service type.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingSystemSource rdf:type rdf:Property ;
    rdfs:label 'Charging System Source' ;
    rdfs:comment 'Source system that generated or updated this balance record. Identifies the authoritative charging platform.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Consumption Percentage' ;
    rdfs:comment 'Percentage of the initial balance that has been consumed. Calculated as (consumed / initial) * 100.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairUsagePolicyFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Usage Policy Flag' ;
    rdfs:comment 'Indicates whether this balance is subject to fair usage policy restrictions that may limit consumption.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairUsageThreshold rdf:type rdf:Property ;
    rdfs:label 'Fair Usage Threshold' ;
    rdfs:comment 'Consumption threshold defined by fair usage policy. Beyond this limit, restrictions or throttling may apply.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialBalanceQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Balance Quantity' ;
    rdfs:comment 'The starting quantity of the balance at the beginning of the period. Represents the total allowance granted.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastConsumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Timestamp' ;
    rdfs:comment 'Timestamp of the most recent consumption event that affected this balance. Used for real-time balance queries.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastTopUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Top Up Timestamp' ;
    rdfs:comment 'Timestamp of the most recent top-up or recharge event that added to this balance.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationThreshold1 rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold 1' ;
    rdfs:comment 'First consumption percentage threshold that triggers a balance notification to the subscriber.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationThreshold2 rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold 2' ;
    rdfs:comment 'Second consumption percentage threshold that triggers a balance notification to the subscriber.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageFlag rdf:type rdf:Property ;
    rdfs:label 'Overage Flag' ;
    rdfs:comment 'Indicates whether the subscriber has exceeded the allocated balance and is incurring overage charges.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overageQuantity rdf:type rdf:Property ;
    rdfs:label 'Overage Quantity' ;
    rdfs:comment 'Quantity consumed beyond the allocated balance. Only populated when overage_flag is true.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Timestamp' ;
    rdfs:comment 'Timestamp when the current balance period ends or expires. After this time, unused balance may be forfeited.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Start Timestamp' ;
    rdfs:comment 'Timestamp when the current balance period began. Marks the start of the billing or bundle cycle.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Current remaining quantity available in the balance. Calculated as initial minus consumed.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Flag' ;
    rdfs:comment 'Indicates whether unused balance can roll over to the next period. Defines balance carryover policy.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverQuantity rdf:type rdf:Property ;
    rdfs:label 'Rollover Quantity' ;
    rdfs:comment 'Quantity of balance rolled over from the previous period. Only populated when rollover_flag is true.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedBalanceFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Balance Flag' ;
    rdfs:comment 'Indicates whether this balance is shared across multiple subscribers or devices in a family or corporate plan.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throttleAction rdf:type rdf:Property ;
    rdfs:label 'Throttle Action' ;
    rdfs:comment 'Description of the throttling action applied when threshold is reached. May include speed reduction details or service restrictions.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleStatus rdf:type rdf:Property ;
    rdfs:label 'Throttle Status' ;
    rdfs:comment 'Current throttling state of the balance. Indicates whether service speed or quality has been reduced due to consumption.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Throttle Threshold Quantity' ;
    rdfs:comment 'The consumption level at which throttling or speed reduction is triggered. Typically a percentage of initial balance.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topUpCount rdf:type rdf:Property ;
    rdfs:label 'Top Up Count' ;
    rdfs:comment 'Number of top-up or recharge events that have added to this balance during the current period.' ;
    rdfs:domain ind:Balance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctionId rdf:type rdf:Property ;
    rdfs:label 'Correction Id' ;
    rdfs:comment 'Unique identifier for the usage correction record. Primary key for the usage correction entity.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'User ID of the manager or supervisor who approved the correction. Null if correction does not require approval or is still pending.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctionCorrectedSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Correction Corrected Subscriber Id' ;
    rdfs:comment 'Subscriber ID to which the usage was reassigned after correction. Used for subscriber reassignment corrections.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:correctionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Correction Employee Id' ;
    rdfs:comment 'User ID or system identifier of the person or process that initiated the correction. Used for audit trail and accountability tracking.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctionOriginalSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Correction Original Subscriber Id' ;
    rdfs:comment 'Subscriber ID to which the usage was originally attributed before correction. Used for subscriber reassignment corrections.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:correctionSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Correction Subscriber Id' ;
    rdfs:comment 'Reference to the subscriber account associated with the corrected usage event. Used for billing dispute resolution and subscriber-specific corrections.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:reversedCorrectionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Correction Id' ;
    rdfs:comment 'Reference to the original correction record that is being reversed by this correction. Null if this is not a reversal correction.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Correction .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Date and time when the correction was applied to the billing system and financial impact was realized. Null if correction has not yet been applied. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctedCallDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Corrected Call Duration Seconds' ;
    rdfs:comment 'Corrected call or session duration in seconds after adjustment. Null if correction does not involve duration adjustment.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctedDataVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Corrected Data Volume Bytes' ;
    rdfs:comment 'Corrected data volume in bytes after adjustment. Null if correction does not involve volume adjustment.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctedRatedAmount rdf:type rdf:Property ;
    rdfs:label 'Corrected Rated Amount' ;
    rdfs:comment 'Corrected monetary amount charged for the usage event after adjustment. Used to calculate financial impact of the correction.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctionStatus rdf:type rdf:Property ;
    rdfs:label 'Correction Status' ;
    rdfs:comment 'Current workflow status of the correction record. Tracks approval and application lifecycle. Values: pending (awaiting approval), approved (authorized for application), rejected (correction denied), applied (correction successfully applied to billing), reversed (correction rolled back).' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Correction Timestamp' ;
    rdfs:comment 'Date and time when the correction was created in the system. Represents the business event time of the correction initiation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctionType rdf:type rdf:Property ;
    rdfs:label 'Correction Type' ;
    rdfs:comment 'Category of correction applied to the usage event. Determines the nature of the adjustment and the fields modified. Values: duplicate_removal (duplicate CDR detected), duration_adjustment (call/session duration corrected), volume_correction (data volume adjusted), misrouted_cdr (CDR routed to wrong account), subscriber_reassignment (usage reassigned to correct subscriber), test_call_removal (test/maintenance traffic removed).' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNoteGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Note Generated Flag' ;
    rdfs:comment 'Indicates whether a credit note was issued to the customer as a result of this correction. True if credit note was generated, false otherwise.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Net financial impact of the correction (corrected amount minus original amount). Positive values indicate additional charges (debit), negative values indicate credits to the customer.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCallDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Original Call Duration Seconds' ;
    rdfs:comment 'Original call or session duration in seconds before correction was applied. Null if correction does not involve duration adjustment.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalDataVolumeBytes rdf:type rdf:Property ;
    rdfs:label 'Original Data Volume Bytes' ;
    rdfs:comment 'Original data volume in bytes before correction was applied. Null if correction does not involve volume adjustment.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalRatedAmount rdf:type rdf:Property ;
    rdfs:label 'Original Rated Amount' ;
    rdfs:comment 'Original monetary amount charged for the usage event before correction. Used to calculate financial impact of the correction.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAuditReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Audit Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory audit or compliance review that identified the need for this correction. Required for FCC, Ofcom, and other regulatory audit trails.' ;
    rdfs:domain ind:Correction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volteSessionId rdf:type rdf:Property ;
    rdfs:label 'Volte Session Id' ;
    rdfs:comment 'Unique identifier for the VoLTE/VoNR IMS session record. Primary key.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callSetupTimeMs rdf:type rdf:Property ;
    rdfs:label 'Call Setup Time Ms' ;
    rdfs:comment 'Time in milliseconds from SIP INVITE to SIP 200 OK (answer). Key metric for Call Setup Success Rate (CSSR) KPI.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callingPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Calling Party Number' ;
    rdfs:comment 'Telephone number of the party initiating the call (A-party). May be MSISDN or other E.164 number.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargingType rdf:type rdf:Property ;
    rdfs:label 'Charging Type' ;
    rdfs:comment 'Charging model applied to this session: postpaid (offline charging) or prepaid (online charging with real-time balance deduction).' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecNegotiated rdf:type rdf:Property ;
    rdfs:label 'Codec Negotiated' ;
    rdfs:comment 'Audio codec negotiated for the VoLTE session via SDP (Session Description Protocol). AMR-WB and EVS provide HD voice quality.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCallFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Call Flag' ;
    rdfs:comment 'Boolean flag indicating whether this was an emergency call (E911 in North America, E112 in Europe). Emergency calls have special routing and regulatory requirements.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverCount rdf:type rdf:Property ;
    rdfs:label 'Handover Count' ;
    rdfs:comment 'Number of handover events (cell changes) that occurred during the VoLTE session. Includes intra-RAT and inter-RAT handovers.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imsChargingReference rdf:type rdf:Property ;
    rdfs:label 'Ims Charging Reference' ;
    rdfs:comment 'IMS charging correlation identifier used to correlate this session record with charging events in the online/offline charging systems.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Location Accuracy Meters' ;
    rdfs:comment 'Estimated accuracy radius of the location coordinates in meters. Critical for E911 compliance (FCC requires <50m for 80% of calls).' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the subscriber at session start. Captured for emergency call location and network analytics.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the subscriber at session start. Captured for emergency call location and network analytics.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediationBatchReference rdf:type rdf:Property ;
    rdfs:label 'Mediation Batch Reference' ;
    rdfs:comment 'Identifier of the mediation batch that processed and transformed this raw IMS session record. Used for reconciliation and reprocessing.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pCscfAddress rdf:type rdf:Property ;
    rdfs:label 'P Cscf Address' ;
    rdfs:comment 'IP address of the Proxy Call Session Control Function node that served as the first point of contact in the IMS network for this session.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundTripDelayMs rdf:type rdf:Property ;
    rdfs:label 'Round Trip Delay Ms' ;
    rdfs:comment 'Average round-trip delay (latency) in milliseconds for RTP packets during the session. ITU-T recommends <150ms for acceptable voice quality.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sCscfAddress rdf:type rdf:Property ;
    rdfs:label 'S Cscf Address' ;
    rdfs:comment 'IP address of the Serving Call Session Control Function node that performed session control and routing for this VoLTE session.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionAnswerTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Answer Timestamp' ;
    rdfs:comment 'Timestamp when the called party answered the call (SIP 200 OK received). Null if call was not answered.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sipSessionReference rdf:type rdf:Property ;
    rdfs:label 'Sip Session Reference' ;
    rdfs:comment 'Session Initiation Protocol session identifier (Call-ID header) uniquely identifying the IMS call session at the SIP layer.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sipTerminationCode rdf:type rdf:Property ;
    rdfs:label 'Sip Termination Code' ;
    rdfs:comment 'SIP response code at session termination (e.g., 200 for normal, 486 for busy, 503 for unavailable). Numeric code per IETF RFC 3261.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:srvccEventFlag rdf:type rdf:Property ;
    rdfs:label 'Srvcc Event Flag' ;
    rdfs:comment 'Boolean flag indicating whether a Single Radio Voice Call Continuity handover occurred (LTE VoLTE to 3G/2G circuit-switched fallback).' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:srvccTargetRat rdf:type rdf:Property ;
    rdfs:label 'Srvcc Target Rat' ;
    rdfs:comment 'Target Radio Access Technology for SRVCC handover: UMTS (3G) or GSM (2G). Null if no SRVCC event occurred.' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationCause rdf:type rdf:Property ;
    rdfs:label 'Termination Cause' ;
    rdfs:comment 'Reason for session termination. Maps to SIP response codes and IMS release causes. Critical for call drop analysis. [ENUM-REF-CANDIDATE: normal_clearing|user_busy|no_answer|network_congestion|call_rejected|service_unavailable|radio_link_failure|handover_failure|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolteSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTerritoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Approved Territory Coverage' ;
    rdfs:comment 'Geographic regions, states, or service areas where the contractor is authorized to operate. May include postal codes, city names, or regional identifiers.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageSlaAdherencePct rdf:type rdf:Property ;
    rdfs:label 'Average Sla Adherence Pct' ;
    rdfs:comment 'Average percentage of work orders completed within agreed SLA (Service Level Agreement) timeframes, calculated over the trailing 12 months.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexOpexAllocation rdf:type rdf:Property ;
    rdfs:label 'Capex Opex Allocation' ;
    rdfs:comment 'Accounting classification indicating whether contractor costs are primarily allocated to CAPEX (Capital Expenditure) for network build-out or OPEX (Operational Expenditure) for maintenance and operations.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationsHeld rdf:type rdf:Property ;
    rdfs:label 'Certifications Held' ;
    rdfs:comment 'Comma-separated list of industry certifications and qualifications held by the contractor organization (e.g., BICSI, OSHA 30, FCC Tower Climbing, 5G NR Specialist).' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number of the master service agreement or framework contract governing the contractor engagement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorType rdf:type rdf:Property ;
    rdfs:label 'Contractor Type' ;
    rdfs:comment 'Classification of the contractor relationship type based on engagement model and scope.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the contractor engagement indicating whether the contractor is available for new work assignments.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the contractor\'s liability and workers compensation insurance certificate on file.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for contractor invoicing and payments.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean indicator of whether this contractor has been designated as a preferred vendor for priority assignment consideration.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityDefectRate rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Rate' ;
    rdfs:comment 'Percentage of completed work orders that required rework or failed quality inspection, calculated over the trailing 12 months.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier for the agreed rate card or pricing schedule governing contractor billing rates by service type and skill level.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Total number of reportable safety incidents involving the contractor\'s workforce during the engagement period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCategories rdf:type rdf:Property ;
    rdfs:label 'Service Categories' ;
    rdfs:comment 'Comma-separated list of service categories the contractor is approved to perform, such as FTTH (Fiber to the Home) installation, 5G NR (5G New Radio) deployment, tower maintenance, GPON (Gigabit Passive Optical Network) provisioning, CPE (Customer Premises Equipment) installation, or RAN (Radio Access Network) optimization.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTechniciansAssigned rdf:type rdf:Property ;
    rdfs:label 'Total Technicians Assigned' ;
    rdfs:comment 'Current count of individual technicians or crew members from this contractor actively assigned to work orders or projects.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWorkOrdersCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Work Orders Completed' ;
    rdfs:comment 'Cumulative count of work orders successfully completed by this contractor since onboarding.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorManagementSystemCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Management System Code' ;
    rdfs:comment 'External identifier for this contractor in the enterprise Vendor Management System or procurement platform (e.g., SAP S/4HANA Supplier ID).' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEnterpriseSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Enterprise Segment Id' ;
    rdfs:comment 'Foreign key linking to enterprise.segment. Business justification: Depots often specialize by customer segment (enterprise vs SMB vs residential) due to different CPE inventory, skill requirements, vehicle equipment, and SLA urgency. Drives depot capacity planning, p' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:depotCode rdf:type rdf:Property ;
    rdfs:label 'Depot Code' ;
    rdfs:comment 'Business identifier code for the depot used in workforce management systems and route optimization. Externally-known unique code for operational reference.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'Human-readable name of the depot facility (e.g., \'North Regional Dispatch Center\', \'Downtown Service Yard\').' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Classification of the depot facility based on its operational role and capacity. Central warehouse serves as primary distribution hub, satellite yard provides local staging, NOC (Network Operations Center) dispatch center handles network emergency response, mobile hub supports temporary deployments, regional staging consolidates area operations, field office provides administrative support.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for the depot facility for administrative communication and work order coordination.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Facility Ownership Type' ;
    rdfs:comment 'Classification of how the depot facility is controlled. Owned indicates company property, leased for rental agreement, shared for co-location with partners, temporary for short-term arrangements.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Availability Flag' ;
    rdfs:comment 'Indicates whether the depot operates on public holidays. True if depot maintains operations during holidays, False if closed.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nocIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Noc Integration Flag' ;
    rdfs:comment 'Indicates whether this depot is integrated with or co-located with a Network Operations Center for real-time network fault response and emergency dispatch.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the depot on weekdays (Monday-Friday) in format \'HH:MM-HH:MM\' (e.g., \'06:00-18:00\'). Used for dispatch scheduling and technician availability planning.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Operating hours for the depot on weekends (Saturday-Sunday) in format \'HH:MM-HH:MM\'. May differ from weekday hours or be closed.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Flag' ;
    rdfs:comment 'Indicates whether this depot maintains an inventory of network equipment parts and Customer Premises Equipment (CPE) for technician provisioning. True if inventory is stocked, False if technicians source parts elsewhere.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the depot facility for operational coordination and technician communication.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDepotFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Depot Flag' ;
    rdfs:comment 'Indicates whether this is the primary depot for its service territory. True if primary hub, False if satellite or secondary facility.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionalManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Email' ;
    rdfs:comment 'Email address of the regional manager for operational communication and escalation.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerName rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Name' ;
    rdfs:comment 'Full name of the regional manager responsible for overseeing depot operations and workforce coordination.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Phone' ;
    rdfs:comment 'Contact phone number for the regional manager responsible for this depot.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Physical security classification of the depot facility. Standard for basic access control, enhanced for monitored entry, high security for critical infrastructure protection, restricted access for sensitive equipment storage.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceZonePolygon rdf:type rdf:Property ;
    rdfs:label 'Service Zone Polygon' ;
    rdfs:comment 'Geographic boundary polygon defining the service coverage area assigned to this depot, stored as Well-Known Text (WKT) or GeoJSON format. Used for territory assignment and technician dispatch optimization.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianHeadcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Technician Headcount Capacity' ;
    rdfs:comment 'Maximum number of field technicians that can be assigned to and dispatched from this depot as their home base.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Tool Storage Capacity Sqft' ;
    rdfs:comment 'Total tool and equipment storage capacity at the depot measured in square feet. Used for inventory planning and space utilization analysis.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleBayCapacity rdf:type rdf:Property ;
    rdfs:label 'Vehicle Bay Capacity' ;
    rdfs:comment 'Maximum number of service vehicles that can be parked and maintained at the depot facility simultaneously.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekendAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Availability Flag' ;
    rdfs:comment 'Indicates whether the depot operates on weekends. True if depot is open Saturday or Sunday, False if closed all weekend.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wfmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wfm System Code' ;
    rdfs:comment 'External identifier for this depot in the Granite Telecommunications Workforce Management system. Used for system integration and data reconciliation.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchEventId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Event Id' ;
    rdfs:comment 'Unique identifier for the dispatch event record. Primary key for the dispatch event transaction.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldVehicleId rdf:type rdf:Property ;
    rdfs:label 'Field Vehicle Id' ;
    rdfs:comment 'Reference to the service vehicle assigned to the technician for this dispatch event. Used for fleet management, route optimization, and asset utilization analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldVehicle .

ind:primaryDispatchTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Dispatch Technician Id' ;
    rdfs:comment 'Reference to the field technician assigned to this dispatch event. Represents the current technician responsible for executing the work order.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:afterHoursFlag rdf:type rdf:Property ;
    rdfs:label 'After Hours Flag' ;
    rdfs:comment 'Boolean indicator of whether the dispatch occurred outside of standard business hours (evenings, weekends, holidays). True indicates after-hours dispatch, which may incur premium labor costs and affect OPEX (Operational Expenditure) analysis.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Date and time when the technician arrived at the customer premises or network site, as recorded by the mobile workforce application or GPS tracking. Used for SLA compliance verification.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchChannel rdf:type rdf:Property ;
    rdfs:label 'Dispatch Channel' ;
    rdfs:comment 'The communication channel or interface through which the dispatch instruction was transmitted to the technician: mobile workforce app, two-way radio, manual entry in WFM (Workforce Management) system, automated WFM routing engine, voice call, or SMS notification.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchLatitude rdf:type rdf:Property ;
    rdfs:label 'Dispatch Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84) of the technician\'s location at the moment of dispatch event creation. Used for route optimization analysis and dispatch efficiency metrics.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchLongitude rdf:type rdf:Property ;
    rdfs:label 'Dispatch Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84) of the technician\'s location at the moment of dispatch event creation. Used for route optimization analysis and dispatch efficiency metrics.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text operational notes entered by the dispatcher or system, providing additional instructions, site access information, safety warnings, or special handling requirements for the technician.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Human-readable business identifier for the dispatch event, used for tracking and audit purposes in field operations and NOC (Network Operations Center) systems.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPriority rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority' ;
    rdfs:comment 'Urgency classification of the dispatch event: critical for network outages affecting multiple customers, high for SLA-sensitive installations, medium for standard service requests, low for routine maintenance.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the dispatch action. For initial dispatch: work order type. For reassignment: reason for reassignment (skill mismatch, technician unavailable, workload balancing). For escalation: complexity escalation, SLA breach risk. For cancellation: customer cancellation, duplicate order, resolved remotely.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispatch Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the dispatch action, supplementing the standardized reason code. Used for root-cause analysis and operational improvement.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Dispatch Source System' ;
    rdfs:comment 'The originating system or module that created the dispatch event: Granite Telecommunications WFM automated routing, manual NOC dispatcher entry, automated OSS (Operations Support Systems) integration, CRM-triggered dispatch, or emergency dispatch system.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch event: pending technician acknowledgment, acknowledged by technician, technician en route to site, technician arrived on site, dispatch completed, dispatch failed, or dispatch cancelled. [ENUM-REF-CANDIDATE: pending|acknowledged|en_route|arrived|completed|failed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchType rdf:type rdf:Property ;
    rdfs:label 'Dispatch Type' ;
    rdfs:comment 'Classification of the dispatch action: initial assignment to technician, reassignment to different technician, escalation to senior technician, cancellation of dispatch, return-to-depot instruction, or emergency dispatch for critical network outages.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchZoneCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Zone Code' ;
    rdfs:comment 'Geographic service zone or territory code where the dispatch event occurs. Used for workload balancing, regional performance analysis, and territory management.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Flag' ;
    rdfs:comment 'Boolean indicator of whether this dispatch is classified as an emergency response (e.g., critical network outage, service-affecting fault, safety hazard). True indicates emergency dispatch requiring immediate response.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enRouteTimestamp rdf:type rdf:Property ;
    rdfs:label 'En Route Timestamp' ;
    rdfs:comment 'Date and time when the technician marked themselves as en route to the target site in the mobile workforce application. Used for real-time tracking and customer ETA updates.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Projected date and time when the technician is expected to arrive at the target site, calculated at dispatch time. Used for customer communication and SLA monitoring.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Calculated travel time in minutes from the technician\'s dispatch location to the target site, based on route optimization algorithms and real-time traffic data at dispatch time.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'Cumulative count of how many times the underlying work order has been reassigned to different technicians. Incremented with each reassignment dispatch event. Used for operational efficiency analysis and first-time-fix rate calculation.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement Code' ;
    rdfs:comment 'Standardized code representing the technical skill or certification required for this dispatch event (e.g., FTTH installation, GPON troubleshooting, CPE configuration, RAN maintenance). Used for skill-based routing and technician assignment validation.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetArrivalMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Arrival Minutes' ;
    rdfs:comment 'The contractual SLA target for technician arrival time in minutes from dispatch timestamp, based on work order priority and customer service tier. Used for SLA breach detection and root-cause analysis.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSiteLatitude rdf:type rdf:Property ;
    rdfs:label 'Target Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84) of the customer premises or network site where the technician is being dispatched. Used for travel time estimation and route planning.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSiteLongitude rdf:type rdf:Property ;
    rdfs:label 'Target Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84) of the customer premises or network site where the technician is being dispatched. Used for travel time estimation and route planning.' ;
    rdfs:domain ind:DispatchEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Current Technician Id' ;
    rdfs:comment 'Identifier of the technician currently assigned to this vehicle. Null if vehicle is unassigned. Reflects the most recent assignment record.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost paid to acquire the vehicle, including purchase price, taxes, and initial outfitting. Used for asset valuation and ROI analysis.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFuelConsumptionPer100km rdf:type rdf:Property ;
    rdfs:label 'Average Fuel Consumption Per 100km' ;
    rdfs:comment 'Rolling average fuel consumption rate in liters (or kWh for electric) per 100 kilometers. Used for cost forecasting and environmental reporting.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Primary exterior color of the vehicle. Used for visual identification and branding compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentAssignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Assignment Start Timestamp' ;
    rdfs:comment 'Timestamp when the current technician assignment began. Null if vehicle is unassigned. Used for utilization tracking.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentAssignmentType rdf:type rdf:Property ;
    rdfs:label 'Current Assignment Type' ;
    rdfs:comment 'Type of the current assignment. Permanent assignments are long-term; daily and emergency are short-term. Affects dispatch planning.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFitted rdf:type rdf:Property ;
    rdfs:label 'Equipment Fitted' ;
    rdfs:comment 'Comma-separated list of specialized equipment installed on the vehicle (e.g., aerial lift, cable drum, OTDR, fusion splicer, ladder rack). Determines work order eligibility.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel or energy source the vehicle uses. Critical for fuel cost allocation and environmental reporting.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether the vehicle is equipped with active GPS tracking. Used for real-time fleet visibility and route optimization.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight Kg' ;
    rdfs:comment 'Maximum allowable total weight of the vehicle including cargo and passengers. Used for regulatory compliance and route planning.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Due Date' ;
    rdfs:comment 'Date when the next mandatory safety inspection is due. Required for regulatory compliance and dispatch eligibility.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Load Capacity Kg' ;
    rdfs:comment 'Maximum payload capacity of the vehicle in kilograms. Used for equipment assignment and safety compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Due Date' ;
    rdfs:comment 'Date when the next scheduled preventive maintenance is due. Calculated based on odometer and time intervals per manufacturer specifications.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer or brand of the vehicle (e.g., Ford, Chevrolet, Mercedes-Benz).' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific model designation of the vehicle (e.g., Transit, Silverado, Sprinter).' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'Year the vehicle model was manufactured. Used for depreciation calculation and maintenance scheduling.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Current odometer reading in kilometers. Updated at each assignment return. Used for maintenance scheduling and lifecycle management.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationPlate rdf:type rdf:Property ;
    rdfs:label 'Registration Plate' ;
    rdfs:comment 'License plate number assigned to the vehicle by the motor vehicle authority. Unique identifier for legal and operational tracking.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Number of passenger seats in the vehicle. Used for crew assignment and safety compliance.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the telematics device installed in the vehicle. Used to link vehicle data with real-time telemetry streams.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Cumulative maintenance and repair costs incurred over the vehicle\'s lifetime. Used for total cost of ownership (TCO) analysis.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Identification Number' ;
    rdfs:comment '17-character unique identifier assigned by the manufacturer. Used for warranty, recall, theft tracking, and asset verification.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Status' ;
    rdfs:comment 'Current operational status of the vehicle. Determines dispatch eligibility and fleet utilization metrics.' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Functional classification of the vehicle based on its primary use in field operations. Determines equipment compatibility and dispatch eligibility. [ENUM-REF-CANDIDATE: van|bucket_truck|cable_laying_truck|fiber_splicing_unit|pickup_truck|utility_vehicle|heavy_equipment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FieldVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePlanId rdf:type rdf:Property ;
    rdfs:label 'Route Plan Id' ;
    rdfs:comment 'Unique identifier for the route plan record. Primary key for the route plan entity.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRouteCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Route Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that created the route plan (dispatcher, automated scheduler, or system).' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRouteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Route Employee Id' ;
    rdfs:comment 'Identifier of the dispatcher or supervisor who approved the route plan for execution.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'Actual travel distance covered by the technician in kilometers, captured from GPS tracking or vehicle telematics.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Travel Time Minutes' ;
    rdfs:comment 'Actual total travel time in minutes spent by the technician moving between stops, captured from GPS tracking.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWorkTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Work Time Minutes' ;
    rdfs:comment 'Actual total on-site work time in minutes spent by the technician across all stops.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedStops rdf:type rdf:Property ;
    rdfs:label 'Completed Stops' ;
    rdfs:comment 'Number of stops that have been completed by the technician as of the current time.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerEtaNotificationsSent rdf:type rdf:Property ;
    rdfs:label 'Customer Eta Notifications Sent' ;
    rdfs:comment 'Count of customer ETA notifications sent for stops in this route plan, supporting customer experience and SLA compliance.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedWorkTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Work Time Minutes' ;
    rdfs:comment 'Total estimated on-site work time in minutes across all stops, based on work order type and historical averages.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelEstimateLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Estimate Liters' ;
    rdfs:comment 'Estimated fuel consumption in liters for the route, calculated based on distance and vehicle fuel efficiency profile.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm' ;
    rdfs:comment 'The route optimization algorithm used by Granite WFM to generate this plan (e.g., time-window constrained, priority-weighted, fuel-optimized).' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Score' ;
    rdfs:comment 'Numerical score (0-100) representing the quality of the route optimization, calculated by the WFM engine based on efficiency metrics.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The calendar date for which this route plan was generated and is scheduled to be executed.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled return time to the depot after completing all stops, as planned by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled departure time from the depot to begin the route, as planned by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeNotes rdf:type rdf:Property ;
    rdfs:label 'Route Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to the route plan, such as road closures, access restrictions, or coordination requirements.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePlanNumber rdf:type rdf:Property ;
    rdfs:label 'Route Plan Number' ;
    rdfs:comment 'Human-readable business identifier for the route plan, typically formatted as RP-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Type of work shift during which this route plan is scheduled to be executed.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skippedStops rdf:type rdf:Property ;
    rdfs:label 'Skipped Stops' ;
    rdfs:comment 'Number of stops that were skipped or not completed during route execution.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total planned travel distance for the entire route in kilometers, calculated by the optimization engine.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of stops (work order sites) included in this route plan.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficConditionsConsidered rdf:type rdf:Property ;
    rdfs:label 'Traffic Conditions Considered' ;
    rdfs:comment 'Indicates whether real-time or historical traffic conditions were factored into the route optimization algorithm.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherConditionsConsidered rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions Considered' ;
    rdfs:comment 'Indicates whether weather forecast data was factored into the route planning and time estimates.' ;
    rdfs:domain ind:RoutePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Unique identifier for the safety incident record. Primary key.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Incident Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Safety incidents at network element locations (tower falls, electrical hazards) require linking incident to specific equipment for OSHA reporting, risk assessment, and site safety audits. Regulatory c' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:primarySafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Employee Id' ;
    rdfs:comment 'Workforce supervisor responsible for the technician at the time of incident. Required for accountability and investigation chain.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySafetyInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Investigator Employee Id' ;
    rdfs:comment 'Safety officer or manager assigned to lead the incident investigation. Null if investigation not yet assigned.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:triggeringRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Triggering Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Safety incidents trigger specific regulatory reporting obligations (OSHA recordable events, state safety authority notifications, workers\' compensation filings). Telecommunications companies must trac' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Body part(s) injured or affected by the incident (e.g., hand, back, head). Null for non-injury incidents.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Specific actions taken or planned to prevent recurrence of similar incidents. Includes procedural changes, training, equipment modifications, or policy updates.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the employee was unable to work due to the incident. Zero for incidents not requiring time off. Used for DART rate calculation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Duty' ;
    rdfs:comment 'Number of calendar days the employee worked restricted or light duty due to the incident. Used for DART rate calculation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Weather and environmental conditions at time of incident (e.g., rain, ice, high winds, extreme heat). Relevant for outdoor telecom work.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentInvolved rdf:type rdf:Property ;
    rdfs:label 'Equipment Involved' ;
    rdfs:comment 'Description of equipment, tools, or vehicles involved in the incident. Supports equipment safety tracking and maintenance correlation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentAddress rdf:type rdf:Property ;
    rdfs:label 'Incident Address' ;
    rdfs:comment 'Street address or site location where the incident occurred. Required for regulatory reporting and investigation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCity rdf:type rdf:Property ;
    rdfs:label 'Incident City' ;
    rdfs:comment 'City where the incident occurred. Supports geographic risk analysis and regional compliance reporting.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Incident Cost Estimate' ;
    rdfs:comment 'Estimated total cost of the incident including medical expenses, lost time, equipment damage, and administrative costs. Used for safety ROI analysis.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentLatitude rdf:type rdf:Property ;
    rdfs:label 'Incident Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of incident location. Enables GIS mapping and spatial risk analysis.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentLocationType rdf:type rdf:Property ;
    rdfs:label 'Incident Location Type' ;
    rdfs:comment 'Category of location where the incident occurred. Telecom-specific location taxonomy for hazard pattern analysis. [ENUM-REF-CANDIDATE: cell_tower|customer_premises|central_office|fiber_route|vehicle|warehouse|office|public_right_of_way|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLongitude rdf:type rdf:Property ;
    rdfs:label 'Incident Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of incident location. Enables GIS mapping and spatial risk analysis.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentPostalCode rdf:type rdf:Property ;
    rdfs:label 'Incident Postal Code' ;
    rdfs:comment 'ZIP or postal code of incident location. Supports geographic clustering and regional safety analytics.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Severity classification of the incident outcome. Determines regulatory reporting requirements and investigation depth.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentState rdf:type rdf:Property ;
    rdfs:label 'Incident State' ;
    rdfs:comment 'Two-letter state code where the incident occurred. Required for state-level OSHA reporting.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Precise timestamp when the incident occurred. Supports root cause analysis and shift pattern correlation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Specific nature of injury sustained (e.g., laceration, fracture, burn, strain). Null for non-injury incidents. Aligns with OSHA injury classification.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date the incident investigation was completed and findings documented. Null if investigation still in progress.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of hospital, clinic, or medical facility where treatment was provided. Null if no medical treatment required.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Required Flag' ;
    rdfs:comment 'Indicates whether the incident required medical treatment beyond first aid. Key factor in OSHA recordability determination.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Case Number' ;
    rdfs:comment 'OSHA 300 log case number assigned to recordable incidents. Null for non-recordable incidents.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recording on the 300 log. True if recordable, false otherwise.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeType rdf:type rdf:Property ;
    rdfs:label 'Ppe Type' ;
    rdfs:comment 'Specific types of PPE that were (or should have been) used during the incident (e.g., hard hat, safety harness, gloves, safety glasses).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Used Flag' ;
    rdfs:comment 'Indicates whether required Personal Protective Equipment was being used at the time of incident. Critical for compliance and root cause analysis.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMeasures rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures' ;
    rdfs:comment 'Proactive measures implemented to reduce likelihood of similar incidents across the workforce. Broader than corrective action for this specific incident.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Timestamp when regulatory notification was made to OSHA or other authorities. Null if notification not required or not yet completed.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Method' ;
    rdfs:comment 'Method used to notify regulatory authorities of the incident. Null if notification not required.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether the incident severity requires notification to OSHA or other regulatory bodies within mandated timeframes (e.g., fatality, hospitalization).' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date the incident was formally reported to management or safety team. Used to track reporting timeliness.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workersCompensationClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Claim Number' ;
    rdfs:comment 'Workers compensation insurance claim number associated with the incident. Null if no claim filed.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillId rdf:type rdf:Property ;
    rdfs:label 'Skill Id' ;
    rdfs:comment 'Unique identifier for the technical skill in the workforce skill taxonomy. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Skill .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Official name of the required certification (e.g., Ericsson Certified RAN Expert, Nokia NetAct Administrator, FOA CFOT).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether formal external certification is required to hold this skill (e.g., vendor certification for Ericsson RAN, Nokia NetAct, safety certifications).' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchPriorityWeight rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority Weight' ;
    rdfs:comment 'Numeric weight used in Granite WFM dispatch algorithm to prioritize technicians with this skill for matching work orders (higher weight = higher priority).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prerequisiteSkills rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Skills' ;
    rdfs:comment 'Comma-separated list of skill codes that must be held before this skill can be acquired (e.g., basic safety certification required before advanced RAN work).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelCompetentDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Competent Definition' ;
    rdfs:comment 'Definition of competent proficiency level for this skill: ability to perform tasks independently with standard supervision and quality expectations.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelExpertDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Expert Definition' ;
    rdfs:comment 'Definition of expert proficiency level for this skill: advanced capabilities, ability to handle complex scenarios, mentor others, and perform quality assurance.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevelTraineeDefinition rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Trainee Definition' ;
    rdfs:comment 'Definition of trainee proficiency level for this skill: expected capabilities, supervision requirements, and task limitations.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification events if recertification_required_flag is true.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementSkillCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Skill Code' ;
    rdfs:comment 'Skill code of the replacement skill if this skill has been deprecated or obsoleted (e.g., LTE skill replaced by 5G NR skill).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'High-level classification of the skill domain: RAN (Radio Access Network), Transport (MPLS, SD-WAN), Access (FTTH, GPON, DSLAM), Core (IMS, HSS, UDM), CPE (Customer Premises Equipment), Safety, Compliance, or Other. [ENUM-REF-CANDIDATE: RAN|Transport|Access|Core|CPE|Safety|Compliance|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillCode rdf:type rdf:Property ;
    rdfs:label 'Skill Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the skill, used in Granite WFM dispatch matching and work order assignment (e.g., FIBER-SPLICE, 5G-RAN-COMM, GPON-OLT-CFG).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillDescription rdf:type rdf:Property ;
    rdfs:label 'Skill Description' ;
    rdfs:comment 'Detailed description of the skill, including technical scope, typical tasks, and application context (e.g., \'Ability to perform single-mode and multi-mode fiber splicing, OTDR testing, and loss certification for trunk and distribution fiber networks\').' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Human-readable name of the technical skill (e.g., Fiber Splicing, 5G NR RAN Commissioning, GPON OLT Configuration, VoLTE IMS Troubleshooting).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillStatus rdf:type rdf:Property ;
    rdfs:label 'Skill Status' ;
    rdfs:comment 'Current lifecycle status of the skill in the taxonomy: Active (in use), Deprecated (being phased out), Obsolete (no longer used), Planned (future skill).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Estimated number of training hours required to achieve competent proficiency level for this skill.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Specific Flag' ;
    rdfs:comment 'Indicates whether this skill is specific to a particular equipment vendor (e.g., Ericsson RAN, Nokia NetAct, Huawei Transport) versus vendor-agnostic.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Work Order Type Applicability' ;
    rdfs:comment 'Comma-separated list of work order types this skill is applicable to (e.g., Installation, Maintenance, Repair, Commissioning, Decommissioning, Troubleshooting, Upgrade).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique identifier for the field workforce team or crew grouping. Primary key.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDepotId rdf:type rdf:Property ;
    rdfs:label 'Assigned Depot Id' ;
    rdfs:comment 'Reference to the depot or service center where the team is based. Defines the home location for team dispatch and resource allocation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:averageCompletionRatePct rdf:type rdf:Property ;
    rdfs:label 'Average Completion Rate Pct' ;
    rdfs:comment 'Historical average percentage of work orders completed successfully by the team on first visit. Key Performance Indicator (KPI) for team effectiveness.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Response Time Minutes' ;
    rdfs:comment 'Historical average time in minutes from work order dispatch to team arrival at site. Key Performance Indicator (KPI) for team responsiveness.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disbandmentDate rdf:type rdf:Property ;
    rdfs:label 'Disbandment Date' ;
    rdfs:comment 'Date when the team was disbanded or deactivated. Null for active teams. Used for historical workforce analysis.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbandmentReason rdf:type rdf:Property ;
    rdfs:label 'Disbandment Reason' ;
    rdfs:comment 'Business reason for team disbandment. Examples: project_completion, reorganization, budget_reduction, skill_consolidation. Null for active teams.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseCapable rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Capable' ;
    rdfs:comment 'Indicates whether the team is trained and equipped for emergency response and network outage restoration. True if the team can be mobilized for critical incidents.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date when the team was originally formed and activated in the workforce management system. Used for team lifecycle tracking.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headcount rdf:type rdf:Property ;
    rdfs:label 'Headcount' ;
    rdfs:comment 'Current number of active technicians assigned to the team. Used for capacity planning and resource allocation.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSafetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Training Date' ;
    rdfs:comment 'Date when the team last completed mandatory safety training. Used for compliance tracking and certification management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'Maximum number of technicians that can be assigned to this team based on operational design and resource constraints.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileEquipped rdf:type rdf:Property ;
    rdfs:label 'Mobile Equipped' ;
    rdfs:comment 'Indicates whether the team has mobile workforce management devices and real-time connectivity for field operations. True if equipped with mobile WFM (Workforce Management) tools.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCertificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Certification Review Date' ;
    rdfs:comment 'Scheduled date for the next team certification review or skills assessment. Used for workforce development planning.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operational Hours End' ;
    rdfs:comment 'Standard daily end time for team operations in HH:MM format (24-hour). Used for dispatch scheduling and route optimization.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Start' ;
    rdfs:comment 'Standard daily start time for team operations in HH:MM format (24-hour). Used for dispatch scheduling and route optimization.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkillCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Skill Category' ;
    rdfs:comment 'Primary technical skill domain of the team. Defines the main area of expertise for work order assignment and capacity planning.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard work schedule pattern for the team. Defines availability windows for dispatch and work order scheduling.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationTags rdf:type rdf:Property ;
    rdfs:label 'Specialization Tags' ;
    rdfs:comment 'Comma-separated list of technical specializations and certifications held by the team. Examples: fiber_splicing, 5G_NR_rollout, GPON_activation, FTTH_installation, CPE_configuration, OLT_maintenance. Used for skill-based dispatch and work order matching.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Business identifier for the team, used in dispatch systems and field operations. Externally-known unique code for the team.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Human-readable name of the field workforce team or crew.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamStatus rdf:type rdf:Property ;
    rdfs:label 'Team Status' ;
    rdfs:comment 'Current operational status of the team in the workforce management system. Indicates whether the team is available for dispatch and work order assignment.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team based on primary function and specialization. Defines the operational role of the team within the workforce structure. [ENUM-REF-CANDIDATE: installation_crew|maintenance_gang|emergency_response|specialized_squad|fiber_splicing|5g_rollout|gpon_activation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Count' ;
    rdfs:comment 'Number of service vehicles assigned to the team for field operations and equipment transport.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisorTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Technician Id' ;
    rdfs:comment 'Identifier of the direct supervisor or field manager responsible for this technician\'s performance management and work assignment.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:attendanceRate rdf:type rdf:Property ;
    rdfs:label 'Attendance Rate' ;
    rdfs:comment 'Percentage of scheduled work days attended. Used for reliability assessment and workforce planning.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Current Performance Rating' ;
    rdfs:comment 'Most recent overall performance evaluation rating from the latest review cycle. Used for promotion decisions and workforce optimization.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTestDate rdf:type rdf:Property ;
    rdfs:label 'Drug Test Date' ;
    rdfs:comment 'Date of the most recent drug screening test. Required for safety-sensitive positions and compliance with Department of Transportation (DOT) regulations for commercial drivers.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstTimeFixRate rdf:type rdf:Property ;
    rdfs:label 'First Time Fix Rate' ;
    rdfs:comment 'Percentage of work orders resolved on the first visit without requiring return trips. Key performance indicator (KPI) for technician efficiency and customer satisfaction.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeDepotCode rdf:type rdf:Property ;
    rdfs:label 'Home Depot Code' ;
    rdfs:comment 'Code identifying the technician\'s assigned home depot or service center for reporting, equipment storage, and route optimization.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether the technician is currently on a formal performance improvement plan. Used for HR compliance and management escalation.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average time in minutes to complete repair work orders. Critical KPI for workforce productivity and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Score' ;
    rdfs:comment 'Percentage score (0-100) representing adherence to safety protocols, personal protective equipment (PPE) usage, and incident-free work history. Critical for field workforce risk management.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceZone rdf:type rdf:Property ;
    rdfs:label 'Service Zone' ;
    rdfs:comment 'Geographic service zone or territory assignment for dispatch optimization and workload balancing.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Rate' ;
    rdfs:comment 'Percentage of work orders completed within committed SLA timeframes. Critical for customer satisfaction and penalty avoidance.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolsKitCode rdf:type rdf:Property ;
    rdfs:label 'Tools Kit Code' ;
    rdfs:comment 'Identifier of the standard tools and equipment kit assigned to the technician. Used for inventory tracking and maintenance scheduling.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursYtd rdf:type rdf:Property ;
    rdfs:label 'Training Hours Ytd' ;
    rdfs:comment 'Total training and professional development hours completed in the current calendar year. Used for compliance reporting and skill development tracking.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Identifier of the company vehicle or fleet unit assigned to this technician for field operations and equipment transport.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrdersPerDay rdf:type rdf:Property ;
    rdfs:label 'Work Orders Per Day' ;
    rdfs:comment 'Average number of work orders completed per working day. Productivity metric used for capacity planning and workload balancing.' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceClassification rdf:type rdf:Property ;
    rdfs:label 'Workforce Classification' ;
    rdfs:comment 'Technical specialization area: Radio Access Network (RAN), Fiber to the Home (FTTH), Gigabit Passive Optical Network (GPON), Customer Premises Equipment (CPE), fiber splicing, transport network, core network, or hybrid multi-skill. [ENUM-REF-CANDIDATE: ran|ftth|gpon|cpe|splicing|transport|core|hybrid — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Technician ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianScheduleId rdf:type rdf:Property ;
    rdfs:label 'Technician Schedule Id' ;
    rdfs:comment 'Unique identifier for the technician schedule record. Primary key for the technician_schedule data product.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedNetworkElementId rdf:type rdf:Property ;
    rdfs:label 'Assigned Network Element Id' ;
    rdfs:comment 'Foreign key linking to network.element. Business justification: Preventive maintenance schedules assign technicians to specific network elements for routine inspections and maintenance. Enables proactive maintenance planning, ensures critical infrastructure receiv' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Element .

ind:primaryTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Technician Id' ;
    rdfs:comment 'Identifier of the technician to whom this schedule applies. Links to the technician master record in the workforce domain.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:shiftTemplateId rdf:type rdf:Property ;
    rdfs:label 'Shift Template Id' ;
    rdfs:comment 'Identifier of the shift template from which this schedule was generated. References standard shift patterns such as day shift, evening shift, on-call rotation, or weekend rotation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftTemplate .

ind:actualOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Overtime Hours' ;
    rdfs:comment 'Actual overtime hours worked during this shift, including both planned and emergency overtime. Captured from time tracking systems and used for payroll processing.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualWorkHours rdf:type rdf:Property ;
    rdfs:label 'Actual Work Hours' ;
    rdfs:comment 'Total hours the technician actually worked during this shift, captured from time tracking or mobile workforce systems. Used for payroll and productivity analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total allocated break time within the shift, measured in minutes. Includes lunch breaks and rest periods as per labor regulations and company policy.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the technician confirmed receipt and acceptance of this schedule assignment. Used to track acknowledgment compliance.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchSystemSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch System Sync Flag' ;
    rdfs:comment 'Indicates whether this schedule record has been successfully synchronized to the Granite Telecommunications WFM dispatch optimization system. Used for integration monitoring.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Leave Approval Date' ;
    rdfs:comment 'Date when the leave request was approved by the manager. Used for audit trail and to measure approval cycle time.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveRequestDate rdf:type rdf:Property ;
    rdfs:label 'Leave Request Date' ;
    rdfs:comment 'Date when the leave request was submitted by the technician. Used to track request-to-approval workflow timing and compliance with notice requirements.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Classification of absence or leave taken during this scheduled period. Null if the technician is working; populated when the schedule represents a leave block. [ENUM-REF-CANDIDATE: annual_leave|sick_leave|fmla|training_leave|emergency_absence|bereavement|jury_duty — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimePayClassification rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Classification' ;
    rdfs:comment 'Pay rate multiplier applied to overtime hours. Determined by labor agreements, shift timing (weekday vs weekend vs holiday), and overtime duration.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Overtime Reason Code' ;
    rdfs:comment 'Classification code indicating the business reason for overtime work. Used for cost allocation, workforce planning, and operational analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSystemSyncFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll System Sync Flag' ;
    rdfs:comment 'Indicates whether this schedule record and associated hours have been successfully synchronized to SAP S/4HANA payroll. Used for integration monitoring and payroll reconciliation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Overtime Hours' ;
    rdfs:comment 'Pre-approved overtime hours scheduled for this shift. Typically used for planned network rollout surges, maintenance windows, or outage response preparation.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWorkHours rdf:type rdf:Property ;
    rdfs:label 'Planned Work Hours' ;
    rdfs:comment 'Total hours the technician was scheduled to work during this shift, excluding breaks. Used for capacity planning and utilization analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this schedule was published to the technician. Marks the transition from draft to active schedule and starts the confirmation window.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleChangeReason rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Reason' ;
    rdfs:comment 'Free-text description of the reason for any schedule modification after initial publication. Captures business context for audit and operational review.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'The calendar date for which this schedule assignment applies. Represents the business day of the scheduled work.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version number of this schedule record. Incremented each time the schedule is modified, supporting change audit trail and historical analysis.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Total duration of the shift in hours, including break time. Standard shifts are typically 8 or 10 hours; on-call shifts may vary.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The precise date and time when the technician\'s shift ends. Used to calculate shift duration and availability windows.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The precise date and time when the technician\'s shift begins. Used for dispatch optimization and field coordination.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workOrderImpactCount rdf:type rdf:Property ;
    rdfs:label 'Work Order Impact Count' ;
    rdfs:comment 'Number of work orders originally assigned to this technician for this shift that were impacted by leave or schedule changes. Used to assess operational disruption.' ;
    rdfs:domain ind:TechnicianSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolCheckoutId rdf:type rdf:Property ;
    rdfs:label 'Tool Checkout Id' ;
    rdfs:comment 'Unique identifier for the tool checkout transaction. Primary key.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryToolEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tool Employee Id' ;
    rdfs:comment 'Unique identifier of the depot supervisor or manager who authorized the tool checkout.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReturnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Return Timestamp' ;
    rdfs:comment 'Actual date and time when the tool was returned to the depot. Nullable if tool has not yet been returned.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calibrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Expiry Date' ;
    rdfs:comment 'Date when the current calibration certificate for the tool expires. Critical for ensuring measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Calibration status of the test equipment at the time of checkout, indicating whether the tool is within its valid calibration period.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Flag' ;
    rdfs:comment 'Indicator of whether the technician\'s required certifications were verified at the time of checkout.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkoutChannel rdf:type rdf:Property ;
    rdfs:label 'Checkout Channel' ;
    rdfs:comment 'Channel or method through which the tool checkout transaction was initiated, such as depot counter, mobile app, or automated kiosk.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutNotes rdf:type rdf:Property ;
    rdfs:label 'Checkout Notes' ;
    rdfs:comment 'Free-text notes or comments recorded at the time of checkout, such as special handling instructions or observed issues.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutNumber rdf:type rdf:Property ;
    rdfs:label 'Checkout Number' ;
    rdfs:comment 'Human-readable business identifier for the tool checkout transaction, used for tracking and reference purposes.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutPurpose rdf:type rdf:Property ;
    rdfs:label 'Checkout Purpose' ;
    rdfs:comment 'Business purpose or reason for checking out the tool, aligned with work order types and field activities.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutStatus rdf:type rdf:Property ;
    rdfs:label 'Checkout Status' ;
    rdfs:comment 'Current lifecycle status of the tool checkout transaction indicating whether the tool is still out, returned, overdue, lost, or damaged.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkout Timestamp' ;
    rdfs:comment 'Date and time when the tool was checked out to the technician. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Detailed description of any damage observed on the tool at return, including severity and affected components. Nullable if no damage reported.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Reported Flag' ;
    rdfs:comment 'Indicator of whether damage to the tool was reported upon return, triggering repair or replacement workflows.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated cost to repair any damage to the tool, used for financial tracking and technician accountability. Nullable if no damage or cost not yet estimated.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Insurance claim reference number if a claim was filed for lost or damaged tool. Nullable if no claim filed.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdueDays rdf:type rdf:Property ;
    rdfs:label 'Overdue Days' ;
    rdfs:comment 'Number of days the tool is overdue past the scheduled return timestamp. Calculated as current date minus scheduled return date for unreturned tools.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementToolAssetCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Tool Asset Code' ;
    rdfs:comment 'Unique identifier of the replacement tool asset issued to the technician. Nullable if no replacement was issued.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementToolIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Tool Issued Flag' ;
    rdfs:comment 'Indicator of whether a replacement tool was issued due to damage, loss, or malfunction of the originally checked-out tool.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnNotes rdf:type rdf:Property ;
    rdfs:label 'Return Notes' ;
    rdfs:comment 'Free-text notes or comments recorded at the time of return, such as condition observations, damage reports, or maintenance needs. Nullable if tool has not yet been returned.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required Flag' ;
    rdfs:comment 'Indicator of whether the tool requires the technician to hold specific safety certifications before checkout is permitted.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledReturnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Return Timestamp' ;
    rdfs:comment 'Expected date and time by which the tool should be returned to the depot.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Date and time when the technician signature was captured at checkout. Nullable if signature was not captured.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicianSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Technician Signature Captured Flag' ;
    rdfs:comment 'Indicator of whether the technician provided a digital or physical signature acknowledging receipt and responsibility for the tool at checkout.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolAssetCode rdf:type rdf:Property ;
    rdfs:label 'Tool Asset Code' ;
    rdfs:comment 'Unique identifier of the specialized test equipment or tool being checked out. References the tool inventory asset.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolCategory rdf:type rdf:Property ;
    rdfs:label 'Tool Category' ;
    rdfs:comment 'High-level classification of the tool type being checked out, such as optical test equipment, cable certifiers, or safety harnesses.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolConditionAtCheckout rdf:type rdf:Property ;
    rdfs:label 'Tool Condition At Checkout' ;
    rdfs:comment 'Physical and operational condition of the tool at the time of checkout, assessed by the depot staff or technician.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolConditionAtReturn rdf:type rdf:Property ;
    rdfs:label 'Tool Condition At Return' ;
    rdfs:comment 'Physical and operational condition of the tool at the time of return, assessed by the depot staff. Nullable if tool has not yet been returned. [ENUM-REF-CANDIDATE: excellent|good|fair|needs_maintenance|defective|damaged|lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolManufacturer rdf:type rdf:Property ;
    rdfs:label 'Tool Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or vendor of the tool, such as EXFO, Fluke, or Corning.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolModelNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Model Number' ;
    rdfs:comment 'Manufacturer model number or designation of the tool, used for identifying specifications and compatibility.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Tool Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the specific tool unit being checked out, used for asset tracking and warranty management.' ;
    rdfs:domain ind:ToolCheckout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Parent Work Order Id' ;
    rdfs:comment 'Reference to the parent work order if this is a follow-up or child work order, enabling tracking of multi-visit resolution chains.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Immediate customer satisfaction rating provided at work completion, typically on a 1-5 scale, used for technician performance evaluation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured' ;
    rdfs:comment 'Boolean indicator whether customer sign-off was obtained via digital signature on the mobile device, confirming work completion and acceptance.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstTimeFixFlag rdf:type rdf:Property ;
    rdfs:label 'First Time Fix Flag' ;
    rdfs:comment 'Boolean indicator whether the work order was completed successfully on the first visit without requiring follow-up, a key operational KPI.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatVisitFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Visit Flag' ;
    rdfs:comment 'Boolean indicator whether this work order is a repeat visit to the same site for the same issue, indicating initial resolution failure.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteLatitude rdf:type rdf:Property ;
    rdfs:label 'Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the work site, used for GPS navigation and route optimization.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteLongitude rdf:type rdf:Property ;
    rdfs:label 'Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the work site, used for GPS navigation and route optimization.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborHours rdf:type rdf:Property ;
    rdfs:label 'Total Labor Hours' ;
    rdfs:comment 'Total hours of labor expended on this work order across all technicians and activities, used for cost allocation and productivity analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Total cost of all materials and parts consumed during work order execution, aggregated from material line items.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally visible business identifier for the work order, used for tracking and reference by field technicians and customers.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order in the field service workflow, from initial creation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|scheduled|dispatched|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order based on the nature of field activity: installation of new service, repair of existing service, preventive maintenance, site survey, network upgrade, or equipment decommissioning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Work Start Timestamp' ;
    rdfs:comment 'Timestamp when the technician began actual field work activities, distinct from arrival time which may include site assessment.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the user or manager who approved this capacity plan.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryWorkforceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Workforce Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this capacity plan record.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesForecastId rdf:type rdf:Property ;
    rdfs:label 'Sales Forecast Id' ;
    rdfs:comment 'Foreign key linking to sales.forecast. Business justification: Workforce capacity planning in telecom uses sales forecasts to project technician headcount needs for installations, maintenance, and service delivery. Critical for aligning operational capacity with ' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:tertiaryWorkforceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this capacity plan record.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attritionRatePct rdf:type rdf:Property ;
    rdfs:label 'Attrition Rate Pct' ;
    rdfs:comment 'Expected workforce attrition rate (as percentage) during the planning period, used to adjust capacity projections.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageWorkOrderDurationHours rdf:type rdf:Property ;
    rdfs:label 'Average Work Order Duration Hours' ;
    rdfs:comment 'Average estimated time (in hours) required to complete a work order for the specified skill category and technology domain.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated for workforce capacity actions (hiring, contractor engagement, training) in the plan currency.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorAugmentationTarget rdf:type rdf:Property ;
    rdfs:label 'Contractor Augmentation Target' ;
    rdfs:comment 'Target number of contractor or temporary workforce members to be engaged to address the capacity gap.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerContractorAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Per Contractor Amount' ;
    rdfs:comment 'Estimated average cost to engage one contractor for the planning period for this skill category.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerHireAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hire Amount' ;
    rdfs:comment 'Estimated average cost to recruit and onboard one new permanent employee for this skill category.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerTrainingAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Per Training Amount' ;
    rdfs:comment 'Estimated average cost to upskill or cross-train one existing workforce member to the required skill category.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of technicians or workforce members available with the required skill category in the specified territory at the time of plan creation.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hiringTarget rdf:type rdf:Property ;
    rdfs:label 'Hiring Target' ;
    rdfs:comment 'Target number of new permanent employees to be hired to address the capacity gap.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the capacity planning period for which workforce requirements are being forecasted.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the capacity planning period for which workforce requirements are being forecasted.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Name of the CAPEX (Capital Expenditure) network build program or initiative driving this capacity requirement (e.g., \'5G NR Metro Expansion\', \'FTTH Rural Broadband Initiative\').' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedDemandHeadcount rdf:type rdf:Property ;
    rdfs:label 'Projected Demand Headcount' ;
    rdfs:comment 'Forecasted number of technicians or workforce members required to meet the anticipated workload during the planning period.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonal Factor' ;
    rdfs:comment 'Multiplier representing seasonal demand variation (e.g., 1.2 for 20% increase during peak season, 0.8 for 20% decrease during off-peak).' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingTarget rdf:type rdf:Property ;
    rdfs:label 'Training Target' ;
    rdfs:comment 'Target number of existing workforce members to be upskilled or cross-trained to meet the required skill category.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Pct' ;
    rdfs:comment 'Target workforce utilization rate (as percentage) representing the planned productive time versus total available time.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderVolumeForecast rdf:type rdf:Property ;
    rdfs:label 'Work Order Volume Forecast' ;
    rdfs:comment 'Projected number of work orders expected during the planning period for the specified territory and skill category.' ;
    rdfs:domain ind:WorkforceCapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workforceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Workforce Certification Id' ;
    rdfs:comment 'Unique identifier for the workforce certification record. Primary key.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Reference to the certification type from the certification catalog. Links to the certification master record defining the qualification type.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:mandatingRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Mandating Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Specific workforce certifications are mandated by regulatory obligations (FCC tower climbing safety certification, state electrical licenses for fiber splicing, OSHA confined space entry certification' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to the scanned certificate document, digital badge, or credential stored in the document management system. Used for audit and verification purposes.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpdHoursEarned rdf:type rdf:Property ;
    rdfs:label 'Cpd Hours Earned' ;
    rdfs:comment 'Number of Continuing Professional Development hours or Continuing Education Units (CEUs) earned through the training or certification process. Used for tracking professional development requirements and renewal eligibility.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized code or abbreviation for the issuing authority. Used for grouping and reporting by certifying body.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to maintain active status. Used for proactive renewal tracking and compliance monitoring.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean indicator of whether this certification is mandated by federal, state, or local regulation (e.g., FCC General Radiotelephone Operator License, OSHA safety certifications). True indicates regulatory requirement; False indicates voluntary or company-preferred certification.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of cost reimbursement to the technician or training provider. Not_applicable indicates company-paid certification; pending indicates reimbursement request submitted; approved indicates reimbursement authorized; reimbursed indicates payment completed; denied indicates reimbursement request rejected.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Work Type Eligibility' ;
    rdfs:comment 'Comma-separated list or coded representation of work order types or service categories that this certification qualifies the technician to perform. Examples include tower_climbing, confined_space_entry, fiber_splicing, RAN_installation, 5G_NR_deployment, FTTH_installation. Used for dispatch eligibility and work assignment rules.' ;
    rdfs:domain ind:WorkforceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Membership Id' ;
    rdfs:comment 'Primary key for customer_segment_membership' ;
    rdfs:domain ind:CustomerSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideByUser rdf:type rdf:Property ;
    rdfs:label 'Override By User' ;
    rdfs:comment 'Username or identifier of the analyst or business user who performed the manual override. Null for automated assignments.' ;
    rdfs:domain ind:CustomerSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipCode rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Code' ;
    rdfs:comment 'Unique identifier for this segment membership record. Primary key.' ;
    rdfs:domain ind:CustomerSegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Device Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this device supply agreement record. Primary key.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryAllocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Quantity' ;
    rdfs:comment 'Committed inventory allocation quantity for this device model from this partner. Represents guaranteed supply capacity under the agreement.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum order quantity (MOQ) required by the partner for this device model. Impacts procurement batch sizing and inventory holding costs.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this partner is the preferred supplier for this device model. Used in procurement routing logic when multiple suppliers are available.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Return Policy Days' ;
    rdfs:comment 'Number of days within which unsold or defective devices can be returned to the partner under this agreement. Varies by partner and device category.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Warranty terms provided by the partner for this device model (e.g., \'12 months parts and labor\', \'24 months manufacturer warranty\'). Impacts customer service commitments.' ;
    rdfs:domain ind:DeviceSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Ott Subscription Id' ;
    rdfs:comment 'Unique identifier for this OTT platform subscription record. Primary key.' ;
    rdfs:domain ind:OttSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlySubscriptionFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Subscription Fee' ;
    rdfs:comment 'Monthly recurring charge for this corporate account\'s subscription to the OTT platform. May be a negotiated enterprise rate different from consumer pricing.' ;
    rdfs:domain ind:OttSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRoamingSessionId rdf:type rdf:Property ;
    rdfs:label 'Service Roaming Session Id' ;
    rdfs:comment 'Primary key for service_roaming_session' ;
    rdfs:domain ind:ServiceRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roamingSessionId rdf:type rdf:Property ;
    rdfs:label 'Roaming Session Id' ;
    rdfs:comment 'Unique identifier for this roaming session record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerRoamingSession .

ind:dataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb' ;
    rdfs:comment 'Total data usage in megabytes during this roaming session. Used for wholesale settlement calculation based on agreement data_mb_rate.' ;
    rdfs:domain ind:ServiceRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudAlertTriggered rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Triggered' ;
    rdfs:comment 'Indicates whether this roaming session triggered fraud detection thresholds defined in the roaming agreement or NRTRDE monitoring.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the roaming session: active (ongoing), completed (ended, awaiting settlement), disputed (settlement dispute raised), settled (invoiced and paid).' ;
    rdfs:domain ind:ServiceRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapRecordReference rdf:type rdf:Property ;
    rdfs:label 'Tap Record Reference' ;
    rdfs:comment 'Reference identifier to the TAP (Transferred Account Procedure) file record generated for this roaming session for inter-operator settlement.' ;
    rdfs:domain ind:ServiceRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceMinutes rdf:type rdf:Property ;
    rdfs:label 'Voice Minutes' ;
    rdfs:comment 'Total voice call minutes during this roaming session. Used for wholesale settlement calculation based on agreement voice_mou_rate.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicianSkillProficiencyId rdf:type rdf:Property ;
    rdfs:label 'Technician Skill Proficiency Id' ;
    rdfs:comment 'Primary key for the technician_skill_proficiency association' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certified By Employee Id' ;
    rdfs:comment 'Employee identifier of the supervisor, trainer, or assessor who certified or evaluated this technician-skill proficiency. Required for certification audit trail.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used to assess or certify this technician-skill proficiency: field evaluation, written exam, practical test, vendor certification, or peer review. Required for audit and compliance tracking.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessedDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessed Date' ;
    rdfs:comment 'Date of the most recent proficiency assessment or evaluation for this technician-skill combination. May differ from certification_date if reassessments occur without level changes.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Current proficiency level for this technician-skill combination: trainee, competent, or expert. Used by dispatch algorithms to match work order complexity with technician capability.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Proficiency Score' ;
    rdfs:comment 'Numeric assessment score (0-100) from the most recent proficiency evaluation for this technician-skill combination. Provides granular capability measurement within proficiency levels.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date when recertification or reassessment is required for this technician-skill combination. Drives training notifications and dispatch eligibility. Calculated from certification_date plus skill validity_period_months.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:yearsExperienceWithSkill rdf:type rdf:Property ;
    rdfs:label 'Years Experience With Skill' ;
    rdfs:comment 'Total years of experience the technician has with this specific skill, including prior employment. Used for seniority-based dispatch prioritization and expert identification.' ;
    rdfs:domain ind:TechnicianSkillProficiency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineupChannelMembershipId rdf:type rdf:Property ;
    rdfs:label 'Lineup Channel Membership Id' ;
    rdfs:comment 'Unique identifier for this channel membership record. Primary key.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Timestamp when this channel was added to this lineup in the system. Supports audit trail of lineup composition changes.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Position Number' ;
    rdfs:comment 'The logical channel number or position where this channel appears within this specific lineup. Same channel may have different positions in different lineups.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHdIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Hd Included' ;
    rdfs:comment 'Indicates whether the HD variant of this channel is included in this lineup. Same channel may be SD in one lineup and HD in another.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremiumTier rdf:type rdf:Property ;
    rdfs:label 'Is Premium Tier' ;
    rdfs:comment 'Indicates whether this channel is included as part of a premium tier within this lineup, potentially requiring additional subscription fees.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licensingNotes rdf:type rdf:Property ;
    rdfs:label 'Licensing Notes' ;
    rdfs:comment 'Free-text notes regarding licensing terms, restrictions, or special conditions for this channel\'s inclusion in this specific lineup.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedDate rdf:type rdf:Property ;
    rdfs:label 'Removed Date' ;
    rdfs:comment 'Timestamp when this channel was removed from this lineup. Null for active memberships.' ;
    rdfs:domain ind:LineupChannelMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique system identifier for this promotional offer redemption record. Primary key.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedToInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Applied To Invoice Id' ;
    rdfs:comment 'Reference to the invoice where this promotional discount was first applied. Supports revenue impact tracking.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:discountAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Applied Amount' ;
    rdfs:comment 'Actual monetary discount amount applied to this customer account for this promotional offer redemption. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Status' ;
    rdfs:comment 'Current status of this specific redemption instance. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeemedByUser rdf:type rdf:Property ;
    rdfs:label 'Redeemed By User' ;
    rdfs:comment 'Username or identifier of the customer service representative or system user who processed the redemption, if applicable.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDealerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Account Dealer Transaction Id' ;
    rdfs:comment 'Primary key uniquely identifying each transaction event between a customer account and a dealer' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Account Customer Account Id' ;
    rdfs:comment 'Foreign key linking to the customer account involved in this dealer transaction' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:activationCount rdf:type rdf:Property ;
    rdfs:label 'Activation Count' ;
    rdfs:comment 'Number of new line activations performed in this transaction - typically 1 for single-line activations, can be multiple for family plans or business account bulk activations' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'System timestamp when this association record was created' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceSaleCount rdf:type rdf:Property ;
    rdfs:label 'Device Sale Count' ;
    rdfs:comment 'Number of devices sold to the customer account in this transaction - used for dealer performance metrics and inventory tracking' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'System timestamp when this association record was last modified' ;
    rdfs:domain ind:AccountDealerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offeringFilingMetricId rdf:type rdf:Property ;
    rdfs:label 'Offering Filing Metric Id' ;
    rdfs:comment 'Unique identifier for this offering-filing metric record. Primary key.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Date when the offering metrics for this filing were prepared and validated.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Reported Revenue Amount' ;
    rdfs:comment 'Revenue amount attributed to this specific offering for the filing period, as reported to the regulatory authority. This is offering-specific revenue within the context of this particular filing.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Reported Subscriber Count' ;
    rdfs:comment 'Number of active subscribers for this offering during the filing period, as reported to the regulatory authority.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedUsageVolume rdf:type rdf:Property ;
    rdfs:label 'Reported Usage Volume' ;
    rdfs:comment 'Aggregated usage volume (data GB, voice minutes, or other usage metric) for this offering during the filing period, as reported to the regulatory authority.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Regulatory revenue classification category for this offering within this filing (e.g., retail_mobile, retail_broadband, wholesale, enterprise, roaming). Required for FCC Form 499 and similar filings.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Service Classification Code' ;
    rdfs:comment 'Regulatory service classification code assigned to this offering for this filing (e.g., FCC service codes, EU service type codes). Classification may vary by filing type and regulatory authority.' ;
    rdfs:domain ind:OfferingFilingMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelOfferingId rdf:type rdf:Property ;
    rdfs:label 'Channel Offering Id' ;
    rdfs:comment 'Unique identifier for this channel-offering assignment record. Primary key.' ;
    rdfs:domain ind:ChannelOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesChannelId rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Id' ;
    rdfs:comment 'Foreign key linking to the sales channel through which this offering is distributed' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:channelOfferingStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Offering Status' ;
    rdfs:comment 'Current operational status of this channel-offering assignment. Values: active (currently selling), pending_launch (configured but not yet live), suspended (temporarily unavailable), discontinued (permanently removed).' ;
    rdfs:domain ind:ChannelOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPriority rdf:type rdf:Property ;
    rdfs:label 'Channel Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) indicating the strategic importance of this offering in this channel\'s portfolio. Used for sales team focus, promotional planning, and inventory allocation decisions.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionOverrideRate rdf:type rdf:Property ;
    rdfs:label 'Commission Override Rate' ;
    rdfs:comment 'Commission rate override specific to this offering-channel combination, expressed as a decimal (e.g., 0.0850 for 8.5%). Overrides the channel\'s default commission_structure_code when set. Nullable if default commission applies.' ;
    rdfs:domain ind:ChannelOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAllocation rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation' ;
    rdfs:comment 'Number of units or subscription slots allocated to this channel for this offering. Relevant for device-included offerings or capacity-constrained services. Nullable for unlimited digital offerings.' ;
    rdfs:domain ind:ChannelOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Customer Subscription Id' ;
    rdfs:comment 'Primary key for customer_subscription' ;
    rdfs:domain ind:CustomerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addonStatus rdf:type rdf:Property ;
    rdfs:label 'Addon Status' ;
    rdfs:comment 'Current lifecycle status of this specific subscriber-addon subscription. Active: in use; Suspended: temporarily disabled; Expired: validity period ended; Cancelled: terminated by user or system; Pending: awaiting activation.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'Prorated charge amount calculated when the add-on is activated or deactivated mid-billing cycle. Null if no proration applies.' ;
    rdfs:domain ind:CustomerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurringCharge rdf:type rdf:Property ;
    rdfs:label 'Recurring Charge' ;
    rdfs:comment 'The actual recurring charge amount applied to this subscriber for this add-on. May differ from the standard add-on price due to promotions, discounts, or subscriber-specific pricing.' ;
    rdfs:domain ind:CustomerSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerRoamingSessionId rdf:type rdf:Property ;
    rdfs:label 'Customer Roaming Session Id' ;
    rdfs:comment 'Primary key for customer_roaming_session' ;
    rdfs:domain ind:CustomerRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataUsageMb rdf:type rdf:Property ;
    rdfs:label 'Data Usage Mb' ;
    rdfs:comment 'Total data volume consumed during this roaming session in megabytes. Used for wholesale billing calculation based on agreement data_mb_rate.' ;
    rdfs:domain ind:CustomerRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roamingCharges rdf:type rdf:Property ;
    rdfs:label 'Roaming Charges' ;
    rdfs:comment 'Total wholesale charges for this roaming session calculated based on usage and agreement rates. Used for settlement and fraud threshold monitoring.' ;
    rdfs:domain ind:CustomerRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyUsed rdf:type rdf:Property ;
    rdfs:label 'Technology Used' ;
    rdfs:comment 'Network technology standard used during this roaming session. Must match one of the technology_standards covered by the agreement.' ;
    rdfs:domain ind:CustomerRoamingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontServiceBindingId rdf:type rdf:Property ;
    rdfs:label 'Ont Service Binding Id' ;
    rdfs:comment 'Unique identifier for this ONT-to-service binding record. Primary key.' ;
    rdfs:domain ind:OntServiceBinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qosProfileId rdf:type rdf:Property ;
    rdfs:label 'Qos Profile Id' ;
    rdfs:comment 'Reference to the QoS profile applied to this specific service-ONT binding. Defines traffic prioritization and bandwidth allocation for this service on this ONT.' ;
    rdfs:domain ind:OntServiceBinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceQosProfile .

ind:bandwidthDownstreamMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Downstream Mbps' ;
    rdfs:comment 'Provisioned downstream bandwidth in megabits per second allocated to this service on this ONT. Configured at binding activation time.' ;
    rdfs:domain ind:OntServiceBinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bandwidthUpstreamMbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Upstream Mbps' ;
    rdfs:comment 'Provisioned upstream bandwidth in megabits per second allocated to this service on this ONT. Configured at binding activation time.' ;
    rdfs:domain ind:OntServiceBinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ontPortAssignment rdf:type rdf:Property ;
    rdfs:label 'Ont Port Assignment' ;
    rdfs:comment 'Specific Ethernet port on the ONT device assigned to this service instance. Relevant for multi-service scenarios where different services use different physical ports.' ;
    rdfs:domain ind:OntServiceBinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addonEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Addon Eligibility Id' ;
    rdfs:comment 'Unique identifier for this eligibility rule. Primary key.' ;
    rdfs:domain ind:AddonEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addonPriceOverride rdf:type rdf:Property ;
    rdfs:label 'Addon Price Override' ;
    rdfs:comment 'Offering-specific price override for this add-on. When populated, overrides the standard price_amount from the addon product. Allows same add-on to have different pricing when attached to different offerings. Explicitly identified in detection phase.' ;
    rdfs:domain ind:AddonEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoAttachFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Attach Flag' ;
    rdfs:comment 'Indicates whether this add-on is automatically attached to customer subscriptions when this offering is purchased. Used for mandatory add-ons or promotional bundles. Explicitly identified in detection phase.' ;
    rdfs:domain ind:AddonEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Sort order for displaying this add-on in the list of available add-ons for this offering in sales channels and self-service portals. Lower numbers appear first.' ;
    rdfs:domain ind:AddonEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxQuantityPerOffering rdf:type rdf:Property ;
    rdfs:label 'Max Quantity Per Offering' ;
    rdfs:comment 'Maximum number of instances of this add-on that can be attached when purchased with this specific offering. May differ from the add-on\'s global max_quantity_per_subscription. Explicitly identified in detection phase.' ;
    rdfs:domain ind:AddonEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAddonSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Service Addon Subscription Id' ;
    rdfs:comment 'Unique identifier for this add-on subscription instance. Primary key.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalOverride rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Override' ;
    rdfs:comment 'Subscription-level override for the add-on\'s default auto-renewal behavior. Allows per-subscription control of renewal even when the add-on product has auto-renewal enabled by default.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Start Date' ;
    rdfs:comment 'Date when billing commenced for this add-on subscription. May differ from activation_date if trial period or promotional delay applies.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastBillingDate rdf:type rdf:Property ;
    rdfs:label 'Last Billing Date' ;
    rdfs:comment 'Most recent date when this add-on subscription was billed. Used for billing cycle tracking and revenue recognition.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Scheduled date for the next billing cycle for this add-on subscription. Null for one-time add-ons or deactivated subscriptions.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceOverride rdf:type rdf:Property ;
    rdfs:label 'Price Override' ;
    rdfs:comment 'Custom pricing amount for this specific add-on subscription, overriding the standard catalog price. Used for negotiated enterprise pricing, promotional discounts, or volume-based pricing adjustments. Null if standard catalog pricing applies.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date when technical provisioning of the add-on was completed on the managed service infrastructure. Used for SLA tracking and operational reporting.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Flag' ;
    rdfs:comment 'Indicates whether this add-on subscription is currently in a free trial period. When true, billing is suspended until trial expiration.' ;
    rdfs:domain ind:ServiceAddonSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractBillingArrangementId rdf:type rdf:Property ;
    rdfs:label 'Contract Billing Arrangement Id' ;
    rdfs:comment 'Unique identifier for this contract-billing account arrangement record' ;
    rdfs:domain ind:ContractBillingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrangementType rdf:type rdf:Property ;
    rdfs:label 'Arrangement Type' ;
    rdfs:comment 'Classification of how this billing account relates to the contract: primary (main billing account), secondary (additional account), split_billing (charges split across accounts), consolidated (receives consolidated invoice), cost_center (departmental billing)' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Billing Allocation Percentage' ;
    rdfs:comment 'For split billing arrangements, the percentage of contract charges allocated to this billing account (e.g., 60.00 means 60% of charges go to this account, 40% to another)' ;
    rdfs:domain ind:ContractBillingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceFormatOverride rdf:type rdf:Property ;
    rdfs:label 'Invoice Format Override' ;
    rdfs:comment 'Contract-specific invoice format that overrides the billing account default for this contract\'s charges (e.g., detailed_itemized, summary, regulatory_format)' ;
    rdfs:domain ind:ContractBillingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsOverride rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Override' ;
    rdfs:comment 'Contract-specific payment terms that override the billing account default payment terms for charges originating from this contract (e.g., net_45 instead of account default net_30)' ;
    rdfs:domain ind:ContractBillingArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Billing Subscription Id' ;
    rdfs:comment 'Primary key for billing_subscription' ;
    rdfs:domain ind:BillingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingSubscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Subscription Status' ;
    rdfs:comment 'Current lifecycle state of this subscription: active (content accessible), suspended (temporarily disabled), cancelled (terminated by customer), pending_activation (ordered but not yet provisioned), trial (in trial period), expired (end_date passed). Explicitly identified in detection phase as subscription_status.' ;
    rdfs:domain ind:BillingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Commitment End Date' ;
    rdfs:comment 'Date on which the minimum commitment period for this subscription ends. Early cancellation before this date may incur early termination fees.' ;
    rdfs:domain ind:BillingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date on which this subscription is scheduled for its next automatic renewal. Null if auto_renewal_flag is False or subscription is cancelled.' ;
    rdfs:domain ind:BillingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Id' ;
    rdfs:comment 'Unique identifier for this budget allocation record. Primary key.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual expenditure posted against this specific allocation as of the last update. Enables zone-level budget vs. actual tracking.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Budget Amount' ;
    rdfs:comment 'The specific monetary amount allocated from the budget plan to this network rollout zone. Represents the financial commitment for this zone from this plan.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the master service agreement or specific contract under which this bundle subscription is governed. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Telecommunication .

ind:bundleQuantity rdf:type rdf:Property ;
    rdfs:label 'Bundle Quantity' ;
    rdfs:comment 'Number of bundle instances subscribed by the corporate account. Explicitly identified in detection phase relationship data. Relevant for enterprise accounts with multiple locations or departments.' ;
    rdfs:domain ind:BundleSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountApplied rdf:type rdf:Property ;
    rdfs:label 'Discount Applied' ;
    rdfs:comment 'Monetary discount amount applied to this specific subscription, which may differ from the standard bundle discount due to enterprise negotiation. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BundleSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this bundle subscription is set to auto-renew at contract term expiration. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Date when this bundle subscription ended or is scheduled to end. Null for active ongoing subscriptions. Supports historical tracking of subscription lifecycle.' ;
    rdfs:domain ind:BundleSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Date when this bundle subscription was activated for the corporate account. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BundleSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bundleChannelInclusionId rdf:type rdf:Property ;
    rdfs:label 'Bundle Channel Inclusion Id' ;
    rdfs:comment 'Unique identifier for this bundle-channel inclusion record. Primary key.' ;
    rdfs:domain ind:BundleChannelInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalCharge rdf:type rdf:Property ;
    rdfs:label 'Additional Charge' ;
    rdfs:comment 'Additional monthly charge for this channel within this bundle, if applicable. Used when a channel incurs an extra fee beyond the base bundle price (e.g., premium sports channels).' ;
    rdfs:domain ind:BundleChannelInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPosition rdf:type rdf:Property ;
    rdfs:label 'Channel Position' ;
    rdfs:comment 'The display position or sequence order of this channel within the bundle\'s channel lineup. Used for EPG presentation and channel ordering specific to this bundle.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOptional rdf:type rdf:Property ;
    rdfs:label 'Is Optional' ;
    rdfs:comment 'Indicates whether this channel is optional (can be added/removed by customer) or mandatory (always included) within this bundle. Supports flexible and customizable bundle configurations.' ;
    rdfs:domain ind:BundleChannelInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremiumChannel rdf:type rdf:Property ;
    rdfs:label 'Is Premium Channel' ;
    rdfs:comment 'Indicates whether this channel is treated as a premium channel within this specific bundle, potentially requiring additional entitlement or incurring additional charges. A channel may be premium in one bundle but included in another.' ;
    rdfs:domain ind:BundleChannelInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundlePromotionId rdf:type rdf:Property ;
    rdfs:label 'Bundle Promotion Id' ;
    rdfs:comment 'Unique identifier for this bundle-promotion eligibility record. Primary key.' ;
    rdfs:domain ind:BundlePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalBundlePrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Bundle Price' ;
    rdfs:comment 'Special price for this bundle when this specific promotion is applied. Overrides the standard bundle_price_amount from the bundle master record for promotional periods.' ;
    rdfs:domain ind:BundlePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit' ;
    rdfs:comment 'Maximum number of times this promotion can be redeemed specifically for this bundle. Allows bundle-level inventory or capacity constraints separate from the promotion\'s overall redemption_limit_total.' ;
    rdfs:domain ind:BundlePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeProjectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Finance Project Assignment Id' ;
    rdfs:comment 'Primary key for finance_project_assignment' ;
    rdfs:domain ind:FinanceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Project Assignment Id' ;
    rdfs:comment 'Unique identifier for the project assignment record. Primary key for the association.' ;
    rdfs:domain ind:FinanceProjectAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total actual hours the employee has worked on the capital project to date. Accumulated from time tracking systems. Used for labor cost actuals, project progress measurement, and variance analysis against planned effort.' ;
    rdfs:domain ind:FinanceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableRate rdf:type rdf:Property ;
    rdfs:label 'Billable Rate' ;
    rdfs:comment 'Hourly or daily rate at which the employee\'s time is charged to the capital project budget. May differ from base salary due to overhead allocation, benefits loading, or project-specific rate structures. Used for project cost tracking and labor capitalization calculations.' ;
    rdfs:domain ind:FinanceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The functional role or capacity in which the employee is assigned to the capital project. Determines responsibilities, approval authority, and labor cost classification for capitalization.' ;
    rdfs:domain ind:FinanceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productChannelLineupId rdf:type rdf:Property ;
    rdfs:label 'Product Channel Lineup Id' ;
    rdfs:comment 'Primary key for product_channel_lineup' ;
    rdfs:domain ind:ProductChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelLineupId rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Id' ;
    rdfs:comment 'Unique identifier for this package-channel lineup configuration record. Primary key.' ;
    rdfs:domain ind:ProductChannelLineup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentChannelLineup .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current operational status of this channel inclusion in this package. Active=currently available to subscribers, Pending=scheduled for future activation, Suspended=temporarily unavailable, Removed=permanently removed from lineup.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this channel is promoted as a featured or highlighted channel in marketing materials for this specific package. A channel may be featured in one package but not in another.' ;
    rdfs:domain ind:ProductChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagePlatformInclusionId rdf:type rdf:Property ;
    rdfs:label 'Package Platform Inclusion Id' ;
    rdfs:comment 'Unique identifier for this package-platform inclusion record. Primary key.' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoProvisionEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Provision Enabled' ;
    rdfs:comment 'Indicates whether this platform should be automatically provisioned when a subscriber activates the package (true) or requires manual activation (false). Supports opt-in vs. auto-include business rules.' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryPlatform rdf:type rdf:Property ;
    rdfs:label 'Is Primary Platform' ;
    rdfs:comment 'Indicates whether this OTT platform is the primary or featured platform in the package for marketing and UI presentation purposes. Typically one primary platform per package.' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ottPlatformsIncluded rdf:type rdf:Property ;
    rdfs:label 'Ott Platforms Included' ;
    rdfs:comment 'Comma-separated list of OTT streaming platform names or identifiers included in this package (e.g., \'Netflix, Disney+, HBO Max\'). Empty if no OTT platforms are bundled. [Moved from content_package: This comma-separated list attribute in content_package is a denormalized representation of the M:N relationship. The actual platform inclusions should be managed as individual records in the package_platform_inclusion association, which provides proper normalization, supports relationship-specific attributes (priority, dates, revenue share), and enables historical tracking. The ott_platforms_included attribute becomes a derived/cached field or should be removed entirely in favor of querying the association table.]' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Platform Display Order' ;
    rdfs:comment 'Numeric order for displaying this platform in the package description, marketing materials, and subscriber portal. Lower numbers display first.' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:provisioningPriority rdf:type rdf:Property ;
    rdfs:label 'Provisioning Priority' ;
    rdfs:comment 'Numeric priority order for provisioning this platform when a subscriber activates the package. Lower numbers provision first. Used for dependency management (e.g., SSO platform must provision before dependent platforms).' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueShareOverride rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Override' ;
    rdfs:comment 'Package-specific revenue share percentage override for this platform inclusion. Overrides the default revenue_share_percentage from the ott_platform master when this platform is sold as part of this specific package. Null means use default from platform record.' ;
    rdfs:domain ind:PackagePlatformInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAccountCoverageId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Coverage Id' ;
    rdfs:comment 'Primary key for customer_account_coverage' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCoverageCode rdf:type rdf:Property ;
    rdfs:label 'Account Coverage Code' ;
    rdfs:comment 'Unique identifier for this account coverage assignment record. Primary key.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Split Percentage' ;
    rdfs:comment 'Percentage of commission this employee receives for sales to this corporate hierarchy node when multiple employees share coverage. Sum across all employees for a node may equal 100% or vary based on compensation plan.' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Coverage Flag' ;
    rdfs:comment 'Indicates whether this employee is the primary point of contact for this corporate hierarchy node. Used when multiple employees have coverage roles.' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaAllocation rdf:type rdf:Property ;
    rdfs:label 'Quota Allocation' ;
    rdfs:comment 'Revenue or unit quota allocated to this employee for this specific corporate hierarchy node. Used for performance measurement and compensation calculation.' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'The specific sales or account management role the employee performs for this corporate hierarchy node. Determines responsibilities and authority level.' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or vertical territory designation for this coverage assignment. Used for territory planning and conflict resolution.' ;
    rdfs:domain ind:CustomerAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementOutageImpactId rdf:type rdf:Property ;
    rdfs:label 'Element Outage Impact Id' ;
    rdfs:comment 'Unique identifier for this element-outage impact record. Primary key for the association.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedNetworkElementIds rdf:type rdf:Property ;
    rdfs:label 'Affected Network Element Ids' ;
    rdfs:comment 'Comma-separated list of network element identifiers (RAN, core, transport, GPON, MPLS, SD-WAN, NFV/SDN nodes, OLT, ONT, DSLAM, BNG, BRAS, POP sites) impacted by this planned outage. [Moved from planned_outage: This comma-separated STRING field is a poor implementation of the M:N relationship. It should be replaced by proper foreign key relationships in the element_outage_impact association table, enabling relational queries, referential integrity, and granular element-level tracking.]' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementActualDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Element Actual Downtime Minutes' ;
    rdfs:comment 'Calculated duration in minutes that this specific network element was out of service, derived from element_downtime_start and element_downtime_end. Used for per-element SLA impact calculation and network availability reporting.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:elementDowntimeEnd rdf:type rdf:Property ;
    rdfs:label 'Element Downtime End' ;
    rdfs:comment 'Actual timestamp when this specific network element was restored to service during the planned outage. May differ from the overall outage end time as elements are restored sequentially or may require additional validation time.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:elementDowntimeStart rdf:type rdf:Property ;
    rdfs:label 'Element Downtime Start' ;
    rdfs:comment 'Actual timestamp when this specific network element was taken out of service during the planned outage. May differ from the overall outage start time as elements are often taken down sequentially.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:elementSpecificImpactSeverity rdf:type rdf:Property ;
    rdfs:label 'Element Specific Impact Severity' ;
    rdfs:comment 'Impact severity classification specific to this network element within the broader planned outage. While the outage may have an overall severity, individual elements may experience different impact levels based on redundancy, traffic load, and criticality.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Element Validation Status' ;
    rdfs:comment 'Post-maintenance validation status for this specific network element indicating whether the element passed operational validation tests after the outage work was completed. Critical for ensuring element health before returning to full service.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Element Validation Timestamp' ;
    rdfs:comment 'Timestamp when validation testing was completed for this network element post-outage.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:elementWorkNotes rdf:type rdf:Property ;
    rdfs:label 'Element Work Notes' ;
    rdfs:comment 'Detailed notes documenting element-specific work performed, issues encountered, or observations made during the planned outage for this particular network element.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackExecutedForElement rdf:type rdf:Property ;
    rdfs:label 'Rollback Executed For Element' ;
    rdfs:comment 'Boolean indicator whether the rollback procedure was executed specifically for this network element. In complex outages, some elements may require rollback while others complete successfully.' ;
    rdfs:domain ind:ElementOutageImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:circuitCapacityGbps rdf:type rdf:Property ;
    rdfs:label 'Circuit Capacity Gbps' ;
    rdfs:comment 'Allocated transmission capacity in gigabits per second for this lease agreement. Represents the bandwidth or fiber count allocated to the carrier. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:FiberLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiberCountAllocated rdf:type rdf:Property ;
    rdfs:label 'Fiber Count Allocated' ;
    rdfs:comment 'Number of individual fiber strands allocated to the carrier under this lease agreement. Relevant for dark fiber and IRU agreements.' ;
    rdfs:domain ind:FiberLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle status of the lease agreement. Active indicates live service, pending indicates contract signed but not yet provisioned.' ;
    rdfs:domain ind:FiberLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEquipmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Service Equipment Assignment Id' ;
    rdfs:comment 'Unique identifier for this service equipment assignment record. Primary key.' ;
    rdfs:domain ind:ServiceEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Flag' ;
    rdfs:comment 'Boolean indicator: TRUE if this equipment is designated as primary for the service, FALSE if backup or secondary' ;
    rdfs:domain ind:ServiceEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleInService rdf:type rdf:Property ;
    rdfs:label 'Role In Service' ;
    rdfs:comment 'Functional role this equipment plays in delivering the managed service: PRIMARY (main active equipment), BACKUP (hot standby for failover), LOAD_BALANCED (active-active traffic sharing), STANDBY (cold spare), FAILOVER (automatic switchover target)' ;
    rdfs:domain ind:ServiceEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Percentage' ;
    rdfs:comment 'Percentage of service traffic routed through this equipment in load-balanced configurations. Range 0.00-100.00. Sum across all active equipment for a service should equal 100.' ;
    rdfs:domain ind:ServiceEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sliceVnfAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Slice Vnf Assignment Id' ;
    rdfs:comment 'Unique identifier for this VNF-to-slice assignment record. Primary key.' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceSlaProfileId rdf:type rdf:Property ;
    rdfs:label 'Performance Sla Profile Id' ;
    rdfs:comment 'Reference to the SLA profile governing this VNF\'s performance requirements within this slice. Different slices may impose different SLA requirements on the same VNF.' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaProfile .

ind:amfInstanceIds rdf:type rdf:Property ;
    rdfs:label 'Amf Instance Ids' ;
    rdfs:comment 'Comma-separated list of AMF network function instance identifiers assigned to serve this slice. AMF handles registration, connection, and mobility management. [Moved from network_slice: This comma-separated list attribute is a poor implementation of the M:N relationship between network slices and VNF instances. The specific AMF instances assigned to a slice should be tracked in the slice_vnf_assignment association with proper role, resource allocation, and configuration attributes.]' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Resource Allocation Percentage' ;
    rdfs:comment 'Percentage of the VNF\'s total compute/network resources allocated to serving this specific slice. Enables resource sharing and isolation tracking across slices.' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sliceSpecificConfigParameters rdf:type rdf:Property ;
    rdfs:label 'Slice Specific Config Parameters' ;
    rdfs:comment 'JSON or XML configuration parameters specific to this VNF\'s operation within this slice. Includes slice-specific QoS policies, routing rules, security policies, and performance thresholds that differ from the VNF\'s base configuration.' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smfInstanceIds rdf:type rdf:Property ;
    rdfs:label 'Smf Instance Ids' ;
    rdfs:comment 'Comma-separated list of SMF network function instance identifiers assigned to serve this slice. SMF manages PDU sessions and UPF selection. [Moved from network_slice: This comma-separated list attribute is a poor implementation of the M:N relationship between network slices and VNF instances. The specific SMF instances assigned to a slice should be tracked in the slice_vnf_assignment association with proper role, resource allocation, and configuration attributes.]' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfInstanceIds rdf:type rdf:Property ;
    rdfs:label 'Upf Instance Ids' ;
    rdfs:comment 'Comma-separated list of UPF network function instance identifiers assigned to serve this slice. UPF handles packet routing, forwarding, and QoS enforcement. [Moved from network_slice: This comma-separated list attribute is a poor implementation of the M:N relationship between network slices and VNF instances. The specific UPF instances assigned to a slice should be tracked in the slice_vnf_assignment association with proper role, resource allocation, and configuration attributes.]' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vnfRoleInSlice rdf:type rdf:Property ;
    rdfs:label 'Vnf Role In Slice' ;
    rdfs:comment 'The specific network function role this VNF performs within the slice context (e.g., AMF, SMF, UPF). A single VNF instance may serve different roles or priorities across multiple slices.' ;
    rdfs:domain ind:SliceVnfAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringPlatformBundleId rdf:type rdf:Property ;
    rdfs:label 'Offering Platform Bundle Id' ;
    rdfs:comment 'Unique identifier for this offering-platform bundling relationship. Primary key.' ;
    rdfs:domain ind:OfferingPlatformBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current operational status of this offering-platform bundle. Active=available for new subscriptions, Suspended=temporarily unavailable, Deprecated=no longer offered but existing subscriptions continue, Pending-Approval=awaiting commercial or technical approval.' ;
    rdfs:domain ind:OfferingPlatformBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalMonthlyCharge rdf:type rdf:Property ;
    rdfs:label 'Incremental Monthly Charge' ;
    rdfs:comment 'Additional monthly charge to the customer for including this OTT platform in the offering, beyond the base offering price. Zero if the platform is included at no extra cost.' ;
    rdfs:domain ind:OfferingPlatformBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Trial Duration Months' ;
    rdfs:comment 'Number of months of free or promotional trial access to the OTT platform included with this offering. Null if no trial period applies.' ;
    rdfs:domain ind:OfferingPlatformBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colocationId rdf:type rdf:Property ;
    rdfs:label 'Colocation Id' ;
    rdfs:comment 'Unique identifier for this colocation agreement record. Primary key.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Physical access rights granted to the partner for this facility. Determines whether partner technicians can enter unescorted, require escort, or must use remote hands service.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitCount rdf:type rdf:Property ;
    rdfs:label 'Circuit Count' ;
    rdfs:comment 'Number of network circuits or cross-connects provisioned for the partner at this facility. Used for capacity planning and billing.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colocationStatus rdf:type rdf:Property ;
    rdfs:label 'Colocation Status' ;
    rdfs:comment 'Current lifecycle status of the colocation arrangement. Active indicates equipment is installed and operational.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyColocationFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Colocation Fee' ;
    rdfs:comment 'Recurring monthly fee charged to the partner for colocation services at this facility. Typically based on rack space, power allocation, and service tier.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerAllocationKw rdf:type rdf:Property ;
    rdfs:label 'Power Allocation Kw' ;
    rdfs:comment 'Electrical power capacity allocated to the partner for their equipment in this facility, measured in kilowatts. Part of the colocation SLA and billing calculation.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackSpaceAllocatedUnits rdf:type rdf:Property ;
    rdfs:label 'Rack Space Allocated Units' ;
    rdfs:comment 'Number of rack units (RU) allocated to the partner within this facility. Typically measured in standard 19-inch rack units where 1U = 1.75 inches.' ;
    rdfs:domain ind:Colocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPromotionEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Channel Promotion Eligibility Id' ;
    rdfs:comment 'Unique identifier for this channel-promotion eligibility configuration record. Primary key.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configuredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Configured By Employee Id' ;
    rdfs:comment 'User ID of the marketing operations or sales operations employee who configured this channel-promotion eligibility record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'User ID of the employee who last modified this eligibility configuration. Used for change tracking and audit trail.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:channelEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Channel Effective End Date' ;
    rdfs:comment 'Date when this promotion expires and is no longer available for redemption in this specific channel. May differ from the promotion\'s global end_date to support early termination or extended availability in specific channels.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Channel Effective Start Date' ;
    rdfs:comment 'Date when this promotion becomes available for redemption in this specific channel. May differ from the promotion\'s global start_date to support phased rollouts or channel-specific launch timing.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelEligibility rdf:type rdf:Property ;
    rdfs:label 'Channel Eligibility' ;
    rdfs:comment 'Comma-separated list of sales channels where this promotion can be applied (e.g., \'web\', \'mobile_app\', \'retail_store\', \'telesales\', \'dealer\', \'all_channels\'). Used to control distribution and prevent unauthorized channel usage. [Moved from promotion: The channel_eligibility attribute in promotion is a comma-separated list attempting to denormalize the many-to-many relationship. With the proper association table, this attribute becomes redundant - channel eligibility is now represented by the existence of records in channel_promotion_eligibility. This eliminates data duplication and allows proper tracking of channel-specific configuration (dates, limits, terms) that cannot be captured in a simple comma-separated list.]' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelInventoryLimit rdf:type rdf:Property ;
    rdfs:label 'Channel Inventory Limit' ;
    rdfs:comment 'Maximum number of times this promotion can be redeemed through this specific channel. Null indicates no channel-specific limit (subject to promotion\'s global redemption_limit_total). Used to allocate promotion inventory across channels and prevent over-redemption in any single channel.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Channel Redemption Count' ;
    rdfs:comment 'Current count of how many times this promotion has been redeemed through this specific channel. Incremented with each redemption transaction. Used to enforce channel_inventory_limit and track channel-level promotion performance.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelSpecificTerms rdf:type rdf:Property ;
    rdfs:label 'Channel Specific Terms' ;
    rdfs:comment 'Additional terms, conditions, or business rules that apply to this promotion when redeemed through this specific channel. For example, \'Requires in-store device trade-in\' for retail channels, or \'Online exclusive - no phone orders\' for digital channels. Supplements the promotion\'s global terms_and_conditions.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configuredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Configured Timestamp' ;
    rdfs:comment 'Timestamp when this channel-promotion eligibility record was first created. Used for audit trail and historical analysis of promotion rollout timing.' ;
    rdfs:domain ind:ChannelPromotionEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current operational status of this promotion\'s eligibility in this channel: active (available for redemption), suspended (temporarily disabled by ops team), expired (past channel_effective_end_date), pending (configured but not yet effective). Allows channel-specific promotion control independent of global promotion status.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellSliceAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Cell Slice Assignment Id' ;
    rdfs:comment 'Unique identifier for this cell-slice assignment record. Primary key.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admissionControlThreshold rdf:type rdf:Property ;
    rdfs:label 'Admission Control Threshold' ;
    rdfs:comment 'Maximum number of User Equipment (UE) connections allowed for this slice on this specific cell. Used for admission control to prevent slice oversubscription at the cell level.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedPrbPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocated Prb Percentage' ;
    rdfs:comment 'Percentage of the cell\'s Physical Resource Blocks (PRBs) allocated to this network slice. Defines the radio resource share for this slice on this cell. Range: 0.00-100.00.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellSliceActivationStatus rdf:type rdf:Property ;
    rdfs:label 'Cell Slice Activation Status' ;
    rdfs:comment 'Current operational status of this slice on this specific cell. Indicates whether the cell is actively serving traffic for this slice. Values: active, inactive, suspended, testing, decommissioned.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Status' ;
    rdfs:comment 'Current SLA compliance status for this slice on this cell. Indicates whether the cell is meeting the slice SLA requirements (latency, throughput, reliability). Values: compliant, degraded, violated, not_measured.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slicePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Slice Priority Level' ;
    rdfs:comment 'Priority level for this slice on this cell, used for resource arbitration and preemption decisions when multiple slices compete for resources. Lower values indicate higher priority.' ;
    rdfs:domain ind:CellSliceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratePlanContentPackageId rdf:type rdf:Property ;
    rdfs:label 'Rate Plan Content Package Id' ;
    rdfs:comment 'Unique identifier for this rate plan content package association record' ;
    rdfs:domain ind:RatePlanContentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associationStatus rdf:type rdf:Property ;
    rdfs:label 'Association Status' ;
    rdfs:comment 'Current lifecycle status of this rate plan content package association: active (available for provisioning), inactive (temporarily unavailable), pending (scheduled for future activation), discontinued (no longer offered)' ;
    rdfs:domain ind:RatePlanContentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Bundle Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the content package monthly recurring charge when bundled with this specific rate plan (e.g., 15.00 = 15% discount)' ;
    rdfs:domain ind:RatePlanContentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIncludedInBase rdf:type rdf:Property ;
    rdfs:label 'Is Included In Base' ;
    rdfs:comment 'Indicates whether this content package is included in the base recurring charge of the rate plan (true) or requires an additional charge (false)' ;
    rdfs:domain ind:RatePlanContentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalRate rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate' ;
    rdfs:comment 'Special promotional monthly recurring charge for this content package when bundled with this rate plan. Null if standard pricing applies.' ;
    rdfs:domain ind:RatePlanContentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateRatePlanAgreementId rdf:type rdf:Property ;
    rdfs:label 'Corporate Rate Plan Agreement Id' ;
    rdfs:comment 'Unique identifier for this corporate rate plan agreement record' ;
    rdfs:domain ind:CorporateRatePlanAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentTermMonths rdf:type rdf:Property ;
    rdfs:label 'Commitment Term Months' ;
    rdfs:comment 'Duration in months of the commitment period for this rate plan agreement, determining contract lock-in and early termination penalties. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CorporateRatePlanAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percentage' ;
    rdfs:comment 'Custom discount percentage negotiated for this corporate account on this rate plan, applied on top of the standard rate plan pricing. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:CorporateRatePlanAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageObligationId rdf:type rdf:Property ;
    rdfs:label 'Coverage Obligation Id' ;
    rdfs:comment 'Primary key for the coverage_obligation association' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name or identifier of the individual, team, or third-party auditor who conducted the last compliance assessment for this obligation-area pair.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The deadline by which this coverage area must achieve compliance with this regulatory obligation. May differ from the obligation\'s general effective date based on phased rollout requirements or area-specific build-out schedules.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceGapPercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Gap Percentage' ;
    rdfs:comment 'The difference between required and actual coverage percentage (required minus actual). Positive values indicate non-compliance. Used for prioritizing remediation efforts and regulatory reporting.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePercentageActual rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage Actual' ;
    rdfs:comment 'The actual coverage percentage achieved in this coverage area as measured against this regulatory obligation\'s requirements. Updated based on drive tests, propagation models, or crowdsourced data. Used to calculate compliance gap.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePercentageRequired rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage Required' ;
    rdfs:comment 'The minimum coverage percentage required by this regulatory obligation for this specific coverage area. Expressed as a percentage (0-100). May vary by area based on regulatory classification (urban, rural, tribal, etc.).' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent compliance assessment or audit conducted for this obligation-area combination. Used to track assessment frequency and identify areas requiring re-assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'The scheduled date for the next compliance assessment or verification activity for this obligation-area pair. Calculated based on the obligation\'s compliance frequency and last assessment date.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Reference' ;
    rdfs:comment 'Reference identifier to the remediation plan, capital project, or network expansion initiative addressing any compliance gap in this obligation-area combination. Null if compliant or no plan exists.' ;
    rdfs:domain ind:CoverageObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountObligationId rdf:type rdf:Property ;
    rdfs:label 'Account Obligation Id' ;
    rdfs:comment 'Unique identifier for this account-obligation compliance relationship record. Primary key.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Applicability Determination Date' ;
    rdfs:comment 'Date when it was determined that this regulatory obligation applies to this corporate account, based on services contracted, jurisdictions served, or industry vertical.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicabilityReason rdf:type rdf:Property ;
    rdfs:label 'Applicability Reason' ;
    rdfs:comment 'Business reason why this obligation applies to this account. Examples: \'Account operates in California - CCPA applies\', \'Account uses POTS services - CALEA applies\', \'Government account - FedRAMP required\'.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Repository Reference' ;
    rdfs:comment 'Reference identifier, URL, or file path to the repository location where compliance evidence, audit trails, and certification documents for this account-obligation combination are stored.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditFinding rdf:type rdf:Property ;
    rdfs:label 'Last Audit Finding' ;
    rdfs:comment 'Summary of the most recent audit or assessment finding for this account\'s compliance with this obligation. Captures issues identified, corrective actions required, or clean audit confirmation.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Next scheduled date by which this corporate account must demonstrate compliance, submit filings, or complete certification for this specific obligation. Account-specific deadline tracking. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer' ;
    rdfs:comment 'Name or identifier of the compliance officer, account manager, or business unit representative responsible for ensuring this corporate account\'s compliance with this specific obligation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:AccountObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Unique identifier for this promotion redemption event. Primary key.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applying Employee Id' ;
    rdfs:comment 'Employee ID of the sales representative or dealer who applied this promotion to the subscriber\'s account. Null for self-service redemptions.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit End Date' ;
    rdfs:comment 'Date when the promotional benefit expires for this subscriber. For time-limited offers (e.g., 50% off for 6 months), marks the end of the discounted period. Null for one-time discounts.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Start Date' ;
    rdfs:comment 'Date when the promotional benefit begins for this subscriber. For recurring discounts (e.g., 3 months free), marks the start of the benefit period.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Discount Amount Applied' ;
    rdfs:comment 'Actual monetary discount amount applied to this specific subscriber\'s transaction as a result of this promotion redemption. May differ from promotion.discount_value due to stacking rules, minimum purchase requirements, or percentage calculations.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteReference rdf:type rdf:Property ;
    rdfs:label 'Quote Reference' ;
    rdfs:comment 'Reference to the sales quote or order where this promotion was applied. Links the redemption to the specific sales transaction.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Unique identifier for this service visit record. Primary key.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Present Flag' ;
    rdfs:comment 'Indicates whether customer or authorized representative was present during the visit. Required for certain work types.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours spent by the technician on this service visit. Used for workforce productivity analysis and cost allocation. Identified in detection phase.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Used Flag' ;
    rdfs:comment 'Indicates whether inventory parts were consumed during this visit. Triggers inventory replenishment workflows.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether this visit met the committed SLA timeframe. Feeds into technician and service performance dashboards.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'Date when the service visit occurred. Corresponds to service_visit_date from detection phase.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the service visit purpose: installation (new service activation), maintenance (preventive), repair (reactive fault resolution), upgrade (service enhancement), troubleshooting (diagnostic), or decommission (service termination). Identified in detection phase.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Free-text description of the work performed during this visit. Captured by technician in field service app. Identified in detection phase.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Service Line Id' ;
    rdfs:comment 'Unique identifier for this contract service line record. Primary key.' ;
    rdfs:domain ind:ContractServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing End Date' ;
    rdfs:comment 'Date when billing ended or is scheduled to end for this service under this contract. Null for active ongoing services. Populated when service is terminated, migrated to another contract, or contract expires.' ;
    rdfs:domain ind:ContractServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workforceProjectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Workforce Project Assignment Id' ;
    rdfs:comment 'Primary key for workforce_project_assignment' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes about the assignment, including special requirements, constraints, or context relevant to this technician-project pairing.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursActual rdf:type rdf:Property ;
    rdfs:label 'Hours Actual' ;
    rdfs:comment 'Actual hours worked by the technician on this capital project. Used for labor cost accounting and project financial tracking.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Hours Allocated' ;
    rdfs:comment 'Total hours allocated or planned for this technician on this capital project. Used for resource capacity planning and utilization tracking.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Hourly labor rate for this technician on this specific project. May vary by project type, role, or contract terms. Critical for project cost accounting and CAPEX tracking.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the labor rate. Typically matches the project budget currency.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleOnProject rdf:type rdf:Property ;
    rdfs:label 'Role On Project' ;
    rdfs:comment 'Role or function the technician performs on this specific capital project (e.g., Lead Technician, Crew Member, Specialist). Determines responsibility level and may affect labor rate.' ;
    rdfs:domain ind:WorkforceProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Technician Kpi Target Id' ;
    rdfs:comment 'Unique identifier for this technician-KPI target assignment record. Primary key.' ;
    rdfs:domain ind:TechnicianKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievementStatus rdf:type rdf:Property ;
    rdfs:label 'Achievement Status' ;
    rdfs:comment 'The achievement status of this target for this technician at period end.' ;
    rdfs:domain ind:TechnicianKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'The supervisor or manager who assigned this target to this technician.' ;
    rdfs:domain ind:TechnicianKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessId rdf:type rdf:Property ;
    rdfs:label 'Site Access Id' ;
    rdfs:comment 'Unique identifier for this site access authorization record. Primary key.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Access Badge Number' ;
    rdfs:comment 'Physical or electronic badge number issued for site access. Corresponds to access_badge_number from detection data. Used for physical security and entry logging.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessStatus rdf:type rdf:Property ;
    rdfs:label 'Access Status' ;
    rdfs:comment 'Current lifecycle status of the site access authorization indicating whether the technician can currently access the site.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedDate rdf:type rdf:Property ;
    rdfs:label 'Granted Date' ;
    rdfs:comment 'Date when site access authorization was granted to the technician. Corresponds to site_access_granted_date from detection data.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastServiceVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Visit Date' ;
    rdfs:comment 'Date of the most recent field technician visit to this site for installation, maintenance, or troubleshooting. [Moved from site: This attribute currently exists on the site product but actually represents the most recent visit by ANY technician. In the M:N model, last_site_visit_date in the site_access association tracks visits per technician-site combination, providing more granular operational data. The site-level attribute may be retained as a denormalized summary or removed in favor of deriving it from the association.]' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSiteVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Site Visit Date' ;
    rdfs:comment 'Date of the most recent visit by this technician to this site. Used for access review and credential renewal decisions.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySiteContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Site Contact Flag' ;
    rdfs:comment 'Indicates whether this technician is designated as the primary contact for this site. Corresponds to primary_site_contact_flag from detection data. Used for escalations and site relationship management.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when site access was revoked, if applicable. Used for security audit and compliance tracking.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteTrainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Site Training Completed Flag' ;
    rdfs:comment 'Indicates whether the technician has completed site-specific safety and access training requirements. Corresponds to site_training_completed_flag from detection data. Required before first site visit.' ;
    rdfs:domain ind:SiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountTeamAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Account Team Assignment Id' ;
    rdfs:comment 'Unique identifier for this account team assignment record. Primary key.' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Account Team Members' ;
    rdfs:comment 'Comma-separated list or JSON array of team member IDs or names who are part of the extended account team (sales engineers, solution architects, customer success managers). [Moved from b2b_account_plan: This comma-separated list or JSON array in b2b_account_plan is a denormalized representation of the many-to-many relationship. The proper model is individual assignment records with role, dates, and coverage percentage. This attribute should be removed and replaced by queries against the account_team_assignment association.]' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when this employee\'s assignment to this account plan team ended or is planned to end. Null for active assignments. Used for tracking team changes and historical coverage.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date when this employee began their assignment to this account plan team. Used for tracking team tenure and transition history.' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'The percentage of this employee\'s time allocated to this account plan. Used for capacity planning and workload balancing. Sum across all account plans for an employee should not exceed 100%.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryOwner rdf:type rdf:Property ;
    rdfs:label 'Is Primary Owner' ;
    rdfs:comment 'Indicates whether this team member is the primary owner/lead for this account plan. Typically true for the Account Executive role. Used for routing, escalation, and accountability.' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibilityScope rdf:type rdf:Property ;
    rdfs:label 'Responsibility Scope' ;
    rdfs:comment 'Detailed description of this team member\'s specific responsibilities within the account plan. May include geographic coverage, product line focus, business unit alignment, or specific initiative ownership.' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamRole rdf:type rdf:Property ;
    rdfs:label 'Team Role' ;
    rdfs:comment 'The specific role this employee plays on the account team. Defines responsibilities and engagement model. Examples: Account Executive (owns relationship), Solutions Architect (designs technical solutions), Customer Success Manager (post-sale adoption), Technical Specialist (product expertise).' ;
    rdfs:domain ind:AccountTeamAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetApprovalId rdf:type rdf:Property ;
    rdfs:label 'Budget Approval Id' ;
    rdfs:comment 'Unique identifier for this budget approval record. Primary key.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delegatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delegated By Employee Id' ;
    rdfs:comment 'Reference to the employee who delegated approval authority to this approver. Null if not delegated.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the approver explaining their decision or requesting clarifications.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'The maximum budget amount this employee can approve in their assigned role. Role-specific authority limit for financial controls.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalSequence rdf:type rdf:Property ;
    rdfs:label 'Approval Sequence' ;
    rdfs:comment 'The sequential order of this approval in the workflow (1=first approver, 2=second approver, etc.). Enforces approval hierarchy.' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delegationFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Flag' ;
    rdfs:comment 'Indicates whether this approval was delegated to this employee by another approver (true) or is their direct responsibility (false).' ;
    rdfs:domain ind:BudgetApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogRoamingEnablementId rdf:type rdf:Property ;
    rdfs:label 'Catalog Roaming Enablement Id' ;
    rdfs:comment 'Unique surrogate identifier for this catalog item to carrier agreement enablement record. Primary key.' ;
    rdfs:domain ind:CatalogRoamingEnablement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enablementStatus rdf:type rdf:Property ;
    rdfs:label 'Enablement Status' ;
    rdfs:comment 'Current operational status of this catalog item enablement through this carrier agreement. ACTIVE = live and routing traffic; SUSPENDED = temporarily disabled due to commercial dispute or technical issue; PENDING_ACTIVATION = configured but not yet live; DEPRECATED = end-of-life, no new subscriptions.' ;
    rdfs:domain ind:CatalogRoamingEnablement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequirementId rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement Id' ;
    rdfs:comment 'Unique identifier for this product-skill requirement record. Primary key.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proficiencyLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level Required' ;
    rdfs:comment 'Minimum proficiency level required for this catalog item: trainee, competent, or expert. Determines which technicians can be dispatched to work orders for this product. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillRequirementStatus rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement Status' ;
    rdfs:comment 'Lifecycle status of this product-skill requirement: active (currently enforced), deprecated (being phased out), obsolete (no longer applicable). Tracks evolution of skill requirements as products and technologies change.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'Estimated training hours required for a technician to achieve the required proficiency level for this specific catalog item. Used for workforce training planning and capacity modeling. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderPhaseApplicability rdf:type rdf:Property ;
    rdfs:label 'Work Order Phase Applicability' ;
    rdfs:comment 'Comma-separated list of work order phases where this skill is required: installation, provisioning, configuration, maintenance, troubleshooting, decommissioning. Enables phase-specific skill matching in Granite WFM dispatch.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Segment Eligibility Id' ;
    rdfs:comment 'Unique identifier for this product-segment eligibility record. Primary key.' ;
    rdfs:domain ind:SegmentEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRuleTestId rdf:type rdf:Property ;
    rdfs:label 'Audit Rule Test Id' ;
    rdfs:comment 'Unique identifier for this audit rule test record. Primary key.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Threshold Percentage' ;
    rdfs:comment 'The actual pass rate percentage achieved when this rule was tested during the audit. Compared against the rule\'s defined threshold_percentage to determine pass/fail status.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Free-text observations and commentary from the auditor regarding the testing of this rule, including context for findings, remediation recommendations, or mitigating factors.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributesToNonconformityFlag rdf:type rdf:Property ;
    rdfs:label 'Contributes To Nonconformity Flag' ;
    rdfs:comment 'Indicates whether the failure of this rule test contributed to a major or minor nonconformity finding in the overall audit outcome.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'The number of violations or non-conformities identified when testing this rule during the audit. Zero indicates full compliance.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'The outcome of testing this rule during the audit. Indicates whether the rule met its threshold and compliance requirements. Corresponds to rule_pass_fail_status from detection phase.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'The date when this rule was retested after corrective actions were implemented. Null if no retest was required or has not yet occurred.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Required Flag' ;
    rdfs:comment 'Indicates whether this rule must be retested as part of corrective action verification or follow-up audit activities.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date when this specific DQ rule was tested during the audit engagement. Corresponds to audit_test_date from detection phase.' ;
    rdfs:domain ind:AuditRuleTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'The methodology used by auditors to test this rule during the audit engagement.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageLineupInclusionId rdf:type rdf:Property ;
    rdfs:label 'Package Lineup Inclusion Id' ;
    rdfs:comment 'Unique identifier for this package-lineup inclusion relationship. Primary key.' ;
    rdfs:domain ind:PackageLineupInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPackageId rdf:type rdf:Property ;
    rdfs:label 'Content Package Id' ;
    rdfs:comment 'Foreign key to the content package that includes this lineup' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:isPrimaryLineup rdf:type rdf:Property ;
    rdfs:label 'Is Primary Lineup' ;
    rdfs:comment 'Indicates whether this is the primary or featured channel lineup for this package (true) or a secondary/add-on lineup (false). Used for marketing presentation and default provisioning logic.' ;
    rdfs:domain ind:PackageLineupInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineupDisplayPriority rdf:type rdf:Property ;
    rdfs:label 'Lineup Display Priority' ;
    rdfs:comment 'Marketing display priority for this lineup within the package composition. Used to determine prominence in package descriptions and subscriber-facing interfaces.' ;
    rdfs:domain ind:PackageLineupInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageTerritoryAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Package Territory Availability Id' ;
    rdfs:comment 'Unique identifier for this package-territory availability configuration. Primary key.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee or system user who last modified this configuration record. Used for audit and accountability.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contentLicensingNotes rdf:type rdf:Property ;
    rdfs:label 'Content Licensing Notes' ;
    rdfs:comment 'Free-text notes regarding territory-specific content licensing restrictions, blackout periods, or special conditions that apply to this package in this territory. Used to document regulatory or contractual constraints.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Code' ;
    rdfs:comment 'Reference identifier for the specific promotional campaign governing this package-territory offering. Null if promotional_flag is False. Links to marketing campaign management systems.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Restrictions' ;
    rdfs:comment 'Comma-separated list of sales channels through which this package may be sold in this territory (e.g., online, retail, telesales, partner). Null indicates no restrictions. Used for territory-specific distribution strategies.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Territory Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the territory_monthly_charge. May differ from the package\'s base currency_code for international territories.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryMonthlyCharge rdf:type rdf:Property ;
    rdfs:label 'Territory Monthly Charge' ;
    rdfs:comment 'Monthly recurring charge for this content package in this specific territory, potentially overriding the package\'s base monthly_recurring_charge to reflect regional pricing. Null indicates use of base package pricing.' ;
    rdfs:domain ind:PackageTerritoryAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enterpriseAccountCoverageId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Account Coverage Id' ;
    rdfs:comment 'Primary key for enterprise_account_coverage' ;
    rdfs:domain ind:EnterpriseAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountRole rdf:type rdf:Property ;
    rdfs:label 'Account Role' ;
    rdfs:comment 'The specific role this employee plays in covering this corporate account. Defines responsibilities and engagement model. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:EnterpriseAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this employee is the primary owner/contact for this corporate account in their role. Used for routing and escalation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:EnterpriseAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Allocation Percentage' ;
    rdfs:comment 'Percentage of this employee\'s sales quota allocated to this corporate account. Used for compensation calculations and performance tracking. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:EnterpriseAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Territory Coverage' ;
    rdfs:comment 'Geographic or organizational territory scope for this coverage assignment (e.g., EMEA, North America East, Federal). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:EnterpriseAccountCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResponseRate rdf:type rdf:Property ;
    rdfs:label 'Actual Response Rate' ;
    rdfs:comment 'Measured percentage of target audience that responded.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Total amount actually spent on the campaign to date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Category of marketing objective the campaign addresses.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerAcquisition rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acquisition' ;
    rdfs:comment 'Average cost incurred to acquire a single customer through the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Free-form narrative describing the campaign details and creative theme.' ;
    rdfs:domain ind:Telecommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResponseRate rdf:type rdf:Property ;
    rdfs:label 'Expected Response Rate' ;
    rdfs:comment 'Projected percentage of target audience expected to respond.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyPerMonth rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Month' ;
    rdfs:comment 'Number of times the campaign is executed each month.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
