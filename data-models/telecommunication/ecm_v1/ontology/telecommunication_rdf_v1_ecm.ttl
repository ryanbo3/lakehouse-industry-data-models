ind:carrierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Agreement Id' ;
    rdfs:comment 'Foreign key linking to interconnect.carrier_agreement. Business justification: IoT deployments requiring global connectivity leverage roaming agreements for international coverage. Business need: linking enterprise IoT deployments to underlying roaming agreements for cost alloca' ;
    rdfs:domain ind:Telecommunication ;
